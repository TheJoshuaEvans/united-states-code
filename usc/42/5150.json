{"tag":"section","attrib":{"id":"idbd0f99b4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5150"},"text":null,"children":[{"tag":"num","attrib":{"value":"5150"},"text":"§ 5150.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of local firms and individuals","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd0f99b5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5150/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contracts or agreements with private entities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd0f99b6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5150/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the expenditure of Federal funds for debris clearance, distribution of supplies, reconstruction, and other major disaster or emergency assistance activities which may be carried out by contract or agreement with private organizations, firms, or individuals, preference shall be given, to the extent feasible and practicable, to those organizations, firms, and individuals residing or doing business primarily in the area affected by such major disaster or emergency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd0f99b7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5150/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This subsection shall not be considered to restrict the use of Department of Defense resources under this chapter in the provision of assistance in a major disaster.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd0f99b8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5150/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specific geographic area","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out this section, a contract or agreement may be set aside for award based on a specific geographic area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd0f99b9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5150/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd0f99ba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5150/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contracts not to entities in area","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any expenditure of Federal funds for debris clearance, distribution of supplies, reconstruction, and other major disaster or emergency assistance activities which may be carried out by contract or agreement with private organizations, firms, or individuals, not awarded to an organization, firm, or individual residing or doing business primarily in the area affected by such major disaster shall be justified in writing in the contract file.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd0f99bb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5150/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Following the declaration of an emergency or major disaster, an agency performing response, relief, and reconstruction activities shall transition work performed under contracts in effect on the date on which the President declares the emergency or major disaster to organizations, firms, and individuals residing or doing business primarily in any area affected by the major disaster or emergency, unless the head of such agency determines that it is not feasible or practicable to do so.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd0f99bc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5150/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Formulation of requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The head of a Federal agency, as feasible and practicable, shall formulate appropriate requirements to facilitate compliance with this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd0f99bd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5150/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prior contracts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed to require any Federal agency to breach or renegotiate any contract in effect before the occurrence of a major disaster or emergency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd0f99be-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/288/tIII/s307"},"text":"Pub. L. 93–288, title III, § 307","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/295/tVI/s694"},"text":"Pub. L. 109–295, title VI, § 694","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-04"},"text":"Oct. 4, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1459"},"text":"120 Stat. 1459","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/347/tVI/s611"},"text":"Pub. L. 109–347, title VI, § 611","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-13"},"text":"Oct. 13, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1943"},"text":"120 Stat. 1943","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd0f99bf-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd0f99c0-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbd0f99c1-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (a)(2), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/288"},"text":"Pub. L. 93–288","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-05-22"},"text":"May 22, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/143"},"text":"88 Stat. 143","children":[],"tail":". For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5121"},"text":"section 5121 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbd0f99c2-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 5150, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/288/tIII/s307"},"text":"Pub. L. 93–288, title III, § 307","children":[],"tail":", formerly § 310, "},{"tag":"date","attrib":{"date":"1974-05-22"},"text":"May 22, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/150"},"text":"88 Stat. 150","children":[],"tail":"; renumbered § 307 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/707/tI/s105/e"},"text":"Pub. L. 100–707, title I, § 105(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-23"},"text":"Nov. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4691"},"text":"102 Stat. 4691","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/218/s2"},"text":"Pub. L. 109–218, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-04-20"},"text":"Apr. 20, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/333"},"text":"120 Stat. 333","children":[],"tail":", provided for the use of local firms and individuals for major disaster or emergency assistance activities, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/109/295/tVI/s694"},"text":"Pub. L. 109–295, title VI, § 694","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-04"},"text":"Oct. 4, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1459"},"text":"120 Stat. 1459","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/288/s307"},"text":"section 307 of Pub. L. 93–288","children":[],"tail":" was renumbered section 304 by "},{"tag":"ref","attrib":{"href":"/us/pl/100/707"},"text":"Pub. L. 100–707","children":[],"tail":" and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5147"},"text":"section 5147 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd0f99c3-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/347"},"text":"Pub. L. 109–347","children":[],"tail":" added par. (3)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
