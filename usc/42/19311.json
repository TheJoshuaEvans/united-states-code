{"tag":"section","attrib":{"id":"idc08b7937-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19311"},"text":null,"children":[{"tag":"num","attrib":{"value":"19311"},"text":"§ 19311.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lab-Embedded Entrepreneurship Program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc08b7938-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19311/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall competitively award grants to National Laboratories for the purpose of establishing or supporting Lab-Embedded Entrepreneurship Programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc08b7939-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19311/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The purposes of such programs are to provide entrepreneurial fellows with access to National Laboratory research facilities, National Laboratory expertise, and mentorship to perform research and development and gain expertise that may be required or beneficial for the commercial application of research ideas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc08b793a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19311/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Entrepreneurial fellows","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An entrepreneurial fellow participating in a program described in subsection (a) shall be provided with—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc08b793b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19311/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" opportunities for entrepreneurial training, professional development, and exposure to leaders from academia, industry, government, and finance who may serve as advisors to or partners of the fellow;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc08b793c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19311/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" financial and technical support for research, development, and commercial application activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc08b793d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19311/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fellowship awards to cover costs of living, health insurance, and travel stipends for the duration of the fellowship; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc08b793e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19311/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other resources determined appropriate by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc08b793f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19311/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each National Laboratory that receives funding under this section shall support entrepreneurial fellows by providing—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc08b7940-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19311/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" access to facilities and expertise within the National Laboratory;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc08b7941-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19311/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" engagement with external stakeholders; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc08b7942-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19311/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" market and customer development opportunities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc08b7943-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19311/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"National Laboratories that receive grants under this section shall prioritize the support and success of the entrepreneurial fellow with regards to professional development and development of a relevant technology.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc08b7944-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19311/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Partnerships","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out a Lab-Embedded Entrepreneurship Program, a National Laboratory may partner with an external entity, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc08b7945-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19311/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a nonprofit organization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc08b7946-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19311/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an institution of higher education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc08b7947-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19311/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a federally-owned corporation; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc08b7948-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19311/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a consortium of 2 or more entities described in paragraphs (1) through (3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc08b7949-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19311/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Metrics","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall support the development of short-term and long-term metrics to assess the effectiveness of programs receiving a grant under subsection (a) in achieving the purposes of the program in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc08b794a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19311/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16391a"},"text":"section 16391a of this title","children":[],"tail":", the Secretary shall submit to the Committee on Science, Space, and Technology of the House of Representatives and the Committee on Energy and Natural Resources of the Senate an evaluation of the effectiveness of the programs under subsection (a) based on the metrics developed pursuant to subsection (g)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc08b794b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19311/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall oversee the planning and coordination of grants under subsection (a) and shall identify and disseminate best practices for achieving the purposes of subsection (a) to National Laboratories that receive grants under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc08b794c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19311/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interagency collaboration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall collaborate with other executive branch agencies, including the Department of Defense and other agencies with Federal laboratories, regarding opportunities to partner with National Laboratories receiving a grant under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc08b794d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19311/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to the Secretary to carry out the activities authorized in this section $25,000,000 for each of fiscal years 2023 through 2027.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc08b794e-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/tVI/s10717"},"text":"Pub. L. 117–167, div. B, title VI, § 10717","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1704"},"text":"136 Stat. 1704","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
