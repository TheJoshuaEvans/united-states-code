{"tag":"section","attrib":{"id":"idbb96dc48-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862u"},"text":null,"children":[{"tag":"num","attrib":{"value":"1862u"},"text":"§ 1862u.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" NSF support of research on opioid addiction","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Director of the National Science Foundation, in consultation with the Director of the National Institutes of Health, shall support merit-reviewed and competitively awarded research on the science of opioid addiction.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbb96dc49-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/335/s2"},"text":"Pub. L. 116–335, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-13"},"text":"Jan. 13, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/5117"},"text":"134 Stat. 5117","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbb96dc4a-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbb96dc4b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbb96dc4c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Expanding Findings for Federal Opioid Research and Treatment Act, also known as the EFFORT Act, and not as part of the National Science Foundation Act of 1950 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbb96dc4d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbb96dc4e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Findings","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/335/s1/b"},"text":"Pub. L. 116–335, § 1(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-13"},"text":"Jan. 13, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/5117"},"text":"134 Stat. 5117","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/335/s1/b"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The Congress finds that—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" research gaps currently exist in the prevention and treatment of opioid addiction;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Science Foundation’s research on opioid addiction has increased understanding of the neuroscience of addiction, substance abuse intervention, the role of illicit supply networks, the secondary effects on families, the use of technology to address the opioid epidemic, and options for alternative, non-addictive therapeutics for pain; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Science Foundation and the National Institutes of Health have recognized that fundamental questions in basic, clinical, and translational research would benefit greatly from multidisciplinary approaches and collaboration.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
