{"tag":"section","attrib":{"id":"idc08b792b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19303"},"text":null,"children":[{"tag":"num","attrib":{"value":"19303"},"text":"§ 19303.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Clean energy technology transfer coordination","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc08b792c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19303/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, acting through the Chief Commercialization Officer established in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16391/a"},"text":"section 16391(a) of this title","children":[],"tail":", shall support the coordination of relevant technology transfer programs that advance the commercial application of clean energy technologies nationally and across all energy sectors. In particular, the Secretary may support activities to—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc08b792d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19303/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitate the sharing of information on best practices for successful operation of clean energy technology transfer programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc08b792e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19303/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate resources and improve cooperation among clean energy technology transfer programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc08b792f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19303/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitate connections between entrepreneurs and start-up companies and the variety of programs related to clean energy technology transfer under the Department; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc08b7930-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19303/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" facilitate the development of metrics to measure the impact of clean energy technology transfer programs on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc08b7931-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19303/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advancing the development, demonstration, and commercial application of clean energy technologies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc08b7932-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19303/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increasing the competitiveness of United States in the clean energy sector, including in manufacturing; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc08b7933-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19303/a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" commercial application of clean energy technologies being developed by entrepreneurs from under-represented backgrounds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc08b7934-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19303/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to the Secretary to carry out the activities in this section $3,000,000 for each of fiscal years 2023 through 2027.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc08b7935-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/tVI/s10715"},"text":"Pub. L. 117–167, div. B, title VI, § 10715","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1703"},"text":"136 Stat. 1703","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
