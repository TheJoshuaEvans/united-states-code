/s325/b"},"text":"Pub. L. 104–193, § 325(b)","children":[],"tail":", added subsec. (h)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb7b9537a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb7b9537b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2014 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/183/tIII/s306/b"},"text":"Pub. L. 113–183, title III, § 306(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-09-29"},"text":"Sept. 29, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1949"},"text":"128 Stat. 1949","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/113/183/tIII/s306/b"},"text":"“The amendments made by subsection (a) [amending this section] shall take effect on ","children":[{"tag":"date","attrib":{"date":"2015-10-01"},"text":"October 1, 2015","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb7b9537c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1997 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34"},"text":"Pub. L. 105–34","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1998-10-01"},"text":"Oct. 1, 1998","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/34/s1090/a/4"},"text":"section 1090(a)(4) of Pub. L. 105–34","children":[],"tail":", set