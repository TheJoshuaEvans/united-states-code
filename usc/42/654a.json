{"tag":"section","attrib":{"id":"idb7b6e242-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s654a"},"text":null,"children":[{"tag":"num","attrib":{"value":"654a"},"text":"§ 654a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Automated data processing","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb7b6e243-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s654a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order for a State to meet the requirements of this section, the State agency administering the State program under this part shall have in operation a single statewide automated data processing and information retrieval system which has the capability to perform the tasks specified in this section with the frequency and in the manner required by or under this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7b6e244-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s654a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program management","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The automated system required by this section shall perform such functions as the Secretary may specify relating to management of the State program under this part, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7b6e245-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s654a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" controlling and accounting for use of Federal, State, and local funds in carrying out the program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7b6e246-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s654a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintaining the data necessary to meet Federal reporting requirements under this part on a timely basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7b6e247-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s654a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Calculation of performance indicators","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In order to enable the Secretary to determine the incentive payments and penalty adjustments required by sections 652(g) and 658a of this title, the State agency shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7b6e248-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s654a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" use the automated system—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb7b6e249-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s654a/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to maintain the requisite data on State performance with respect to paternity establishment and child support enforcement in the State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7b6e24a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s654a/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to calculate the paternity establishment percentage for the State for each fiscal year; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7b6e24b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s654a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have in place systems controls to ensure the completeness and reliability of, and ready access to, the data described in paragraph (1)(A), and the accuracy of the calculations described in paragraph (1)(B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7b6e24c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s654a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information integrity and security","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The State agency shall have in effect safeguards on the integrity, accuracy, and completeness of, access to, and use of data in the automated system required by this section, which shall include the following (in addition to such other safeguards as the Secretary may specify in regulations):","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7b6e24d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s654a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Policies restricting access","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Written policies concerning access to data by State agency personnel, and sharing of data with other persons, which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb7b6e24e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s654a/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" permit access to and use of data only to the extent necessary to carry out the State program under this part; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7b6e24f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s654a/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specify the data which may be used for particular program purposes, and the personnel permitted access to such data.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7b6e250-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s654a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Systems controls","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Systems controls (such as passwords or blocking of fields) to ensure strict adherence to the policies described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7b6e251-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s654a/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Monitoring of access","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Routine monitoring of access to and use of the automated system, through methods such as audit trails and feedback mechanisms, to guard against and promptly identify unauthorized access or use.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7b95352-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s654a/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training and information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Procedures to ensure that all personnel (including State and local agency staff and contractors) who may have access to or be required to use confidential program data are informed of applicable requirements and penalties (including those in section 6103 of the Internal Revenue Code of 1986), and are adequately trained in security procedures.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7b95353-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s654a/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Administrative penalties (up to and including dismissal from employment) for unauthorized access to, or disclosure or use of, confidential data.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7b95354-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s654a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State case registry","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7b95355-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s654a/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The automated system required by this section shall include a registry (which shall be known as the “State case registry”) that contains records with respect to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb7b95356-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s654a/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each case in which services are being provided by the State agency under the State plan approved under this part; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7b95357-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s654a/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each support order established or modified in the State on or after ","children":[{"tag":"date","attrib":{"date":"1998-10-01"},"text":"October 1, 1998","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7b95358-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s654a/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Linking of local registries","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The State case registry may be established by linking local case registries of support orders through an automated information network, subject to this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7b95359-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s654a/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of standardized data elements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Such records shall use standardized data elements for both parents (such as names, social security numbers and other uniform identification numbers, dates of birth, and case identification numbers), and contain such other information (such as on case status) as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7b9535a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s654a/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment records","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each case record in the State case registry with respect to which services are being provided under the State plan approved under this part and with respect to which a support order has been established shall include a record of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb7b9535b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s654a/e/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of monthly (or other periodic) support owed under the order, and other amounts (including arrearages, interest or late payment penalties, and fees) due or overdue under the order;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7b9535c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s654a/e/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any amount described in subparagraph (A) that has been collected;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7b9535d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s654a/e/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the distribution of such collected amounts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7b9535e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s654a/e/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the birth date and, beginning not later than ","children":[{"tag":"date","attrib":{"date":"1999-10-01"},"text":"October 1, 1999","children":[],"tail":", the social security number, of any child for whom the order requires the provision of support; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7b9535f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s654a/e/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of any lien imposed with respect to the order pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s666/a/4"},"text":"section 666(a)(4) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7b95360-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s654a/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Updating and monitoring","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The State agency operating the automated system required by this section shall promptly establish and update, maintain, and regularly monitor, case records in the State case registry with respect to which services are being provided under the State plan approved under this part, on the basis of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb7b95361-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s654a/e/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information on administrative actions and administrative and judicial proceedings and orders relating to paternity and support;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7b95362-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s654a/e/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information obtained from comparison with Federal, State, or local sources of information;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7b95363-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s654a/e/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information on support collections and distributions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7b95364-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s654a/e/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other relevant information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7b95365-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s654a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information comparisons and other disclosures of information","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The State shall use the automated system required by this section to extract information from (at such times, and in such standardized format or formats, as may be required by the Secretary), to share and compare information with, and to receive information from, other data bases and information comparison services, in order to obtain (or provide) information necessary to enable the State agency (or the Secretary or other State or Federal agencies) to carry out this part, subject to section 6103 of the Internal Revenue Code of 1986. Such information comparison activities shall include the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7b95366-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s654a/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal Case Registry of Child Support Orders","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Furnishing to the Federal Case Registry of Child Support Orders established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s653/h"},"text":"section 653(h) of this title","children":[],"tail":" (and update as necessary, with information including notice of expiration of orders) the minimum amount of information on child support cases recorded in the State case registry that is necessary to operate the registry (as specified by the Secretary in regulations)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7b95367-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s654a/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal Parent Locator Service","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Exchanging information with the Federal Parent Locator Service for the purposes specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s653"},"text":"section 653 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7b95368-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s654a/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Temporary family assistance and medicaid agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Exchanging information with State agencies (of the State and of other States) administering programs funded under part A, programs operated under a State plan approved under subchapter XIX, and other programs designated by the Secretary, as necessary to perform State agency responsibilities under this part and under such programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7b95369-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s654a/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Intrastate and interstate information comparisons","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Exchanging information with other agencies of the State, agencies of other States, and interstate information networks, as necessary and appropriate to carry out (or assist other States to carry out) the purposes of this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7b9536a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s654a/f/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Private industry councils receiving welfare-to-work grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Disclosing to a private industry council (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s603/a/5/D/ii"},"text":"section 603(a)(5)(D)(ii) of this title","children":[],"tail":") to which funds are provided under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s603/a/5"},"text":"section 603(a)(5) of this title","children":[],"tail":" the names, addresses, telephone numbers, and identifying case number information in the State program funded under part A, of noncustodial parents residing in the service delivery area of the private industry council, for the purpose of identifying and contacting noncustodial parents regarding participation in the program under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s603/a/5"},"text":"section 603(a)(5) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7b9536b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s654a/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collection and distribution of support payments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7b9536c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s654a/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The State shall use the automated system required by this section to assist and facilitate the collection and disbursement of support payments through the State disbursement unit operated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s654b"},"text":"section 654b of this title","children":[],"tail":", through the performance of functions, including, at a minimum—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb7b9536d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s654a/g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" transmission of orders and notices to employers (and other debtors) for the withholding of income—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb7b9536e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s654a/g/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" within 2 business days after receipt of notice of, and the income source subject to, such withholding from a court, another State, an employer, the Federal Parent Locator Service, or another source recognized by the State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb7b9536f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s654a/g/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" using uniform formats prescribed by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb7b95370-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s654a/g/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at the option of the employer, using the electronic transmission methods prescribed by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7b95371-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s654a/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ongoing monitoring to promptly identify failures to make timely payment of support; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7b95372-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s654a/g/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" automatic use of enforcement procedures (including procedures authorized pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s666/c"},"text":"section 666(c) of this title","children":[],"tail":") if payments are not timely made."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7b95373-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s654a/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Business day” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As used in paragraph (1), the term “business day” means a day on which State offices are open for regular business.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7b95374-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s654a/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expedited administrative procedures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The automated system required by this section shall be used, to the maximum extent feasible, to implement the expedited administrative procedures required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s666/c"},"text":"section 666(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb7b95375-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title IV, § 454A, as added and amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/193/tIII"},"text":"Pub. L. 104–193, title III","child