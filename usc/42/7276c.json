{"tag":"section","attrib":{"id":"idbe0088ae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7276c"},"text":null,"children":[{"tag":"num","attrib":{"value":"7276c"},"text":"§ 7276c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Miscellaneous provisions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbe0088af-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7276c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Environmental impact statement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provisions of the National Environmental Policy Act of 1969 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"42 U.S.C. 4321","children":[],"tail":" et seq.] shall apply to actions of the Administrator implementing sections 7275 to 7276c of this title in the same manner and to the same extent as such provisions apply to other major Federal actions significantly affecting the quality of the human environment."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe0088b0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7276c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall include in the annual report submitted by the Western Area Power Administration (1) a description of the activities undertaken by the Administrator and by customers under sections 7275 to 7276c of this title and (2) an estimate of the energy savings and renewable resource benefits achieved as a result of such activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe0088b1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7276c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State regulated investor-owned utilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any State regulated electric utility (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s2602/18"},"text":"section 2602(18) of title 16","children":[],"tail":") shall be exempt from the provisions of sections 7275 to 7276c of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe0088b2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7276c/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rural Electrification Administration requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in sections 7275 to 7276c of this title shall require a customer to take any action inconsistent with a requirement imposed by the Rural Electrification Administration ","children":[{"tag":"ref","attrib":{"idref":"fn003573"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003573"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be followed by a period."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbe0088b3-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/381/tII/s205"},"text":"Pub. L. 98–381, title II, § 205","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/486/tI/s114"},"text":"Pub. L. 102–486, title I, § 114","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2803"},"text":"106 Stat. 2803","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbe0088b4-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbe0088b5-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbe0088b6-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The National Environmental Policy Act of 1969, referred to in subsec. (a), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/190"},"text":"Pub. L. 91–190","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-01-01"},"text":"Jan. 1, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/852"},"text":"83 Stat. 852","children":[],"tail":", which is classified generally to chapter 55 (§ 4321 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"section 4321 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbe0088b7-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Hoover Power Plant Act of 1984, and not as part of the Department of Energy Organization Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
