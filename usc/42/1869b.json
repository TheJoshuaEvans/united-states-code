{"tag":"section","attrib":{"id":"idbb994ce3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1869b"},"text":null,"children":[{"tag":"num","attrib":{"value":"1869b"},"text":"§ 1869b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Issuance of instructions to grantees of pre-college curriculum projects","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The National Science Foundation is directed to issue instructions to grantees for pre-college curriculum projects covering the protection of pre-college students and procedures for involving such students in pre-college education research and development, pilot-testing, evaluation, and revision of experimental and innovative pre-college curriculum projects funded by the Foundation. These instructions shall require such grantees to obtain written approval of the school board or comparable authority responsible for the schools prior to the involvement of such students.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbb994ce4-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/99/s8"},"text":"Pub. L. 95–99, § 8","children":[],"tail":", formerly § 9, "},{"tag":"date","attrib":{"date":"1977-08-15"},"text":"Aug. 15, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/833"},"text":"91 Stat. 833","children":[],"tail":"; renumbered § 8, "},{"tag":"ref","attrib":{"href":"/us/pl/99/159/tI/s109/h"},"text":"Pub. L. 99–159, title I, § 109(h)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-11-22"},"text":"Nov. 22, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/890"},"text":"99 Stat. 890","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbb994ce5-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbb994ce6-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbb994ce7-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of the National Science Foundation Act of 1950 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
