{"tag":"section","attrib":{"id":"idb6136be7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–6"},"text":null,"children":[{"tag":"num","attrib":{"value":"300d–6"},"text":"§ 300d–6.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Competitive grants for trauma centers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb6136be8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–6/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Assistant Secretary for Preparedness and Response, shall award not fewer than 4 multiyear contracts or competitive grants to eligible entities to support pilot projects to design, implement, and evaluate new or existing innovative models of regionalized, comprehensive, and accountable emergency medical and trauma systems, and improve access to trauma care within such systems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6136be9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–6/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entity; region","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6136bea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–6/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible entity” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6136beb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–6/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State or consortia of States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6136bec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–6/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an Indian Tribe or Tribal organization (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304"},"text":"section 5304 of title 25","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6136bed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–6/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a consortium of level I, II, or III trauma centers designated by applicable State or local agencies within an applicable State or region, and, as applicable, other emergency services providers; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6136bee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–6/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a consortium or partnership of nonprofit Indian Health Service, Indian Tribal, and urban Indian trauma centers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6136bef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–6/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Region","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “region” means an area within a State, an area that lies within multiple States, or a similar area (such as a multicounty area), as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6136bf0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–6/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emergency services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “emergency services” includes acute, prehospital, and trauma care.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6136bf1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–6/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pilot projects","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall award a contract or grant under subsection (a) to an eligible entity to design, implement, and evaluate a new or existing emergency medical and trauma system. Such eligible entity shall use amounts awarded under this subsection to carry out 2 or more of the following activities:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6136bf2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–6/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Strengthening coordination and communication with public health and safety services, emergency medical services, medical facilities, trauma centers, and other entities in a region to develop approaches to improve situational awareness and emergency medical and trauma system access.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6136bf3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–6/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Providing a mechanism, such as a regional medical direction or transport communications system, that operates throughout the region to support patient movement to ensure that the patient is taken to the medically appropriate facility (whether an initial facility or a higher-level facility) in a timely fashion.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6136bf4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–6/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Improving the tracking of prehospital and hospital resources, including inpatient bed capacity, emergency department capacity, trauma center capacity, on-call specialist coverage, ambulance diversion status, and the coordination of such tracking with regional communications and hospital destination decisions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6136bf5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–6/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Supporting a consistent region-wide prehospital, hospital, and interfacility data management system that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6136bf6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–6/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submits data to the National EMS Information System, the National Trauma Data Bank, and others;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6136bf7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–6/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reports data to appropriate Federal and State databanks and registries; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6136bf8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–6/c/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contains information sufficient to evaluate key elements of prehospital care, hospital destination decisions, including initial hospital and interfacility decisions, and relevant health outcomes of hospital care.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6136bf9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–6/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Establishing, implementing, and disseminating, or utilizing existing, as applicable, evidence-based or evidence-informed practices across facilities within such emergency medical and trauma system to improve health outcomes, including such practices related to management of injuries, and the ability of such facilities to surge.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb615dbfa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–6/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Conducting activities to facilitate clinical research, as applicable and appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb615dbfb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–6/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb615dbfc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–6/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An eligible entity that seeks a contract or grant described in subsection (a) shall submit to the Secretary an application at such time and in such manner as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb615dbfd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–6/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application information","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each application shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb615dbfe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–6/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an assurance from the eligible entity that the applicable emergency medical and trauma system system— ","children":[{"tag":"ref","attrib":{"idref":"fn002329"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002329"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original."}],"tail":null}],"tail":null},{"tag":"clause","attrib":{"id":"idb615dbff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–6/d/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has been coordinated with the applicable State Office of Emergency Medical Services (or equivalent State office or Tribal entity);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb615dc00-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–6/d/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes consistent indirect and direct medical oversight of prehospital, hospital, and interfacility transport throughout the region;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb615dc01-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–6/d/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinates prehospital treatment and triage, hospital destination, and interfacility transport throughout the region;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb615dc02-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–6/d/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes a categorization or designation system for special medical facilities throughout the region that is integrated with transport and destination protocols;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb615dc03-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–6/d/2/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes a regional medical direction, patient tracking, and resource allocation system that supports day-to-day emergency care and surge capacity and is integrated with other components of the national and State emergency preparedness system; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb615dc04-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–6/d/2/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" addresses pediatric concerns related to integration, planning, preparedness, and coordination of emergency medical services for infants, children and adolescents;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb615dc05-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–6/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for eligible entities described in subparagraph (C) or (D) of subsection (b)(1), a description of, and evidence of, coordination with the applicable State Office of Emergency Medical Services (or equivalent State Office) or applicable such office for a Tribe or Tribal organization; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb615dc06-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–6/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other information as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb615dc07-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–6/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement of matching funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb615dc08-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–6/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may not make a grant under this section unless the State (or consortia of States) involved agrees, with respect to the costs to be incurred by the State (or consortia) in carrying out the purpose for which such grant was made, to make available non-Federal contributions (in cash or in kind under paragraph (2)) toward such costs in an amount equal to not less than $1 for each $3 of Federal funds provided in the grant. Such contributions may be made directly or through donations from public or private entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb615dc09-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–6/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-Federal contributions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Non-Federal contributions required in paragraph (1) may be in cash or in kind, fairly evaluated, including equipment or services (and excluding indirect or overhead costs). Amounts provided by the Federal Government, or services assisted or subsidized to any significant extent by the Federal Government, may not be included in determining the amount of such non-Federal contributions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb615dc0a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–6/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The matching requirement described in paragraph (1) shall take effect on ","children":[{"tag":"date","attrib":{"date":"2025-10-01"},"text":"October 1, 2025","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb615dc0b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–6/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall give priority for the award of the contracts or grants described in subsection (a) to any eligible entity that serves a medically underserved population (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s254b/b/3"},"text":"section 254b(b)(3) of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb615dc0c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–6/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 90 days after the completion of a pilot project under subsection (a), the recipient of such contract or grant shall submit to the Secretary a report containing the results of an evaluation of the program, including an identification of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb615dc0d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–6/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the impact of the regional, accountable emergency care and trauma system on patient health outcomes for various critical care categories, such as trauma, stroke, cardiac emergencies, neurological emergencies, and pediatric emergencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb615dc0e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–6/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" opportunities for improvement, including recommendations for how to improve the effectiveness and efficiency of the program (or lack thereof);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb615dc0f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–6/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" methods of assuring the long-term financial sustainability of the emergency care and trauma system;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb615dc10-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–6/g/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the barriers to developing regionalized, accountable emergency care and trauma systems, as well as the methods to overcome such barriers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb615dc11-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–6/g/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommendations on the utilization of available funding for future regionalization efforts; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb615dc12-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–6/g/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any evidence-based or evidence-informed strategies developed or utilized pursuant to subsection (c)(5).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb615dc13-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–6/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dissemination of findings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after the completion of the final project under subsection (a), the Secretary shall submit to the Committee on Health, Education, Labor, and Pensions of the Senate and the Committee on Energy and Commerce of the House of Representatives a report describing the information contained in each report submitted pursuant to subsection (g) and any additional actions planned by the Secretary related to regionalized emergency care and trauma systems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb615dc14-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XII, § 1204, as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tIII/s3504/a/2"},"text":"Pub. L. 111–148, title III, § 3504(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/518"},"text":"124 Stat. 518","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dFF/tII/s2113/c"},"text":"Pub. L. 117–328, div. FF, title II, § 2113(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5724"},"text":"136 Stat. 5724","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb615dc15-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb615dc16-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb615dc17-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 300d–6, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373/tXII/s1202"},"text":"act July 1, 1944, ch. 373, title XII, § 1202","children":[],"tail":", formerly § 1207, as added "},{"tag":"date","attrib":{"date":"1973-11-16"},"text":"Nov. 16, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/93/154/s2/a"},"text":"Pub. L. 93–154, § 2(a)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/602"},"text":"87 Stat. 602","children":[],"tail":"; amended "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/94/573/s8"},"text":"Pub. L. 94–573, § 8","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2714"},"text":"90 Stat. 2714","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1978-11-10"},"text":"Nov. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/95/626/tII/s210/d"},"text":"Pub. L. 95–626, title II, § 210(d)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3588"},"text":"92 Stat. 3588","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"19