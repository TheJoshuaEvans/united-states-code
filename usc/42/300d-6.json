ldren":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2716"},"text":"90 Stat. 2716","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1979-10-17"},"text":"Oct. 17, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/96/88/tV/s509/b"},"text":"Pub. L. 96–88, title V, § 509(b)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/695"},"text":"93 Stat. 695","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1979-12-12"},"text":"Dec. 12, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/96/142/tI/s106"},"text":"Pub. L. 96–142, title I, § 106","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/1069"},"text":"93 Stat. 1069","children":[],"tail":", related to Interagency Committee on Emergency Medical Services."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 300d–9, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373/tXII/s1210"},"text":"act July 1, 1944, ch. 373, title XII, § 1210","children":[],"tail":", as added "},{"tag":"date","attrib":{"date":"1973-11-16"},"text":"Nov. 16, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/93/154/s2/a"},"text":"Pub. L. 93–154, § 2(a)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/603"},"text":"87 Stat. 603","children":[],"tail":"; amended "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/94/573/s11"},"text":"Pub. L. 94–573, § 11","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2717"},"text":"90 Stat. 2717","children":[],"tail":", related to annual report to Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb615dc18-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s2113/c/1"},"text":"Pub. L. 117–328, § 2113(c)(1)","children":[],"tail":", amended section catchline generally. Prior to amendment, section catchline read as follows: “Competitive grants for regionalized systems for emergency care response”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s2113/c/2"},"text":"Pub. L. 117–328, § 2113(c)(2)","children":[],"tail":", substituted “to design, implement, and evaluate new or existing” for “that design, implement, and evaluate” and “emergency medical” for “emergency care” and inserted “, and improve access to trauma care within such systems” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s2113/c/3"},"text":"Pub. L. 117–328, § 2113(c)(3)","children":[],"tail":", added subpars. (A) to (D) and struck out former subpars. (A) and (B) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) a State or a partnership of 1 or more States and 1 or more local governments; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) an Indian tribe (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1603"},"text":"section 1603 of title 25","children":[],"tail":") or a partnership of 1 or more Indian tribes.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s2113/c/4/A"},"text":"Pub. L. 117–328, § 2113(c)(4)(A)","children":[],"tail":", struck out “that proposes a pilot project” after “an eligible entity” and substituted “a new or existing emergency medical and trauma system. Such eligible entity shall use amounts awarded under this subsection to carry out 2 or more of the following activities:” for “an emergency medical and trauma system that—” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s2113/c/4/B"},"text":"Pub. L. 117–328, § 2113(c)(4)(B)","children":[],"tail":", substituted “Strengthening coordination and communication” for “coordinates” and “approaches to improve situational awareness and emergency medical and trauma system access.” for “an approach to emergency medical and trauma system access throughout the region, including 9–1–1 Public Safety Answering Points and emergency medical dispatch;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s2113/c/4/C"},"text":"Pub. L. 117–328, § 2113(c)(4)(C)","children":[],"tail":", substituted “Providing” for “includes” and “fashion.” for “fashion;” and inserted “support patient movement to” after “region to”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s2113/c/4/D"},"text":"Pub. L. 117–328, § 2113(c)(4)(D)","children":[],"tail":", substituted “Improving” for “allows for” and “decisions.” for “decisions; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s2113/c/4/E"},"text":"Pub. L. 117–328, § 2113(c)(4)(E)","children":[],"tail":", substituted “Supporting a consistent” for “includes a consistent” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(5), (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s2113/c/4/F"},"text":"Pub. L. 117–328, § 2113(c)(4)(F)","children":[],"tail":", added pars. (5) and (6)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s2113/c/5/A/i"},"text":"Pub. L. 117–328, § 2113(c)(5)(A)(i)","children":[],"tail":", substituted “the applicable emergency medical and trauma system” for “the proposed” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2)(A)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s2113/c/5/A/ii"},"text":"Pub. L. 117–328, § 2113(c)(5)(A)(ii)","children":[],"tail":", inserted “or Tribal entity” after “equivalent State office”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2)(B), (C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s2113/c/5/A/iii"},"text":"Pub. L. 117–328, § 2113(c)(5)(A)(iii)","children":[],"tail":"–(C), added subpar. (B) and redesignated former subpar. (B) as (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s2113/c/6"},"text":"Pub. L. 117–328, § 2113(c)(6)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s2113/c/7"},"text":"Pub. L. 117–328, § 2113(c)(7)","children":[],"tail":", substituted “medically underserved population” for “population in a medically underserved area”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s2113/c/8/A"},"text":"Pub. L. 117–328, § 2113(c)(8)(A)","children":[],"tail":", struck out “described in” after “grant” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s2113/c/8/B"},"text":"Pub. L. 117–328, § 2113(c)(8)(B)","children":[],"tail":", substituted “opportunities for improvement, including recommendations for how to improve” for “the system characteristics that contribute to”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g)(4) to (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s2113/c/8/C"},"text":"Pub. L. 117–328, § 2113(c)(8)(C)","children":[],"tail":"–(G), added par. (6), redesignated former pars. (5) and (6) as (4) and (5), respectively, and struck out former par. (4) which read as follows: “the State and local legislation necessary to implement and to maintain the system;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s2113/c/9"},"text":"Pub. L. 117–328, § 2113(c)(9)","children":[],"tail":", amended subsec. (h) generally. Prior to amendment, text read as follows: “The Secretary shall, as appropriate, disseminate to the public and to the appropriate Committees of the Congress, the information contained in a report made under subsection (g).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
