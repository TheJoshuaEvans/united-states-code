{"tag":"section","attrib":{"id":"idbb817f30-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1856o"},"text":null,"children":[{"tag":"num","attrib":{"value":"1856o"},"text":"§ 1856o.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Funds available to the Secretary of Agriculture or the Secretary of the Interior for wildfire protection resources in connection with activities under the jurisdiction of such Secretary may be used to carry out activities authorized under agreements or otherwise under this subchapter, or for reimbursements authorized under this subchapter: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That no such funds may be expended for wildfire protection resources (including personnel) provided by a foreign fire organization for wildfire suppression activities unless the Secretary determines that no wildfire protection resources (including personnel) within the United States are reasonably available to provide wildfire suppression."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbb817f31-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/428/s5"},"text":"Pub. L. 100–428, § 5","children":[],"tail":", formerly § 4, "},{"tag":"date","attrib":{"date":"1988-09-09"},"text":"Sept. 9, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1616"},"text":"102 Stat. 1616","children":[],"tail":"; renumbered § 5 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/112/74/dE/tIV/s411/4"},"text":"Pub. L. 112–74, div. E, title IV, § 411(4)","children":[],"tail":", (6), "},{"tag":"date","attrib":{"date":"2011-12-23"},"text":"Dec. 23, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1040"},"text":"125 Stat. 1040","children":[],"tail":", 1041.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbb817f32-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbb817f33-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbb817f34-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/428/s5"},"text":"section 5 of Pub. L. 100–428","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1856p"},"text":"section 1856p of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/101/11"},"text":"Pub. L. 101–11","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbb817f35-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2011—","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/74/s411/6"},"text":"Pub. L. 112–74, § 411(6)","children":[],"tail":", substituted “under this subchapter” for “under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1856n/c"},"text":"section 1856n(c) of this title","children":[],"tail":"”, “wildfire protection resources (including personnel)” for “wildfire protection resources or personnel” in two places, and “provide wildfire suppression” for “provide wildfire protection” and inserted “for wildfire suppression activities” before “unless”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
