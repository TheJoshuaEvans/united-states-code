{"tag":"section","attrib":{"id":"idbbb5d538-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000c"},"text":null,"children":[{"tag":"num","attrib":{"value":"2000c"},"text":"§ 2000c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this subchapter—","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbbb5d539-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Secretary” means the Secretary of Education.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbbb5d53a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Desegregation” means the assignment of students to public schools and within such schools without regard to their race, color, religion, sex or national origin, but “desegregation” shall not mean the assignment of students to public schools in order to overcome racial imbalance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbbb5d53b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Public school” means any elementary or secondary educational institution, and “public college” means any institution of higher education or any technical or vocational school above the secondary school level, provided that such public school or public college is operated by a State, subdivision of a State, or governmental agency within a State, or operated wholly or predominantly from or through the use of governmental funds or property, or funds or property derived from a governmental source.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbbb5d53c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000c/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “School board” means any agency or agencies which administer a system of one or more public schools and any other agency which is responsible for the assignment of students to or within such system.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbbb5d53d-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/352/tIV/s401"},"text":"Pub. L. 88–352, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-07-02"},"text":"July 2, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/246"},"text":"78 Stat. 246","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/92/318/tIX/s906/a"},"text":"Pub. L. 92–318, title IX, § 906(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-06-23"},"text":"June 23, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/375"},"text":"86 Stat. 375","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/88/tIII/s301/a/1"},"text":"Pub. L. 96–88, title III, § 301(a)(1)","children":[],"tail":", title V, § 507, "},{"tag":"date","attrib":{"date":"1979-10-17"},"text":"Oct. 17, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/677"},"text":"93 Stat. 677","children":[],"tail":", 692.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbbb5d53e-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbbb5d53f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbbb5d540-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1972—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/318"},"text":"Pub. L. 92–318","children":[],"tail":" inserted “sex” after “religion,”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbbb5d541-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"idbbb5d542-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Secretary means the Secretary of Education” substituted for “Commissioner means the Commissioner of Education” in subsec. (a) pursuant to sections 301(a)(1) and 507 of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/88"},"text":"Pub. L. 96–88","children":[],"tail":", which are classified to sections 3441(a)(1) and 3507 of Title 20, Education, and which transferred all functions of Commissioner of Education of Department of Health, Education, and Welfare to Secretary of Education."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
