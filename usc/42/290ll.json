{"tag":"section","attrib":{"id":"idb5c720d2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ll"},"text":null,"children":[{"tag":"num","attrib":{"value":"290ll"},"text":"§ 290ll.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fellowships","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5c720d3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ll/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall maintain a program, to be known as the Minority Fellowship Program, under which the Secretary shall award fellowships, which may include stipends, for the purposes of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5c720d4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ll/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increasing the knowledge of mental and substance use disorders practitioners on issues related to diagnosis, prevention, treatment, and recovery support for individuals who are from racial and ethnic minority populations and who have a mental or substance use disorder;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5c720d5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ll/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improving the quality of mental and substance use disorder prevention and treatment services delivered to racial and ethnic minority populations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5c720d6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ll/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increasing the number of culturally competent mental and substance use disorders professionals who teach, administer services, conduct research, and provide direct mental or substance use disorder services to racial and ethnic minority populations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5c720d7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ll/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training covered","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The fellowships awarded under subsection (a) shall be for postbaccalaureate training (including for master’s and doctoral degrees) for mental and substance use disorder treatment professionals, including in the fields of psychiatry, addiction medicine, nursing, social work, psychology, marriage and family therapy, mental health counseling, and substance use disorder and addiction counseling.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5c720d8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ll/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To carry out this section, there are authorized to be appropriated $25,000,000 for each of fiscal years 2023 through 2027.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5c720d9-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title V, § 597, as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/255/dB/tIX/s9024"},"text":"Pub. L. 114–255, div. B, title IX, § 9024","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-13"},"text":"Dec. 13, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1253"},"text":"130 Stat. 1253","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dFF/tI/s1312"},"text":"Pub. L. 117–328, div. FF, title I, § 1312","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5697"},"text":"136 Stat. 5697","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/44/tII/s202"},"text":"Pub. L. 119–44, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-01"},"text":"Dec. 1, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/680"},"text":"139 Stat. 680","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb5c720da-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb5c720db-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb5c720dc-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/44/s202/1"},"text":"Pub. L. 119–44, § 202(1)","children":[],"tail":", inserted “diagnosis,” after “related to”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/44/s202/2"},"text":"Pub. L. 119–44, § 202(2)","children":[],"tail":", inserted “addiction medicine,” after “psychiatry,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2022—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328"},"text":"Pub. L. 117–328","children":[],"tail":" substituted “$25,000,000 for each of fiscal years 2023 through 2027” for “$12,669,000 for each of fiscal years 2018 through 2022”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
