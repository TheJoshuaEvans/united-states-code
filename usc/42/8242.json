{"tag":"section","attrib":{"id":"idbe839b7c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8242"},"text":null,"children":[{"tag":"num","attrib":{"value":"8242"},"text":"§ 8242.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal solar program","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary, in consultation with the Administrator of the General Services Administration, shall develop and carry out a program to demonstrate the application to buildings of solar heating and solar heating and cooling technology in Federal buildings.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbe839b7d-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/619/tV/s522"},"text":"Pub. L. 95–619, title V, § 522","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-09"},"text":"Nov. 9, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3276"},"text":"92 Stat. 3276","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
