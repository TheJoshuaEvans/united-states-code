/96/499/tIX/s901/b"},"text":"“The amendment made by subsection (a) [enacting this section] shall apply to grants, gifts, and endowments, and income therefrom, made or established after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1980-12-05"},"text":"Dec. 5, 1980","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
