{"tag":"section","attrib":{"id":"idbc95fbea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3614"},"text":null,"children":[{"tag":"num","attrib":{"value":"3614"},"text":"§ 3614.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement by Attorney General","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbc95fbeb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3614/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pattern or practice cases","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Whenever the Attorney General has reasonable cause to believe that any person or group of persons is engaged in a pattern or practice of resistance to the full enjoyment of any of the rights granted by this subchapter, or that any group of persons has been denied any of the rights granted by this subchapter and such denial raises an issue of general public importance, the Attorney General may commence a civil action in any appropriate United States district court.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc95fbec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3614/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" On referral of discriminatory housing practice or conciliation agreement for enforcement","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc95fbed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3614/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc95fbee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3614/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Attorney General may commence a civil action in any appropriate United States district court for appropriate relief with respect to a discriminatory housing practice referred to the Attorney General by the Secretary under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3610/g"},"text":"section 3610(g) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc95fbef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3614/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A civil action under this paragraph may be commenced not later than the expiration of 18 months after the date of the occurrence or the termination of the alleged discriminatory housing practice.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc95fbf0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3614/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc95fbf1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3614/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Attorney General may commence a civil action in any appropriate United States district court for appropriate relief with respect to breach of a conciliation agreement referred to the Attorney General by the Secretary under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3610/c"},"text":"section 3610(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc95fbf2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3614/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A civil action may be commenced under this paragraph not later than the expiration of 90 days after the referral of the alleged breach under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3610/c"},"text":"section 3610(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc95fbf3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3614/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement of subpoenas","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General, on behalf of the Secretary, or other party at whose request a subpoena is issued, under this subchapter, may enforce such subpoena in appropriate proceedings in the United States district court for the district in which the person to whom the subpoena was addressed resides, was served, or transacts business.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc95fbf4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3614/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relief which may be granted in civil actions under subsections (a) and (b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc95fbf5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3614/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In a civil action under subsection (a) or (b), the court—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc95fbf6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3614/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may award such preventive relief, including a permanent or temporary injunction, restraining order, or other order against the person responsible for a violation of this subchapter as is necessary to assure the full enjoyment of the rights granted by this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc95fbf7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3614/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may award such other relief as the court deems appropriate, including monetary damages to persons aggrieved; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc95fbf8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3614/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" may, to vindicate the public interest, assess a civil penalty against the respondent—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbc95fbf9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3614/d/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in an amount not exceeding $50,000, for a first violation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc95fbfa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3614/d/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in an amount not exceeding $100,000, for any subsequent violation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc95fbfb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3614/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In a civil action under this section, the court, in its discretion, may allow the prevailing party, other than the United States, a reasonable attorney’s fee and costs. The United States shall be liable for such fees and costs to the extent provided by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s2412"},"text":"section 2412 of title 28","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc95fbfc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3614/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Intervention in civil actions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon timely application, any person may intervene in a civil action commenced by the Attorney General under subsection (a) or (b) which involves an alleged discriminatory housing practice with respect to which such person is an aggrieved person or a conciliation agreement to which such person is a party. The court may grant such appropriate relief to any such intervening party as is authorized to be granted to a plaintiff in a civil action under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3613"},"text":"section 3613 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc95fbfd-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/284/tVIII/s814"},"text":"Pub. L. 90–284, title VIII, § 814","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/430/s8/2"},"text":"Pub. L. 100–430, § 8(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-09-13"},"text":"Sept. 13, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1634"},"text":"102 Stat. 1634","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc95fbfe-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc95fbff-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbc95fc00-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 3614, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/284/tVIII/s814"},"text":"Pub. L. 90–284, title VIII, § 814","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-04-11"},"text":"Apr. 11, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/88"},"text":"82 Stat. 88","children":[],"tail":", related to expedition of court proceedings under section 3612 or 3613 of this title, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/98/620/tIV/s402/40"},"text":"Pub. L. 98–620, title IV, § 402(40)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-11-08"},"text":"Nov. 8, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3360"},"text":"98 Stat. 3360","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbc95fc01-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbc95fc02-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on 180th day beginning after ","children":[{"tag":"date","attrib":{"date":"1988-09-13"},"text":"Sept. 13, 1988","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/430/s13/a"},"text":"section 13(a) of Pub. L. 100–430","children":[],"tail":", set out as an Effective Date of 1988 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3601"},"text":"section 3601 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
