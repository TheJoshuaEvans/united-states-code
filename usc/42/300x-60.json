{"tag":"section","attrib":{"id":"idb66e0f36-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–60"},"text":null,"children":[{"tag":"num","attrib":{"value":"300x–60"},"text":"§ 300x–60.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction regarding delegation of authority to States","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"With respect to States receiving grants under section 300x or 300x–21 of this title, this part may not be construed to authorize the Secretary to delegate to the States the primary responsibility for interpreting the governing provisions of this part.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb66e0f37-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XIX, § 1950, as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/321/tII/s203/a"},"text":"Pub. L. 102–321, title II, § 203(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-10"},"text":"July 10, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/408"},"text":"106 Stat. 408","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
