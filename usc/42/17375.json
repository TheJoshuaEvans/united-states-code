{"tag":"section","attrib":{"id":"idc038024c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17375"},"text":null,"children":[{"tag":"num","attrib":{"value":"17375"},"text":"§ 17375.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regional clean energy innovation program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc038024d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17375/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc038024e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17375/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regional clean energy innovation partnership","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “regional clean energy innovation partnership” means a group of one or more persons, including a covered consortium, who perform a collection of activities that are coordinated by such covered consortium to carry out the purposes of the program under subsection (c) in a region of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc038024f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17375/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered consortium","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “covered consortium” means an individual or group of individuals in partnership with a government entity, including a State, territorial, local, or tribal government or unit of such government, and at least 2 or more of the following additional entities—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0380250-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17375/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an institution of higher education or a consortium of institutions of higher education, including community colleges;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0380251-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17375/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a workforce development program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0380252-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17375/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a private sector entity or group of entities, including a trade or industry association;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0380253-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17375/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a nonprofit organization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0380254-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17375/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a community group or community-based organization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0380255-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17375/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a labor organization or joint labor-management organization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0380256-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17375/a/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a National Laboratory;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0380257-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17375/a/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a venture development organization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0380258-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17375/a/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a community development financial institution or minority depository institution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0380259-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17375/a/2/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a worker cooperative membership association or state or local employee ownership or cooperative development center;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc038025a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17375/a/2/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an organization focused on clean energy technology innovation or entrepreneurship;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc038025b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17375/a/2/L"},"text":null,"children":[{"tag":"num","attrib":{"value":"L"},"text":"(L)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a business or clean energy accelerator or incubator;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc038025c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17375/a/2/M"},"text":null,"children":[{"tag":"num","attrib":{"value":"M"},"text":"(M)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an economic development organization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc038025d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17375/a/2/N"},"text":null,"children":[{"tag":"num","attrib":{"value":"N"},"text":"(N)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a manufacturing facility or organization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc038025e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17375/a/2/O"},"text":null,"children":[{"tag":"num","attrib":{"value":"O"},"text":"(O)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a multi-institutional collaboration; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc038025f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17375/a/2/P"},"text":null,"children":[{"tag":"num","attrib":{"value":"P"},"text":"(P)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other entity that the Secretary determines to be relevant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0380260-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17375/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “program” means the Regional Clean Energy Innovation Program authorized in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0380261-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17375/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Institution of higher education","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “institution of higher education” has the meaning given such term in section 1001 or 1002(a)(1)(B) of title 20.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0380262-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17375/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Laboratory","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “National Laboratory” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s15801"},"text":"section 15801 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0380263-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17375/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Clean energy technology","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “clean energy technology” means a technology that significantly reduces energy use, increases energy efficiency, reduces greenhouse gas emissions, reduces emissions of other pollutants, or mitigates other negative environmental consequences of energy production, transmission or use.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0380264-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17375/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Community-based organization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “community-based organization” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3102"},"text":"section 3102 of title 29","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0380265-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17375/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Community college","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “community college” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0380266-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17375/a/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a public institution of higher education, including additional locations, at which the highest degree, or the predominantly awarded degree, is an associate degree; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0380267-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17375/a/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any Tribal college or university (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1059c"},"text":"section 1059c of title 20","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0380268-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17375/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Workforce development program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “workforce development program” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3102"},"text":"section 3102 of title 29","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0380269-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17375/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a Regional Clean Energy Innovation Program, a research, development, demonstration, and commercial application program designed to enhance the economic, environmental, and energy security of the United States and accelerate the pace of innovation of diverse clean energy technologies through the formation or support of regional clean energy innovation partnerships.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc038026a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17375/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes of the Program","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of the Program established under subsection (b) are to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc038026b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17375/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve the competitiveness of United States’ clean energy technology research, development, demonstration, and commercial application; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc038026c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17375/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support the development of tools and technologies best suited for use in diverse regions of the United States, including in rural, tribal, and low-income communities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc038026d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17375/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regional clean energy innovation partnerships","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc038026e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17375/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall competitively award grants to covered consortia to establish or support regional clean energy innovation partnerships that achieve the purposes of the Program in subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc038026f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17375/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Permissible activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Grants awarded under this subsection shall be used for activities determined appropriate by the Secretary to achieve the purposes of the Program in subsection (c), including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0380270-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17375/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitating the commercial application of clean energy products, processes, and services, including through research, development, demonstration, or technology transfer;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0380271-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17375/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" planning among participants of a regional clean energy innovation partnership to improve the strategic and cost-effective coordination of the partnership;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0380272-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17375/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improving stakeholder involvement in the development of goals and activities of a regional clean energy innovation partnership;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0380273-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17375/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assessing different incentive mechanisms for clean energy development and commercial application in the region;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0380274-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17375/d/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hosting events and conferences; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0380275-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17375/d/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing and updating roadmaps to measure progress on relevant goals, such as those relevant to metrics developed under subsection (g).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0380276-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17375/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each application submitted to the Secretary under paragraph (1) may include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0380277-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17375/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a list of members and roles of members of the covered consortia, as well as any other stakeholders supporting the activities of the regional clean energy innovation partnership;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0380278-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17375/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of the relevant clean energy innovation assets needed in a region to achieve proposed outcomes, such as education and workforce development programs, research facilities, infrastructure or site development, access to capital, manufacturing capabilities, or other assets;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0380279-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17375/d/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of proposed activities that the regional clean energy innovation partnership plans to undertake and how the proposed activities will achieve the purposes described in subsection (c);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc038027a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17375/d/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a plan for attracting additional funds and identification of funding sources from non-Federal sources to deliver the proposed outcomes of the regional clean energy innovation partnership;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc038027b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17375/d/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a plan for partnering and collaborating with community development financial institutions and minority depository institutions, labor organizations and community groups, worker cooperative membership associations, local and state employee ownership and cooperative development centers, and other local institutions in order to promote employee, community, and public ownership in the clean energy sector, and advance models of local economic development that build and retain wealth in the region;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc038027c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17375/d/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a plan for sustaining activities of the regional clean energy innovation partnership after funds received under this program have been expended; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc038027d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17375/d/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a proposed budget, including financial contributions from non-Federal sources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc038027e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17375/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Considerations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In selecting covered consortia for funding under the Program, the Secretary shall, to the maximum extent practicable—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc038027f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17375/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" give special consideration to applications from rural, tribal, and low-income communities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0380280-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17375/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that there is geographic diversity among the covered consortia selected to receive funding.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0380281-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17375/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Award amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Grants given out under this Program shall be in an amount not greater than $10,000,000, with the total grant award in any year less than that in the previous year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0380282-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17375/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For grants that are disbursed over the course of three or more years, the Secretary shall require, as a condition of receipt of funds under this section, that a covered consortium provide not less than 50 percent of the funding for the activities of the regional clean energy partnership under this section for years 3, 4, and 5.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0380283-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17375/d/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each grant under paragraph shall be for a period of not longer than 5 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0380284-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17375/d/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Renewal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A grant awarded under this section may be renewed for a period of not more than 5 years, subject to a rigorous merit review based on the progress of a regional clean energy innovation partnership towards achieving the purposes of the program in subsection (c) and the metrics developed under subsection (g).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0380285-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17375/d/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Consistent with the existing authorities of the Department, the Secretary may terminate grant funding under this subsection to covered consortia during the performance period if the Secretary determines that the regional clean energy innovation partnership is underperforming.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0380286-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17375/d/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may allow a covered consortium that receives funds under this section to allocate a portion of the funding received to be used for administrative or indirect costs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0380287-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17375/d/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may accept funds from other Federal agencies to support funding and activities under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0380288-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17375/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Planning funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may competitively award grants in an amount no greater than $2,000,000 for a period not longer than 2 years to an entity consisting of a government entity, including a State, territorial, local, or tribal government or unit of such government or any entity listed under subsection (a)(2) to plan a regional clean energy innovation partnership or establish a covered consortium for the purpose of applying for funds under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0380289-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17375/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information sharing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As part of the program, the Secretary shall support the gathering, analysis, and dissemination of information on best practices for developing and operating successful regional clean energy innovation partnerships.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc038028a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17375/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Metrics","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In evaluating a grant renewal under subsection (d)(8), the Secretary shall work with program evaluation experts to develop and make publicly available metrics to assess the progress of a regional clean energy innovation partnership towards achieving the purposes of the program in subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc038028b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17375/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out the program, the Secretary shall coordinate with, and avoid unnecessary duplication of, the activities carried out under this section with the activities of other research entities of the Department or relevant programs at other Federal agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc038028c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17375/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conflicts of interest","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out the program, the Secretary shall maintain conflict of interest procedures, consistent with the conflict of interest procedures of the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc038028d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17375/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation by Comptroller General","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 3 years after ","children":[{"tag":"date","attrib":{"date":"2022-08-09"},"text":"August 9, 2022","children":[],"tail":", and again 3 years later, the Comptroller General shall submit to the Committee on Science, Space, and Technology of the House of Representatives and the Committee on Energy and Natural Resources of the Senate an evaluation on the operation of the program during the most recent 3-year period, including—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc03a728e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17375/j/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of the progress made towards achieving the purposes specified in subsection (c) based on the metrics developed under subsection (g);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc03a728f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17375/j/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the short-term and long-term metrics used to determine the success of the program under subsection (g), and any changes recommended to the metrics used;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc03a7290-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17375/j/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the regional clean energy innovation partnerships established or supported by covered consortia that have received grants under subsection (d); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc03a7291-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17375/j/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any recommendations on how the program may be improved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc03a7292-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17375/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Laboratories","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In supporting technology transfer activities at the National Laboratories, the Secretary shall encourage partnerships with entities that are located in the same region or State as the National Laboratory.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc03a7293-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17375/l"},"text":null,"children":[{"tag":"num","attrib":{"value":"l"},"text":"(l)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Security","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out the activities under this section, the Secretary shall ensure proper security controls are in place to protect sensitive information, as appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc03a7294-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17375/m"},"text":null,"children":[{"tag":"num","attrib":{"value":"m"},"text":"(m)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No funds for construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No funds provided to the Department of Energy under this section shall be used for construction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc03a7295-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17375/n"},"text":null,"children":[{"tag":"num","attrib":{"value":"n"},"text":"(n)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to the Secretary to carry out this section $50,000,000 for each of fiscal years 2023 through 2027.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc03a7296-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/tIX/s936"},"text":"Pub. L. 110–140, title IX, § 936","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/tVI/s10622"},"text":"Pub. L. 117–167, div. B, title VI, § 10622","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1660"},"text":"136 Stat. 1660","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
