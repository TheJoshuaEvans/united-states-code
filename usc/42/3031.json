{"tag":"section","attrib":{"id":"idbc5cc3b4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3031"},"text":null,"children":[{"tag":"num","attrib":{"value":"3031"},"text":"§ 3031.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purposes of this subchapter are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc5cc3b5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3031/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to expand the Nation’s knowledge and understanding of the older population and the aging process;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc5cc3b6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3031/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to design, test, and promote the use of innovative ideas and best practices in programs and services for older individuals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc5cc3b7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3031/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to help meet the needs for trained personnel in the field of aging; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc5cc3b8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3031/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to increase awareness of citizens of all ages of the need to assume personal responsibility for their own longevity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"i