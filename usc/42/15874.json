{"tag":"section","attrib":{"id":"idbfe48c0f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15874"},"text":null,"children":[{"tag":"num","attrib":{"value":"15874"},"text":"§ 15874.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Intermountain West Geothermal Consortium","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfe48c10-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15874/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Participation authorized","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Idaho National Laboratory, may participate in a consortium described in subsection (b) to address science and science policy issues surrounding the expanded discovery and use of geothermal energy, including from geothermal resources on public lands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfe48c11-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15874/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Members","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The consortium referred to in subsection (a) shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfe48c12-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15874/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be known as the “Intermountain West Geothermal Consortium”;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe48c13-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15874/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be a regional consortium of institutions and government agencies that focuses on building collaborative efforts among the universities in the State of Idaho, other regional universities, State agencies, and the Idaho National Laboratory;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe48c14-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15874/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include Boise State University, the University of Idaho (including the Idaho Water Resources Research Institute), the Oregon Institute of Technology, the Desert Research Institute with the University and Community College System of Nevada, and the Energy and Geoscience Institute at the University of Utah;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe48c15-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15874/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be hosted and managed by Boise State University; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe48c16-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15874/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have a director appointed by Boise State University, and associate directors appointed by each participating institution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfe48c17-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15874/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Idaho National Laboratory and subject to the availability of appropriations, will provide financial assistance to Boise State University for expenditure under contracts with members of the consortium to carry out the activities of the consortium.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfe48c18-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tII/s237"},"text":"Pub. L. 109–58, title II, § 237","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/673"},"text":"119 Stat. 673","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
