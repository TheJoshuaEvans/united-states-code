{"tag":"section","attrib":{"id":"idbc2141b7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2386"},"text":null,"children":[{"tag":"num","attrib":{"value":"2386"},"text":"§ 2386.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of installations without charge","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The transfer of any municipal installation authorized to be made under the provisions of this subchapter may be made without charge to the entity receiving the installation.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbc2141b8-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1955-08-04/ch543"},"text":"Aug. 4, 1955, ch. 543","children":[],"tail":", ch. 8, § 86, "},{"tag":"ref","attrib":{"href":"/us/stat/69/481"},"text":"69 Stat. 481","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
