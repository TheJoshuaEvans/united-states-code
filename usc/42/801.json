{"tag":"section","attrib":{"id":"idb7f9b74d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s801"},"text":null,"children":[{"tag":"num","attrib":{"value":"801"},"text":"§ 801.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coronavirus relief fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb7f9b74e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s801/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7f9b74f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s801/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Out of any money in the Treasury of the United States not otherwise appropriated, there are appropriated for making payments to States, Tribal governments, and units of local government under this section, $150,000,000,000 for fiscal year 2020.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7f9b750-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s801/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reservation of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Of the amount appropriated under paragraph (1), the Secretary shall reserve—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb7f9b751-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s801/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $3,000,000,000 of such amount for making payments to the District of Columbia, the Commonwealth of Puerto Rico, the United States Virgin Islands, Guam, the Commonwealth of the Northern Mariana Islands, and American Samoa; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7f9b752-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s801/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $8,000,000,000 of such amount for making payments to Tribal governments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7f9b753-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s801/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to make payments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7f9b754-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s801/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (2), not later than 30 days after ","children":[{"tag":"date","attrib":{"date":"2020-03-27"},"text":"March 27, 2020","children":[],"tail":", the Secretary shall pay each State and Tribal government, and each unit of local government that meets the condition described in paragraph (2), the amount determined for the State, Tribal government, or unit of local government, for fiscal year 2020 under subsection (c)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7f9b755-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s801/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Direct payments to units of local government","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a unit of local government of a State submits the certification required by subsection (e) for purposes of receiving a direct payment from the Secretary under the authority of this paragraph, the Secretary shall reduce the amount determined for that State by the relative unit of local government population proportion amount described in subsection (c)(5) and pay such amount directly to such unit of local government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7f9b756-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s801/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment amounts","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7f9b757-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s801/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (2), the amount paid under this section for fiscal year 2020 to a State that is 1 of the 50 States shall be the amount equal to the relative population proportion amount determined for the State under paragraph (3) for such fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7f9b758-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s801/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum payment","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb7f9b759-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s801/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No State that is 1 of the 50 States shall receive a payment under this section for fiscal year 2020 that is less than $1,250,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7f9b75a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s801/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pro rata adjustments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall adjust on a pro rata basis the amount of the payments for each of the 50 States determined under this subsection without regard to this subparagraph to the extent necessary to comply with the requirements of subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7f9b75b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s801/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relative population proportion amount","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of paragraph (1), the relative population proportion amount determined under this paragraph for a State for fiscal year 2020 is the product of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb7f9b75c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s801/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount appropriated under paragraph (1) of subsection (a) for fiscal year 2020 that remains after the application of paragraph (2) of that subsection; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7f9b75d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s801/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the relative State population proportion (as defined in paragraph (4)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7f9b75e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s801/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relative State population proportion defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of paragraph (3)(B), the term “relative State population proportion” means, with respect to a State, the quotient of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb7f9b75f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s801/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the population of the State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7f9b760-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s801/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total population of all States (excluding the District of Columbia and territories specified in subsection (a)(2)(A)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7f9b761-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s801/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relative unit of local government population proportion amount","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subsection (b)(2), the term “relative unit of local government population proportion amount” means, with respect to a unit of local government and a State, the amount equal to the product of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb7f9b762-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s801/c/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 45 percent of the amount of the payment determined for the State under this subsection (without regard to this paragraph); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7f9b763-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s801/c/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the amount equal to the quotient of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb7f9b764-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s801/c/5/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the population of the unit of local government; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb7f9b765-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s801/c/5/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total population of the State in which the unit of local government is located.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7f9b766-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s801/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" District of Columbia and territories","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount paid under this section for fiscal year 2020 to a State that is the District of Columbia or a territory specified in subsection (a)(2)(A) shall be the amount equal to the product of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb7f9b767-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s801/c/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount set aside under subsection (a)(2)(A) for such fiscal year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7f9b768-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s801/c/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each such District’s and territory’s share of the combined total population of the District of Columbia and all such territories, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7f9b769-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s801/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tribal governments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"From the amount set aside under subsection (a)(2)(B) for fiscal year 2020, the amount paid under this section for fiscal year 2020 to a Tribal government shall be the amount the Secretary shall determine, in consultation with the Secretary of the Interior and Indian Tribes, that is based on increased expenditures of each such Tribal government (or a tribally-owned entity of such Tribal government) relative to aggregate expenditures in fiscal year 2019 by the Tribal government (or tribally-owned entity) and determined in such manner as the Secretary determines appropriate to ensure that all amounts available under subsection (a)(2)(B) for fiscal year 2020 are distributed to Tribal governments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7f9b76a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s801/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subsection, the population of States and units of local governments shall be determined based on the most recent year for which data are available from the Bureau of the Census.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7f9b76b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s801/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A State, Tribal government, and unit of local government shall use the funds provided under a payment made under this section to cover only those costs of the State, Tribal government, or unit of local government that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7f9b76c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s801/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are necessary expenditures incurred due to the public health emergency with respect to the Coronavirus Disease 2019 (COVID–19);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7f9b76d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s801/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" were not accounted for in the budget most recently approved as of ","children":[{"tag":"date","attrib":{"date":"2020-03-27"},"text":"March 27, 2020","children":[],"tail":", for the State or government; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7f9b76e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s801/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" were incurred during the period that begins on ","children":[{"tag":"date","attrib":{"date":"2020-03-01"},"text":"March 1, 2020","children":[],"tail":", and ends on "},{"tag":"date","attrib":{"date":"2021-12-31"},"text":"December 31, 2021","children":[],"tail":" (or, in the case of costs incurred by a Tribal government, during the period that begins on "},{"tag":"date","attrib":{"date":"2020-03-01"},"text":"March 1, 2020","children":[],"tail":", and ends on "},{"tag":"date","attrib":{"date":"2022-12-31"},"text":"December 31, 2022","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7f9b76f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s801/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to receive a payment under this section, a unit of local government shall provide the Secretary with a certification signed by the Chief Executive for the unit of local government that the local government’s proposed uses of the funds are consistent with subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7f9b770-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s801/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inspector General oversight; recoupment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7f9b771-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s801/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Oversight authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Inspector General of the Department of the Treasury shall conduct monitoring and oversight of the receipt, disbursement, and use of funds made available under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7f9b772-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s801/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recoupment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Inspector General of the Department of the Treasury determines that a State, Tribal government, or unit of local government has failed to comply with subsection (d), the amount equal to the amount of funds used in violation of such subsection shall be booked as a debt of such entity owed to the Federal Government. Amounts recovered under this subsection shall be deposited into the general fund of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7f9b773-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s801/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Out of any money in the Treasury of the United States not otherwise appropriated, there are appropriated to the Office of the Inspector General of the Department of the Treasury, $35,000,000 to carry out oversight and recoupment activities under this subsection. Amounts appropriated under the preceding sentence shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7f9b774-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s801/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of Inspector General","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subsection shall be construed to diminish the authority of any Inspector General, including such authority as provided in the Inspector General Act of 1978 (5 U.S.C. App.).","children":[{"tag":"ref","attrib":{"idref":"fn002652"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002652"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7f9b775-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s801/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7f9b776-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s801/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian Tribe","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Indian Tribe” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304/e"},"text":"section 5304(e) of title 25","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7f9b777-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s801/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Local government","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “unit of local government” means a county, municipality, town, township, village, parish, borough, or other unit of general government below the State level with a population that exceeds 500,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7f9b778-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s801/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7f9b779-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s801/g/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State” means the 50 States, the District of Columbia, the Commonwealth of Puerto Rico, the United States Virgin Islands, Guam, the Commonwealth of the Northern Mariana Islands, and American Samoa.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7f9b77a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s801/g/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tribal government","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Tribal government” means the recognized governing body of an Indian Tribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb7f9b77b-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title VI, § 601, as added "},{"tag":"ref","attrib":{"href":"/us/pl/116/136/dA/tV/s5001/a"},"text":"Pub. L. 116–136, div. A, title V, § 5001(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-03-27"},"text":"Mar. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/501"},"text":"134 Stat. 501","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dN/tX/s1001"},"text":"Pub. L. 116–260, div. N, title X, § 1001","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2145"},"text":"134 Stat. 2145","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dLL/s104"},"text":"Pub. L. 1