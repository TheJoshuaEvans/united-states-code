{"tag":"section","attrib":{"id":"idc03cbe02-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17912"},"text":null,"children":[{"tag":"num","attrib":{"value":"17912"},"text":"§ 17912.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research and development programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc03cbe03-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17912/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Health Care Information Enterprise Integration Research Centers","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc03cbe04-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17912/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the National Institute of Standards and Technology, in consultation with the Director of the National Science Foundation and other appropriate Federal agencies, shall establish a program of assistance to institutions of higher education (or consortia thereof which may include nonprofit entities and Federal Government laboratories) to establish multidisciplinary Centers for Health Care Information Enterprise Integration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc03cbe05-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17912/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review; competition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Grants shall be awarded under this subsection on a merit-reviewed, competitive basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc03cbe06-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17912/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of the Centers described in paragraph (1) shall be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc03cbe07-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17912/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to generate innovative approaches to health care information enterprise integration by conducting cutting-edge, multidisciplinary research on the systems challenges to health care delivery; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc03cbe08-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17912/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development and use of health information technologies and other complementary fields.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc03cbe09-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17912/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research areas","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Research areas may include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc03cbe0a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17912/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" interfaces between human information and communications technology systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc03cbe0b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17912/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" voice-recognition systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc03cbe0c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17912/a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" software that improves interoperability and connectivity among health information systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc03cbe0d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17912/a/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" software dependability in systems critical to health care delivery;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc03cbe0e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17912/a/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" measurement of the impact of information technologies on the quality and productivity of health care;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc03cbe0f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17912/a/4/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" health information enterprise management;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc03cbe10-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17912/a/4/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" health information technology security and integrity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc03cbe11-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17912/a/4/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" relevant health information technology to reduce medical errors.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc03cbe12-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17912/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An institution of higher education (or a consortium thereof) seeking funding under this subsection shall submit an application to the Director of the National Institute of Standards and Technology at such time, in such manner, and containing such information as the Director may require. The application shall include, at a minimum, a description of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc03cbe13-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17912/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the research projects that will be undertaken by the Center established pursuant to assistance under paragraph (1) and the respective contributions of the participating entities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc03cbe14-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17912/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how the Center will promote active collaboration among scientists and engineers from different disciplines, such as information technology, biologic sciences, management, social sciences, and other appropriate disciplines;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc03cbe15-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17912/a/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" technology transfer activities to demonstrate and diffuse the research results, technologies, and knowledge; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc03cbe16-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17912/a/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how the Center will contribute to the education and training of researchers and other professionals in fields relevant to health information enterprise integration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc03cbe17-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17912/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National information technology research and development program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Networking and Information Technology Research and Development Program established by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s5511"},"text":"section 5511 of title 15","children":[],"tail":" shall include Federal research and development programs related to health information technology."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc03cbe18-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/5/dA/tXIII/s13202"},"text":"Pub. L. 111–5, div. A, title XIII, § 13202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-02-17"},"text":"Feb. 17, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/245"},"text":"123 Stat. 245","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/329/tI/s105/s"},"text":"Pub. L. 114–329, title I, § 105(s)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-01-06"},"text":"Jan. 6, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2985"},"text":"130 Stat. 2985","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc03cbe19-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc03cbe1a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc03cbe1b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/329"},"text":"Pub. L. 114–329","children":[],"tail":" substituted “Networking and Information Technology Research and Development Program” for “National High-Performance Computing Program”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
