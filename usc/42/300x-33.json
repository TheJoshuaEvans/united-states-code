{"tag":"section","attrib":{"id":"idb66b9d7e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–33"},"text":null,"children":[{"tag":"num","attrib":{"value":"300x–33"},"text":"§ 300x–33.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of amount of allotment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb66b9d7f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–33/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" States","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb66b9d80-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–33/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subsection (b), the Secretary shall determine the amount of the allotment required in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x–21"},"text":"section 300x–21 of this title","children":[],"tail":" for a State for a fiscal year as follows:"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb66b9d81-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–33/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The formula established in paragraph (1) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x–7/a"},"text":"section 300x–7(a) of this title","children":[],"tail":" shall apply to this subsection to the same extent and in the same manner as the formula applies for purposes of "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x–7/a"},"text":"section 300x–7(a) of this title","children":[],"tail":", except that, in the application of such formula for purposes of this subsection, the modifications described in subparagraph (B) shall apply."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb66b9d82-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–33/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of subparagraph (A), the modifications described in this subparagraph are as follows:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb66b9d83-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–33/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amount specified in paragraph (2)(A) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x–7/a"},"text":"section 300x–7(a) of this title","children":[],"tail":" is deemed to be the amount appropriated under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x–35/a"},"text":"section 300x–35(a) of this title","children":[],"tail":" for allotments under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x–21"},"text":"section 300x–21 of this title","children":[],"tail":" for the fiscal year involved."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb66b9d84-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–33/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “P” is deemed to have the meaning given in paragraph (2) of this subsection. ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x–7/a/5/B"},"text":"Section 300x–7(a)(5)(B) of this title","children":[],"tail":" applies to the data used in determining such term for the States."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb66b9d85-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–33/a/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The factor determined under paragraph (8) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x–7/a"},"text":"section 300x–7(a) of this title","children":[],"tail":" is deemed to have the purpose of reflecting the differences that exist between the State involved and other States in the costs of providing authorized services."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb66b9d86-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–33/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of term “P”","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection, the term “P” means the percentage that is the arithmetic mean of the percentage determined under subparagraph (A) and the percentage determined under subparagraph (B), as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb66b9d87-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–33/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The percentage constituted by the ratio of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb66b9d88-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–33/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an amount equal to the sum of the total number of individuals who reside in the State involved and are between 18 and 24 years of age (inclusive) and the number of individuals in the State who reside in urbanized areas of the State and are between such years of age; to","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb66b9d89-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–33/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an amount equal to the total of the respective sums determined for the States under clause (i).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb66b9d8a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–33/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The percentage constituted by the ratio of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb66b9d8b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–33/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total number of individuals in the State who are between 25 and 64 years of age (inclusive); to","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb66b9d8c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–33/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an amount equal to the sum of the respective amounts determined for the States under clause (i).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb66b9d8d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–33/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum allotments for States","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb66b9d8e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–33/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to fiscal year 2000, and each subsequent fiscal year, the amount of the allotment of a State under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x–21"},"text":"section 300x–21 of this title","children":[],"tail":" shall not be less than the amount the State received under such section for the previous fiscal year increased by an amount equal to 30.65 percent of the percentage by which the aggregate amount allotted to all States for such fiscal year exceeds the aggregate amount allotted to all States for the previous fiscal year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb66b9d8f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–33/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb66b9d90-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–33/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subparagraph (B), a State shall not receive an allotment under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x–21"},"text":"section 300x–21 of this title","children":[],"tail":" for a fiscal year in an amount that is less than an amount equal to 0.375 percent of the amount appropriated under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x–35/a"},"text":"section 300x–35(a) of this title","children":[],"tail":" for such fiscal year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb66b9d91-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–33/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In applying subparagraph (A), the Secretary shall ensure that no State receives an increase in its allotment under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x–21"},"text":"section 300x–21 of this title","children":[],"tail":" for a fiscal year (as compared to the amount allotted to the State in the prior fiscal year) that is in excess of an amount equal to 300 percent of the percentage by which the amount appropriated under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x–35/a"},"text":"section 300x–35(a) of this title","children":[],"tail":" for such fiscal year exceeds the amount appropriated for the prior fiscal year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb66b9d92-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–33/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Decrease in or equal appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the amount appropriated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x–35/a"},"text":"section 300x–35(a) of this title","children":[],"tail":" for a fiscal year is equal to or less than the amount appropriated under such section for the prior fiscal year, the amount of the State allotment under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x–21"},"text":"section 300x–21 of this title","children":[],"tail":" shall be equal to the amount that the State received under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x–21"},"text":"section 300x–21 of this title","children":[],"tail":" in the prior fiscal year decreased by the percentage by which the amount appropriated for such fiscal year is less than the amount appropriated or "},{"tag":"ref","attrib":{"idref":"fn002394"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002394"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “for”."}],"tail":" such section for the prior fiscal year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb66b9d93-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–33/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Territories","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb66b9d94-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–33/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination under formula","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to paragraphs (2) and (4), the amount of an allotment under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x–21"},"text":"section 300x–21 of this title","children":[],"tail":" for a territory of the United States for a fiscal year shall be the product of—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb66b9d95-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–33/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an amount equal to the amounts reserved under paragraph (3) for the fiscal year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb66b9d96-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–33/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a percentage equal to the quotient of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb66b9d97-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–33/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the civilian population of the territory, as indicated by the most recently available data; divided by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb66b9d98-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–33/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the aggregate civilian population of the territories of the United States, as indicated by such data.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb66b9d99-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–33/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum allotment for territories","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount of an allotment under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x–21"},"text":"section 300x–21 of this title","children":[],"tail":" for a territory of the United States for a fiscal year shall be the greater of—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb66b9d9a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–33/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount determined under paragraph (1) for the territory for the fiscal year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb66b9d9b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–33/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $50,000; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb66b9d9c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–33/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to fiscal years 1993 and 1994, an amount equal to 79.4 percent of the amount received by the territory from allotments made pursuant to this part for fiscal year 1992.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb66b9d9d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–33/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reservation of amounts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall each fiscal year reserve for the territories of the United States 1.5 percent of the amounts appropriated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x–35/a"},"text":"section 300x–35(a) of this title","children":[],"tail":" for allotments under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x–21"},"text":"section 300x–21 of this title","children":[],"tail":" for the fiscal year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb66b9d9e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–33/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of data on population","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to data on the civilian population of the territories of the United States, if the Secretary determines for a fiscal year that recent such data for purposes of paragraph (1)(B) do not exist regarding a territory, the Secretary shall for such purposes estimate the civilian population of the territory by modifying the data on the territory to reflect the average extent of change occurring during the ensuing period in the population of all territories with respect to which recent such data do exist.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb66b9d9f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–33/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of certain provisions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of subsections (a) and (b), the term “State” does not include the territories of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb66b9da0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–33/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian Tribes and Tribal organizations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb66b9da1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–33/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Secretary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb66b9da2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–33/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" receives a request from the governing body of an Indian Tribe or Tribal organization within any State that funds under this subpart be provided directly by the Secretary to such Tribe or organization; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb66b9da3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–33/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" makes a determination that the members of such Tribe or Tribal organization would be better served by means of grants made directly by the Secretary under this subpart;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the Secretary shall reserve from the allotment under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x–21"},"text":"section 300x–21 of this title","children":[],"tail":" for the State for the fiscal year involved an amount that bears the same ratio to the allotment as the amount provided under this subpart to the Tribe or Tribal organization for fiscal year 1991 for activities relating to the prevention and treatment of the use of substances bore to the amount of the portion of the allotment under this subpart for the State for such fiscal year that was expended for such activities."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb66e0ea4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–33/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian Tribe or Tribal organization as grantee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount reserved by the Secretary on the basis of a determination under this subsection shall be granted to the Indian Tribe or Tribal organization serving the individuals for whom such a determination has been made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb66e0ea5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–33/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order for an Indian Tribe or Tribal organization to be eligible for a grant for a fiscal year under this paragraph,","children":[{"tag":"ref","attrib":{"idref":"fn002395"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002395"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be “subsection,”."}],"tail":" it shall submit to the Secretary a plan for such fiscal year that meets such criteria as the Secretary may prescribe."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb66e0ea6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–33/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “Indian Tribe” and “Tribal organization” have the meanings given the terms “Indian tribe” and “tribal organization” in subsections (b) and (c) ","children":[{"tag":"ref","attrib":{"idref":"fn002396"},"text":"3","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002396"},"text":null,"children":[{"tag":"num","attrib":{},"text":"3","children":[],"tail":" See References in Text note below."}],"tail":" of "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304"},"text":"section 5304 of title 25","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb66e0ea7-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XIX, § 1933, as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/321/tII/s202"},"text":"Pub. L. 102–321, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-10"},"text":"July 10, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/400"},"text":"106 Stat. 400","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/352/s2/a/11"},"text":"Pub. L. 102–352, § 2(a)(11)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-08-26"},"text":"Aug. 26, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/938"},"text":"106 Stat. 938","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dA/s101/f/tII/s218/b"},"text":"Pub. L. 105–277, div. A, § 101(f) [title II, § 218(b)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-337"},"text":"112 Stat. 2681–337","children":[],"tail":", 2681–362; "},{"tag":"ref","attrib":{"href":"/us/pl/106/113/dB/s1000/a/4/tII/s212/b"},"text":"Pub. L. 106–113, div. B, § 1000(a)(4) [title II, § 212(b)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-29"},"text":"Nov. 29, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1535"},"text":"113 Stat. 1535","children":[],"tail":", 1501A–239; "},{"tag":"ref","attrib":{"href":"/us/pl/106/310/dB/tXXXIII/s3304"},"text":"Pub. L. 106–310, div. B, title XXXIII, § 3304","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-17"},"text":"Oct. 17, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1212"},"text":"114 Stat. 1212","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dFF/tI"},"text":"Pub. L. 117–328, div. FF, title I","children":[],"tail":", §§ 1241(a)(8), 1244, "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5678"},"text":"136 Stat. 5678","children":[],"tail":", 5679.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb66e0ea8-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb66e0ea9-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb66e0eaa-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304"},"text":"Section 5304 of title 25","children":[],"tail":", referred to in subsec. (d)(4), was amended, and subsecs. (b) and (c) of section 5304 no longer define the terms “Indian tribe” and “tribal organization”. However, such terms are defined elsewhere in that section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb66e0eab-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1933 of act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300y–23"},"text":"section 300y–23 of this title","children":[],"tail":" and subsequently omitted from the Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb66e0eac-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s1244/1/C"},"text":"Pub. L. 117–328, § 1244(1)(C)","children":[],"tail":", substituted “Tribe or Tribal organization” for “tribe or tribal organization” in concluding provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s1241/a/8"},"text":"Pub. L. 117–328, § 1241(a)(8)","children":[],"tail":", substituted “use of substances” for “abuse of alcohol and other drugs” in concluding provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s1244/1/A"},"text":"Pub. L. 117–328, § 1244(1)(A)","children":[],"tail":", substituted “of an Indian Tribe or Tribal organization” for “of an Indian tribe or tribal organization” and “such Tribe” for “such tribe”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s1244/1/B"},"text":"Pub. L. 117–328, § 1244(1)(B)","children":[],"tail":", substituted “Tribe or Tribal organization” for “tribe or tribal organization” and “Secretary under this subpart” for “Secretary under this”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s1244/2"},"text":"Pub. L. 117–328, § 1244(2)","children":[],"tail":", amended par. (2) generally. Prior to amendment, text read as follows: “The amount reserved by the Secretary on the basis of a determination under this paragraph shall be granted to the Indian tribe or tribal organization serving the individuals for whom such a determination has been made.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s1244/3"},"text":"Pub. L. 117–328, § 1244(3)","children":[],"tail":", substituted “Tribe or Tribal organization” for “tribe or tribal organization”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s1244/4"},"text":"Pub. L. 117–328, § 1244(4)","children":[],"tail":", substituted “Definitions” for “Definition” in heading and “The terms ‘Indian Tribe’ and ‘Tribal organization’ have the meanings given the terms ‘Indian tribe’ and ‘tribal organization’ ” for “The terms ‘Indian tribe’ and ‘tribal organization’ have the same meaning given such terms” in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/310"},"text":"Pub. L. 106–310","children":[],"tail":" reenacted heading without change and amended text generally. Prior to amendment, text read as follows: “Each State’s allotment for fiscal year 2000 for programs under this subpart shall be equal to such State’s allotment for such programs for fiscal year 1999, except that, if the amount appropriated in fiscal year 2000 is less than the amount appropriated in fiscal year 1999, then the amount of a State’s allotment under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x–21"},"text":"section 300x–21 of this title","children":[],"tail":" shall be equal to the amount that the State received under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x–21"},"text":"section 300x–21 of this title","children":[],"tail":" in fiscal year 1999 decreased by the percentage by which the amount appropriated for fiscal year 2000 is less than the amount appropriated for such section for fiscal year 1999.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/113"},"text":"Pub. L. 106–113","children":[],"tail":" amended heading and text of subsec. (b) generally. Prior to amendment, text read as follows: “For each of the fiscal years 1993 and 1994, the amount of the allotment required in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x–21"},"text":"section 300x–21 of this title","children":[],"tail":" for a State for the fiscal year involved shall be the greater of—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) the amount determined under subsection (a) of this section for the State for the fiscal year; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) an amount equal to 79.4 percent of the amount received by the State from allotments made pursuant to this part for fiscal year 1992 (including reallotments under section 205(a) of the ADAMHA Reorganization Act).”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277"},"text":"Pub. L. 105–277","children":[],"tail":", temporarily amended subsec. (b) to read as follows: “(b) "},{"tag":"inline","attrib":{},"text":"Minimum allotments for States.—","children":[],"tail":null}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—With respect to fiscal year 1999, the amount of the allotment of a State under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x–21"},"text":"section 300x–21 of this title","children":[],"tail":" shall not be less than the amount the State received under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x–21"},"text":"section 300x–21 of this title","children":[],"tail":" for fiscal year 1998 increased by 30.65 percent of the percentage by which the amount allotted to the States for fiscal year 1999 exceeds the amount allotted to the States for fiscal year 1998."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) ","children":[{"tag":"inline","attrib":{},"text":"Limitation","children":[],"tail":null}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—Except as provided in subparagraph (B), a State shall not receive an allotment under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x–21"},"text":"section 300x–21 of this title","children":[],"tail":" for fiscal year 1999 in an amount that is less than an amount equal to 0.375 percent of the amount appropriated under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x–35/a"},"text":"section 300x–35(a) of this title","children":[],"tail":" for such fiscal year."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) ","children":[{"tag":"inline","attrib":{},"text":"Exception","children":[],"tail":".—In applying subparagraph (A), the Secretary shall ensure that no State receives an increase in its allotment under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x–21"},"text":"section 300x–21 of this title","children":[],"tail":" for fiscal year 1999 (as compared to the amount allotted to the State in the fiscal year 1998) that is in excess of an amount equal to 300 percent of the percentage by which the amount appropriated under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x–35/a"},"text":"section 300x–35(a) of this title","children":[],"tail":" for fiscal year 1999 exceeds the amount appropriated for the prior fiscal year."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) Only for the purposes of calculating minimum allotments under this subsection, any reference to the amount appropriated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x–35/a"},"text":"section 300x–35(a) of this title","children":[],"tail":" for fiscal year 1998, allotments to States under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x–21"},"text":"section 300x–21 of this title","children":[],"tail":" and any references to amounts received by States in fiscal year 1998 shall include amounts appropriated or received under the amendments made by section 105 of the Contract with America Advancement Act of 1996 ("},{"tag":"ref","attrib":{"href":"/us/pl/104/121"},"text":"Public Law 104–121","children":[],"tail":").”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"See Effective and Termination Dates of 1998 Amendment note below.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (c)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/352"},"text":"Pub. L. 102–352","children":[],"tail":" added subpar. (C)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb66e0ead-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb66e0eae-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective and Termination Dates of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277"},"text":"Pub. L. 105–277","children":[],"tail":" effective as if enacted on "},{"tag":"date","attrib":{"date":"1998-10-01"},"text":"Oct. 1, 1998","children":[],"tail":", and applicable only during fiscal year 1999, and upon expiration of fiscal year 1999, subsec. (b) of this section, as in effect on "},{"tag":"date","attrib":{"date":"1998-09-30"},"text":"Sept. 30, 1998","children":[],"tail":", to be applied as if such amendment had not been enacted, see section 101(f) [title II, § 218(c)] of "},{"tag":"ref","attrib":{"href":"/us/pl/105/277"},"text":"Pub. L. 105–277","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x–7"},"text":"section 300x–7 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb66e0eaf-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1992 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/352"},"text":"Pub. L. 102–352","children":[],"tail":" effective immediately upon effectuation of amendment made by "},{"tag":"ref","attrib":{"href":"/us/pl/102/321"},"text":"Pub. L. 102–321","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/102/352/s3/1"},"text":"section 3(1) of Pub. L. 102–352","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s285n"},"text":"section 285n of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
