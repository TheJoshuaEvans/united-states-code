{"tag":"section","attrib":{"id":"idbea50628-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8819"},"text":null,"children":[{"tag":"num","attrib":{"value":"8819"},"text":"§ 8819.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review; reorganization","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbea50629-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8819/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The President shall review periodically the progress of the Secretary of Agriculture and the Secretary of Energy in carrying out the purposes of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbea5062a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8819/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the President determines it necessary in order to achieve such purposes the President may, in accordance with the provisions of chapter 9 of title 5, provide for a reorganization, including any required realignment of the respective programs of the Secretaries under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbea5062b-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/294/tII/s219"},"text":"Pub. L. 96–294, title II, § 219","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-06-30"},"text":"June 30, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/695"},"text":"94 Stat. 695","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
