{"tag":"section","attrib":{"id":"idbeb35dd9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9213"},"text":null,"children":[{"tag":"num","attrib":{"value":"9213"},"text":"§ 9213.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbeb35dda-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9213/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is authorized to be appropriated to the Secretary to carry out this chapter (1) for the fiscal year ending ","children":[{"tag":"date","attrib":{"date":"1981-09-30"},"text":"September 30, 1981","children":[],"tail":", the sum of $100,000,000 (of which $10,000,000 shall be available exclusively for purposes of "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s9206"},"text":"section 9206 of this title","children":[],"tail":"), and (2) for each fiscal year beginning after that date, such sum as may be authorized by legislation hereafter enacted."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbeb35ddb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9213/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In each of the five years of the small wind energy systems program, at least 25 per centum of the total authorization for appropriations under subsection (a) shall be for small wind energy systems activities, including supporting activities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbeb35ddc-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/345/s14"},"text":"Pub. L. 96–345, § 14","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-09-08"},"text":"Sept. 8, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1146"},"text":"94 Stat. 1146","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
