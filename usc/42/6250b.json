{"tag":"section","attrib":{"id":"idbd7622b2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6250b"},"text":null,"children":[{"tag":"num","attrib":{"value":"6250b"},"text":"§ 6250b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conditions for release; plan","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd7622b3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6250b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Finding","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may sell products from the Reserve only upon a finding by the President that there is a severe energy supply interruption. Such a finding may be made only if he determines that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd7622b4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6250b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a dislocation in the heating oil market has resulted from such interruption; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd7622b5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6250b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a circumstance, other than that described in paragraph (1), exists that constitutes a regional supply shortage of significant scope and duration and that action taken under this section would assist directly and significantly in reducing the adverse impact of such shortage.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd7622b6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6250b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section a “dislocation in the heating oil market” shall be deemed to occur only when—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd7622b7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6250b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The price differential between crude oil, as reflected in an industry daily publication such as “Platt’s Oilgram Price Report” or “Oil Daily” and No. 2 heating oil, as reported in the Energy Information Administration’s retail price data for the Northeast, increases by more than 60 percent over its 5-year rolling average for the months of mid-October through March (considered as a heating season average), and continues for 7 consecutive days; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd7622b8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6250b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The price differential continues to increase during the most recent week for which price information is available.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd7622b9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6250b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continuing evaluation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall conduct a continuing evaluation of the residential price data supplied by the Energy Information Administration for the Northeast and data on crude oil prices from published sources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd7622ba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6250b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Release of petroleum distillate","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"After consultation with the heating oil industry, the Secretary shall determine procedures governing the release of petroleum distillate from the Reserve. The procedures shall provide that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd7622bb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6250b/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Secretary may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd7622bc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6250b/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sell petroleum distillate from the Reserve through a competitive process, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd7622bd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6250b/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enter into exchange agreements for the petroleum distillate that results ","children":[{"tag":"ref","attrib":{"idref":"fn003452"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003452"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “result”."}],"tail":" in the Secretary receiving a greater volume of petroleum distillate as repayment than the volume provided to the acquirer;"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd7622be-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6250b/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in all such sales or exchanges, the Secretary shall receive revenue or its equivalent in petroleum distillate that provides the Department with fair market value. At no time may the oil be sold or exchanged resulting in a loss of revenue or value to the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd7622bf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6250b/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary shall only sell or dispose of the oil in the Reserve to entities customarily engaged in the sale and distribution of petroleum distillate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd7622c0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6250b/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plan","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Within 45 days of ","children":[{"tag":"date","attrib":{"date":"2000-11-09"},"text":"November 9, 2000","children":[],"tail":", the Secretary shall transmit to the President and, if the President approves, to the Congress a plan describing—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd7622c1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6250b/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the acquisition of storage and related facilities or storage services for the Reserve, including the potential use of storage facilities not currently in use;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd7622c2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6250b/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the acquisition of petroleum distillate for storage in the Reserve;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd7622c3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6250b/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the anticipated methods of disposition of petroleum distillate from the Reserve;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd7622c4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6250b/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the estimated costs of establishment, maintenance, and operation of the Reserve;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd7622c5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6250b/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" efforts the Department will take to minimize any potential need for future drawdowns and ensure that distributors and importers are not discouraged from maintaining and increasing supplies to the Northeast; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd7622c6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6250b/e/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" actions to ensure quality of the petroleum distillate in the Reserve.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd7622c7-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/163/tI/s183"},"text":"Pub. L. 94–163, title I, § 183","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/469/tII/s201/a/3"},"text":"Pub. L. 106–469, title II, § 201(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-09"},"text":"Nov. 9, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2035"},"text":"114 Stat. 2035","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/58/tIII/s301/d"},"text":"Pub. L. 109–58, title III, § 301(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/684"},"text":"119 Stat. 684","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd7622c8-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd7622c9-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd7622ca-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2005—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58"},"text":"Pub. L. 109–58","children":[],"tail":" substituted “by more than 60 percent over its 5-year rolling average for the months of mid-October through March (considered as a heating season average)” for “by more tan 60 percent over its 5 year rolling average for the months of mid-October through March”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
