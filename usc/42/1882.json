{"tag":"section","attrib":{"id":"idbb9e07a7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1882"},"text":null,"children":[{"tag":"num","attrib":{"value":"1882"},"text":"§ 1882.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information furnished to Congressional committees","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of this or any other Act, the Director of the National Science Foundation and the National Science Board shall keep the Committee on Labor and Human Resources of the Senate and the Committee on Science, Space, and Technology of the House of Representatives fully and currently informed with respect to all of the activities of the National Science Foundation.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbb9e07a8-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/44/s9"},"text":"Pub. L. 96–44, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-08-02"},"text":"Aug. 2, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/335"},"text":"93 Stat. 335","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/159/tI/s109/i"},"text":"Pub. L. 99–159, title I, § 109(i)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-11-22"},"text":"Nov. 22, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/890"},"text":"99 Stat. 890","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/437/s15/c/2"},"text":"Pub. L. 103–437, § 15(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-11-02"},"text":"Nov. 2, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4591"},"text":"108 Stat. 4591","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbb9e07a9-3a70-11f1-ae07-e4213316b5fa"},"text":"\n"