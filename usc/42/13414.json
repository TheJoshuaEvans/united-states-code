{"tag":"section","attrib":{"id":"idbfc0d6e8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13414"},"text":null,"children":[{"tag":"num","attrib":{"value":"13414"},"text":"§ 13414.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Natural gas end-use technologies","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary shall carry out a 5-year program, in accordance with sections 13541 and 13542 of this title, on new and advanced natural gas utilization technologies including, but not limited to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfc0d6e9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13414/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" stationary source emissions control and efficiency improvements including combustion systems, industrial processes, cogeneration, and waste fuels; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc0d6ea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13414/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" natural gas storage including increased deliverability from existing gas storage facilities and new capabilities for storage near demand centers, and on-site storage at major energy consuming facilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfc0d6eb-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/tXX/s2014"},"text":"Pub. L. 102–486, title XX, § 2014","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3060"},"text":"106 Stat. 3060","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
