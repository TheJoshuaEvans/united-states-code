{"tag":"section","attrib":{"id":"idb58d9971-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s289e"},"text":null,"children":[{"tag":"num","attrib":{"value":"289e"},"text":"§ 289e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb58d9972-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s289e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Appropriations to carry out the purposes of this subchapter, unless otherwise expressly provided, may be expended in the District of Columbia for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb58d9973-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s289e/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" personal services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb58d9974-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s289e/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" stenographic recording and translating services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb58d9975-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s289e/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" travel expenses (including the expenses of attendance at meetings when specifically authorized by the Secretary);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb58d9976-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s289e/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rental;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb58d9977-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s289e/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supplies and equipment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb58d9978-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s289e/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" purchase and exchange of medical books, books of reference, directories, periodicals, newspapers, and press clippings;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb58d9979-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s289e/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" purchase, operation, and maintenance of passenger motor vehicles;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb58d997a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s289e/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" printing and binding (in addition to that otherwise provided by law); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb58d997b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s289e/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all other necessary expenses in carrying out this subchapter.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Such appropriations may be expended by contract if deemed necessary, without regard to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s6101"},"text":"section 6101 of title 41","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb58d997c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s289e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb58d997d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s289e/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" None of the amounts appropriated under this chapter for the purposes of this subchapter may be obligated for the construction of facilities (including the acquisition of land) unless a provision of this subchapter establishes express authority for such purpose and unless the Act making appropriations under such provision specifies that the amounts appropriated are available for such purpose.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb58d997e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s289e/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any grants, cooperative agreements, or contracts authorized in this subchapter for the construction of facilities may be awarded only on a competitive basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb58d997f-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title IV, § 496, as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/158/s2"},"text":"Pub. L. 99–158, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-11-20"},"text":"Nov. 20, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/877"},"text":"99 Stat. 877","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/190/s8"},"text":"Pub. L. 101–190, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-29"},"text":"Nov. 29, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1695"},"text":"103 Stat. 1695","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/43/tXX/s2008/b/15"},"text":"Pub. L. 103–43, title XX, § 2008(b)(15)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-06-10"},"text":"June 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/211"},"text":"107 Stat. 211","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb58d9980-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb58d9981-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb58d9982-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsec. (a), “","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s6101"},"text":"section 6101 of title 41","children":[],"tail":"” substituted for “section 3709 of the Revised Statutes ("},{"tag":"ref","attrib":{"href":"/us/usc/t41/s5"},"text":"41 U.S.C. 5","children":[],"tail":")” on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/111/350/s6/c"},"text":"Pub. L. 111–350, § 6(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3854"},"text":"124 Stat. 3854","children":[],"tail":", which Act enacted Title 41, Public Contracts."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb58d9983-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1993—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/43"},"text":"Pub. L. 103–43","children":[],"tail":" substituted “Appropriations to carry out the purposes of this subchapter” for “Such appropriations”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/190"},"text":"Pub. L. 101–190","children":[],"tail":" designated existing provisions as subsec. (a), struck out first sentence which read as follows: “Appropriations to carry out the purposes of this subchapter shall be available for the acquisition of land or the erection of buildings only if so specified.”, and added subsec. (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb58d9984-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb58d9985-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Construction of Biomedical Facilities for Development and Breeding of Specialized Strains of Mice","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/190"},"text":"Pub. L. 101–190","children":[],"tail":", §§ 1–7, "},{"tag":"date","attrib":{"date":"1989-11-29"},"text":"Nov. 29, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1691-1695"},"text":"103 Stat. 1691–1695","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/101/374/s4/a"},"text":"Pub. L. 101–374, § 4(a)","children":[],"tail":", (c)(1), "},{"tag":"date","attrib":{"date":"1990-08-15"},"text":"Aug. 15, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/458"},"text":"104 Stat. 458","children":[],"tail":", 459, authorized a reservation of funds for making a grant to construct facilities for development and breeding of specialized strains of mice for use in biomedical research, provided for a competitive grant award process, required applicant for the grant to agree to a twenty-year transferable obligation, restricted grant applicant to public or nonprofit private status, with assurances of sufficient financial resources, set forth other grant requirements, and specified consequences of failure to comply with agreements and violation of the twenty-year obligation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
