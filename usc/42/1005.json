{"tag":"section","attrib":{"id":"idb8059ee7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1005"},"text":null,"children":[{"tag":"num","attrib":{"value":"1005"},"text":"§ 1005.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Benefit amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The benefit under this subchapter payable to a qualified individual for any month shall be in an amount equal to 75 percent of the Federal benefit rate under subchapter XVI for the month, reduced by the amount of the qualified individual’s benefit income for the month.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb8059ee8-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title VIII, § 805, as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/169/tII/s251/a"},"text":"Pub. L. 106–169, title II, § 251(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-12-14"},"text":"Dec. 14, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1845"},"text":"113 Stat. 1845","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8059ee9-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8059eea-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb8059eeb-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For prior provisions, see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1001"},"text":"section 1001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
