{"tag":"section","attrib":{"id":"idc03cbcb6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17392"},"text":null,"children":[{"tag":"num","attrib":{"value":"17392"},"text":"§ 17392.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Micro-grid and integrated micro-grid systems program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc03cbcb7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17392/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc03cbcb8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17392/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Integrated micro-grid system","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “integrated micro-grid system” means a micro-grid system that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc03cbcb9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17392/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" comprises generation from both conventional and renewable energy resources; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc03cbcba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17392/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may use grid-scale energy storage.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc03cbcbb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17392/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Isolated community","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “isolated community” means a community that is powered by a stand-alone electric generation and distribution system without the economic and reliability benefits of connection to a regional electric grid.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc03cbcbc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17392/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Micro-grid system","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “micro-grid system” means a localized grid that operates autonomously, regardless of whether the grid can operate in connection with another grid.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc03cbcbd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17392/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rural electric cooperative","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “rural electric cooperative” means an electric cooperative (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s796"},"text":"section 796 of title 16","children":[],"tail":") that sells electric energy to persons in rural areas."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc03cbcbe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17392/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Strategy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “strategy” means the strategy developed pursuant to subsection (b)(2)(B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc03cbcbf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17392/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc03cbcc0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17392/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Energy (in this section referred to as the “Secretary”) shall establish a program to promote the development of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc03cbcc1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17392/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" integrated micro-grid systems for isolated communities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc03cbcc2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17392/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" micro-grid systems to increase the resilience of critical infrastructure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc03cbcc3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17392/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The program established under paragraph (1) shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc03cbcc4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17392/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" develop a feasibility assessment for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc03cbcc5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17392/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" integrated micro-grid systems in isolated communities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc03cbcc6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17392/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" micro-grid systems to enhance the resilience of critical infrastructure;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc03cbcc7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17392/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop an implementation strategy, in accordance with paragraph (3), to promote the development of integrated micro-grid systems for isolated communities, particularly for those communities exposed to extreme weather conditions and high energy costs, including electricity, space heating and cooling, and transportation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc03cbcc8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17392/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop an implementation strategy to promote the development of micro-grid systems that increase the resilience of critical infrastructure; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc03cbcc9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17392/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry out cost-shared demonstration projects, based upon the strategies developed under subparagraph (B) that include the development of physical and cybersecurity plans to take appropriate measures to protect and secure the electric grid.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc03cbcca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17392/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements for strategy","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In developing the strategy under paragraph (2)(B), the Secretary shall consider—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc03cbccb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17392/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" opportunities for improving the efficiency of existing integrated micro-grid systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc03cbccc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17392/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the capacity of the local workforce to operate, maintain, and repair a integrated micro-grid system as well as opportunities to improve that capacity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc03cbccd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17392/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" leveraging existing capacity within local or regional research organizations, such as organizations based at institutions of higher education, to support development of integrated micro-grid systems, including by testing novel components and systems prior to field deployment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc03cbcce-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17392/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the need for basic infrastructure to develop, deploy, and sustain a integrated micro-grid system;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc03cbccf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17392/b/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" input of traditional knowledge from local leaders of isolated communities in the development of a integrated micro-grid system;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc03cbcd0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17392/b/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the impact of integrated micro-grid systems on defense, homeland security, economic development, and environmental interests;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc03cbcd1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17392/b/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" opportunities to leverage existing interagency coordination efforts and recommendations for new interagency coordination efforts to minimize unnecessary overhead, mobilization, and other project costs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc03cbcd2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17392/b/3/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other criteria the Secretary determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc03cbcd3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17392/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collaboration","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The program established under subsection (b)(1) shall be carried out in collaboration with relevant stakeholders, including, as appropriate—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc03cbcd4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17392/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc03cbcd5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17392/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Indian Tribes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc03cbcd6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17392/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" regional entities and regulators;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc03cbcd7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17392/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" units of local government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc03cbcd8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17392/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" institutions of higher education; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc03cbcd9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17392/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" private sector entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc03cbcda-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17392/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2020-12-27"},"text":"December 27, 2020","children":[],"tail":", and annually thereafter until calendar year 2029, the Secretary shall submit to the Committee on Energy and Natural Resources of the Senate and the Committee on Energy and Commerce of the House of Representatives a report on the efforts to implement the program established under subsection (b)(1) and the status of the strategy developed under subsection (b)(2)(B)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc03cbcdb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17392/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Barriers and benefits to micro-grid systems","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc03cbcdc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17392/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 270 days after ","children":[{"tag":"date","attrib":{"date":"2020-12-27"},"text":"December 27, 2020","children":[],"tail":", the Secretary shall submit to the Committee on Energy and Natural Resources of the Senate and the Committee on Energy and Commerce of the House of Representatives a report on the benefits of, and barriers to, implementing resilient micro-grid systems that are—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc03cbcdd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17392/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc03cbcde-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17392/e/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" owned or operated by an isolated community, rural electric cooperative, or municipal government; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc03cbcdf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17392/e/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operated on behalf of a municipal government or rural electric cooperative; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc03cbce0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17392/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" designed to maximize the use of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc03cbce1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17392/e/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" energy-generation facilities owned or operated by isolated communities; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc03cbce2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17392/e/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a municipal or rural electric cooperative energy-generation facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc03cbce3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17392/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants to overcome barriers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall award grants of not more than $500,000 to not fewer than 20 municipal governments, rural electric cooperatives, or isolated communities, up to a total of $15,000,000, each year to assist those municipal governments, rural electric cooperatives, and isolated communities in overcoming the barriers identified in the report under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc03cbce4-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dZ/tVIII/s8011"},"text":"Pub. L. 116–260, div. Z, title VIII, § 8011","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2589"},"text":"134 Stat. 2589","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc03cbce5-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc03cbce6-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idc03cbce7-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Energy Act of 2020, and not as part of the Energy Independence and Security Act of 2007 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
