{"tag":"section","attrib":{"id":"idb5cbdb21-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s291j–10"},"text":null,"children":[{"tag":"num","attrib":{"value":"291j–10"},"text":"§ 291j–10.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Grants under this part shall be paid in advance or by way of reimbursement, in such installments and on such conditions, as in the judgment of the Secretary will best carry out the purposes of this part.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb5cbdb22-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title VI, § 633, as added "},{"tag":"ref","attrib":{"href":"/us/pl/91/296/tIII/s301"},"text":"Pub. L. 91–296, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-06-30"},"text":"June 30, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/351"},"text":"84 Stat. 351","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
