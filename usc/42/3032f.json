{"tag":"section","attrib":{"id":"idbc5cc42c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032f"},"text":null,"children":[{"tag":"num","attrib":{"value":"3032f"},"text":"§ 3032f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Demonstration, support, and research projects for multigenerational and civic engagement activities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbc5cc42d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032f/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants and contracts","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Assistant Secretary shall award grants to and enter into contracts with eligible organizations to carry out projects, serving individuals in younger generations and older individuals, to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc5cc42e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032f/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide opportunities for older individuals to participate in multigenerational activities and civic engagement activities that contribute to the health and wellness of older individuals and individuals in younger generations by promoting—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc5cc42f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032f/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meaningful roles for participants;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc5cc430-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032f/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reciprocity in relationship building;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc5cc431-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032f/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reduced social isolation and improved participant social connectedness;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc5cc432-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032f/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improved economic well-being for older individuals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc5cc433-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032f/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increased lifelong learning; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc5cc434-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032f/a/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" support for caregivers of families by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbc5cc435-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032f/a/1/F/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing support for older relative caregivers (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3030s/a"},"text":"section 3030s(a) of this title","children":[],"tail":") raising children (such as support for kinship navigator programs); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc5cc436-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032f/a/1/F/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" involving volunteers who are older individuals who provide support and information to families who have a child with a disability or chronic illness, or other families in need of such family support;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc5cc437-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032f/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate multigenerational activities and civic engagement activities, including multigenerational nutrition and meal service programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc5cc438-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032f/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote volunteerism, including by providing opportunities for older individuals to become a mentor to individuals in younger generations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc5cc439-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032f/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitate development of, and participation in, multigenerational activities and civic engagement activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc5cc43a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032f/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant and contract periods","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each grant awarded and contract entered into under subsection (a) shall be for a period of not less than 36 months.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc5cc43b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032f/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc5cc43c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032f/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An eligible organization shall use funds made available under a grant awarded, or a contract entered into, under this section to carry out a project described in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc5cc43d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032f/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provision of projects through grantees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In awarding grants and entering into contracts under this section, the Assistant Secretary shall ensure that such grants and contracts are for the projects that satisfy each requirement under paragraphs (1) through (4) of subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc5cc43e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032f/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preference","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In awarding grants and entering into contracts to carry out a project described in subsection (a), the Assistant Secretary shall give preference to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc5cc43f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032f/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" eligible organizations with a demonstrated record of carrying out, intent to carry out, or intent to partner with local organizations or multiservice organizations to carry out, multigenerational activities or civic engagement activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc5cc440-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032f/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" eligible organizations proposing multigenerational activity projects that will serve older individuals and communities with the greatest need (with particular attention to low-income minority individuals, older individuals with limited English proficiency, older individuals residing in rural areas, and low-income minority communities);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc5cc441-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032f/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" eligible organizations proposing civic engagement projects that will serve communities with the greatest need;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc5cc442-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032f/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" eligible organizations with the capacity to develop meaningful roles and assignments that use the time, skills, and experience of older individuals to serve public and nonprofit organizations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc5cc443-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032f/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" eligible organizations proposing multigenerational activity projects that utilize shared site programs, such as collocated child care and long-term care facilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc5cc444-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032f/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be eligible to receive a grant or enter into a contract under subsection (a), an organization shall submit an application to the Assistant Secretary at such time, in such manner, and accompanied by such information as the Assistant Secretary may reasonably require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc5cc445-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032f/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible organizations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Organizations eligible to receive a grant or enter into a contract under subsection (a) shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc5cc446-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032f/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be a State, an area agency on aging, or an organization that provides opportunities for older individuals to participate in activities described in such subsection; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc5cc447-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032f/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have the capacity to conduct the coordination, promotion, and facilitation described in such subsection through the use of multigenerational coordinators.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc5cc448-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032f/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc5cc449-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032f/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 3 years after ","children":[{"tag":"date","attrib":{"date":"2020-03-25"},"text":"March 25, 2020","children":[],"tail":", the Assistant Secretary shall, through data submitted by organizations carrying out projects through grants or contracts under this section, evaluate the activities supported through such grants and contracts to determine—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc5cc44a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032f/g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effectiveness of such activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc5cc44b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032f/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the impact of such activities on the community being served and the organization providing the activities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc5cc44c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032f/g/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the impact of such activities on older individuals participating in such projects.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc5cc44d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032f/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 6 months after the Assistant Secretary completes the evaluation under paragraph (1), the Assistant Secretary shall prepare and submit to the Speaker of the House of Representatives and the President pro tempore of the Senate a report that assesses such evaluation and contains, at a minimum—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc5cc44e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032f/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the names or descriptive titles of the projects funded under subsection (a);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc5cc44f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032f/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the nature and operation of such projects;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc5cc450-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032f/g/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the names and addresses of organizations that conducted such projects;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc5cc451-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032f/g/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the methods and success of such projects in recruiting older individuals as employees and as volunteers to participate in the projects;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc5cc452-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032f/g/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the success of the projects in retaining older individuals participating in such projects as employees and as volunteers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc5cc453-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032f/g/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the rate of turnover of older individuals who are employees or volunteers in such projects;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc5cc454-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032f/g/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a strategy for disseminating the findings resulting from such projects; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc5cc455-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032f/g/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any policy change recommendations relating to such projects.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc5cc456-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032f/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As used in this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc5cc457-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032f/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Multigenerational activity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “multigenerational activity” means an activity that provides an opportunity for interaction between 2 or more individuals of different generations, including activities connecting older individuals and youth in a child care program, a youth day care program, an educational assistance program, an at-risk youth intervention program, a juvenile delinquency treatment program, a before- or after-school program, a library program, or a family support program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc5cc458-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032f/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Multigenerational coordinator","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “multigenerational coordinator” means a person who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc5cc459-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032f/h/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" builds the capacity of public and nonprofit organizations to develop meaningful roles and assignments, that use the time, skill, and experience of older individuals to serve those organizations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc5f345a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032f/h/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" nurtures productive, sustainable working relationships between—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbc5f345b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032f/h/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" older individuals; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc5f345c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032f/h/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" individuals in younger generations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc5f345d-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/73/tIV/s417"},"text":"Pub. L. 89–73, title IV, § 417","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/501/tIV/s401"},"text":"Pub. L. 106–501, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-13"},"text":"Nov. 13, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2261"},"text":"114 Stat. 2261","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/365/tIV/s406"},"text":"Pub. L. 109–365, title IV, § 406","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2555"},"text":"120 Stat. 2555","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/144/s5/e"},"text":"Pub. L. 114–144, § 5(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-04-19"},"text":"Apr. 19, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/342"},"text":"130 Stat. 342","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/131/tIII/s306"},"text":"Pub. L. 116–131, title III, § 306","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-03-25"},"text":"Mar. 25, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/264"},"text":"134 Stat. 264","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc5f345e-3a70-11f1-a