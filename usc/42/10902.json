{"tag":"section","attrib":{"id":"idbf31b5de-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10902"},"text":null,"children":[{"tag":"num","attrib":{"value":"10902"},"text":"§ 10902.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application for grants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf31b5df-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10902/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State desiring to participate in the grant program established by this chapter shall submit an application to the Secretary in such form as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf31b5e0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10902/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents of applications","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A State’s application shall contain appropriate assurances that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf31b5e1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10902/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" scholarship assistance made available with funds provided under this chapter will be awarded—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf31b5e2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10902/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" only to eligible individuals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf31b5e3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10902/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on the basis of the financial need of such individuals; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf31b5e4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10902/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in amounts sufficient to cover the cost of application, assessment, and credentialing (including, at the option of the State, any training necessary for credentialing) for the Child Development Associate credential for such individuals;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf31b5e5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10902/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not more than 35 percent of the funds received under this chapter by a State may be used to provide scholarship assistance under paragraph (1) to cover the cost of training described in paragraph (1)(C); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf31b5e6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10902/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not more than 10 percent of the funds received by the State under this chapter will be used for the costs of administering the program established in such State to award such assistance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf31b5e7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10902/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Equitable distribution","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In making grants under this chapter, the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf31b5e8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10902/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" distribute such grants equitably among States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf31b5e9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10902/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that the needs of rural and urban areas are appropriately addressed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf31b5ea-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/425/tVI/s603"},"text":"Pub. L. 99–425, title VI, § 603","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-09-30"},"text":"Sept. 30, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/976"},"text":"100 Stat. 976","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/501/tV/s501"},"text":"Pub. L. 101–501, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-03"},"text":"Nov. 3, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1256"},"text":"104 Stat. 1256","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf31b5eb-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf31b5ec-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbf31b5ed-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1990—Subsec. (b)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/501/s501/a"},"text":"Pub. L. 101–501, § 501(a)","children":[],"tail":", (b)(1), inserted “(including, at the option of the State, any training necessary for credentialing)” after “credentialing” and struck out “and” at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2), (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/501/s501/b/2"},"text":"Pub. L. 101–501, § 501(b)(2)","children":[],"tail":", (3), added par. (2) and redesignated former par. (2) as (3)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbf31b5ee-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbf31b5ef-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1990 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/501"},"text":"Pub. L. 101–501","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1990-10-01"},"text":"Oct. 1, 1990","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/101/501/s1001/a"},"text":"section 1001(a) of Pub. L. 101–501","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s8621"},"text":"section 8621 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbf31b5f0-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1986-10-01"},"text":"Oct. 1, 1986","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/425/s1001"},"text":"section 1001 of Pub. L. 99–425","children":[],"tail":", set out as an Effective Date of 1986 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s8621"},"text":"section 8621 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
