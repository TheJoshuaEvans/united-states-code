{"tag":"section","attrib":{"id":"idc0144dac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16411"},"text":null,"children":[{"tag":"num","attrib":{"value":"16411"},"text":"§ 16411.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Workforce trends and traineeship grants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc0144dad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16411/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0144dae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16411/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Energy technology industry","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “energy technology industry” includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0144daf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16411/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a renewable energy industry;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0144db0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16411/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a company that develops or commercializes a device to increase energy efficiency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0144db1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16411/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the oil and gas industry;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0144db2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16411/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the nuclear power industry;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0144db3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16411/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the coal industry;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0144db4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16411/a/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the electric utility industry; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0144db5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16411/a/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other industrial sector, as the Secretary determines to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0144db6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16411/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Skilled technical personnel","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “skilled technical personnel” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0144db7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16411/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" journey- and apprentice-level workers who are enrolled in, or have completed, a federally-recognized or State-recognized apprenticeship program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0144db8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16411/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other skilled workers in energy technology industries, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0144db9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16411/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Workforce trends","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0144dba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16411/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Monitoring","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, in consultation with, and using data collected by, the Secretary of Labor, shall monitor trends in the workforce of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0144dbb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16411/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" skilled technical personnel that support energy technology industries; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0144dbc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16411/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" electric power and transmission engineers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0144dbd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16411/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report on trends","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":", the Secretary shall submit to Congress a report on current trends under paragraph (1), with recommendations (as appropriate) to meet the future labor requirements for the energy technology industries."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0144dbe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16411/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report on shortage","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As soon as practicable after the date on which the Secretary identifies or predicts a significant national shortage of skilled technical personnel in one or more energy technology industries, the Secretary shall submit to Congress a report describing the shortage.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0144dbf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16411/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Traineeship grants for skilled technical personnel","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in consultation with the Secretary of Labor, may establish programs in the appropriate offices of the Department under which the Secretary provides grants to enhance training (including distance learning) for any workforce category for which a shortage is identified or predicted under subsection (b)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0144dc0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16411/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this section $20,000,000 for each of fiscal years 2006 through 2008.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc0144dc1-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tXI/s1101"},"text":"Pub. L. 109–58, title XI, § 1101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/937"},"text":"119 Stat. 937","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
