{"tag":"section","attrib":{"id":"idbfb9aa99-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13292"},"text":null,"children":[{"tag":"num","attrib":{"value":"13292"},"text":"§ 13292.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Proposals","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfb9aa9a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13292/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Solicitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than one year after ","children":[{"tag":"date","attrib":{"date":"1992-10-24"},"text":"October 24, 1992","children":[],"tail":", the Secretary shall solicit proposals from non-Federal persons, including fleet operators, for projects under this part. Within 240 days after proposals have been solicited, the Secretary shall select proposals."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfb9aa9b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13292/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfb9aa9c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13292/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall provide financial assistance to no more than 10 projects under this part, unless the Secretary determines that the total amount of available funds is not likely to be otherwise used.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfb9aa9d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13292/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The proposals selected by the Secretary shall, to the extent practicable, represent geographically and climatically diverse regions of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfb9aa9e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13292/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The aggregate Federal financial assistance for each project under this part may not exceed $4,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfb9aa9f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13292/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Projects","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The infrastructure and support systems programs for which projects are selected under this part may address—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfb9aaa0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13292/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the ability to service electric motor vehicles and to provide or service associated equipment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfb9aaa1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13292/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the installation of charging facilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfb9aaa2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13292/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rates and cost recovery for electric utilities who invest in infrastructure capital-related expenditures;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfb9aaa3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13292/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development of safety and health procedures and guidelines related to battery charging, watering, and emissions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfb9aaa4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13292/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the conduct of information dissemination programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfb9aaa5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13292/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other subjects as the Secretary considers necessary in order to address the infrastructure and support systems needed to support the development and use of energy storage technologies, including advanced batteries, and the demonstration of electric motor vehicles.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfb9aaa6-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/tVI/s622"},"text":"Pub. L. 102–486, title VI, § 622","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2904"},"text":"106 Stat. 2904","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
