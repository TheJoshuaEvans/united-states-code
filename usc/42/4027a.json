{"tag":"section","attrib":{"id":"idbcadf14b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4027a"},"text":null,"children":[{"tag":"num","attrib":{"value":"4027a"},"text":"§ 4027a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report of the Administrator on activities under the National Flood Insurance Program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbcadf14c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4027a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall, on an annual basis, submit a full report on the operations, activities, budget, receipts, and expenditures of the National Flood Insurance Program for the preceding 12-month period to the Committee on Banking, Housing, and Urban Affairs of the Senate and the Committee on Financial Services of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcadf14d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4027a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each report required under paragraph (1) shall be submitted to the committees described in paragraph (1) not later than 3 months following the end of each fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcadf14e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4027a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each report required under paragraph (1) shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbcadf14f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4027a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the current financial condition and income statement of the National Flood Insurance Fund established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4017"},"text":"section 4017 of this title","children":[],"tail":", including—"}],"tail":null},{"tag":"clause","attrib":{"id":"idbcadf150-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4027a/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" premiums paid into such Fund;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbcadf151-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4027a/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" policy claims against such Fund; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbcadf152-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4027a/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expenses in administering such Fund;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcadf153-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4027a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number and face value of all policies issued under the National Flood Insurance Program that are in force;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcadf154-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4027a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description and summary of the losses attributable to repetitive loss structures;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcadf155-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4027a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a description and summary of all losses incurred by the National Flood Insurance Program due to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbcadf156-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4027a/3/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hurricane related damage; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbcadf157-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4027a/3/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nonhurricane related damage;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcadf158-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4027a/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amounts made available by the Administrator for mitigation assistance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4104c/c/4"},"text":"section 4104c(c)(4) of this title","children":[],"tail":", as so redesignated by this Act, for the purchase of properties substantially damaged by flood for that fiscal year, and the actual number of flood damaged properties purchased and the total cost expended to purchase such properties;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcadf159-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4027a/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the estimate of the Administrator as to the average historical loss year, and the basis for that estimate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcadf15a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4027a/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the estimate of the Administrator as to the maximum amount of claims that the National Flood Insurance Program would have to expend in the event of a catastrophic year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcadf15b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4027a/3/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the average—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbcadf15c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4027a/3/H/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" amount of insurance carried per flood insurance policy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbcadf15d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4027a/3/H/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" premium per flood insurance policy; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbcadf15e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4027a/3/H/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" loss per flood insurance policy; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcadf15f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4027a/3/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of claims involving damages in excess of the maximum amount of flood insurance available under the National Flood Insurance Program and the sum of the amount of all damages in excess of such amount.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbcadf160-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141/dF/tII/s100231/b"},"text":"Pub. L. 112–141, div. F, title II, § 100231(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-06"},"text":"July 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/950"},"text":"126 Stat. 950","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbcadf161-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbcadf162-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbcadf163-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in par. (3)(E), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141"},"text":"Pub. L. 112–141","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-06"},"text":"July 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/405"},"text":"126 Stat. 405","children":[],"tail":", known as the Moving Ahead for Progress in the 21st Century Act and also as the MAP–21. For complete classification of this Act to the Code, see Short Title of 2012 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t23/s101"},"text":"section 101 of Title 23","children":[],"tail":", Highways, and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbcadf164-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Biggert-Waters Flood Insurance Reform Act of 2012, and also as part of the Moving Ahead for Progress in the 21st Century Act, also known as the MAP–21, and not as part of the National Flood Insurance Act of 1968 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbcadf165-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idbcadf166-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definitions of terms used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4004"},"text":"section 4004 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
