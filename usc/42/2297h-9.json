{"tag":"section","attrib":{"id":"idbc1c5f4b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2297h–9"},"text":null,"children":[{"tag":"num","attrib":{"value":"2297h–9"},"text":"§ 2297h–9.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ownership limitations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbc1c5f4c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2297h–9/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Securities limitations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No director, officer, or employee of the Corporation may acquire any securities, or any rights to acquire any securities of the private corporation on terms more favorable than those offered to the general public—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc1c5f4d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2297h–9/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in a public offering designed to transfer ownership of the Corporation to private investors,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc1c5f4e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2297h–9/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pursuant to any agreement, arrangement, or understanding entered into before the privatization date, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc1c5f4f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2297h–9/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" before the election of the directors of the private corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc1c5f50-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2297h–9/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ownership limitation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Immediately following the consummation of the transaction or series of transactions pursuant to which 100 percent of the ownership of the Corporation is transferred to private investors, and for a period of three years thereafter, no person may acquire, directly or indirectly, beneficial ownership of securities representing more than 10 percent of the total votes of all outstanding voting securities of the Corporation. The foregoing limitation shall not apply to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc1c5f51-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2297h–9/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any employee stock ownership plan of the Corporation,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc1c5f52-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2297h–9/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" members of the underwriting syndicate purchasing shares in stabilization transactions in connection with the privatization, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc1c5f53-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2297h–9/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of shares beneficially held in the ordinary course of business for others, any commercial bank, broker-dealer, or clearing agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc1c5f54-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/134/tIII/s3111"},"text":"Pub. L. 104–134, title III, § 3111","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-26"},"text":"Apr. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1321-343"},"text":"110 Stat. 1321–343","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc1c5f55-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc1c5f56-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbc1c5f57-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the USEC Privatization Act and also as part of the Omnibus Consolidated Rescissions and Appropriations Act of 1996, and not as part of the Atomic Energy Act of 1954 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
