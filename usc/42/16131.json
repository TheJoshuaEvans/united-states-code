{"tag":"section","attrib":{"id":"idbff2e39c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16131"},"text":null,"children":[{"tag":"num","attrib":{"value":"16131"},"text":"§ 16131.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this part:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbff2e39d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16131/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrator","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Administrator” means the Administrator of the Environmental Protection Agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff2e39e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16131/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certified engine configuration","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “certified engine configuration” means a new, rebuilt, or remanufactured engine configuration—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbff2e39f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16131/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" that has been certified or verified by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbff2e3a0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16131/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Administrator; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbff2e3a1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16131/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the California Air Resources Board;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff2e3a2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16131/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that meets or is rebuilt or remanufactured to a more stringent set of engine emission standards, as determined by the Administrator; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff2e3a3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16131/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of a certified engine configuration involving the replacement of an existing engine or vehicle, an engine configuration that replaced an engine that was—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbff2e3a4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16131/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" removed from the vehicle; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbff2e3a5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16131/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" returned to the supplier for remanufacturing to a more stringent set of engine emissions standards or for scrappage.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff2e3a6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16131/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible entity” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbff2e3a7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16131/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a regional, State, local, or tribal agency or port authority with jurisdiction over transportation or air quality;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff2e3a8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16131/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a nonprofit organization or institution that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbff2e3a9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16131/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" represents or provides pollution reduction or educational services to persons or organizations that own or operate diesel fleets; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbff2e3aa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16131/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has, as its principal purpose, the promotion of transportation or air quality; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff2e3ab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16131/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any private individual or entity that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbff2e3ac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16131/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is the owner of record of a diesel vehicle or fleet operated pursuant to a contract, license, or lease with a Federal department or agency or an entity described in subparagraph (A); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbff2e3ad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16131/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meets such timely and appropriate requirements as the Administrator may establish for vehicle use and for notice to and approval by the Federal department or agency or entity described in subparagraph (A) with respect to which the owner has entered into a contract, license, or lease as described in clause (i).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff2e3ae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16131/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emerging technology","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “emerging technology” means a technology that is not currently, or has not been previously, certified or verified by the Administrator or the California Air Resources Board but for which an approvable application and test plan has been submitted for verification to the Administrator or the California Air Resources Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff2e3af-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16131/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fleet","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “fleet” means one or more diesel vehicles or mobile or stationary diesel engines.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff2e3b0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16131/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Heavy-duty truck","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “heavy-duty truck” has the meaning given the term “heavy duty vehicle” in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7521"},"text":"section 7521 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff2e3b1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16131/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Medium-duty truck","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “medium-duty truck” has such meaning as shall be determined by the Administrator, by regulation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff2e3b2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16131/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State” means the several States, the District of Columbia, the Commonwealth of Puerto Rico, Guam, the United States Virgin Islands, American Samoa, and the Commonwealth of the Northern Mariana Islands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff2e3b3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16131/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Verified technology","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “verified technology” means a pollution control technology, including a retrofit technology or auxiliary power unit, that has been verified by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbff2e3b4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16131/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Administrator; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff2e3b5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16131/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the California Air Resources Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbff2e3b6-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tVII/s791"},"text":"Pub. L. 109–58, title VII, § 791","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/838"},"text":"119 Stat. 838","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/255/s3/a"},"text":"Pub. L. 110–255, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-06-30"},"text":"June 30, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2423"},"text":"122 Stat. 2423","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/364/s2/a"},"text":"Pub. L. 111–364, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4056"},"text":"124 Stat. 4056","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbff2e3b7-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbff2e3b8-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbff2e3b9-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2011—Par. (3)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/364/s2/a/1"},"text":"Pub. L. 111–364, § 2(a)(1)","children":[],"tail":", added subpar. (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/364/s2/a/2"},"text":"Pub. L. 111–364, § 2(a)(2)","children":[],"tail":", inserted “currently, or has not been previously,” after “that is not”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/364/s2/a/6"},"text":"Pub. L. 111–364, § 2(a)(6)","children":[],"tail":", added par. (8). Former par. (8) redesignated (9)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/364/s2/a/5"},"text":"Pub. L. 111–364, § 2(a)(5)","children":[],"tail":", struck out “, advanced truckstop electrification system,” after “retrofit technology” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/364/s2/a/4"},"text":"Pub. L. 111–364, § 2(a)(4)","children":[],"tail":", redesignated par. (8) as (9). Former par. (9) struck out."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/364/s2/a/3"},"text":"Pub. L. 111–364, § 2(a)(3)","children":[],"tail":", struck out par. (9) which defined “State” to include the District of Columbia."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Par. (9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/255"},"text":"Pub. L. 110–255","children":[],"tail":" added par. (9)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbff2e3ba-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbff2e3bb-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2011 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/364/s4"},"text":"Pub. L. 111–364, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4061"},"text":"124 Stat. 4061","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/364/s4"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Rule","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in subsection (b), the amendments made by section 2 [amending this section and sections 16132 to 16134 and 16137 of this title] shall take effect on ","children":[{"tag":"date","attrib":{"date":"2011-10-01"},"text":"October 1, 2011","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendments made by subsections (a)(4) and (6) and (c)(4) of section 2 [amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16133"},"text":"section 16133 of this title","children":[],"tail":"] shall take effect on the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
