{"tag":"section","attrib":{"id":"idbc666154-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3057e–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"3057e–1"},"text":"§ 3057e–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distribution of funds among tribal organizations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbc666155-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3057e–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maintenance of 1991 amounts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the availability of appropriations to carry out this part, the amount of the grant (if any) made under this part to a tribal organization for fiscal year 1992 and for each subsequent fiscal year shall be not less than the amount of the grant made under this part to the tribal organization for fiscal year 1991.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc666156-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3057e–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of additional amounts appropriated","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the funds appropriated to carry out this part in a fiscal year subsequent to fiscal year 1991 exceed the funds appropriated to carry out this part in fiscal year 1991, then the amount of the grant (if any) made under this part to a tribal organization for the subsequent fiscal year shall be—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc666157-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3057e–1/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increased by such amount as the Assistant Secretary considers to be appropriate, in addition to the amount of any increase required by subsection (a), so that the grant equals or more closely approaches the amount of the grant made under this part to the tribal organization for fiscal year 1980; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc666158-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3057e–1/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an amount the Assistant Secretary considers to be sufficient if the tribal organization did not receive a grant under this part for either fiscal year 1980 or fiscal year 1991.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc666159-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3057e–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Clarification","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc66615a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3057e–1/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this subsection, the term “covered year” means fiscal year 2006 or a subsequent fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc66615b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3057e–1/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consortia of tribal organizations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a tribal organization received a grant under this part for fiscal year 1991 as part of a consortium, the Assistant Secretary shall consider the tribal organization to have received a grant under this part for fiscal year 1991 for purposes of subsections (a) and (b), and shall apply the provisions of subsections (a) and (b)(1) (under the conditions described in subsection (b)) to the tribal organization for each covered year for which the tribal organization submits an application under this part, even if the tribal organization submits—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc66615c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3057e–1/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a separate application from the remaining members of the consortium; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc66615d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3057e–1/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an application as 1 of the remaining members of the consortium.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc66615e-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/73/tVI/s614A"},"text":"Pub. L. 89–73, title VI, § 614A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/375/tVI/s602"},"text":"Pub. L. 102–375, title VI, § 602","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-09-30"},"text":"Sept. 30, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1270"},"text":"106 Stat. 1270","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/171/s3/a/13"},"text":"Pub. L. 103–171, § 3(a)(13)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-02"},"text":"Dec. 2, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1990"},"text":"107 Stat. 1990","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/365/tVI/s601/a"},"text":"Pub. L. 109–365, title VI, § 601(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2590"},"text":"120 Stat. 2590","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc66615f-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc666160-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbc666161-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/365"},"text":"Pub. L. 109–365","children":[],"tail":" added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/171"},"text":"Pub. L. 103–171","children":[],"tail":" substituted “Assistant Secretary” for “Commissioner” in pars. (1) and (2)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbc666162-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbc666163-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2006 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/365/tVI/s601/b"},"text":"Pub. L. 109–365, title VI, § 601(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2590"},"text":"120 Stat. 2590","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/365/tVI/s601/b"},"text":"“The amendment made by subsection (a) [amending this section] shall apply to grants awarded under part A of title VI of the Older Americans Act of 1965 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3057b"},"text":"42 U.S.C. 3057b","children":[],"tail":" et seq.) during the grant period beginning "},{"tag":"date","attrib":{"date":"2008-04-01"},"text":"April 1, 2008","children":[],"tail":", and all subsequent grant periods.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
