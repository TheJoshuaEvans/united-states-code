{"tag":"section","attrib":{"id":"idbdfe1744-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7261"},"text":null,"children":[{"tag":"num","attrib":{"value":"7261"},"text":"§ 7261.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition of copyrights, patents, etc.","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary is authorized to acquire any of the following described rights if the property acquired thereby is for use by or for, or useful to, the Department:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbdfe1745-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7261/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" copyrights, patents, and applications for patents, designs, processes, and manufacturing data;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdfe1746-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7261/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" licenses under copyrights, patents, and applications for patents; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdfe1747-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7261/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" releases, before suit is brought, for past infringement of patents or copyrights.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbdfe1748-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/91/tVI/s651"},"text":"Pub. L. 95–91, title VI, § 651","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-08-04"},"text":"Aug. 4, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/601"},"text":"91 Stat. 601","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
