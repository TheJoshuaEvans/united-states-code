{"tag":"section","attrib":{"id":"idc03cbdde-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17902"},"text":null,"children":[{"tag":"num","attrib":{"value":"17902"},"text":"§ 17902.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application to private entities","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Each agency (as defined in such Executive Order issued on ","children":[{"tag":"date","attrib":{"date":"2006-08-22"},"text":"August 22, 2006","children":[],"tail":", relating to promoting quality and efficient health care in Federal government administered or sponsored health care programs) shall require in contracts or agreements with health care providers, health plans, or health insurance issuers that as each provider, plan, or issuer implements, acquires, or upgrades health information technology systems, it shall utilize, where available, health information technology systems and products that meet standards and implementation specifications adopted under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300jj–14"},"text":"section 300jj–14 of this title","children":[],"tail":", as added by section 13101."},{"tag":"ref","attrib":{"idref":"fn004280"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004280"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc03cbddf-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/5/dA/tXIII/s13112"},"text":"Pub. L. 111–5, div. A, title XIII, § 13112","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-02-17"},"text":"Feb. 17, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/243"},"text":"123 Stat. 243","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc03cbde0-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc03cbde1-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc03cbde2-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Executive Order issued on ","children":[{"tag":"date","attrib":{"date":"2006-08-22"},"text":"August 22, 2006","children":[],"tail":", referred to in text, is Ex. Ord. No. 13410, "},{"tag":"date","attrib":{"date":"2006-08-22"},"text":"Aug. 22, 2006","children":[],"tail":", 71 F.R. 51089, which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300u"},"text":"section 300u of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 13101, referred to in text, means ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/5/dA/s13101"},"text":"section 13101 of div. A of Pub. L. 111–5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
