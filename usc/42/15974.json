{"tag":"section","attrib":{"id":"idbfee2887-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15974"},"text":null,"children":[{"tag":"num","attrib":{"value":"15974"},"text":"§ 15974.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coal gasification","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to provide loan guarantees for a project to produce energy from a plant using integrated gasification combined cycle technology of at least 400 megawatts in capacity that produces power at competitive rates in deregulated energy generation markets and that does not receive any subsidy (direct or indirect) from ratepayers.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbfee2888-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tIV/s414"},"text":"Pub. L. 109–58, title IV, § 414","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/755"},"text":"119 Stat. 755","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
