{"tag":"section","attrib":{"id":"idbfe48b0f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15821"},"text":null,"children":[{"tag":"num","attrib":{"value":"15821"},"text":"§ 15821.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Energy efficient appliance rebate programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfe48b10-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15821/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfe48b11-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15821/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “eligible State” means a State that meets the requirements of subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe48b12-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15821/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Energy Star program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Energy Star program” means the program established by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6294a"},"text":"section 6294a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe48b13-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15821/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Residential Energy Star product","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “residential Energy Star product” means a product for a residence that is rated for energy efficiency under the Energy Star program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe48b14-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15821/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State energy office","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State energy office” means the State agency responsible for developing State energy conservation plans under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6322"},"text":"section 6322 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe48b15-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15821/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State program” means a State energy efficient appliance rebate program described in subsection (b)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfe48b16-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15821/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible States","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A State shall be eligible to receive an allocation under subsection (c) if the State—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfe48b17-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15821/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishes (or has established) a State energy efficient appliance rebate program to provide rebates to residential consumers for the purchase of residential Energy Star products, or products with improved energy efficiency in cold climates, to replace used appliances of the same type;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe48b18-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15821/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submits an application for the allocation at such time, in such form, and containing such information as the Secretary may require; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe48b19-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15821/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides assurances satisfactory to the Secretary that the State will use the allocation to supplement, but not supplant, funds made available to carry out the State program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfe48b1a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15821/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of allocations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfe48b1b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15821/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (2), for each fiscal year, the Secretary shall allocate to the State energy office of each eligible State to carry out subsection (d) an amount equal to the product obtained by multiplying the amount made available under subsection (f) for the fiscal year by the ratio that the population of the State in the most recent calendar year for which data are available bears to the total population of all eligible States in that calendar year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe48b1c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15821/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum allocations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For each fiscal year, the amounts allocated under this subsection shall be adjusted proportionately so that no eligible State is allocated a sum that is less than an amount determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfe48b1d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15821/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of allocated funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The allocation to a State energy office under subsection (c) may be used to pay up to 50 percent of the cost of establishing and carrying out a State program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfe48b1e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15821/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Issuance of rebates","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Rebates may be provided to residential consumers that meet the requirements of the State program. The amount of a rebate shall be determined by the State energy office, taking into consideration—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfe48b1f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15821/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of the allocation to the State energy office under subsection (c);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe48b20-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15821/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of any Federal or State tax incentive available for the purchase of the residential Energy Star product or product with improved energy efficiency in a cold climate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe48b21-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15821/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the difference between the cost of the residential Energy Star product or product with improved energy efficiency in a cold climate and the cost of an appliance that is not a residential Energy Star product or product with improved energy efficiency in a cold climate, but is of the same type as, and is the nearest capacity, performance, and other relevant characteristics (as determined by the State energy office) to, the residential Energy Star product or product with improved energy efficiency in a cold climate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfe48b22-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15821/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to the Secretary to carry out this section $50,000,000 for each of the fiscal years 2006 through 2010.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfe48b23-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tI/s124"},"text":"Pub. L. 109–58, title I, § 124","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/617"},"text":"119 Stat. 617","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/tIII/s315/b"},"text":"Pub. L. 110–140, title III, § 315(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1572"},"text":"121 Stat. 1572","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbfe48b24-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbfe48b25-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbfe48b26-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2007—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/s315/b/1"},"text":"Pub. L. 110–140, § 315(b)(1)","children":[],"tail":", inserted “, or products with improved energy efficiency in cold climates,” after “residential Energy Star products”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(2), (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/s315/b/2"},"text":"Pub. L. 110–140, § 315(b)(2)","children":[],"tail":", inserted “or product with improved energy efficiency in a cold climate” after “residential Energy Star product” wherever appearing."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbfe48b27-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbfe48b28-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2007 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140"},"text":"Pub. L. 110–140","children":[],"tail":" effective on the date that is 1 day after "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/s1601"},"text":"section 1601 of Pub. L. 110–140","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1824"},"text":"section 1824 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
