{"tag":"section","attrib":{"id":"idbf82bc39-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12623"},"text":null,"children":[{"tag":"num","attrib":{"value":"12623"},"text":"§ 12623.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisory Board","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf82bc3a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12623/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment and purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There shall be established a National Civilian Community Corps Advisory Board to advise the Director concerning the administration of this division and to assist the Corps in responding rapidly and efficiently in times of natural and other disasters. The Advisory Board members shall help coordinate activities with the Corps as appropriate, including the mobilization of volunteers and coordination of volunteer centers to help local communities recover from the effects of natural and other disasters.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf82bc3b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12623/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Advisory Board shall be composed of the following members:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf82bc3c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12623/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Labor.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf82bc3d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12623/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf82bc3e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12623/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Interior.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf82bc3f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12623/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf82bc40-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12623/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Education.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf82bc41-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12623/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Housing and Urban Development.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf82bc42-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12623/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chief of the National Guard Bureau.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf82bc43-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12623/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Administrator of the Federal Emergency Management Agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf82bc44-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12623/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Transportation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf82bc45-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12623/b/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chief of the Forest Service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf82bc46-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12623/b/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Administrator of the Environmental Protection Agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf82bc47-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12623/b/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Energy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf82bc48-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12623/b/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Individuals appointed by the Director from among persons who are broadly representative of educational institutions, voluntary organizations, public and private organizations, youth, and labor unions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf82bc49-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12623/b/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chief Executive Officer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf82bc4a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12623/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inapplicability of termination requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s1013"},"text":"Section 1013 of title 5","children":[],"tail":" shall not apply to the Advisory Board."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf82bc4b-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/610/tI/s163"},"text":"Pub. L. 101–610, title I, § 163","children":[],"tail":", formerly § 195L, as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/484/dA/tX/s1092/a/1"},"text":"Pub. L. 102–484, div. A, title X, § 1092(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2532"},"text":"106 Stat. 2532","children":[],"tail":"; renumbered § 163 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/tI/s104/b"},"text":"Pub. L. 103–82, title I, § 104(b)","children":[],"tail":", title IV, §§ 402(b)(3), 403(b), "},{"tag":"date","attrib":{"date":"1993-09-21"},"text":"Sept. 21, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"