{"tag":"section","attrib":{"id":"idbfdfcfcd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15093"},"text":null,"children":[{"tag":"num","attrib":{"value":"15093"},"text":"§ 15093.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants to States","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfdfcfce-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15093/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall make grants to States on a competitive basis, in accordance with the provisions of this subchapter, to support systems change activities designed to assist States to develop and implement, or expand and enhance, a statewide system of family support services for families of children with disabilities that accomplishes the purposes of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfdfcfcf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15093/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Award period and grant limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No grant shall be awarded under this section for a period of more than 3 years. No State shall be eligible for more than 1 grant under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfdfcfd0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15093/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of grants","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfdfcfd1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15093/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants to States","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfdfcfd2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15093/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal matching share","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"From amounts appropriated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s15101/a"},"text":"section 15101(a) of this title","children":[],"tail":", the Secretary shall pay to each State that has an application approved under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s15094"},"text":"section 15094 of this title","children":[],"tail":", for each year of the grant period, an amount that is—"}],"tail":null},{"tag":"clause","attrib":{"id":"idbfdfcfd3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15093/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" equal to not more than 75 percent of the cost of the systems change activities to be carried out by the State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbfdfcfd4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15093/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than $100,000 and not more than $500,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfdfcfd5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15093/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-Federal share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The non-Federal share of the cost of the systems change activities may be in cash or in kind, fairly evaluated, including plant, equipment, or services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfdfcfd6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15093/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Calculation of amounts","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall calculate a grant amount described in paragraph (1) on the basis of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfdfcfd7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15093/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amounts available for making grants under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfdfcfd8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15093/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the child population of the State concerned.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfdfcfd9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15093/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority for previously participating States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the second and third fiscal years for which amounts are appropriated to carry out this section, the Secretary, in providing payments under this section, shall give priority to States that received payments under this section during the preceding fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfdfcfda-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15093/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priorities for distribution","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To the extent practicable, the Secretary shall award grants to States under this section in a manner that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfdfcfdb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15093/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is geographically equitable;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfdfcfdc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15093/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" distributes the grants among States that have differing levels of development of statewide systems of family support services for families of children with disabilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfdfcfdd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15093/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" distributes the grants among States that attempt to meet the needs of unserved and underserved populations, such as individuals from racial and ethnic minority backgrounds, disadvantaged individuals, individuals with limited English proficiency, and individuals from underserved geographic areas (rural or urban).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfdfcfde-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/402/tII/s204"},"text":"Pub. L. 106–402, title II, § 204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1730"},"text":"114 Stat. 1730","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
