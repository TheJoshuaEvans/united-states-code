{"tag":"section","attrib":{"id":"idbbcdca92-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000ff–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2000ff–2"},"text":"§ 2000ff–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employment agency practices","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbbcdca93-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000ff–2/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Discrimination based on genetic information","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It shall be an unlawful employment practice for an employment agency—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbbcdca94-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000ff–2/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to fail or refuse to refer for employment, or otherwise to discriminate against, any individual because of genetic information with respect to the individual;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbcdca95-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000ff–2/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to limit, segregate, or classify individuals or fail or refuse to refer for employment any individual in any way that would deprive or tend to deprive any individual of employment opportunities, or otherwise adversely affect the status of the individual as an employee, because of genetic information with respect to the individual; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbcdca96-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000ff–2/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to cause or attempt to cause an employer to discriminate against an individual in violation of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbbcdca97-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000ff–2/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition of genetic information","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It shall be an unlawful employment practice for an employment agency to request, require, or purchase genetic information with respect to an individual or a family member of the individual except—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbbcdca98-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000ff–2/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" where an employment agency inadvertently requests or requires family medical history of the individual or family member of the individual;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbcdca99-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000ff–2/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" where—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbbcdca9a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000ff–2/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" health or genetic services are offered by the employment agency, including such services offered as part of a wellness program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbbcdca9b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000ff–2/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the individual provides prior, knowing, voluntary, and written authorization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbbcdca9c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000ff–2/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" only the individual (or family member if the family member is receiving genetic services) and the licensed health care professional or board certified genetic counselor involved in providing such services receive individually identifiable information concerning the results of such services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbbcdca9d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000ff–2/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any individually identifiable genetic information provided under subparagraph (C) in connection with the services provided under subparagraph (A) is only available for purposes of such services and shall not be disclosed to the employment agency except in aggregate terms that do not disclose the identity of specific individuals;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbcdca9e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000ff–2/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" where an employment agency requests or requires family medical history from the individual to comply with the certification provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s2613"},"text":"section 2613 of title 29","children":[],"tail":" or such requirements under State family and medical leave laws;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbcdca9f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000ff–2/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" where an employment agency purchases documents that are commercially and publicly available (including newspapers, magazines, periodicals, and books, but not including medical databases or court records) that include family medical history; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbcdcaa0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000ff–2/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" where the information involved is to be used for genetic monitoring of the biological effects of toxic substances in the workplace, but only if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbbcdcaa1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000ff–2/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the employment agency provides written notice of the genetic monitoring to the individual;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbbcdcaa2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000ff–2/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbbcdcaa3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000ff–2/b/5/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the individual provides prior, knowing, voluntary, and written authorization; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbbcdcaa4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000ff–2/b/5/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the genetic monitoring is required by Federal or State law;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbbcdcaa5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000ff–2/b/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the individual is informed of individual monitoring results;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbbcdcaa6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000ff–2/b/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the monitoring is in compliance with—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbbcdcaa7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000ff–2/b/5/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any Federal genetic monitoring regulations, including any such regulations that may be promulgated by the Secretary of Labor pursuant to the Occupational Safety and Health Act of 1970 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s651"},"text":"29 U.S.C. 651","children":[],"tail":" et seq.), the Federal Mine Safety and Health Act of 1977 ("},{"tag":"ref","attrib":{"href":"/us/usc/t30/s801"},"text":"30 U.S.C. 801","children":[],"tail":" et seq.), or the Atomic Energy Act of 1954 ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2011"},"text":"42 U.S.C. 2011","children":[],"tail":" et seq.); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbbcdcaa8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000ff–2/b/5/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State genetic monitoring regulations, in the case of a State that is implementing genetic monitoring regulations under the authority of the Occupational Safety and Health Act of 1970 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s651"},"text":"29 U.S.C. 651","children":[],"tail":" et seq.); and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbbcdcaa9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000ff–2/b/5/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the employment agency, excluding any licensed health care professional or board certified genetic counselor that is involved in the genetic monitoring program, receives the results of the monitoring only in aggregate terms that do not disclose the identity of specific individuals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbbcdcaaa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000ff–2/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preservation of protections","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of information to which any of paragraphs (1) through (5) of subsection (b) applies, such information may not be used in violation of paragraph (1), (2), or (3) of subsection (a) or treated or disclosed in a manner that violates ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2000ff–5"},"text":"section 2000ff–5 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbbcdcaab-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/233/tII/s203"},"text":"Pub. L. 110–233, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-21"},"text":"May 21, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/908"},"text":"122 Stat. 908","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbbcdcaac-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbbcdcaad-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbbcdcaae-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Occupational Safety and Health Act of 1970, referred to in subsec. (b)(5)(D), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/596"},"text":"Pub. L. 91–596","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-29"},"text":"Dec. 29, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1590"},"text":"84 Stat. 1590","children":[],"tail":", which is classified principally to chapter 15 (§ 651 et seq.) of Title 29, Labor. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s651"},"text":"section 651 of Title 29","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Federal Mine Safety and Health Act of 1977, referred to in subsec. (b)(5)(D)(i), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/173"},"text":"Pub. L. 91–173","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-12-30"},"text":"Dec. 30, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/742"},"text":"83 Stat. 742","children":[],"tail":", which is classified principally to chapter 22 (§ 801 et seq.) of Title 30, Mineral Lands and Mining. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t30/s801"},"text":"section 801 of Title 30","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Atomic Energy Act of 1954, referred to in subsec. (b)(5)(D)(i), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-08-01/ch724"},"text":"act Aug. 1, 1946, ch. 724","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/act/1954-08-30/ch1073/s1"},"text":"act Aug. 30, 1954, ch. 1073, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/919"},"text":"68 Stat. 919","children":[],"tail":", which is classified principally to chapter 23 (§ 2011 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2011"},"text":"section 2011 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbbcdcaaf-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbbcdcab0-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 18 months after ","children":[{"tag":"date","attrib":{"date":"2008-05-21"},"text":"May 21, 2008","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/233/s213"},"text":"section 213 of Pub. L. 110–233","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2000ff"},"text":"section 2000ff of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
