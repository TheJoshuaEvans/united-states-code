{"tag":"section","attrib":{"id":"idbd99feec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6345"},"text":null,"children":[{"tag":"num","attrib":{"value":"6345"},"text":"§ 6345.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" CHP Technical Assistance Partnership Program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd99feed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6345/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Renaming","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd99feee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6345/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Clean Energy Application Centers of the Department of Energy are redesignated as the CHP Technical Assistance Partnership Program (referred to in this section as the “Program”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd99feef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6345/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program description","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Program shall consist of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd99fef0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6345/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the 10 regional CHP Technical Assistance Partnerships in existence on ","children":[{"tag":"date","attrib":{"date":"2020-12-27"},"text":"December 27, 2020","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd99fef1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6345/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other regional CHP Technical Assistance Partnerships as the Secretary may establish with consideration given to establishing such partnerships in rural communities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd99fef2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6345/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any supporting technical activities under the Technical Partnership Program of the Advanced Manufacturing Office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd99fef3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6345/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" References","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any reference in any law, rule, regulation, or publication to a Combined Heat and Power Application Center or a Clean Energy Application Center shall be deemed to be a reference to the Program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd99fef4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6345/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" CHP Technical Assistance Partnership Program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd99fef5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6345/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Program shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd99fef6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6345/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" operate programs to encourage deployment of combined heat and power, waste heat to power, and efficient district energy (collectively referred to in this subsection as “CHP”) technologies by providing education and outreach to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbd9c47e7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6345/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" building, industrial, and electric and natural gas utility professionals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd9c47e8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6345/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State and local policymakers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd9c47e9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6345/b/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other individuals and organizations with an interest in efficient energy use, local or opportunity fuel use, resiliency, or energy security, microgrids, and district energy; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd9c47ea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6345/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide project specific support to building and industrial professionals through economic and engineering assessments and advisory activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd9c47eb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6345/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding for certain activities","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd9c47ec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6345/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Program shall make funds available to institutions of higher education, research centers, and other appropriate institutions to ensure the continued operations and effectiveness of the regional CHP Technical Assistance Partnerships.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd9c47ed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6345/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Funds made available under subparagraph (A) may be used—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbd9c47ee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6345/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to collect and distribute informational materials relevant to manufacturers, commercial buildings, institutional facilities, and Federal sites, including continued support of the mission goals of the Department of Defense, on CHP and microgrid technologies, including continuation and updating of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbd9c47ef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6345/b/2/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the CHP installation database;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbd9c47f0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6345/b/2/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" CHP technology potential analyses;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbd9c47f1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6345/b/2/B/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State CHP resource pages; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbd9c47f2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6345/b/2/B/i/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" CHP Technical Assistance Partnerships websites;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd9c47f3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6345/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to produce and conduct workshops, reports, seminars, internet programs, CHP resiliency resources, and other activities to provide education to end users, regulators, and stakeholders in a manner that leads to the deployment of CHP technologies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd9c47f4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6345/b/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide or coordinate onsite assessments for sites and enterprises that may consider deployment of CHP technology, including the potential use of biomass CHP systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd9c47f5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6345/b/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to identify candidates for deployment of CHP technologies, hybrid renewable-CHP technologies, biomass CHP, microgrids, and clean energy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd9c47f6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6345/b/2/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide nonbiased engineering support to sites considering deployment of CHP technologies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd9c47f7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6345/b/2/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assist organizations and communities, including rural communities, developing clean energy technologies and policies in overcoming barriers to deployment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd9c47f8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6345/b/2/B/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assist companies, communities (including rural communities), and organizations with field validation and performance evaluations of CHP and other clean energy technologies implemented.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd9c47f9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6345/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Program shall make funds available under subparagraph (A) for a period of 5 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd9c47fa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6345/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this section $12,000,000 for each of fiscal years 2021 through 2025.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd9c47fb-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/163/tIII/s375"},"text":"Pub. L. 94–163, title III, § 375","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/tIV/s451/a"},"text":"Pub. L. 110–140, title IV, § 451(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1632"},"text":"121 Stat. 1632","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dZ/tI/s1013/a"},"text":"Pub. L. 116–260, div. Z, title I, § 1013(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2449"},"text":"134 Stat. 2449","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd9c47fc-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd9c47fd-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbd9c47fe-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 6345, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/163/tIII/s375"},"text":"Pub. L. 94–163, title III, § 375","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-12-22"},"text":"Dec. 22, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/937"},"text":"89 Stat. 937","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/619/tVI/s601/b"},"text":"Pub. L. 95–619, title VI, § 601(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-09"},"text":"Nov. 9, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3282"},"text":"92 Stat. 3282","children":[],"tail":", required reports on progress made in improving energy efficiency and achievement of energy efficiency improvement targets, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/99/509/tIII/s3101/b"},"text":"Pub. L. 99–509, title III, § 3101(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-21"},"text":"Oct. 21, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1888"},"text":"100 Stat. 1888","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd9c47ff-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Pub. L. 116–260","children":[],"tail":" amended section generally. Prior to amendment, section related to Clean Energy Application Centers."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbd9c4800-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbd9c4801-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the date that is 1 day after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/s1601"},"text":"section 1601 of Pub. L. 110–140","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1824"},"text":"section 1824 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
