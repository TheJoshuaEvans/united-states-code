{"tag":"section","attrib":{"id":"idbf47398b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11381"},"text":null,"children":[{"tag":"num","attrib":{"value":"11381"},"text":"§ 11381.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purposes of this part are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf47398c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11381/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to promote community-wide commitment to the goal of ending homelessness;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf47398d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11381/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide funding for efforts by nonprofit providers and State and local governments to quickly rehouse homeless individuals and families while minimizing the trauma and dislocation caused to individuals, families, and communities by homelessness;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf47398e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11381/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to promote access to, and effective utilization of, mainstream programs described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11313/a/7"},"text":"section 11313(a)(7) of this title","children":[],"tail":" and programs funded with State or local resources; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf47398f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11381/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to optimize self-sufficiency among individuals and families experiencing homelessness.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf473990-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/77/tIV/s421"},"text":"Pub. L. 100–77, title IV, § 421","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/22/dB/tIII/s1301/2"},"text":"Pub. L. 111–22, div. B, title III, § 1301(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-05-20"},"text":"May 20, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1680"},"text":"123 Stat. 1680","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf473991-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf473992-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbf473993-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 11381, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/77/tIV/s421"},"text":"Pub. L. 100–77, title IV, § 421","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/550/tXIV/s1403/a"},"text":"Pub. L. 102–550, title XIV, § 1403(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4013"},"text":"106 Stat. 4013","children":[],"tail":", which related to the purpose of the supportive housing program, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/111/22/dB/tIII/s1301/2"},"text":"Pub. L. 111–22, div. B, title III, § 1301(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-05-20"},"text":"May 20, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1680"},"text":"123 Stat. 1680","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 11381, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/77/tIV/s421"},"text":"Pub. L. 100–77, title IV, § 421","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-07-22"},"text":"July 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/498"},"text":"101 Stat. 498","children":[],"tail":", which related to establishment of a supportive housing demonstration program, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/102/550/tXIV/s1403/a"},"text":"Pub. L. 102–550, title XIV, § 1403(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4013"},"text":"106 Stat. 4013","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbf473994-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbf473995-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the earlier of 18 months after ","children":[{"tag":"date","attrib":{"date":"2009-05-20"},"text":"May 20, 2009","children":[],"tail":", or 3 months after publication of certain final regulations by Secretary of Housing and Urban Development, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/22/s1503"},"text":"section 1503 of Pub. L. 111–22","children":[],"tail":", set out as an Effective Date of 2009 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s11302"},"text":"section 11302 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbf473996-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Transitional Provision","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550/tXIV/s1403/b"},"text":"Pub. L. 102–550, title XIV, § 1403(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4021"},"text":"106 Stat. 4021","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/106/400/s2"},"text":"Pub. L. 106–400, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1675"},"text":"114 Stat. 1675","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/400/s2"},"text":"“Notwithstanding the amendment made by subsection (a) [adding part C and repealing former parts C and D of this subchapter], before the date of the effectiveness of the regulations issued under section 427 of the McKinney-Vento Homeless Assistance Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11387"},"text":"42 U.S.C. 11387","children":[],"tail":"] (as amended by subsection (a) of this section) the Secretary may make grants under the provisions of subtitles C and D of [title IV of] the McKinney-Vento Homeless Assistance Act [former parts C and D of this subchapter], as in effect immediately before the enactment of this Act ["},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":"]. Any grants made before such effective date shall be subject to the provisions of such subtitles.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbf473997-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Demonstration Projects To Reduce Number of Homeless Families in Welfare Hotels","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/628/tIX/s903"},"text":"Pub. L. 100–628, title IX, § 903","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-07"},"text":"Nov. 7, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3258"},"text":"102 Stat. 3258","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/104/193/tI/s110/g"},"text":"Pub. L. 104–193, title I, § 110(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-22"},"text":"Aug. 22, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2171"},"text":"110 Stat. 2171","children":[],"tail":", authorized Secretary of Health and Human Services to carry out 2 or 3 demonstration projects to provide housing in transitional facilities for homeless families who are recipients of assistance under a State program funded by part A of subchapter IV of chapter 7 of this title and who reside in commercial or similar transient facilities and authorized appropriations of not more than $20,000,000 for the grants for fiscal year 1990."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idbf473998-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definition","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For provisions relating to definition of “local government” as used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141/s100261"},"text":"section 100261 of Pub. L. 112–141","children":[],"tail":", set out as a HEARTH Act Technical Corrections note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s11360"},"text":"section 11360 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
