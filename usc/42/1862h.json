{"tag":"section","attrib":{"id":"idbb863a11-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862h"},"text":null,"children":[{"tag":"num","attrib":{"value":"1862h"},"text":"§ 1862h.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional statement of findings and declaration of purposes respecting scientific and technical education and training","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbb863a12-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862h/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb863a13-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862h/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the position of the United States in the world economy faces great challenges from highly trained foreign competition;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb863a14-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862h/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the workforce of the United States must be better prepared for the technologically advanced, competitive, global economy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb863a15-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862h/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the improvement of our work force’s productivity and our international economic position depend upon the strengthening of our educational efforts in science, technology, engineering, and mathematics or STEM, especially at the associate-degree level;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb863a16-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862h/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shortages of scientifically and technically educated ","children":[{"tag":"ref","attrib":{"idref":"fn003205"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003205"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be followed by “and”."}],"tail":" trained workers in a wide variety of fields will best be addressed by collaboration among the Nation’s associate-degree-granting colleges and private industry to produce skilled, advanced technicians; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb863a17-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862h/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Science Foundation’s traditional role in developing model curricula, disseminating instructional materials, enhancing faculty development, and stimulating partnerships between educational institutions and industry, makes an enlarged role for the Foundation in STEM education and training particularly appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb863a18-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862h/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is the purpose of sections 1862h to 1862j of this title to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb863a19-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862h/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve science and technical education at associate-degree-granting colleges;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb863a1a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862h/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve secondary school and postsecondary curricula in STEM fields;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb863a1b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862h/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve the educational opportunities of postsecondary students by creating comprehensive articulation agreements and planning between 2-year and 4-year institutions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb863a1c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862h/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote outreach to secondary schools to improve STEM instruction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbb863a1d-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/476/s2"},"text":"Pub. L. 102–476, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2297"},"text":"106 Stat. 2297","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/tIII/s10312/f/1"},"text":"Pub. L. 117–167, div. B, title III, § 10312(f)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1519"},"text":"136 Stat. 1519","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbb863a1e-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbb863a1f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbb863a20-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Sections 1862h to 1862j of this title, referred to in subsec. (b), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/476"},"text":"Pub. L. 102–476","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2297"},"text":"106 Stat. 2297","children":[],"tail":", known as the Scientific and Advanced-Technology Act of 1992, which enacted this section and sections 1862i and 1862j of this title and amended "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1862"},"text":"section 1862 of this title","children":[],"tail":". For complete classification of this Act to the Code, see Short Title of 1992 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1861"},"text":"section 1861 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbb863a21-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Scientific and Advanced-Technology Act of 1992, and not as part of the National Science Foundation Act of 1950 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbb863a22-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/s10312/f/1/A/i"},"text":"Pub. L. 117–167, § 10312(f)(1)(A)(i)","children":[],"tail":", substituted “science, technology, engineering, and mathematics or STEM” for “science, mathematics, and technology”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/s10312/f/1/A/ii"},"text":"Pub. L. 117–167, § 10312(f)(1)(A)(ii)","children":[],"tail":", inserted “educated” before “trained”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/s10312/f/1/A/iii"},"text":"Pub. L. 117–167, § 10312(f)(1)(A)(iii)","children":[],"tail":", substituted “STEM education and training” for “scientific and technical education and training”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/s10312/f/1/B/i"},"text":"Pub. L. 117–167, § 10312(f)(1)(B)(i)","children":[],"tail":", substituted “STEM fields” for “mathematics and science”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/s10312/f/1/B/ii"},"text":"Pub. L. 117–167, § 10312(f)(1)(B)(ii)","children":[],"tail":", substituted “STEM instruction” for “mathematics and science instruction”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
