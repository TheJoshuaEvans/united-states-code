{"tag":"section","attrib":{"id":"idc0786645-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19058"},"text":null,"children":[{"tag":"num","attrib":{"value":"19058"},"text":"§ 19058.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Biological field stations and marine laboratories","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Director shall continue to support enhancing, repairing and maintaining research instrumentation, laboratories, telecommunications and housing at biological field stations and marine laboratories.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc0786646-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/tIII/s10349"},"text":"Pub. L. 117–167, div. B, title III, § 10349","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1560"},"text":"136 Stat. 1560","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
