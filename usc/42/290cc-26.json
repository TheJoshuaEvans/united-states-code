{"tag":"section","attrib":{"id":"idb5b8c816-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290cc–26"},"text":null,"children":[{"tag":"num","attrib":{"value":"290cc–26"},"text":"§ 290cc–26.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provision of certain information from State","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary may not make payments under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s290cc–21"},"text":"section 290cc–21 of this title","children":[],"tail":" to a State unless, as part of the application required in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s290cc–29"},"text":"section 290cc–29 of this title","children":[],"tail":", the State submits to the Secretary a statement—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5b8c817-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290cc–26/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying existing programs providing services and housing to eligible homeless individuals and identify gaps in the delivery systems of such programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5b8c818-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290cc–26/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" containing a plan for providing services and housing to eligible homeless individuals, which plan—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5b8c819-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290cc–26/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describes the coordinated and comprehensive means of providing services and housing to homeless individuals; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5b8c81a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290cc–26/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes documentation that suitable housing for eligible homeless individuals will accompany the provision of services to such individuals;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5b8c81b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290cc–26/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describes the source of the non-Federal contributions described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s290cc–23"},"text":"section 290cc–23 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5b8c81c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290cc–26/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contains assurances that the non-Federal contributions described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s290cc–23"},"text":"section 290cc–23 of this title","children":[],"tail":" will be available at the beginning of the grant period;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5b8c81d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290cc–26/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describe any voucher system that may be used to carry out this part; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5b8c81e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290cc–26/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contain such other information or assurances as the Secretary may reasonably require.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5b8c81f-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title V, § 526, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/77/tVI/s611/3"},"text":"Pub. L. 100–77, title VI, § 611(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-07-22"},"text":"July 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/519"},"text":"101 Stat. 519","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/645/tV/s511"},"text":"Pub. L. 101–645, title V, § 511","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4729"},"text":"104 Stat. 4729","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb5b8c820-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb5b8c821-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb5b8c822-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 526 of act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", was renumbered section 547 by "},{"tag":"ref","attrib":{"href":"/us/pl/100/77/s611/2"},"text":"section 611(2) of Pub. L. 100–77","children":[],"tail":" and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s290ee–2"},"text":"section 290ee–2 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb5b8c823-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1990—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/645"},"text":"Pub. L. 101–645","children":[],"tail":" amended section generally, substituting provisions relating to providing certain information from State for provisions relating to requirement of submission of description of intended use of block grant."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
