{"tag":"section","attrib":{"id":"idbcc82f5e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336c"},"text":null,"children":[{"tag":"num","attrib":{"value":"4336c"},"text":"§ 4336c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adoption of categorical exclusions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"An agency may adopt a categorical exclusion listed in another agency’s NEPA procedures for a category of proposed agency actions for which the categorical exclusion was established consistent with this paragraph. The agency shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbcc82f5f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify the categorical exclusion listed in another agency’s NEPA procedures that covers a category of proposed actions or related actions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcc82f60-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consult with the agency that established the categorical exclusion to ensure that the proposed adoption of the categorical exclusion to a category of actions is appropriate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcc82f61-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify to the public the categorical exclusion that the agency plans to use for its proposed actions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcc82f62-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" document adoption of the categorical exclusion.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbcc82f63-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/190/tI/s109"},"text":"Pub. L. 91–190, title I, § 109","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/118/5/dC/tIII/s321/b"},"text":"Pub. L. 118–5, div. C, title III, § 321(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-06-03"},"text":"June 3, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/43"},"text":"137 Stat. 43","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
