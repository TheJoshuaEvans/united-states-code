{"tag":"section","attrib":{"id":"idb8545b9c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–26"},"text":null,"children":[{"tag":"num","attrib":{"value":"1320b–26"},"text":"§ 1320b–26.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding for providers relating to COVID–19","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8545b9d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–26/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to amounts otherwise available, there is appropriated to the Secretary, for fiscal year 2021, out of any monies in the Treasury not otherwise appropriated, $8,500,000,000 for purposes of making payments to eligible health care providers for health care related expenses and lost revenues that are attributable to COVID–19. Amounts appropriated under the preceding sentence shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8545b9e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–26/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application requirement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible for a payment under this section, an eligible health care provider shall submit to the Secretary an application in such form and manner as the Secretary shall prescribe. Such application shall contain the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8545b9f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–26/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A statement justifying the need of the provider for the payment, including documentation of the health care related expenses attributable to COVID–19 and lost revenues attributable to COVID–19.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8545ba0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–26/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The tax identification number of the provider.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8545ba1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–26/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such assurances as the Secretary determines appropriate that the eligible health care provider will maintain and make available such documentation and submit such reports (at such time, in such form, and containing such information as the Secretary shall prescribe) as the Secretary determines is necessary to ensure compliance with any conditions imposed by the Secretary under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8545ba2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–26/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other information determined appropriate by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8545ba3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–26/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Payments made to an eligible health care provider under this section may not be used to reimburse any expense or loss that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8545ba4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–26/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has been reimbursed from another source; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8545ba5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–26/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" another source is obligated to reimburse.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8545ba6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–26/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of requirements, rules, and procedures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall apply any requirements, rules, or procedures as the Secretary deems appropriate for the efficient execution of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8545ba7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–26/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8545ba8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–26/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible health care provider","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible health care provider” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8545ba9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–26/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a provider of services (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395x/u"},"text":"section 1395x(u) of this title","children":[],"tail":") or a supplier (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395x/d"},"text":"section 1395x(d) of this title","children":[],"tail":") that—"}],"tail":null},{"tag":"clause","attrib":{"id":"idb8545baa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–26/e/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is enrolled in the Medicare program under subchapter XVIII under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395cc/j"},"text":"section 1395cc(j) of this title","children":[],"tail":" (including temporarily enrolled during the emergency period described in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320b–5/g/1/B"},"text":"section 1320b–5(g)(1)(B) of this title","children":[],"tail":" for such period);"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8545bab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–26/e/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides diagnoses, testing, or care for individuals with possible or actual cases of COVID–19; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8545bac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–26/e/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a rural provider or supplier; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8545bad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–26/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a provider or supplier that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb8545bae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–26/e/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is enrolled with a State Medicaid plan under subchapter XIX (or a waiver of such plan) in accordance with subsections (a)(77) and (kk) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1396a"},"text":"section 1396a of this title","children":[],"tail":" (including enrolled pursuant to section 1396a(a)(78) or "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1396u–2/d/6"},"text":"section 1396u–2(d)(6) of this title","children":[],"tail":") or enrolled with a State child health plan under subchapter XXI (or a waiver of such plan) in accordance with subparagraph (G) of "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1397gg/e/1"},"text":"section 1397gg(e)(1) of this title","children":[],"tail":" (including enrolled pursuant to subparagraph (D) or (Q) of such section);"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8545baf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–26/e/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides diagnoses, testing, or care for individuals with possible or actual cases of COVID–19; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8545bb0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–26/e/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a rural provider or supplier.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8545bb1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–26/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Health care related expenses attributable to COVID–19","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “health care related expenses attributable to COVID–19” means health care related expenses to prevent, prepare for, and respond to COVID–19, including the building or construction of a temporary structure, the leasing of a property, the purchase of medical supplies and equipment, including personal protective equipment and testing supplies, providing for increased workforce and training (including maintaining staff, obtaining additional staff, or both), the operation of an emergency operation center, retrofitting a facility, providing for surge capacity, and other expenses determined appropriate by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8545bb2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–26/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lost revenue attributable to COVID–19","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “lost revenue attributable to COVID–19” has the meaning given that term in the Frequently Asked Questions guidance released by the Department of Health and Human Services in June 2020, including the difference between such provider’s budgeted and actual revenue if such budget had been established and approved prior to ","children":[{"tag":"date","attrib":{"date":"2020-03-27"},"text":"March 27, 2020","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8545bb3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–26/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":" The term “payment” includes, as determined appropriate by the Secretary, a pre-payment, a prospective payment, a retrospective payment, or a payment through a grant or other mechanism.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8545bb4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–26/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rural provider or supplier","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “rural provider or supplier” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8545bb5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–26/e/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb8545bb6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–26/e/5/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provider or supplier located in a rural area (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395ww/d/2/D"},"text":"section 1395ww(d)(2)(D) of this title","children":[],"tail":"); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8545bb7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–26/e/5/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provider treated as located in a rural area pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395ww/d/8/E"},"text":"section 1395ww(d)(8)(E) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8545bb8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–26/e/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a provider or supplier located in any other area that serves rural patients (as defined by the Secretary), which may include, but is not required to include, a metropolitan statistical area with a population of less than 500,000 (determined based on the most recently available data);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8545bb9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–26/e/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a rural health clinic (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395x/aa/2"},"text":"section 1395x(aa)(2) of this title","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8545bba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–26/e/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a provider or supplier that furnishes home health, hospice, or long-term services and supports in an individual’s home located in a rural area (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395ww/d/2/D"},"text":"section 1395ww(d)(2)(D) of this title","children":[],"tail":"); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8545bbb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–26/e/5/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other rural provider or supplier (as defined by the Secretary).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8545bbc-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title XI, § 1150C, as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/2/tIX/s9911"},"text":"Pub. L. 117–2, title IX, § 9911","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-03-11"},"text":"Mar. 11, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/236"},"text":"135 Stat. 236","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
