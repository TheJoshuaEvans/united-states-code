{"tag":"section","attrib":{"id":"idb6836b8d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–11"},"text":null,"children":[{"tag":"num","attrib":{"value":"300cc–11"},"text":"§ 300cc–11.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Clinical evaluation units at National Institutes of Health","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb6836b8e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–11/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, acting through the Director of the National Cancer Institute and the Director of the National Institute of Allergy and Infectious Diseases, shall for each such Institute establish a clinical evaluation unit at the Clinical Center at the National Institutes of Health. Each of the clinical evaluation units—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6836b8f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–11/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall conduct clinical evaluations of experimental treatments for acquired immune deficiency syndrome developed within the preclinical drug development program, including evaluations of methods of diagnosing immune deficiency and evaluations of methods of predicting, diagnosing, preventing, and treating opportunistic cancers and infectious diseases; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6836b90-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–11/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may conduct clinical evaluations of experimental treatments for such syndrome that are developed by any other national research institute of the National Institutes of Health or by any other entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6836b91-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–11/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Personnel and administrative support","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6836b92-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–11/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For the purposes described in subsection (a), the Secretary, acting through the Director of the National Institutes of Health, shall provide each of the clinical evaluation units required in such subsection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6836b93-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–11/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb6836b94-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–11/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with not less than 50 beds; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6836b95-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–11/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with an outpatient clinical capacity equal to not less than twice the outpatient clinical capacity, with respect to acquired immune deficiency syndrome, possessed by the Clinical Center of the National Institutes of Health on ","children":[{"tag":"date","attrib":{"date":"1988-06-01"},"text":"June 1, 1988","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6836b96-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–11/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with such personnel, such administrative support, and such other support services as may be necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6836b97-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–11/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Facilities, personnel, administrative support, and other support services provided pursuant to paragraph (1) shall be in addition to the number or level of facilities, personnel, administrative support, and other support services that otherwise would be available at the Clinical Center at the National Institutes of Health for the provision of clinical care for individuals with diseases or disorders.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6836b98-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–11/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of carrying out this section, there are authorized to be appropriated such sums as may be necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb6836b99-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XXIII, § 2311, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/607/tII/s201/4"},"text":"Pub. L. 100–607, title II, § 201(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-04"},"text":"Nov. 4, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3066"},"text":"102 Stat. 3066","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/43/tXVIII/s1811/2"},"text":"Pub. L. 103–43, title XVIII, § 1811(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-06-10"},"text":"June 10, 1993","children":[],"tail":","},{"tag":"ref","attrib":{"href":"/us/stat/107/199"},"text":"107 Stat. 199","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb6836b9a-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb6836b9b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb6836b9c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 300cc–11, act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", § 2312, was successively renumbered by subsequent acts and transferred, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s238i"},"text":"section 238i of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb6836b9d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1993—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/43"},"text":"Pub. L. 103–43","children":[],"tail":" inserted before semicolon at end “, including evaluations of methods of diagnosing immune deficiency and evaluations of methods of predicting, diagnosing, preventing, and treating opportunistic cancers and infectious dis­eases”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
