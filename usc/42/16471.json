{"tag":"section","attrib":{"id":"idc01696f4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16471"},"text":null,"children":[{"tag":"num","attrib":{"value":"16471"},"text":"§ 16471.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consumer privacy and unfair trade practices","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc01696f5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16471/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Privacy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal Trade Commission may issue rules protecting the privacy of electric consumers from the disclosure of consumer information obtained in connection with the sale or delivery of electric energy to electric consumers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc01696f6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16471/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Slamming","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal Trade Commission may issue rules prohibiting the change of selection of an electric utility except with the informed consent of the electric consumer or if approved by the appropriate State regulatory authority.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc01696f7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16471/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cramming","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal Trade Commission may issue rules prohibiting the sale of goods and services to an electric consumer unless expressly authorized by law or the electric consumer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc01696f8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16471/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rulemaking","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal Trade Commission shall proceed in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s553"},"text":"section 553 of title 5","children":[],"tail":" when prescribing a rule under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc01696f9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16471/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Federal Trade Commission determines that a State’s regulations provide equivalent or greater protection than the provisions of this section, such State regulations shall apply in that State in lieu of the regulations issued by the Commission under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc01696fa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16471/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc01696fb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16471/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State regulatory authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State regulatory authority” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s796/21"},"text":"section 796(21) of title 16","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc01696fc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16471/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Electric consumer and electric utility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “electric consumer” and “electric utility” have the meanings given those terms in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s2602"},"text":"section 2602 of title 16","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc01696fd-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tXII/s1287"},"text":"Pub. L. 109–58, title XII, § 1287","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/981"},"text":"119 Stat. 981","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
