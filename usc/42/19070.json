{"tag":"section","attrib":{"id":"idc07866b3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19070"},"text":null,"children":[{"tag":"num","attrib":{"value":"19070"},"text":"§ 19070.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research on the impact of inflation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc07866b4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19070/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director may make awards, on a competitive merit-reviewed basis, to institutions of higher education or nonprofit organizations (or consortia of such institutions or organizations) to support research to improve our understanding of the impact of inflation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc07866b5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19070/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Activities funded by an award under this section may include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc07866b6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19070/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" measuring the economic impact of inflation on the American people, including an analysis of cost-of-living and wage impacts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc07866b7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19070/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" considering the impact of inflation on American international competitiveness;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc07866b8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19070/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluating the impact of inflation on rural and underserved communities throughout the country;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc07866b9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19070/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assessing the ways inflation could impact future American generations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc07866ba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19070/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluating the impact of policymaking on inflation, including the impact of further Government spending.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc07866bb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19070/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination to avoid duplication","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In making awards under this section, the Director shall, for purposes of avoiding duplication of activities and research, consult, collaborate, and coordinate with the programs and policies of other relevant Federal agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc07866bc-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/tIII/s10363"},"text":"Pub. L. 117–167, div. B, title III, § 10363","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1568"},"text":"136 Stat. 1568","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
