{"tag":"section","attrib":{"id":"idbc12e8ef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2278"},"text":null,"children":[{"tag":"num","attrib":{"value":"2278"},"text":"§ 2278.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statute of limitations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Except for a capital offense, no individual or person shall be prosecuted, tried, or punished for any offense prescribed or defined in sections 2274 to 2276 of this title unless the indictment is found or the information is instituted within ten years next after such offense shall have been committed.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbc12e8f0-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-08-01/ch724"},"text":"Aug. 1, 1946, ch. 724","children":[],"tail":", title I, § 228, as added "},{"tag":"ref","attrib":{"href":"/us/act/1954-08-30/ch1073/s1"},"text":"Aug. 30, 1954, ch. 1073, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/959"},"text":"68 Stat. 959","children":[],"tail":"; renumbered title I, "},{"tag":"ref","attrib":{"href":"/us/pl/102/486/tIX/s902/a/8"},"text":"Pub. L. 102–486, title IX, § 902(a)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2944"},"text":"106 Stat. 2944","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
