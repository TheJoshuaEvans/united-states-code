{"tag":"section","attrib":{"id":"idbce4b848-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4856"},"text":null,"children":[{"tag":"num","attrib":{"value":"4856"},"text":"§ 4856.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports of Secretary of Housing and Urban Development","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbce4b849-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4856/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall transmit to the Congress an annual report that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbce4b84a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4856/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sets forth the Secretary’s assessment of the progress made in implementing the various programs authorized by this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbce4b84b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4856/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" summarizes the most current health and environmental studies on childhood lead poisoning, including studies that analyze the relationship between interim control and abatement activities and the incidence of lead poisoning in resident children;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbce4b84c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4856/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommends legislative and administrative initiatives that may improve the performance by the Department of Housing and Urban Development in combating lead hazards through the expansion of lead hazard evaluation and reduction activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbce4b84d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4856/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describes the results of research carried out in accordance with subchapter III; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbce4b84e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4856/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" estimates the amount of Federal assistance annually expended on lead hazard evaluation and reduction activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbce4b84f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4856/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Biennial report","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbce4b850-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4856/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"24 months after ","children":[{"tag":"date","attrib":{"date":"1992-10-28"},"text":"October 28, 1992","children":[],"tail":", and at the end of every 24-month period thereafter, the Secretary shall report to the Congress on the progress of the Department of Housing and Urban Development in implementing expanded lead-based paint hazard evaluation and reduction activities."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbce4b851-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4856/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The report shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbce4b852-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4856/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assess the effectiveness of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4852d"},"text":"section 4852d of this title","children":[],"tail":" in making the public aware of lead-based paint hazards;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbce4b853-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4856/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" estimate the extent to which lead-based paint hazard evaluation and reduction activities are being conducted in the various categories of housing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbce4b854-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4856/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" monitor and report expenditures for lead-based paint hazard evaluation and reduction for programs within the jurisdiction of the Department of Housing and Urban Development;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbce4b855-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4856/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify the infrastructure needed to eliminate lead-based paint hazards in all housing as expeditiously as possible, including cost-effective technology, standards and regulations, trained and certified contractors, certified laboratories, liability insurance, private financing techniques, and appropriate Government subsidies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbce4b856-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4856/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assess the extent to which the infrastructure described in subparagraph (D) exists, make recommendations to correct shortcomings, and provide estimates of the costs of measures needed to build an adequate infrastructure; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbce4b857-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4856/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include any additional information that the Secretary deems appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbce4b858-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550/tX/s1061"},"text":"Pub. L. 102–550, title X, § 1061","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3926"},"text":"106 Stat. 3926","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbce4b859-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbce4b85a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbce4b85b-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (a)(1), was in the original “this title”, meaning title X of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550"},"text":"Pub. L. 102–550","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3897"},"text":"106 Stat. 3897","children":[],"tail":", known as the Residential Lead-Based Paint Hazard Reduction Act of 1992. For complete classification of this title to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4851"},"text":"section 4851 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
