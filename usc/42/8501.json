{"tag":"section","attrib":{"id":"idbe991f85-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8501"},"text":null,"children":[{"tag":"num","attrib":{"value":"8501"},"text":"§ 8501.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional findings and purposes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbe991f86-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8501/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe991f87-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8501/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serious disruptions have recently occurred in the gasoline and diesel fuel markets of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe991f88-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8501/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" it is likely that such disruptions will recur;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe991f89-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8501/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" interstate commerce is significantly affected by those market disruptions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe991f8a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8501/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an urgent need exists to provide for emergency conservation and other measures with respect to gasoline, diesel fuel, home heating oil, and other energy sources in potentially short supply in order to cope with market disruptions and protect interstate commerce; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe991f8b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8501/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" up-to-date and reliable information concerning the supply and demand of gasoline, diesel fuel, and other related data is not available to the President, the Congress, or the public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe991f8c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8501/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of this chapter are to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe991f8d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8501/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide a means for the Federal Government, States, and units of local government to establish emergency conservation measures with respect to gasoline, diesel fuel, home heating oil, and other energy sources which may be in short supply;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe991f8e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8501/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish other emergency measures to alleviate disruptions in gasoline and diesel fuel markets;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe991f8f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8501/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" obtain data concerning such fuels; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe991f90-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8501/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protect interstate commerce.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbe991f91-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/102/tII/s201"},"text":"Pub. L. 96–102, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-11-05"},"text":"Nov. 5, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/757"},"text":"93 Stat. 757","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbe991f92-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbe991f93-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbe991f94-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/96/102/tIII/s302"},"text":"Pub. L. 96–102, title III, § 302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-11-05"},"text":"Nov. 5, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/770"},"text":"93 Stat. 770","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/96/102/tIII/s302"},"text":"“The amendments made by this Act [enacting this chapter, amending sections 6262, 6263, and 6422 of this title, and enacting provisions set out as notes under this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6261"},"text":"section 6261 of this title","children":[],"tail":"] shall take effect on the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1979-11-05"},"text":"Nov. 5, 1979","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"idbe991f95-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/96/102/s1/a"},"text":"Pub. L. 96–102, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-11-05"},"text":"Nov. 5, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/749"},"text":"93 Stat. 749","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/96/102/s1/a"},"text":"“This Act [enacting this chapter, amending sections 6261, 6262, 6263, and 6422 of this title, and enacting provisions set out as notes under this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6261"},"text":"section 6261 of this title","children":[],"tail":"] may be cited as the ‘Emergency Energy Conservation Act of 1979’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbe991f96-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Congressional Findings","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/96/102/tI/s101"},"text":"Pub. L. 96–102, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-11-05"},"text":"Nov. 5, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/750"},"text":"93 Stat. 750","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/96/102/tI/s101"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The Congress finds that—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a standby rationing plan for gasoline and diesel fuel should provide, to the maximum extent practicable, that the burden of reduced supplies of gasoline and diesel fuel be shared by all persons in a fair and equitable manner and that the economic and social impacts of such plan be minimized; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such a plan should be sufficiently flexible to respond to changed conditions and sufficiently simple to be effectively administered and enforced.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbe991f97-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Funding for Fiscal Years 1979 and 1980","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/96/102/tIII/s301"},"text":"Pub. L. 96–102, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-11-05"},"text":"Nov. 5, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/769"},"text":"93 Stat. 769","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/96/102/tIII/s301"},"text":"“For purposes of any law relating to appropriations or authorizations for appropriations as such law relates to the fiscal year ending ","children":[{"tag":"date","attrib":{"date":"1979-09-30"},"text":"September 30, 1979","children":[],"tail":", or the fiscal year ending "},{"tag":"date","attrib":{"date":"1980-09-30"},"text":"September 30, 1980","children":[],"tail":", the provisions of this Act (including amendments made by this Act) [see Short Title note above] shall be treated as if it were a contingency plan under section 202 or 203 of the Energy Policy and Conservation Act [former sections 6262 and 6263 of this title] which was approved in accordance with the procedures under that Act [see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s6201"},"text":"section 6201 of this title","children":[],"tail":"] or as otherwise provided by law, and funds made available pursuant to such appropriations shall be available to carry out the provisions of this Act and the amendments made by this Act.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
