{"tag":"section","attrib":{"id":"idc052405b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18113"},"text":null,"children":[{"tag":"num","attrib":{"value":"18113"},"text":"§ 18113.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition against discrimination on assisted suicide","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc052405c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18113/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal Government, and any State or local government or health care provider that receives Federal financial assistance under this Act (or under an amendment made by this Act) or any health plan created under this Act (or under an amendment made by this Act), may not subject an individual or institutional health care entity to discrimination on the basis that the entity does not provide any health care item or service furnished for the purpose of causing, or for the purpose of assisting in causing, the death of any individual, such as by assisted suicide, euthanasia, or mercy killing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc052405d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18113/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “health care entity” includes an individual physician or other health care professional, a hospital, a provider-sponsored organization, a health maintenance organization, a health insurance plan, or any other kind of health care facility, organization, or plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc052405e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18113/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction and treatment of certain services","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in subsection (a) shall be construed to apply to, or to affect, any limitation relating to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc052405f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18113/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the withholding or withdrawing of medical treatment or medical care;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0524060-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18113/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the withholding or withdrawing of nutrition or hydration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0524061-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18113/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" abortion; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0524062-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18113/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use of an item, good, benefit, or service furnished for the purpose of alleviating pain or discomfort, even if such use may increase the risk of death, so long as such item, good, benefit, or service is not also furnished for the purpose of causing, or the purpose of assisting in causing, death, for any reason.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0524063-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18113/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Office for Civil Rights of the Department of Health and Human Services is designated to receive complaints of discrimination based on this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc0524064-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/tI/s1553"},"text":"Pub. L. 111–148, title I, § 1553","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/259"},"text":"124 Stat. 259","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc0524065-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc0524066-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc0524067-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in subsec. (a), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148"},"text":"Pub. L. 111–148","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/119"},"text":"124 Stat. 119","children":[],"tail":", known as the Patient Protection and Affordable Care Act. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s18001"},"text":"section 18001 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
