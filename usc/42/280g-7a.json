{"tag":"section","attrib":{"id":"idb53cba58-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–7a"},"text":null,"children":[{"tag":"num","attrib":{"value":"280g–7a"},"text":"§ 280g–7a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Surveillance of neurological diseases","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb53cba59-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–7a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, acting through the Director of the Centers for Disease Control and Prevention and in coordination with other agencies as the Secretary determines, shall, as appropriate—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb53cba5a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–7a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhance and expand infrastructure and activities to track the epidemiology of neurological diseases; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53cba5b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–7a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" incorporate information obtained through such activities into an integrated surveillance system, which may consist of or include a registry, to be known as the National Neurological Conditions Surveillance System.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb53cba5c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–7a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall ensure that the National Neurological Conditions Surveillance System is designed in a manner that facilitates further research on neurological diseases.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb53cba5d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–7a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Content","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out subsection (a), the Secretary—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb53cba5e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–7a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall provide for the collection and storage of information on the incidence and prevalence of neurological diseases in the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53cba5f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–7a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to the extent practicable, shall provide for the collection and storage of other available information on neurological diseases, including information related to persons living with neurological diseases who choose to participate, such as—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb53cba60-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–7a/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demographics, such as age, race, ethnicity, sex, geographic location, family history, and other information, as appropriate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb53cba61-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–7a/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" risk factors that may be associated with neurological diseases, such as genetic and environmental risk factors and other information, as appropriate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb53cba62-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–7a/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" diagnosis and progression markers;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53cba63-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–7a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" may provide for the collection and storage of information relevant to analysis on neurological diseases, such as information concerning—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb53cba64-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–7a/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the natural history of the diseases;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb53cba65-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–7a/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the prevention of the diseases;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb53cba66-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–7a/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the detection, management, and treatment approaches for the diseases; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb53cba67-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–7a/c/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development of outcomes measures;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53cba68-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–7a/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may address issues identified during the consultation process under subsection (d); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53cba69-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–7a/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" initially may address a limited number of neurological diseases.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb53cba6a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–7a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out this section, the Secretary shall consult with individuals with appropriate expertise, which may include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb53cba6b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–7a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" epidemiologists with experience in disease surveillance or registries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53cba6c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–7a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" representatives of national voluntary health associations that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb53cba6d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–7a/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" focus on neurological diseases; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb53cba6e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–7a/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have demonstrated experience in research, care, or patient services;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53cba6f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–7a/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" health information technology experts or other information management specialists;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53cba70-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–7a/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" clinicians with expertise in neurological diseases; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53cba71-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–7a/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" research scientists with experience conducting translational research or utilizing surveillance systems for scientific research purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb53cba72-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–7a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may award grants to, or enter into contracts or cooperative agreements with, public or private nonprofit entities to carry out activities under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb53cba73-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–7a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with other Federal, State, and local agencies","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subsection (h), the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb53cba74-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–7a/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" make information and analysis in the National Neurological Conditions Surveillance System available, as appropriate—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb53cba75-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–7a/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to Federal departments and agencies, such as the National Institutes of Health and the Department of Veterans Affairs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb53cba76-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–7a/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to State and local agencies; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53cba77-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–7a/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify, build upon, leverage, and coordinate among existing data and surveillance systems, surveys, registries, and other Federal public health infrastructure, wherever practicable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb53cba78-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–7a/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public access","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subsection (h), the Secretary shall ensure that information and analysis in the National Neurological Conditions Surveillance System are available, as appropriate, to the public, including researchers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb53cba79-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–7a/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Privacy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall ensure that information and analysis in the National Neurological Conditions Surveillance System are made available only to the extent permitted by applicable Federal and State law, and in a manner that protects personal privacy, to the extent required by applicable Federal and State privacy law, at a minimum.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb53cba7a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–7a/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb53cba7b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–7a/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report on information and analyses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after the date on which any system is established under this section, the Secretary shall submit an interim report to the Committee on Health, Education, Labor, and Pensions of the Senate and the Committee on Energy and Commerce of the House of Representatives regarding aggregate information collected pursuant to this section and epidemiological analyses, as appropriate. Such report shall be posted on the Internet website of the Department of Health and Human Services and shall be updated biennially.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53cba7c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–7a/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 4 years after ","children":[{"tag":"date","attrib":{"date":"2016-12-13"},"text":"December 13, 2016","children":[],"tail":", the Secretary shall submit a report to the Congress concerning the implementation of this section. Such report shall include information on—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb53cba7d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–7a/i/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development and maintenance of the National Neurological Conditions Surveillance System;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb53cba7e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–7a/i/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the type of information collected and stored in the surveillance system;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb53cba7f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–7a/i/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use and availability of such information, including guidelines for such use; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb53cba80-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–7a/i/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use and coordination of databases that collect or maintain information on neurological diseases.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb53cba81-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–7a/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “national voluntary health association” means a national nonprofit organization with chapters, other affiliated organizations, or networks in States throughout the United States with experience serving the population of individuals with neurological disease and have demonstrated experience in neurological disease research, care, and patient services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb53f2b82-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–7a/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To carry out this section, there is authorized to be appropriated $5,000,000 for each of fiscal years 2018 through 2022.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb53f2b83-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title III, § 399S–1, as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/255/dA/tII/s2061"},"text":"Pub. L. 114–255, div. A, title II, § 2061","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-13"},"text":"Dec. 13, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1076"},"text":"130 Stat. 1076","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
