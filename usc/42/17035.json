{"tag":"section","attrib":{"id":"idc0203545-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17035"},"text":null,"children":[{"tag":"num","attrib":{"value":"17035"},"text":"§ 17035.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" University based research and development grant program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc0203546-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17035/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a competitive grant program, in a geographically diverse manner, for projects submitted for consideration by institutions of higher education to conduct research and development of renewable energy technologies. Each grant made shall not exceed $2,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0203547-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17035/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Priority shall be given to institutions of higher education with—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0203548-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17035/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" established programs of research in renewable energy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0203549-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17035/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" locations that are low income or outside of an urbanized area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc020354a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17035/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a joint venture with an Indian tribe; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc020354b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17035/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" proximity to trees dying of disease or insect infestation as a source of woody biomass.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc020354c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17035/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to the Secretary $25,000,000 for carrying out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc020354d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17035/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc020354e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17035/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian tribe","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Indian tribe” has the meaning as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s15823/c"},"text":"section 15823(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc020354f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17035/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Renewable energy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “renewable energy” has the meaning as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16181"},"text":"section 16181 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0203550-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17035/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Urbanized area","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “urbanized area” has the meaning as defined by the U.S. Bureau of the Census.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc0203551-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/tII/s234"},"text":"Pub. L. 110–140, title II, § 234","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1538"},"text":"121 Stat. 1538","childr