{"tag":"section","attrib":{"id":"idbdbb422d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6804"},"text":null,"children":[{"tag":"num","attrib":{"value":"6804"},"text":"§ 6804.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding, administrative, and judicial authorities of Secretary","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbdbb422e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6804/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fund (A) demonstration projects to improve electric utility load management procedures and (B) regulatory rate reform initiatives,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdbb422f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6804/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on request of a State, a utility regulatory commission, or of any participant in any proceeding before a State utility regulatory commission which relates to electric utility rates or rate design, intervene and participate in such proceeding, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdbb4230-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6804/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on request of any State, utility regulatory commission, or party to any action to obtain judicial review of an administrative proceeding in which the Secretary intervened or participated under paragraph (2), intervene and participate in such action.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbdbb4231-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/385/tII/s204"},"text":"Pub. L. 94–385, title II, § 204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-08-14"},"text":"Aug. 14, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1143"},"text":"90 Stat. 1143","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/617/tI/s143"},"text":"Pub. L. 95–617, title I, § 143","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-09"},"text":"Nov. 9, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3134"},"text":"92 Stat. 3134","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbdbb4232-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbdbb4233-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbdbb4234-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1978—","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/617"},"text":"Pub. L. 95–617","children":[],"tail":" substituted “Secretary” for “Administrator”, meaning Administrator of the Federal Energy Administration in two places."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
