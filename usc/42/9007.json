{"tag":"section","attrib":{"id":"idbea9c0a2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9007"},"text":null,"children":[{"tag":"num","attrib":{"value":"9007"},"text":"§ 9007.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical Panel of Energy Research Advisory Board","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbea9c0a3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9007/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A Technical Panel of the Energy Research Advisory Board shall be established to advise the Board on the conduct of the ocean thermal energy conversion program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbea9c0a4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9007/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbea9c0a5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9007/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Technical Panel shall be comprised of such representatives from domestic industry, universities, Government laboratories, financial, environmental and other organizations as the Chairman of the Energy Research Advisory Board deems appropriate based on his assessment of the technical and other qualifications of such representative.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbea9c0a6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9007/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Members of the Technical Panel need not be members of the full Energy Research Advisory Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbea9c0a7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9007/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compliance with laws and regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The activities of the Technical Panel shall be in compliance with any laws and regulations guiding the activities of technical and fact-finding groups reporting to the Energy Research Advisory Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbea9c0a8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9007/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review and recommendations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Technical Panel shall review and may make recommendations on the following items, among others:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbea9c0a9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9007/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" implementation and conduct of the programs established by this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbea9c0aa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9007/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" definition of ocean thermal energy conversion system performance requirements for various user applications; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbea9c0ab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9007/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" economic, technological, and environmental consequences of the deployment of ocean thermal energy conversion systems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbea9c0ac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9007/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Technical Panel shall submit to the Energy Research Advisory Board on at least an annual basis a written report of its findings and recommendations with regard to the program. Such report, shall include at a minimum—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbea9c0ad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9007/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a summary of the Panel’s activities for the preceding year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbea9c0ae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9007/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment and evaluation of the status of the programs mandated by this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbea9c0af-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9007/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" comments on and recommendations for improvements in the comprehensive program management plan required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s9002"},"text":"section 9002 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbea9c0b0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9007/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submittal of report to Secretary of Energy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After consideration of the Technical Panel report, the Energy Research Advisory Board shall submit such report, together with any comments such Board deems appropriate, to the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbea9c0b1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9007/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperation by agency heads","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The heads of the departments, agencies, and instrumentalities of the executive branch of the Federal Government shall cooperate with the Technical Panel in carrying out the requirements of this section and shall furnish to the Technical Panel such information as the Technical Panel deems necessary to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbea9c0b2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9007/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Staff, funds, and other support from Secretary of Energy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide sufficient staff, funds, and other support as necessary to enable the Technical Panel to carry out the functions described in this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbea9c0b3-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/310/s8"},"text":"Pub. L. 96–310, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-07-17"},"text":"July 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/945"},"text":"94 Stat. 945","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbea9c0b4-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbea9c0b5-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbea9c0b6-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Advisory Panels","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Advisory panels established after ","children":[{"tag":"date","attrib":{"date":"1973-01-05"},"text":"Jan. 5, 1973","children":[],"tail":", to terminate not later than the expiration of the 2-year period beginning on the date of their establishment, unless, in the case of a panel established by the President or an officer of the Federal Government, such panel is renewed by appropriate action prior to the expiration of such 2-year period, or in the case of a panel established by the Congress, its duration is otherwise provided for by law. See sections 1001(2) and 1013 of Title 5, Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
