{"tag":"section","attrib":{"id":"idbd60c680-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5845"},"text":null,"children":[{"tag":"num","attrib":{"value":"5845"},"text":"§ 5845.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of Nuclear Regulatory Research","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd60c681-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5845/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment; appointment of Director","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is hereby established in the Commission an Office of Nuclear Regulatory Research under the direction of a Director of Nuclear Regulatory Research, who shall be appointed by the Commission, who may report directly to the Commission as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5849"},"text":"section 5849 of this title","children":[],"tail":", and who shall serve at the pleasure of and be removable by the Commission."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd60c682-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5845/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions of Director","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to the provisions of this chapter, the Director of Nuclear Regulatory Research shall perform such functions as the Commission shall delegate including:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd60c683-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5845/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Developing recommendations for research deemed necessary for performance by the Commission of its licensing and related regulatory functions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd60c684-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5845/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Engaging in or contracting for research which the Commission deems necessary for the performance of its licensing and related regulatory functions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd60c685-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5845/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperation of Federal agencies","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator of the Administration and the head of every other Federal agency shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd60c686-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5845/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cooperate with respect to the establishment of priorities for the furnishing of such research services as requested by the Commission for the conduct of its functions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd60c687-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5845/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" furnish to the Commission, on a reimbursable basis, through their own facilities or by contract or other arrangement, such research services as the Commission deems necessary and requests for the performance of its functions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd60c688-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5845/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consult and cooperate with the Commission on research and development matters of mutual interest and provide such information and physical access to its facilities as will assist the Commission in acquiring the expertise necessary to perform its licensing and related regulatory functions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd60c689-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5845/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibility for safety of activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in subsections (a) and (b) of this section or ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5841"},"text":"section 5841 of this title","children":[],"tail":" shall be construed to limit in any way the functions of the Administration relating to the safety of activities within the jurisdiction of the Administration."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd60c68a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5845/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information and research services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each Federal agency, subject to the provisions of existing law, shall cooperate with the Commission and provide such information and research services, on a reimbursable basis, as it may have or be reasonably able to acquire.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd60c68b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5845/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Improved safety systems research","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall develop a long-term plan for projects for the development of new or improved safety systems for nuclear powerplants.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd60c68c-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/438/tII/s205"},"text":"Pub. L. 93–438, title II, § 205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-10-11"},"text":"Oct. 11, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1246"},"text":"88 Stat. 1246","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/209/s4/a"},"text":"Pub. L. 95–209, § 4(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-12-13"},"text":"Dec. 13, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1482"},"text":"91 Stat. 1482","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd60c68d-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd60c68e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbd60c68f-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (b), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/438"},"text":"Pub. L. 93–438","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-10-11"},"text":"Oct. 11, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1233"},"text":"88 Stat. 1233","children":[],"tail":", known as the Energy Reorganization Act of 1974, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5801"},"text":"section 5801 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd60c690-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1977—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/209"},"text":"Pub. L. 95–209","children":[],"tail":" added subsec. (f)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idbd60c691-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"idbd60c692-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of certain functions from Nuclear Regulatory Commission to Chairman thereof, see Reorg. Plan No. 1 of 1980, 45 F.R. 40561, ","children":[{"tag":"ref","attrib":{"href":"/us/stat/94/3585"},"text":"94 Stat. 3585","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5841"},"text":"section 5841 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
