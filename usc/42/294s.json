{"tag":"section","attrib":{"id":"idb5e619ab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294s"},"text":null,"children":[{"tag":"num","attrib":{"value":"294s"},"text":"§ 294s.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rural maternal and obstetric care training demonstration","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5e619ac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294s/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall award grants to accredited schools of allopathic medicine, osteopathic medicine, and nursing, and other appropriate health professional training programs, to establish a training demonstration program to support—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5e619ad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294s/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" training for physicians, medical residents, fellows, nurse practitioners, physician assistants, nurses, certified nurse midwives, relevant home visiting workforce professionals and paraprofessionals, or other professionals who meet relevant State training and licensing requirements, as applicable, to reduce preventable maternal mortality and severe maternal morbidity by improving prenatal care, labor care, birthing, and postpartum care in rural community-based settings; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5e619ae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294s/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing recommendations for such training programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5e619af-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294s/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be eligible to receive a grant under subsection (a), an entity shall submit to the Secretary an application at such time, in such manner, and containing such information as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5e619b0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294s/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5e619b1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294s/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training for health care professionals","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A recipient of a grant under subsection (a)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5e619b2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294s/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall use the grant funds to plan, develop, and operate a training program to provide prenatal care, labor care, birthing, and postpartum care in rural areas; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5e619b3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294s/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may use the grant funds to provide additional support for the administration of the program or to meet the costs of projects to establish, maintain, or improve faculty development, or departments, divisions, or other units necessary to implement such training.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5e619b4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294s/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training program requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The recipient of a grant under subsection (a) shall ensure that training programs carried out under the grant are evidence-based and address improving prenatal care, labor care, birthing, and postpartum care in rural areas, and such programs may include training on topics such as—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5e619b5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294s/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maternal mental health, including perinatal depression and anxiety;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5e619b6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294s/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" substance use disorders;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5e619b7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294s/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" social determinants of health that affect individuals living in rural areas; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5e619b8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294s/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improving the provision of prenatal care, labor care, birthing, and postpartum care for racial and ethnic minority populations, including with respect to perceptions and biases that may affect the approach to, and provision of, care.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5e619b9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294s/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation and report","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5e619ba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294s/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5e619bb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294s/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall evaluate the outcomes of the demonstration program under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5e619bc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294s/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data submission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Recipients of a grant under subsection (a) shall submit to the Secretary performance metrics and other related data in order to evaluate the program for the report described in paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5e619bd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294s/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2026-01-01"},"text":"January 1, 2026","children":[],"tail":", the Secretary shall submit to Congress a report that includes—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5e619be-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294s/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an analysis of the effects of the demonstration program under this section on the quality, quantity, and distribution of maternal health care services, including prenatal care, labor care, birthing, and postpartum care services, and the demographics of the recipients of those services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5e619bf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294s/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an analysis of maternal and infant health outcomes (including quality of care, morbidity, and mortality) before and after implementation of the program in the communities served by entities participating in the demonstration; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5e619c0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294s/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommendations on whether the demonstration program should be continued.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5e619c1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294s/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this section $5,000,000 for each of fiscal years 2023 through 2027.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5e619c2-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title VII, § 764, as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/103/dP/tI/s144"},"text":"Pub. L. 117–103, div. P, title I, § 144","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/800"},"text":"136 Stat. 800","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb5e619c3-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb5e619c4-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb5e619c5-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another section 764 of act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", was renumbered section 764A and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s294t"},"text":"section 294t of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb5e619c6-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 294s, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373/tVII/s749"},"text":"act July 1, 1944, ch. 373, title VII, § 749","children":[],"tail":", as added "},{"tag":"date","attrib":{"date":"1976-10-12"},"text":"Oct. 12, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/94/484/tIV/s408/a"},"text":"Pub. L. 94–484, title IV, § 408(a)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2280"},"text":"90 Stat. 2280","children":[],"tail":"; amended "},{"tag":"date","attrib":{"date":"1977-08-01"},"text":"Aug. 1, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/95/83/tIII/s307/f"},"text":"Pub. L. 95–83, title III, § 307(f)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/391"},"text":"91 Stat. 391","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/96/88/tIII/s301/a/1"},"text":"Pub. L. 96–88, title III, § 301(a)(1)","children":[],"tail":", title V, § 507, "},{"tag":"ref","attrib":{"href":"/us/stat/93/677"},"text":"93 Stat. 677","children":[],"tail":", 692, which related to traineeships for students in other graduate programs, was renumbered section 791A of act "},{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", by "},{"tag":"ref","attrib":{"href":"/us/pl/97/35"},"text":"Pub. L. 97–35","children":[],"tail":" and transferred to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s295h–1a"},"text":"section 295h–1a of this title","children":[],"tail":", and was subsequently omitted in the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/102/408"},"text":"Pub. L. 102–408","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
