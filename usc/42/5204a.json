{"tag":"section","attrib":{"id":"idbd310310-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5204a"},"text":null,"children":[{"tag":"num","attrib":{"value":"5204a"},"text":"§ 5204a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations for insular areas","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"There are hereby authorized to be appropriated to the Secretary such sums as may be necessary to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd310311-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5204a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reconstruct essential public facilities damaged by disasters in the insular areas that occurred prior to ","children":[{"tag":"date","attrib":{"date":"1992-02-24"},"text":"February 24, 1992","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd310312-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5204a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhance the survivability of essential public facilities in the event of disasters in the insular areas,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"except that with respect to the disaster declared by the President in the case of Hurricane Hugo, September 1989, amounts for any fiscal year shall not exceed 25 percent of the estimated aggregate amount of grants to be made under sections 5170b and 5172 of this title for such disaster. Such sums shall remain available until expended.","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd310313-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/247/tII/s202"},"text":"Pub. L. 102–247, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-02-24"},"text":"Feb. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/37"},"text":"106 Stat. 37","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd310314-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd310315-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbd310316-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Omnibus Insular Areas Act of 1992, and not as part of the Robert T. Stafford Disaster Relief and Emergency Assistance Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
