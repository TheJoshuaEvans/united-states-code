{"tag":"section","attrib":{"id":"idbcb9d76c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4124"},"text":null,"children":[{"tag":"num","attrib":{"value":"4124"},"text":"§ 4124.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of fiscal controls","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The provisions of chapter 91 of title 31 shall apply to the program authorized under this chapter to the same extent as they apply to wholly owned Government corporations.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbcb9d76d-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/448/tXIII/s1373"},"text":"Pub. L. 90–448, title XIII, § 1373","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-08-01"},"text":"Aug. 1, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/589"},"text":"82 Stat. 589","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/479/tII/s203/j/3"},"text":"Pub. L. 98–479, title II, § 203(j)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-17"},"text":"Oct. 17, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2231"},"text":"98 Stat. 2231","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbcb9d76e-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbcb9d76f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbcb9d770-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag