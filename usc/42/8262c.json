{"tag":"section","attrib":{"id":"idbe8ac7ab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8262c"},"text":null,"children":[{"tag":"num","attrib":{"value":"8262c"},"text":"§ 8262c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal agency energy management training","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbe8ac7ac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8262c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Energy management training","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe8ac7ad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8262c/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Each executive department described under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s101"},"text":"section 101 of title 5","children":[],"tail":", the Environmental Protection Agency, the National Aeronautics and Space Administration, the General Services Administration, and the United States Postal Service shall establish and maintain a program to ensure that facility energy managers are trained energy managers. Such programs shall be managed—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbe8ac7ae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8262c/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by the department or agency representative on the Task Force; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe8ac7af-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8262c/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if a department or agency is not represented on the Task Force, by the designee of the head of such department or agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe8ac7b0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8262c/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Departments and agencies described in paragraph (1) shall encourage appropriate employees to participate in energy manager training courses. Employees may enroll in courses of study in the areas described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s8262/3"},"text":"section 8262(3) of this title","children":[],"tail":" including, but not limited to, courses offered by—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbe8ac7b1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8262c/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" private or public educational institutions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe8ac7b2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8262c/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal agencies; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe8ac7b3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8262c/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" professional associations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe8ac7b4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8262c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Task Force","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe8ac7b5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8262c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Each department and agency described in subsection (a)(1) shall, not later than 60 days following ","children":[{"tag":"date","attrib":{"date":"1992-10-24"},"text":"October 24, 1992","children":[],"tail":", report to the Task Force the following information:"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbe8ac7b6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8262c/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Those individuals employed by such department or agency on ","children":[{"tag":"date","attrib":{"date":"1992-10-24"},"text":"October 24, 1992","children":[],"tail":", who qualify as trained energy managers."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe8ac7b7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8262c/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The General Schedule (GS) or grade level at which each of the individuals described in subparagraph (A) is employed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe8ac7b8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8262c/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The facility or facilities for which such individuals are responsible or otherwise stationed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe8ac7b9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8262c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall provide a summary of the reports described in paragraph (1) to the Congress as part of the first report submitted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s8258"},"text":"section 8258 of this title","children":[],"tail":" after "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"October 24, 1992","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe8ac7ba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8262c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements at Federal facilities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe8ac7bb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8262c/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Not later than one year after ","children":[{"tag":"date","attrib":{"date":"1992-10-24"},"text":"October 24, 1992","children":[],"tail":", the departments and agencies described under subsection (a)(1) shall upgrade their energy management capabilities by—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbe8ac7bc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8262c/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designating facility energy supervisors;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe8ac7bd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8262c/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encouraging facility energy supervisors to become trained energy managers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe8ac7be-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8262c/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increasing the overall number of trained energy managers within such department or agency to a sufficient level to ensure effective implementation of this Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe8ac7bf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8262c/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Departments and agencies described in subsection (a)(1) may hire trained energy managers to be facility energy supervisors. Trained energy managers, including those who are facility supervisors as well as other trained personnel, shall focus their efforts on improving energy efficiency in the following facilities—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbe8ac7c0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8262c/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" department or agency facilities identified as most costly to operate or most energy inefficient; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe8ac7c1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8262c/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other facilities identified by the department or agency head as having significant energy savings potential.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe8ac7c2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8262c/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report to Secretary and Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each department and agency listed in subsection (a)(1) shall report to the Secretary on the status and implementation of the requirements of this section. The Secretary shall include a summary of each such report in the annual report to Congress as required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s8258/b"},"text":"section 8258(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbe8ac7c3-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/tI/s157"},"text":"Pub. L. 102–486, title I, § 157","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2856"},"text":"106 Stat. 2856","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbe8ac7c4-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbe8ac7c5-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbe8ac7c6-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The General Schedule, referred to in subsec. (b)(1)(B), is set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5332"},"text":"section 5332 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This Act, referred to in subsec. (c)(1)(C), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486"},"text":"Pub. L. 102–486","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2776"},"text":"106 Stat. 2776","children":[],"tail":", known as the Energy Policy Act of 1992. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s13201"},"text":"section 13201 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbe8ac7c7-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Energy Policy Act of 1992, and not as part of the National Energy Conservation Policy Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
