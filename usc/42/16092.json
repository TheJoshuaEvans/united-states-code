{"tag":"section","attrib":{"id":"idbff0729d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16092"},"text":null,"children":[{"tag":"num","attrib":{"value":"16092"},"text":"§ 16092.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Diesel truck retrofit and fleet modernization program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbff0729e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16092/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator, in consultation with the Secretary, shall establish a program for awarding grants on a competitive basis to public agencies and entities for fleet modernization programs including installation of retrofit technologies for diesel trucks.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff0729f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16092/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible recipients","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A grant shall be awarded under this section only to a State or local government or an agency or instrumentality of a State or local government or of two or more State or local governments who will allocate funds, with preference to ports and other major hauling operations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff072a0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16092/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Awards","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbff072a1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16092/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall seek, to the maximum extent practicable, to ensure a broad geographic distribution of grants under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff072a2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16092/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preferences","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In making awards of grants under this section, the Administrator shall give preference to proposals that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbff072a3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16092/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will achieve the greatest reductions in emissions of nonmethane hydrocarbons, oxides of nitrogen, and/or particulate matter per proposal or per truck; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff072a4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16092/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" involve the use of Environmental Protection Agency or California Air Resources Board verified emissions control retrofit technology on diesel trucks that operate solely on ultra-low sulfur diesel fuel after September 2006.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff072a5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16092/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conditions of grant","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A grant shall be provided under this section on the conditions that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbff072a6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16092/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" trucks which are replacing scrapped trucks and on which retrofit emissions-control technology are to be demonstrated—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbff072a7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16092/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will operate on ultra-low sulfur diesel fuel where such fuel is reasonably available or required for sale by State or local law or regulation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff072a8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16092/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" were manufactured in model year 1998 and before; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff072a9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16092/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will be used for the transportation of cargo goods especially in port areas or used in goods movement and major hauling operations;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff072aa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16092/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" grant funds will be used for the purchase of emission control retrofit technology, including State taxes and contract fees; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff072ab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16092/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" grant recipients will provide at least 50 percent of the total cost of the retrofit, including the purchase of emission control retrofit technology and all necessary labor for installation of the retrofit, from any source other than this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff072ac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16092/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Verification","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":", the Administrator shall publish in the Federal Register procedures to—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbff072ad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16092/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make grants pursuant to this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff072ae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16092/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" verify that trucks powered by ultra-low sulfur diesel fuel on which retrofit emissions-control technology are to be demonstrated will operate on diesel fuel containing not more than 15 parts per million of sulfur after September 2006; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff072af-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16092/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" verify that grants are administered in accordance with this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff072b0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16092/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated to the Administrator to carry out this section, to remain available until expended the following sums:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbff072b1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16092/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $20,000,000 for fiscal year 2006.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff072b2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16092/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $35,000,000 for fiscal year 2007.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff072b3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16092/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $45,000,000 for fiscal year 2008.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff072b4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16092/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such sums as are necessary for each of fiscal years 2009 and 2010.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbff072b5-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tVII/s742"},"text":"Pub. L. 109–58, title VII, § 742","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/824"},"text":"119 Stat. 824","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
