{"tag":"section","attrib":{"id":"idc03347fb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17303"},"text":null,"children":[{"tag":"num","attrib":{"value":"17303"},"text":"§ 17303.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement by the Federal Trade Commission","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc03347fc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17303/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This part shall be enforced by the Federal Trade Commission in the same manner, by the same means, and with the same jurisdiction as though all applicable terms of the Federal Trade Commission Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s41"},"text":"15 U.S.C. 41","children":[],"tail":" et seq.) were incorporated into and made a part of this part."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc03347fd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17303/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Violation is treated as unfair or deceptive act or practice","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The violation of any provision of this part shall be treated as an unfair or deceptive act or practice proscribed under a rule issued under section 18(a)(1)(B) of the Federal Trade Commission Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s57a/a/1/B"},"text":"15 U.S.C. 57a(a)(1)(B)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc03347fe-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/tVIII/s813"},"text":"Pub. L. 110–140, title VIII, § 813","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1724"},"text":"121 Stat. 1724","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc03347ff-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc0334800-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc0334801-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Trade Commission Act, referred to in subsec. (a), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1914-09-26/ch311"},"text":"act Sept. 26, 1914, ch. 311","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/38/717"},"text":"38 Stat. 717","children":[],"tail":", which is classified generally to subchapter I (§ 41 et seq.) of chapter 2 of Title 15, Commerce and Trade. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s58"},"text":"section 58 of Title 15","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc03590f2-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc03590f3-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the date that is 1 day after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/s1601"},"text":"section 1601 of Pub. L. 110–140","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1824"},"text":"section 1824 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
