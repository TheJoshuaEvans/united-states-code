{"tag":"section","attrib":{"id":"idc024eef4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17083"},"text":null,"children":[{"tag":"num","attrib":{"value":"17083"},"text":"§ 17083.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public outreach","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Commercial Director and Federal Director, in coordination with the Consortium, shall carry out public outreach to inform individuals and entities of the information and services available governmentwide by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc024eef5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17083/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" establishing and maintaining a national high-performance green building clearinghouse, including on the Internet, that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc024eef6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17083/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifies existing similar efforts and coordinates activities of common interest; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc024eef7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17083/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provides information relating to high-performance green buildings, including hyperlinks to Internet sites that describe the activities, information, and resources of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc024eef8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17083/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc024eef9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17083/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State and local governments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc024eefa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17083/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the private sector (including nongovernmental and nonprofit entities and organizations); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc024eefb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17083/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" international organizations;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc024eefc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17083/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying and recommending educational resources for implementing high-performance green building practices, including security and emergency benefits and practices;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc024eefd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17083/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing access to technical assistance, tools, and resources for constructing high-performance green buildings, particularly tools to conduct life-cycle costing and life-cycle assessment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc024eefe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17083/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing information on application processes for certifying a high-performance green building, including certification and commissioning;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc024eeff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17083/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing to the public, through the Commercial Director, technical and research information or other forms of assistance or advice that would be useful in planning and constructing high-performance green buildings;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc024ef00-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17083/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" using such additional methods as are determined by the Commercial Director to be appropriate to conduct public outreach;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc024ef01-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17083/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" surveying existing research and studies relating to high-performance green buildings; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc024ef02-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17083/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinating activities of common interest.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc024ef03-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/tIV/s423"},"text":"Pub. L. 110–140, title IV, § 423","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1606"},"text":"121 Stat. 1606","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc024ef04-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc024ef05-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc024ef06-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the date that is 1 day after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/s1601"},"text":"section 1601 of Pub. L. 110–140","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1824"},"text":"section 1824 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
