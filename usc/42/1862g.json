{"tag":"section","attrib":{"id":"idbb863a05-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862g"},"text":null,"children":[{"tag":"num","attrib":{"value":"1862g"},"text":"§ 1862g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Established Program to Stimulate Competitive Research","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbb863a06-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862g/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Director shall operate a program to stimulate competitive research (known as the “Established Program to Stimulate Competitive Research”), the purpose of which is to assist those States that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb863a07-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862g/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" historically have received relatively little Federal research and development funding; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb863a08-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862g/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have demonstrated a commitment to develop their research bases and improve science and engineering research and education programs at their universities and colleges.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb863a09-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862g/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A State which has received an initial award under such Program, whether or not the award was received before or after ","children":[{"tag":"date","attrib":{"date":"1988-10-31"},"text":"October 31, 1988","children":[],"tail":", shall be eligible for up to 5 years of additional support under the Program if that State provides assurances of new matching funds and submits an acceptable new plan for using Program funds and matching funds to build the research capabilities of the State."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbb863a0a-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/570/tI/s113"},"text":"Pub. L. 100–570, title I, § 113","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-31"},"text":"Oct. 31, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2870"},"text":"102 Stat. 2870","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/329/tI/s103/e/2"},"text":"Pub. L. 114–329, title I, § 103(e)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-01-06"},"text":"Jan. 6, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2975"},"text":"130 Stat. 2975","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbb863a0b-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbb863a0c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbb863a0d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the National Science Foundation Authorization Act of 1988, and not as part of the National Science Foundation Act of 1950 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbb863a0e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/329/s103/e/2/A"},"text":"Pub. L. 114–329, § 103(e)(2)(A)","children":[],"tail":", substituted “Established” for “Experimental” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/329/s103/e/2/B"},"text":"Pub. L. 114–329, § 103(e)(2)(B)","children":[],"tail":", substituted “a program to stimulate competitive research (known as the ‘Established Program to Stimulate Competitive Research’)” for “an Experimental Program to Stimulate Competitive Research” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/329/s103/e/2/C"},"text":"Pub. L. 114–329, § 103(e)(2)(C)","children":[],"tail":", substituted “the Program” for “the program”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbb863a0f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbb863a10-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Planning Grants","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/368/s26"},"text":"Pub. L. 107–368, § 26","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-19"},"text":"Dec. 19, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/3067"},"text":"116 Stat. 3067","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/368/s26"},"text":"“The Director is authorized to accept planning proposals from applicants who are within .075 percentage points of the current eligibility level for the Experimental Program to Stimulate Competitive Research. Such proposals shall be reviewed by the Foundation to determine their merit for support under the Experimental Program to Stimulate Competitive Research or any other appropriate program.”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[For definitions of terms used in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/368/s26"},"text":"section 26 of Pub. L. 107–368","children":[],"tail":", set out above, see "},{"tag":"ref","attrib":{"href":"/us/pl/107/368/s4"},"text":"section 4 of Pub. L. 107–368","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1862n"},"text":"section 1862n of this title","children":[],"tail":".]"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
