{"tag":"section","attrib":{"id":"idb4879abc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s239d"},"text":null,"children":[{"tag":"num","attrib":{"value":"239d"},"text":"§ 239d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation for lost employment income","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb4879abd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s239d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the succeeding provisions of this section, the Secretary shall provide compensation to an eligible individual for loss of employment income (based on such income at the time of injury) incurred as a result of a covered injury, at the rate specified in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4879abe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s239d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of compensation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4879abf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s239d/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Compensation under subsection (a) shall be at the rate of 66⅔ percent of the relevant pay period (weekly, monthly, or otherwise), except as provided in paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4879ac0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s239d/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Augmented compensation for dependents","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If an eligible individual has one or more dependents, the basic compensation for loss of employment income as described in paragraph (1) shall be augmented at the rate of 8⅓ percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4879ac1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s239d/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consideration of other programs","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4879ac2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s239d/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may consider the provisions of sections 8114, 8115, and 8146a of title 5, and any implementing regulations, in determining the amount of payment under subsection (a) and the circumstances under which such payments are reasonable and necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4879ac3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s239d/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minors","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to an eligible individual who is a minor, the Secretary may consider the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8113"},"text":"section 8113 of title 5","children":[],"tail":", and any implementing regulations, in determining the amount of payment under subsection (a) and the circumstances under which such payments are reasonable and necessary."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4879ac4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s239d/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of self-employment income","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “employment income” includes income from self-employment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4879ac5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s239d/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4879ac6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s239d/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Benefits secondary to other coverage","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4879ac7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s239d/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any compensation under subsection (a) shall be secondary to the obligation of the United States or any third party (including any State or local governmental entity, private insurance carrier, or employer), under any other law or contractual agreement, to pay compensation for loss of employment income or to provide disability or retirement benefits.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4879ac8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s239d/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relation to other obligations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Compensation under subsection (a) shall not be made to an eligible individual to the extent that the total of amounts paid to the individual under such subsection and under the other obligations referred to in subparagraph (A) is an amount that exceeds the rate specified in subsection (b)(1). If under any such other obligation a lump-sum payment is made, such payment shall, for purposes of this paragraph, be deemed to be received over multiple years rather than received in a single year. The Secretary may, in the discretion of the Secretary, determine how to apportion such payment over multiple years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4879ac9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s239d/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No benefits in case of death","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No payment shall be made under subsection (a) in compensation for loss of employment income subsequent to the receipt, by the survivor or survivors of an eligible individual, of benefits under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s239e"},"text":"section 239e of this title","children":[],"tail":" for death."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4879aca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s239d/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limit on total benefits","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4879acb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s239d/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subparagraph (B)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb4879acc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s239d/c/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" total compensation paid to an individual under subsection (a) shall not exceed $50,000 for any year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb4879acd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s239d/c/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the lifetime total of such compensation for the individual may not exceed an amount equal to the amount authorized to be paid under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s239e"},"text":"section 239e of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4879ace-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s239d/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Permanent and total disability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The limitation under subparagraph (A)(ii) does not apply in the case of an eligible individual who is determined to have a covered injury or injuries meeting the definition of disability in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s416/i"},"text":"section 416(i) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4879acf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s239d/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiting period","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4879ad0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s239d/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subparagraph (B), an eligible individual shall not be provided compensation under this section for the first 5 work days of loss of employment income.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4879ad1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s239d/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subparagraph (A) does not apply if the period of loss of employment income of an eligible individual is 10 or more work days.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4879ad2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s239d/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of benefits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No payment shall be made under subsection (a) in compensation for loss of employment income once the eligible individual involves ","children":[{"tag":"ref","attrib":{"idref":"fn002022"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002022"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “involved”."}],"tail":" reaches the age of 65."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4879ad3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s239d/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Benefit in addition to medical benefits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A benefit under subsection (a) shall be in addition to any amounts received by an eligible individual under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s239c"},"text":"section 239c of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb4879ad4-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title II, § 265, as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/20/s2"},"text":"Pub. L. 108–20, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-04-30"},"text":"Apr. 30, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/642"},"text":"117 Stat. 642","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
