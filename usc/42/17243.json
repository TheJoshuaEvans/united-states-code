:[],"tail":null},{"tag":"content","attrib":{},"text":" having 70 percent of the lumen value under subparagraph (A) exceeding 25,000 hours under typical conditions expected in residential use;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc030d769-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17243/b/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" having a light distribution pattern similar to a soft 60-watt incandescent A19 bulb;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc030d76a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17243/b/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" having a size and shape that fits within the maximum dimensions of an A19 bulb in accordance with American National Standards Institute standard C78.20–2003, figure C78.20–211;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc030d76b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17243/b/1/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" using a single contact medium screw socket; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc030d76c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17243/b/1/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" mass production for a competitive sales commercial market satisfied by producing commercially accepted quality control lots of such units equal to or exceeding the criteria described in subparagraphs (A) through (I).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{