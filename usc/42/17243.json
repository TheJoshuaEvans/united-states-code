children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0334672-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17243/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" having a correlated color coordinate temperature of not less than 2,750, and not more than 3,000, degrees Kelvin;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0334673-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17243/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" having 70 percent of the lumen value under subparagraph (A) exceeding 25,000 hours under typical conditions expected in residential use;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0334674-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17243/b/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" having a light distribution pattern similar to a PAR 38 halogen lamp;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0334675-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17243/b/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" having a size and shape that fits within the maximum dimensions of a PAR 38 halogen lamp in accordance with American National Standards Institute standard C78–21–2003, figure C78.21–238;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0334676-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17243/b/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" using a single contact medium screw socket; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0334677-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17243/b/2/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" mass production for a competitive sales commercial market satisfied by producing commercially accepted quality control lots of such units equal to or exceeding the criteria described in subparagraphs (A) through (I).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0334678-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17243/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Twenty-First Century Lamp Prize","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall award a Twenty-First Century Lamp Prize to an entrant that produces a solid-state-light-light ","children":[{"tag":"ref","attrib":{"idref":"fn004269"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004269"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original."}],"tail":" capable of—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0334679-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17243/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" producing a light output greater than 1,200 lumens;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc033467a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17243/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" having an efficiency greater than 150 lumens per watt;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc033467b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17243/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" having a color rendering index greater than 90;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc033467c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17243/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" having a color coordinate temperature between 2,800 and 3,000 degrees Kelvin; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc033467d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17243/b/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" having a lifetime exceeding 25,000 hours.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc033467e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17243/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Private funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc033467f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17243/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to paragraph (2), and notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3302"},"text":"section 3302 of title 31","children":[],"tail":", the Secretary may accept, retain, and use funds contributed by any person, government entity, or organization for purposes of carrying out this subsection—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0334680-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17243/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" without further appropriation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0334681-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17243/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" without fiscal year limitation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0334682-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17243/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prize competition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A private source of funding may not participate in the competition for prizes awarded under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0334683-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17243/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a technical review committee composed of non-Federal officers to review entrant data submitted under this section to determine whether the data meets the prize specifications described in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0334684-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17243/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Third party administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may competitively select a third party to administer awards under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0334685-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17243/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility for prizes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to be awarded a prize under this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0334686-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17243/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a private entity, the entity shall be incorporated in and maintain a primary place of business in the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0334687-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17243/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an individual (whether participating as a single individual or in a group), the individual shall be a citizen or lawful permanent resident of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0334688-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17243/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Award amounts","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to the availability of funds to carry out this section, the amount of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0334689-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17243/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the 60-Watt Incandescent Replacement Lamp Prize described in subsection (b)(1) shall be $10,000,000;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc033468a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17243/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the PAR Type 38 Halogen Replacement Lamp Prize described in subsection (b)(2) shall be $5,000,000; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc033468b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17243/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Twenty-First Century Lamp Prize described in subsection (b)(3) shall be $5,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc033468c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17243/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal procurement of solid-state-lights","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc033468d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17243/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" 60-watt incandescent replacement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (3), as soon as practicable after the successful award of the 60-Watt Incandescent Replacement Lamp Prize under subsection (b)(1), the Secretary (in consultation with the Administrator of General Services) shall develop governmentwide Federal purchase guidelines with a goal of replacing the use of 60-watt incandescent lamps in Federal Government buildings with a solid-state-light package described in subsection (b)(1) by not later than the date that is 5 years after the date the award is made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc033468e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17243/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" PAR 38 halogen replacement lamp replacement ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":null}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (3), as soon as practicable after the successful award of the PAR Type 38 Halogen Replacement Lamp Prize under subsection (b)(2), the Secretary (in consultation with the Administrator of General Services) shall develop governmentwide Federal purchase guidelines with the goal of replacing the use of PAR 38 halogen lamps in Federal Government buildings with a solid-state-light package described in subsection (b)(2) by not later than the date that is 5 years after the date the award is made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc033468f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17243/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waivers","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0334690-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17243/h/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary or the Administrator of General Services may waive the application of paragraph (1) or (2) if the Secretary or Administrator determines that the return on investment from the purchase of a solid-state-light package described in paragraph (1) or (2) of subsection (b), respectively, is cost prohibitive.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0334691-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17243/h/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report of waiver","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary or Administrator waives the application of paragraph (1) or (2), the Secretary or Administrator, respectively, shall submit to Congress an annual report that describes the waiver and provides a detailed justification for the waiver.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0334692-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17243/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"December 19, 2007","children":[],"tail":", and annually thereafter, the Administrator of General Services shall submit to the Energy Information Agency a report describing the quantity, type, and cost of each lighting product purchased by the Federal Government."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0334693-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17243/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bright Tomorrow Lighting Award Fund","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0334694-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17243/j/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established in the United States Treasury a Bright Tomorrow Lighting permanent fund without fiscal year limitation to award prizes under paragraphs (1), (2), and (3) of subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0334695-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17243/j/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sources of funding","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The fund established under paragraph (1) shall accept—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0334696-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17243/j/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fiscal year appropriations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0334697-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17243/j/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" private contributions authorized under subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0334698-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17243/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums as are necessary to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc0334699-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/tVI/s655"},"text":"Pub. L. 110–140, title VI, § 655","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1700"},"text":"121 Stat. 1700","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc033469a-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc033469b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc033469c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the date that is 1 day after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/s1601"},"text":"section 1601 of Pub. L. 110–140","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1824"},"text":"section 1824 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
