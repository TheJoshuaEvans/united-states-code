{"tag":"section","attrib":{"id":"idbffa0eaa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16215"},"text":null,"children":[{"tag":"num","attrib":{"value":"16215"},"text":"§ 16215.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Electric transmission and distribution programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbffa0eab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16215/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall establish a comprehensive research, development, and demonstration program to ensure the reliability, efficiency, and environmental integrity of electrical transmission and distribution systems, which shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbffa0eac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16215/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advanced energy delivery technologies, energy storage technologies, materials, and systems, giving priority to new transmission technologies, including composite conductor materials and other technologies that enhance reliability, operational flexibility, or power-carrying capability;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbffa0ead-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16215/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advanced grid reliability and efficiency technology development;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbffa0eae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16215/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" technologies contributing to significant load reductions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbffa0eaf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16215/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advanced metering, load management, and control technologies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbffa0eb0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16215/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" technologies to enhance existing grid components;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbffa0eb1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16215/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the development and use of high-temperature superconductors to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbffa0eb2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16215/a/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhance the reliability, operational flexibility, or power-carrying capability of electric transmission or distribution systems; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbffa0eb3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16215/a/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase the efficiency of electric energy generation, transmission, distribution, or storage systems;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbffa0eb4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16215/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" integration of power systems, including systems to deliver high-quality electric power, electric power reliability, and combined heat and power;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbffa0eb5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16215/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supply of electricity to the power grid by small scale, distributed and residential-based power generators;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbffa0eb6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16215/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development and use of advanced grid design, operation, and planning tools;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbffa0eb7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16215/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development of cost-effective technologies that enable two-way information and power flow between distributed energy resources and the electric grid;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbffa0eb8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16215/a/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development of technologies and concepts that enable interoperability between distributed energy resources and other behind-the-meter devices and the electric grid;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbffa0eb9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16215/a/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other infrastructure technologies, as appropriate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbffa0eba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16215/a/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" technology transfer and education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbffa0ebb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16215/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program plan","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbffa0ebc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16215/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":", the Secretary, in consultation with other appropriate Federal agencies, shall prepare and submit to Congress a 5-year program plan to guide activities under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbffa0ebd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16215/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In preparing the program plan, the Secretary shall consult with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbffa0ebe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16215/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" utilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbffa0ebf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16215/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" energy service providers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbffa0ec0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16215/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" manufacturers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbffa0ec1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16215/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" institutions of higher education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbffa0ec2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16215/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other appropriate State and local agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbffa0ec3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16215/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" environmental organizations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbffa0ec4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16215/b/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" professional and technical societies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbffa0ec5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16215/b/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other persons the Secretary considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbffa0ec6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16215/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall consider implementing the program under this section using a consortium of participants from industry, institutions of higher education, and National Laboratories.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbffa0ec7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16215/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 2 years after the submission of the plan under subsection (b), the Secretary shall submit to Congress a report—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbffa0ec8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16215/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describing the progress made under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbffa0ec9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16215/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying any additional resources needed to continue the development and commercial application of transmission and distribution of infrastructure technologies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbffa0eca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16215/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Power delivery research initiative","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbffa0ecb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16215/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a research, development, and demonstration initiative specifically focused on power delivery using components incorporating high temperature superconductivity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbffa0ecc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16215/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Goals","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The goals of the Initiative shall be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbffa0ecd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16215/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to establish world-class facilities to develop high temperature superconductivity power applications in partnership with manufacturers and utilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbffa0ece-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16215/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide technical leadership for establishing reliability for high temperature superconductivity power applications, including suitable modeling and analysis;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbffa0ecf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16215/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to facilitate the commercial transition toward direct current power transmission, storage, and use for high power systems using high temperature superconductivity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbffa0ed0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16215/e/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to facilitate the integration of very low impedance high temperature superconducting wires and cables in existing electric networks to improve system performance, power flow control, and reliability.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbffa0ed1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16215/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Initiative shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbffa0ed2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16215/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" feasibility analysis, planning, research, and design to construct demonstrations of superconducting links in high power, direct current, and controllable alternating current transmission systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbffa0ed3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16215/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" public-private partnerships to demonstrate deployment of high temperature superconducting cable into testbeds simulating a realistic transmission grid and under varying transmission conditions, including actual grid insertions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbffa0ed4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16215/e/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" testbeds developed in cooperation with National Laboratories, industries, and institutions of higher education to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbffa0ed5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16215/e/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrate those technologies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbffa0ed6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16215/e/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prepare the technologies for commercial introduction; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbffa0ed7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16215/e/3/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" address cost or performance roadblocks to successful commercial use.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbffa0ed8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16215/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transmission and distribution grid planning and operations initiative","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbffa0ed9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16215/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a research, development, and demonstration initiative specifically focused on tools needed to plan, operate, and expand the transmission and distribution grids in the presence of competitive market mechanisms for energy, load demand, customer response, and ancillary services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbffa0eda-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16215/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Goals","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The goals of the Initiative shall be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbffa0edb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16215/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbffa0edc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16215/f/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop and use a geographically distributed center, consisting of institutions of higher education, and National Laboratories, with expertise and facilities to develop the underlying theory and software for power system application; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbffa0edd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16215/f/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to ensure commercial development in partnership with software vendors and utilities;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbffa0ede-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16215/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide technical leadership in engineering and economic analysis for the reliability and efficiency of power systems planning and operations in the presence of competitive markets for electricity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbffa0edf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16215/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to model, simulate, and experiment with new market mechanisms and operating practices to understand and optimize those new methods before actual use; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbffa0ee0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16215/f/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide technical support and technology transfer to electric utilities and other participants in the domestic electric industry and marketplace.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbffa0ee1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16215/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" High-voltage transmission lines","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As part of the program described in subsection (a), the Secretary shall award a grant to a university research program to design and test, in consultation with the Tennessee Valley Authority, state-of-the-art optimization techniques for power flow through existing high voltage transmission lines.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbffa0ee2-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag