{"tag":"section","attrib":{"id":"idb8439277-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1320b–1"},"text":"§ 1320b–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification of Social Security claimant with respect to deferred vested benefits","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8439278-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Whenever—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8439279-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–1/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Commissioner of Social Security makes a finding of fact and a decision as to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb843927a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–1/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the entitlement of any individual to monthly benefits under section 402, 423, or 428 of this title, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb843927b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–1/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the entitlement of any individual to a lump-sum death payment payable under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s402/i"},"text":"section 402(i) of this title","children":[],"tail":" on account of the death of any person to whom such individual is related by blood, marriage, or adoption,"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb843927c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–1/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary makes a finding of fact and a decision as to the entitlement under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s426"},"text":"section 426 of this title","children":[],"tail":" of any individual to hospital insurance benefits under part A of subchapter XVIII, or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb843927d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–1/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Commissioner of Social Security is requested to do so—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb843927e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–1/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by any individual with respect to whom the Commissioner of Social Security holds information obtained under section 6057 of the Internal Revenue Code of 1986, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb843927f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–1/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of the death of the individual referred to in subparagraph (A), by the individual who would be entitled to payment under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s404/d"},"text":"section 404(d) of this title","children":[],"tail":","}],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the Commissioner of Social Security shall transmit to the individual referred to in paragraph (1) or (2) or the individual making the request under paragraph (3) any information, as reported by the employer, regarding any deferred vested benefit transmitted to the Commissioner of Social Security pursuant to such section 6057 with respect to the individual referred to in paragraph (1), (2), or (3)(A) or the person on whose wages and self-employment income entitlement (or claim of entitlement) is based.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8439280-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8439281-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–1/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s401/g/1"},"text":"section 401(g)(1) of this title","children":[],"tail":", expenses incurred in the administration of subsection (a) shall be deemed to be expenses incurred for the administration of subchapter II."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8439282-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–1/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There are hereby authorized to be appropriated to the Federal Old-Age and Survivors Insurance Trust Fund for each fiscal year (commencing with the fiscal year ending ","children":[{"tag":"date","attrib":{"date":"1974-06-30"},"text":"June 30, 1974","children":[],"tail":") such sums as the Commissioner of Social Security deems necessary on account of additional administrative expenses resulting from the enactment of the provisions of subsection (a)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8439283-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title XI, § 1131, as added "},{"tag":"ref","attrib":{"href":"/us/pl/93/406/tII/s1032"},"text":"Pub. L. 93–406, title II, § 1032","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-09-02"},"text":"Sept. 2, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/947"},"text":"88 Stat. 947","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dB/tVI/s2663/e/7"},"text":"Pub. L. 98–369, div. B, title VI, § 2663(e)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1168"},"text":"98 Stat. 1168","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s2"},"text":"Pub. L. 99–514, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2095"},"text":"100 Stat. 2095","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/296/tI/s108/b/11"},"text":"Pub. L. 103–296, title I, § 108(b)(11)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-08-15"},"text":"Aug. 15, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1484"},"text":"108 Stat. 1484","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8439284-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8439285-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb8439286-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Internal Revenue Code of 1986, referred to in subsec. (a)(3)(A), is classified generally to Title 26, Internal Revenue Code.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8439287-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/296/s108/b/11/A"},"text":"Pub. L. 103–296, § 108(b)(11)(A)","children":[],"tail":", (G), in closing provisions substituted “the Commissioner of Social Security shall transmit” for “he shall transmit”, “paragraph (1) or (2)” for “paragraph (1)”, “paragraph (3)” for “paragraph (2)”, “Commissioner of Social Security pursuant to” for “Secretary pursuant to”, and “paragraph (1), (2), or (3)(A)” for “paragraph (1) or (2)(A)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/296/s108/b/11/A"},"text":"Pub. L. 103–296, § 108(b)(11)(A)","children":[],"tail":"–(D), substituted “Commissioner of Social Security” for “Secretary” in introductory provisions, inserted “or” at end of subpar. (A), struck out “or” at end of subpar. (B), and struck out subpar. (C) which read as follows: “the entitlement under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s426"},"text":"section 426 of this title","children":[],"tail":" of any individual to hospital insurance benefits under part A of subchapter XVIII of this chapter, or”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/296/s108/b/11/F"},"text":"Pub. L. 103–296, § 108(b)(11)(F)","children":[],"tail":", added par. (2). Former par. (2) redesignated (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/296/s108/b/11/A"},"text":"Pub. L. 103–296, § 108(b)(11)(A)","children":[],"tail":", (E), redesignated par. (2) as (3) and substituted “Commissioner of Social Security” for “Secretary” in introductory provisions and in subpar. (A)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/296/s108/b/11/A"},"text":"Pub. L. 103–296, § 108(b)(11)(A)","children":[],"tail":", substituted “Commissioner of Social Security” for “Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (a)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" substituted “Internal Revenue Code of 1986” for “Internal Revenue Code of 1954”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/s2663/e/7/B"},"text":"Pub. L. 98–369, § 2663(e)(7)(B)","children":[],"tail":", realigned margin of provisions following par. (2)(B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/s2663/e/7/A"},"text":"Pub. L. 98–369, § 2663(e)(7)(A)","children":[],"tail":", substituted a comma for the period after “"},{"tag":"ref","attrib":{"href":"/us/usc/t42/s404/d"},"text":"section 404(d) of this title","children":[],"tail":"”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8460288-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb8460289-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/296"},"text":"Pub. L. 103–296","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1995-03-31"},"text":"Mar. 31, 1995","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/296/s110/a"},"text":"section 110(a) of Pub. L. 103–296","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s401"},"text":"section 401 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb846028a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369"},"text":"Pub. L. 98–369","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", but not to be construed as changing or affecting any right, liability, status, or interpretation which existed (under the provisions of law involved) before that date, see "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/s2664/b"},"text":"section 2664(b) of Pub. L. 98–369","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s401"},"text":"section 401 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb846028b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"d