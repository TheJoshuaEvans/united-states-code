{"tag":"section","attrib":{"id":"idb4fc55af-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254o–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"254o–1"},"text":"§ 254o–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fund regarding use of amounts recovered for contract breach to replace services lost as result of breach","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb4fc55b0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254o–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of Fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established in the Treasury of the United States a fund to be known as the National Health Service Corps Member Replacement Fund (hereafter in this section referred to as the “Fund”). The Fund shall consist of such amounts as may be appropriated under subsection (b) to the Fund. Amounts appropriated for the Fund shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4fc55b1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254o–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations to Fund","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For each fiscal year, there is authorized to be appropriated to the Fund an amount equal to the sum of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4fc55b2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254o–1/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount collected during the preceding fiscal year by the Federal Government pursuant to the liability of individuals under section 254","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":" of this title for the breach of contracts entered into under section 254"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":" or 254"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"–1 of this title;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4fc55b3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254o–1/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount by which grants under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s254q–1"},"text":"section 254q–1 of this title","children":[],"tail":" have, for such preceding fiscal year, been reduced under subsection (g)(2)(B) of such section; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4fc55b4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254o–1/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the aggregate of the amount of interest accruing during the preceding fiscal year on obligations held in the Fund pursuant to subsection (d) and the amount of proceeds from the sale or redemption of such obligations during such fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4fc55b5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254o–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of Fund","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4fc55b6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254o–1/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments to certain health facilities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Amounts in the Fund and available pursuant to appropriations Act may, subject to paragraph (2), be expended by the Secretary to make payments to any entity—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4fc55b7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254o–1/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to which a Corps member has been assigned under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s254f"},"text":"section 254f of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4fc55b8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254o–1/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that has a need for a health professional to provide primary health services as a result of the Corps member having breached the contract entered into under section 254","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":" or 254"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"–1 of this title by the individual."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4fc55b9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254o–1/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose of payments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An entity receiving payments pursuant to paragraph (1) may expend the payments to recruit and employ a health professional to provide primary health services to patients of the entity, or to enter into a contract with such a professional to provide the services to the patients.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4fc55ba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254o–1/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4fc55bb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254o–1/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of the Treasury shall invest such amounts of the Fund as such Secretary determines are not required to meet current withdrawals from the Fund. Such investments may be made only in interest-bearing obligations of the United States. For such purpose, such obligations may be acquired on original issue at the issue price, or by purchase of outstanding obligations at the market price.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4fc55bc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254o–1/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sale of obligations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any obligation acquired by the Fund may be sold by the Secretary of the Treasury at the market price.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb4fc55bd-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title III, § 338F, as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/597/tII/s204"},"text":"Pub. L. 101–597, title II, § 204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3027"},"text":"104 Stat. 3027","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb4fc55be-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb4fc55bf-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb4fc55c0-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 338F of act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", was renumbered section 338G by "},{"tag":"ref","attrib":{"href":"/us/pl/101/597"},"text":"Pub. L. 101–597","children":[],"tail":" and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s254p"},"text":"section 254p of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 338F of act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", was renumbered section 338G by "},{"tag":"ref","attrib":{"href":"/us/pl/100/177/s201/2"},"text":"section 201(2) of Pub. L. 100–177","children":[],"tail":" and classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s254q"},"text":"section 254q of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/100/177/tII/s203"},"text":"Pub. L. 100–177, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-01"},"text":"Dec. 1, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/999"},"text":"101 Stat. 999","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
