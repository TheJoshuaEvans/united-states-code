{"tag":"section","attrib":{"id":"idbc55975e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3030c"},"text":null,"children":[{"tag":"num","attrib":{"value":"3030c"},"text":"§ 3030c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Audit; request for information","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbc55975f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3030c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Assistant Secretary and the Comptroller General of the United States or any of their duly authorized representatives shall have access for the purpose of audit and examination to any books, documents, papers, and records that are pertinent to a grant or contract received under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc559760-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3030c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State agencies and area agencies on aging shall not request information or data from providers which is not pertinent to services furnished pursuant to this chapter or a payment made for such services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc559761-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/73/tIII/s313"},"text":"Pub. L. 89–73, title III, § 313","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/95/478/tI/s103/b"},"text":"Pub. L. 95–478, title I, § 103(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-18"},"text":"Oct. 18, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1535"},"text":"92 Stat. 1535","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us