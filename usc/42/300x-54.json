{"tag":"section","attrib":{"id":"idb66e0ee9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–54"},"text":null,"children":[{"tag":"num","attrib":{"value":"300x–54"},"text":"§ 300x–54.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposition of certain funds appropriated for allotments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb66e0eea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–54/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts described in subsection (b) and available for a fiscal year pursuant to section 300x or 300x–21 of this title, as the case may be, shall be allotted by the Secretary and paid to the States receiving a grant under the program involved, other than any State referred to in subsection (b) with respect to such program. Such amounts shall be allotted in a manner equivalent to the manner in which the allotment under the program involved was determined.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb66e0eeb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–54/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specification of amounts","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amounts referred to in subsection (a) are any amounts that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb66e0eec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–54/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" are not paid to States under the program involved as a result of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb66e0eed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–54/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the failure of any State to submit an application in accordance with the program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb66e0eee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–54/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the failure of any State to prepare such application in compliance with the program; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb66e0eef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–54/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any State informing the Secretary that the State does not intend to expend the full amount of the allotment made to the State under the program;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb66e0ef0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–54/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are terminated, repaid, or offset under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x–55"},"text":"section 300x–55 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb66e0ef1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–54/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of the program established in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x"},"text":"section 300x of this title","children":[],"tail":", are available as a result of reductions in allotments under such section pursuant to section 300x–1(d) or 300x–4(b) of this title; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb66e0ef2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–54/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of the program established in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x–21"},"text":"section 300x–21 of this title","children":[],"tail":", are available as a result of reductions in allotments under such section pursuant to section 300x–26 or 300x–30 of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb66e0ef3-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XIX, § 1944, as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/321/tII/s203/a"},"text":"Pub. L. 102–321, title II, § 203(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-10"},"text":"July 10, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/404"},"text":"106 Stat. 404","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
