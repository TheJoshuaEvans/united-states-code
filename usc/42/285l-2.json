{"tag":"section","attrib":{"id":"idb575f3b4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285l–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"285l–2"},"text":"§ 285l–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In sections 285","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":"–2 to 285"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"–5 of this title:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb575f3b5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285l–2/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Alternative test method","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “alternative test method” means a test method that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb575f3b6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285l–2/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes any new or revised test method; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb575f3b7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285l–2/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb575f3b8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285l–2/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reduces the number of animals required;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb575f3b9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285l–2/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" refines procedures to lessen or eliminate pain or distress to animals, or enhances animal well-being; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb575f3ba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285l–2/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" replaces animals with non-animal systems or one animal species with a phylogenetically lower animal species, such as replacing a mammal with an invertebrate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb575f3bb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285l–2/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ICCVAM test recommendation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “ICCVAM test recommendation” means a summary report prepared by the ICCVAM characterizing the results of a scientific expert peer review of a test method.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb575f3bc-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/545/s2"},"text":"Pub. L. 106–545, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-19"},"text":"Dec. 19, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2721"},"text":"114 Stat. 2721","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb575f3bd-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb575f3be-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb575f3bf-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the ICCVAM Authorization Act of 2000, and not as part of the Public Health Service Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
