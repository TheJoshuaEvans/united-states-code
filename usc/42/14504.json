{"tag":"section","attrib":{"id":"idbfd177ae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14504"},"text":null,"children":[{"tag":"num","attrib":{"value":"14504"},"text":"§ 14504.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liability for noneconomic loss","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfd177af-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14504/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In any civil action against a volunteer, based on an action of a volunteer acting within the scope of the volunteer’s responsibilities to a nonprofit organization or governmental entity, the liability of the volunteer for noneconomic loss shall be determined in accordance with subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfd177b0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14504/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of liability","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfd177b1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14504/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each defendant who is a volunteer, shall be liable only for the amount of noneconomic loss allocated to that defendant in direct proportion to the percentage of responsibility of that defendant (determined in accordance with paragraph (2)) for the harm to the claimant with respect to which that defendant is liable. The court shall render a separate judgment against each defendant in an amount determined pursuant to the preceding sentence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfd177b2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14504/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Percentage of responsibility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of determining the amount of noneconomic loss allocated to a defendant who is a volunteer under this section, the trier of fact shall determine the percentage of responsibility of that defendant for the claimant’s harm.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfd177b3-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/19/s5"},"text":"Pub. L. 105–19, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-06-18"},"text":"June 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/221"},"text":"111 Stat. 221","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
