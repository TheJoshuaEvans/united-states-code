{"tag":"section","attrib":{"id":"idb575f367-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285h"},"text":null,"children":[{"tag":"num","attrib":{"value":"285h"},"text":"§ 285h.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose of Institute","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The general purpose of the National Institute of Dental Research is the conduct and support of research, training, health information dissemination, and other programs with respect to the cause, prevention, and methods of diagnosis and treatment of dental and oral diseases and conditions.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb575f368-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title IV, § 453, as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/158/s2"},"text":"Pub. L. 99–158, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-11-20"},"text":"Nov. 20, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/856"},"text":"99 Stat. 856","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
