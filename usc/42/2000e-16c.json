{"tag":"section","attrib":{"id":"idbbc42d19-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000e–16c"},"text":null,"children":[{"tag":"num","attrib":{"value":"2000e–16c"},"text":"§ 2000e–16c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coverage of previously exempt State employees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbbc42d1a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000e–16c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The rights, protections, and remedies provided pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2000e–16b"},"text":"section 2000e–16b of this title","children":[],"tail":" shall apply with respect to employment of any individual chosen or appointed, by a person elected to public office in any State or political subdivision of any State by the qualified voters thereof—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbbc42d1b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000e–16c/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to be a member of the elected official’s personal staff;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbc42d1c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000e–16c/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to serve the elected official on the policymaking level; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbc42d1d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000e–16c/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to serve the elected official as an immediate advisor with respect to the exercise of the constitutional or legal powers of the office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbbc42d1e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000e–16c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement by administrative action","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbbc42d1f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000e–16c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any individual referred to in subsection (a) may file a complaint alleging a violation, not later than 180 days after the occurrence of the alleged violation, with the Equal Employment Opportunity Commission, which, in accordance with the principles and procedures set forth in sections 554 through 557 of title 5, shall determine whether a violation has occurred and shall set forth its determination in a final order. If the Equal Employment Opportunity Commission determines that a violation has occurred, the final order shall also provide for appropriate relief.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbc42d20-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000e–16c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Referral to State and local authorities","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbbc42d21-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000e–16c/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2000e–5/d"},"text":"Section 2000e–5(d) of this title","children":[],"tail":" shall apply with respect to any proceeding under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbbc42d22-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000e–16c/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of the application described in subparagraph (A), the term “any charge filed by a member of the Commission alleging an unlawful employment practice” means a complaint filed under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbbc42d23-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000e–16c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Judicial review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any party aggrieved by a final order under subsection (b) may obtain a review of such order under chapter 158 of title 28. For the purpose of this review, the Equal Employment Opportunity Commission shall be an “agency” as that term is used in chapter 158 of title 28.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbbc42d24-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000e–16c/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standard of review","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To the extent necessary to decision and when presented, the reviewing court shall decide all relevant questions of law and interpret constitutional and statutory provisions. The court shall set aside a final order under subsection (b) if it is determined that the order was—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbbc42d25-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000e–16c/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" arbitrary, capricious, an abuse of discretion, or otherwise not consistent with law;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbc42d26-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000e–16c/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not made consistent with required procedures; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbc42d27-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000e–16c/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" unsupported by substantial evidence.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"In making the foregoing determinations, the court shall review the whole record or those parts of it cited by a party, and due account shall be taken of the rule of prejudicial error.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbbc42d28-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000e–16c/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Attorney’s fees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the individual referred to in subsection (a) is the prevailing party in a proceeding under this subsection,","children":[{"tag":"ref","attrib":{"idref":"fn003239"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003239"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original."}],"tail":" attorney’s fees may be allowed by the court in accordance with the standards prescribed under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2000e–5/k"},"text":"section 2000e–5(k) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbbc42d29-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/166/tIII/s304"},"text":"Pub. L. 102–166, title III, § 304","children":[],"tail":", formerly § 321, "},{"tag":"date","attrib":{"date":"1991-11-21"},"text":"Nov. 21, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1097"},"text":"105 Stat. 1097","children":[],"tail":"; renumbered § 304 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/1/tV/s504/a/3"},"text":"Pub. L. 104–1, title V, § 504(a)(3)","children":[],"tail":", (4), "},{"tag":"date","attrib":{"date":"1995-01-23"},"text":"Jan. 23, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/41"},"text":"109 Stat. 41","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbbc42d2a-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbbc42d2b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbbc42d2c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Government Employee Rights Act of 1991, and not as part of the Civil Rights Act of 1964, title VII of which comprises this subchapter.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s1220"},"text":"section 1220 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbbc42d2d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/166/s304"},"text":"section 304 of Pub. L. 102–166","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1204"},"text":"section 1204 of Title 2","children":[],"tail":", The Congress, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/104/1"},"text":"Pub. L. 104–1","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbbc42d2e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1995—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/1/s504/a/4"},"text":"Pub. L. 104–1, § 504(a)(4)","children":[],"tail":", struck out “and 1207(h) of title 2” before “shall apply” in introductory provisions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbbc42d2f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbbc42d30-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1991-11-21"},"text":"Nov. 21, 1991","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/102/166/s402"},"text":"section 402 of Pub. L. 102–166","children":[],"tail":", set out as an Effective Date of 1991 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1981"},"text":"section 1981 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
