{"tag":"section","attrib":{"id":"idbfe946d5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15923"},"text":null,"children":[{"tag":"num","attrib":{"value":"15923"},"text":"§ 15923.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Methodology","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior shall use the same assessment methodology across all geological provinces, areas, and regions in preparing and issuing national geological assessments to ensure accurate comparisons of geological resources.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbfe946d6-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tIII/s364/b"},"text":"Pub. L. 109–58, title III, § 364(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/723"},"text":"119 Stat. 723","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
