{"tag":"section","attrib":{"id":"idc054b175-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18323"},"text":null,"children":[{"tag":"num","attrib":{"value":"18323"},"text":"§ 18323.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Multi-purpose crew vehicle","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc054b176-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18323/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initiation of development","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc054b177-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18323/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall continue the development of a multi-purpose crew vehicle to be available as soon as practicable, and no later than for use with the Space Launch System. The vehicle shall continue to advance development of the human safety features, designs, and systems in the Orion project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc054b178-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18323/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Goal for operational capability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It shall be the goal to achieve full operational capability for the transportation vehicle developed pursuant to this subsection by not later than ","children":[{"tag":"date","attrib":{"date":"2016-12-31"},"text":"December 31, 2016","children":[],"tail":". For purposes of meeting such goal, the Administrator may undertake a test of the transportation vehicle at the ISS before that date."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc054b179-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18323/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum capability requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The multi-purpose crew vehicle developed pursuant to subsection (a) shall be designed to have, at a minimum, the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc054b17a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18323/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The capability to serve as the primary crew vehicle for missions beyond low-Earth orbit.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc054b17b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18323/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The capability to conduct regular in-space operations, such as rendezvous, docking, and extra-vehicular activities, in conjunction with payloads delivered by the Space Launch System developed pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s18322"},"text":"section 18322 of this title","children":[],"tail":", or other vehicles, in preparation for missions beyond low-Earth orbit or servicing of assets described in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s18383"},"text":"section 18383 of this title","children":[],"tail":", or other assets in cis-lunar space."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc054b17c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18323/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The capability to provide an alternative means of delivery of crew and cargo to the ISS, in the event other vehicles, whether commercial vehicles or partner-supplied vehicles, are unable to perform that function.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc054b17d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18323/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The capacity for efficient and timely evolution, including the incorporation of new technologies, competition of sub-elements, and commercial operations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc054b17e-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/267/tIII/s303"},"text":"Pub. L. 111–267, title III, § 303","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-11"},"text":"Oct. 11, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2815"},"text":"124 Stat. 2815","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
