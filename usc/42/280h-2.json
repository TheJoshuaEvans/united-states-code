{"tag":"section","attrib":{"id":"idb543e63a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280h–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"280h–2"},"text":"§ 280h–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Education campaign","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb543e63b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280h–2/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, acting through the Director of the Centers for Disease Control and Prevention, and in collaboration with national, State, and local partners, physical activity organizations, nutrition experts, and health professional organizations, shall develop a national public campaign to promote and educate children and their parents concerning—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb543e63c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280h–2/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the health risks associated with obesity, inactivity, and poor nutrition;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb543e63d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280h–2/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ways in which to incorporate physical activity into daily living; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb543e63e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280h–2/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the benefits of good nutrition and strategies to improve eating habits.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb543e63f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280h–2/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this section such sums as may be necessary for each of the fiscal years 2001 through 2005.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb543e640-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title III, § 399Y, as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/310/dA/tXXIV/s2401"},"text":"Pub. L. 106–310, div. A, title XXIV, § 2401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-17"},"text":"Oct. 17, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1160"},"text":"114 Stat. 1160","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
