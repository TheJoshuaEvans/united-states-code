{"tag":"section","attrib":{"id":"idbe0c704d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385i"},"text":null,"children":[{"tag":"num","attrib":{"value":"7385i"},"text":"§ 7385i.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Forfeiture of benefits by convicted felons","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbe0c704e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385i/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Forfeiture of compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any individual convicted of a violation of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1920"},"text":"section 1920 of title 18","children":[],"tail":", or any other Federal or State criminal statute relating to fraud in the application for or receipt of any benefit under this subchapter or under any other Federal or State workers’ compensation law, shall forfeit (as of the date of such conviction) any entitlement to any compensation or benefit under this subchapter such individual would otherwise be awarded for any injury, illness or death covered by this subchapter for which the time of injury was on or before the date of the conviction."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe0c704f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385i/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552a"},"text":"section 552a of title 5","children":[],"tail":", or any other Federal or State law, an agency of the United States, a State, or a political subdivision of a State shall make available to the President, upon written request from the President and if the President requires the information to carry out this section, the names and Social Security account numbers of individuals confined, for conviction of a felony, in a jail, prison, or other penal institution or correctional facility under the jurisdiction of that agency."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbe0c7050-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dC/tXXXVI/s3650"},"text":"Pub. L. 106–398, § 1 [div. C, title XXXVI, § 3650]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–511; "},{"tag":"ref","attrib":{"href":"/us/pl/108/375/dC/tXXXI/s3162/h"},"text":"Pub. L. 108–375, div. C, title XXXI, § 3162(h)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-28"},"text":"Oct. 28, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2186"},"text":"118 Stat. 2186","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbe0c7051-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbe0c7052-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbe0c7053-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375"},"text":"Pub. L. 108–375","children":[],"tail":" substituted “this subchapter” for “part B” wherever appearing."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
