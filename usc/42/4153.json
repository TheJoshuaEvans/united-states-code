{"tag":"section","attrib":{"id":"idbcbc21cf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4153"},"text":null,"children":[{"tag":"num","attrib":{"value":"4153"},"text":"§ 4153.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standards for design, construction, and alteration of buildings; Secretary of Housing and Urban Development","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of Housing and Urban Development, in consultation with the Secretary of Health and Human Services, shall prescribe standards for the design, construction, and alteration of buildings which are residential structures subject to this chapter to insure whenever possible that physically handicapped persons will have ready access to, and use of, such buildings.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbcbc21d0-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/480/s3"},"text":"Pub. L. 90–480, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-08-12"},"text":"Aug. 12, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/719"},"text":"82 Stat. 719","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/541/tII/s201/3"},"text":"Pub. L. 94–541, title II, § 201(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-18"},"text":"Oct. 18, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2507"},"text":"90 Stat. 2507","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/88/tV/s509/b"},"text":"Pub. L. 96–88, title V, § 509(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-10-17"},"text":"Oct. 17, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/695"},"text":"93 Stat. 695","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbcbc21d1-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbcbc21d2-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbcbc21d3-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/541"},"text":"Pub. L. 94–541","children":[],"tail":" substituted “shall prescribe” and “to insure whenever possible” for “is authorized to prescribe such” and “as may be necessary to insure”, respectively."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbcbc21d4-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idbcbc21d5-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Secretary of Health and Human Services” substituted in text for “Secretary of Health, Education, and Welfare” pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/88/s509/b"},"text":"section 509(b) of Pub. L. 96–88","children":[],"tail":", which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s3508/b"},"text":"section 3508(b) of Title 20","children":[],"tail":", Education."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
