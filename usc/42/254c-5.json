{"tag":"section","attrib":{"id":"idb4e942d4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254c–5"},"text":null,"children":[{"tag":"num","attrib":{"value":"254c–5"},"text":"§ 254c–5.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Epilepsy; seizure disorder","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb4e942d5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254c–5/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National public health campaign","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4e942d6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254c–5/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall develop and implement public health surveillance, education, research, and intervention strategies to improve the lives of persons with epilepsy, with a particular emphasis on children. Such projects may be carried out by the Secretary directly and through awards of grants or contracts to public or nonprofit private entities. The Secretary may directly or through such awards provide technical assistance with respect to the planning, development, and operation of such projects.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4e942d7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254c–5/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Activities under paragraph (1) shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4e942d8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254c–5/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expanding current surveillance activities through existing monitoring systems and improving registries that maintain data on individuals with epilepsy, including children;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4e942d9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254c–5/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhancing research activities on the diagnosis, treatment, and management of epilepsy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4e942da-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254c–5/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" implementing public and professional information and education programs regarding epilepsy, including initiatives which promote effective management of the disease through children’s programs which are targeted to parents, schools, daycare providers, patients;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4e942db-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254c–5/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" undertaking educational efforts with the media, providers of health care, schools and others regarding stigmas and secondary disabilities related to epilepsy and seizures, and its effects on youth;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4e942dc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254c–5/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" utilizing and expanding partnerships with organizations with experience addressing the health and related needs of people with disabilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4e942dd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254c–5/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other activities the Secretary deems appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4e942de-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254c–5/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination of activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall ensure that activities under this subsection are coordinated as appropriate with other agencies of the Public Health Service that carry out activities regarding epilepsy and seizure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4e942df-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254c–5/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Seizure disorder; demonstration projects in medically underserved areas","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4e942e0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254c–5/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Administrator of the Health Resources and Services Administration, may make grants for the purpose of carrying out demonstration projects to improve access to health and other services regarding seizures to encourage early detection and treatment in children and others residing in medically underserved areas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4e942e1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254c–5/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application for grant","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A grant may not be awarded under paragraph (1) unless an application therefore is submitted to the Secretary and the Secretary approves such application. Such application shall be submitted in such form and manner and shall contain such information as the Secretary may prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4e942e2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254c–5/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4e942e3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254c–5/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “epilepsy” refers to a chronic and serious neurological condition characterized by excessive electrical discharges in the brain causing recurring seizures affecting all life activities. The Secretary may revise the definition of such term to the extent the Secretary determines necessary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4e942e4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254c–5/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “medically underserved” has the meaning applicable under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s295p/6"},"text":"section 295p(6) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4e942e5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254c–5/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of carrying out this section, there are authorized to be appropriated such sums as may be necessary for each of the fiscal years 2001 through 2005.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb4e942e6-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title III, § 330E, as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/310/dA/tVIII/s801"},"text":"Pub. L. 106–310, div. A, title VIII, § 801","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-17"},"text":"Oct. 17, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1124"},"text":"114 Stat. 1124","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
