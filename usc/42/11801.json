{"tag":"section","attrib":{"id":"idbf57db2b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11801"},"text":null,"children":[{"tag":"num","attrib":{"value":"11801"},"text":"§ 11801.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of drug abuse education and prevention program relating to youth gangs","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary of Health and Human Services, through the Administration on Children, Youth, and Families, shall make grants to, and enter into contracts with, public and nonprofit private agencies (including agencies described in paragraph (7)(A) acting jointly), organizations (including community based organizations with demonstrated experience in this field), institutions, and individuals, to carry out projects and activities—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf57db2c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11801/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to prevent and to reduce the participation of youth in the activities of gangs that engage in illicit drug-related activities,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf57db2d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11801/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to promote the involvement of youth in lawful activities in communities in which such gangs commit drug-related crimes,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf57db2e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11801/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to prevent the abuse of drugs by youth, to educate youth about such abuse, and to refer for treatment and rehabilitation members of such gangs who abuse drugs,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf57db2f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11801/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to support activities of local police departments and other local law enforcement agencies to conduct educational outreach activities in communities in which gangs commit drug-related crimes,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf57db30-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11801/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to inform gang members and their families of the availability of treatment and rehabilitation services for drug abuse,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf57db31-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11801/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to facilitate Federal and State cooperation with local school officials to assist youth who are likely to participate in gangs that commit drug-related crimes,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf57db32-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11801/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to facilitate coordination and cooperation among—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf57db33-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11801/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" local education, juvenile justice, employment and social service agencies, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf57db34-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11801/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" drug abuse referral, treatment, and rehabilitation programs,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"for the purpose of preventing or reducing the participation of youth in activities of gangs that commit drug-related crimes, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf57db35-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11801/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide technical assistance to eligible organizations in planning and implementing drug abuse education, prevention, rehabilitation, and referral programs for youth who are members of gangs that commit drug-related crimes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf57db36-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690/tIII/s3501"},"text":"Pub. L. 100–690, title III, § 3501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4254"},"text":"102 Stat. 4254","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/132/s1/a"},"text":"Pub. L. 102–132, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-10-18"},"text":"Oct. 18, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/630"},"text":"105 Stat. 630","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf57db37-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf57db38-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbf57db39-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/132"},"text":"Pub. L. 102–132","children":[],"tail":" inserted “(including agencies described in paragraph (7)(A) acting jointly)” after “agencies” in introductory provisions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbf57db3a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbf57db3b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1991 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/132/s3"},"text":"Pub. L. 102–132, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-10-18"},"text":"Oct. 18, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/631"},"text":"105 Stat. 631","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/132/s3"},"text":"“This Act [enacting ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11806"},"text":"section 11806 of this title","children":[],"tail":" and amending this section and sections 11805 and 11823 of this title] shall take effect on "},{"tag":"date","attrib":{"date":"1991-10-01"},"text":"October 1, 1991","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
