{"tag":"section","attrib":{"id":"idbcc5bf1d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336a"},"text":null,"children":[{"tag":"num","attrib":{"value":"4336a"},"text":"§ 4336a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timely and unified Federal reviews","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbcc5bf1e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lead agency","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbcc5bf1f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbcc5bf20-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336a/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If there are two or more participating Federal agencies, such agencies shall determine, by letter or memorandum, which agency shall be the lead agency based on consideration of the—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbcc5bf21-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336a/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" magnitude of agency’s involvement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbcc5bf22-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336a/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" project approval or disapproval authority;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbcc5bf23-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336a/a/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expertise concerning the action’s environmental effects;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbcc5bf24-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336a/a/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" duration of agency’s involvement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbcc5bf25-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336a/a/1/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sequence of agency’s involvement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcc5bf26-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336a/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Joint lead agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In making a determination under subparagraph (A), the participating Federal agencies may appoint such State, Tribal, or local agencies as joint lead agencies as the involved Federal agencies shall determine appropriate. Joint lead agencies shall jointly fulfill the role described in paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcc5bf27-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Role","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A lead agency shall, with respect to a proposed agency action—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbcc5bf28-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336a/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supervise the preparation of an environmental document if, with respect to such proposed agency action, there is more than one participating Federal agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcc5bf29-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336a/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" request the participation of each cooperating agency at the earliest practicable time;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcc5bf2a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336a/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in preparing an environmental document, give consideration to any analysis or proposal created by a cooperating agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcc5bf2b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336a/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop a schedule, in consultation with each cooperating agency, the applicant, and such other entities as the lead agency determines appropriate, for completion of any environmental review, permit, or authorization required to carry out the proposed agency action;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcc5bf2c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336a/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the lead agency determines that a review, permit, or authorization will not be completed in accordance with the schedule developed under subparagraph (D), notify the agency responsible for issuing such review, permit, or authorization of the discrepancy and request that such agency take such measures as such agency determines appropriate to comply with such schedule; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcc5bf2d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336a/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meet with a cooperating agency that requests such a meeting.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcc5bf2e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperating agency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The lead agency may, with respect to a proposed agency action, designate any Federal, State, Tribal, or local agency that has jurisdiction by law or special expertise with respect to any environmental impact involved in a proposal to serve as a cooperating agency. A cooperating agency may, not later than a date specified in the schedule established by the lead agency, submit comments to the lead agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcc5bf2f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336a/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Request for designation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any Federal, State, Tribal, or local agency or person that is substantially affected by the lack of a designation of a lead agency with respect to a proposed agency action under paragraph (1) may submit a written request for such a designation to a participating Federal agency. An agency that receives a request under this paragraph shall transmit such request to each participating Federal agency and to the Council.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcc5bf30-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336a/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Council designation","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbcc5bf31-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336a/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Request","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the participating Federal agencies are unable to agree on the designation of a lead agency within 45 days of the request under paragraph (4), then the Federal, State, Tribal or local agency or person that is substantially affected by the lack or a designation of a lead agency may request that the Council designate a lead agency. Such request shall consist of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbcc5bf32-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336a/a/5/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a precise description of the nature and extent of the proposed agency action; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbcc5bf33-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336a/a/5/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a detailed statement with respect to each participating Federal agency and each factor listed in paragraph (1) regarding which agency should serve as lead agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcc5bf34-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336a/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transmission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Council shall transmit a request received under subparagraph (A) to each participating Federal agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcc5bf35-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336a/a/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Response","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A participating Federal agency may, not later than 20 days after the date of the submission of a request under subparagraph (A), submit to the Council a response to such request.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcc82f36-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336a/a/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 40 days after the date of the submission of a request under subparagraph (A), the Council shall designate the lead agency with respect to the relevant proposed agency action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcc82f37-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" One document","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the extent practicable, if a proposed agency action will require action by more than one Federal agency and the lead agency has determined that it requires preparation of an environmental document, the lead and cooperating agencies shall evaluate the proposal in a single environmental document.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcc82f38-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Request for public comment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each notice of intent to prepare an environmental impact statement under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4332"},"text":"section 4332 of this title","children":[],"tail":" shall include a request for public comment on alternatives or impacts and on relevant information, studies, or analyses with respect to the proposed agency action."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcc82f39-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statement of purpose and need","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each environmental document shall include a statement of purpose and need that briefly summarizes the underlying purpose and need for the proposed agency action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcc82f3a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Page limits","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbcc82f3b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336a/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Environmental impact statements","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbcc82f3c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336a/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subparagraph (B), an environmental impact statement shall not exceed 150 pages, not including any citations or appendices.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcc82f3d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336a/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extraordinary complexity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An environmental impact statement for a proposed agency action of extraordinary complexity shall not exceed 300 pages, not including any citations or appendices.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcc82f3e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336a/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Environmental assessments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An environmental assessment shall not exceed 75 pages, not including any citations or appendices.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcc82f3f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sponsor preparation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A lead agency shall prescribe procedures to allow a project sponsor to prepare an environmental assessment or an environmental impact statement under the supervision of the agency. Such agency may provide such sponsor with appropriate guidance and assist in the preparation. The lead agency shall independently evaluate the environmental document and shall take responsibility for the contents.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcc82f40-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336a/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deadlines","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbcc82f41-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336a/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in paragraph (2), with respect to a proposed agency action, a lead agency shall complete, as applicable—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbcc82f42-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336a/g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the environmental impact statement not later than the date that is 2 years after the sooner of, as applicable—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbcc82f43-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336a/g/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which such agency determines that ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4332/2/C"},"text":"section 4332(2)(C) of this title","children":[],"tail":" requires the issuance of an environmental impact statement with respect to such action;"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbcc82f44-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336a/g/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which such agency notifies the applicant that the application to establish a right-of-way for such action is complete; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbcc82f45-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336a/g/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which such agency issues a notice of intent to prepare the environmental impact statement for such action; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcc82f46-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336a/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the environmental assessment not later than the date that is 1 year after the sooner of, as applicable—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbcc82f47-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336a/g/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which such agency determines that ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4336/b/2"},"text":"section 4336(b)(2) of this title","children":[],"tail":" requires the preparation of an environmental assessment with respect to such action;"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbcc82f48-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336a/g/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which such agency notifies the applicant that the application to establish a right-of-way for such action is complete; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbcc82f49-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336a/g/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which such agency issues a notice of intent to prepare the environmental assessment for such action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcc82f4a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336a/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Delay","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A lead agency that determines it is not able to meet the deadline described in paragraph (1) may extend such deadline, in consultation with the applicant, to establish a new deadline that provides only so much additional time as is necessary to complete such environmental impact statement or environmental assessment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcc82f4b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336a/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Petition to court","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbcc82f4c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336a/g/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Right to petition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A project sponsor may obtain a review of an alleged failure by an agency to act in accordance with an applicable deadline under this section by filing a written petition with a court of competent jurisdiction seeking an order under subparagraph (B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcc82f4d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336a/g/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Court order","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a court of competent jurisdiction finds that an agency has failed to act in accordance with an applicable deadline, the court shall set a schedule and deadline for the agency to act as soon as practicable, which shall not exceed 90 days from the date on which the order of the court is issued, unless the court determines a longer time period is necessary to comply with applicable law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcc82f4e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336a/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbcc82f4f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336a/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The head of each lead agency shall annually submit to the Committee on Natural Resources of the House of Representatives and the Committee on Environment and Public Works of the Senate a report that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbcc82f50-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336a/h/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifies any environmental assessment and environmental impact statement that such lead agency did not complete by the deadline described in subsection (g); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcc82f51-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336a/h/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides an explanation for any failure to meet such deadline.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcc82f52-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336a/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each report submitted under paragraph (1) shall identify, as applicable—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbcc82f53-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336a/h/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the office, bureau, division, unit, or other entity within the Federal agency responsible for each such environmental assessment and environmental impact statement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcc82f54-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336a/h/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the date on which—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbcc82f55-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336a/h/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such lead agency notified the applicant that the application to establish a right-of-way for the major Federal action is complete;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbcc82f56-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336a/h/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such lead agency began the scoping for the major Federal action; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbcc82f57-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336a/h/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such lead agency issued a notice of intent to prepare the environmental assessment or environmental impact statement for the major Federal action; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcc82f58-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336a/h/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" when such environmental assessment and environmental impact statement is expected to be complete.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbcc82f59-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/190/tI/s107"},"text":"Pub. L. 91–190, title I, § 107","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/118/5/dC/tIII/s321/b"},"text":"Pub. L. 118–5, div. C, title III, § 321(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-06-03"},"text":"June 3, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/40"},"text":"137 Stat. 40","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
