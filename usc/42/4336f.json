{"tag":"section","attrib":{"id":"idbcc82f99-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336f"},"text":null,"children":[{"tag":"num","attrib":{"value":"4336f"},"text":"§ 4336f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Project sponsor opt-in fees for environmental reviews","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbcc82f9a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336f/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Process","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbcc82f9b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336f/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Project sponsor","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A project sponsor that intends to pay a fee under this section for the preparation, or supervision of the preparation, of an environmental assessment or environmental impact statement for a project shall submit to the Council—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbcc82f9c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336f/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the project; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcc82f9d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336f/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a declaration of whether the project sponsor intends to prepare the environmental assessment or environmental impact statement under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4336a/f"},"text":"section 4336a(f) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcc82f9e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336f/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Council on Environmental Quality","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 15 days after the date on which the Council receives information described in paragraph (1) from a project sponsor, the Council shall provide to the project sponsor notice of the amount of the fee to be paid under this section, as determined under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcc82f9f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336f/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment of fee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A project sponsor may pay a fee under this section after receipt of the notice described in paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcc82fa0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336f/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deadline for environmental reviews for which a fee is paid","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4336a/g/1"},"text":"section 4336a(g)(1) of this title","children":[],"tail":"—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbcc82fa1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336f/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an environmental assessment for which a fee is paid under this section shall be completed not later than 180 days after the date on which the fee is paid; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcc82fa2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336f/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an environmental impact statement for which a fee is paid under this section shall be completed not later than 1 year after the date of publication of the notice of intent to prepare the environmental impact statement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcc82fa3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336f/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fee amount","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount of a fee under this section shall be—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbcc82fa4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336f/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 125 percent of the anticipated costs to prepare the environmental assessment or environmental impact statement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcc82fa5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336f/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an environmental assessment or environmental impact statement to be prepared in whole or in part by a project sponsor under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4336a/f"},"text":"section 4336a(f) of this title","children":[],"tail":", 125 percent of the anticipated costs to supervise preparation of, and, as applicable, prepare, the environmental assessment or environmental impact statement."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbcc82fa6-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/190/tI/s112"},"text":"Pub. L. 91–190, title I, § 112","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/119/21/tVI/s60026"},"text":"Pub. L. 119–21, title VI, § 60026","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/157"},"text":"139 Stat. 157","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
