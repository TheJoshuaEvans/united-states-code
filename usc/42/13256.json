{"tag":"section","attrib":{"id":"idbfb73990-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13256"},"text":null,"children":[{"tag":"num","attrib":{"value":"13256"},"text":"§ 13256.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical and policy analysis","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfb73991-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13256/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"1995-03-01"},"text":"March 1, 1995","children":[],"tail":", and "},{"tag":"date","attrib":{"date":"1997-03-01"},"text":"March 1, 1997","children":[],"tail":", the Secretary shall prepare and transmit to the President and the Congress a technical and policy analysis under this section. The Secretary shall utilize the analytical capability and authorities of the Energy Information Administration and such other offices of the Department of Energy as the Secretary considers appropriate."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfb73992-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13256/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The technical and policy analysis prepared under this section shall be based on the best available data and information obtainable by the Secretary under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s13253"},"text":"section 13253 of this title","children":[],"tail":", or otherwise, and on experience under this subchapter and other provisions of law in the development and use of replacement fuels and alternative fueled vehicles, and shall evaluate—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfb73993-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13256/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" progress made in achieving the goals described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s13252/b/2"},"text":"section 13252(b)(2) of this title","children":[],"tail":", as modified under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s13254"},"text":"section 13254 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfb73994-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13256/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the actual and potential role of replacement fuels and alternative fueled vehicles in significantly reducing United States reliance on imported oil to the extent of the goals referred to in paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfb73995-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13256/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the actual and potential availability of various domestic replacement fuels and dedicated vehicles and dual fueled vehicles.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfb73996-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13256/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall publish a proposed version of each analysis under this section in the Federal Register for public comment before transmittal to the President and the Congress. Public comment received in response to such publication shall be preserved for use in rulemaking proceedings under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s13257"},"text":"section 13257 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfb73997-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/tV/s506"},"text":"Pub. L. 102–486, title V, § 506","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2891"},"text":"106 Stat. 2891","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
