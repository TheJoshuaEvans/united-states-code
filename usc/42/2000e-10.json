{"tag":"section","attrib":{"id":"idbbc1bbbc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000e–10"},"text":null,"children":[{"tag":"num","attrib":{"value":"2000e–10"},"text":"§ 2000e–10.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Posting of notices; penalties","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbbc1bbbd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000e–10/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Every employer, employment agency, and labor organization, as the case may be, shall post and keep posted in conspicuous places upon its premises where notices to employees, applicants for employment, and members are customarily posted a notice to be prepared or approved by the Commission setting forth excerpts, from or, summaries of, the pertinent provisions of this subchapter and information pertinent to the filing of a complaint.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbbc1bbbe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000e–10/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A willful violation of this section shall be punishable by a fine of not more than $100 for each separate offense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbbc1bbbf-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/352/tVII/s711"},"text":"Pub. L. 88–352, title VII, § 711","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-07-02"},"text":"July 2, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/265"},"text":"78 Stat. 265","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
