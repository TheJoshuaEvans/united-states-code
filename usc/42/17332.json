{"tag":"section","attrib":{"id":"idc0359132-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17332"},"text":null,"children":[{"tag":"num","attrib":{"value":"17332"},"text":"§ 17332.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States exports and outreach programs for India, China, and other countries","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc0359133-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17332/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance authorized","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Commerce shall direct the United States and Foreign Commercial Service to expand or create a corps of the Foreign Commercial Service officers to promote United States exports in clean and efficient energy technologies and build the capacity of government officials in India, China, and any other country the Secretary of Commerce determines appropriate, to become more familiar with the available technologies—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0359134-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17332/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by assigning or training Foreign Commercial Service attachés, who have expertise in clean and efficient energy technologies from the United States, to embark on business development and outreach efforts to such countries; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0359135-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17332/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by deploying the attachés described in paragraph (1) to educate provincial, state, and local government officials in such countries on the variety of United States-based technologies in clean and efficient energy technologies for the purposes of promoting United States exports and reducing global greenhouse gas emissions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0359136-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17332/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Commerce shall submit to the appropriate congressional committees an annual report on the implementation of this section for each of the fiscal years 2008 through 2012.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0359137-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17332/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To carry out this section, there are authorized to be appropriated to the Secretary of Commerce such sums as may be necessary for each of the fiscal years 2008 through 2012.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc0359138-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/tIX/s912"},"text":"Pub. L. 110–140, title IX, § 912","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1726"},"text":"121 Stat. 1726","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc0359139-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc035913a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc035913b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the date that is 1 day after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/s1601"},"text":"section 1601 of Pub. L. 110–140","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1824"},"text":"section 1824 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
