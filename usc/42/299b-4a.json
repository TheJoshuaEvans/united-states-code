{"tag":"section","attrib":{"id":"idb60058a8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–4a"},"text":null,"children":[{"tag":"num","attrib":{"value":"299b–4a"},"text":"§ 299b–4a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Studies on preventive interventions in primary care for older Americans","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb60058a9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–4a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Studies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Health and Human Services, acting through the United States Preventive Services Task Force, shall conduct a series of studies designed to identify preventive interventions that can be delivered in the primary care setting and that are most valuable to older Americans.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb60058aa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–4a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mission statement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The mission statement of the United States Preventive Services Task Force is amended to include the evaluation of services that are of particular relevance to older Americans.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb60058ab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–4a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2000-12-21"},"text":"December 21, 2000","children":[],"tail":", and annually thereafter, the Secretary of Health and Human Services shall submit to Congress a report on the conclusions of the studies conducted under subsection (a), together with recommendations for such legislation and administrative actions as the Secretary considers appropriate."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb60058ac-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/6/tI/s126"},"text":"Pub. L. 106–554, § 1(a)(6) [title I, § 126]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–479.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb60058ad-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb60058ae-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb60058af-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Medicare, Medicaid, and SCHIP Benefits Improvement and Protection Act of 2000, and also as part of the Consolidated Appropriations Act, 2001, and not as part of the Public Health Service Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
