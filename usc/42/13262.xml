<section xmlns="http://xml.house.gov/schemas/uslm/1.0" style="-uslm-lc:I80" id="idbfb73a20-3a70-11f1-ae07-e4213316b5fa" identifier="/us/usc/t42/s13262"><num value="13262">§ 13262.</num><heading> Enforcement</heading><subsection style="-uslm-lc:I19" class="indent2 firstIndent-2" id="idbfb73a21-3a70-11f1-ae07-e4213316b5fa" identifier="/us/usc/t42/s13262/a"><num value="a" class="bold">(a)</num><heading class="bold"> Violation</heading><content><p style="-uslm-lc:I11" class="indent0">Whoever violates <ref href="/us/usc/t42/s13261">section 13261 of this title</ref> shall be subject to a civil penalty of not more than $5,000 for each violation.</p>
</content>
</subsection>
<subsection style="-uslm-lc:I19" class="indent2 firstIndent-2" id="idbfb73a22-3a70-11f1-ae07-e4213316b5fa" identifier="/us/usc/t42/s13262/b"><num value="b" class="bold">(b)</num><heading class="bold"> Willful violation</heading><content><p style="-uslm-lc:I11" class="indent0">Whoever willfully violates <ref href="/us/usc/t42/s13261">section 13261 of this title</ref> shall be fined not more than $10,000 for each violation.</p>
</content>
</subsection>
<subsection style="-uslm-lc:I19" class="indent2 firstIndent-2" id="idbfb73a23-3a70-11f1-ae07-e4213316b5fa" identifier="/us/usc/t42/s13262/c"><num value="c" class="bold">(c)</num><heading class="bold"> Knowing and willful violation following prior violation and penalty</heading><content><p style="-uslm-lc:I11" class="indent0">Any person who knowingly and willfully violates <ref href="/us/usc/t42/s13261">section 13261 of this title</ref> after having been subjected to a civil penalty for a prior violation of <ref href="/us/usc/t42/s13261">section 13261 of this title</ref> shall be fined not more than $50,000.</p>
</content>
</subsection>
<sourceCredit id="idbfb73a24-3a70-11f1-ae07-e4213316b5fa">(<ref href="/us/pl/102/486/tV/s512">Pub. L. 102–486, title V, § 512</ref>, <date date="1992-10-24">Oct. 24, 1992</date>, <ref href="/us/stat/106/2899">106 Stat. 2899</ref>.)</sourceCredit>
</section>
