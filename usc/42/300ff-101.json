{"tag":"section","attrib":{"id":"idb6a28cd0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–101"},"text":null,"children":[{"tag":"num","attrib":{"value":"300ff–101"},"text":"§ 300ff–101.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special projects of national significance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb6a28cd1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–101/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Of the amount appropriated under each of parts A, B, C, and D for each fiscal year, the Secretary shall use the greater of $20,000,000 or an amount equal to 3 percent of such amount appropriated under each such part, but not to exceed $25,000,000, to administer special projects of national significance to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6a28cd2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–101/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" quickly respond to emerging needs of individuals receiving assistance under this subchapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6a28cd3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–101/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to fund special programs to develop a standard electronic client information data system to improve the ability of grantees under this subchapter to report client-level data to the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6a28cd4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–101/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall award grants under subsection (a) to entities eligible for funding under parts A, B, C, and D based on—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6a28cd5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–101/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether the funding will promote obtaining client level data as it relates to the creation of a severity of need index, including funds to facilitate the purchase and enhance the utilization of qualified health information technology systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6a28cd6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–101/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrated ability to create and maintain a qualified health information technology system;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6a28cd7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–101/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the potential replicability of the proposed activity in other similar localities or nationally;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6a28cd8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–101/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the demonstrated reliability of the proposed qualified health information technology system across a variety of providers, geographic regions, and clients; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6a28cd9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–101/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the demonstrated ability to maintain a safe and secure qualified health information system; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6a28cda-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–101/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" newly emerging needs of individuals receiving assistance under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6a28cdb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–101/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may not make a grant under this section unless the applicant submits evidence that the proposed program is consistent with the statewide coordinated statement of need, and the applicant agrees to participate in the ongoing revision process of such statement of need.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6a28cdc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–101/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Privacy protection","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may not make a grant under this section for the development of a qualified health information technology system unless the applicant provides assurances to the Secretary that the system will, at a minimum, comply with the privacy regulations promulgated under section 264(c) of the Health Insurance Portability and Accountability Act of 1996.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6a28cdd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–101/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Replication","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall make information concerning successful models or programs developed under this part available to grantees under this subchapter for the purpose of coordination, replication, and integration. To facilitate efforts under this subsection, the Secretary may provide for peer-based technical assistance for grantees funded under this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb6a28cde-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XXVI, § 2691, as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/146/s3/g/1"},"text":"Pub. L. 104–146, § 3(g)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-05-20"},"text":"May 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1362"},"text":"110 Stat. 1362","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/415/tVI/s601"},"text":"Pub. L. 109–415, title VI, § 601","children":[],"tail":", title VII, § 703, "},{"tag":"date","attrib":{"date":"2006-12-19"},"text":"Dec. 19, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2816"},"text":"120 Stat. 2816","children":[],"tail":", 2820; "},{"tag":"ref","attrib":{"href":"/us/pl/111/87/s2/a/1"},"text":"Pub. L. 111–87, § 2(a)(1)","children":[],"tail":", (3)(A), "},{"tag":"date","attrib":{"date":"2009-10-30"},"text":"Oct. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2885"},"text":"123 Stat. 2885","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb6a28cdf-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb6a28ce0-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb6a28ce1-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 264(c) of the Health Insurance Portability and Accountability Act of 1996, referred to in subsec. (d), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/191/s264/c"},"text":"section 264(c) of Pub. L. 104–191","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320d–2"},"text":"section 1320d–2 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb6a28ce2-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2009—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/87"},"text":"Pub. L. 111–87","children":[],"tail":" repealed "},{"tag":"ref","attrib":{"href":"/us/pl/109/415/s703"},"text":"Pub. L. 109–415, § 703","children":[],"tail":", and revived the provisions of this section as in effect on "},{"tag":"date","attrib":{"date":"2009-09-30"},"text":"Sept. 30, 2009","children":[],"tail":". See 2006 Amendment note and Effective Date of 2009 Amendment; Revival of Section note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/415/s703"},"text":"Pub. L. 109–415, § 703","children":[],"tail":", which directed repeal of this section effective "},{"tag":"date","attrib":{"date":"2009-10-01"},"text":"Oct. 1, 2009","children":[],"tail":", was itself repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/111/87/s2/a/1"},"text":"Pub. L. 111–87, § 2(a)(1)","children":[],"tail":", effective "},{"tag":"date","attrib":{"date":"2009-09-30"},"text":"Sept. 30, 2009","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/415/s601"},"text":"Pub. L. 109–415, § 601","children":[],"tail":", amended section generally. Prior to amendment, section related to use of funds for special projects of national significance."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb6a28ce3-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb6a28ce4-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2009 Amendment; Revival of Section","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions that repeal by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/87/s2/a/1"},"text":"section 2(a)(1) of Pub. L. 111–87","children":[],"tail":" of "},{"tag":"ref","attrib":{"href":"/us/pl/109/415/s703"},"text":"section 703 of Pub. L. 109–415","children":[],"tail":" be effective "},{"tag":"date","attrib":{"date":"2009-09-30"},"text":"Sept. 30, 2009","children":[],"tail":", and that the provisions of this section as in effect on "},{"tag":"date","attrib":{"date":"2009-09-30"},"text":"Sept. 30, 2009","children":[],"tail":", be revived, see section 2(a)(2), (3)(A) of "},{"tag":"ref","attrib":{"href":"/us/pl/111/87"},"text":"Pub. L. 111–87","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–11"},"text":"section 300ff–11 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
