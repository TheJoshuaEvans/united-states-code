{"tag":"section","attrib":{"id":"idbfd8a499-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15021"},"text":null,"children":[{"tag":"num","attrib":{"value":"15021"},"text":"§ 15021.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purpose of this part is to provide for allotments to support State Councils on Developmental Disabilities (referred to individually in this part as a “Council”) in each State to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfd8a49a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15021/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" engage in advocacy, capacity building, and systemic change activities that are consistent with the purpose described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s15001/b"},"text":"section 15001(b) of this title","children":[],"tail":" and the policy described in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s15001/c"},"text":"section 15001(c) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfd8a49b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15021/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contribute to a coordinated, consumer- and family-centered, consumer- and family-directed, comprehensive system of community services, individualized supports, and other forms of assistance that enable individuals with developmental disabilities to exercise self-determination, be independent, be productive, and be integrated and included in all facets of community life.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfd8a49c-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/402/tI/s121"},"text":"Pub. L. 106–402, title I, § 121","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1693"},"text":"114 Stat. 1693","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
