{"tag":"section","attrib":{"id":"idbc6d8c90-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058dd"},"text":null,"children":[{"tag":"num","attrib":{"value":"3058dd"},"text":"§ 3058dd.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbc6d8c91-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058dd/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out the provisions of this subchapter, the Assistant Secretary may request the technical assistance and cooperation of such Federal entities as may be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc6d8c92-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058dd/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistant Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Assistant Secretary shall provide technical assistance and training (by contract, grant, or otherwise) to persons and entities that administer programs established under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc6d8c93-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/73/tVII/s763"},"text":"Pub. L. 89–73, title VII, § 763","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/375/tVII/s707"},"text":"Pub. L. 102–375, title VII, § 707","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-09-30"},"text":"Sept. 30, 1992","children":[],"tail