{"tag":"section","attrib":{"id":"idb8628bfa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320f"},"text":null,"children":[{"tag":"num","attrib":{"value":"1320f"},"text":"§ 1320f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8628bfb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320f/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall establish a Drug Price Negotiation Program (in this part referred to as the “program”). Under the program, with respect to each price applicability period, the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8628bfc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320f/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" publish a list of selected drugs in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320f–1"},"text":"section 1320f–1 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8628bfd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320f/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enter into agreements with manufacturers of selected drugs with respect to such period, in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320f–2"},"text":"section 1320f–2 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8628bfe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320f/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" negotiate and, if applicable, renegotiate maximum fair prices for such selected drugs, in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320f–3"},"text":"section 1320f–3 of this title","children":[],"tail":"; "},{"tag":"ref","attrib":{"idref":"fn002741"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002741"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be followed by “and”."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8628bff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320f/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry out the publication and administrative duties and compliance monitoring in accordance with sections 1320f–4 and 1320f–5 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8628c00-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320f/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions relating to timing","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this part:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8628c01-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320f/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial price applicability year","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “initial price applicability year” means a year (beginning with 2026).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8628c02-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320f/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Price applicability period","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “price applicability period” means, with respect to a qualifying single source drug, the period beginning with the first initial price applicability year with respect to which such drug is a selected drug and ending with the last year during which the drug is a selected drug.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8628c03-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320f/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selected drug publication date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “selected drug publication date” means, with respect to each initial price applicability year, February 1 of the year that begins 2 years prior to such year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8628c04-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320f/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Negotiation period","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “negotiation period” means, with respect to an initial price applicability year with respect to a selected drug, the period—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8628c05-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320f/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" beginning on the sooner of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb8628c06-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320f/b/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which the manufacturer of the drug and the Secretary enter into an agreement under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320f–2"},"text":"section 1320f–2 of this title","children":[],"tail":" with respect to such drug; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8628c07-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320f/b/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" February 28 following the selected drug publication date with respect to such selected drug; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8628c08-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320f/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ending on November 1 of the year that begins 2 years prior to the initial price applicability year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8628c09-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320f/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this part:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8628c0a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320f/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Manufacturer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “manufacturer” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395w–3a/c/6/A"},"text":"section 1395w–3a(c)(6)(A) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8628c0b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320f/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum fair price eligible individual","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “maximum fair price eligible individual” means, with respect to a selected drug—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8628c0c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320f/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case such drug is dispensed to the individual at a pharmacy, by a mail order service, or by another dispenser, an individual who is enrolled in a prescription drug plan under part D of subchapter XVIII or an MA–PD plan under part C of such subchapter if coverage is provided under such plan for such selected drug; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8628c0d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320f/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case such drug is furnished or administered to the individual by a hospital, physician, or other provider of services or supplier, an individual who is enrolled under part B of subchapter XVIII, including an individual who is enrolled in an MA plan under part C of such subchapter, if payment may be made under part B for such selected drug.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8628c0e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320f/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum fair price","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “maximum fair price” means, with respect to a year during a price applicability period and with respect to a selected drug (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320f–1/c"},"text":"section 1320f–1(c) of this title","children":[],"tail":") with respect to such period, the price negotiated pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320f–3"},"text":"section 1320f–3 of this title","children":[],"tail":", and updated pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320f–4/b"},"text":"section 1320f–4(b) of this title","children":[],"tail":", as applicable, for such drug and year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8628c0f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320f/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reference product","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “reference product” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s262/i"},"text":"section 262(i) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8628c10-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320f/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Total expenditures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “total expenditures” includes, in the case of expenditures with respect to part D of subchapter XVIII, the total gross covered prescription drug costs (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395w–115/b/3"},"text":"section 1395w–115(b)(3) of this title","children":[],"tail":"). The term “total expenditures” excludes, in the case of expenditures with respect to part B of such subchapter, expenditures for a drug or biological product that are bundled or packaged into the payment for another service."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8628c11-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320f/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “unit” means, with respect to a drug or biological product, the lowest identifiable amount (such as a capsule or tablet, milligram of molecules, or grams) of the drug or biological product that is dispensed or furnished.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8628c12-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320f/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timing for initial price applicability year 2026","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding the provisions of this part, in the case of initial price applicability year 2026, the following rules shall apply for purposes of implementing the program:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8628c13-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320f/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subsection (b)(3) shall be applied by substituting “","children":[{"tag":"date","attrib":{"date":"2023-09-01"},"text":"September 1, 2023","children":[],"tail":"” for “, with respect to each initial price applicability year, February 1 of the year that begins 2 years prior to such year”."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8628c14-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320f/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subsection (b)(4) shall be applied—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8628c15-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320f/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in subparagraph (A)(ii), by substituting “","children":[{"tag":"date","attrib":{"date":"2023-10-01"},"text":"October 1, 2023","children":[],"tail":"” for “February 28 following the selected drug publication date with respect to such selected drug”; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8628c16-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320f/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in subparagraph (B), by substituting “","children":[{"tag":"date","attrib":{"date":"2024-08-01"},"text":"August 1, 2024","children":[],"tail":"” for “November 1 of the year that begins 2 years prior to the initial price applicability year”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8628c17-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320f/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320f–1"},"text":"Section 1320f–1 of this title","children":[],"tail":" shall be applied—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8628c18-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320f/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in subsection (b)(1)(A), by substituting “during the period beginning on ","children":[{"tag":"date","attrib":{"date":"2022-06-01"},"text":"June 1, 2022","children":[],"tail":", and ending on "},{"tag":"date","attrib":{"date":"2023-05-31"},"text":"May 31, 2023","children":[],"tail":"” for “during the most recent period of 12 months prior to the selected drug publication date (but ending not later than October 31 of the year prior to the year of such drug publication date), with respect to such year, for which data are available”; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8628c19-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320f/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in subsection (d)(1)(A), by substituting “during the period beginning on ","children":[{"tag":"date","attrib":{"date":"2022-06-01"},"text":"June 1, 2022","children":[],"tail":", and ending on "},{"tag":"date","attrib":{"date":"2023-05-31"},"text":"May 31, 2023","children":[],"tail":"” for “during the most recent period for which data are available of at least 12 months prior to the selected drug publication date (but ending no later than October 31 of the year prior to the year of such drug publication date), with respect to such year”."},{"tag":"ref","attrib":{"idref":"fn002742"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002742"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should read as follows: “during the most recent 12-month period for which data are available prior to such selected drug publication date (but ending no later than October 31 of the year prior to the year of such drug publication date)”."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8628c1a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320f/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320f–2/a"},"text":"Section 1320f–2(a) of this title","children":[],"tail":" shall be applied by substituting “"},{"tag":"date","attrib":{"date":"2023-10-01"},"text":"October 1, 2023","children":[],"tail":"” for “February 28 following the selected drug publication date with respect to such selected drug”."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8628c1b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320f/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320f–3/b/2"},"text":"Section 1320f–3(b)(2) of this title","children":[],"tail":" shall be applied—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8628c1c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320f/d/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in subparagraph (A), by substituting “","children":[{"tag":"date","attrib":{"date":"2023-10-02"},"text":"October 2, 2023","children":[],"tail":"” for “March 1 of the year of the selected drug publication date, with respect to the selected drug”;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8628c1d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320f/d/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in subparagraph (B), by substituting “","children":[{"tag":"date","attrib":{"date":"2024-02-01"},"text":"February 1, 2024","children":[],"tail":"” for “the June 1 following the selected drug publication date”; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8628c1e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320f/d/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in subparagraph (E), by substituting “","children":[{"tag":"date","attrib":{"date":"2024-08-01"},"text":"August 1, 2024","children":[],"tail":"” for “the first day of November following the selected drug publication date, with respect to the initial price applicability year”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8628c1f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320f/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320f–4/a/1"},"text":"Section 1320f–4(a)(1) of this title","children":[],"tail":" shall be applied by substituting “"},{"tag":"date","attrib":{"date":"2024-09-01"},"text":"September 1, 20