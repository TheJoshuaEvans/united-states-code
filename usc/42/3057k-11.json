{"tag":"section","attrib":{"id":"idbc68aa9b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3057k–11"},"text":null,"children":[{"tag":"num","attrib":{"value":"3057k–11"},"text":"§ 3057k–11.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbc68aa9c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3057k–11/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Assistant Secretary shall carry out a program for making grants to tribal organizations with applications approved under parts A and B, to pay for the Federal share of carrying out tribal programs, to enable the tribal organizations to provide multifaceted systems of the support services described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3030s–1"},"text":"section 3030s–1 of this title","children":[],"tail":" for caregivers described in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3030s–1"},"text":"section 3030s–1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc68aa9d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3057k–11/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In providing services under subsection (a), a tribal organization shall meet the requirements specified for an area agency on aging and for a State in the provisions of subsections (c), (d), and (f) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3030s–1"},"text":"section 3030s–1 of this title","children":[],"tail":" and of "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3030s–2"},"text":"section 3030s–2 of this title","children":[],"tail":". For purposes of this subsection, references in such provisions to a State program shall be considered to be references to a tribal program under this part."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc68aa9e-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/73/tVI/s631"},"text":"Pub. L. 89–73, title VI, § 631","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/501/tVI/s604/3"},"text":"Pub. L. 106–501, title VI, § 604(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-13"},"text":"Nov. 13, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2288"},"text":"114 Stat. 2288","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/131/tII/s217/d"},"text":"Pub. L. 116–131, title II, § 217(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-03-25"},"text":"Mar. 25, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/262"},"text":"134 Stat. 262","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc68aa9f-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc68aaa0-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbc68aaa1-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/73/s631"},"text":"section 631 of Pub. L. 89–73","children":[],"tail":" was renumbered section 641 and is classified to section 3057"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbc68aaa2-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/131"},"text":"Pub. L. 116–131","children":[],"tail":" substituted “(c), (d), and (f)” for “(c), (d), and (e)”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
