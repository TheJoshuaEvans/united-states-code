{"tag":"section","attrib":{"id":"idbc2f71c8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2991b–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"2991b–3"},"text":"§ 2991b–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant program to ensure survival and continuing vitality of Native American languages","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbc2f71c9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2991b–3/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to award grants","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall award a grant to any agency or organization that is—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc2f71ca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2991b–3/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" eligible for financial assistance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2991b/a"},"text":"section 2991b(a) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc2f71cb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2991b–3/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" selected under subsection (c);","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"to be used to assist Native Americans in ensuring the survival and continuing vitality of Native American languages.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc2f71cc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2991b–3/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes for which grants may be used","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes for which each grant awarded under subsection (a) may be used include, but are not limited to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc2f71cd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2991b–3/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the establishment and support of a community Native American language project to bring older and younger Native Americans together to facilitate and encourage the transfer of Native American language skills from one generation to another;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc2f71ce-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2991b–3/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the establishment of a project to train Native Americans to teach a Native American language to others or to enable them to serve as interpreters or translators of such language;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc2f71cf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2991b–3/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development, printing, and dissemination of materials to be used for the teaching and enhancement of a Native American language;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc2f71d0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2991b–3/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the establishment or support of a project to train Native Americans to produce or participate in a television or radio program to be broadcast in a Native American language;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc2f71d1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2991b–3/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the compilation, transcription, and analysis of oral testimony to record and preserve a Native American language;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc2f71d2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2991b–3/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the purchase of equipment (including audio and video recording equipment, computers, and software) required to conduct a Native American language project; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc2f71d3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2991b–3/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc2f71d4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2991b–3/b/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Native American language nests, which are site-based educational programs that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbc2f71d5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2991b–3/b/7/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide instruction and child care through the use of a Native American language for at least 5 children under the age of 7 for an average of at least 500 hours per year per student;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc2f71d6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2991b–3/b/7/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide classes in a Native American language for parents (or legal guardians) of students enrolled in a Native American language nest (including Native American language-speaking parents); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc2f71d7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2991b–3/b/7/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that a Native American language is the dominant medium of instruction in the Native American language nest;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc2f71d8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2991b–3/b/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Native American language survival schools, which are site-based educational programs for school-age students that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbc2f71d9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2991b–3/b/7/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide an average of at least 500 hours of instruction through the use of 1 or more Native American languages for at least 10 students for whom a Native American language survival school is their principal place of instruction;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc2f71da-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2991b–3/b/7/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop instructional courses and materials for learning Native American languages and for instruction through the use of Native American languages;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc2f71db-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2991b–3/b/7/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for teacher training;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc2f71dc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2991b–3/b/7/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" work toward a goal of all students achieving—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbc2f71dd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2991b–3/b/7/B/iv/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fluency in a Native American language; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbc2f71de-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2991b–3/b/7/B/iv/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" academic proficiency in mathematics, reading (or language arts), and science; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc2f71df-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2991b–3/b/7/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are located in areas that have high numbers or percentages of Native American students; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc2f71e0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2991b–3/b/7/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Native American language restoration programs, which are educational programs that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbc2f71e1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2991b–3/b/7/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operate at least 1 Native American language program for the community in which it serves;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc2f71e2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2991b–3/b/7/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide training programs for teachers of Native American languages;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc2f71e3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2991b–3/b/7/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop instructional materials for the programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc2f71e4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2991b–3/b/7/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" work toward a goal of increasing proficiency and fluency in at least 1 Native American language;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc2f71e5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2991b–3/b/7/C/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide instruction in at least 1 Native American language; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc2f71e6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2991b–3/b/7/C/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" may use funds received under this section for—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbc2f71e7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2991b–3/b/7/C/vi/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Native American language programs, such as Native American language immersion programs, Native American language and culture camps, Native American language programs provided in coordination and cooperation with educational entities, Native American language programs provided in coordination and cooperation with local universities and colleges, Native American language programs that use a master-apprentice model of learning languages, and Native American language programs provided through a regional program to better serve geographically dispersed students;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbc2f71e8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2991b–3/b/7/C/vi/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Native American language teacher training programs, such as training programs in Native American language translation for fluent speakers, training programs for Native American language teachers, training programs for teachers in schools to utilize Native American language materials, tools, and interactive media to teach Native American language; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbc2f71e9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2991b–3/b/7/C/vi/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development of Native American language materials, such as books, audio and visual tools, and interactive media programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc2f71ea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2991b–3/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purpose of making grants under subsection (a), the Secretary shall select applicants from among agencies and organizations described in such subsection on the basis of applications submitted to the Secretary at such time, in such form, and containing such information as the Secretary shall require, but each application shall include at a minimum—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc2f71eb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2991b–3/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a detailed description of the current status of the Native American language to be addressed by the project for which a grant under subsection (a) is requested, including a description of existing programs and projects, if any, in support of such language;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc2f71ec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2991b–3/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a detailed description of the project for which such grant is requested;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc2f71ed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2991b–3/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a statement of objectives that are consonant with the purpose described in subsection (a);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc2f71ee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2991b–3/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a detailed description of a plan to be carried out by the applicant to evaluate such project, consonant with the purpose for which such grant is made;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc2f71ef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2991b–3/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if appropriate, an identification of opportunities for the replication of such project or the modification of such project for use by other Native Americans;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc2f71f0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2991b–3/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a plan for the preservation of the products of the Native American language project for the benefit of future generations of Native Americans and other interested persons; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc2f71f1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2991b–3/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an application for a grant to carry out any purpose specified in subsection (b)(7)(B), a certification by the applicant that the applicant has not less than 3 years of experience in operating and administering a Native American language survival school, a Native American language nest, or any other educational program in which instruction is conducted in a Native American language.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc2f71f2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2991b–3/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Participating organizations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a Tribal organization or other eligible applicant decides that the objectives of its proposed Native American language project would be accomplished more effectively through a partnership arrangement with a school, college, or university, the applicant shall identify such school, college, or university as a participating organization in the application submitted under subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc2f71f3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2991b–3/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on funding","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc2f71f4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2991b–3/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Share","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of this subchapter, a grant made under subsection (a) may not be expended to pay more than 80 percent of the cost of the project that is assisted by such grant. Not less than 20 percent of such cost—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc2f71f5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2991b–3/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be in cash or in kind, fairly evaluated, including plant, equipment, or services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc2f71f6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2991b–3/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbc2f71f7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2991b–3/e/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be provided from any private or non-Federal source; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc2f71f8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2991b–3/e/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" may include funds (including interest) distributed to a Tribe—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbc2f71f9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2991b–3/e/1/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by the Federal Government pursuant to the satisfaction of a claim made under Federal law;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbc2f71fa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2991b–3/e/1/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" from funds collected and administered by the Federal Government on behalf of such Tribe or its constituent members; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbc2f71fb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2991b–3/e/1/B/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by the Federal Government for general Tribal administration or Tribal development under a formula or subject to a Tribal budgeting priority system, such as, but not limited to, funds involved in the settlement of land or other judgment claims, severance or other royalty payments, or payments under the Indian Self-Determination Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s450f"},"text":"25 U.S.C. 450f","children":[],"tail":" et seq.) "},{"tag":"ref","attrib":{"idref":"fn003290"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003290"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" or Tribal budget priority system."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc2f71fc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2991b–3/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may make grants made under subsection (a) on a 1-year, 2-year, 3-year, 4-year, or 5-year basis, except that grants made under such subsection for any purpose specified in subsection (b)(7) may be made only on a 3-year, 4-year, or 5-year basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc2f71fd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2991b–3/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc2f71fe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2991b–3/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall carry out this section through the Administration for Native Americans.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc2f71ff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2991b–3/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc2f7200-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2991b–3/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"1992-10-26"},"text":"October 26, 1992","children":[],"tail":", the Secretary shall appoint a panel of experts for the purpose of assisting the Secretary to review—"}],"tail":null},{"tag":"clause","attrib":{"id":"idbc2f7201-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2991b–3/f/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" applications submitted under subsection (a);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc2f7202-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2991b–3/f/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluations carried out to comply with subsection (c)(4); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc2f7203-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2991b–3/f/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the preservation of products required by subsection (c)(5).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc2f7204-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2991b–3/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Such panel shall include, but not be limited to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbc2f7205-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2991b–3/f/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a designee of the Institute of American Indian and Alaska Native Culture and Arts Development;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc2f7206-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2991b–3/f/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a designee of the regional centers funded under section 3215 ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of title 20;"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc2f7207-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2991b–3/f/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" representatives of national, Tribal, and regional organizations that focus on Native American language, or Native American cultural,","children":[{"tag":"ref","attrib":{"idref":"fn003291"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003291"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. The comma probably should not appear."}],"tail":" research, development, or training; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc2f7208-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2991b–3/f/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other individuals who are recognized for their expertise in the area of Native American language.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Recommendations for appointment to such panel shall be solicited from Indian Tribes and Tribal organizations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc2f7209-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2991b–3/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The duties of such panel include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbc2f720a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2991b–3/f/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" making recommendations regarding the development and implementation of regulations, policies, procedures, and rules of general applicability with respect to the administration of this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc2f720b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2991b–3/f/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reviewing applications received under subsection (c);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc2f720c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2991b–3/f/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" providing to the Secretary a list of recommendations for the approval of such applications—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbc2f720d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2991b–3/f/2/C/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in accordance with regulations issued by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbc2f720e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2991b–3/f/2/C/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the relative need for the project; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc2f720f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2991b–3/f/2/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reviewing evaluations submitted to comply with subsection (c)(4).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc2f7210-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2991b–3/f/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbc2f7211-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2991b–3/f/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subject to clause (ii), a copy of the products of the Native American language project for which a grant is made under subsection (a)—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbc2f7212-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2991b–3/f/2/D/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be transmitted to the Institute of American Indian and Alaska Native Culture and Arts Development; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbc2f7213-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2991b–3/f/2/D/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be transmitted, in the discretion of the grantee, to national and regional repositories of similar material;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"for preservation and use consonant with their respective responsibilities under other Federal law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc2f7214-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2991b–3/f/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Based on the Federal recognition of the sovereign authority of Indian Tribes over all aspects of their cultures and language and except as provided in clause (iii), an Indian Tribe may make a determination—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbc2f7215-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2991b–3/f/2/D/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not to transmit copies of such products under clause (i) or not to permit the redistribution of such copies; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbc2f7216-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2991b–3/f/2/D/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to restrict in any manner the use or redistribution of such copies after transmission under such clause.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc2f7217-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2991b–3/f/2/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Clause (ii) shall not be construed to authorize Indian Tribes—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbc2f7218-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2991b–3/f/2/D/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to limit the access of the Secretary to such products for purposes of administering this section or evaluating such products; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbc2f7219-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2991b–3/f/2/D/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to sell such products, or copies of such products, for profit to the entities referred to in clause (i).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc2f721a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2991b–3/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emergency grants for Native American language preservation and maintenance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after the effective date of this subsection, the Secretary shall award grants to entities eligible to receive assistance under subsection (a)(1) to ensure the survival and continuing vitality of Native American languages during and after the public health emergency declared by the Secretary pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s247d"},"text":"section 247d of this title","children":[],"tail":" with respect to the COVID–19 pandemic."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc2f721b-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/452/tVIII/s803C"},"text":"Pub. L. 88–452, title VIII, § 803C","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/524/s2"},"text":"Pub. L. 102–524, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-26"},"text":"Oct. 26, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3434"},"text":"106 Stat. 3434","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/394/s2"},"text":"Pub. L. 109–394, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-14"},"text":"Dec. 14, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2705"},"text":"120 Stat. 2705","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/101/s2"},"text":"Pub. L. 116–101, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/3261"},"text":"133 Stat. 3261","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/261/s5/d"},"text":"Pub. L. 116–261, § 5(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-30"},"text":"Dec. 30, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3314"},"text":"134 Stat. 3314","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/2/tXI/s11004/b"},"text":"Pub. L. 117–2, title XI, § 11004(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-03-11"},"text":"Mar. 11, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/244"},"text":"135 Stat. 244","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc2f721c-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc2f721d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbc2f721e-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Indian Self-Determination Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s450f"},"text":"25 U.S.C. 450f","children":[],"tail":" et seq.), referred to in subsec. (e)(1)(B)(ii)(III), is title I of "},{"tag":"ref","attrib":{"href":"/us/pl/93/638"},"text":"Pub. L. 93–638","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-04"},"text":"Jan. 4, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2206"},"text":"88 Stat. 2206","children":[],"tail":", which was classified principally to part A (§ 450f et seq.) of subchapter II of chapter 14 of Title 25, Indians, prior to editorial reclassification as subchapter I (§ 5321 et seq.) of chapter 46 of Title 25. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5301"},"text":"section 5301 of Title 25","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s3215"},"text":"Section 3215 of title 20","children":[],"tail":", referred to in subsec. (f)(2)(B)(ii), was in the original a reference to section 5135 of the Elementary and Secondary Education Act of 1965, "},{"tag":"ref","attrib":{"href":"/us/pl/89/10"},"text":"Pub. L. 89–10","children":[],"tail":". Section 5135 of that Act was omitted in the general amendment of "},{"tag":"ref","attrib":{"href":"/us/pl/89/10"},"text":"Pub. L. 89–10","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/tI/s101"},"text":"Pub. L. 103–382, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3519"},"text":"108 Stat. 3519","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The effective date of this subsection, referred to in subsec. (g), probably means the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/2"},"text":"Pub. L. 117–2","children":[],"tail":", which added subsec. (g) of this section and was approved "},{"tag":"date","attrib":{"date":"2021-03-11"},"text":"Mar. 11, 2021","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbc2f721f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/2"},"text":"Pub. L. 117–2","children":[],"tail":" added subsec. (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2020—Subsecs. (d) to (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/261"},"text":"Pub. L. 116–261","children":[],"tail":" substituted “Tribe” for “tribe”, “Tribes” for “tribes”, and “Tribal” for “tribal” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2019—Subsec. (b)(7)(A)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/101/s2/1/A"},"text":"Pub. L. 116–101, § 2(1)(A)","children":[],"tail":", substituted “5 children” for “10 children”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(7)(B)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/101/s2/1/B"},"text":"Pub. L. 116–101, § 2(1)(B)","children":[],"tail":", substituted “10 students” for “15 students”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/101/s2/2"},"text":"Pub. L. 116–101, § 2(2)","children":[],"tail":", substituted “3-year, 4-year, or 5-year basis” for “or 3-year basis” and inserted “, 4-year, or 5-year” after “on a 3-year”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (b)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/394/s2/1"},"text":"Pub. L. 109–394, § 2(1)","children":[],"tail":", added par. (7)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/394/s2/2"},"text":"Pub. L. 109–394, § 2(2)","children":[],"tail":", added par. (7)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/394/s2/3"},"text":"Pub. L. 109–394, § 2(3)","children":[],"tail":", inserted “, except that grants made under such subsection for any purpose specified in subsection (b)(7) may be made only on a 3-year basis” before period at end."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
