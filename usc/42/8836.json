{"tag":"section","attrib":{"id":"idbea776bf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8836"},"text":null,"children":[{"tag":"num","attrib":{"value":"8836"},"text":"§ 8836.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial assistance program administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of Energy shall establish procedures and take such other actions as may be necessary regarding the solicitation, review, and evaluation of applications, and awarding of financial assistance under section 8832, 8833, or 8834 of this title as may be necessary to carry out the plan established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s8831"},"text":"section 8831 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbea776c0-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/294/tII/s236"},"text":"Pub. L. 96–294, title II, § 236","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-06-30"},"text":"June 30, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/703"},"text":"94 Stat. 703","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
