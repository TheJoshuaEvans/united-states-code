{"tag":"section","attrib":{"id":"idbfadc3c3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13102"},"text":null,"children":[{"tag":"num","attrib":{"value":"13102"},"text":"§ 13102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfadc3c4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13102/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Administrator” means the Administrator of the Environmental Protection Agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfadc3c5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13102/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Agency” means the Environmental Protection Agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfadc3c6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13102/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “toxic chemical” means any substance on the list described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11023/c"},"text":"section 11023(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfadc3c7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13102/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “release” has the same meaning as provided by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11049/8"},"text":"section 11049(8) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfadc3c8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13102/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfadc3c9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13102/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “source reduction” means any practice which—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbfadc3ca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13102/5/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reduces the amount of any hazardous substance, pollutant, or contaminant entering any waste stream or otherwise released into the environment (including fugitive emissions) prior to recycling, treatment, or disposal; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbfadc3cb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13102/5/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reduces the hazards to public health and the environment associated with the release of such substances, pollutants, or contaminants.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The term includes equipment or technology modifications, process or procedure modifications, reformulation or redesign of products, substitution of raw materials, and improvements in housekeeping, maintenance, training, or inventory control.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfadc3cc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13102/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “source reduction” does not include any practice which alters the physical, chemical, or biological characteristics or the volume of a hazardous substance, pollutant, or contaminant through a process or activity which itself is not integral to and necessary for the production of a product or the providing of a service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfb00cbd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13102/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “multi-media” means water, air, and land.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfb00cbe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13102/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “SIC codes” refers to the 2-digit code numbers used for classification of economic activity in the Standard Industrial Classification Manual.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfb00cbf-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508/tVI/s6603"},"text":"Pub. L. 101–508, title VI, § 6603","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-321"},"text":"104 Stat. 1388–321","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
