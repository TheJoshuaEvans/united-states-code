{"tag":"section","attrib":{"id":"idb8780f4a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1382f"},"text":null,"children":[{"tag":"num","attrib":{"value":"1382f"},"text":"§ 1382f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost-of-living adjustments in benefits","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8780f4b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1382f/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Increase of dollar amounts","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Whenever benefit amounts under subchapter II are increased by any percentage effective with any month as a result of a determination made under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s415/i"},"text":"section 415(i) of this title","children":[],"tail":"—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8780f4c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1382f/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" each of the dollar amounts in effect for such month under subsections (a)(1)(A), (a)(2)(A), (b)(1), and (b)(2) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1382"},"text":"section 1382 of this title","children":[],"tail":", and subsection (a)(1)(A) of "},{"tag":"ref","attrib":{"href":"/us/pl/93/66/s211"},"text":"section 211 of Public Law 93–66","children":[],"tail":", as specified in such subsections or as previously increased under this section, shall be increased by the amount (if any) by which—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8780f4d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1382f/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount which would have been in effect for such month under such subsection but for the rounding of such amount pursuant to paragraph (2), exceeds","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb87a804e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1382f/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount in effect for such month under such subsection; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb87a804f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1382f/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount obtained under paragraph (1) with respect to each subsection shall be further increased by the same percentage by which benefit amounts under subchapter II are increased for such month, or, if greater (in any case where the increase under subchapter II was determined on the basis of the wage increase percentage rather than the CPI increase percentage), the percentage by which benefit amounts under subchapter II would be increased for such month if the increase had been determined on the basis of the CPI increase percentage, (and rounded, when not a multiple of $12, to the next lower multiple of $12), effective with respect to benefits for months after such month.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb87a8050-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1382f/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication in Federal Register of new dollar amounts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The new dollar amounts to be in effect under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1382"},"text":"section 1382 of this title","children":[],"tail":" and under "},{"tag":"ref","attrib":{"href":"/us/pl/93/66/s211"},"text":"section 211 of Public Law 93–66","children":[],"tail":" by reason of subsection (a) of this section shall be published in the Federal Register together with, and at the same time as, the material required by "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s415/i/2/D"},"text":"section 415(i)(2)(D) of this title","children":[],"tail":" to be published therein by reason of the determination involved."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb87a8051-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1382f/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional increases","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Effective ","children":[{"tag":"date","attrib":{"date":"1983-07-01"},"text":"July 1, 1983","children":[],"tail":"—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb87a8052-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1382f/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each of the dollar amounts in effect under subsections (a)(1)(A) and (b)(1) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1382"},"text":"section 1382 of this title","children":[],"tail":", as previously increased under this section, shall be increased by $240 (and the dollar amount in effect under subsection (a)(1)(A) of section 211 of Public Law 93-66, as previously so increased, shall be increased by $120); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb87a8053-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1382f/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each of the dollar amounts in effect under subsections (a)(2)(A) and (b)(2) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1382"},"text":"section 1382 of this title","children":[],"tail":", as previously increased under this section, shall be increased by $360."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb87a8054-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title XVI, § 1617, as added "},{"tag":"ref","attrib":{"href":"/us/pl/93/368/s6/b"},"text":"Pub. L. 93–368, § 6(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-08-07"},"text":"Aug. 7, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/421"},"text":"88 Stat. 421","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/97/248/tI/s182/a"},"text":"Pub. L. 97–248, title I, § 182(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-03"},"text":"Sept. 3, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/404"},"text":"96 Stat. 404","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/21/tIV/s401"},"text":"Pub. L. 98–21, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-04-20"},"text":"Apr. 20, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/138"},"text":"97 Stat. 138","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb87a8055-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb87a8056-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}