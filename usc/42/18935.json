{"tag":"section","attrib":{"id":"idc0713af7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18935"},"text":null,"children":[{"tag":"num","attrib":{"value":"18935"},"text":"§ 18935.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dissemination of resources for research institutions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc0713af8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18935/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dissemination of resources for research institutions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0713af9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18935/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than one year after ","children":[{"tag":"date","attrib":{"date":"2022-08-09"},"text":"August 9, 2022","children":[],"tail":", the Director shall, using the authorities of the Director under subsections (c)(15) and (e)(1)(A)(ix) of "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s272"},"text":"section 272 of title 15","children":[],"tail":", disseminate and make publicly available tailored resources to help qualifying institutions identify, assess, manage, and reduce their cybersecurity risk related to conducting research."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0713afa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18935/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director shall ensure that the resources disseminated pursuant to paragraph (1)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0713afb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18935/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are generally applicable and usable by a wide range of qualifying institutions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0713afc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18935/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" vary with the nature and size of the qualifying institutions, and the nature and sensitivity of the data collected or stored on the information systems or devices of the qualifying institutions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0713afd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18935/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include elements that promote awareness of simple, basic controls, a workplace cybersecurity culture, and third-party stakeholder relationships, to assist qualifying institutions in mitigating common cybersecurity risks;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0713afe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18935/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include case studies, examples, and scenarios of practical application;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0713aff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18935/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are outcomes-based and can be implemented using a variety of technologies that are commercial and off-the-shelf; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0713b00-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18935/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent practicable, are based on international technical standards.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0713b01-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18935/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National cybersecurity awareness and education program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall ensure that the resources disseminated under paragraph (1) are consistent with the efforts of the Director under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s7443"},"text":"section 7443 of title 15","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0713b02-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18935/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Updates","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall review periodically and update the resources under paragraph (1) as the Director determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0713b03-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18935/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Voluntary resources","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The use of the resources disseminated under paragraph (1) shall be considered voluntary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0713b04-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18935/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other Federal cybersecurity requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section may be construed to supersede, alter, or otherwise affect any cybersecurity requirements applicable to Federal agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0713b05-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18935/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0713b06-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18935/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifying institutions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “qualifying institutions” means institutions of higher education that are awarded in excess of $50,000,000 per year in total Federal research funding.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0713b07-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18935/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Resources","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “resources” means guidelines, tools, best practices, technical standards, methodologies, and other ways of providing information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc0713b08-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/tII/s10229"},"text":"Pub. L. 117–167, div. B, title II, § 10229","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1481"},"text":"136 Stat. 1481","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
