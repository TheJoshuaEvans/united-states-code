{"tag":"section","attrib":{"id":"idbf01f2c0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858q"},"text":null,"children":[{"tag":"num","attrib":{"value":"9858q"},"text":"§ 9858q.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Miscellaneous provisions","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other law, the value of any child care provided or arranged (or any amount received as payment for such care or reimbursement for costs incurred for such care) under this subchapter shall not be treated as income for purposes of any other Federal or Federally-assisted program that bases eligibility, or the amount of benefits, on need.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbf01f2c1-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35/tVI/s658S"},"text":"Pub. L. 97–35, title VI, § 658S","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/586/s8/b"},"text":"Pub. L. 102–586, § 8(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-11-04"},"text":"Nov. 4, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/5035"},"text":"106 Stat. 5035","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/171/s8"},"text":"Pub. L. 103–171, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-02"},"text":"Dec. 2, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1994"},"text":"107 Stat. 1994","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf01f2c2-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf01f2c3-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"