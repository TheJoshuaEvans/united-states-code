{"tag":"section","attrib":{"id":"idbba9edf7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1962d–5d"},"text":null,"children":[{"tag":"num","attrib":{"value":"1962d–5d"},"text":"§ 1962d–5d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of Secretary of the Army to contract with States and political subdivisions for increased law enforcement services during peak visitation periods; authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbba9edf8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1962d–5d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Army, acting through the Chief of Engineers, is authorized to contract with States and their political subdivisions for the purpose of obtaining increased law enforcement services at water resources development projects under the jurisdiction of the Secretary of the Army to meet needs during peak visitation periods.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbba9edf9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1962d–5d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is authorized to be appropriated $10,000,000 per fiscal year for each fiscal year beginning after ","children":[{"tag":"date","attrib":{"date":"1986-09-30"},"text":"September 30, 1986","children":[],"tail":", to carry out this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbba9edfa-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/587/s120"},"text":"Pub. L. 94–587, § 120","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-22"},"text":"Oct. 22, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2924"},"text":"90 Stat. 2924","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/662/tIX/s920"},"text":"Pub. L. 99–662, title IX, § 920","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-17"},"text":"Nov. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/4193"},"text":"100 Stat. 4193","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbba9edfb-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbba9edfc-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbba9edfd-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Water Resources Development Act of 1976, and not as part of the Water Resources Planning Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbba9edfe-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1986—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/662"},"text":"Pub. L. 99–662","children":[],"tail":" amended subsec. (b) generally, substituting “$10,000,000 per fiscal year for each fiscal year beginning after "},{"tag":"date","attrib":{"date":"1986-09-30"},"text":"September 30, 1986","children":[],"tail":"” for “$6,000,000 per fiscal year for the fiscal years ending "},{"tag":"date","attrib":{"date":"1978-09-30"},"text":"September 30, 1978","children":[],"tail":", and "},{"tag":"date","attrib":{"date":"1979-09-30"},"text":"September 30, 1979","children":[],"tail":"”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
