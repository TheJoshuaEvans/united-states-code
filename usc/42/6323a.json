{"tag":"section","attrib":{"id":"idbd978db8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6323a"},"text":null,"children":[{"tag":"num","attrib":{"value":"6323a"},"text":"§ 6323a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matching State contributions","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"For the base State Energy Conservation Program (part D of the Energy Policy and Conservation Act, sections 361 through 366 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6321–632"},"text":"42 U.S.C. 6321–632","children":[],"tail":"6]), each State will hereafter match in cash or in kind not less than 20 percent of the Federal contribution."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbd978db9-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473/tI/s101/c/tII"},"text":"Pub. L. 98–473, title I, § 101(c) [title II]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1837"},"text":"98 Stat. 1837","children":[],"tail":", 1861.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd978dba-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd978dbb-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbd978dbc-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Energy Policy and Conservation Act, referred to in text, is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/163"},"text":"Pub. L. 94–163","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-12-22"},"text":"Dec. 22, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/871"},"text":"89 Stat. 871","children":[],"tail":". Part D of title III of the Energy Policy and Conservation Act, as amended, is classified generally to this part (§ 6321 et seq.). For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s6201"},"text":"section 6201 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbd978dbd-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Department of the Interior and Related Agencies Appropriations Act, 1985, as enacted by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473"},"text":"Pub. L. 98–473","children":[],"tail":", and not as part of the Energy Policy and Conservation Act which comprises this chapter."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbd978dbe-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in the following prior appropriation act:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/146/tII"},"text":"Pub. L. 98–146, title II","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-11-04"},"text":"Nov. 4, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/942"},"text":"97 Stat. 942","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
