{"tag":"section","attrib":{"id":"idbc1ed0a5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2321"},"text":null,"children":[{"tag":"num","attrib":{"value":"2321"},"text":"§ 2321.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lots; establishment of boundaries","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Commission is authorized to plat each community immediately upon passage of this chapter, or immediately upon the inclusion of the community within the provisions of this chapter. The Commission may establish lot boundaries, and realine, divide, or enlarge existing tracts as it deems appropriate.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbc1ed0a6-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1955-08-04/ch543"},"text":"Aug. 4, 1955, ch. 543","children":[],"tail":", ch. 3, § 31, "},{"tag":"ref","attrib":{"href":"/us/stat/69/474"},"text":"69 Stat. 474","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc1ed0a7-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbc1ed0a8-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"idbc1ed0a9-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Atomic Energy Commission abolished and functions transferred by sections 5814 and 5841 of this title. See also Transfer of Functions notes set out under those sections.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
