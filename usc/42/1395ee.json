 title XVIII, § 1868","children":[],"tail":", as added "},{"tag":"date","attrib":{"date":"1965-07-30"},"text":"July 30, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/89/97/tI/s102/a"},"text":"Pub. L. 89–97, title I, § 102(a)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/329"},"text":"79 Stat. 329","children":[],"tail":", provided for creation of a National Medical Review Committee, functions of such Committee, including submission of annual reports to the Secretary and Congress, employment of technical assistance, and for availability of assistance and data, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/90/248/tI/s164/c"},"text":"Pub. L. 90–248, title I, § 164(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-01-02"},"text":"Jan. 2, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/874"},"text":"81 Stat. 874","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb99d5570-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (c)(1)(B)(iv). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/c/42"},"text":"Pub. L. 117–286, § 4(c)(42)","children":[],"tail":", substituted “subchapter I of chapter 131 of title 5.” for “title I of the Ethics in Government Act of 1978 ("},{"tag":"ref","attrib":{"href":"/us/pl/95/521"},"text":"Public Law 95–521","children":[],"tail":").”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(G). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/255"},"text":"Pub. L. 117–286, § 4(a)(255)","children":[],"tail":", substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t5/s1013"},"text":"Section 1013 of title 5","children":[],"tail":"” for “Section 14 of the Federal Advisory Committee Act (5 U.S.C. App.)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (c)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/123"},"text":"Pub. L. 115–123","children":[],"tail":" amended subpar. (C) generally. Prior to amendment, text read as follows: “The Committee shall, on a periodic basis, review models submitted under subparagraph (B), prepare comments and recommendations regarding whether such models meet the criteria described in subparagraph (A), and submit such comments and recommendations to the Secretary.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2015—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/10"},"text":"Pub. L. 114–10","children":[],"tail":" added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148"},"text":"Pub. L. 111–148","children":[],"tail":" struck out subsec. (a) which related to the Practicing Physicians Advisory Council."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/173/s942/a/1"},"text":"Pub. L. 108–173, § 942(a)(1)","children":[],"tail":", inserted “; Council for Technology and Innovation” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/173/s942/a/2"},"text":"Pub. L. 108–173, § 942(a)(2)","children":[],"tail":"–(4), inserted subsec. heading, redesignated existing provisions as par. (1), substituted “in this subsection” for “in this section”, and redesignated former subsecs. (b) and (c) as pars. (2) and (3), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/173/s942/a/5"},"text":"Pub. L. 108–173, § 942(a)(5)","children":[],"tail":", added subsec. (b). Former subsec. (b) redesignated par. (2) of subsec. (a)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/173/s942/a/4"},"text":"Pub. L. 108–173, § 942(a)(4)","children":[],"tail":", redesignated subsec. (c) as par. (3) of subsec. (a)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb99d5571-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb99d5572-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Advisory Councils","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Advisory councils established after ","children":[{"tag":"date","attrib":{"date":"1973-01-05"},"text":"Jan. 5, 1973","children":[],"tail":", to terminate not later than the expiration of the 2-year period beginning on the date of their establishment, unless, in the case of a council established by the President or an officer of the Federal Government, such council is renewed by appropriate action prior to the expiration of such 2-year period, or in the case of a council established by Congress, its duration is otherwise provided by law. See sections 1001(2) and 1013 of Title 5, Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
