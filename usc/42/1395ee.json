{"tag":"section","attrib":{"id":"idb99b0b53-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395ee"},"text":null,"children":[{"tag":"num","attrib":{"value":"1395ee"},"text":"§ 1395ee.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Practicing Physicians Advisory Council; Council for Technology and Innovation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb99b0b54-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395ee/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repealed. ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/tIII/s3134/b/2"},"text":"Pub. L. 111–148, title III, § 3134(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/435"},"text":"124 Stat. 435","children":[],"tail":null}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb99b0b55-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395ee/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Council for Technology and Innovation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb99b0b56-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395ee/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a Council for Technology and Innovation within the Centers for Medicare & Medicaid Services (in this section referred to as “CMS”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb99b0b57-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395ee/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Composition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Council shall be composed of senior CMS staff and clinicians and shall be chaired by the Executive Coordinator for Technology and Innovation (appointed or designated under paragraph (4)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb99b0b58-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395ee/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Council shall coordinate the activities of coverage, coding, and payment processes under this subchapter with respect to new technologies and procedures, including new drug therapies, and shall coordinate the exchange of information on new technologies between CMS and other entities that make similar decisions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb99b0b59-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395ee/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Executive Coordinator for Technology and Innovation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall appoint (or designate) a noncareer appointee (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3132/a/7"},"text":"section 3132(a)(7) of title 5","children":[],"tail":") who shall serve as the Executive Coordinator for Technology and Innovation. Such executive coordinator shall report to the Administrator of CMS, shall chair the Council, shall oversee the execution of its duties, and shall serve as a single point of contact for outside groups and entities regarding the coverage, coding, and payment processes under this subchapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb99b0b5a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395ee/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Physician-focused payment models","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb99b0b5b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395ee/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical Advisory Committee","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb99b0b5c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395ee/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established an ad hoc committee to be known as the “Physician-Focused Payment Model Technical Advisory Committee” (referred to in this subsection as the “Committee”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb99b0b5d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395ee/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb99b0b5e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395ee/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Number and appointment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Committee shall be composed of 11 members appointed by the Comptroller General of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb99b0b5f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395ee/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The membership of the Committee shall include individuals with national recognition for their expertise in physician-focused payment models and related delivery of care. No more than 5 members of the Committee shall be providers of services or suppliers, or representatives of providers of services or suppliers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb99b0b60-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395ee/c/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on Federal employment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A member of the Committee shall not be an employee of the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb99b0b61-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395ee/c/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ethics disclosure","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Comptroller General shall establish a system for public disclosure by members of the Committee of financial and other potential conflicts of interest relating to such members. Members of the Committee shall be treated as employees of Congress for purposes of applying subchapter I of chapter 131 of title 5.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb99b0b62-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395ee/c/1/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Date of initial appointments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The initial appointments of members of the Committee shall be made by not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2015-04-16"},"text":"April 16, 2015","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb99b0b63-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395ee/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term; vacancies","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb99b0b64-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395ee/c/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms of members of the Committee shall be for 3 years except that the Comptroller General shall designate staggered terms for the members first appointed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb99b0b65-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395ee/c/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vacancies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any member appointed to fill a vacancy occurring before the expiration of the term for which the member’s predecessor was appointed shall be appointed only for the remainder of that term. A member may serve after the expiration of that member’s term until a successor has taken office. A vacancy in the Committee shall be filled in the manner in which the original appointment was made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb99b0b66-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395ee/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Committee shall meet, as needed, to provide comments and recommendations to the Secretary, as described in paragraph (2)(C), on physician-focused payment models.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb99b0b67-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395ee/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation of members","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb99b0b68-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395ee/c/1/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in clause (ii), a member of the Committee shall serve without compensation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb99b0b69-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395ee/c/1/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Travel expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A member of the Committee shall be allowed travel expenses, including per diem in lieu of subsistence, at rates authorized for an employee of an agency under subchapter I of chapter 57 of title 5 while away from the home or regular place of business of the member in the performance of the duties of the Committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb99b0b6a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395ee/c/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Operational and technical support","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb99b0b6b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395ee/c/1/F/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Assistant Secretary for Planning and Evaluation shall provide technical and operational support for the Committee, which may be by use of a contractor. The Office of the Actuary of the Centers for Medicare & Medicaid Services shall provide to the Committee actuarial assistance as needed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb99b0b6c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395ee/c/1/F/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide for the transfer, from the Federal Supplementary Medical Insurance Trust Fund under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395t"},"text":"section 1395t of this title","children":[],"tail":", such amounts as are necessary to carry out this paragraph (not to exceed $5,000,000) for fiscal year 2015 and each subsequent fiscal year. Any amounts transferred under the preceding sentence for a fiscal year shall remain available until expended."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb99b0b6d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395ee/c/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s1013"},"text":"Section 1013 of title 5","children":[],"tail":" shall not apply to the Committee."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb99b0b6e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395ee/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria and process for submission and review of physician-focused payment models","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb99b0b6f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395ee/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria for assessing physician-focused payment models","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb99b0b70-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395ee/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rulemaking","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2016-11-01"},"text":"November 1, 2016","children":[],"tail":", the Secretary shall, through notice and comment rulemaking, following a request for information, establish criteria for physician-focused payment models, including models for specialist physicians, that could be used by the Committee for making comments and recommendations pursuant to paragraph (1)(D)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb99b0b71-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395ee/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" MedPAC submission of comments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"During the comment period for the proposed rule described in clause (i), the Medicare Payment Advisory Commission may submit comments to the Secretary on the proposed criteria under such clause.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb99d5562-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395ee/c/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Updating","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may update the criteria established under this subparagraph through rulemaking.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb99d5563-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395ee/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Stakeholder submission of physician-focused payment models","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On an ongoing basis, individuals and stakeholder entities may submit to the Committee proposals for physician-focused payment models that such individuals and entities believe meet the criteria described in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb99d5564-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395ee/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Committee review of models submitted","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Committee, on a periodic basis—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb99d5565-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395ee/c/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall review models submitted under subparagraph (B);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb99d5566-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395ee/c/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" may provide individuals and stakeholder entities who submitted such models with—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb99d5567-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395ee/c/2/C/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" initial feedback on such models regarding the extent to which such models meet the criteria described in subparagraph (A); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb99d5568-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395ee/c/2/C/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an explanation of the basis for the feedback provided under subclause (I); and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb99d5569-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395ee/c/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall prepare comments and recommendations regarding whether such models meet the criteria described in subparagraph (A) and submit such comments and recommendations to the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb99d556a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395ee/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary review and response","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall review the comments and recommendations submitted by the Committee under subparagraph (C) and post a detailed response to such comments and recommendations on the Internet website of the Centers for Medicare & Medicaid Services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb99d556b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395ee/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subsection shall be construed to impact the development or testing of models under this subchapter or subchapters XI, XIX, or XXI.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb99d556c-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title XVIII, § 1868, as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/tIV/s4112"},"text":"Pub. L. 101–508, title IV, § 4112","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-64"},"text":"104 Stat. 1388–64","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/173/tIX/s942/a"},"text":"Pub. L. 108–173, title IX, § 942(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-08"},"text":"Dec. 8, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2420"},"text":"117 Stat. 2420","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tIII/s3134/b/2"},"text":"Pub. L. 111–148, title III, § 3134(b)(2)","children":[],"tail":", 