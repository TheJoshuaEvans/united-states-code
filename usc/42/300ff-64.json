{"tag":"section","attrib":{"id":"idb6a01abb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–64"},"text":null,"children":[{"tag":"num","attrib":{"value":"300ff–64"},"text":"§ 300ff–64.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional required agreements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb6a01abc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–64/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports to Secretary","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may not make a grant under this part unless—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6a01abd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–64/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the applicant submits to the Secretary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6a01abe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–64/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a specification of the expenditures made by the applicant for early intervention services for the fiscal year preceding the fiscal year for which the applicant is applying to receive the grant;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6a01abf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–64/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an estimate of the number of individuals to whom the applicant has provided such services for such fiscal year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6a01ac0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–64/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information regarding how the expected expenditures of the grant are related to the planning process for localities funded under part A (including the planning process described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–12"},"text":"section 300ff–12 of this title","children":[],"tail":") and for States funded under part B (including the planning process described in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–27/b"},"text":"section 300ff–27(b) of this title","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6a01ac1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–64/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a specification of the expected expenditures and how those expenditures will improve overall client outcomes, as described in the State plan under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–27/b"},"text":"section 300ff–27(b) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6a01ac2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–64/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the applicant agrees to submit to the Secretary a report providing—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6a01ac3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–64/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of individuals to whom the applicant provides early intervention services pursuant to the grant;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6a01ac4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–64/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" epidemiological and demographic data on the population of such individuals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6a01ac5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–64/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which the costs of HIV-related health care for such individuals are paid by third-party payors;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6a01ac6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–64/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the average costs of providing each category of early intervention service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6a01ac7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–64/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the aggregate amounts expended for each such category;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6a01ac8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–64/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the applicant agrees to provide additional documentation to the Secretary regarding the process used to obtain community input into the design and implementation of activities related to such grant; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6a01ac9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–64/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the applicant agrees to submit, every 2 years, to the lead State agency under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–27/b/4"},"text":"section 300ff–27(b)(4) of this title","children":[],"tail":" audits, consistent with Office of Management and Budget circular A133, regarding funds expended in accordance with this subchapter and shall include necessary client level data to complete unmet need calculations and Statewide coordinated statements of need process."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6a01aca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–64/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provision of opportunities for anonymous counseling and testing","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may not make a grant under this part unless the applicant for the grant agrees that, to the extent permitted under State law, regulation or rule, the applicant will offer substantial opportunities for an individual—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6a01acb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–64/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to undergo counseling and testing regarding HIV/AIDS without being required to provide any information relating to the identity of the individual; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6a01acc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–64/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to undergo such counseling and testing through the use of a pseudonym.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6a01acd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–64/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition against requiring testing as condition of receiving other health services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may not make a grant under this part unless the applicant for the grant agrees that, with respect to an individual seeking health services from the applicant, the applicant will not require the individual to undergo testing for HIV as a condition of receiving any health services unless such testing is medically indicated in the provision of the health services sought by the individual.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6a01ace-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–64/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maintenance of support","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may not make a grant under this part unless the applicant for the grant agrees to maintain the expenditures of the applicant for early intervention services at a level equal to not less than the level of such expenditures maintained by the State for the fiscal year preceding the fiscal year for which the applicant is applying to receive the grant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6a01acf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–64/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements regarding imposition of charges for services","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6a01ad0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–64/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may not make a grant under this part unless, subject to paragraph (5), the applicant for the grant agrees that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6a01ad1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–64/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of individuals with an income less than or equal to 100 percent of the official poverty line, the applicant will not impose a charge on any such individual for the provision of early intervention services under the grant;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6a01ad2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–64/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of individuals with an income greater than 100 percent of the official poverty line, the applicant—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb6a01ad3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–64/e/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will impose a charge on each such individual for the provision of such services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6a01ad4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–64/e/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will impose the charge according to a schedule of charges that is made available to the public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6a01ad5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–64/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on charges regarding individuals subject to charges","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to the imposition of a charge for purposes of paragraph (1)(B)(ii), the Secretary may not make a grant under this part unless, subject to paragraph (5), the applicant for the grant agrees that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6a01ad6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–64/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of individuals with an income greater than 100 percent of the official poverty line and not exceeding 200 percent of such poverty line, the applicant will not, for any calendar year, impose charges in an amount exceeding 5 percent of the annual gross income of the individual involved;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6a01ad7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–64/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of individuals with an income greater than 200 percent of the official poverty line and not exceeding 300 percent of such poverty line, the applicant will not, for any calendar year, impose charges in an amount exceeding 7 percent of the annual gross income of the individual involved; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6a01ad8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–64/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of individuals with an income greater than 300 percent of the official poverty line, the applicant will not, for any calendar year, impose charges in an amount exceeding 10 percent of the annual gross income of the individual involved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6a01ad9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–64/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessment of charge","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to compliance with the agreement made under paragraph (1), a grantee under this part may, in the case of individuals subject to a charge for purposes of such paragraph—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6a01ada-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–64/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assess the amount of the charge in the discretion of the grantee, including imposing only a nominal charge for the provision of services, subject to the provisions of such paragraph regarding public schedules and of paragraph (2) regarding limitations on the maximum amount of charges; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6a01adb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–64/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take into consideration the medical expenses of individuals in assessing the amount of the charge, subject to such provisions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6a01adc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–64/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of limitation on amount of charge","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may not make a grant under this part unless the applicant for the grant agrees that the limitations established in paragraph (2) regarding the imposition of charges for services applies to the annual aggregate of charges imposed for such services, without regard to whether they are characterized as enrollment fees, premiums, deductibles, cost sharing, copayments, coinsurance, or similar charges.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6a01add-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–64/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver regarding certain secondary agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The requirement established in paragraph (1)(B)(i) shall be waived by the Secretary in the case of any entity for whom the Secretary has granted a waiver under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–52/b/2"},"text":"section 300ff–52(b)(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6a01ade-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–64/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relationship to items and services under other programs","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6a01adf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–64/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may not make a grant under this part unless the applicant for the grant agrees that, subject to paragraph (2), the grant will not be expended by the applicant, or by any entity receiving amounts from the applicant for the provision of early intervention services, to make payment for any such service to the extent that payment has been made, or can reasonably be expected to be made, with respect to such service—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6a01ae0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–64/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under any State compensation program, under an insurance policy, or under any Federal or State health benefits program (except for a program administered by or providing the services of the Indian Health Service); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6a01ae1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–64/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by an entity that provides health services on a prepaid basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6a01ae2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–64/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability to certain secondary agreements for provision of services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An agreement made under paragraph (1) shall not apply in the case of an entity through which a grantee under this part provides early intervention services if the Secretary has provided a waiver under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–52/b/2"},"text":"section 300ff–52(b)(2) of this title","children":[],"tail":" regarding the entity."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6a01ae3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–64/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration of grant","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may not make a grant under this part unless the applicant for the grant agrees that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6a01ae4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–64/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the applicant will not expend amounts received pursuant to this part for any purpose other than the purposes described in the subpart under which the grant involved is made;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6a01ae5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–64/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the applicant will establish such procedures for fiscal control and fund accounting as may be necessary to ensure proper disbursement and accounting with respect to the grant;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6a01ae6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–64/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the applicant will not expend more than 10 percent of the grant for administrative expenses with respect to the grant, including planning and evaluation, except that the costs of a clinical quality management program under paragraph (5) may not be considered administrative expenses for purposes of such limitation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6a01ae7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–64/g/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the applicant will submit evidence that the proposed program is consistent with the statewide coordinated statement of need and agree to participate in the ongoing revision of such statement of need; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6a01ae8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–64/g/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the applicant will provide for the establishment of a clinical quality management program—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6a01ae9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–64/g/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assess the extent to which medical services funded under this subchapter that are provided to patients are consistent with the most recent Public Health Service guidelines for the treatment of HIV/AIDS and related opportunistic infections, and as applicable, to develop strategies for ensuring that such services are consistent with the guidelines; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6a01aea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–64/g/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to ensure that improvements in the access to and quality of HIV health services are addressed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb6a01aeb-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XXVI, § 2664, as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/381/tIII/s301/a"},"text":"Pub. L. 101–381, title III, § 301(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-08-18"},"text":"Aug. 18, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/611"},"text":"104 Stat. 611","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/146/s3/d/5"},"text":"Pub. L. 104–146, § 3(d)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-05-20"},"text":"May 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1358"},"text":"110 Stat. 1358","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/345/tIII"},"text":"Pub. L. 106–345, title III","children":[],"tail":", §§ 301(b)(3), 322, "},{"tag":"date","attrib":{"date":"2000-10-20"},"text":"Oct. 20, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1345"},"text":"114 Stat. 1345","children":[],"tail":", 1346; "},{"tag":"ref","attrib":{"href":"/us/pl/109/415/tIII"},"text":"Pub. L. 109–415, title III","children":[],"tail":", §§ 301(b), 306(b), (c), title VII, §§ 702(3), 703, "},{"tag":"date","attrib":{"date":"2006-12-19"},"text":"Dec. 19, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2806"},"text":"120 Stat. 2806","children":[],"tail":", 2809, 2820; "},{"tag":"ref","attrib":{"href":"/us/pl/111/87/s2/a/1"},"text":"Pub. L. 111–87, § 2(a)(1)","children":[],"tail":", (3)(A), "},{"tag":"date","attrib":{"date":"2009-10-30"},"text":"Oct. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2885"},"text":"123 Stat. 2885","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb6a01aec-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb6a01aed-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb6a01aee-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2009—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/87"},"text":"Pub. L. 111–87","children":[],"tail":" repealed "},{"tag":"ref","attrib":{"href":"/us/pl/109/415/s703"},"text":"Pub. L. 109–415, § 703","children":[],"tail":", and revived the provisions of this section as in effect on "},{"tag":"date","attrib":{"date":"2009-09-30"},"text":"Sept. 30, 2009","children":[],"tail":". See 2006 Amendment note and Effective Date of 2009 Amendment; Revival of Section note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/415/s703"},"text":"Pub. L. 109–415, § 703","children":[],"tail":", which directed repeal of this section effective "},{"tag":"date","attrib":{"date":"2009-10-01"},"text":"Oct. 1, 2009","children":[],"tail":", was itself repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/111/87/s2/a/1"},"text":"Pub. L. 111–87, § 2(a)(1)","children":[],"tail":", effective "},{"tag":"date","attrib":{"date":"2009-09-30"},"text":"Sept. 30, 2009","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(C), (D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/415/s306/b/1"},"text":"Pub. L. 109–415, § 306(b)(1)","children":[],"tail":", added subpars. (C) and (D)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3), (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/415/s306/b/2"},"text":"Pub. L. 109–415, § 306(b)(2)","children":[],"tail":", (3), added pars. (3) and (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/415/s702/3"},"text":"Pub. L. 109–415, § 702(3)","children":[],"tail":", substituted “HIV/AIDS” for “HIV disease”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/415/s306/c"},"text":"Pub. L. 109–415, § 306(c)","children":[],"tail":", inserted “(except for a program administered by or providing the services of the Indian Health Service)” before semicolon."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/415/s301/b/1"},"text":"Pub. L. 109–415, § 301(b)(1)","children":[],"tail":", amended par. (3) generally. Prior to amendment, par. (3) read as follows: “the applicant will not expend more than 10 percent including planning and evaluation of the grant for administrative expenses with respect to the grant;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/415/s301/b/2"},"text":"Pub. L. 109–415, § 301(b)(2)","children":[],"tail":", inserted “clinical” before “quality management” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g)(5)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/415/s702/3"},"text":"Pub. L. 109–415, § 702(3)","children":[],"tail":", substituted “HIV/AIDS” for “HIV disease”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsecs. (e)(5), (f)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/345/s301/b/3/A"},"text":"Pub. L. 106–345, § 301(b)(3)(A)","children":[],"tail":", (B), struck out “300ff–42(b) or” after “a waiver under section”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/345/s322/1/A"},"text":"Pub. L. 106–345, § 322(1)(A)","children":[],"tail":", substituted “10 percent” for “7.5 percent”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/345/s322/1/B"},"text":"Pub. L. 106–345, § 322(1)(B)","children":[],"tail":", (2), (3), added par. (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/345/s301/b/3/C"},"text":"Pub. L. 106–345, § 301(b)(3)(C)","children":[],"tail":", struck out heading and text of subsec. (h). Text read as follows: “A State may not use amounts received under a grant awarded under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–41"},"text":"section 300ff–41 of this title","children":[],"tail":" to purchase or improve land, or to purchase, construct, or permanently improve (other than minor remodeling) any building or other facility, or to make cash payments to intended recipients of services.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (g)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/146/s3/d/5/B/i"},"text":"Pub. L. 104–146, § 3(d)(5)(B)(i)","children":[],"tail":", substituted “7.5 percent including planning and evaluation” for “5 percent”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/146/s3/d/5/A"},"text":"Pub. L. 104–146, § 3(d)(5)(A)","children":[],"tail":", (B)(ii), (C), added par. (4)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb6a01aef-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb6a01af0-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2009 Amendment; Revival of Section","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions that repeal by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/87/s2/a/1"},"text":"section 2(a)(1) of Pub. L. 111–87","children":[],"tail":" of "},{"tag":"ref","attrib":{"href":"/us/pl/109/415/s703"},"text":"section 703 of Pub. L. 109–415","children":[],"tail":" be effective "},{"tag":"date","attrib":{"date":"2009-09-30"},"text":"Sept. 30, 2009","children":[],"tail":", and that the provisions of this section as in effect on "},{"tag":"date","attrib":{"date":"2009-09-30"},"text":"Sept. 30, 2009","children":[],"tail":", be revived, see section 2(a)(2), (3)(A) of "},{"tag":"ref","attrib":{"href":"/us/pl/111/87"},"text":"Pub. L. 111–87","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–11"},"text":"section 300ff–11 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb6a01af1-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/146"},"text":"Pub. L. 104–146","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1996-10-01"},"text":"Oct. 1, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/146/s13"},"text":"section 13 of Pub. L. 104–146","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–11"},"text":"section 300ff–11 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
