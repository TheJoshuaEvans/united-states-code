{"tag":"section","attrib":{"id":"idb5b8c852-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290cc–31"},"text":null,"children":[{"tag":"num","attrib":{"value":"290cc–31"},"text":"§ 290cc–31.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to comply with agreements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5b8c853-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290cc–31/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repayment of payments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5b8c854-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290cc–31/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may, subject to subsection (c), require a State to repay any payments received by the State under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s290cc–21"},"text":"section 290cc–21 of this title","children":[],"tail":" that the Secretary determines were not expended by the State in accordance with the agreements required to be contained in the application submitted by the State pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s290cc–29"},"text":"section 290cc–29 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5b8c855-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290cc–31/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If a State fails to make a repayment required in paragraph (1), the Secretary may offset the amount of the repayment against the amount of any payment due to be paid to the State under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s290cc–21"},"text":"section 290cc–21 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5b8c856-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290cc–31/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Withholding of payments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5b8c857-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290cc–31/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may, subject to subsection (c), withhold payments due under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s290cc–21"},"text":"section 290cc–21 of this title","children":[],"tail":" if the Secretary determines that the State involved is not expending amounts received under such section in accordance with the agreements required to be contained in the application submitted by the State pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s290cc–29"},"text":"section 290cc–29 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5b8c858-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290cc–31/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall cease withholding payments from a State under paragraph (1) if the Secretary determines that there are reasonable assurances that the State will expend amounts received under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s290cc–21"},"text":"section 290cc–21 of this title","children":[],"tail":" in accordance with the agreements referred to in such paragraph."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5b8c859-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290cc–31/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may not withhold funds under paragraph (1) from a State for a minor failure to comply with the agreements referred to in such paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5b8c85a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290cc–31/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Opportunity for hearing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Before requiring repayment of payments under subsection (a)(1), or withholding payments under subsection (b)(1), the Secretary shall provide to the State an opportunity for a hearing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5b8c85b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290cc–31/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of this part, a State receiving payments under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s290cc–21"},"text":"section 290cc–21 of this title","children":[],"tail":" may not, with respect to any agreements required to be contained in the application submitted under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s290cc–29"},"text":"section 290cc–29 of this title","children":[],"tail":", be considered to be in violation of any such agreements by reason of the fact that the State, in the regular course of providing services under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s290cc–22/b"},"text":"section 290cc–22(b) of this title","children":[],"tail":" to eligible homeless individuals, incidentally provides services to homeless individuals who are not eligible homeless individuals."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5b8c85c-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title V, § 531, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/77/tVI/s611/3"},"text":"Pub. L. 100–77, title VI, § 611(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-07-22"},"text":"July 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/521"},"text":"101 Stat. 521","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/645/tV/s511"},"text":"Pub. L. 101–645, title V, § 511","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4731"},"text":"104 Stat. 4731","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb5b8c85d-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb5b8c85e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb5b8c85f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1990—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/645"},"text":"Pub. L. 101–645","children":[],"tail":" amended section generally, substituting provisions relating to failure to comply with agreements for provision relating to technical assistance."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
