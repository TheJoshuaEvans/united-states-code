{"tag":"section","attrib":{"id":"idbddf1dcf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6954"},"text":null,"children":[{"tag":"num","attrib":{"value":"6954"},"text":"§ 6954.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technology promotion","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of Commerce is authorized to evaluate the commercial feasibility of resource recovery facilities and to publish the results of such evaluation, and to develop a data base for purposes of assisting persons in choosing such a system.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbddf1dd0-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/272/tII/s5004"},"text":"Pub. L. 89–272, title II, § 5004","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/94/580/s2"},"text":"Pub. L. 94–580, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2821"},"text":"90 Stat. 2821","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
