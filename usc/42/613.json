tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1996-08-22"},"text":"Aug. 22, 1996","children":[],"tail":", with transition rules relating to State options to accelerate such date, rules relating to claims, actions, and proceedings commenced before such date, rules relating to closing out of accounts for terminated or substantially modified programs and continuance in office of Assistant Secretary for Family Support, and provisions relating to termination of entitlement under AFDC program, see "},{"tag":"ref","attrib":{"href":"/us/pl/104/193/s116"},"text":"section 116 of Pub. L. 104–193","children":[],"tail":", as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s601"},"text":"section 601 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb79577d7-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Funding of Research, Evaluations, and National Studies","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/235/dG/tII/s228/c"},"text":"Pub. L. 113–235, div. G, title II, § 228(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-16"},"text":"Dec. 16, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2491"},"text":"128 Stat. 2491","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/113/235/dG/tII/s228/c"},"text":"“In the case of research, evaluations, and national studies funded under section 413(h)(1) of the Social Security Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s613/h/1"},"text":"42 U.S.C. 613(h)(1)","children":[],"tail":"], no funds shall be appropriated under that section for fiscal year 2015 or any fiscal year thereafter.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb79577d8-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Coordination of Substance Abuse and Child Protection Services","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/89/tIV/s405"},"text":"Pub. L. 105–89, title IV, § 405","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-19"},"text":"Nov. 19, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2135"},"text":"111 Stat. 2135","children":[],"tail":", required the Secretary of Health and Human Services, based on information from the Substance Abuse and Mental Health Services Administration and the Administration for Children and Families in the Department of Health and Human Services, to submit to the appropriate committees of Congress a report which described the extent and scope of the problem of substance abuse in the child welfare population, the types of services provided to such population, and the outcomes resulting from the provision of such services to such population, along with appropriate recommendations for legislative changes."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb79577d9-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"GAO Study of Effect of Family Violence on Need for Public Assistance","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/33/tV/s5001/i"},"text":"Pub. L. 105–33, title V, § 5001(i)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/593"},"text":"111 Stat. 593","children":[],"tail":", directed the Comptroller General to conduct a study of the effect of family violence on the use of public assistance programs, and in particular the extent to which family violence prolongs or increases the need for public assistance, and to submit a report to the appropriate committees of Congress within 1 year after "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb79577da-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Study on Alternative Outcomes Measures","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/193/tI/s107"},"text":"Pub. L. 104–193, title I, § 107","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-22"},"text":"Aug. 22, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2164"},"text":"110 Stat. 2164","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/105/33/tV/s5511"},"text":"Pub. L. 105–33, title V, § 5511","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/619"},"text":"111 Stat. 619","children":[],"tail":", directed the Secretary, in cooperation with the States, to study and analyze outcomes measures for evaluating the success of the States in moving individuals out of the welfare system through employment as an alternative to the minimum participation rates described in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s607"},"text":"42 U.S.C. 607","children":[],"tail":", and to submit a report to the appropriate committees of Congress by "},{"tag":"date","attrib":{"date":"1998-09-30"},"text":"Sept. 30, 1998","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
