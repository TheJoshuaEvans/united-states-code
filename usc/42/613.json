ref","attrib":{"href":"/us/pl/105/33/s5509/a"},"text":"Pub. L. 105–33, § 5509(a)","children":[],"tail":", inserted “, directly or through grants, contracts, or interagency agreements,” before “shall conduct” and substituted “section 607” for “section 609”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/33/s5509/b"},"text":"Pub. L. 105–33, § 5509(b)","children":[],"tail":", amended heading and text of par. (1) generally. Prior to amendment, text read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—The Secretary shall annually rank States to which grants are made under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s603"},"text":"section 603 of this title","children":[],"tail":" based on the following ranking factors:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(i) ","children":[{"tag":"inline","attrib":{},"text":"Absolute out-of-wedlock ratios","children":[],"tail":".—The ratio represented by—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(I) the total number of out-of-wedlock births in families receiving assistance under the State program under this part in the State for the most recent fiscal year for which information is available; over","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(II) the total number of births in families receiving assistance under the State program under this part in the State for such year.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(ii) ","children":[{"tag":"inline","attrib":{},"text":"Net changes in the out-of-wedlock ratio","children":[],"tail":".—The difference between the ratio described in subparagraph (A)(i) with respect to a State for the most recent fiscal year for which such information is available and the ratio with respect to the State for the immediately preceding year.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subse