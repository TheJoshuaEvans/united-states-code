{"tag":"section","attrib":{"id":"idbaa1583e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w"},"text":null,"children":[{"tag":"num","attrib":{"value":"1396w"},"text":"§ 1396w.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Asset verification through access to information held by financial institutions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbaa1583f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbaa15840-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the provisions of this section, each State shall implement an asset verification program described in subsection (b), for purposes of determining or redetermining the eligibility of an individual for medical assistance under the State plan under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaa15841-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plan submittal","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In order to meet the requirement of paragraph (1), each State shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbaa15842-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit not later than a deadline specified by the Secretary consistent with paragraph (3), a State plan amendment under this subchapter that describes how the State intends to implement the asset verification program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaa15843-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for implementation of such program for eligibility determinations and redeterminations made on or after 6 months after the deadline established for submittal of such plan amendment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaa15844-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Phase-in","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbaa15845-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbaa15846-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w/a/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation in current asset verification demo States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall require those States specified in subparagraph (C) (to which an asset verification program has been applied before ","children":[{"tag":"date","attrib":{"date":"2008-06-30"},"text":"June 30, 2008","children":[],"tail":") to implement an asset verification program under this subsection by the end of fiscal year 2009."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbaa15847-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w/a/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation in other States","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall require other States to submit and implement an asset verification program under this subsection in such manner as is designed to result in the application of such programs, in the aggregate for all such other States, to enrollment of approximately, but not less than, the following percentage of enrollees, in the aggregate for all such other States, by the end of the fiscal year involved:","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbaa15848-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w/a/3/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 12.5 percent by the end of fiscal year 2009.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbaa15849-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w/a/3/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 25 percent by the end of fiscal year 2010.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbaa1584a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w/a/3/A/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 50 percent by the end of fiscal year 2011.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbaa1584b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w/a/3/A/ii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 75 percent by the end of fiscal year 2012.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbaa1584c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w/a/3/A/ii/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 100 percent by the end of fiscal year 2013.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbaa1584d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w/a/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation in Puerto Rico","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall require Puerto Rico to implement an asset verification program under this subsection by ","children":[{"tag":"date","attrib":{"date":"2026-01-01"},"text":"January 1, 2026","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaa1584e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consideration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In selecting States under subparagraph (A)(ii), the Secretary shall consult with the States involved and take into account the feasibility of implementing asset verification programs in each such State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaa1584f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" States specified","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The States specified in this subparagraph are California, New York, and New Jersey.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaa15850-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in subparagraph (A)(ii) shall be construed as preventing a State from requesting, and the Secretary from approving, the implementation of an asset verification program in advance of the deadline otherwise established under such subparagraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaa15851-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption of certain territories","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall only apply to the 50 States, the District of Columbia, and Puerto Rico.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbaa15852-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Asset verification program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbaa15853-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, an asset verification program means a program described in paragraph (2) under which a State—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbaa15854-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requires each applicant for, or recipient of, medical assistance under the State plan under this subchapter on the basis of being aged, blind, or disabled to provide authorization by such applicant or recipient (and any other person whose resources are required by law to be disclosed to determine the eligibility of the applicant or recipient for such assistance) for the State to obtain (subject to the cost reimbursement requirements of section 1115(a) of the Right to Financial Privacy Act ","children":[{"tag":"ref","attrib":{"idref":"fn003075"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003075"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" ["},{"tag":"ref","attrib":{"href":"/us/usc/t12/s3415"},"text":"12 U.S.C. 3415","children":[],"tail":"] but at no cost to the applicant or recipient) from any financial institution (within the meaning of section 1101(1) of such Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t12/s3401/1"},"text":"12 U.S.C. 3401(1)","children":[],"tail":"]) any financial record (within the meaning of section 1101(2) of such Act) held by the institution with respect to the applicant or recipient (and such other person, as applicable), whenever the State determines the record is needed in connection with a determination with respect to such eligibility for (or the amount or extent of) such medical assistance; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaa15855-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" uses the authorization provided under subparagraph (A) to verify the financial resources of such applicant or recipient (and such other person, as applicable), in order to determine or redetermine the eligibility of such applicant or recipient for medical assistance under the State plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaa15856-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program described","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A program described in this paragraph is a program for verifying individual assets in a manner consistent with the approach used by the Commissioner of Social Security under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1383/e/1/B/ii"},"text":"section 1383(e)(1)(B)(ii) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbaa15857-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration of authorization","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding section 1104(a)(1) of the Right to Financial Privacy Act ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" ["},{"tag":"ref","attrib":{"href":"/us/usc/t12/s3404/a/1"},"text":"12 U.S.C. 3404(a)(1)","children":[],"tail":"], an authorization provided to a State under subsection (b)(1) shall remain effective until the earliest of—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbaa15858-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the rendering of a final adverse decision on the applicant’s application for medical assistance under the State’s plan under this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaa15859-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cessation of the recipient’s eligibility for such medical assistance; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaa1585a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the express revocation by the applicant or recipient (or such other person described in subsection (b)(1), as applicable) of the authorization, in a written notification to the State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbaa1585b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of Right to Financial Privacy Act requirements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbaa1585c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An authorization obtained by the State under subsection (b)(1) shall be considered to meet the requirements of the Right to Financial Privacy Act ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" for purposes of section 1103(a) of such Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t12/s3403/a"},"text":"12 U.S.C. 3403(a)","children":[],"tail":"], and need not be furnished to the financial institution, notwithstanding section 1104(a) of such Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t12/s3404/a"},"text":"12 U.S.C. 3404(a)","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaa1585d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The certification requirements of section 1103(b) of the Right to Financial Privacy Act ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" ["},{"tag":"ref","attrib":{"href":"/us/usc/t12/s3403/b"},"text":"12 U.S.C. 3403(b)","children":[],"tail":"] shall not apply to requests by the State pursuant to an authorization provided under subsection (b)(1)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaa1585e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A request by the State pursuant to an authorization provided under subsection (b)(1) is deemed to meet the requirements of section 1104(a)(3) of the Right to Financial Privacy Act ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" ["},{"tag":"ref","attrib":{"href":"/us/usc/t12/s3404/a/3"},"text":"12 U.S.C. 3404(a)(3)","children":[],"tail":"] and of section 1102 of such Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t12/s3402"},"text":"12 U.S.C. 3402","children":[],"tail":"], relating to a reasonable description of financial records."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbaa1585f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required disclosure","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The State shall inform any person who provides authorization pursuant to subsection (b)(1)(A) of the duration and scope of the authorization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbaa15860-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Refusal or revocation of authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If an applicant for, or recipient of, medical assistance under the State plan under this subchapter (or such other person described in subsection (b)(1), as applicable) refuses to provide, or revokes, any authorization made by the applicant or recipient (or such other person, as applicable) under subsection (b)(1)(A) for the State to obtain from any financial institution any financial record, the State may, on that basis, determine that the applicant or recipient is ineligible for medical assistance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbaa15861-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of contractor","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of implementing an asset verification program under this section, a State may select and enter into a contract with a public or private entity meeting such criteria and qualifications as the State determines appropriate, consistent with requirements in regulations relating to general contracting provisions and with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1396b/i/2"},"text":"section 1396b(i)(2) of this title","children":[],"tail":". In carrying out activities under such contract, such an entity shall be subject to the same requirements and limitations on use and disclosure of information as would apply if the State were to carry out such activities directly."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbaa15862-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide States with technical assistance to aid in implementation of an asset verification program under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbaa15863-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State implementing an asset verification program under this section shall furnish to the Secretary such reports concerning the program, at such times, in such format, and containing such information as the Secretary determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbaa15864-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of program expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, reasonable expenses of States in carrying out the program under this section shall be treated, for purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1396b/a"},"text":"section 1396b(a) of this title","children":[],"tail":", in the same manner as State expenditures specified in paragraph (7) of such section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbaa15865-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reduction in FMAP after 2020 for non-compliant States","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbaa15866-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w/k/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to a calendar quarter, the Federal medical assistance percentage otherwise determined under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1396d/b"},"text":"section 1396d(b) of this title","children":[],"tail":" for—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbaa15867-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w/k/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a non-compliant State that is one of the 50 States or the District of Columbia shall be reduced—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbaa15868-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w/k/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for calendar quarters in 2021 and 2022, by 0.12 percentage points;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbaa15869-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w/k/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for calendar quarters in 2023, by 0.25 percentage points;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbaa1586a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w/k/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for calendar quarters in 2024, by 0.35 percentage points; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbaa1586b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w/k/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for calendar quarters in 2025 and each year thereafter, by 0.5 percentage points; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaa1586c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w/k/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a non-compliant State that is Puerto Rico shall be reduced—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbaa1586d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w/k/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for calendar quarters in fiscal year 2026 beginning on or after ","children":[{"tag":"date","attrib":{"date":"2026-01-01"},"text":"January 1, 2026","children":[],"tail":", by 0.12 percentage points;"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbaa1586e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w/k/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for calendar quarters in fiscal year 2027, by 0.25 percentage points;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbaa1586f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w/k/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for calendar quarters in fiscal year 2028, by 0.35 percentage points; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbaa15870-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w/k/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for calendar quarters in fiscal year 2029 and each fiscal year thereafter, by 0.5 percentage points.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaa15871-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w/k/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-compliant State defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection, the term “non-compliant State” means a State—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbaa15872-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w/k/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is one of the 50 States, the District of Columbia, or Puerto Rico;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaa15873-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w/k/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to which the Secretary has not approved a State plan amendment submitted under subsection (a)(2); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaa15874-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w/k/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is not operating, on an ongoing basis, an asset verification program in accordance with this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbaa15875-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title XIX, § 1940, as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/252/tVII/s7001/d/1"},"text":"Pub. L. 110–252, title VII, § 7001(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-06-30"},"text":"June 30, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2391"},"text":"122 Stat. 2391","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/3/s4"},"text":"Pub. L. 116–3, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-01-24"},"text":"Jan. 24, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/7"},"text":"133 Stat. 7","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dFF/tV/s5101/c"},"text":"Pub. L. 117–328, div. FF, title V, § 5101(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5935"},"text":"136 Stat. 5935","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbaa15876-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbaa15877-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbaa15878-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Right to Financial Privacy Act, referred to in subsecs. (b) to (d), probably means the Right to Financial Privacy Act of 1978, title XI of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/630"},"text":"Pub. L. 95–630","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-10"},"text":"Nov. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3697"},"text":"92 Stat. 3697","children":[],"tail":", which is classified generally to chapter 35 (§ 3401 et seq.) of Title 12, Banks and Banking. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s3401"},"text":"section 3401 of Title 12","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbaa15879-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (a)(3)(A)(iii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s5101/c/1/A"},"text":"Pub. L. 117–328, § 5101(c)(1)(A)","children":[],"tail":", added cl. (iii)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s5101/c/1/B"},"text":"Pub. L. 117–328, § 5101(c)(1)(B)","children":[],"tail":", substituted “Exemption of certain territories” for “Exemption of territories” in heading and “, the District of Columbia, and Puerto Rico” for “and the District of Columbia” in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (k)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s5101/c/2/A"},"text":"Pub. L. 117–328, § 5101(c)(2)(A)","children":[],"tail":", in introductory provisions, struck out “beginning on or after "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"January 1, 2021","children":[],"tail":"” after “With respect to a calendar quarter”; substituted “for—” and subpar. (A) for “for a non-compliant State shall be reduced—”; redesignated former subpars. (A) to (D) as cls. (i) to (iv), respectively, of subpar. (A) and realigned margins; and added subpar. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (k)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s5101/c/2/B"},"text":"Pub. L. 117–328, § 5101(c)(2)(B)","children":[],"tail":", substituted “, the District of Columbia, or Puerto Rico” for “or the District of Columbia”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2019—Subsec. (k). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/3"},"text":"Pub. L. 116–3","children":[],"tail":" added subsec. (k)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
