{"tag":"section","attrib":{"id":"idbf5569d3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11702"},"text":null,"children":[{"tag":"num","attrib":{"value":"11702"},"text":"§ 11702.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Declaration of policy","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf5569d4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11702/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Congress hereby declares that it is the policy of the United States in fulfillment of its special responsibilities and legal obligations to the indigenous people of Hawaii resulting from the unique and historical relationship between the United States and the Government of the indigenous people of Hawaii—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf5569d5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11702/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to raise the health status of Native Hawaiians to the highest possible health level; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf5569d6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11702/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide existing Native Hawaiian health care programs with all resources necessary to effectuate this policy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf5569d7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11702/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Intent of Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is the intent of the Congress that the Nation meet the following health objectives with respect to Native Hawaiians by the year 2000:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf5569d8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11702/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Reduce coronary heart disease deaths to no more than 100 per 100,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf5569d9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11702/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Reduce stroke deaths to no more than 20 per 100,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf5569da-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11702/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Increase control of high blood pressure to at least 50 percent of people with high blood pressure.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf5569db-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11702/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Reduce blood cholesterol to an average of no more than 200 mg/dl.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf5569dc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11702/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Slow the rise in lung cancer deaths to achieve a rate of no more than 42 per 100,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf5569dd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11702/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Reduce breast cancer deaths to no more than 20.6 per 100,000 women.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf5569de-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11702/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Increase Pap tests every 1 to 3 years to at least 85 percent of women age 18 and older.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf5569df-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11702/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Increase fecal occult blood testing every 1 to 2 years to at least 50 percent of people age 50 and older.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf5569e0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11702/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Reduce diabetes-related deaths to no more than 34 per 100,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf5569e1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11702/b/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Reduce the most severe complications of diabetes as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf5569e2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11702/b/10/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" end-stage renal disease to no more than 1.4 in 1,000;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf5569e3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11702/b/10/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" blindness to no more than 1.4 in 1,000;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf5569e4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11702/b/10/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" lower extremity amputation to no more than 4.9 in 1,000;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf5569e5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11702/b/10/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" perinatal mortality to no more than 2 percent; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf5569e6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11702/b/10/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" major congenital malformations to no more than 4 percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf5569e7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11702/b/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Reduce infant mortality to no more than 7 deaths per 1,000 live births.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf5569e8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11702/b/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Reduce low birth weight to no more than 5 percent of live births.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf5569e9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11702/b/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Increase first trimester prenatal care to at least 90 percent of live births.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf5569ea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11702/b/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Reduce teenage pregnancies to no more than 50 per 1,000 girls age 17 and younger.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf5569eb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11702/b/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Reduce unintended pregnancies to no more than 30 percent of pregnancies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf5569ec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11702/b/16"},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"(16)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Increase to at least 60 percent the proportion of primary care providers who provide age-appropriate preconception care and counseling.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf5569ed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11702/b/17"},"text":null,"children":[{"tag":"num","attrib":{"value":"17"},"text":"(17)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Increase years of healthy life to at least 65 years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf5569ee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11702/b/18"},"text":null,"children":[{"tag":"num","attrib":{"value":"18"},"text":"(18)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Eliminate financial barriers to clinical preventive services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf5569ef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11702/b/19"},"text":null,"children":[{"tag":"num","attrib":{"value":"19"},"text":"(19)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Increase childhood immunization levels to at least 90 percent of 2-year-olds.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf5569f0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11702/b/20"},"text":null,"children":[{"tag":"num","attrib":{"value":"20"},"text":"(20)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Reduce the prevalence of dental caries to no more than 35 percent of children by age 8.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf5569f1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11702/b/21"},"text":null,"children":[{"tag":"num","attrib":{"value":"21"},"text":"(21)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Reduce untreated dental caries so that the proportion of children with untreated caries (in permanent or primary teeth) is no more than 20 percent among children age 6 through 8 and no more than 15 percent among adolescents age 15.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf5569f2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11702/b/22"},"text":null,"children":[{"tag":"num","attrib":{"value":"22"},"text":"(22)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Reduce edentulism to no more than 20 percent in people age 65 and older.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf5569f3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11702/b/23"},"text":null,"children":[{"tag":"num","attrib":{"value":"23"},"text":"(23)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Increase moderate daily physical activity to at least 30 percent of the population.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf5569f4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11702/b/24"},"text":null,"children":[{"tag":"num","attrib":{"value":"24"},"text":"(24)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Reduce sedentary lifestyles to no more than 15 percent of the population.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf5569f5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11702/b/25"},"text":null,"children":[{"tag":"num","attrib":{"value":"25"},"text":"(25)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Reduce overweight to a prevalence of no more than 20 percent of the population.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf5569f6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11702/b/26"},"text":null,"children":[{"tag":"num","attrib":{"value":"26"},"text":"(26)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Reduce dietary fat intake to an average of 30 percent of calories or less.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf5569f7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11702/b/27"},"text":null,"children":[{"tag":"num","attrib":{"value":"27"},"text":"(27)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Increase to at least 75 percent the proportion of primary care providers who provide nutrition assessment and counseling or referral to qualified nutritionists or dieticians.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf5569f8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11702/b/28"},"text":null,"children":[{"tag":"num","attrib":{"value":"28"},"text":"(28)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Reduce cigarette smoking prevalence to no more than 15 percent of adults.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf5569f9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11702/b/29"},"text":null,"children":[{"tag":"num","attrib":{"value":"29"},"text":"(29)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Reduce initiation of smoking to no more than 15 percent by age 20.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf5569fa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11702/b/30"},"text":null,"children":[{"tag":"num","attrib":{"value":"30"},"text":"(30)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Reduce alcohol-related motor vehicle crash deaths to no more than 8.5 per 100,000 adjusted for age.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf5569fb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11702/b/31"},"text":null,"children":[{"tag":"num","attrib":{"value":"31"},"text":"(31)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Reduce alcohol use by school children age 12 to 17 to less than 13 percent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf5569fc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11702/b/32"},"text":null,"c