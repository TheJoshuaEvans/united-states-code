{"tag":"section","attrib":{"id":"idbf17772e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10174a"},"text":null,"children":[{"tag":"num","attrib":{"value":"10174a"},"text":"§ 10174a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf17772f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10174a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Within one year of ","children":[{"tag":"date","attrib":{"date":"1987-12-22"},"text":"December 22, 1987","children":[],"tail":", the Secretary shall report to Congress on the potential impacts of locating a repository at the Yucca Mountain site, including the recommendations of the Secretary for mitigation of such impacts and a statement of which impacts should be dealt with by the Federal Government, which should be dealt with by the State with State resources, including the benefits payments under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s10173a"},"text":"section 10173a of this title","children":[],"tail":", and which should be a joint Federal-State responsibility. The report under this subsection shall include the analysis of the Secretary of the authorities available to mitigate these impacts and the appropriate sources of funds for such mitigation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf177730-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10174a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Impacts to be considered","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Potential impacts to be addressed in the report under this ","children":[{"tag":"ref","attrib":{"idref":"fn003948"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003948"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The word “this” probably should not appear."}],"tail":" subsection (a) shall include impacts on—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf177731-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10174a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" education, including facilities and personnel for elementary and secondary schools, community colleges, vocational and technical schools and universities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf177732-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10174a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" public health, including the facilities and personnel for treatment and distribution of water, the treatment of sewage, the control of pests and the disposal of solid waste;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf177733-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10174a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" law enforcement, including facilities and personnel for the courts, police and sheriff’s departments, district attorneys and public defenders and prisons;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf177734-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10174a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fire protection, including personnel, the construction of fire stations, and the acquisition of equipment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf177735-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10174a/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" medical care, including emergency services and hospitals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf177736-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10174a/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cultural and recreational needs, including facilities and personnel for libraries and museums and the acquisition and expansion of parks;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf177737-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10174a/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" distribution of public lands to allow for the timely expansion of existing, or creation of new, communities and the construction of necessary residential and commercial facilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf177738-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10174a/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" vocational training and employment services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf177739-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10174a/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" social services, including public assistance programs, vocational and physical rehabilitation programs, mental health services, and programs relating to the abuse of alcohol and controlled substances;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf17773a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10174a/b/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transportation, including any roads, terminals, airports, bridges, or railways associated with the facility and the repair and maintenance of roads, terminals, airports, bridges, or railways damaged as a result of the construction, operation, and closure of the facility;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf17773b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10174a/b/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" equipment and training for State and local personnel in the management of accidents involving high-level radioactive waste;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf17773c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10174a/b/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" availability of energy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf17773d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10174a/b/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" tourism and economic development, including the potential loss of revenue and future economic growth; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf17773e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10174a/b/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other needs of the State and local governments that would not have arisen but for the characterization of the site and the construction, operation, and eventual closure of the repository facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf17773f-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/425/tI/s175"},"text":"Pub. L. 97–425, title I, § 175","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/202/s101/d/tIII/s300"},"text":"Pub. L. 100–202, § 101(d) [title III, § 300]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1329-104"},"text":"101 Stat. 1329–104","children":[],"tail":", 1329–121; "},{"tag":"ref","attrib":{"href":"/us/pl/100/203/tV/s5031"},"text":"Pub. L. 100–203, title V, § 5031","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1330-240"},"text":"101 Stat. 1330–240","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf177740-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf177741-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbf177742-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/202"},"text":"Pub. L. 100–202","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/100/203"},"text":"Pub. L. 100–203","children":[],"tail":" added identical sections."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
