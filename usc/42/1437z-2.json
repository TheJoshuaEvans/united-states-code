{"tag":"section","attrib":{"id":"idbb0a2c31-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437z–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"1437z–2"},"text":"§ 1437z–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public housing mortgages and security interests","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbb0a2c32-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437z–2/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may, upon such terms and conditions as the Secretary may prescribe, authorize a public housing agency to mortgage or otherwise grant a security interest in any public housing project or other property of the public housing agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb0a2c33-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437z–2/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms and conditions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In making any authorization under subsection (a), the Secretary may consider—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb0a2c34-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437z–2/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the ability of the public housing agency to use the proceeds of the mortgage or security interest for low-income housing uses;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb0a2c35-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437z–2/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the ability of the public housing agency to make payments on the mortgage or security interest; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb0a2c36-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437z–2/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other criteria as the Secretary may specify.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb0a2c37-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437z–2/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No Federal liability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No action taken under this section shall result in any liability to the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbb0a2c38-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1937-09-01/ch896"},"text":"Sept. 1, 1937, ch. 896","children":[],"tail":", title I, § 30, as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/276/tV/s516"},"text":"Pub. L. 105–276, title V, § 516","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2550"},"text":"112 Stat. 2550","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbb0a2c39-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbb0a2c3a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbb0a2c3b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective and applicable beginning upon ","children":[{"tag":"date","attrib":{"date":"1999-10-01"},"text":"Oct. 1, 1999","children":[],"tail":", except as otherwise provided, with provision that Secretary may implement section before such date except to extent otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/105/276/s503"},"text":"section 503 of Pub. L. 105–276","children":[],"tail":", set out as an Effective Date of 1998 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1437"},"text":"section 1437 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
