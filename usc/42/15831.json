{"tag":"section","attrib":{"id":"idbfe48b4d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15831"},"text":null,"children":[{"tag":"num","attrib":{"value":"15831"},"text":"§ 15831.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public energy education program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfe48b4e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15831/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":", the Secretary shall convene an organizational conference for the purpose of establishing an ongoing, self-sustaining national public energy education program."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfe48b4f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15831/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Participants","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall invite to participate in the conference individuals and entities representing all aspects of energy production and distribution, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfe48b50-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15831/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" industrial firms;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe48b51-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15831/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" professional societies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe48b52-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15831/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" educational organizations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe48b53-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15831/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" trade associations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe48b54-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15831/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" governmental agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfe48b55-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15831/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose, scope, and structure","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfe48b56-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15831/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purpose of the conference shall be to establish an ongoing, self-sustaining national public energy education program to examine and recognize interrelationships between energy sources in all forms, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfe48b57-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15831/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conservation and energy efficiency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfe48b58-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15831/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the role of energy use in the economy; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfe48b59-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15831/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the impact of energy use on the environment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe48b5a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15831/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scope and structure","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Taking into consideration the purpose described in paragraph (1), the participants in the conference invited under subsection (b) shall design the scope and structure of the program described in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfe48b5b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15831/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide technical assistance and other guidance necessary to carry out the program described in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfe48b5c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15831/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums as are necessary to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfe48b5d-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tI/s133"},"text":"Pub. L. 109–58, title I, § 133","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/622"},"text":"119 Stat. 622","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
