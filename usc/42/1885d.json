{"tag":"section","attrib":{"id":"idbba077ff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1885d"},"text":null,"children":[{"tag":"num","attrib":{"value":"1885d"},"text":"§ 1885d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Biennial reports","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbba07800-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1885d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" By January 30 of each odd-numbered year, the Director shall simultaneously transmit a report to the Congress, the Attorney General, the Director of the Office of Science and Technology Policy, the Chairman of the Equal Employment Opportunity Commission, the Director of the Office of Personnel Management, the Secretary of Labor, the Secretary of Education, and the Secretary of Health and Human Services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbba07801-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1885d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The report required by subsection (a) shall contain—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbba07802-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1885d/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an accounting and comparison, by sex, race, and ethnic group and by discipline, of the participation of women and men in scientific and engineering positions, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbba07803-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1885d/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of individuals in permanent and temporary and in full-time and part-time scientific and engineering positions by appropriate level or similar category;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbba07804-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1885d/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the average salary of individuals in such scientific and engineering positions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbba07805-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1885d/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number and type of promotional opportunities realized by individuals in such scientific and engineering positions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbba07806-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1885d/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of individuals serving as principal investigators in federally conducted or federally supported research and development; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbba07807-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1885d/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the unemployment rate of individuals seeking scientific and engineering positions;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbba07808-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1885d/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment, including quantitative and other data, of the proportion of women and minorities studying scientific and engineering fields, including mathematics and computer skills, at all educational levels; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbba07809-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1885d/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other data, analyses, and evaluations as the Director, acting on the advice of the Committee on Equal Opportunities in Science and Engineering, determines appropriate to carry out the Foundation’s functions as well as the policies and programs of sections 1885 to 1885d of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbba0780a-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/516/s37"},"text":"Pub. L. 96–516, § 37","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3013"},"text":"94 Stat. 3013","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/159/tI/s111/b/9"},"text":"Pub. L. 99–159, title I, § 111(b)(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-11-22"},"text":"Nov. 22, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/893"},"text":"99 Stat. 893","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/360/tII/s208"},"text":"Pub. L. 108–360, title II, § 208","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-25"},"text":"Oct. 25, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1679"},"text":"118 Stat. 1679","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbba0780b-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbba0780c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbba0780d-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Sections 1885 to 1885d of this title, referred to in subsec. (b)(3), was in the original “this Act”, meaning sections 31 et seq. of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/516"},"text":"Pub. L. 96–516","children":[],"tail":", known as the Science and Engineering Equal Opportunities Act, which enacted sections 1885 to 1885d of this title and provisions set out as notes under sections 1861 and 1885 of this title. For complete classification of this Act to the Code, see Short Title of 1980 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1861"},"text":"section 1861 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbba0780e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Science and Engineering Equal Opportunities Act, and not as part of the National Science Foundation Act of 1950 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbba0780f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/360"},"text":"Pub. L. 108–360","children":[],"tail":" substituted “By January 30 of each odd-numbered year” for “By "},{"tag":"date","attrib":{"date":"1982-01-30"},"text":"January 30, 1982","children":[],"tail":", and biennially thereafter”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1985—Subsec. (b)(1), (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/159/s111/b/9/A"},"text":"Pub. L. 99–159, § 111(b)(9)(A)","children":[],"tail":", substituted “engineering” for “technical” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/159/s111/b/9/B"},"text":"Pub. L. 99–159, § 111(b)(9)(B)","children":[],"tail":", substituted “Engineering” for “Technology”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
