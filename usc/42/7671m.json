{"tag":"section","attrib":{"id":"idbe6bcd51-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7671m"},"text":null,"children":[{"tag":"num","attrib":{"value":"7671m"},"text":"§ 7671m.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relationship to other laws","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbe6bcd52-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7671m/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7416"},"text":"section 7416 of this title","children":[],"tail":", during the 2-year period beginning on "},{"tag":"date","attrib":{"date":"1990-11-15"},"text":"November 15, 1990","children":[],"tail":", no State or local government may enforce any requirement concerning the design of any new or recalled appliance for the purpose of protecting the stratospheric ozone layer."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe6bcd53-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7671m/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Montreal Protocol","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This subchapter as added by the Clean Air Act Amendments of 1990 shall be construed, interpreted, and applied as a supplement to the terms and conditions of the Montreal Protocol, as provided in Article 2, paragraph 11 thereof, and shall not be construed, interpreted, or applied to abrogate the responsibilities or obligations of the United States to implement fully the provisions of the Montreal Protocol. In the case of conflict between any provision of this subchapter and any provision of the Montreal Protocol, the more stringent provision shall govern. Nothing in this subchapter shall be construed, interpreted, or applied to affect the authority or responsibility of the Administrator to implement Article 4 of the Montreal Protocol with other appropriate agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe6bcd54-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7671m/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technology export and overseas investment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Upon ","children":[{"tag":"date","attrib":{"date":"1990-11-15"},"text":"November 15, 1990","children":[],"tail":", the President shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe6bcd55-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7671m/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prohibit the export of technologies used to produce a class I substance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe6bcd56-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7671m/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prohibit direct or indirect investments by any person in facilities designed to produce a class I or class II substance in nations that are not parties to the Montreal Protocol; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe6bcd57-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7671m/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" direct that no agency of the government provide bilateral or multilateral subsidies, aids, credits, guarantees, or insurance programs, for the purpose of producing any class I substance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbe6bcd58-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1955-07-14/ch360"},"text":"July 14, 1955, ch. 360","children":[],"tail":", title VI, § 614, as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/549/tVI/s602/a"},"text":"Pub. L. 101–549, title VI, § 602(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-15"},"text":"Nov. 15, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2668"},"text":"104 Stat. 2668","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbe6bcd59-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbe6bcd5a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbe6bcd5b-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Clean Air Act Amendments of 1990, referred to in subsec. (b), probably means ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/549"},"text":"Pub. L. 101–549","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-15"},"text":"Nov. 15, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2399"},"text":"104 Stat. 2399","children":[],"tail":". For complete classification of this Act to the Code, see Short Title of 1990 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s7401"},"text":"section 7401 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
