{"tag":"section","attrib":{"id":"idbe564991-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7605"},"text":null,"children":[{"tag":"num","attrib":{"value":"7605"},"text":"§ 7605.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Representation in litigation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbe564992-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7605/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Attorney General; attorneys appointed by Administrator","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall request the Attorney General to appear and represent him in any civil action instituted under this chapter to which the Administrator is a party. Unless the Attorney General notifies the Administrator that he will appear in such action, within a reasonable time, attorneys appointed by the Administrator shall appear and represent him.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe564993-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7605/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Memorandum of understanding regarding legal representation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the event the Attorney General agrees to appear and represent the Administrator in any such action, such representation shall be conducted in accordance with, and shall include participation by, attorneys appointed by the Administrator to the extent authorized by, the memorandum of understanding between the Department of Justice and the Environmental Protection Agency, dated ","children":[{"tag":"date","attrib":{"date":"1977-06-13"},"text":"June 13, 1977","children":[],"tail":", respecting representation of the agency by the department in civil litigation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbe564994-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1955-07-14/ch360"},"text":"July 14, 1955, ch. 360","children":[],"tail":", title III, § 305, as added "},{"tag":"ref","attrib":{"href":"/us/pl/91/604/s12/a"},"text":"Pub. L. 91–604, § 12(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-31"},"text":"Dec. 31, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1707"},"text":"84 Stat. 1707","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/95/95/tIII/s304/a"},"text":"Pub. L. 95–95, title III, § 304(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-08-07"},"text":"Aug. 7, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/772"},"text":"91 Stat. 772","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbe564995-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbe564996-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbe564997-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1857h–3"},"text":"section 1857h–3 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbe564998-3a70-11f1-ae07-e4213316b5fa"}