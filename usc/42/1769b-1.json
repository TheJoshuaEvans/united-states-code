{"tag":"section","attrib":{"id":"idbb674049-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769b–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1769b–1"},"text":"§ 1769b–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training, technical assistance, and food service management institute","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbb67404a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769b–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General authority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb67404b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769b–1/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" subject to the availability of, and from, amounts appropriated pursuant to subsection (e)(1), shall conduct training activities and provide—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbb67404c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769b–1/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" training and technical assistance to improve the skills of individuals employed in—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbb67404d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769b–1/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" food service programs carried out with assistance under this chapter and, to the maximum extent practicable, using individuals who administer exemplary local food service programs in the State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbb67404e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769b–1/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" school breakfast programs carried out with assistance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1773"},"text":"section 1773 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbb67404f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769b–1/a/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as appropriate, other federally assisted feeding programs; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb674050-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769b–1/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" assistance, on a competitive basis, to State agencies for the purpose of aiding schools and school food authorities with at least 50 percent of enrolled children certified to receive free or reduced price meals (and, if there are any remaining funds, other schools and school food authorities) in meeting the cost of acquiring or upgrading technology and information management systems for use in food service programs carried out under this chapter and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1773"},"text":"section 1773 of this title","children":[],"tail":", if the school or school food authority submits to the State agency an infrastructure development plan that—"}],"tail":null},{"tag":"clause","attrib":{"id":"idbb674051-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769b–1/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" addresses the cost savings and improvements in program integrity and operations that would result from the use of new or upgraded technology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbb674052-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769b–1/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensures that there is not any overt identification of any child by special tokens or tickets, announced or published list of names, or by any other means;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbb674053-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769b–1/a/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides for processing and verifying applications for free and reduced price school meals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbb674054-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769b–1/a/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" integrates menu planning, production, and serving data to monitor compliance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1758/f/1"},"text":"section 1758(f)(1) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbb674055-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769b–1/a/1/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishes compatibility with statewide reporting systems;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb674056-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769b–1/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" assistance, on a competitive basis, to State agencies with low proportions of schools or students that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbb674057-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769b–1/a/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" participate in the school breakfast program under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1773"},"text":"section 1773 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbb674058-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769b–1/a/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrate the greatest need, for the purpose of aiding schools in meeting costs associated with initiating or expanding a school breakfast program under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1773"},"text":"section 1773 of this title","children":[],"tail":", including outreach and informational activities; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb674059-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769b–1/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" from amounts appropriated pursuant to subsection (e)(2), is authorized to provide financial and other assistance to the University of Mississippi, in cooperation with the University of Southern Mississippi, to establish and maintain a food service management institute.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb67405a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769b–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The activities conducted and assistance provided as required by subsection (a)(1) shall at least include activities and assistance with respect to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb67405b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769b–1/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" menu planning;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb67405c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769b–1/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" implementation of regulations and appropriate guidelines; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb67405d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769b–1/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compliance with program requirements and accountability for program operations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb67405e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769b–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties of food service management institute","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb67405f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769b–1/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any food service management institute established as authorized by subsection (a)(2) shall carry out activities to improve the general operation and quality of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbb674060-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769b–1/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" food service programs assisted under this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb674061-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769b–1/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" school breakfast programs assisted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1773"},"text":"section 1773 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb674062-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769b–1/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as appropriate, other federally assisted feeding programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb674063-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769b–1/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Activities carried out under paragraph (1) shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbb674064-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769b–1/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conducting research necessary to assist schools and other organizations that participate in such programs in providing high quality, nutritious, cost-effective meal service to the children served;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb674065-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769b–1/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" providing training and technical assistance with respect to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbb674066-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769b–1/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" efficient use of physical resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbb674067-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769b–1/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" financial management;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbb674068-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769b–1/c/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" efficient use of computers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbb674069-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769b–1/c/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" procurement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbb67406a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769b–1/c/2/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sanitation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbb67406b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769b–1/c/2/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" safety, including food handling, hazard analysis and critical control point plan implementation, emergency readiness, responding to a food recall, and food biosecurity training;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbb67406c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769b–1/c/2/B/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meal planning and related nutrition activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbb67406d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769b–1/c/2/B/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" culinary skills; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbb67406e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769b–1/c/2/B/ix"},"text":null,"children":[{"tag":"num","attrib":{"value":"ix"},"text":"(ix)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other appropriate activities;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb67406f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769b–1/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing a national network of trained professionals to present training programs and workshops for food service personnel;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb674070-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769b–1/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing training materials for use in the programs and workshops described in subparagraph (C);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb674071-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769b–1/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acting as a clearinghouse for research, studies, and findings concerning all aspects of the operation of food service programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb674072-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769b–1/c/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" training food service personnel to comply with the nutrition guidance and objectives established by the Secretary through a national network of instructors or other means;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb674073-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769b–1/c/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preparing informational materials, such as video instruction tapes and menu planners, to promote healthier food preparation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb698964-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769b–1/c/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assisting State educational agencies in providing additional nutrition and health instructions and instructors, including training personnel to comply with the nutrition guidance and objectives established by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb698965-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769b–1/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb698966-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769b–1/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall coordinate activities carried out and assistance provided as required by subsection (b) with activities carried out by any food service management institute established as authorized by subsection (a)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb698967-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769b–1/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of institute for dietary and nutrition activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall use any food service management institute established under subsection (a)(2) to assist in carrying out dietary and nutrition activities of the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb698968-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769b–1/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Food service management institute","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb698969-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769b–1/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbb69896a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769b–1/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to any amounts otherwise made available for fiscal year 2011, on ","children":[{"tag":"date","attrib":{"date":"2010-10-01"},"text":"October 1, 2010","children":[],"tail":", and each October 1 thereafter, out of any funds in the Treasury not otherwise appropriated, the Secretary of the Treasury shall transfer to the Secretary to carry out subsection (a)(2) $5,000,000, to remain available until expended."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb69896b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769b–1/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Receipt and acceptance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall be entitled to receive, shall accept, and shall use to carry out subsection (a)(2) the funds transferred under subparagraph (A), without further appropriation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb69896c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769b–1/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to amounts made available under paragraph (1), there are authorized to be appropriated to carry out subsection (a)(2) such sums as are necessary for fiscal year 1995 and each subsequent fiscal year. The Secretary shall carry out activities under subsection (a)(2), in addition to the activities funded under paragraph (1), to the extent provided for, and in such amounts as are provided for, in advance in appropriations Acts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb69896d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769b–1/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding for education, training, or applied research or studies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to amounts made available under paragraphs (1) and (2), from amounts otherwise appropriated to the Secretary in discretionary appropriations, the Secretary may provide funds to any food service management institute established under subsection (a)(2) for projects specified by the Secretary that will contribute to implementing dietary or nutrition initiatives. Any additional funding under this subparagraph shall be provided noncompetitively in a separate cooperative agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb69896e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769b–1/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative training and technical assistance material","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In collaboration with State educational agencies, local educational agencies, and school food authorities of varying sizes, the Secretary shall develop and distribute training and technical assistance material relating to the administration of school meals programs that are representative of the best management and administrative practices.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb69896f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769b–1/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal administrative support","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb698970-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769b–1/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbb698971-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769b–1/g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Out of any funds in the Treasury not otherwise appropriated, the Secretary of the Treasury shall transfer to the Secretary of Agriculture to carry out this subsection—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbb698972-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769b–1/g/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on ","children":[{"tag":"date","attrib":{"date":"2004-10-01"},"text":"October 1, 2004","children":[],"tail":", and "},{"tag":"date","attrib":{"date":"2005-10-01"},"text":"October 1, 2005","children":[],"tail":", $3,000,000;"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbb698973-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769b–1/g/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on ","children":[{"tag":"date","attrib":{"date":"2006-10-01"},"text":"October 1, 2006","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-10-01"},"text":"October 1, 2007","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-01"},"text":"October 1, 2008","children":[],"tail":", and "},{"tag":"date","attrib":{"date":"2009-10-01"},"text":"October 1, 2009","children":[],"tail":", $2,000,000; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbb698974-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769b–1/g/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on ","children":[{"tag":"date","attrib":{"date":"2010-10-01"},"text":"October 1, 2010","children":[],"tail":", and every October 1 thereafter, $4,000,000."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb698975-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769b–1/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Receipt and acceptance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall be entitled to receive, shall accept, and shall use to carry out this subsection the funds transferred under subparagraph (A), without further appropriation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb698976-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769b–1/g/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds transferred under subparagraph (A) shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb698977-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769b–1/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may use funds provided under this subsection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbb698978-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769b–1/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide training and technical assistance and material related to improving program integrity and administrative accuracy in school meals programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb698979-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769b–1/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assist State educational agencies in reviewing the administrative practices of local educational agencies, to the extent determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbb69897a-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-06-04/ch281/s21"},"text":"June 4, 1946, ch. 281, § 21","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/147/tI/s109"},"text":"Pub. L. 101–147, title I, § 109","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-10"},"text":"Nov. 10, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/887"},"text":"103 Stat. 887","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/337/s1"},"text":"Pub. L. 102–337, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-08-07"},"text":"Aug. 7, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/865"},"text":"106 Stat. 865","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/448/tI/s120"},"text":"Pub. L. 103–448, title I, § 120","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-11-02"},"text":"Nov. 2, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4726"},"text":"108 Stat. 4726","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/336/tI"},"text":"Pub. L. 105–336, title I","children":[],"tail":", §§ 103(c)(2), 110, "},{"tag":"date","attrib":{"date":"1998-10-31"},"text":"Oct. 31, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3147"}