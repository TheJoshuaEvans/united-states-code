ies for the purpose of aiding schools with at least 50 percent of enrolled children certified to receive free or reduced price meals, and to State agencies with low proportions of students that participate in the school breakfast program and demonstrate the greatest need, for provisions relating to training activities and technical assistance under this chapter, "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1773"},"text":"section 1773 of this title","children":[],"tail":", and other federally assisted programs."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(B)(vi) to (x). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/265/s125/b"},"text":"Pub. L. 108–265, § 125(b)","children":[],"tail":", added cl. (vi), struck out former cls. (vi) and (vii), which related to safety and food handling, respectively, and redesignated former cls. (viii) to (x) as (vii) to (ix), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/265/s205/b"},"text":"Pub. L. 108–265, § 205(b)","children":[],"tail":", struck out “, including activities carried out with assistance provided under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1788"},"text":"section 1788 of this title","children":[],"tail":"” before semicolon at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/265/s125/c/1"},"text":"Pub. L. 108–265, § 125(c)(1)","children":[],"tail":", substituted “2009” for “2003”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/447"},"text":"Pub. L. 108–447","children":[],"tail":" inserted “and” after “2005”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/265/s125/c/2"},"text":"Pub. L. 108–265, § 125(c)(2)","children":[],"tail":", substituted “provide to the Secretary” for “provide to the Secretary $147,000 for fiscal year 1995, $2,000,000 for each of fiscal years 1996 through 1998, and” and “2004 and $4,000,000 for fiscal year 2005” for “1999 and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (f), (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/265/s126/a"},"text":"Pub. L. 108–265, § 126(a)","children":[],"tail":", added subsecs. (f) and (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (c)(2)(F), (H). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/336/s110/a"},"text":"Pub. L. 105–336, § 110(a)","children":[],"tail":", substituted “established by the Secretary” for “of "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1769e"},"text":"section 1769e of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/336/s110/b"},"text":"Pub. L. 105–336, § 110(b)","children":[],"tail":", substituted “2003” for “1998”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/336/s110/c"},"text":"Pub. L. 105–336, § 110(c)","children":[],"tail":", substituted “$2,000,000 for each of fiscal years 1996 through 1998, and $3,000,000 for fiscal year 1999 and each subsequent fiscal year,” for “and $2,000,000 for fiscal year 1996 and each subsequent fiscal year,” in first sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/336/s103/c/2"},"text":"Pub. L. 105–336, § 103(c)(2)","children":[],"tail":", inserted “, without further appropriation” before period at end of second sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/448/s120/c/1"},"text":"Pub. L. 103–448, § 120(c)(1)","children":[],"tail":", substituted “subject to the availability of, and from, amounts” for “from amounts” in introductory provisions."}],"tail":"\n"},{"tag"