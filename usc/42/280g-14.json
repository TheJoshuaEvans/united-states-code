{"tag":"section","attrib":{"id":"idb5417561-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–14"},"text":null,"children":[{"tag":"num","attrib":{"value":"280g–14"},"text":"§ 280g–14.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National diabetes prevention program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5417562-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–14/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Director of the Centers for Disease Control and Prevention, shall establish a national diabetes prevention program (referred to in this section as the “program”) targeted at adults at high risk for diabetes in order to eliminate the preventable burden of diabetes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5417563-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–14/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The program described in subsection (a) shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5417564-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–14/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a grant program for community-based diabetes prevention program model sites;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5417565-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–14/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a program within the Centers for Disease Control and Prevention to determine eligibility of entities to deliver community-based diabetes prevention services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5417566-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–14/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a training and outreach program for lifestyle intervention instructors; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5417567-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–14/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluation, monitoring and technical assistance, and applied research carried out by the Centers for Disease Control and Prevention.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5417568-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–14/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be eligible for a grant under subsection (b)(1), an entity shall be a State or local health department, a tribal organization, a national network of community-based non-profits focused on health and wellbeing, an academic institution, or other entity, as the Secretary determines.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5417569-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–14/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of carrying out this section, there are authorized to be appropriated such sums as may be necessary for each of fiscal years 2010 through 2014.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb541756a-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title III, § 399V–3, as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tX/s10501/g"},"text":"Pub. L. 111–148, title X, § 10501(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/996"},"text":"124 Stat. 996","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
