{"tag":"section","attrib":{"id":"idbc7702cd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3196"},"text":null,"children":[{"tag":"num","attrib":{"value":"3196"},"text":"§ 3196.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Performance evaluations of grant recipients","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbc7702ce-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3196/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall conduct an evaluation of each university center and each economic development district that receives grant assistance under this chapter (each referred to in this section as a “grantee”) to assess the grantee’s performance and contribution toward retention and creation of employment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc7702cf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3196/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose of evaluations of university centers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The purpose of the evaluations of university centers under subsection (a) shall be to determine which university centers are performing well and are worthy of continued grant assistance under this chapter, and which should not receive continued assistance, so that university centers that have not previously received assistance may receive assistance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc7702d0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3196/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timing of evaluations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Evaluations under subsection (a) shall be conducted on a continuing basis so that each grantee is evaluated within 3 years after the first award of assistance to the grantee, and at least once every 3 years thereafter, so long as the grantee receives the assistance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc7702d1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3196/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation criteria","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc7702d2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3196/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish criteria for use in conducting evaluations under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc7702d3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3196/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation criteria for university centers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The criteria for evaluation of a university center shall, at a minimum, provide for an assessment of the center’s contribution to providing technical assistance, conducting applied research, program performance, and disseminating results of the activities of the center.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc7702d4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3196/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation criteria for economic development districts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The criteria for evaluation of an economic development district shall, at a minimum, provide for an assessment of management standards, financial accountability, and program performance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc7702d5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3196/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Peer review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In conducting an evaluation of a university center or economic development district under subsection (a), the Secretary shall provide for the participation of at least 1 other university center or economic development district, as appropriate, on a cost-reimbursement basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc7702d6-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/136/tV/s506"},"text":"Pub. L. 89–136, title V, § 506","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/393/tI/s102/a"},"text":"Pub. L. 105–393, title I, § 102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3611"},"text":"112 Stat. 3611","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/373/tV/s503"},"text":"Pub. L. 108–373, title V, § 503","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-27"},"text":"Oct. 27, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1769"},"text":"118 Stat. 1769","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc7702d7-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc7702d8-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbc7702d9-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 3196, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/136/tV/s517"},"text":"Pub. L. 89–136, title V, § 517","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/94/188/tII/s206"},"text":"Pub. L. 94–188, title II, § 206","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-12-31"},"text":"Dec. 31, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/1090"},"text":"89 Stat. 1090","children":[],"tail":", related to vocational and technical educational demonstration projects, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tXVIII/s1821/a/8"},"text":"Pub. L. 97–35, title XVIII, § 1821(a)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/766"},"text":"95 Stat. 766","children":[],"tail":", effective "},{"tag":"date"