{"tag":"section","attrib":{"id":"idb5f200e6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s296c"},"text":null,"children":[{"tag":"num","attrib":{"value":"296c"},"text":"§ 296c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matching requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary may require that an entity that applies for a grant or contract under this subchapter provide non-Federal matching funds, as appropriate, to ensure the institutional commitment of the entity to the projects funded under the grant. Such non-Federal matching funds may be provided directly or through donations from public or private entities and may be in cash or in-kind, fairly evaluated, including plant, equipment, or services.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb5f200e7-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title VIII, § 804, as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/392/tI/s123/4"},"text":"Pub. L. 105–392, title I, § 123(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3565"},"text":"112 Stat. 3565","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb5f200e8-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb5f200e9-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb5f200ea-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"he