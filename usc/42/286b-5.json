{"tag":"section","attrib":{"id":"idb581d97d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s286b–5"},"text":null,"children":[{"tag":"num","attrib":{"value":"286b–5"},"text":"§ 286b–5.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants for establishing, expanding, and improving basic resources of medical libraries and related instrumentalities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb581d97e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s286b–5/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall make grants of money, materials, or both, to public or private nonprofit medical libraries and related scientific communication instrumentalities for the purpose of establishing, expanding, and improving their basic medical library or related resources. A grant under this subsection may be used for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb581d97f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s286b–5/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the acquisition of books, journals, photographs, motion picture and other films, and other similar materials;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb581d980-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s286b–5/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cataloging, binding, and other services and procedures for processing library resource materials for use by those who are served by the library or related instrumentality;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb581d981-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s286b–5/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the acquisition of duplication devices, facsimile equipment, film projectors, recording equipment, and other equipment to facilitate the use of the resources of the library or related instrumentality by those who are served by it; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb581d982-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s286b–5/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the introduction of new technologies in medical librarianship.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb581d983-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s286b–5/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb581d984-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s286b–5/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The amount of any grant under this section to any medical library or related instrumentality shall be determined by the Secretary on the basis of the scope of library or related services provided by such library or instrumentality in relation to the population and purposes served by it. In making a determination of the scope of services served by any medical library or related instrumentality, the Secretary shall take into account—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb581d985-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s286b–5/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of graduate and undergraduate students making use of the resources of such library or instrumentality;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb581d986-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s286b–5/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of physicians and other practitioners in the sciences related to health utilizing the resources of such library or instrumentality;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb581d987-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s286b–5/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the type of supportive staffs, if any, available to such library or instrumentality;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb581d988-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s286b–5/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the type, size, and qualifications of the faculty of any school with which such library or instrumentality is affiliated;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb581d989-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s286b–5/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the staff of any hospital or hospitals or of any clinic or clinics with which such library or instrumentality is affiliated; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb581d98a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s286b–5/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the geographic area served by such library or instrumentality and the availability within such area of medical library or related services provided by other libraries or related instrumentalities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb581d98b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s286b–5/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Grants to such medical libraries or related instrumentalities under this section shall be in such amounts as the Secretary may by regulation prescribe with a view to assuring adequate continuing financial support for such libraries or instrumentalities from other sources during and after the period for which grants are provided, except that in no case shall any grant under this section to a medical library or related instrumentality for any fiscal year exceed $1,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb581d98c-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title IV, § 474, as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/158/s2"},"text":"Pub. L. 99–158, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-11-20"},"text":"Nov. 20, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/861"},"text":"99 Stat. 861","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/607/tI/s146/b"},"text":"Pub. L. 100–607, title I, § 146(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-04"},"text":"Nov. 4, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3058"},"text":"102 Stat. 3058","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/43/tXIV/s1401/b"},"text":"Pub. L. 103–43, title XIV, § 1401(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-06-10"},"text":"June 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/170"},"text":"107 Stat. 170","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb581d98d-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb581d98e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb581d98f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1993—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/43"},"text":"Pub. L. 103–43","children":[],"tail":" substituted “$1,000,000” for “$750,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/607"},"text":"Pub. L. 100–607","children":[],"tail":" substituted “$750,000” for “$500,000”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
