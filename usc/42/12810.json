{"tag":"section","attrib":{"id":"idbfa1b5c9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12810"},"text":null,"children":[{"tag":"num","attrib":{"value":"12810"},"text":"§ 12810.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost-saving building technologies and construction techniques","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfa1b5ca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12810/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall make available a model program to utilize cost-saving building technologies and construction techniques for purposes of providing homeownership and rental opportunities under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfa1b5cb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12810/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall establish criteria for participating jurisdictions to select projects for assistance under the model program which may include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfa1b5cc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12810/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which innovative, cost-saving building and construction technologies are utilized;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfa1b5cd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12810/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which innovative, cost-saving construction techniques are utilized;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfa1b5ce-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12810/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which units will be made available to low-income families and individuals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfa1b5cf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12810/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which non-Federal public or private assistance is utilized; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfa1b5d0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12810/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other factor, determined by the Secretary to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfa1b5d1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12810/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guidelines","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall publish guidelines for the model program under this section not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"1992-10-28"},"text":"October 28, 1992","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfa1b5d2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12810/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall submit a biennial report to the Congress on the utilization of the model program under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfa1b5d3-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/625/tII/s260"},"text":"Pub. L. 101–625, title II, § 260","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/550/tII/s216"},"text":"Pub. L. 102–550, title II, § 216","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3760"},"text":"106 Stat. 3760","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbfa1b5d4-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbfa1b5d5-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbfa1b5d6-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to unexpended funds allocated under subchapter II of this chapter in fiscal year 1992, except as otherwise specifically provided, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550/s223"},"text":"section 223 of Pub. L. 102–550","children":[],"tail":", set out as an Effective Date of 1992 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12704"},"text":"section 12704 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
