{"tag":"section","attrib":{"id":"idbfdd5f6f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15081"},"text":null,"children":[{"tag":"num","attrib":{"value":"15081"},"text":"§ 15081.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purpose of this part is to provide grants, contracts, or cooperative agreements for projects of national significance that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfdd5f70-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15081/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" create opportunities for individuals with developmental disabilities to directly and fully contribute to, and participate in, all facets of community life; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfdd5f71-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15081/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" support the development of national and State policies that reinforce and promote, with the support of families, guardians, advocates, and communities, of individuals with developmental disabilities, the self-determination, independence, productivity, and integration and inclusion in all facets of community life of such individuals through—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfdd5f72-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15081/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" family support activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfdd5f73-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15081/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" data collection and analysis;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfdd5f74-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15081/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" technical assistance to entities funded under parts B and D, subject to the limitations described in sections 15029(b), 15066(a)(3), and 15083(c) of this title; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfdd5f75-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15081/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" other projects of sufficient size and scope that hold promise to expand or improve opportunities for such individuals, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbfdd5f76-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15081/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" projects that provide technical assistance for the development of information and referral systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbfdd5f77-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15081/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" projects that provide technical assistance to self-advocacy organizations of individuals with developmental disabilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbfdd5f78-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15081/2/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" projects that provide education for policymakers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbfdd5f79-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15081/2/D/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal interagency initiatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbfdd5f7a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15081/2/D/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" projects that enhance the participation of racial and ethnic minorities in public and private sector initiatives in developmental disabilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbfdd5f7b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15081/2/D/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" projects that provide aid to transition youth with developmental disabilities from school to adult life, especially in finding employment and postsecondary education opportunities and in upgrading and changing any assistive technology devices that may be needed as a youth matures;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbfdd5f7c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15081/2/D/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" initiatives that address the development of community quality assurance systems and the training related to the development, implementation, and evaluation of such systems, including training of individuals with developmental disabilities and their families;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbfdd5f7d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15081/2/D/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" initiatives that address the needs of aging individuals with developmental disabilities and aging caregivers of adults with developmental disabilities in the community;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbfdd5f7e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15081/2/D/ix"},"text":null,"children":[{"tag":"num","attrib":{"value":"ix"},"text":"(ix)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" initiatives that create greater access to and use of generic services systems, community organizations, and associations, and initiatives that assist in community economic development;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbfdd5f7f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15081/2/D/x"},"text":null,"children":[{"tag":"num","attrib":{"value":"x"},"text":"(x)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" initiatives that create access to increased living options;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbfdd5f80-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15081/2/D/xi"},"text":null,"children":[{"tag":"num","attrib":{"value":"xi"},"text":"(xi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" initiatives that address the challenging behaviors of individuals with developmental disabilities, including initiatives that promote positive alternatives to the use of restraints and seclusion; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbfdd5f81-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15081/2/D/xii"},"text":null,"children":[{"tag":"num","attrib":{"value":"xii"},"text":"(xii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" initiatives that address other areas of emerging need.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfdd5f82-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/402/tI/s161"},"text":"Pub. L. 106–402, title I, § 161","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1725"},"text":"114 Stat. 1725","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
