{"tag":"section","attrib":{"id":"idb80a5909-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1102"},"text":null,"children":[{"tag":"num","attrib":{"value":"1102"},"text":"§ 1102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfers between Federal unemployment account and employment security administration account","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb80a590a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1102/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of excess; amount transferred","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Whenever the Secretary of the Treasury determines pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1101/f"},"text":"section 1101(f) of this title","children":[],"tail":" that there is an excess in the employment security administration account as of the close of any fiscal year and the entire amount of such excess is not retained in the employment security administration account or transferred to the extended unemployment compensation account as provided in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1101/f/3"},"text":"section 1101(f)(3) of this title","children":[],"tail":", there shall be transferred (as of the beginning of the succeeding fiscal year) to the Federal unemployment account the balance of such excess or so much thereof as is required to increase the amount in the Federal unemployment account to whichever of the following is the greater:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb80a590b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1102/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $550 million, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb80a590c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1102/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount (determined by the Secretary of Labor and certified by him to the Secretary of the Treasury) equal to 0.5 percent of the total wages subject (determined without any limitation on amount) to contributions under all State unemployment compensation laws for the calendar year ending during the fiscal year for which the excess is determined.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb80a590d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1102/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unemployment account excesses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount, if any, by which the amount in the Federal unemployment account as of the close of any fiscal year exceeds the greater of the amounts specified in paragraphs (1) and (2) of subsection (a) shall be transferred to the employment security administration account as of the close of such fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb80a590e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1102/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Whenever the Secretary of Labor has reason to believe that in the next fiscal year the employment security administration account will reach the limit provided for such account in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1101/f/3/A"},"text":"section 1101(f)(3)(A) of this title","children":[],"tail":", and the Federal unemployment account will reach the limit provided for such account in subsection (a), and the extended unemployment compensation account will reach the limit provided for such account in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1105/b/2"},"text":"section 1105(b)(2) of this title","children":[],"tail":", he shall, after consultation with the Secretary of the Treasury, so report to the Congress with a recommendation for appropriate action by the Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb80a590f-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title IX, § 902, as added "},{"tag":"ref","attrib":{"href":"/us/act/1954-08-05/ch657/s2"},"text":"Aug. 5, 1954, ch. 657, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/669"},"text":"68 Stat. 669","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/86/778/tV/s521"},"text":"Pub. L. 86–778, title V, § 521","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-09-13"},"text":"Sept. 13, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/974"},"text":"74 Stat. 974","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/373/tIII/s304/a"},"text":"Pub. L. 91–373, title III, § 304(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"1970-08-10"},"text":"Aug. 10, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/715"},"text":"84 Stat. 715","children":[],"tail":", 716; "},{"tag":"ref","attrib":{"href":"/us/pl/100/203/tIX/s9154/b/1"},"text":"Pub. L. 100–203, title IX, § 9154(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1330-326"},"text":"101 Stat. 1330–326","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/318/tV/s531/b"},"text":"Pub. L. 102–318, title V, § 531(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-03"},"text":"July 3, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/316"},"text":"106 Stat. 316","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/33/tV/s5402/a"},"text":"Pub. L. 105–33, title V, § 5402(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/603"},"text":"111 Stat. 603","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb80a5910-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb80a5911-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb80a5912-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1102, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531/tIX/s902"},"text":"act Aug. 14, 1935, ch. 531, title IX, § 902","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/639"},"text":"49 Stat. 639","children":[],"tail":", related to credit against tax. For further details, see Prior Law note set out preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1101"},"text":"section 1101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb80a5913-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1997—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/33"},"text":"Pub. L. 105–33","children":[],"tail":" substituted “0.5 percent” for “0.25 percent”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/318"},"text":"Pub. L. 102–318","children":[],"tail":" substituted “0.25 percent” for “five-eighths of 1 percent”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/203"},"text":"Pub. L. 100–203","children":[],"tail":" substituted “five-eighths” for “one-eighth”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1970—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/373/s304/a"},"text":"Pub. L. 91–373, § 304(a)","children":[],"tail":", inserted, in provisions preceding par. (1), reference to the retention of the entire amount of the excess in the employment security administration account or the transfer to the extended unemployment compensation account as provided in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1101/f/3"},"text":"section 1101(f)(3) of this title","children":[],"tail":" and, in par. (2), substituted “one-eighth of 1 percent” for “four-tenths of 1 per centum”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/373/s304/b"},"text":"Pub. L. 91–373, § 304(b)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1960—","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/778"},"text":"Pub. L. 86–778","children":[],"tail":" substituted provisions for transfers between Federal unemployment account and employment security administration account for former provisions crediting the Federal unemployment account with funds and defining “adjusted balance”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb80a5914-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb80a5915-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1997 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/33/tV/s5402/b"},"text":"Pub. L. 105–33, title V, § 5402(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/603"},"text":"111 Stat. 603","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/33/tV/s5402/b"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“This section [amending this section] and the amendment made by this section—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall take effect on ","children":[{"tag":"date","attrib":{"date":"2001-10-01"},"text":"October 1, 2001","children":[],"tail":", and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall apply to fiscal years beginning on or after that date.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb80a5916-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1992 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/318/tV/s531/e"},"text":"Pub. L. 102–318, title V, § 531(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-03"},"text":"July 3, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/317"},"text":"106 Stat. 317","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/318/tV/s531/e"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in paragraph (2), the amendments made by this section [enacting ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1110"},"text":"section 1110 of this title","children":[],"tail":" and amending this section and sections 1101, 1104, and 1105 of this title] shall take effect on the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1992-07-03"},"text":"July 3, 1992","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Changes in ceiling amounts","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendments made by subsection[s] (a)(2) and (b) [amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1105"},"text":"section 1105 of this title","children":[],"tail":"] shall apply to fiscal years beginning after "},{"tag":"date","attrib":{"date":"1993-09-30"},"text":"September 30, 1993","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
