{"tag":"section","attrib":{"id":"idb615dca0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–19"},"text":null,"children":[{"tag":"num","attrib":{"value":"300d–19"},"text":"§ 300d–19.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to comply with agreements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb615dca1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–19/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repayment of payments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb615dca2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–19/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may, in accordance with subsection (b), require a State to repay any payments received by the State pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300d–11/a"},"text":"section 300d–11(a) of this title","children":[],"tail":" that the Secretary determines were not expended by the State in accordance with the agreements required to be made by the State as a condition of the receipt of payments under such section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb615dca3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–19/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Offset of amounts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a State fails to make a repayment required in paragraph (1), the Secretary may offset the amount of the repayment against any amount due to be paid to the State under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300d–11/a"},"text":"section 300d–11(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb615dca4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–19/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Opportunity for hearing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Before requiring repayment of payments under subsection (a)(1), the Secretary shall provide to the State an opportunity for a hearing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb615dca5-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XII, § 1219, as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/590/s3"},"text":"Pub. L. 101–590, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2925"},"text":"104 Stat. 2925","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
