{"tag":"section","attrib":{"id":"idb656405f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300t"},"text":null,"children":[{"tag":"num","attrib":{"value":"300t"},"text":"§ 300t.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Development grants for health systems agencies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb6564060-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300t/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible recipients; purpose of grants","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall make in each fiscal year a grant to each health system agency—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6564061-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300t/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with which there is in effect a designation agreement under section 300","children":[{"tag":"i","attrib":{},"text":"l–","children":[],"tail":"4(c) "},{"tag":"ref","attrib":{"idref":"fn002364"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002364"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title,"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6564062-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300t/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which has in effect an HSP and AIP reviewed by the Statewide Health Coordinating Council, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6564063-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300t/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which, as determined under the review made under section 300n–4(c) ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of this title, is organized and operated in the manner prescribed by section 300"},{"tag":"i","attrib":{},"text":"l–","children":[],"tail":"1(b) "},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of this title and is performing its functions under section 300"},{"tag":"i","attrib":{},"text":"l–","children":[],"tail":"2 "},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of this title in a manner satisfactory to the Secretary,"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"to enable the agency to establish and maintain an Area Health Service Development Fund from which it may make grants and enter into contracts in accordance with section 300","children":[{"tag":"i","attrib":{},"text":"l–","children":[],"tail":"2(c)(3) "},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6564064-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300t/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of amounts; maximum amounts","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6564065-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300t/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in paragraph (2), the amount of any grant under subsection (a) shall be determined by the Secretary after taking into consideration the population of the health service area for which the health systems agency is designated, the average family income of the area, and the supply of health services in the area.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6564066-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300t/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amount of any grant under subsection (a) to a health systems agency for any fiscal year may not exceed the product of $1 and the population of the health service area for which such agency is designated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6564067-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300t/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications; submission and approval as prerequisite; form and contents","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No grant may be made under subsection (a) unless an application therefor has been submitted to, and approved by, the Secretary. Such an application shall be submitted in such form and manner and contain such information as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6564068-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300t/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of making payments pursuant to grants under subsection (a), there are authorized to be appropriated $25,000,000 for the fiscal year ending ","children":[{"tag":"date","attrib":{"date":"1975-06-30"},"text":"June 30, 1975","children":[],"tail":", $75,000,000 for the fiscal year ending "},{"tag":"date","attrib":{"date":"1976-06-30"},"text":"June 30, 1976","children":[],"tail":", $120,000,000 each for the fiscal years ending "},{"tag":"date","attrib":{"date":"1977-09-30"},"text":"September 30, 1977","children":[],"tail":", and "},{"tag":"date","attrib":{"date":"1978-09-30"},"text":"September 30, 1978","children":[],"tail":", $20,000,000 for the fiscal year ending "},{"tag":"date","attrib":{"date":"1981-09-30"},"text":"September 30, 1981","children":[],"tail":", and $30,000,000 for the fiscal year ending "},{"tag":"date","attrib":{"date":"1982-09-30"},"text":"September 30, 1982","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb6564069-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XVI, § 1640, as added "},{"tag":"ref","attrib":{"href":"/us/pl/93/641/s4"},"text":"Pub. L. 93–641, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-04"},"text":"Jan. 4, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2273"},"text":"88 Stat. 2273","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/95/83/tI/s103/c"},"text":"Pub. L. 95–83, title I, § 103(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-08-01"},"text":"Aug. 1, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/383"},"text":"91 Stat. 383","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/79/tI/s127/e"},"text":"Pub. L. 96–79, title I, § 127(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-10-04"},"text":"Oct. 4, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/629"},"text":"93 Stat. 629","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb656406a-3a70-1