{"tag":"section","attrib":{"id":"idbde64aa4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6991a"},"text":null,"children":[{"tag":"num","attrib":{"value":"6991a"},"text":"§ 6991a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbde64aa5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6991a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Underground storage tanks","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbde64aa6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6991a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Within 18 months after ","children":[{"tag":"date","attrib":{"date":"1984-11-08"},"text":"November 8, 1984","children":[],"tail":", each owner of an underground storage tank shall notify the State or local agency or department designated pursuant to subsection (b)(1) of the existence of such tank, specifying the age, size, type, location, and uses of such tank."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbde64aa7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6991a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbde64aa8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6991a/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For each underground storage tank taken out of operation after ","children":[{"tag":"date","attrib":{"date":"1974-01-01"},"text":"January 1, 1974","children":[],"tail":", the owner of such tank shall, within eighteen months after "},{"tag":"date","attrib":{"date":"1984-11-08"},"text":"November 8, 1984","children":[],"tail":", notify the State or local agency, or department designated pursuant to subsection (b)(1) of the existence of such tanks (unless the owner knows the tank subsequently was removed from the ground). The owner of a tank taken out of operation on or before "},{"tag":"date","attrib":{"date":"1974-01-01"},"text":"January 1, 1974","children":[],"tail":", shall not be required to notify the State or local agency under this subsection."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbde64aa9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6991a/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Notice under subparagraph (A) shall specify, to the extent known to the owner—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbde64aaa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6991a/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date the tank was taken out of operation,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbde64aab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6991a/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the age of the tank on the date taken out of operation,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbde64aac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6991a/a/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the size, type and location of the tank, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbde64aad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6991a/a/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the type and quantity of substances left stored in such tank on the date taken out of operation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbde64aae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6991a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any owner which brings into use an underground storage tank after the initial notification period specified under paragraph (1), shall notify the designated State or local agency or department within thirty days of the existence of such tank, specifying the age, size, type, location and uses of such tank.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbde64aaf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6991a/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Paragraphs (1) through (3) of this subsection shall not apply to tanks for which notice was given pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s9603/c"},"text":"section 9603(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbde64ab0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6991a/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Beginning thirty days after the Administrator prescribes the form of notice pursuant to subsection (b)(2) and for eighteen months thereafter, any person who deposits regulated substances in an underground storage tank shall reasonably notify the owner or operator of such tank of the owner’s notification requirements pursuant to this subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbde64ab1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6991a/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Beginning thirty days after the Administrator issues new tank performance standards pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6991b/c"},"text":"section 6991b(c) of this title","children":[],"tail":", any person who sells a tank intended to be used as an underground storage tank shall notify the purchaser of such tank of the owner’s notification requirements pursuant to this subsection."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbde64ab2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6991a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agency designation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbde64ab3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6991a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Within one hundred and eighty days after ","children":[{"tag":"date","attrib":{"date":"1984-11-08"},"text":"November 8, 1984","children":[],"tail":", the Governors of each State shall designate the appropriate State agency or department or local agencies or departments to receive the notifications under subsection (a)(1), (2), or (3)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbde64ab4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6991a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Within twelve months after ","children":[{"tag":"date","attrib":{"date":"1984-11-08"},"text":"November 8, 1984","children":[],"tail":", the Administrator, in consultation with State and local officials designated pursuant to subsection (b)(1), and after notice and opportunity for public comment, shall prescribe the form of the notice and the information to be included in the notifications under subsection (a)(1), (2), or (3). In prescribing the form of such notice, the Administrator shall take into account the effect on small businesses and other owners and operators."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbde64ab5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6991a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State inventories","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each State shall make 2 separate inventories of all underground storage tanks in such State containing regulated substances. One inventory shall be made with respect to petroleum and one with respect to other regulated substances. In making such inventories, the State shall utilize and aggregate the data in the notification forms submitted pursuant to subsections (a) and (b) of this section. Each State shall submit such aggregated data to the Administrator not later than 270 days after ","children":[{"tag":"date","attrib":{"date":"1986-10-17"},"text":"October 17, 1986","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbde64ab6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6991a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public record","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbde64ab7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6991a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall require each State that receives Federal funds to carry out this subchapter to maintain, update at least annually, and make available to the public, in such manner and form as the Administrator shall prescribe (after consultation with States), a record of underground storage tanks regulated under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbde64ab8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6991a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Considerations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To the maximum extent practicable, the public record of a State, respectively, shall include, for each year—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbde64ab9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6991a/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number, sources, and causes of underground storage tank releases in the State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbde64aba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6991a/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the record of compliance by underground storage tanks in the State with—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbde64abb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6991a/d/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" this subchapter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbde64abc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6991a/d/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an applicable State program approved under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6991c"},"text":"section 6991c of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbde64abd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6991a/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" data on the number of underground storage tank equipment failures in the State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbde64abe-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/272/tII/s9002"},"text":"Pub. L. 89–272, title II, § 9002","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/98/616/tVI/s601/a"},"text":"Pub. L. 98–616, title VI, § 601(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-11-08"},"text":"Nov. 8, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3278"},"text":"98 Stat. 3278","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/499/tII/s205/b"},"text":"Pub. L. 99–499, title II, § 205(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-17"},"text":"Oct. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1696"},"text":"100 Stat. 1696","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/58/tXV/s1526/c"},"text":"Pub. L. 109–58, title XV, § 1526(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1098"},"text":"119 Stat. 1098","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbde64abf-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbde64ac0-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbde64ac1-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2005—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58"},"text":"Pub. L. 109–58","children":[],"tail":" added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/499"},"text":"Pub. L. 99–499","children":[],"tail":" added subsec. (c)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
