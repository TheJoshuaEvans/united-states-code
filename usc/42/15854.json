{"tag":"section","attrib":{"id":"idbfe48bb9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15854"},"text":null,"children":[{"tag":"num","attrib":{"value":"15854"},"text":"§ 15854.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sugar Cane Ethanol Program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfe48bba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15854/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “program” means the Sugar Cane Ethanol Program established by subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfe48bbb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15854/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established within the Environmental Protection Agency a program to be known as the “Sugar Cane Ethanol Program”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfe48bbc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15854/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Project","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfe48bbd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15854/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to the availability of appropriations under subsection (d), in carrying out the program, the Administrator of the Environmental Protection Agency shall establish a project that is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfe48bbe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15854/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" carried out in multiple States—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbfe48bbf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15854/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in each of which is produced cane sugar that is eligible for loans under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7272"},"text":"section 7272 of title 7","children":[],"tail":", or a similar subsequent authority; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbfe48bc0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15854/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at the option of each such State, that have an incentive program that requires the use of ethanol in the State; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfe48bc1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15854/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designed to study the production of ethanol from cane sugar, sugarcane, and sugarcane byproducts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe48bc2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15854/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A project described in paragraph (1) shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfe48bc3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15854/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be limited to sugar producers and the production of ethanol in the States of Florida, Louisiana, Texas, and Hawaii, divided equally among the States, to demonstrate that the process may be applicable to cane sugar, sugarcane, and sugarcane byproducts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfe48bc4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15854/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include information on the ways in which the scale of production may be replicated once the sugar cane industry has located sites for, and constructed, ethanol production facilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfe48bc5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15854/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not last more than 3 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfe48bc6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15854/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this section $36,000,000, to remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfe48bc7-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tII/s208"},"text":"Pub. L. 109–58, title II, § 208","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/656"},"text":"119 Stat. 656","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
