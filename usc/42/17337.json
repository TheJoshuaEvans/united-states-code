{"tag":"section","attrib":{"id":"idc03591a0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17337"},"text":null,"children":[{"tag":"num","attrib":{"value":"17337"},"text":"§ 17337.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States-Israel energy cooperation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc03591a1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17337/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc03591a2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17337/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" it is in the highest national security interests of the United States to develop covered energy sources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc03591a3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17337/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State of Israel is a steadfast ally of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc03591a4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17337/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the special relationship between the United States and Israel is manifested in a variety of cooperative scientific research and development programs, such as—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc03591a5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17337/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States-Israel Binational Science Foundation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc03591a6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17337/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States-Israel Binational Industrial Research and Development Foundation;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc03591a7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17337/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" those programs have made possible—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc03591a8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17337/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" many scientific, technological, and commercial breakthroughs in the fields of life sciences, medicine, bioengineering, agriculture, biotechnology, communications, and others; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc03591a9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17337/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" significant contributions to the development of renewable energy and energy efficiency through the established programs of the United States-Israel Binational Industrial Research and Development Foundation and the United States-Israel Binational Science Foundation;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc03591aa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17337/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on ","children":[{"tag":"date","attrib":{"date":"1996-02-01"},"text":"February 1, 1996","children":[],"tail":", the Secretary of Energy (referred to in this section as the “Secretary”) and the Israeli Minister of Energy and Infrastructure signed an agreement to establish a framework for collaboration between the United States and Israel in energy research and development activities;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc03591ab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17337/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Israeli scientists and engineers are at the forefront of research and development in the field of covered energy sources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc03591ac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17337/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhanced cooperation between the United States and Israel for the purpose of research and development of covered energy sources would be in the national interests of both countries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc03591ad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17337/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" United States-Israel energy cooperation and the development of natural resources by Israel are in the strategic interest of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc03591ae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17337/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Israel is a strategic partner of the United States in water technology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc03591af-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17337/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States can play a role in assisting Israel with regional safety and security issues;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc03591b0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17337/a/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Science Foundation of the United States, to the extent consistent with the National Science Foundation’s mission, should collaborate with the Israel Science Foundation and the United States-Israel Binational Science Foundation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc03591b1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17337/a/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the United States and Israel should strive to develop more robust academic cooperation in—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc03591b2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17337/a/12/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" energy innovation technology and engineering;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc03591b3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17337/a/12/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" water science;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc03591b4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17337/a/12/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" technology transfer; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc03591b5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17337/a/12/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" analysis of emerging geopolitical implications, crises and threats from foreign natural resource and energy acquisitions, and the development of domestic resources as a response;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc03591b6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17337/a/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States supports the goals of the Alternative Fuels Administration of Israel with respect to expanding the use of alternative fuels;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc03591b7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17337/a/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the United States strongly urges open dialogue and continued mechanisms for regular engagement and encourages further cooperation between applicable departments, agencies, ministries, institutions of higher education, and the private sector of the United States and Israel on energy security issues, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc03591b8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17337/a/14/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying policy priorities associated with the development of natural resources of Israel;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc03591b9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17337/a/14/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" discussing and sharing best practices to secure cyber energy infrastructure and other energy security matters;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc03591ba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17337/a/14/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" leveraging natural gas to positively impact regional stability;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc03591bb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17337/a/14/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issues relating to the energy-water nexus, including improving energy efficiency and the overall performance of water technologies through research and development in water desalination, wastewater treatment and reclamation, water treatment in gas and oil production processes, and other water treatment refiners;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc03591bc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17337/a/14/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" technical and environmental management of deep-water exploration and production;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc03591bd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17337/a/14/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" emergency response and coastal protection and restoration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc03591be-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17337/a/14/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" academic outreach and engagement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc03591bf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17337/a/14/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" private sector and business development engagement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc03591c0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17337/a/14/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" regulatory consultations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc03591c1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17337/a/14/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" leveraging alternative transportation fuels and technologies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc03591c2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17337/a/14/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other areas determined appropriate by the United States and Israel;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc03591c3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17337/a/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the United States—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc03591c4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17337/a/15/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acknowledges the achievements and importance of the Binational Industrial Research and Development Foundation and the United States-Israel Binational Science Foundation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc03591c5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17337/a/15/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supports continued multiyear funding to ensure the continuity of the programs of the foundations specified in subparagraph (A); and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc03591c6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17337/a/16"},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"(16)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States and Israel have a shared interest in addressing immediate, near-term, and long-term energy, energy poverty, energy independence, and environmental challenges facing the United States and Israel, respectively.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc03591c7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17337/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc03591c8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17337/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In implementing the agreement entitled the “Agreement between the Department of Energy of the United States of America and the Ministry of Energy and Infrastructure of Israel Concerning Energy Cooperation”, dated ","children":[{"tag":"date","attrib":{"date":"1996-02-01"},"text":"February 1, 1996","children":[],"tail":", the Secretary shall establish a grant program in accordance with the requirements of sections 16352 and 16353 of this title to support research, development, and commercialization of covered energy."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc03591c9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17337/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Types of energy","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out paragraph (1), the Secretary may make grants to promote—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc03591ca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17337/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" solar energy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc03591cb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17337/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" biomass energy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc03591cc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17337/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" energy efficiency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc03591cd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17337/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" wind energy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc03591ce-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17337/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" geothermal energy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc03591cf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17337/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" wave and tidal energy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc03591d0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17337/b/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advanced battery technology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc03591d1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17337/b/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" natural gas energy, including conventional and unconventional natural gas technologies and other associated technologies, and natural gas projects conducted by or in conjunction with the United States-Israel Binational Science Foundation and the United States-Israel Binational Industrial Research and Development Foundation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc03591d2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17337/b/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improvement of energy efficiency and the overall performance of water technologies through research and development in water desalination, wastewater treatment and reclamation, and other water treatment refiners.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc03591d3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17337/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible applicants","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An applicant shall be eligible to receive a grant under this subsection if the project of the applicant—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc03591d4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17337/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" addresses a requirement in the area of improved covered energy sources, as determined by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc03591d5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17337/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is a joint venture between—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc03591d6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17337/b/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idc03591d7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17337/b/3/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a for-profit business entity, academic institution, National Laboratory (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s15801"},"text":"section 15801 of this title","children":[],"tail":"), or nonprofit entity in the United States; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc03591d8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17337/b/3/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a for-profit business entity, academic institution, or nonprofit entity in Israel; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc03591d9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17337/b/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idc03591da-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17337/b/3/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Government; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc03591db-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17337/b/3/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Government of Israel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc03591dc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17337/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be eligible to receive a grant under this subsection, an applicant shall submit to the Secretary an application for the grant in accordance with procedures established by the Secretary, in consultation with the advisory board established under paragraph (5).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc03591dd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17337/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisory board","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc03591de-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17337/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall establish an advisory board—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc03591df-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17337/b/5/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to monitor the method by which grants are awarded under this subsection; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc03591e0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17337/b/5/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide to the Secretary periodic performance reviews of actions taken to carry out this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc03591e1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17337/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Composition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The advisory board established under subparagraph (A) shall be composed of 3 members, to be appointed by the Secretary, of whom—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc03591e2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17337/b/5/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 shall be a representative of the Federal Government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc03591e3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17337/b/5/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 shall be selected from a list of nominees provided by the United States-Israel Binational Science Foundation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc03591e4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17337/b/5/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 shall be selected from a list of nominees provided by the United States-Israel Binational Industrial Research and Development Foundation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc03591e5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17337/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contributed funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3302"},"text":"section 3302 of title 31","children":[],"tail":", the Secretary may accept, retain, and use funds contributed by any person, government entity, or organization for purposes of carrying out this subsection—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc03591e6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17337/b/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" without further appropriation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc03591e7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17337/b/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" without fiscal year limitation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc03591e8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17337/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after the date of completion of a project for which a grant is provided under this subsection, the grant recipient shall submit to the Secretary a report that contains—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc03591e9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17337/b/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the method by which the recipient used the grant funds; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc03591ea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17337/b/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an evaluation of the level of success of each project funded by the grant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc03591eb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17337/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Classification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Grants shall be awarded under this subsection only for projects that are considered to be unclassified by both the United States and Israel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc03591ec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17337/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" International partnerships","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc03591ed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17337/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, subject to the availability of appropriations, may enter into cooperative agreements supporting and enhancing dialogue and planning involving international partnerships between the Department, including National Laboratories of the Department, and the Government of Israel and its ministries, offices, and institutions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc03591ee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17337/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may not pay more than 50 percent of Federal share of the costs of implementing cooperative agreements entered into pursuant to paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc03591ef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17337/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual reports","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Secretary enters into agreements authorized by paragraph (1), the Secretary shall submit an annual report to the Committee on Energy and Natural Resources of the Senate, the Committee on Foreign Relations of the Senate, the Committee on Appropriations of the Senate, the Committee on Energy and Commerce of the House of Representatives, the Committee on Science, Space, and Technology of the House of Representatives, the Committee on Foreign Affairs of the House of Representatives, and the Committee on Appropriations of the House of Representatives that describes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc03591f0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17337/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" actions taken to implement such agreements; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc03591f1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17337/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any projects undertaken pursuant to such agreements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc03591f2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17337/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States-Israel Energy Center","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may establish a joint United States-Israel Energy Center in the United States leveraging the experience, knowledge, and expertise of institutions of higher education and entities in the private sector, among others, in offshore energy development to further dialogue and collaboration to develop more robust academic cooperation in energy innovation technology and engineering, water science, technology transfer, and analysis of emerging geopolitical implications, crises and threats from foreign natural resource and energy acquisitions, and the development of domestic resources as a response.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc03591f3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17337/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The grant program and the advisory committee established under this section terminate on ","children":[{"tag":"date","attrib":{"date":"2024-09-30"},"text":"September 30, 2024","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc03591f4-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/tIX/s917"},"text":"Pub. L. 110–140, title IX, § 917","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1730"},"text":"121 Stat. 1730","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/296/s12/a"},"text":"Pub. L. 113–296, § 12(a)","children":[],"tail":"–(c)(1), "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/4078-4080"},"text":"128 Stat. 4078–4080","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc03591f5-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc03591f6-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc03591f7-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/296/s12/a/1"},"text":"Pub. L. 113–296, § 12(a)(1)","children":[],"tail":", substituted “covered” for “renewable”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/296/s12/a/2"},"text":"Pub. L. 113–296, § 12(a)(2)","children":[],"tail":", substituted “possible—” for “possible”, designated remaining existing provisions as subpar. (A), and added subpar. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/296/s12/a/3/A"},"text":"Pub. L. 113–296, § 12(a)(3)(A)","children":[],"tail":", substituted “covered” for “renewable”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/296/s12/a/4/A"},"text":"Pub. L. 113–296, § 12(a)(4)(A)","children":[],"tail":", substituted “covered” for “renewable”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(8) to (16). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/296/s12/a/3/B"},"text":"Pub. L. 113–296, § 12(a)(3)(B)","children":[],"tail":", (4)(B), (5), added pars. (8) to (16)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/296/s12/b/1"},"text":"Pub. L. 113–296, § 12(b)(1)","children":[],"tail":", substituted “covered energy” for “renewable energy or energy efficiency”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(H), (I). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/296/s12/b/2"},"text":"Pub. L. 113–296, § 12(b)(2)","children":[],"tail":", added subpars. (H) and (I)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/296/s12/b/3"},"text":"Pub. L. 113–296, § 12(b)(3)","children":[],"tail":", substituted “covered” for “energy efficiency or renewable”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/296/s12/c/1/C"},"text":"Pub. L. 113–296, § 12(c)(1)(C)","children":[],"tail":", added subsec. (c). Former subsec. (c) redesignated (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/296/s12/c/1/A"},"text":"Pub. L. 113–296, § 12(c)(1)(A)","children":[],"tail":", (C), added subsec. (d) and struck out former subsec. (d) which related to authorization of appropriations."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/296/s12/c/1/B"},"text":"Pub. L. 113–296, § 12(c)(1)(B)","children":[],"tail":", (D), redesignated subsec. (c) as (e) and substituted “"},{"tag":"date","attrib":{"date":"2024-09-30"},"text":"September 30, 2024","children":[],"tail":"” for “the date that is 7 years after "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"December 19, 2007","children":[],"tail":"”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc03591f8-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc03591f9-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the date that is 1 day after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/s1601"},"text":"section 1601 of Pub. L. 110–140","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1824"},"text":"section 1824 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
