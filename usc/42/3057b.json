{"tag":"section","attrib":{"id":"idbc66610b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3057b"},"text":null,"children":[{"tag":"num","attrib":{"value":"3057b"},"text":"§ 3057b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Congress finds that the older individuals who are Indians of the United States—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc66610c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3057b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are a rapidly increasing population;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc66610d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3057b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" suffer from high unemployment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc66610e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3057b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" live in poverty at a rate estimated to be as high as 61 percent;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc66610f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3057b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have a life expectancy between 3 and 4 years less than the general population;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc666110-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3057b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" lack sufficient nursing homes, other long-term care facilities, and other health care facilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc666111-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3057b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" lack sufficient Indian area agencies on aging;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc666112-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3057b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" frequently live in substandard and over-crowded housing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc666113-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3057b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" receive less than adequate health care;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc666114-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3057b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are served under this subchapter at a rate of less than 19 percent of the total national population of older individuals who are Indians living on Indian reservations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc666115-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3057b/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are served under subchapter III at a rate of less than 1 percent of the total participants under that subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc666116-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/73/tVI/s611"},"text":"Pub. L. 89–73, title VI, § 611","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/175/tI/s171"},"text":"Pub. L. 100–175, title I, § 171","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-11-29"},"text":"Nov. 29, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/959"},"text":"101 Stat. 959","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/375/tIX/s904/a/21"},"text":"Pub. L. 102–375, title IX, § 904(a)(21)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-09-30"},"text":"Sept. 30, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1309"},"text":"106 Stat. 1309","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/131/tVII/s701/10"},"text":"Pub. L. 116–131, title VII, § 701(10)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-03-25"},"text":"Mar. 25, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/271"},"text":"134 Stat. 271","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc666117-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc666118-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbc666119-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 3057b, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/73/tVI/s603"},"text":"Pub. L. 89–73, title VI, § 603","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/95/478/tI/s106"},"text":"Pub. L. 95–478, title I, § 106","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-18"},"text":"Oct. 18, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1549"},"text":"92 Stat. 1549","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/97/115"},"text":"Pub. L. 97–115","children":[],"tail":", §§ 3(d), 13(a), "},{"tag":"date","attrib":{"date":"1981-12-29"},"text":"Dec. 29, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1597"},"text":"95 Stat. 1597","children":[],"tail":", 1608, related to authority of Commissioner to make grants to pay all costs for delivery of supportive services and nutritional services for older Indians, prior to the general revision of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/100/175"},"text":"Pub. L. 100–175","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3057d"},"text":"section 3057d of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/73/s603"},"text":"section 603 of Pub. L. 89–73","children":[],"tail":", title VI, as added "},{"tag":"ref","attrib":{"href":"/us/pl/91/69/s9"},"text":"Pub. L. 91–69, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-09-17"},"text":"Sept. 17, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/112"},"text":"83 Stat. 112","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/93/29/tVI/s602"},"text":"Pub. L. 93–29, title VI, § 602","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-05-03"},"text":"May 3, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/55"},"text":"87 Stat. 55","children":[],"tail":", related to authorization of appropriations and was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3044a"},"text":"section 3044a of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/93/113/tVI/s604/a"},"text":"Pub. L. 93–113, title VI, § 604(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-10-01"},"text":"Oct. 1, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/417"},"text":"87 Stat. 417","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbc66611a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/131"},"text":"Pub. L. 116–131","children":[],"tail":" struck out “(a)” before “The Congress” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/375/s904/a/21/A"},"text":"Pub. L. 102–375, § 904(a)(21)(A)","children":[],"tail":", inserted “individuals who are” after “older” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/375/s904/a/21/B"},"text":"Pub. L. 102–375, § 904(a)(21)(B)","children":[],"tail":", substituted “population of older individuals who are Indians” for “Indian elderly population”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbc66611b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbc66611c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1987-10-01"},"text":"Oct. 1, 1987","children":[],"tail":", except not applicable with respect to any area plan submitted under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3026/a"},"text":"section 3026(a) of this title","children":[],"tail":" or any State plan submitted under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3027/a"},"text":"section 3027(a) of this title","children":[],"tail":" and approved for any fiscal year beginning before "},{"tag":"date","attrib":{"date":"1987-11-29"},"text":"Nov. 29, 1987","children":[],"tail":", see section 701(a), (b) of "},{"tag":"ref","attrib":{"href":"/us/pl/100/175"},"text":"Pub. L. 100–175","children":[],"tail":", set out as an Effective Date of 1987 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbc66611d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Task Force","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/175/tI/s134/d"},"text":"Pub. L. 100–175, title I, § 134(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-11-29"},"text":"Nov. 29, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/941"},"text":"101 Stat. 941","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/175/tI/s134/d"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Commissioner on Aging [now Assistant Secretary for Aging] shall establish a permanent interagency task force that is representative of departments and agencies of the Federal Government with an interest in older Indians and their welfare, and is designed to make recommendations with respect to facilitating the coordination of services and the improvement of services to older Indians.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The task force shall be chaired by the Associate Commissioner on [now Director of the Office for] American Indian, Alaskan Native, and Native Hawaiian Aging and shall submit its findings and recommendations to the Commissioner at 6-month intervals beginning after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1987-11-29"},"text":"Nov. 29, 1987","children":[],"tail":"]. Such findings and recommendations shall be included in the annual report required by section 207(a) of the Older Americans Act of 1965 ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3018/a"},"text":"42 U.S.C. 3018(a)","children":[],"tail":"] to be submitted by the Commissioner.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbc66611e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Special Report on Services for Older Indians","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/175/tI/s134/e"},"text":"Pub. L. 100–175, title I, § 134(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-11-29"},"text":"Nov. 29, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/942"},"text":"101 Stat. 942","children":[],"tail":", directed Commissioner on Aging to enter into a contract with a public agency or nonprofit private organization to conduct a thorough study of availability and quality of services under the Older Americans Act of 1965, "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3001"},"text":"42 U.S.C. 3001","children":[],"tail":" et seq., to older Indians and, not later than "},{"tag":"date","attrib":{"date":"1988-12-31"},"text":"Dec. 31, 1988","children":[],"tail":", submit to Congress a report and recommendations based on the study."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
