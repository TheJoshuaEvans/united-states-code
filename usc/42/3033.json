{"tag":"section","attrib":{"id":"idbc5f34cd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3033"},"text":null,"children":[{"tag":"num","attrib":{"value":"3033"},"text":"§ 3033.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment of grants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbc5f34ce-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3033/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contributions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the extent the Assistant Secretary determines a contribution to be appropriate, the Assistant Secretary shall require the recipient of any grant or contract under this subchapter to contribute money, facilities, or services for carrying out the project for which such grant or contract was made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc5f34cf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3033/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Payments under this subchapter pursuant to a grant or contract may be made (after necessary adjustment, in the case of grants, on account of previously made overpayments or underpayments) in advance or by way of reimbursement, and in such installments and on such conditions, as the Assistant Secretary may determine.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc5f34d0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3033/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Assistant Secretary shall make no grant or contract under this subchapter in any State that has established or designated a State agency for purposes of subchapter III unless the Assistant Secretary—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc5f34d1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3033/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consults with the State agency prior to issuing the grant or contract; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc5f34d2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3033/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" informs the State agency of the purposes of the grant or contract when the grant or contract is issued.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc5f34d3-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/73/tIV/s431"},"text":"Pub. L. 89–73, title IV, § 431","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/501/tIV/s401"},"text":"Pub. L. 106–501, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-13"},"text":"Nov. 13, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2265"},"text":"114 Stat. 2265","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc5f34d4-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc5f34d5-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbc5f34d6-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 3033, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/73/tIV/s403"},"text":"Pub. L. 89–73, title IV, § 403","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/93/29/tIV/s401"},"text":"Pub. L. 93–29, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-05-03"},"text":"May 3, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/46"},"text":"87 Stat. 46","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/135/tI/s109"},"text":"Pub. L. 94–135, title I, § 109","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-11-28"},"text":"Nov. 28, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/717"},"text":"89 Stat. 717","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/478/tI/s104/a/3"},"text":"Pub. L. 95–478, title I, § 104(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-18"},"text":"Oct. 18, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1537"},"text":"92 Stat. 1537","children":[],"tail":", related to task of attracting qualified persons to field of aging, prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/97/115"},"text":"Pub. L. 97–115","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/73/s431"},"text":"section 431 of Pub. L. 89–73","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3037"},"text":"section 3037 of this title","children":[],"tail":", prior to the gen