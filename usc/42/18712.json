{"tag":"section","attrib":{"id":"idc062e24e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18712"},"text":null,"children":[{"tag":"num","attrib":{"value":"18712"},"text":"§ 18712.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Electric grid reliability and resilience research, development, and demonstration","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc062e24f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18712/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of Federal financial assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “Federal financial assistance” has the meaning given the term in section 200.1 of title 2, Code of Federal Regulations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc062e250-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18712/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Energy infrastructure Federal financial assistance program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc062e251-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18712/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc062e252-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18712/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible entity” means each of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc062e253-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18712/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc062e254-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18712/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a combination of 2 or more States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc062e255-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18712/b/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an Indian Tribe;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc062e256-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18712/b/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a unit of local government; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc062e257-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18712/b/1/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a public utility commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc062e258-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18712/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “program” means the competitive Federal financial assistance program established under paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc062e259-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18712/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2021-11-15"},"text":"November 15, 2021","children":[],"tail":", the Secretary shall establish a program, to be known as the “Program Upgrading Our Electric Grid and Ensuring Reliability and Resiliency”, to provide, on a competitive basis, Federal financial assistance to eligible entities to carry out the purpose described in paragraph (3)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc062e25a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18712/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purpose of the program is to coordinate and collaborate with electric sector owners and operators—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc062e25b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18712/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to demonstrate innovative approaches to transmission, storage, and distribution infrastructure to harden and enhance resilience and reliability; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc062e25c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18712/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to demonstrate new approaches to enhance regional grid resilience, implemented through States by public and rural electric cooperative entities on a cost-shared basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc062e25d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18712/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to receive Federal financial assistance under the program, an eligible entity shall submit to the Secretary an application at such time, in such manner, and containing such information as the Secretary may require, including a description of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc062e25e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18712/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how the Federal financial assistance would be used;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc062e25f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18712/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the expected beneficiaries, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc062e260-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18712/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a proposal from an eligible entity described in paragraph (1)(A)(ii), how the proposal would improve regional energy infrastructure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc062e261-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18712/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall select eligible entities to receive Federal financial assistance under the program on a competitive basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc062e262-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18712/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16352"},"text":"Section 16352 of this title","children":[],"tail":" shall apply to Federal financial assistance provided under the program."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc062e263-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18712/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to the Secretary to carry out this subsection, $5,000,000,000 for the period of fiscal years 2022 through 2026.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc062e264-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18712/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Energy improvement in rural or remote areas","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc062e265-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18712/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of rural or remote area","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this subsection, the term “rural or remote area” means a city, town, or unincorporated area that has a population of not more than 10,000 inhabitants.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc062e266-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18712/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall carry out activities to improve in rural or remote areas of the United States—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc062e267-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18712/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the resilience, safety, reliability, and availability of energy; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc062e268-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18712/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" environmental protection from adverse impacts of energy generation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc062e269-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18712/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal financial assistance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, in consultation with the Secretary of the Interior, may provide Federal financial assistance to rural or remote areas for the purpose of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc062e26a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18712/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" overall cost-effectiveness of energy generation, transmission, or distribution systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc062e26b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18712/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" siting or upgrading transmission and distribution lines;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc062e26c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18712/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reducing greenhouse gas emissions from energy generation by rural or remote areas;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc062e26d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18712/c/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing or modernizing electric generation facilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc062e26e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18712/c/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing microgrids; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc062e26f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18712/c/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increasing energy efficiency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc062e270-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18712/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to the Secretary to carry out this subsection, $1,000,000,000 for the period of fiscal years 2022 through 2026.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc062e271-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18712/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Energy infrastructure resilience framework","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc062e272-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18712/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in collaboration with the Secretary of Homeland Security, the Federal Energy Regulatory Commission, the North American Electric Reliability Corporation, and interested energy infrastructure stakeholders, shall develop common analytical frameworks, tools, metrics, and data to assess the resilience, reliability, safety, and security of energy infrastructure in the United States, including by developing and storing an inventory of easily transported high-voltage recovery transformers and other required equipment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc062e273-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18712/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessment and report","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc062e274-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18712/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall carry out an assessment of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc062e275-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18712/d/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" with respect to the inventory of high-voltage recovery transformers, new transformers, and other equipment proposed to be developed and stored under paragraph (1)—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idc062e276-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18712/d/2/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the policies, technical specifications, and logistical and program structures necessary to mitigate the risks associated with the loss of high-voltage recovery transformers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc062e277-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18712/d/2/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the technical specifications for high-voltage recovery transformers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc062e278-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18712/d/2/A/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" where inventory of high-voltage recovery transformers should be stored;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc062e279-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18712/d/2/A/i/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the quantity of high-voltage recovery transformers necessary for the inventory;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc062e27a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18712/d/2/A/i/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how the stored inventory of high-voltage recovery transformers would be secured and maintained;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc062e27b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18712/d/2/A/i/VI"},"text":null,"children":[{"tag":"num","attrib":{"value":"VI"},"text":"(VI)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how the high-voltage recovery transformers may be transported;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc062e27c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18712/d/2/A/i/VII"},"text":null,"children":[{"tag":"num","attrib":{"value":"VII"},"text":"(VII)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" opportunities for developing new flexible advanced transformer designs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc062e27d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18712/d/2/A/i/VIII"},"text":null,"children":[{"tag":"num","attrib":{"value":"VIII"},"text":"(VIII)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether new Federal regulations or cost-sharing requirements are necessary to carry out the storage of high-voltage recovery transformers; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc062e27e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18712/d/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any efforts carried out by industry as of the date of the assessment—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idc062e27f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18712/d/2/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to share transformers and equipment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc062e280-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18712/d/2/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop plans for next generation transformers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc062e281-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18712/d/2/A/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to plan for surge and long-term manufacturing of, and long-term standardization of, transformer designs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc062e282-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18712/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protection of information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Information that is provided to, generated by, or collected by the Secretary under subparagraph (A) shall be considered to be critical electric infrastructure information under section 824","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":"–1 of title 16."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc062e283-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18712/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2021-11-15"},"text":"November 15, 2021","children":[],"tail":", the Secretary shall submit to Congress a report describing the results of the assessment carried out under subparagraph (A)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc062e284-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dD/tI/s40103"},"text":"Pub. L. 117–58, div. D, title I, § 40103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/928"},"text":"135 Stat. 928","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc062e285-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc062e286-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc062e287-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Wage Rate Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions relating to rates of wages to be paid to laborers and mechanics on projects for construction, alteration, or repair work funded under div. D or an amendment by div. D of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":", including authority of Secretary of Labor, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s18851"},"text":"section 18851 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
