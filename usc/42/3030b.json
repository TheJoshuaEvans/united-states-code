{"tag":"section","attrib":{"id":"idbc559755-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3030b"},"text":null,"children":[{"tag":"num","attrib":{"value":"3030b"},"text":"§ 3030b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recapture of payments made for multipurpose senior centers","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"If, within 10 years after acquisition, or within 20 years after the completion of construction, of any facility for which funds have been paid under this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc559756-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3030b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the owner of the facility ceases to be a public or nonprofit private agency or organization; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc559757-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3030b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the facility ceases to be used for the purposes for which it was acquired (unless the Assistant Secretary determines, in accordance with regulations, that there is good cause for releasing the applicant or other owner from the obligation to do so);","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the United States shall be entitled to recover from the applicant or other owner of the facility an amount which bears to the then value of the facility (or so much thereof as constituted an approved project or projects) the same ratio as the amount of such Federal funds bore to the cost of the facility financed with the aid of such funds. Such value shall be determined by agreement of the parties or by action brought in the United States district court for the district in which such facility is situated.","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc559758-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/73/tIII/s312"},"text":"Pub. L. 89–73, title III, § 312","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/95/478/tI/s103/b"},"text":"Pub. L. 95–478, title I, § 103(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-18"},"text":"Oct. 18, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1534"},"text":"92 Stat. 1534","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/171/s3/a/13"},"text":"Pub. L. 103–171, § 3(a)(13)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-02"},"text":"Dec. 2, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1990"},"text":"107 Stat. 1990","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc559759-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc55975a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbc55975b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1993—Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/171"},"text":"Pub. L. 103–171","children":[],"tail":" substituted “Assistant Secretary” for “Commissioner”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbc55975c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text"