{"tag":"section","attrib":{"id":"idbcdd8c30-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4741"},"text":null,"children":[{"tag":"num","attrib":{"value":"4741"},"text":"§ 4741.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Declaration of purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The purpose of this subchapter is to strengthen the training and development of State and local government employees and officials, particularly in professional, administrative, and technical fields.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbcdd8c31-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/648/tIII/s301"},"text":"Pub. L. 91–648, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-01-05"},"text":"Jan. 5, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1916"},"text":"84 Stat. 1916","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
