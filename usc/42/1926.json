{"tag":"section","attrib":{"id":"idbba07850-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1926"},"text":null,"children":[{"tag":"num","attrib":{"value":"1926"},"text":"§ 1926.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"It shall also be the duty of the Department of Justice to list in its annual budget request the sum of money necessary to carry out the provisions of this chapter, which sum is authorized in a sum not to exceed $5,000 per annum.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbba07851-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-08-03/ch520/s6"},"text":"Aug. 3, 1950, ch. 520, § 6","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/398"},"text":"64 Stat. 398","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
