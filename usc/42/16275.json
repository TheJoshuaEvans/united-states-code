{"tag":"section","attrib":{"id":"idc0013b24-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16275"},"text":null,"children":[{"tag":"num","attrib":{"value":"16275"},"text":"§ 16275.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Department of Energy civilian nuclear infrastructure and facilities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc0013b25-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16275/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall operate and maintain infrastructure and facilities to support the nuclear energy research, development, demonstration, and commercial application programs, including radiological facilities management, isotope production, and facilities management.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0013b26-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16275/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out this section, the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0013b27-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16275/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop an inventory of nuclear science and engineering facilities, equipment, expertise, and other assets at all of the National Laboratories;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0013b28-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16275/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop a prioritized list of nuclear science and engineering plant and equipment improvements needed at each of the National Laboratories;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0013b29-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16275/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consider the available facilities and expertise at all National Laboratories and emphasize investments which complement rather than duplicate capabilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0013b2a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16275/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop a timeline and a proposed budget for the completion of deferred maintenance on plant and equipment, with the goal of ensuring that Department programs under this part will be generally recognized to be among the best in the world.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0013b2b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16275/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Versatile neutron source","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0013b2c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16275/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0013b2d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16275/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2017-12-31"},"text":"December 31, 2017","children":[],"tail":", the Secretary shall provide for a versatile reactor-based fast neutron source, which shall operate as a national user facility."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0013b2e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16275/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultations required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out subparagraph (A), the Secretary shall consult with the private sector, institutions of higher education, the National Laboratories, and relevant Federal agencies to ensure that the user facility described in subparagraph (A) will meet the research needs of the largest practicable majority of prospective users.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0013b2f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16275/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As soon as practicable after determining the mission need under paragraph (1)(A), the Secretary shall submit to the appropriate committees of Congress a detailed plan for the establishment of the user facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0013b30-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16275/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Facility requirements","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0013b31-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16275/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Capabilities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall ensure that the user facility will provide, at a minimum, the following capabilities:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc0013b32-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16275/c/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Fast neutron spectrum irradiation capability.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc0013b33-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16275/c/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Capacity for upgrades to accommodate new or expanded research needs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0013b34-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16275/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Considerations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the plan submitted under paragraph (2), the Secretary shall consider the following:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc0013b35-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16275/c/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Capabilities that support experimental high-temperature testing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc0013b36-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16275/c/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Providing a source of fast neutrons at a neutron flux, higher than that at which current research facilities operate, sufficient to enable research for an optimal base of prospective users.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc0013b37-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16275/c/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Maximizing irradiation flexibility and irradiation volume to accommodate as many concurrent users as possible.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc0013b38-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16275/c/3/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Capabilities for irradiation with neutrons of a lower energy spectrum.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc0013b39-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16275/c/3/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Multiple loops for fuels and materials testing in different coolants.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc0013b3a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16275/c/3/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Additional pre-irradiation and post-irradiation examination capabilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc0013b3b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16275/c/3/B/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Lifetime operating costs and lifecycle costs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0013b3c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16275/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deadline for establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall, to the maximum extent practicable, complete construction of, and approve the start of operations for, the user facility by not later than ","children":[{"tag":"date","attrib":{"date":"2026-12-31"},"text":"December 31, 2026","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0013b3d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16275/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall include in the annual budget request of the Department an explanation for any delay in the progress of the Department in completing the user facility by the deadline described in paragraph (4).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0013b3e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16275/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall leverage the best practices for management, construction, and operation of national user facilities from the Office of Science.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0013b3f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16275/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated to the Secretary to carry out to completion the construction of the facility under this section—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0013b40-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16275/c/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $295,000,000 for fiscal year 2021;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0013b41-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16275/c/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $348,000,000 for fiscal year 2022;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0013b42-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16275/c/7/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $525,000,000 for fiscal year 2023;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0013b43-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16275/c/7/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $534,000,000 for fiscal year 2024; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0013b44-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16275/c/7/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $584,000,000 for fiscal year 2025.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0013b45-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16275/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Gateway for Accelerated Innovation in Nuclear","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0013b46-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16275/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the programs under this part, the Secretary is authorized to establish a new initiative to be known as the Gateway for Accelerated Innovation in Nuclear (GAIN). The initiative shall, to the maximum extent practicable and consistent with national security, provide the nuclear energy industry with access to cutting edge research and development along with the technical, regulatory, and financial support necessary to move innovative nuclear energy technologies toward commercialization in an accelerated and cost-effective fashion. The Secretary shall make available, as a minimum—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0013b47-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16275/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" experimental capabilities and testing facilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0013b48-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16275/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" computational capabilities, modeling, and simulation tools;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0013b49-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16275/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" access to existing datasets and data validation tools; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0013b4a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16275/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" technical assistance with guidance or processes as needed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0013b4b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16275/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0013b4c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16275/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall select industry partners for awards on a competitive merit-reviewed basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0013b4d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16275/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Considerations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In selecting industry partners under subparagraph (A), the Secretary shall consider—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc0013b4e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16275/d/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the information disclosed by the Department as described in paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc0013b4f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16275/d/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any existing facilities the Department will provide for public private partnership activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc0013b50-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tIX/s955"},"text":"Pub. L. 109–58, title IX, § 955","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/887"},"text":"119 Stat. 887","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/248/s2/e"},"text":"Pub. L. 115–248, § 2(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-09-28"},"text":"Sept. 28, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3156"},"text":"132 Stat. 3156","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dZ/tII/s2003/f"},"text":"Pub. L. 116–260, div. Z, title II, § 2003(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2466"},"text":"134 Stat. 2466","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc0013b51-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc0013b52-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc0013b53-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s2003/f/1/A"},"text":"Pub. L. 116–260, § 2003(f)(1)(A)","children":[],"tail":", substituted “Authorization” for “Mission need” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s2003/f/1/B"},"text":"Pub. L. 116–260, § 2003(f)(1)(B)","children":[],"tail":", substituted “provide” for “determine the mission need”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s2003/f/3"},"text":"Pub. L. 116–260, § 2003(f)(3)","children":[],"tail":", substituted “2026” for “2025”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s2003/f/2"},"text":"Pub. L. 116–260, § 2003(f)(2)","children":[],"tail":", added par. (7)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s2003/f/4"},"text":"Pub. L. 116–260, § 2003(f)(4)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/248"},"text":"Pub. L. 115–248","children":[],"tail":" added subsec. (c) and struck out former subsecs. (c) and (d) which required development of a comprehensive plan for the facilities at the Idaho National Laboratory and transmittal of the plan to Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
