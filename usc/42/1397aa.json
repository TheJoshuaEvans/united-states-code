{"tag":"section","attrib":{"id":"idbaaf8965-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"1397aa"},"text":"§ 1397aa.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose; State child health plans","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbaaf8966-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397aa/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except with respect to the rural health transformation program established in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1397ee/h"},"text":"section 1397ee(h) of this title","children":[],"tail":", the purpose of this subchapter is to provide funds to States to enable them to initiate and expand the provision of child health assistance to uninsured, low-income children in an effective and efficient manner that is coordinated with other sources of health benefits coverage for children. Such assistance shall be provided primarily for obtaining health benefits coverage through—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbaaf8967-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397aa/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" obtaining coverage that meets the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1397cc"},"text":"section 1397cc of this title","children":[],"tail":", or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaaf8968-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397aa/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing benefits under the State’s medicaid plan under subchapter XIX,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"or a combination of both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbaaf8969-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397aa/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State child health plan required","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A State is not eligible for payment under subsection (a) or (g) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1397ee"},"text":"section 1397ee of this title","children":[],"tail":" unless the State has submitted to the Secretary under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1397ff"},"text":"section 1397ff of this title","children":[],"tail":" a plan that—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbaaf896a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397aa/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sets forth how the State intends to use the funds provided under this subchapter to provide child health assistance to needy children consistent with the provisions of this subchapter, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaaf896b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397aa/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has been approved under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1397ff"},"text":"section 1397ff of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbaaf896c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397aa/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State entitlement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This subchapter constitutes budget authority in advance of appropriations Acts and represents the obligation of the Federal Government to provide for the payment to States of amounts provided under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1397dd"},"text":"section 1397dd of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbaaf896d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397aa/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No State is eligible for payments under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1397ee"},"text":"section 1397ee of this title","children":[],"tail":" for child health assistance for coverage provided for periods beginning before "},{"tag":"date","attrib":{"date":"1997-10-01"},"text":"October 1, 1997","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbaaf896e-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title XXI, § 2101, as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/33/tIV/s4901/a"},"text":"Pub. L. 105–33, title IV, § 4901(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/552"},"text":"111 Stat. 552","children":[],"tail":"; amended "},{"tag":"ref","attri