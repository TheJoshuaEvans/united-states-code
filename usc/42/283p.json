{"tag":"section","attrib":{"id":"idb55e256c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s283p"},"text":null,"children":[{"tag":"num","attrib":{"value":"283p"},"text":"§ 283p.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Population focused research","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Director of the National Institutes of Health shall, as appropriate, encourage efforts to improve research related to the health of sexual and gender minority populations, including by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb55e256d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s283p/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitating increased participation of sexual and gender minority populations in clinical research supported by the National Institutes of Health, and reporting on such participation, as applicable;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55e256e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s283p/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitating the development of valid and reliable methods for research relevant to sexual and gender minority populations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55e256f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s283p/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" addressing methodological challenges.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb55e2570-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title IV, § 404N, as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/255/dA/tII/s2038/d"},"text":"Pub. L. 114–255, div. A, title II, § 2038(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-13"},"text":"Dec. 13, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1065"},"text":"130 Stat. 1065","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb55e2571-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb55e2572-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb55e2573-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Reporting","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255/dA/tII/s2038/e"},"text":"Pub. L. 114–255, div. A, title II, § 2038(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-13"},"text":"Dec. 13, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1065"},"text":"130 Stat. 1065","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/255/dA/tII/s2038/e"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, in collaboration with the Director of the National Institutes of Health, shall as appropriate—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" continue to support research for the development of appropriate measures related to reporting health information about sexual and gender minority populations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 2 years after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2016-12-13"},"text":"Dec. 13, 2016","children":[],"tail":"], disseminate and make public such measures."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"National academy of medicine recommendations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In developing the measures described in paragraph (1)(A), the Secretary shall take into account recommendations made by the National Academy of Medicine.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
