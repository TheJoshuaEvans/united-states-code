{"tag":"section","attrib":{"id":"idb6ba5a16-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–94"},"text":null,"children":[{"tag":"num","attrib":{"value":"300gg–94"},"text":"§ 300gg–94.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ensuring that consumers get value for their dollars","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb6ba5a17-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–94/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial premium review process","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6ba5a18-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–94/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in conjunction with States, shall establish a process for the annual review, beginning with the 2010 plan year and subject to subsection (b)(2)(A), of unreasonable increases in premiums for health insurance coverage.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6ba5a19-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–94/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Justification and disclosure","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The process established under paragraph (1) shall require health insurance issuers to submit to the Secretary and the relevant State a justification for an unreasonable premium increase prior to the implementation of the increase. Such issuers shall prominently post such information on their Internet websites. The Secretary shall ensure the public disclosure of information on such increases and justifications for all health insurance issuers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6ba5a1a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–94/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continuing premium review process","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6ba5a1b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–94/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Informing Secretary of premium increase patterns","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As a condition of receiving a grant under subsection (c)(1), a State, through its Commissioner of Insurance, shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6ba5a1c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–94/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide the Secretary with information about trends in premium increases in health insurance coverage in premium rating areas in the State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6ba5a1d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–94/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make recommendations, as appropriate, to the State Exchange about whether particular health insurance issuers should be excluded from participation in the Exchange based on a pattern or practice of excessive or unjustified premium increases.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6ba5a1e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–94/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Monitoring by Secretary of premium increases","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6ba5a1f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–94/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Beginning with plan years beginning in 2014, the Secretary, in conjunction with the States and consistent with the provisions of subsection (a)(2), shall monitor premium increases of health insurance coverage offered through an Exchange and outside of an Exchange.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6ba5a20-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–94/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consideration in opening Exchange","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In determining under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s18032/f/2/B"},"text":"section 18032(f)(2)(B) of this title","children":[],"tail":" whether to offer qualified health plans in the large group market through an Exchange, the State shall take into account any excess of premium growth outside of the Exchange as compared to the rate of such growth inside the Exchange."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6ba5a21-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–94/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants in support of process","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6ba5a22-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–94/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Premium review grants during 2010 through 2014","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall carry out a program to award grants to States during the 5-year period beginning with fiscal year 2010 to assist such States in carrying out subsection (a), including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6ba5a23-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–94/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in reviewing and, if appropriate under State law, approving premium increases for health insurance coverage;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6ba5a24-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–94/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in providing information and recommendations to the Secretary under subsection (b)(1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6ba5a25-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–94/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in establishing centers (consistent with subsection (d)) at academic or other nonprofit institutions to collect medical reimbursement information from health insurance issuers, to analyze and organize such information, and to make such information available to such issuers, health care providers, health researchers, health care policy makers, and the general public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6ba5a26-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–94/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6ba5a27-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–94/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Out of all funds in the Treasury not otherwise appropriated, there are appropriated to the Secretary $250,000,000, to be available for expenditure for grants under paragraph (1) and subparagraph (B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6ba5a28-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–94/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Further availability for insurance reform and consumer protection","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the amounts appropriated under subparagraph (A) are not fully obligated under grants under paragraph (1) by the end of fiscal year 2014, any remaining funds shall remain available to the Secretary for grants to States for planning and implementing the insurance reforms and consumer protections under part A.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6ba5a29-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–94/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall establish a formula for determining the amount of any grant to a State under this subsection. Under such formula—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb6ba5a2a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–94/c/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary shall consider the number of plans of health insurance coverage offered in each State and the population of the State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6ba5a2b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–94/c/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no State qualifying for a grant under paragraph (1) shall receive less than $1,000,000, or more than $5,000,000 for a grant year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6ba5a2c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–94/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Parity implementation","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6ba5a2d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–94/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Beginning during the first fiscal year that begins after ","children":[{"tag":"date","attrib":{"date":"2022-12-29"},"text":"December 29, 2022","children":[],"tail":", the Secretary shall, out of funds made available pursuant to subparagraph (C), award grants to eligible States to enforce and ensure compliance with the mental health and substance use disorder parity provisions of section 300gg––26 of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6ba5a2e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–94/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible State","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A State shall be eligible for a grant awarded under this paragraph only if such State—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb6ba5a2f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–94/c/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submits to the Secretary an application for such grant at such time, in such manner, and containing such information as specified by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6ba5a30-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–94/c/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" agrees to request and review from health insurance issuers offering group or individual health insurance coverage the comparative analyses and other information required of such health insurance issuers under subsection (a)(8)(A) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300gg–26"},"text":"section 300gg–26 of this title","children":[],"tail":" relating to the design and application of nonquantitative treatment limitations imposed on mental health or substance use disorder benefits."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6ba5a31-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–94/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated $10,000,000 for each of the first five fiscal years beginning after ","children":[{"tag":"date","attrib":{"date":"2022-12-29"},"text":"December 29, 2022","children":[],"tail":", to remain available until expended, for purposes of awarding grants under subparagraph (A)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6ba5a32-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–94/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Medical reimbursement data centers","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6ba5a33-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–94/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A center established under subsection (c)(1)(C) shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6ba5a34-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–94/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop fee schedules and other database tools that fairly and accurately reflect market rates for medical services and the geographic differences in those rates;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6ba5a35-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–94/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use the best available statistical methods and data processing technology to develop such fee schedules and other database tools;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6ba5a36-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–94/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" regularly update such fee schedules and other database tools to reflect changes in charges for medical services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6ba5a37-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–94/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make health care cost information readily available to the public through an Internet website that allows consumers to understand the amounts that health care providers in their area charge for particular medical services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6ba5a38-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–94/d/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" regularly publish information concerning the statistical methodologies used by the center to analyze health charge data and make such data available to researchers and policy makers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6ba5a39-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–94/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conflicts of interest","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A center established under subsection (c)(1)(C) shall adopt by-laws that ensures that the center (and all members of the governing board of the center) is independent and free from all conflicts of interest. Such by-laws shall ensure that the center is not controlled or influenced by, and does not have any corporate relation to, any individual or entity that may make or receive payments for health care services based on the center’s analysis of health care costs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6ba5a3a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–94/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subsection shall be construed to permit a center established under subsection (c)(1)(C) to compel health insurance issuers to provide data to the center.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb6ba5a3b-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XXVII, § 2794, as added and amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tI/s1003"},"text":"Pub. L. 111–148, title I, § 1003","children":[],"tail":", title X, § 10101(i), "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/139"},"text":"124 Stat. 139","children":[],"tail":", 891; "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dFF/tI/s1331/a"},"text":"Pub. L. 117–328, div. FF, title I, § 1331(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5698"},"text":"136 Stat. 5698","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb6ba5a3c-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb6ba5a3d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb6ba5a3e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2794 of act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", was renumbered section 2795 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300gg–95"},"text":"section 300gg–95 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb6ba5a3f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328"},"text":"Pub. L. 117–328","children":[],"tail":" added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—Subsec. (c)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/s10101/i/1"},"text":"Pub. L. 111–148, § 10101(i)(1)","children":[],"tail":", added subpar. (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/s10101/i/2"},"text":"Pub. L. 111–148, § 10101(i)(2)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb6ba5a40-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb6ba5a41-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective for fiscal years beginning with fiscal year 2010, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/s1004/a"},"text":"section 1004(a) of Pub. L. 111–148","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300gg–11"},"text":"section 300gg–11 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/s1004/b"},"text":"section 1004(b) of Pub. L. 111–148","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300gg–11"},"text":"section 300gg–11 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
