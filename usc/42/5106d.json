{"tag":"section","attrib":{"id":"idbd0167f4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5106d"},"text":null,"children":[{"tag":"num","attrib":{"value":"5106d"},"text":"§ 5106d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Miscellaneous requirements relating to assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd0167f5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5106d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction of facilities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd0167f6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5106d/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restriction on use of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Assistance provided under this subchapter and subchapter III may not be used for construction of facilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd0167f7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5106d/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lease, rental, or repair","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may authorize the use of funds received under this subchapter and subchapter III—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd0167f8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5106d/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" where adequate facilities are not otherwise available, for the lease or rental of facilities; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd0167f9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5106d/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the repair or minor remodeling or alteration of existing facilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd0167fa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5106d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Geographical distribution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish criteria designed to achieve equitable distribution of assistance under this subchapter and subchapter III among the States, among geographic areas of the Nation, and among rural and urban areas of the Nation. To the extent possible, the Secretary shall ensure that the citizens of each State receive assistance from at least one project under this subchapter and subchapter III.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd0167fb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5106d/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No funds appropriated for any grant or contract pursuant to authorizations made in this subchapter and subchapter III may be used for any purpose other than that for which such funds were authorized to be appropriated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd0167fc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5106d/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sense of Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is the sense of Congress that the Secretary should encourage all States and public and private entities that receive assistance under this subchapter to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd0167fd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5106d/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that children and families with limited English proficiency who participate in programs under this subchapter are provided with materials and services through such programs in an appropriate language other than English; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd0167fe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5106d/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that individuals with disabilities who participate in programs under this subchapter are provided with materials and services through such programs that are appropriate to their disabilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd0167ff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5106d/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State that receives funds under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5106a/a"},"text":"section 5106a(a) of this title","children":[],"tail":" shall annually prepare and submit to the Secretary a report describing the manner in which funds provided under this subchapter and subchapter III, alone or in combination with other Federal funds, were used to address the purposes and achieve the objectives of "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5106a"},"text":"section 5106a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd016800-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/247/tI/s108"},"text":"Pub. L. 93–247, title I, § 108","children":[],"tail":", formerly § 11, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/294/tI/s101"},"text":"Pub. L. 100–294, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-04-25"},"text":"Apr. 25, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/115"},"text":"102 Stat. 115","children":[],"tail":"; renumbered title I, § 110, "},{"tag":"ref","attrib":{"href":"/us/pl/101/126/s3/a/1"},"text":"Pub. L. 101–126, § 3(a)(1)","children":[],"tail":", (2), "},{"tag":"date","attrib":{"date":"1989-10-25"},"text":"Oct. 25, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/764"},"text":"103 Stat. 764","children":[],"tail":"; renumbered § 108 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/235/tI"},"text":"Pub. L. 104–235, title I","children":[],"tail":", §§ 109, 113(a)(1)(B), "},{"tag":"date","attrib":{"date":"1996-10-03"},"text":"Oct. 3, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3078"},"text":"110 Stat. 3078","children":[],"tail":", 3079; "},{"tag":"ref","attrib":{"href":"/us/pl/108/36/tI/s116"},"text":"Pub. L. 108–36, title I, § 116","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-06-25"},"text":"June 25, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/812"},"text":"117 Stat. 812","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/320/tI/s117"},"text":"Pub. L. 111–320, title I, § 117","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-20"},"text":"Dec. 20, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3475"},"text":"124 Stat. 3475","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd016801-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd016802-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbd016803-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/247/s108"},"text":"section 108 of Pub. L. 93–247","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5106b"},"text":"section 5106b of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/104/235"},"text":"Pub. L. 104–235","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd016804-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/320"},"text":"Pub. L. 111–320","children":[],"tail":" amended subsec. (d) generally. Prior to amendment, text read as follows: “It is the sense of Congress that the Secretary should encourage all States and public and private agencies or organizations that receive assistance under this subchapter to ensure that children and families with limited English proficiency who participate in programs under this subchapter are provided materials and services under such programs in an appropriate language other than English.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—Subsecs. (d), (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/36"},"text":"Pub. L. 108–36","children":[],"tail":" added subsecs. (d) and (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/235"},"text":"Pub. L. 104–235","children":[],"tail":" redesignated subsec. (d) as (c) and struck out heading and text of former subsec. (c). Text read as follows: “The Secretary, in consultation with the task force and the board, shall ensure that a majority share of assistance under this subchapter and subchapters III and V of this chapter is available for discretionary research and demonstration grants.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
