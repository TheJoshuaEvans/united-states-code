en":[],"tail":null},{"tag":"content","attrib":{},"text":" power interchange between directly connected balancing authorities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc067c58f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18772/c/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expanding Regional Transmission Organization balancing authorities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc067c590-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18772/c/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" improvements in real-time—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc067c591-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18772/c/2/I/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accuracy of locational marginal prices; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc067c592-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18772/c/2/I/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" signals to flexible demand; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc067c593-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18772/c/2/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disruptions to grid operations, including disruptions caused by cyber sources, physical sources, extreme weather events, or other sources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc067c594-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18772/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distribution system operations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc067c595-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18772/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2021-11-15"},"text":"November 15, 2021","children":[],"tail":", the Administrator shall establish a system to provide to the public timely data on the operations of load-serving entities in the electricity grids of the United States."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc067c596-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18772/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc067c597-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18772/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out paragraph (1), the Administrator shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc067c598-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18772/d/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" not less frequently than annually, provide data on—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idc067c599-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18772/d/2/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the delivered generation resource mix for each load-serving entity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc067c59a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18772/d/2/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the distributed energy resources operating within each service area of a load-serving entity;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc067c59b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18772/d/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" harmonize the data on delivered generation resource mix described in clause (i)(I) with measurements of greenhouse gas emissions collected by the Environmental Protection Agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc067c59c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18772/d/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the maximum extent practicable, disseminate the data described in clause (i)(I) and the harmonized data described in clause (ii) on a real-time basis; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc067c59d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18772/d/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide historical data, beginning with the earliest calendar year practicable, but not later than calendar year 2020, on the delivered generation resource mix described in clause (i)(I).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc067c59e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18772/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data on the delivered generation resource mix","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In collecting the data described in subparagraph (A)(i)(I), the Administrator shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc067c59f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18772/d/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use existing voluntary industry methodologies, including reporting protocols, databases, and emissions and energy use tracking software that provide consistent, timely, and accessible carbon emissions intensity rates for delivered electricity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc067c5a0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18772/d/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consider that generation and transmission entities may provide data on behalf of load-serving entities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc067c5a1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18772/d/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent that the Administrator determines necessary, and in a manner designed to protect confidential information, require each load-serving entity to submit additional information as needed to determine the delivered generation resource mix of the load-serving entity, including financial or contractual agreements for power and generation resource type attributes with respect to power owned by or retired by the load-serving entity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc06a0e92-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18772/d/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for any portion of the generation resource mix of a load-serving entity that is otherwise unaccounted for, develop a methodology to assign to the load-serving entity a share of the otherwise unaccounted for resource mix of the relevant balancing authority.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc06a0e93-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dD/tIV/s40412"},"text":"Pub. L. 117–58, div. D, title IV, § 40412","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1039"},"text":"135 Stat. 1039","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc06a0e94-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc06a0e95-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc06a0e96-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Wage Rate Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions relating to rates of wages to be paid to laborers and mechanics on projects for construction, alteration, or repair work funded under div. D or an amendment by div. D of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":", including authority of Secretary of Labor, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s18851"},"text":"section 18851 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
