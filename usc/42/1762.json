{"tag":"section","attrib":{"id":"idbb5b3259-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1762"},"text":null,"children":[{"tag":"num","attrib":{"value":"1762"},"text":"§ 1762.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Summer electronic benefits transfer for children program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbb5b325a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1762/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program established","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall establish a program under which States and covered Indian Tribal organizations electing to participate in such program shall, beginning with summer 2024 and annually for each summer thereafter, issue to each eligible household summer electronic benefit transfer benefits (referred to in this section as “summer EBT benefits”)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb5b325b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1762/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in accordance with this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb5b325c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1762/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the purpose of providing nutrition assistance through electronic benefit transfer or methods described in clauses (ii) and (iii) of subsection (b)(2)(B) during the summer months for each eligible child, to ensure continued access to food when school is not in session for the summer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb5b325d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1762/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Summer EBT benefits requirements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb5b325e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1762/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purchase options","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbb5b325f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1762/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Benefits issued by states","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Summer EBT benefits issued pursuant to subsection (a) by a State may only be used by the eligible household that receives such summer EBT benefits to purchase food (as defined in section 3 of the Food and Nutrition Act of 2008 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2012"},"text":"7 U.S.C. 2012","children":[],"tail":")) from retail food stores that have been approved for participation in the supplemental nutrition assistance program established under such Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2011"},"text":"7 U.S.C. 2011","children":[],"tail":" et seq.] and in accordance with section 7(b) of such Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2016/b"},"text":"7 U.S.C. 2016(b)","children":[],"tail":") or in the nutrition assistance program in American Samoa, the Commonwealth of Puerto Rico, and the Commonwealth of the Northern Mariana Islands."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb5b3260-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1762/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Benefits issued by covered Indian Tribal organizations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Summer EBT benefits issued pursuant to subsection (a) by a covered Indian Tribal organization may only be used by the eligible household that receives such summer EBT benefits to purchase supplemental foods from vendors that have been approved for participation in the special supplemental nutrition program for women, infants, and children under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1786"},"text":"section 1786 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb5b3261-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1762/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Summer EBT benefits issued pursuant to subsection (a)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbb5b3262-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1762/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall be—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbb5b3263-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1762/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for calendar year 2024, in an amount equal to $40, which may be proportionately higher consistent with the adjustments established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1760/f"},"text":"section 1760(f) of this title","children":[],"tail":" for each eligible child in the eligible household per month during the summer operational period; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbb5b3264-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1762/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for calendar year 2025 and each year thereafter, in an amount equal to the unrounded benefit amount from the prior year, adjusted to the nearest lower dollar increment to reflect changes to the cost of the diet described in section 3(u) of the Food and Nutrition Act of 2008 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2012/u"},"text":"7 U.S.C. 2012(u)","children":[],"tail":") for the 12-month period ending on November 30 of the preceding calendar year and rounded to the nearest lower dollar increment; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb5b3265-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1762/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" may be issued—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbb5b3266-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1762/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the form of an EBT card;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbb5b3267-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1762/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" through other electronic methods, as determined by the Secretary; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbb5b3268-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1762/b/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a State that does not issue nutrition assistance program benefits electronically, using the same methods by which that State issues benefits under the nutrition assistance program of that State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb5b3269-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1762/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Summer EBT benefits issued pursuant to subsection (a) shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbb5b326a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1762/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be subject to sections 12, 14, and 15 of the Food and Nutrition Act of 2008 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2021"},"text":"7 U.S.C. 2021","children":[],"tail":", 2023, 2024) and subsections (n), ("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":"), and (p) of "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1786"},"text":"section 1786 of this title","children":[],"tail":", as applicable; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb5b326b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1762/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the maximum extent practicable, incorporate technology tools consistent with industry standards that track or prevent theft of benefits, cloning, or other fraudulent activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb5b326c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1762/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timing","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbb5b326d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1762/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subparagraph (B), summer EBT benefits issued pursuant to subsection (a) may only be issued for the purpose of purchasing food during the summer months, with appropriate issuance and expungement timelines as determined by the Secretary (but with an expungement timeline not to exceed 4 months).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb5b326e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1762/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continuous school calendar","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of children who are under a continuous school calendar, the Secretary shall establish alternative plans for the period during which summer EBT benefits may be issued pursuant to subsection (a) and used.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb5b326f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1762/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enrollment in program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb5b3270-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1762/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"States that elect to participate in the program under this section shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbb5b3271-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1762/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to summer, automatically enroll each eligible child who is directly certified, is an identified student (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1759a/a/1/F/i"},"text":"section 1759a(a)(1)(F)(i) of this title","children":[],"tail":"), or is otherwise determined by a school food authority to be eligible to receive free or reduced price meals in the instructional year immediately preceding the summer or during the summer operational period in the program under this section, without further application from households;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb5b3272-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1762/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make an application available for children who do not meet the criteria described in subparagraph (A) and make eligibility determinations using the eligibility criteria for free or reduced price lunches under this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb5b3273-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1762/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish procedures to carry out the enrollment described in subparagraph (A);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb5b3274-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1762/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish procedures for expunging summer EBT benefits from the account of a household, consistent with the requirements under subsection (b)(4); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb5b3275-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1762/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allow eligible households to opt out of participation in the program under this section and establish procedures for opting out of such participation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb5b3276-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1762/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered Indian Tribal organization requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Covered Indian Tribal organizations participating in the program under this section shall, to the maximum extent practicable, meet the requirements under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb5b3277-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1762/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall pay to each State agency and covered Indian Tribal organization an amount equal to 50 percent of the administrative expenses incurred by the State agency or covered Indian Tribal organization in operating the program under this section, including the administrative expenses of local educational agencies and other agencies in each State or covered Indian Tribal organization relating to the operation of the program under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb5b3278-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1762/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Summer EBT authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Beginning in summer 2024, the Secretary shall not allow States to use the authority in section 749(g) of the Agriculture, Rural Development, Food and Drug Administration, and Related Agencies Appropriations Act, 2010 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/80"},"text":"Public Law 111–80","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/123/2132"},"text":"123 Stat. 2132","children":[],"tail":"), to provide access to food through electronic benefit transfer benefits to children during the summer months when schools are not in regular session."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb5b3279-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1762/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Issuance of interim final regulations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2022-12-29"},"text":"December 29, 2022","children":[],"tail":", the Secretary shall promulgate regulations (which shall include interim final regulations) to carry out this section, including provisions that—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb5b327a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1762/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" incorporate best practices and lessons learned from demonstration projects under—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbb5b327b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1762/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 749(g) of the Agriculture, Rural Development, Food and Drug Administration, and Related Agencies Appropriations Act, 2010 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/80"},"text":"Public Law 111–80","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/123/2132"},"text":"123 Stat. 2132","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb5b327c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1762/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the pandemic EBT program under section 1101 of the Families First Coronavirus Response Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2011"},"text":"7 U.S.C. 2011","children":[],"tail":" note; "},{"tag":"ref","attrib":{"href":"/us/pl/116/127"},"text":"Public Law 116–127","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb5b327d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1762/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure timely and fair service to applicants for and recipients of benefits under this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb5b327e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1762/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" establish quality assurance and program integrity procedures to ensure that States and local educational agencies have adequate processes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbb5b327f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1762/f/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to correctly determine the eligibility of children for benefits under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb5b3280-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1762/f/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to reliably enroll and issue benefits to eligible children; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb5b3281-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1762/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" allow States and covered Indian Tribal organizations to streamline program administration, including by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbb5b3282-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1762/f/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" automatically enrolling each eligible child who is able to be directly certified; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb5b3283-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1762/f/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing a single summer operational period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb5b3284-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1762/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative and management plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Beginning in 2024, each State desiring to participate in the program under this section shall comply with the requirements under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1761/n"},"text":"section 1761(n) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb5b3285-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1762/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb5b3286-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1762/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered Indian Tribal organization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “covered Indian Tribal organization” means an Indian Tribal organization that participates in the special supplemental nutrition program for women, infants, and children established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1786"},"text":"section 1786 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb5b3287-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1762/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible child","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible child” means, with respect to a summer, a child who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbb5b3288-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1762/h/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" was, at the end of the instructional year immediately preceding such summer or during the summer operational period—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbb5b3289-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1762/h/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" certified to receive free or reduced price lunch under the school lunch program under this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbb5b328a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1762/h/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" certified to receive free or reduced price breakfast under the school breakfast program under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1773"},"text":"section 1773 of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbb5b328b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1762/h/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" able to be directly certified;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb5b328c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1762/h/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" was, at the end of the instructional year immediately preceding such summer—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbb5b328d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1762/h/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enrolled in a school described in subparagraph (B), (C), (D), (E), or (F) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1759a/a/1"},"text":"section 1759a(a)(1) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbb5b328e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1762/h/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbb5b328f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1762/h/2/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an identified student (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1759a/a/1/F/i"},"text":"section 1759a(a)(1)(F)(i) of this title","children":[],"tail":"); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbb5b3290-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1762/h/2/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a child who otherwise met the requirements to receive free or reduced price meals, as determined through an application process using the eligibility criteria for free or reduced price meals under this chapter; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb5b3291-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1762/h/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has been determined to be eligible for the program under this section in accordance with subsection (c)(1)(B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb5b3292-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1762/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible household","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “eligible household” means a household that includes at least 1 eligible child.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb5b3293-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1762/h/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supplemental foods","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “supplemental foods”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbb5b3294-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1762/h/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" means foods—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbb5b3295-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1762/h/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" containing nutrients determined by nutritional research to be lacking in the diets of children; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbb5b3296-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1762/h/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that promote the health of the population served by the program under this section, as indicated by relevant nutrition science, public health concerns, and cultural eating patterns, as determined by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb5b3297-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1762/h/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" includes foods not described in subparagraph (A) substituted by State agencies, with the approval of the Secretary, that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbb5da298-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1762/h/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide the nutritional equivalent of foods described in such subparagraph; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbb5da299-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1762/h/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allow for different cultural eating patterns than foods described in such subparagraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbb5da29a-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-06-04/ch281/s13A"},"text":"June 4, 1946, ch. 281, § 13A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dHH/tIV/s502/c"},"text":"Pub. L. 117–328, div. HH, title IV, § 502(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5990"},"text":"136 Stat. 5990","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbb5da29b-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbb5da29c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbb5da29d-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Food and Nutrition Act of 2008, referred to in subsec. (b)(1)(A), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/525"},"text":"Pub. L. 88–525","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-08-31"},"text":"Aug. 31, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/703"},"text":"78 Stat. 703","children":[],"tail":", which is classified generally to chapter 51 (§ 2011 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2011"},"text":"section 2011 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 749(g) of the Agriculture, Rural Development, Food and Drug Administration, and Related Agencies Appropriations Act, 2010, referred to in subsecs. (e) and (f)(1)(A), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/80/s749/g"},"text":"section 749(g) of Pub. L. 111–80","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-21"},"text":"Oct. 21, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2132"},"text":"123 Stat. 2132","children":[],"tail":", which is not classified to the Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbb5da29e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1762, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-06-04/ch281/s13A"},"text":"act June 4, 1946, ch. 281, § 13A","children":[],"tail":", as added "},{"tag":"date","attrib":{"date":"1970-03-12"},"text":"Mar. 12, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/91/207"},"text":"Pub. L. 91–207","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/51"},"text":"84 Stat. 51","children":[],"tail":", related to emergency assistance to provide nutritious meals to needy children in schools, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/101/147/tIII/s308"},"text":"Pub. L. 101–147, title III, § 308","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-10"},"text":"Nov. 10, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/915"},"text":"103 Stat. 915","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbb5da29f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbb5da2a0-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"No Duplication of Summer Benefits","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/dHH/tIV/s502/e"},"text":"Pub. L. 117–328, div. HH, title IV, § 502(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5994"},"text":"136 Stat. 5994","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/328/dHH/tIV/s502/e"},"text":"“A State may not provide to a household summer EBT benefits (as described in section 13A(a) of the Richard B. Russell National School Lunch Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1762/a"},"text":"42 U.S.C. 1762(a)","children":[],"tail":"]) under that section and benefits under section 1101(i) of the Families First Coronavirus Response Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2011"},"text":"7 U.S.C. 2011","children":[],"tail":" note; "},{"tag":"ref","attrib":{"href":"/us/pl/116/127"},"text":"Public Law 116–127","children":[],"tail":") for the same period.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
