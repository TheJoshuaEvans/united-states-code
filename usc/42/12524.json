{"tag":"section","attrib":{"id":"idbf7219bd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12524"},"text":null,"children":[{"tag":"num","attrib":{"value":"12524"},"text":"§ 12524.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allotments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf7219be-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12524/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian tribes and territories","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the amounts appropriated to carry out this part for any fiscal year, the Corporation shall reserve an amount of not less than 2 percent and not more than 3 percent for payments to Indian tribes, the United States Virgin Islands, Guam, American Samoa, and the Commonwealth of the Northern Mariana Islands, to be allotted in accordance with their respective needs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf7219bf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12524/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allotments through States","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf7219c0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12524/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"After reserving an amount under subsection (a), the Corporation shall use the remainder of the funds appropriated to carry out this part for the fiscal year as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf7219c1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12524/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allotments based on school-age youth","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"From 50 percent of such remainder, the Corporation shall allot to each State an amount that bears the same ratio to 50 percent of such remainder as the number of school-age youth in the State bears to the total number of school-age youth in all States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf7219c2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12524/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allotments based on allocations under Elementary and Secondary Education Act of 1965","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"From 50 percent of such remainder, the Corporation shall allot to each State an amount that bears the same ratio to 50 percent of such remainder as the allocation to the State for the previous fiscal year under title I of the Elementary and Secondary Education Act of 1965 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"20 U.S.C. 6301","children":[],"tail":" et seq.) bears to the total of such allocations to all States."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf7219c3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12524/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For any fiscal year for which amounts appropriated for this division exceed $50,000,000, the minimum allotment to each State under paragraph (1) shall be $75,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf7219c4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12524/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reallotment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Corporation determines that the allotment of a State, territory, or Indian tribe under this section will not be required for a fiscal year because the State, territory, or Indian tribe did not submit and receive approval of an application for the allotment under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12525"},"text":"section 12525 of this title","children":[],"tail":", the Corporation shall make the allotment for such State, territory, or Indian tribe available for grants to community-based entities to carry out service-learning programs as described in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12523/b"},"text":"section 12523(b) of this title","children":[],"tail":" in such State, in such territory, or for such Indian tribe. After community-based entities apply for grants from the allotment, by submitting an application at such time and in such manner as the Corporation requires, and receive approval, the remainder of such allotment shall be available for reallotment to such other States, territories, or Indian tribes with approved applications submitted under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12525"},"text":"section 12525 of this title","children":[],"tail":" as the Corporation may determine to be appropriate."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf7219c5-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/610/tI/s112A"},"text":"Pub. L. 101–610, title I, § 112A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/13/tI/s1201"},"text":"Pub. L. 111–13, title I, § 1201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-04-21"},"text":"Apr. 21, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1470"},"text":"123 Stat. 1470","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf7219c6-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf7219c7-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbf7219c8-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Elementary and Secondary Education Act of 1965, referred to in subsec. (b)(1)(B), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10"},"text":"Pub. L. 89–10","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-04-11"},"text":"Apr. 11, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/27"},"text":"79 Stat. 27","children":[],"tail":". Title I of the Act is classified generally to subchapter I (§ 6301 et seq.) of chapter 70 of Title 20, Education. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of Title 20","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbf7219c9-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 12524, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/610/tI/s112"},"text":"Pub. L. 101–610, title I, § 112","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/tI/s103/a/2"},"text":"Pub. L. 103–82, title I, § 103(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-09-21"},"text":"Sept. 21, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/827"},"text":"107 Stat. 827","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/tIII"},"text":"Pub. L. 103–382, title III","children":[],"tail":", §§ 391(y), 394(h)(2), "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4026"},"text":"108 Stat. 4026","children":[],"tail":", 4028, related to grants and allotments, prior to the general amendment of this part by "},{"tag":"ref","attrib":{"href":"/us/pl/111/13"},"text":"Pub. L. 111–13","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 12524, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/610/tI/s114"},"text":"Pub. L. 101–610, title I, § 114","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3135"},"text":"104 Stat. 3135","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/10/s4/4"},"text":"Pub. L. 102–10, § 4(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-03-12"},"text":"Mar. 12, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/30"},"text":"105 Stat. 30","children":[],"tail":", related to local applications for assistance, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/s103/a/2"},"text":"Pub. L. 103–82, § 103(a)(2)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbf7219ca-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbf7219cb-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2009-10-01"},"text":"Oct. 1, 2009","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/111/13/s6101/a"},"text":"section 6101(a) of Pub. L. 111–13","children":[],"tail":", set out as an Effective Date of 2009 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4950"},"text":"section 4950 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
