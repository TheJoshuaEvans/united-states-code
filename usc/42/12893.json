{"tag":"section","attrib":{"id":"idbfa8e1a5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12893"},"text":null,"children":[{"tag":"num","attrib":{"value":"12893"},"text":"§ 12893.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation grants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfa8e1a6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12893/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to make implementation grants to applicants for the purpose of carrying out homeownership programs approved under this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfa8e1a7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12893/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Implementation grants may be used for activities to carry out homeownership programs (which may include programs for cooperative ownership), including the following activities:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfa8e1a8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12893/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Architectural and engineering work.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfa8e1a9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12893/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Acquisition of the property for the purpose of transferring ownership to eligible families in accordance with a homeownership program meeting the requirements of this part.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfa8e1aa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12893/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Rehabilitation of the property covered by the homeownership program, in accordance with standards established by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfa8e1ab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12893/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Abatement of lead-based paint hazards, as required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4822/a"},"text":"section 4822(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfa8e1ac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12893/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Administrative costs of the applicant, which may not exceed 15 percent of the amount of assistance provided under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfa8e1ad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12893/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Counseling and training of homebuyers and homeowners under the homeownership program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfa8e1ae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12893/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Relocation of eligible families who elect to move.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfa8e1af-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12893/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any necessary temporary relocation of homebuyers during rehabilitation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfa8e1b0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12893/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Legal fees.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfa8e1b1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12893/b/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Defraying costs for the ongoing training needs of the recipient that are related to developing and carrying out the homeownership program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfa8e1b2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12893/b/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Economic development activities that promote economic self-sufficiency of homebuyers and homeowners under the homeownership program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfa8e1b3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12893/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matching funding","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfa8e1b4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12893/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each recipient shall assure that contributions equal to not less than 25 percent of the grant amounts under this section are provided from non-Federal sources to carry out the homeownership program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfa8e1b5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12893/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Such contributions may be in the form of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfa8e1b6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12893/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cash contributions from non-Federal resources which may not include funds from a grant made under section 5306(b) or ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5306/d"},"text":"section 5306(d) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfa8e1b7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12893/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" payment of administrative expenses, as defined by the Secretary, from non-Federal resources, including funds from a grant made under section 5306(b) or ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5306/d"},"text":"section 5306(d) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfa8e1b8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12893/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the value of taxes, fees, or other charges that are normally and customarily imposed but are waived, foregone, or deferred in a manner that facilitates the implementation of a homeownership program assisted under this part;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfa8e1b9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12893/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the value of investment in on-site and off-site infrastructure required for a homeownership program assisted under this part; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfa8e1ba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12893/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other in-kind contributions as the Secretary may approve.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Contributions for administrative expenses shall be recognized only up to an amount equal to 7 percent of the total amount of grants made available under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfa8e1bb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12893/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfa8e1bc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12893/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form and procedure","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An application for an implementation grant shall be submitted by an applicant in such form and in accordance with such procedures as the Secretary shall establish.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfa8e1bd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12893/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall require that an application contain at a minimum—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfa8e1be-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12893/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a request for an implementation grant, specifying the amount of the grant requested and its proposed uses;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfa8e1bf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12893/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the qualifications and experience of the applicant in providing low-income housing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfa8e1c0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12893/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the proposed homeownership program, consistent with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12894"},"text":"section 12894 of this title","children":[],"tail":" and the other requirements of this part specifying the activities proposed to be carried out and their estimated costs, identifying reasonable schedules for carrying it out, and demonstrating that the program will comply with the affordability requirements under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12894/b"},"text":"section 12894(b) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfa8e1c1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12893/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an identification and description of the properties to be acquired under the homeownership program and a description of the composition of potential eligible families, including family size and income;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfa8e1c2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12893/d/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of and commitment for the resources that are expected to be made available to provide the matching funding required under subsection (c) and of other resources that are expected to be made available in support of the homeownership program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfa8e1c3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12893/d/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identification and description of the financing proposed for any (i) rehabilitation and (ii) acquisition (I) of the project, where applicable, by an entity for transfer to eligible families, and (II) by eligible families of ownership interests in, or shares representing, units in the project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfa8e1c4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12893/d/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the proposed sales prices for the properties, the basis for such price determinations, and terms to an entity, if any, that will purchase that property for resale to eligible families;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfa8e1c5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12893/d/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the proposed sales prices, if any, and terms to eligible families;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfa8e1c6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12893/d/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identification and description of the entity that will operate and manage the property;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfa8e1c7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12893/d/2/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a certification by the public official responsible for submitting the comprehensive housing affordability strategy under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12705"},"text":"section 12705 of this title","children":[],"tail":" that the proposed activities are consistent with the approved housing strategy of the State or unit of general local government within which the project is located (or, during the first 12 months after "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"November 28, 1990","children":[],"tail":", that the application is consistent with such other existing State or local housing plan or strategy that the Secretary shall determine to be appropriate); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfa8e1c8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12893/d/2/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a certification that the applicant will comply with the requirements of the Fair Housing Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3601"},"text":"42 U.S.C. 3601","children":[],"tail":" et seq.], title VI of the Civil Rights Act of 1964 ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2000d"},"text":"42 U.S.C. 2000d","children":[],"tail":" et seq.], section 504 of the Rehabilitation Act of 1973 ["},{"tag":"ref","attrib":{"href":"/us/usc/t29/s794"},"text":"29 U.S.C. 794","children":[],"tail":"], and the Age Discrimination Act of 1975 ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s6101"},"text":"42 U.S.C. 6101","children":[],"tail":" et seq.], and will affirmatively further fair housing."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfa8e1c9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12893/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall establish selection criteria for assistance under this part, which shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfa8e1ca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12893/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the ability of the applicant to develop and carry out the proposed homeownership program, taking into account the qualifications and experience of the applicant and the quality of any related ongoing program of the applicant;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfa8e1cb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12893/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the feasibility of the homeownership program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfa8e1cc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12893/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the quality and viability of the proposed homeownership program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfa8e1cd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12893/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which suitable eligible property is available for use under the program in the area to be served, and the extent to which the types of property expected to be covered by the proposed homeownership program are federally owned;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfa8e1ce-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12893/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether the approved comprehensive housing affordability strategy for the jurisdiction within which the eligible property is located includes the proposed homeownership program as one of the general priorities identified pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12705/b/7"},"text":"section 12705(b)(7) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfa8e1cf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12893/e/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" national geographic diversity among housing for which applicants are selected to receive assistance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfa8e1d0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12893/e/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which a sufficient supply of affordable rental housing of the type assisted under this part exists in the locality, so that the implementation of the homeownership program will not appreciably reduce the number of such rental units available to residents currently residing in such units or eligible for residency in such units.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfa8e1d1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12893/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall notify each applicant, not later than 6 months after the date of the submission of the application, whether the application is approved or not approved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfa8e1d2-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/625/tIV/s443"},"text":"Pub. L. 101–625, title IV, § 443","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4174"},"text":"104 Stat. 4174","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/550/tX/s1012/j/2"},"text":"Pub. L. 102–550, title X, § 1012(j)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3906"},"text":"106 Stat. 3906","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/233/tII/s221"},"text":"Pub. L. 103–233, title II, § 221","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-04-11"},"text":"Apr. 11, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/366"},"text":"108 Stat. 366","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbfa8e1d3-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbfa8e1d4-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbfa8e1d5-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Fair Housing A