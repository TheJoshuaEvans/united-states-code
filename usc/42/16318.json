{"tag":"section","attrib":{"id":"idc00d217c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16318"},"text":null,"children":[{"tag":"num","attrib":{"value":"16318"},"text":"§ 16318.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fission and fusion energy materials research program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc00d217d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16318/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Along with the budget request of the President submitted to Congress for fiscal year 2007, the Secretary shall establish a research and development program on material science issues presented by advanced fission reactors and the fusion energy program of the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc00d217e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16318/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the program, the Secretary shall develop—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc00d217f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16318/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a catalog of material properties required for applications described in subsection (a);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00d2180-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16318/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" theoretical models for materials possessing the required properties;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00d2181-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16318/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" benchmark models against existing data; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00d2182-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16318/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a roadmap to guide further research and development in the area covered by the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc00d2183-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tIX/s978"},"text":"Pub. L. 109–58, title IX, § 978","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/904"},"text":"119 Stat. 904","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
