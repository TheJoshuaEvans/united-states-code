{"tag":"section","attrib":{"id":"idb4d8a1db-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–11"},"text":null,"children":[{"tag":"num","attrib":{"value":"247d–11"},"text":"§ 247d–11.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State All Payer Claims Databases","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb4d8a1dc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–11/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall make one-time grants to eligible States for the purposes described in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4d8a1dd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–11/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uses","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A State may use a grant received under subsection (a) for one of the following purposes:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4d8a1de-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–11/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To establish a State All Payer Claims Database.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4d8a1df-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–11/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To improve an ","children":[{"tag":"ref","attrib":{"idref":"fn002072"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002072"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original."}],"tail":" existing State All Payer Claims Databases."},{"tag":"ref","attrib":{"idref":"fn002072"},"text":"1","children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4d8a1e0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–11/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be eligible to receive a grant under subsection (a), a State shall submit to the Secretary an application at such time, in such manner, and containing such information as the Secretary specifies, including, with respect to a State All Payer Claims Database, at least specifics on how the State will ensure uniform data collection and the privacy and security of such data.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4d8a1e1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–11/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant period and amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Grants awarded under this section shall be for a period of 3-years,","children":[{"tag":"ref","attrib":{"idref":"fn002073"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002073"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be “3 years,”."}],"tail":" and in an amount of $2,500,000, of which $1,000,000 shall be made available to the State for each of the first 2 years of the grant period, and $500,000 shall be made available to the State for the third year of the grant period."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4d8a1e2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–11/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorized users","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4d8a1e3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–11/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An entity desiring authorization for access to a State All Payer Claims Database that has received a grant under this section shall submit to the State All Payer Claims Database an application for such access, which shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4d8a1e4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–11/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of an entity requesting access for research purposes—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb4d8a1e5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–11/e/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the uses and methodologies for evaluating health system performance using such data; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb4d8a1e6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–11/e/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" documentation of approval of the research by an institutional review board, if applicable for a particular plan of research; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4d8a1e7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–11/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an entity such as an employer, health insurance issuer, third-party administrator, or health care provider, requesting access for the purpose of quality improvement or cost-containment, a description of the intended uses for such data.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4d8a1e8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–11/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4d8a1e9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–11/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Access for research purposes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon approval of an application for research purposes under paragraph (1)(A), the authorized user shall enter into a data use and confidentiality agreement with the State All Payer Claims Database that has received a grant under this subsection, which shall include a prohibition on attempts to reidentify and disclose individually identifiable health information and proprietary financial information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4d8a1ea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–11/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Customized reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Employers and employer organizations may request customized reports from a State All Payer Claims Database that has received a grant under this section, at cost, subject to the requirements of this section with respect to privacy, security, and proprietary financial information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4d8a1eb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–11/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-customized reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State All Payer Claims Database that has received a grant under this section shall make available to all authorized users aggregate data sets available through the State All Payer Claims Database, free of charge.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4d8a1ec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–11/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waivers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may waive the requirements of this subsection of a State All Payer Claims Database to provide access of entities to such database if such State All Payer Claims Database is substantially in compliance with this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4d8a1ed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–11/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expanded access","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4d8a1ee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–11/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Multi-State applications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may prioritize applications submitted by a State whose application demonstrates that the State will work with other State All Payer Claims Databases to establish a single application for access to data by authorized users across multiple States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4d8a1ef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–11/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expansion of data sets","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may prioritize applications submitted by a State whose application demonstrates that the State will implement the reporting format for self-insured group health plans described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1191d"},"text":"section 1191d of title 29","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4d8a1f0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–11/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4d8a1f1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–11/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “individually identifiable health information” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320d/6"},"text":"section 1320d(6) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4d8a1f2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–11/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “proprietary financial information” means data that would disclose the terms of a specific contract between an individual health care provider or facility and a specific group health plan, managed care entity (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1396u–2/a/1/B"},"text":"section 1396u–2(a)(1)(B) of this title","children":[],"tail":") or other managed care organization, or health insurance issuer offering group or individual health insurance coverage; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4d8a1f3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–11/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “State All Payer Claims Database” means, with respect to a State, a database that may include medical claims, pharmacy claims, dental claims, and eligibility and provider files, which are collected from private and public payers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4d8a1f4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–11/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To carry out this section, there is authorized to be appropriated $50,000,000 for each of fiscal years 2022 and 2023, and $25,000,000 for fiscal year 2024, to remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb4d8a1f5-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title III, § 320B, as added "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dBB/tI/s115/a"},"text":"Pub. L. 116–260, div. BB, title I, § 115(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2875"},"text":"134 Stat. 2875","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb4d8a1f6-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb4d8a1f7-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb4d8a1f8-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dBB/s115/a"},"text":"Section 115(a) of div. BB of Pub. L. 116–260","children":[],"tail":", which directed that section 320B (this section) be added at the end of part B of title III of the Public Health Service Act, was executed as directed, notwithstanding that section 320 of the Public Health Service Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s247e"},"text":"section 247e of this title","children":[],"tail":") appears in part C of title III of the Act, resulting in section 320B of the Act preceding section 320."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
