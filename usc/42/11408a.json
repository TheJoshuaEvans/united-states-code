{"tag":"section","attrib":{"id":"idbf4bf423-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11408a"},"text":null,"children":[{"tag":"num","attrib":{"value":"11408a"},"text":"§ 11408a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of FMHA inventory for transitional housing for homeless persons and for turnkey housing","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf4bf424-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11408a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Agriculture (in this section referred to as the “Secretary”) shall, on a priority basis, lease or sell program and nonprogram inventory properties held by the Secretary under title V of the Housing Act of 1949 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1471"},"text":"42 U.S.C. 1471","children":[],"tail":" et seq.]—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf4bf425-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11408a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide transitional housing; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf4bf426-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11408a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide turnkey housing for tenants of such transitional housing and for eligible families.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf4bf427-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11408a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The priority uses of inventory property under this section shall not have a higher priority than—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf4bf428-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11408a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the disposition of such property by sale to eligible families; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf4bf429-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11408a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the disposition of such property by transfer for use as rental housing by eligible families.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf4bf42a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11408a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transitional housing","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf4bf42b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11408a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Leases authorized","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall lease inventory properties to public agencies and nonprofit organizations to provide transitional housing for homeless families and individuals and to provide such agencies the option to provide turnkey housing opportunities for homeless persons and other inadequately housed families.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf4bf42c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11408a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rental to eligible families","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A public agency or nonprofit organization may rent housing leased to it under paragraph (1) to a family for up to 10 years and may, during that period, assist the tenant in obtaining a loan and credit assistance under title V of the Housing Act of 1949 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1471"},"text":"42 U.S.C. 1471","children":[],"tail":" et seq.] to purchase the housing from the Secretary."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf4bf42d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11408a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lease procedures","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf4bf42e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11408a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Identification of property","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Upon receipt by the Secretary of written notification from a public agency or nonprofit organization that it proposes to lease a property for the purpose of providing transitional housing or for the purpose of providing transitional housing and turnkey housing opportunities, the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf4bf42f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11408a/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" withdraw the property from the market for not more than 30 days for the purpose of negotiations under subparagraph (B);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf4bf430-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11408a/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" negotiate a lease agreement with the organization or agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf4bf431-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11408a/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if a lease is agreed to, commence the repairs necessary to make the property meet standards for decent, safe, and sanitary housing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf4bf432-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11408a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lease terms","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A lease of inventory property under this section shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf4bf433-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11408a/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be for a period of not more than 10 years;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf4bf434-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11408a/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for the payment of $1 for the 10-year lease; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf4bf435-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11408a/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide the nonprofit organization or public agency—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbf4bf436-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11408a/d/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the right to use the property for transitional housing; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf4bf437-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11408a/d/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the option to arrange for the sale of the property to an eligible purchaser.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf4bf438-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11408a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purchase procedures","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf4bf439-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11408a/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Identification of property","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Upon receipt by the Secretary of written notification from a public agency or nonprofit organization that it proposes to purchase a property for the purpose of providing transitional housing or for the purpose of providing transitional housing and turnkey housing opportunities, the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf4bf43a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11408a/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" withdraw the property from the market for not more than 30 days for the purpose of negotiations under subparagraph (B);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf4bf43b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11408a/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" negotiate a purchase agreement with the organization or agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf4bf43c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11408a/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if a purchase agreement is agreed to, commence the repairs necessary to make the property meet standards for decent, safe, and sanitary housing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf4bf43d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11408a/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purchase terms","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A purchase of inventory property under this section shall provide for a purchase price equal to not more than the fair market value of the property minus 10 percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf4bf43e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11408a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employment of homeless individuals","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A public agency or nonprofit organization may lease or purchase property under this section only if the agency or organization, to the maximum extent practicable, involves homeless individuals and families, through employment, volunteer services, or otherwise, in maintaining, operating, and renovating any properties leased or acquired under this section and in providing any services for occupants of properties assisted under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf4bf43f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11408a/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Participation of homeless individuals","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf4bf440-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11408a/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall, by regulation, require each public agency and nonprofit organization leasing or purchasing property under this section to provide for the participation of not less than 1 homeless individual or former homeless individual on the board of directors or other equivalent policy making entity of such agency or organization, to the extent that such organization or applicant considers and makes policies and decisions regarding any property acquired under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf4bf441-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11408a/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may grant a waiver to a public agency or nonprofit organization that is unable to meet the requirement of paragraph (1), if the agency or organization agrees to otherwise consult with homeless or formerly homeless individuals in considering and making such policies and decisions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf4bf442-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11408a/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Budget compliance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The authority provided to the Secretary under this section shall be effective only to the extent approved in advance in appropriations Acts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf4bf443-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/77/tIV/s592/s492"},"text":"Pub. L. 100–77, title IV, § 592[492]","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/550/tXIV/s1414"},"text":"Pub. L. 102–550, title XIV, § 1414","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4041"},"text":"106 Stat. 4041","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf4bf444-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf4bf445-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbf4bf446-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Housing Act of 1949, referred to in subsecs. (a) and (c)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-07-15/ch338"},"text":"act July 15, 1949, ch. 338","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/413"},"text":"63 Stat. 413","children":[],"tail":". Title V of the Act is classified generally to subchapter III (§ 1471 et seq.) of chapter 8A of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1441"},"text":"section 1441 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
