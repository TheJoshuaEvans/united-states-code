{"tag":"section","attrib":{"id":"idbe07b47d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381l"},"text":null,"children":[{"tag":"num","attrib":{"value":"7381l"},"text":"§ 7381l.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Laboratories Centers of Excellence in Science, Technology, Engineering, and Mathematics education","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbe07b47e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381l/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of high-need public secondary school","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “high-need public secondary school” means a secondary school—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe07b47f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381l/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in which 40 percent or more of the students attending the school are children from low-income families; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe07b480-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381l/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designated with a school locale code of 41, 42, or 43, as determined by the Secretary of Education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe07b481-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381l/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish at each of the National Laboratories a program to support a Center of Excellence in Science, Technology, Engineering, and Mathematics (referred to in this section as a “Center of Excellence”) in at least 1 high-need public secondary school located in the region served by the National Laboratory to provide assistance in accordance with subsection (f).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe07b482-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381l/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collaboration","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe07b483-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381l/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To comply with subsection (g), each high-need public secondary school selected as a Center of Excellence and the National Laboratory shall form a partnership with a school, department, or program of education at an institution of higher education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe07b484-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381l/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonprofit entities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The partnership may include a nonprofit entity with demonstrated experience and effectiveness in science or mathematics, as agreed to by other members of the partnership.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe07b485-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381l/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe07b486-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381l/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Director, shall establish criteria to guide the National Laboratories in selecting the sites for Centers of Excellence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe07b487-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381l/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Process","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A National Laboratory shall select a site for a Center of Excellence through an open, widely-publicized, and competitive process.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe07b488-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381l/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Goals","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish goals and performance assessments for each Center of Excellence authorized under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe07b489-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381l/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Consistent with sections 7381b and 7381c of this title, the Director shall make available necessary assistance for a program established under this section through the use of scientific and engineering staff of a National Laboratory, including the use of staff—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe07b48a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381l/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assist teachers in teaching a course at a Center of Excellence in Science, Technology, Engineering, and Mathematics; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe07b48b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381l/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to use National Laboratory scientific equipment in the teaching of the course.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe07b48c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381l/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A Center of Excellence in a region shall ensure—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe07b48d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381l/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provision of clinical practicum, student teaching, or internship experiences for science, technology, and mathematics teacher candidates as part of the teacher preparation program of the Center of Excellence;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe07b48e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381l/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provision of supervision and mentoring for teacher candidates in the teacher preparation program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe07b48f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381l/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the maximum extent practicable, provision of professional development for veteran teachers in the public secondary schools in the region.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe07b490-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381l/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall consider the results of performance assessments required under subsection (e) in determining the contract award fee of a National Laboratory management and operations contractor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe07b491-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381l/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plan","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe07b492-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381l/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop an evaluation and accountability plan for the activities funded under this section that objectively measures the impact of the activities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe07b493-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381l/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disseminate information obtained from those measurements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe07b494-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381l/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No effect on similar programs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section displaces or otherwise affects any similar program being carried out as of ","children":[{"tag":"date","attrib":{"date":"2007-08-09"},"text":"August 9, 2007","children":[],"tail":", at any National Laboratory under any other provision of law."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbe07b495-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510/dC/tXXXI/s3181"},"text":"Pub. L. 101–510, div. C, title XXXI, § 3181","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/69/tV/s5003/d/3"},"text":"Pub. L. 110–69, title V, § 5003(d)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-08-09"},"text":"Aug. 9, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/607"},"text":"121 Stat. 607","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tIX/s9215/w"},"text":"Pub. L. 114–95, title IX, § 9215(w)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2171"},"text":"129 Stat. 2171","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbe07b496-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbe07b497-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbe07b498-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":" substituted “in which 40 percent or more of the students attending the school are children from low-income families” for “with a high concentration of low-income individuals (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6537"},"text":"section 6537 of title 20","children":[],"tail":")”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbe07b499-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbe07b49a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5"},"text":"section 5 of Pub. L. 114–95","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of Title 20","children":[],"tail":", Education."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
