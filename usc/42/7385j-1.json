{"tag":"section","attrib":{"id":"idbe0c7059-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385j–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"7385j–1"},"text":"§ 7385j–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Social Security earnings information","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Notwithstanding the provision of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552a"},"text":"section 552a of title 5","children":[],"tail":" or any other provision of Federal or State law, the Social Security Administration shall make available to the Secretary of Labor, upon written request, the Social Security earnings information of living or deceased employees who may have sustained an illness that is the subject of a claim under this subchapter, which the Secretary of Labor may require to carry out the provisions of this subchapter."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbe0c705a-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dC/tXXXVI/s3652"},"text":"Pub. L. 106–398, § 1 [div. C, title XXXVI, § 3652]","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/375/dC/tXXXI/s3163/b"},"text":"Pub. L. 108–375, div. C, title XXXI, § 3163(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-28"},"text":"Oct. 28, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2187"},"text":"118 Stat. 2187","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
