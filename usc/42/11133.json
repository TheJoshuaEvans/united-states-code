{"tag":"section","attrib":{"id":"idbf38e23e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11133"},"text":null,"children":[{"tag":"num","attrib":{"value":"11133"},"text":"§ 11133.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting of certain professional review actions taken by health care entities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf38e23f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11133/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting by health care entities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf38e240-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11133/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" On physicians","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each health care entity which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf38e241-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11133/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" takes a professional review action that adversely affects the clinical privileges of a physician for a period longer than 30 days;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf38e242-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11133/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" accepts the surrender of clinical privileges of a physician—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbf38e243-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11133/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" while the physician is under an investigation by the entity relating to possible incompetence or improper professional conduct, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf38e244-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11133/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in return for not conducting such an investigation or proceeding; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf38e245-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11133/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of such an entity which is a professional society, takes a professional review action which adversely affects the membership of a physician in the society,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall report to the Board of Medical Examiners, in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11134/a"},"text":"section 11134(a) of this title","children":[],"tail":", the information described in paragraph (3)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf38e246-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11133/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Permissive reporting on other licensed health care practitioners","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A health care entity may report to the Board of Medical Examiners, in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11134/a"},"text":"section 11134(a) of this title","children":[],"tail":", the information described in paragraph (3) in the case of a licensed health care practitioner who is not a physician, if the entity would be required to report such information under paragraph (1) with respect to the practitioner if the practitioner were a physician."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf38e247-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11133/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information to be reported","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The information to be reported under this subsection is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf38e248-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11133/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name of the physician or practitioner involved,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf38e249-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11133/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the acts or omissions or other reasons for the action or, if known, for the surrender, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf38e24a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11133/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other information respecting the circumstances of the action or surrender as the Secretary deems appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf38e24b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11133/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting by Board of Medical Examiners","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each Board of Medical Examiners shall report, in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11134"},"text":"section 11134 of this title","children":[],"tail":", the information reported to it under subsection (a) and known instances of a health care entity’s failure to report information under subsection (a)(1)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf38e24c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11133/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sanctions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf38e24d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11133/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Health care entities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A health care entity that fails substantially to meet the requirement of subsection (a)(1) shall lose the protections of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11111/a/1"},"text":"section 11111(a)(1) of this title","children":[],"tail":" if the Secretary publishes the name of the entity under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s11111/b"},"text":"section 11111(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf38e24e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11133/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Board of Medical Examiners","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If, after notice of noncompliance and providing an opportunity to correct noncompliance, the Secretary determines that a Board of Medical Examiners has failed to report information in accordance with subsection (b), the Secretary shall designate another qualified entity for the reporting of information under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf38e24f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11133/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" References to Board of Medical Examiners","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any reference in this subchapter to a Board of Medical Examiners includes, in the case of a Board in a State that fails to meet the reporting requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11132/a"},"text":"section 11132(a) of this title","children":[],"tail":" or subsection (b), a reference to such other qualified entity as the Secretary designates."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf38e250-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/660/tIV/s423"},"text":"Pub. L. 99–660, title IV, § 423","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3789"},"text":"100 Stat. 3789","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
