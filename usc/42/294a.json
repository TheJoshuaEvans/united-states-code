{"tag":"section","attrib":{"id":"idb5dca404-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294a"},"text":null,"children":[{"tag":"num","attrib":{"value":"294a"},"text":"§ 294a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Area health education centers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5dca405-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of awards","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall make the following 2 types of awards in accordance with this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5dca406-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Infrastructure development award","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall make awards to eligible entities to enable such entities to initiate health care workforce educational programs or to continue to carry out comparable programs that are operating at the time the award is made by planning, developing, operating, and evaluating an area health education center program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5dca407-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Point of service maintenance and enhancement award","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall make awards to eligible entities to maintain and improve the effectiveness and capabilities of an existing area health education center program, and make other modifications to the program that are appropriate due to changes in demographics, needs of the populations served, or other similar issues affecting the area health education center program. For the purposes of this section, the term “Program” refers to the area health education center program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5dca408-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entities; application","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5dca409-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entities","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5dca40a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294a/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Infrastructure development","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of subsection (a)(1), the term “eligible entity” means a school of medicine or osteopathic medicine, an incorporated consortium of such schools, or the parent institutions of such a school. With respect to a State in which no area health education center program is in operation, the Secretary may award a grant or contract under subsection (a)(1) to a school of nursing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5dca40b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294a/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Point of service maintenance and enhancement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of subsection (a)(2), the term “eligible entity” means an entity that has received funds under this section, is operating an area health education center program, including an area health education center or centers, and has a center or centers that are no longer eligible to receive financial assistance under subsection (a)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5dca40c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An eligible entity desiring to receive an award under this section shall submit to the Secretary an application at such time, in such manner, and containing such information as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5dca40d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5dca40e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An eligible entity shall use amounts awarded under a grant under subsection (a)(1) or (a)(2) to carry out the following activities:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5dca40f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294a/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Develop and implement strategies, in coordination with the applicable one-stop delivery system under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3151/e"},"text":"section 3151(e) of title 29","children":[],"tail":", to recruit individuals from underrepresented minority populations or from disadvantaged or rural backgrounds into health professions, and support such individuals in attaining such careers."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5dca410-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294a/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Develop and implement strategies to foster and provide community-based training and education to individuals seeking careers in health professions within underserved areas for the purpose of developing and maintaining a diverse health care workforce that is prepared to deliver high-quality care, with an emphasis on primary care, in underserved areas or for health disparity populations, in collaboration with other Federal and State health care workforce development programs, the State workforce agency, and local workforce investment boards, and in health care safety net sites.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5dca411-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294a/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Prepare individuals to more effectively provide health services to underserved areas and health disparity populations through field placements or preceptorships in conjunction with community-based organizations, accredited primary care residency training programs, Federally qualified health centers, rural health clinics, public health departments, or other appropriate facilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5dca412-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294a/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Conduct and participate in interdisciplinary training that involves physicians, physician assistants, nurse practitioners, nurse midwives, dentists, psychologists, pharmacists, optometrists, community health workers, public and allied health professionals, or other health professionals, as practicable.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5dca413-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294a/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Deliver or facilitate continuing education and information dissemination programs for health care professionals, with an emphasis on individuals providing care in underserved areas and for health disparity populations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5dca414-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294a/c/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Propose and implement effective program and outcomes measurement and evaluation strategies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5dca415-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294a/c/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Establish a youth public health program to expose and recruit high school students into health careers, with a focus on careers in public health.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5dca416-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Innovative opportunities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An eligible entity may use amounts awarded under a grant under subsection (a)(1) or subsection (a)(2) to carry out any of the following activities:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5dca417-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294a/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Develop and implement innovative curricula in collaboration with community-based accredited primary care residency training programs, Federally qualified health centers, rural health clinics, behavioral and mental health facilities, public health departments, or other appropriate facilities, with the goal of increasing the number of primary care physicians and other primary care providers prepared to serve in underserved areas and health disparity populations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5dca418-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294a/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Coordinate community-based participatory research with academic health centers, and facilitate rapid flow and dissemination of evidence-based health care information, research results, and best practices to improve quality, efficiency, and effectiveness of health care and health care systems within community settings.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5dca419-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294a/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Develop and implement other strategies to address identified workforce needs and increase and enhance the health care workforce in the area served by the area health education center program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5dca41a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5dca41b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Area health education center program","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out this section, the Secretary shall ensure the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5dca41c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294a/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An entity that receives an award under this section shall conduct at least 10 percent of clinical education required for medical students in community settings that are removed from the primary teaching facility of the contracting institution for grantees that operate a school of medicine or osteopathic medicine. In States in which an entity that receives an award under this section is a nursing school or its parent institution, the Secretary shall alternatively ensure that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb5dca41d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294a/d/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the nursing school conducts at least 10 percent of clinical education required for nursing students in community settings that are remote from the primary teaching facility of the school; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5dca41e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294a/d/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the entity receiving the award maintains a written agreement with a school of medicine or osteopathic medicine to place students from that school in training sites in the area health education center program area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5dca41f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294a/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An entity receiving funds under subsection (a)(2) does not distribute such funding to a center that is eligible to receive funding under subsection (a)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5dca420-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Area health education center","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall ensure that each area health education center program includes at least 1 area health education center, and that each such center—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5dca421-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294a/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a public or private organization whose structure, governance, and operation is independent from the awardee and the parent institution of the awardee;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5dca422-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294a/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not a school of medicine or osteopathic medicine, the parent institution of such a school, or a branch campus or other subunit of a school of medicine or osteopathic medicine or its parent institution, or a consortium of such entities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5dca423-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294a/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designates an underserved area or population to be served by the center which is in a location removed from the main location of the teaching facilities of the schools participating in the program with such center and does not duplicate, in whole or in part, the geographic area or population served by any other center;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5dca424-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294a/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fosters networking and collaboration among communities and between academic health centers and community-based centers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5dca425-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294a/d/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serves communities with a demonstrated need of health professionals in partnership with academic medical centers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5dca426-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294a/d/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" addresses the health care workforce needs of the communities served in coordination with the public workforce investment system; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5dca427-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294a/d/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a community-based governing or advisory board that reflects the diversity of the communities involved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5dca428-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matching funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to the costs of operating a program through a grant under this section, to be eligible for financial assistance under this section, an entity shall make available (directly or through contributions from State, county or municipal governments, or the private sector) recurring non-Federal contributions in cash or in kind, toward such costs in an amount that is equal to not less than 50 percent of such costs. At least 25 percent of the total required non-Federal contributions shall be in cash. An entity may apply to the Secretary for a waiver of not more than 75 percent of the matching fund amount required by the entity for each of the first 3 years the entity is funded through a grant under subsection (a)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5dca429-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not less than 75 percent of the total amount provided to an area health education center program under subsection (a)(1) or (a)(2) shall be allocated to the area health education centers participating in the program under this section. To provide needed flexibility to newly funded area health education center programs, the Secretary may waive the requirement in the sentence for the first 2 years of a new area health education center program funded under subsection (a)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5dca42a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294a/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Award","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An award to an entity under this section shall be not less than $250,000 annually per area health education center included in the program involved. If amounts appropriated to carry out this section are not sufficient to comply with the preceding sentence, the Secretary may reduce the per center amount provided for in such sentence as necessary, provided the distribution established in subsection (j)(2) is maintained.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5dca42b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294a/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Project terms","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5dca42c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294a/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in paragraph (2), the period during which payments may be made under an award under subsection (a)(1) may not exceed—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5dca42d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294a/h/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a program, 12 years; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5dca42e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294a/h/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a center within a program, 6 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5dca42f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294a/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The periods described in paragraph (1) shall not apply to programs receiving point of service maintenance and enhancement awards under subsection (a)(2) to maintain existing centers and activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5dca430-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294a/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inapplicability of provision","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of this subchapter, ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s295j/a"},"text":"section 295j(a) of this title","children":[],"tail":" shall not apply to an area health education center funded under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5dca431-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294a/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5dca432-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294a/j/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this section $41,250,000 for each of fiscal years 2021 through 2025.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5dca433-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294a/j/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Of the amounts appropriated for a fiscal year under paragraph (1)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5dca434-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294a/j/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not more than 35 percent shall be used for awards under subsection (a)(1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5dca435-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294a/j/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than 60 percent shall be used for awards under subsection (a)(2);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5dca436-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294a/j/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not more than 1 percent shall be used for grants and contracts to implement outcomes evaluation for the area health education centers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5dca437-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294a/j/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not more than 4 percent shall be used for grants and contracts to provide technical assistance to entities receiving awards under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5dca438-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294a/j/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Carryover funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An entity that receives an award under this section may carry over funds from 1 fiscal year to another without obtaining approval from the Secretary. In no case may any funds be carried over pursuant to the preceding sentence for more than 3 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5dca439-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294a/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sense of Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It is the sense of the Congress that every State have an area health education center program in effect under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5dca43a-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title VII, § 751, as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/392/tI/s103"},"text":"Pub. L. 105–392, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"}