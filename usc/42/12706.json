{"tag":"section","attrib":{"id":"idbf983f42-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12706"},"text":null,"children":[{"tag":"num","attrib":{"value":"12706"},"text":"§ 12706.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary shall, by regulation or otherwise, as deemed by the Secretary to be appropriate, require any application for housing assistance under subchapter II of this chapter, assistance under the Housing and Community Development Act of 1974, or assistance under the McKinney-Vento Homeless Assistance Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11301"},"text":"42 U.S.C. 11301","children":[],"tail":" et seq.], to contain or be accompanied by a certification by an appropriate State or local public official that the proposed housing activities are consistent with the housing strategy of the jurisdiction to be served."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbf983f43-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/625/tI/s106"},"text":"Pub. L. 101–625, title I, § 106","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4091"},"text":"104 Stat. 4091","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/400/s2"},"text":"Pub. L. 106–400, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1675"},"text":"114 Stat. 1675","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf983f44-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf983f45-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbf983f46-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Housing and Community Development Act of 1974, referred to in text, is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/383"},"text":"Pub. L. 93–383","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-08-22"},"text":"Aug. 22, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/633"},"text":"88 Stat. 633","children":[],"tail":". For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5301"},"text":"section 5301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The McKinney-Vento Homeless Assistance Act, referred to in text, is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/77"},"text":"Pub. L. 100–77","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-07-22"},"text":"July 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/482"},"text":"101 Stat. 482","children":[],"tail":", which is classified principally to chapter 119 (§ 11301 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s11301"},"text":"section 11301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbf983f47-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/400"},"text":"Pub. L. 106–400","children":[],"tail":" substituted “McKinney-Vento Homeless Assistance Act” for “Stewart B. McKinney Homeless Assistance Act”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
