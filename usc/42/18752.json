{"tag":"section","attrib":{"id":"idc067c4c2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18752"},"text":null,"children":[{"tag":"num","attrib":{"value":"18752"},"text":"§ 18752.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Property interests relating to certain projects and protection of information relating to certain agreements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc067c4c3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18752/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"idref":"fn004373"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004373"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. No subsec. (b) has been enacted."}],"tail":" Property interests relating to federally funded advanced nuclear reactor projects"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc067c4c4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18752/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc067c4c5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18752/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advanced nuclear reactor","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “advanced nuclear reactor” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16271/b"},"text":"section 16271(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc067c4c6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18752/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Property interest","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc067c4c7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18752/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in clause (ii), the term “property interest” means any interest in real property or personal property (as those terms are defined in section 200.1 of title 2, Code of Federal Regulations (as in effect on ","children":[{"tag":"date","attrib":{"date":"2021-11-15"},"text":"November 15, 2021","children":[],"tail":"))."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc067c4c8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18752/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “property interest” does not include any interest in intellectual property developed using funding provided under a project described in paragraph (3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc067c4c9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18752/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assignment of property interests","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may assign to any entity, including the United States, fee title or any other property interest acquired by the Secretary under an agreement entered into with respect to a project described in paragraph (3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc067c4ca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18752/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Project described","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A project referred to in paragraph (2) is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc067c4cb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18752/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a project for which funding is provided pursuant to the funding opportunity announcement of the Department numbered DE–FOA–0002271, including any project for which funding has been provided pursuant to that announcement as of ","children":[{"tag":"date","attrib":{"date":"2021-11-15"},"text":"November 15, 2021","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc067c4cc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18752/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other project for which funding is provided using amounts made available for the Advanced Reactor Demonstration Program of the Department under the heading “Nuclear Energy” under the heading “ENERGY PROGRAMS” in title III of division C of the Further Consolidated Appropriations Act, 2020 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94"},"text":"Public Law 116–94","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/133/2670"},"text":"133 Stat. 2670","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc067c4cd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18752/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other project for which Federal funding is provided under the Advanced Reactor Demonstration Program of the Department; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc067c4ce-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18752/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a project—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc067c4cf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18752/a/3/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" relating to advanced nuclear reactors; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc067c4d0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18752/a/3/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for which Federal funding is provided under a program focused on development and demonstration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc067c4d1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18752/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retroactive vesting","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The vesting of fee title or any other property interest assigned under paragraph (2) shall be retroactive to the date on which the applicable project first received Federal funding as described in any of subparagraphs (A) through (D) of paragraph (3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc067c4d2-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dD/tIII/s40322/a"},"text":"Pub. L. 117–58, div. D, title III, § 40322(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1017"},"text":"135 Stat. 1017","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc067c4d3-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc067c4d4-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc067c4d5-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Further Consolidated Appropriations Act, 2020, referred to in subsec. (a)(3)(B), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94"},"text":"Pub. L. 116–94","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/2534"},"text":"133 Stat. 2534","children":[],"tail":". Title III of division C of the Act is title III of div. C of "},{"tag":"ref","attrib":{"href":"/us/pl/116/94"},"text":"Pub. L. 116–94","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/2669"},"text":"133 Stat. 2669","children":[],"tail":", which enacted "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s825s–8"},"text":"section 825s–8 of Title 16","children":[],"tail":", Conservation, and provisions set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s6939f"},"text":"section 6939f of this title","children":[],"tail":" and 838i of Title 16, and provisions set out in a table under sections 6241 and 7171 of this title. For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc067c4d6-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc067c4d7-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Wage Rate Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions relating to rates of wages to be paid to laborers and mechanics on projects for construction, alteration, or repair work funded under div. D or an amendment by div. D of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":", including authority of Secretary of Labor, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s18851"},"text":"section 18851 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
