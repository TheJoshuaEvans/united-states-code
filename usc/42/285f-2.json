{"tag":"section","attrib":{"id":"idb573a8aa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285f–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"285f–2"},"text":"§ 285f–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research and research training regarding tuberculosis","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In carrying out ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s285f"},"text":"section 285f of this title","children":[],"tail":", the Director of the Institute shall conduct or support research and research training regarding the cause, diagnosis, early detection, prevention and treatment of tuberculosis."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb573a8ab-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title IV, § 447A, formerly § 447, as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/183/tIII/s302/a"},"text":"Pub. L. 103–183, title III, § 302(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-14"},"text":"Dec. 14, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2235"},"text":"107 Stat. 2235","children":[],"tail":"; renumbered § 447A, "},{"tag":"ref","attrib":{"href":"/us/pl/105/392/tIV/s401/b/3"},"text":"Pub. L. 105–392, title IV, § 401(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3587"},"text":"112 Stat. 3587","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/482/tI/s103/b/27"},"text":"Pub. L. 109–482, title I, § 103(b)(27)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-01-15"},"text":"Jan. 15, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3688"},"text":"120 Stat. 3688","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb573a8ac-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb573a8ad-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb573a8ae-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2007—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/482"},"text":"Pub. L. 109–482","children":[],"tail":" struck out subsec. (a) designation before “In carrying out” and subsec. (b) which read as follows: “For the purpose of carrying out subsection (a) of this section, there are authorized to be appropriated $50,000,000 for fiscal year 1994, and such sums as may be necessary for each of the fiscal years 1995 through 1998. Such authorization is in addition to any other authorization of appropriations that is available for such purpose.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb573a8af-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb573a8b0-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2007 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/482"},"text":"Pub. L. 109–482","children":[],"tail":" applicable only with respect to amounts appropriated for fiscal year 2007 or subsequent fiscal years, see "},{"tag":"ref","attrib":{"href":"/us/pl/109/482/s109"},"text":"section 109 of Pub. L. 109–482","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s281"},"text":"section 281 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb573a8b1-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Research Through Food and Drug Administration","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/183/tIII/s303"},"text":"Pub. L. 103–183, title III, § 303","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-14"},"text":"Dec. 14, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2235"},"text":"107 Stat. 2235","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/183/tIII/s303"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The Secretary of Health and Human Services, acting through the Commissioner of Food and Drugs, shall implement a tuberculosis drug and device research program under which the Commissioner may—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide assistance to other Federal agencies for the development of tuberculosis protocols;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review and evaluate medical devices designed for the diagnosis and control of airborne tuberculosis; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct research concerning drugs or devices to be used in diagnosing, controlling and preventing tuberculosis.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
