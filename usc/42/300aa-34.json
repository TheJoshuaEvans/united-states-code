{"tag":"section","attrib":{"id":"idb67c66bd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300aa–34"},"text":null,"children":[{"tag":"num","attrib":{"value":"300aa–34"},"text":"§ 300aa–34.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb67c66be-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300aa–34/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reviews","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall review the number of awards of compensation made under the program to petitioners under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300aa–11"},"text":"section 300aa–11 of this title","children":[],"tail":" for vaccine-related injuries and deaths associated with the administration of vaccines on or after "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"December 22, 1987","children":[],"tail":", as follows:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb67c66bf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300aa–34/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall review the number of such awards made in the 12-month period beginning on ","children":[{"tag":"date","attrib":{"date":"1987-12-22"},"text":"December 22, 1987","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb67c66c0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300aa–34/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" At the end of each 3-month period beginning after the expiration of the 12-month period referred to in paragraph (1) the Secretary shall review the number of such awards made in the 3-month period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb67c66c1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300aa–34/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb67c66c2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300aa–34/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If in conducting a review under subsection (a) the Secretary determines that at the end of the period reviewed the total number of awards made by the end of that period and accepted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300aa–21/a"},"text":"section 300aa–21(a) of this title","children":[],"tail":" exceeds the number of awards listed next to the period reviewed in the table in paragraph (2)—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb67c66c3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300aa–34/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary shall notify the Congress of such determination, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb67c66c4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300aa–34/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" beginning 180 days after the receipt by Congress of a notification under paragraph (1), no petition for a vaccine-related injury or death associated with the administration of a vaccine on or after ","children":[{"tag":"date","attrib":{"date":"1987-12-22"},"text":"December 22, 1987","children":[],"tail":", may be filed under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300aa–11"},"text":"section 300aa–11 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300aa–11/a"},"text":"Section 300aa–11(a) of this title","children":[],"tail":" and subpart B of this part shall not apply to civil actions for damages for a vaccine-related injury or death for which a petition may not be filed because of subparagraph (B)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb67c66c5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300aa–34/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The table referred to in paragraph (1) is as follows:","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb67c66c6-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:b","attrib":{},"text":null,"children":[],"tail":" Period reviewed:"}],"tail":null},{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:b","attrib":{},"text":"Total number of awards by the end of the period reviewed","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null