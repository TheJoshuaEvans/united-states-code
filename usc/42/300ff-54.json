{"tag":"section","attrib":{"id":"idb69daa68-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–54"},"text":null,"children":[{"tag":"num","attrib":{"value":"300ff–54"},"text":"§ 300ff–54.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Miscellaneous provisions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb69daa69-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–54/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Services for individuals with hemophilia","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In making grants under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–51"},"text":"section 300ff–51 of this title","children":[],"tail":", the Secretary shall ensure that any such grants made regarding the provision of early intervention services to individuals with hemophilia are made through the network of comprehensive hemophilia diagnostic and treatment centers."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb69daa6a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–54/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may, directly or through grants or contracts, provide technical assistance to nonprofit private entities regarding the process of submitting to the Secretary applications for grants under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–51"},"text":"section 300ff–51 of this title","children":[],"tail":", and may provide technical assistance with respect to the planning, development, and operation of any program or service carried out pursuant to such section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb69daa6b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–54/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Planning and development grants","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb69daa6c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–54/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may provide planning grants to public and nonprofit private entities for purposes of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb69daa6d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–54/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enabling such entities to provide early intervention services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb69daa6e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–54/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assisting the entities in expanding their capacity to provide HIV/AIDS-related health services, including early intervention services, in low-income communities and affected subpopulations that are underserved with respect to such services (subject to the condition that a grant pursuant to this subparagraph may not be expended to purchase or improve land, or to purchase, construct, or permanently improve, other than minor remodeling, any building or other facility).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb69daa6f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–54/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may only award a grant to an entity under paragraph (1) if the Secretary determines that the entity will use such grant to assist the entity in qualifying for a grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–51"},"text":"section 300ff–51 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb69daa70-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–54/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preference","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In awarding grants under paragraph (1), the Secretary shall give preference to entities that provide primary care services in rural areas or to underserved populations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb69daa71-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–54/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount and duration of grants","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb69daa72-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–54/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Early intervention services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A grant under paragraph (1)(A) may be made in an amount not to exceed $50,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb69daa73-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–54/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Capacity development","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb69daa74-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–54/c/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A grant under paragraph (1)(B) may be made in an amount not to exceed $150,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb69daa75-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–54/c/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The total duration of a grant under paragraph (1)(B), including any renewal, may not exceed 3 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb69daa76-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–54/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not to exceed 5 percent of the amount appropriated for a fiscal year under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–55"},"text":"section 300ff–55 of this title","children":[],"tail":" may be used to carry out this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb69daa77-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XXVI, § 2654, as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/381/tIII/s301/a"},"text":"Pub. L. 101–381, title III, § 301(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-08-18"},"text":"Aug. 18, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/608"},"text":"104 Stat. 608","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/146/s3/d/3"},"text":"Pub. L. 104–146, § 3(d)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-05-20"},"text":"May 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1357"},"text":"110 Stat. 1357","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/345/tIII/s312"},"text":"Pub. L. 106–345, title III, § 312","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-20"},"text":"Oct. 20, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1345"},"text":"114 Stat. 1345","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/415/tIII/s302/c"},"text":"Pub. L. 109–415, title III, § 302(c)","children":[],"tail":", title VII, § 703, "},{"tag":"date","attrib":{"date":"2006-12-19"},"text":"Dec. 19, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2807"},"text":"120 Stat. 2807","children":[],"tail":", 2820; "},{"tag":"ref","attrib":{"href":"/us/pl/111/87/s2/a/1"},"text":"Pub. L. 111–87, § 2(a)(1)","children":[],"tail":", (3)(A), "},{"tag":"date","attrib":{"date":"2009-10-30"},"text":"Oct. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2885"},"text":"123 Stat. 2885","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb69daa78-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb69daa79-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb69daa7a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2009—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/87"},"text":"Pub. L. 111–87","children":[],"tail":" repealed "},{"tag":"ref","attrib":{"href":"/us/pl/109/415/s703"},"text":"Pub. L. 109–415, § 703","children":[],"tail":", and revived the provisions of this section as in effect on "},{"tag":"date","attrib":{"date":"2009-09-30"},"text":"Sept. 30, 2009","children":[],"tail":". See 2006 Amendment note and Effective Date of 2009 Amendment; Revival of Section note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/415/s703"},"text":"Pub. L. 109–415, § 703","children":[],"tail":", which directed repeal of this section effective "},{"tag":"date","attrib":{"date":"2009-10-01"},"text":"Oct. 1, 2009","children":[],"tail":", was itself repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/111/87/s2/a/1"},"text":"Pub. L. 111–87, § 2(a)(1)","children":[],"tail":", effective "},{"tag":"date","attrib":{"date":"2009-09-30"},"text":"Sept. 30, 2009","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/415/s302/c/1/A"},"text":"Pub. L. 109–415, § 302(c)(1)(A)","children":[],"tail":", struck out “HIV” after “provide”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/415/s302/c/1/B"},"text":"Pub. L. 109–415, § 302(c)(1)(B)","children":[],"tail":", substituted “HIV/AIDS-related” for “HIV-related”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/415/s302/c/2"},"text":"Pub. L. 109–415, § 302(c)(2)","children":[],"tail":", substituted “areas or to underserved populations” for “or underserved communities”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/345/s312/a"},"text":"Pub. L. 106–345, § 312(a)","children":[],"tail":", substituted “planning grants to public and nonprofit private entities for purposes of—” and subpars. (A) and (B) for “planning grants, in an amount not to exceed $50,000 for each such grant, to public and nonprofit private entities for the purpose of enabling such entities to provide HIV early intervention services.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/345/s312/b/2"},"text":"Pub. L. 106–345, § 312(b)(2)","children":[],"tail":", added par. (4). Former par. (4) redesignated (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/345/s312/b/1"},"text":"Pub. L. 106–345, § 312(b)(1)","children":[],"tail":", (c), redesignated par. (4) as (5) and substituted “5 percent” for “1 percent”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/146"},"text":"Pub. L. 104–146","children":[],"tail":" added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb69daa7b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb69daa7c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2009 Amendment; Revival of Section","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions that repeal by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/87/s2/a/1"},"text":"section 2(a)(1) of Pub. L. 111–87","children":[],"tail":" of "},{"tag":"ref","attrib":{"href":"/us/pl/109/415/s703"},"text":"section 703 of Pub. L. 109–415","children":[],"tail":" be effective "},{"tag":"date","attrib":{"date":"2009-09-30"},"text":"Sept. 30, 2009","children":[],"tail":", and that the provisions of this section as in effect on "},{"tag":"date","attrib":{"date":"2009-09-30"},"text":"Sept. 30, 2009","children":[],"tail":", be revived, see section 2(a)(2), (3)(A) of "},{"tag":"ref","attrib":{"href":"/us/pl/111/87"},"text":"Pub. L. 111–87","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–11"},"text":"section 300ff–11 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb69daa7d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/146"},"text":"Pub. L. 104–146","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1996-10-01"},"text":"Oct. 1, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/146/s13"},"text":"section 13 of Pub. L. 104–146","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–11"},"text":"section 300ff–11 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
