{"tag":"section","attrib":{"id":"idbeae7bb7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9125"},"text":null,"children":[{"tag":"num","attrib":{"value":"9125"},"text":"§ 9125.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Judicial review","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Any person suffering legal wrong, or who is adversely affected or aggrieved by the Administrator’s decision to issue, transfer, modify, renew, suspend, or terminate a license may, not later than 60 days after such decision is made, seek judicial review of such decision in the United States Court of Appeals for the District of Columbia. A person shall be deemed to be aggrieved by the Administrator’s decision within the meaning of this chapter if he—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbeae7bb8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9125/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has participated in the administrative proceedings before the Administrator (or if he did not so participate, he can show that his failure to do so was caused by the Administrator’s failure to provide the required notice); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbeae7bb9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9125/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is adversely affected by the Administrator’s action.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbeae7bba-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/320/tI/s115"},"text":"Pub. L. 96–320, title I, § 115","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-08-03"},"text":"Aug. 3, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/990"},"text":"94 Stat. 990","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbeae7bbb-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbeae7bbc-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbeae7bbd-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in introductory provisions, was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/320"},"text":"Pub. L. 96–320","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-08-03"},"text":"Aug. 3, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/974"},"text":"94 Stat. 974","children":[],"tail":", known as the Ocean Thermal Energy Conversion Act of 1980, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s9101"},"text":"section 9101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
