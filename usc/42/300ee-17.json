{"tag":"section","attrib":{"id":"idb68a9739-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–17"},"text":null,"children":[{"tag":"num","attrib":{"value":"300ee–17"},"text":"§ 300ee–17.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of amount of allotments for States","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb68a973a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–17/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum allotment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to the extent of amounts made available in appropriation Acts, the allotment for a State under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ee–11/a"},"text":"section 300ee–11(a) of this title","children":[],"tail":" for a fiscal year shall be the greater of—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb68a973b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–17/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the applicable amount specified in subsection (b); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb68a973c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–17/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount determined in accordance with subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb68a973d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–17/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of minimum allotment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb68a973e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–17/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the total amount appropriated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ee–24/a"},"text":"section 300ee–24(a) of this title","children":[],"tail":" for a fiscal year exceeds $100,000,000, the amount referred to in subsection (a)(1) shall be $300,000 for the fiscal year."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb68a973f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–17/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the total amount appropriated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ee–24/a"},"text":"section 300ee–24(a) of this title","children":[],"tail":" for a fiscal year equals or exceeds $50,000,000, but is less than $100,000,000, the amount referred to in subsection (a)(1) shall be $200,000 for the fiscal year."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb68a9740-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–17/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the total amount appropriated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ee–24/a"},"text":"section 300ee–24(a) of this title","children":[],"tail":" for a fiscal year is less than $50,000,000, the amount referred to in subsection (a)(1) shall be $100,000 for the fiscal year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb68a9741-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–17/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination under formula","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb68a9742-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–17/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The amount referred to in subsection (a)(2) is the sum of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb68a9743-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–17/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount determined under paragraph (2); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb68a9744-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–17/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount determined under paragraph (3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb68a9745-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–17/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The amount referred to in paragraph (1)(A) is the product of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb68a9746-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–17/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an amount equal to 50 percent of the amounts appropriated pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ee–24/a"},"text":"section 300ee–24(a) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb68a9747-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–17/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a percentage equal to the quotient of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb68a9748-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–17/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the population of the State involved; divided by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb68a9749-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–17/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the population of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb68a974a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–17/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The amount referred to in paragraph (1)(B) is the product of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb68a974b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–17/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an amount equal to 50 percent of the amounts appropriated pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ee–24/a"},"text":"section 300ee–24(a) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb68a974c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–17/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a percentage equal to the quotient of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb68a974d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–17/c/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of additional cases of acquired immune deficiency syndrome reported to and confirmed by the Secretary for the State involved for the most recent fiscal year for which such data is available; divided by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb68a974e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–17/c/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of additional cases of such syndrome reported to and confirmed by the Secretary for the United States for such fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb68a974f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–17/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposition of certain funds appropriated for allotments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb68a9750-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–17/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Amounts described in paragraph (2) shall be allotted by the Secretary to States receiving payments under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ee–11/a"},"text":"section 300ee–11(a) of this title","children":[],"tail":" for the fiscal year (other than any State referred to in paragraph (2)(C)). Such amounts shall be allotted according to a formula established by the Secretary. The formula shall be equivalent to the formula described in this section under which the allotment under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ee–11/a"},"text":"section 300ee–11(a) of this title","children":[],"tail":" for the State for the fiscal year involved was determined."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb68a9751-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–17/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The amounts referred to in paragraph (1) are any amounts that are not paid to States under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ee–11/a"},"text":"section 300ee–11(a) of this title","children":[],"tail":" as a result of—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb68a9752-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–17/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the failure of any State to submit an application under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ee–13"},"text":"section 300ee–13 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb68a9753-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–17/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the failure, in the determination of the Secretary, of any State to prepare within a reasonable period of time such application in compliance with such section; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb68a9754-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–17/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any State informing the Secretary that the State does not intend to expend the full amount of the allotment made to the State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb68a9755-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XXV, formerly title XV, § 2507, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/607/tII/s221"},"text":"Pub. L. 100–607, title II, § 221","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-04"},"text":"Nov. 4, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3098"},"text":"102 Stat. 3098","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tII/s2619/e"},"text":"Pub. L. 100–690, title II, § 2619(e) [(f)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4243"},"text":"102 Stat. 4243","children":[],"tail":"; renumbered title XXV and amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/93/s5/e/1"},"text":"Pub. L. 101–93, § 5(e)(1)","children":[],"tail":", (2), "},{"tag":"date","attrib":{"date":"1989-08-16"},"text":"Aug. 16, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/612"},"text":"103 Stat. 612","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb68a9756-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb68a9757-3a70-11f1-ae07-e4213316b5fa"},"text":nu