{"tag":"section","attrib":{"id":"idb8604221-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–8"},"text":null,"children":[{"tag":"num","attrib":{"value":"1320d–8"},"text":"§ 1320d–8.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Processing payment transactions by financial institutions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"To the extent that an entity is engaged in activities of a financial institution (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s3401"},"text":"section 3401 of title 12","children":[],"tail":"), or is engaged in authorizing, processing, clearing, settling, billing, transferring, reconciling, or collecting payments, for a financial institution, this part, and any standard adopted under this part, shall not apply to the entity with respect to such activities, including the following:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8604222-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–8/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The use or disclosure of information by the entity for authorizing, processing, clearing, settling, billing, transferring, reconciling or collecting, a payment for, or related to, health plan premiums or health care, where such payment is made by any means, including a credit, debit, or other payment card, an account, check, or electronic funds transfer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8604223-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–8/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The request for, or the use or disclosure of, information by the entity with respect to a payment described in paragraph (1)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8604224-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–8/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for transferring receivables;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8604225-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–8/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for auditing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8604226-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–8/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in connection with—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb8604227-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–8/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a customer dispute; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8604228-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–8/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an inquiry from, or to, a customer;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8604229-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–8/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in a communication to a customer of the entity regarding the customer’s transactions, payment card, account, check, or electronic funds transfer;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb860422a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–8/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for reporting to consumer reporting agencies; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb860422b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–8/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for complying with—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb860422c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–8/2/F/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a civil or criminal subpoena; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb860422d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–8/2/F/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Federal or State law regulating the entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb860422e-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title XI, § 1179, as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/191/tII/s262/a"},"text":"Pub. L. 104–191, title II, § 262(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-21"},"text":"Aug. 21, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2030"},"text":"110 Stat. 2030","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
