{"tag":"section","attrib":{"id":"idbded7551-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6992h"},"text":null,"children":[{"tag":"num","attrib":{"value":"6992h"},"text":"§ 6992h.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Health impacts report","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Within 24 months after ","children":[{"tag":"date","attrib":{"date":"1988-11-01"},"text":"November 1, 1988","children":[],"tail":", the Administrator of the Agency for Toxic Substances and Disease Registry shall prepare for Congress a report on the health effects of medical waste, including each of the following—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbded7552-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6992h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of the potential for infection or injury from the segregation, handling, storage, treatment, or disposal of medical wastes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbded7553-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6992h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An estimate of the number of people injured or infected annually by sharps, and the nature and seriousness of those injuries or infections.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbded7554-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6992h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An estimate of the number of people infected annually by other means related to waste segregation, handling, storage, treatment, or disposal, and the nature and seriousness of those infections.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbded7555-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6992h/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For diseases possibly spread by medical waste, including Acquired Immune Deficiency Syndrome and hepatitis B, an estimate of what percentage of the total number of cases nationally may be traceable to medical wastes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbded7556-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/272/tII/s11008"},"text":"Pub. L. 89–272, title II, § 11008","children":[],"tail":", formerly § 11009, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/582/s2/a"},"text":"Pub. L. 100–582, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-01"},"text":"Nov. 1, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2957"},"text":"102 Stat. 2957","children":[],"tail":"; renumbered § 11008, "},{"tag":"ref","attrib":{"href":"/us/pl/105/362/tV/s501/h/1/B"},"text":"Pub. L. 105–362, title V, § 501(h)(1)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-10"},"text":"Nov. 10, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3284"},"text":"112 Stat. 3284","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbded7557-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbded7558-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbded7559-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"