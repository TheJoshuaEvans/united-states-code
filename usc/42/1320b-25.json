{"tag":"section","attrib":{"id":"idb8545b7b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–25"},"text":null,"children":[{"tag":"num","attrib":{"value":"1320b–25"},"text":"§ 1320b–25.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting to law enforcement of crimes occurring in federally funded long-term care facilities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8545b7c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–25/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination and notification","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8545b7d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–25/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The owner or operator of each long-term care facility that receives Federal funds under this chapter shall annually determine whether the facility received at least $10,000 in such Federal funds during the preceding year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8545b7e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–25/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the owner or operator determines under paragraph (1) that the facility received at least $10,000 in such Federal funds during the preceding year, such owner or operator shall annually notify each covered individual (as defined in paragraph (3)) of that individual’s obligation to comply with the reporting requirements described in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8545b7f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–25/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered individual defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “covered individual” means each individual who is an owner, operator, employee, manager, agent, or contractor of a long-term care facility that is the subject of a determination described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8545b80-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–25/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting requirements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8545b81-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–25/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each covered individual shall report to the Secretary and 1 or more law enforcement entities for the political subdivision in which the facility is located any reasonable suspicion of a crime (as defined by the law of the applicable political subdivision) against any individual who is a resident of, or is receiving care from, the facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8545b82-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–25/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timing","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the events that cause the suspicion—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8545b83-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–25/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" result in serious bodily injury, the individual shall report the suspicion immediately, but not later than 2 hours after forming the suspicion; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8545b84-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–25/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" do not result in serious bodily injury, the individual shall report the suspicion not later than 24 hours after forming the suspicion.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8545b85-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–25/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalties","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8545b86-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–25/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a covered individual violates subsection (b)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8545b87-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–25/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the covered individual shall be subject to a civil money penalty of not more than $200,000; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8545b88-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–25/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary may make a determination in the same proceeding to exclude the covered individual from participation in any Federal health care program (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320a–7b/f"},"text":"section 1320a–7b(f) of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8545b89-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–25/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Increased harm","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a covered individual violates subsection (b) and the violation exacerbates the harm to the victim of the crime or results in harm to another individual—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8545b8a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–25/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the covered individual shall be subject to a civil money penalty of not more than $300,000; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8545b8b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–25/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary may make a determination in the same proceeding to exclude the covered individual from participation in any Federal health care program (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320a–7b/f"},"text":"section 1320a–7b(f) of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8545b8c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–25/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Excluded individual","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"During any period for which a covered individual is classified as an excluded individual under paragraph (1)(B) or (2)(B), a long-term care facility that employs such individual shall be ineligible to receive Federal funds under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8545b8d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–25/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extenuating circumstances","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8545b8e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–25/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may take into account the financial burden on providers with underserved populations in determining any penalty to be imposed under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8545b8f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–25/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Underserved population defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this paragraph, the term “underserved population” means the population of an area designated by the Secretary as an area with a shortage of elder justice programs or a population group designated by the Secretary as having a shortage of such programs. Such areas or groups designated by the Secretary may include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb8545b90-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–25/c/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" areas or groups that are geographically isolated (such as isolated in a rural area);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8545b91-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–25/c/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" racial and ethnic minority populations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8545b92-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–25/c/4/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" populations underserved because of special needs (such as language barriers, disabilities, alien status, or age).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8545b93-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–25/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional penalties for retaliation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8545b94-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–25/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A long-term care facility may not—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8545b95-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–25/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" discharge, demote, suspend, threaten, harass, or deny a promotion or other employment-related benefit to an employee, or in any other manner discriminate against an employee in the terms and conditions of employment because of lawful acts done by the employee; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8545b96-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–25/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" file a complaint or a report against a nurse or other employee with the appropriate State professional disciplinary agency because of lawful acts done by the nurse or employee,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"for making a report, causing a report to be made, or for taking steps in furtherance of making a report pursuant to subsection (b)(1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8545b97-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–25/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalties for retaliation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a long-term care facility violates subparagraph (A) or (B) of paragraph (1) the facility shall be subject to a civil money penalty of not more than $200,000 or the Secretary may classify the entity as an excluded entity for a period of 2 years pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320a–7/b"},"text":"section 1320a–7(b) of this title","children":[],"tail":", or both."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8545b98-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–25/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement to post notice","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each long-term care facility shall post conspicuously in an appropriate location a sign (in a form specified by the Secretary) specifying the rights of employees under this section. Such sign shall include a statement that an employee may file a complaint with the Secretary against a long-term care facility that violates the provisions of this subsection and information with respect to the manner of filing such a complaint.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8545b99-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–25/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedure","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320a–7a"},"text":"section 1320a–7a of this title","children":[],"tail":" (other than subsections (a) and (b) and the second sentence of subsection (f)) shall apply to a civil money penalty or exclusion under this section in the same manner as such provisions apply to a penalty or proceeding under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320a–7a/a"},"text":"section 1320a–7a(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8545b9a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–25/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the terms “elder justice”, “long-term care facility”, and “law enforcement” have the meanings given those terms in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1397j"},"text":"section 1397j of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8545b9b-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title XI, § 1150B, as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tVI/s6703/b/3"},"text":"Pub. L. 111–148, title VI, § 6703(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/800"},"text":"124 Stat. 800","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
