{"tag":"section","attrib":{"id":"idbc2140b9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2325"},"text":null,"children":[{"tag":"num","attrib":{"value":"2325"},"text":"§ 2325.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sales price","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbc2140ba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2325/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Government-owned single or duplex houses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the sale to priority purchasers of properties on which are located Government-owned single or duplex houses, the sales price shall be the appraised value less a deduction of 15 per centum of the appraised value and less the deductions provided by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2326"},"text":"section 2326 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc2140bb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2325/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other properties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In all other cases the sales price to priority purchasers shall be the appraised value less the deductions provided by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2326"},"text":"section 2326 of this title","children":[],"tail":", except that sales made under sections 2343(b) and 2343(c) of this title shall be made at the prices set forth therein."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc2140bc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2325/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appraised value of interest in commercial property","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The appraised value of the Government’s interest in commercial property shall, in the cases where renegotiation of the lease is requested by the lessee under the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2201/e"},"text":"section 2201(e) of this title","children":[],"tail":" be based upon the renegotiated lease if any is agreed on. Where such renegotiations are requested, the sales proceedings shall not be initiated until the completion of the renegotiation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc2140bd-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1955-08-04/ch543"},"text":"Aug. 4, 1955, ch. 543","children":[],"tail":", ch. 3, § 35, "},{"tag":"ref","attrib":{"href":"/us/stat/69/474"},"text":"69 Stat. 474","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/85/162/tII/s202"},"text":"Pub. L. 85–162, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1957-08-21"},"text":"Aug. 21, 1957","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/71/410"},"text":"71 Stat. 410","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc2140be-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc2140bf-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbc2140c0-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1957—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/162"},"text":"Pub. L. 85–162","children":[],"tail":" added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbc2140c1-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbc2140c2-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Report With Respect to Renegotiations, Reappraisals, and Sales Proceedings","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/85/162/tII/s203"},"text":"Pub. L. 85–162, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1957-08-21"},"text":"Aug. 21, 1957","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/71/410"},"text":"71 Stat. 410","children":[],"tail":", required Atomic Energy Commission, Federal Housing Administration, and Housing and Home Finance Agency to report to Joint Committee by "},{"tag":"date","attrib":{"date":"1958-01-31"},"text":"Jan. 31, 1958","children":[],"tail":", with respect to renegotiations, reappraisals, and sales proceedings authorized under subsec. (c) of this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
