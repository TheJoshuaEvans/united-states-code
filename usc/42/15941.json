{"tag":"section","attrib":{"id":"idbfebb68f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15941"},"text":null,"children":[{"tag":"num","attrib":{"value":"15941"},"text":"§ 15941.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Great Lakes oil and gas drilling ban","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No Federal or State permit or lease shall be issued for new oil and gas slant, directional, or offshore drilling in or under one or more of the Great Lakes.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbfebb690-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tIII/s386"},"text":"Pub. L. 109–58, title III, § 386","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/744"},"text":"119 Stat. 744","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
