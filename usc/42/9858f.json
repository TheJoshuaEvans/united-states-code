{"tag":"section","attrib":{"id":"idbefd386e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858f"},"text":null,"children":[{"tag":"num","attrib":{"value":"9858f"},"text":"§ 9858f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criminal background checks","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbefd386f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858f/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A State that receives funds to carry out this subchapter shall have in effect—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbefd3870-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858f/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requirements, policies, and procedures to require and conduct criminal background checks for child care staff members (including prospective child care staff members) of child care providers described in subsection (c)(1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbefd3871-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858f/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" licensing, regulation, and registration requirements, as applicable, that prohibit the employment of child care staff members as described in subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbefd3872-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858f/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A criminal background check for a child care staff member under subsection (a) shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbefd3873-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858f/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a search of the State criminal and sex offender registry or repository in the State where the child care staff member resides, and each State where such staff member resided during the preceding 5 years;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbefd3874-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858f/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a search of State-based child abuse and neglect registries and databases in the State where the child care staff member resides, and each State where such staff member resided during the preceding 5 years;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbefd3875-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858f/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a search of the National Crime Information Center;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbefd3876-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858f/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Federal Bureau of Investigation fingerprint check using the Integrated Automated Fingerprint Identification System; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbefd3877-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858f/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a search of the National Sex Offender Registry established under the Adam Walsh Child Protection and Safety Act of 2006 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16901"},"text":"42 U.S.C. 16901","children":[],"tail":" et seq.)."},{"tag":"ref","attrib":{"idref":"fn003907"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003907"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbefd3878-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858f/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibitions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbefd3879-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858f/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Child care staff members","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A child care staff member shall be ineligible for employment by a child care provider that is receiving assistance under this subchapter if such individual—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbefd387a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858f/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" refuses to consent to the criminal background check described in subsection (b);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbefd387b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858f/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" knowingly makes a materially false statement in connection with such criminal background check;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbefd387c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858f/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is registered, or is required to be registered, on a State sex offender registry or repository or the National Sex Offender Registry established under the Adam Walsh Child Protection and Safety Act of 2006 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16901"},"text":"42 U.S.C. 16901","children":[],"tail":" et seq.); "},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbeffa87d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858f/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" has been convicted of a felony consisting of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbeffa87e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858f/c/1/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" murder, as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1111"},"text":"section 1111 of title 18","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbeffa87f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858f/c/1/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" child abuse or neglect;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbeffa880-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858f/c/1/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a crime against children, including child pornography;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbeffa881-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858f/c/1/D/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" spousal abuse;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbeffa882-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858f/c/1/D/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a crime involving rape or sexual assault;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbeffa883-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858f/c/1/D/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" kidnapping;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbeffa884-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858f/c/1/D/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" arson;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbeffa885-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858f/c/1/D/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" physical assault or battery; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbeffa886-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858f/c/1/D/ix"},"text":null,"children":[{"tag":"num","attrib":{"value":"ix"},"text":"(ix)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to subsection (e)(4), a drug-related offense committed during the preceding 5 years; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbeffa887-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858f/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has been convicted of a violent misdemeanor committed as an adult against a child, including the following crimes: child abuse, child endangerment, sexual assault, or of a misdemeanor involving child pornography.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbeffa888-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858f/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Child care providers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A child care provider described in subsection (i)(1) shall be ineligible for assistance provided in accordance with this subchapter if the provider employs a staff member who is ineligible for employment under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbeffa889-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858f/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission of requests for background checks","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbeffa88a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858f/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A child care provider covered by subsection (c) shall submit a request, to the appropriate State agency designated by a State, for a criminal background check described in subsection (b), for each child care staff member (including prospective child care staff members) of the provider.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbeffa88b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858f/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Staff members","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to paragraph (4), in the case of an individual who became a child care staff member before ","children":[{"tag":"date","attrib":{"date":"2014-11-19"},"text":"November 19, 2014","children":[],"tail":", the provider shall submit such a request—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbeffa88c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858f/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prior to the last day described in subsection (j)(1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbeffa88d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858f/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less often than once during each 5-year period following the first submission date under this paragraph for that staff member.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbeffa88e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858f/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prospective staff members","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to paragraph (4), in the case of an individual who is a prospective child care staff member on or after ","children":[{"tag":"date","attrib":{"date":"2014-11-19"},"text":"November 19, 2014","children":[],"tail":", the provider shall submit such a request—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbeffa88f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858f/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prior to the date the individual becomes a child care staff member of the provider; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbeffa890-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858f/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than once during each 5-year period following the first submission date under this paragraph for that staff member.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbeffa891-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858f/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Background check for another child care provider","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A child care provider shall not be required to submit a request under paragraph (2) or (3) for a child care staff member if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbeffa892-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858f/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the staff member received a background check described in subsection (b)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbeffa893-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858f/d/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" within 5 years before the latest date on which such a submission may be made; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbeffa894-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858f/d/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" while employed by or seeking employment by another child care provider within the State;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbeffa895-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858f/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State provided to the first provider a qualifying background check result, consistent with this subchapter, for the staff member; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbeffa896-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858f/d/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the staff member is employed by a child care provider within the State, or has been separated from employment from a child care provider within the State for a period of not more than 180 consecutive days.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbeffa897-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858f/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Background check results and appeals","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbeffa898-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858f/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Background check results","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The State shall carry out the request of a child care provider for a criminal background check as expeditiously as possible, but not to exceed 45 days after the date on which such request was submitted, and shall provide the results of the criminal background check to such provider and to the current or prospective staff member.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbeffa899-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858f/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Privacy","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbeffa89a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858f/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The State shall provide the results of the criminal background check to the provider in a statement that indicates whether a child care staff member (including a prospective child care staff member) is eligible or ineligible for employment described in subsection (c), without revealing any disqualifying crime or other related information regarding the individual.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbeffa89b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858f/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ineligible staff member","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the child care staff member is ineligible for such employment due to the background check, the State will, when providing the results of the background check, include information related to each disqualifying crime, in a report to the staff member or prospective staff member.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbeffa89c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858f/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public release of results","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No State shall publicly release or share the results of individual background checks, except States may release aggregated data by crime as listed under subsection (c)(1)(D) from background check results, as long as such data is not personally identifiable information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbeffa89d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858f/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appeals","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbeffa89e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858f/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The State shall provide for a process by which a child care staff member (including a prospective child care staff member) may appeal the results of a criminal background check conducted under this section to challenge the accuracy or completeness of the information contained in such member’s criminal background report.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbeffa89f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858f/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appeals process","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The State shall ensure that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbeffa8a0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858f/e/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each child care staff member shall be given notice of the opportunity to appeal;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbeffa8a1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858f/e/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a child care staff member will receive instructions about how to complete the appeals process if the child care staff member wishes to challenge the accuracy or completeness of the information contained in such member’s criminal background report; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbeffa8a2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858f/e/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the appeals process is completed in a timely manner for each child care staff member.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbeffa8a3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858f/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The State may allow for a review process through which the State may determine that a child care staff member (including a prospective child care staff member) disqualified for a crime specified in subsection (c)(1)(D)(ix) is eligible for employment described in subsection (c)(1), notwithstanding subsection (c). The review process shall be consistent with title VII of the Civil Rights Act of 1964 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2000e"},"text":"42 U.S.C. 2000e","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbeffa8a4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858f/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No private right of action","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed to create a private right of action if a provider has acted in accordance with this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbeffa8a5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858f/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fees for background checks","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Fees that a State may charge for the costs of processing applications and administering a criminal background check as required by this section shall not exceed the actual costs to the State for the processing and administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbeffa8a6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858f/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transparency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The State must ensure that the policies and procedures under this section are published on the Web site (or otherwise publicly available venue in the absence of a Web site) of the State and the Web sites of local lead agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbeffa8a7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858f/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbeffa8a8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858f/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disqualification for other crimes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed to prevent a State from disqualifying individuals as child care staff members based on their conviction for crimes not specifically listed in this section that bear upon the fitness of an individual to provide care for and have responsibility for the safety and well-being of children.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbeffa8a9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858f/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rights and remedies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed to alter or otherwise affect the rights and remedies provided for child care staff members residing in a State that disqualifies individuals as child care staff members for crimes not specifically provided for under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbeffa8aa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858f/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbeffa8ab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858f/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “child care provider” means a center-based child care provider, a family child care provider, or another provider of child care services for compensation and on a regular basis that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbeffa8ac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858f/i/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not an individual who is related to all children for whom child care services are provided; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbeffa8ad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858f/i/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is licensed, regulated, or registered under State law or receives assistance provided under this subchapter; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbeffa8ae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858f/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “child care staff member” means an individual (other than an individual who is related to all children for whom child care services are provided)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbeffa8af-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858f/i/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who is employed by a child care provider for compensation; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbeffa8b0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858f/i/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whose activities involve the care or supervision of children for a child care provider or unsupervised access to children who are cared for or supervised by a child care provider.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbeffa8b1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858f/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbeffa8b2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858f/j/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State that receives funds under this subchapter shall meet the requirements of this section for the provision of criminal background checks for child care staff members described in subsection (d)(1) not later than the last day of the second full fiscal year after ","children":[{"tag":"date","attrib":{"date":"2014-11-19"},"text":"November 19, 2014","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbeffa8b3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858f/j/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extension","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may grant a State an extension of time, of not more than 1 fiscal year, to meet the requirements of this section if the State demonstrates a good faith effort to comply with the requirements of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbeffa8b4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858f/j/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalty for noncompliance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraphs (1) and (2), for any fiscal year that a State fails to comply substantially with the requirements of this section, the Secretary shall withhold 5 percent of the funds that would otherwise be allocated to that State in accordance with this subchapter for the following fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbeffa8b5-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35/tVI/s658H"},"text":"Pub. L. 97–35, title VI, § 658H","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/113/186/s7"},"text":"Pub. L. 113–186, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-11-19"},"text":"Nov. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1990"},"text":"128 Stat. 1990","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbeffa8b6-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbeffa8b7-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbeffa8b8-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Adam Walsh Child Protection and Safety Act of 2006, referred to in subsecs. (b)(5) and (c)(1)(C), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/248"},"text":"Pub. L. 109–248","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-07-27"},"text":"July 27, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/587"},"text":"120 Stat. 587","children":[],"tail":", which was classified principally to chapter 151 (§ 16901 et seq.) of this title, prior to editorial reclassification and renumbering as chapter 209 (§ 20901 et seq.) of Title 34, Crime Control and Law Enforcement. For complete classification of this Act to the Code, see Short Title of 2006 Act note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s10101"},"text":"section 10101 of Title 34","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Civil Rights Act of 1964, referred to in subsec. (e)(4), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/352"},"text":"Pub. L. 88–352","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-07-02"},"text":"July 2, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/241"},"text":"78 Stat. 241","children":[],"tail":". Title VII of the Act is classified generally to subchapter VI (§ 2000e et seq.) of chapter 21 of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2000a"},"text":"section 2000a of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbeffa8b9-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 9858f, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35/tVI/s658H"},"text":"Pub. L. 97–35, title VI, § 658H","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/tV/s5082/2"},"text":"Pub. L. 101–508, title V, § 5082(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-241"},"text":"104 Stat. 1388–241","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/401/s3/a"},"text":"Pub. L. 102–401, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-07"},"text":"Oct. 7, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1959"},"text":"106 Stat. 1959","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/586/s8/c/1"},"text":"Pub. L. 102–586, § 8(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-11-04"},"text":"Nov. 4, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/5036"},"text":"106 Stat. 5036","children":[],"tail":", related to early childhood development and before- and after-school services, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/104/193/tVI/s608"},"text":"Pub. L. 104–193, title VI, § 608","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-22"},"text":"Aug. 22, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2284"},"text":"110 Stat. 2284","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
