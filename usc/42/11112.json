{"tag":"section","attrib":{"id":"idbf38e1f1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11112"},"text":null,"children":[{"tag":"num","attrib":{"value":"11112"},"text":"§ 11112.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standards for professional review actions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf38e1f2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11112/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of the protection set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11111/a"},"text":"section 11111(a) of this title","children":[],"tail":", a professional review action must be taken—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf38e1f3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11112/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the reasonable belief that the action was in the furtherance of quality health care,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf38e1f4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11112/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after a reasonable effort to obtain the facts of the matter,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf38e1f5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11112/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after adequate notice and hearing procedures are afforded to the physician involved or after such other procedures as are fair to the physician under the circumstances, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf38e1f6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11112/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the reasonable belief that the action was warranted by the facts known after such reasonable effort to obtain facts and after meeting the requirement of paragraph (3).","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"A professional review action shall be presumed to have met the preceding standards necessary for the protection set out in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11111/a"},"text":"section 11111(a) of this title","children":[],"tail":" unless the presumption is rebutted by a preponderance of the evidence."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf38e1f7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11112/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adequate notice and hearing","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A health care entity is deemed to have met the adequate notice and hearing requirement of subsection (a)(3) with respect to a physician if the following conditions are met (or are waived voluntarily by the physician):","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf38e1f8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11112/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice of proposed action","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The physician has been given notice stating—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf38e1f9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11112/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbf38e1fa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11112/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that a professional review action has been proposed to be taken against the physician,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf38e1fb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11112/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reasons for the proposed action,","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf38e1fc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11112/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbf38e1fd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11112/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that the physician has the right to request a hearing on the proposed action,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf38e1fe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11112/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any time limit (of not less than 30 days) within which to request such a hearing, and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf38e1ff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11112/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a summary of the rights in the hearing under paragraph (3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf38e200-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11112/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice of hearing","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a hearing is requested on a timely basis under paragraph (1)(B), the physician involved must be given notice stating—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf38e201-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11112/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the place, time, and date, of the hearing, which date shall not be less than 30 days after the date of the notice, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf38e202-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11112/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a list of the witnesses (if any) expected to testify at the hearing on behalf of the professional review body.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf38e203-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11112/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conduct of hearing and notice","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a hearing is requested on a timely basis under paragraph (1)(B)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf38e204-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11112/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" subject to subparagraph (B), the hearing shall be held (as determined by the health care entity)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbf38e205-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11112/b/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" before an arbitrator mutually acceptable to the physician and the health care entity,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf38e206-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11112/b/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" before a hearing officer who is appointed by the entity and who is not in direct economic competition with the physician involved, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf38e207-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11112/b/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" before a panel of individuals who are appointed by the entity and are not in direct economic competition with the physician involved;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf38e208-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11112/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the right to the hearing may be forfeited if the physician fails, without good cause, to appear;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf38e209-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11112/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the hearing the physician involved has the right—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbf38e20a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11112/b/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to representation by an attorney or other person of the physician’s choice,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf38e20b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11112/b/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to have a record made of the proceedings, copies of which may be obtained by the physician upon payment of any reasonable charges associated with the preparation thereof,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf38e20c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11112/b/3/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to call, examine, and cross-examine witnesses,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf38e20d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11112/b/3/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to present evidence determined to be relevant by the hearing officer, regardless of its admissibility in a court of law, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf38e20e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11112/b/3/C/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to submit a written statement at the close of the hearing; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf38e20f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11112/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" upon completion of the hearing, the physician involved has the right—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbf38e210-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11112/b/3/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to receive the written recommendation of the arbitrator, officer, or panel, including a statement of the basis for the recommendations, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf38e211-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11112/b/3/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to receive a written decision of the health care entity, including a statement of the basis for the decision.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"A professional review body’s failure to meet the conditions described in this subsection shall not, in itself, constitute failure to meet the standards of subsection (a)(3).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf38e212-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11112/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adequate procedures in investigations or health emergencies","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11111/a"},"text":"section 11111(a) of this title","children":[],"tail":", nothing in this section shall be construed as—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf38e213-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11112/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" requiring the procedures referred to in subsection (a)(3)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf38e214-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11112/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" where there is no adverse professional review action taken, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf38e215-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11112/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a suspension or restriction of clinical privileges, for a period of not longer than 14 days, during which an investigation is being conducted to determine the need for a professional review action; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf38e216-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11112/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" precluding an immediate suspension or restriction of clinical privileges, subject to subsequent notice and hearing or other adequate procedures, where the failure to take such an action may result in an imminent danger to the health of any individual.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf38e217-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/660/tIV/s412"},"text":"Pub. L. 99–660, title IV, § 412","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3785"},"text":"100 Stat. 3785","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
