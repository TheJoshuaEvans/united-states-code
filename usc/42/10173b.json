{"tag":"section","attrib":{"id":"idbf177707-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10173b"},"text":null,"children":[{"tag":"num","attrib":{"value":"10173b"},"text":"§ 10173b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review Panel","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf177708-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10173b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Review Panel required to be established by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s10173a/b/1"},"text":"section 10173a(b)(1) of this title","children":[],"tail":" shall consist of a Chairman selected by the Secretary in consultation with the Governor of the State or governing body of the Indian tribe, as appropriate, that is party to such agreement and 6 other members as follows:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf177709-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10173b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 2 members selected by the Governor of such State or governing body of such Indian tribe;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf17770a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10173b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 2 members selected by units of local government affected by the repository or monitored retrievable storage facility;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf17770b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10173b/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 member to represent persons making payments into the Waste Fund, to be selected by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf17770c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10173b/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 member to represent other public interests, to be selected by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf17770d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10173b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf17770e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10173b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The members of the Review Panel shall serve for terms of 4 years each.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf17770f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10173b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Members of the Review Panel who are not full-time employees of the Federal Government, shall receive a per diem compensation for each day spent conducting work of the Review Panel, including their necessary travel or other expenses while engaged in the work of the Review Panel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf177710-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10173b/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Expenses of the Panel shall be paid by the Secretary from the Waste Fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf177711-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10173b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Review Panel shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf177712-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10173b/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advise the Secretary on matters relating to the proposed repository or monitored retrievable storage facility, including issues relating to design, construction, operation, and decommissioning of the facility;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf177713-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10173b/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluate performance of the repository or monitored retrievable storage facility, as it considers appropriate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf177714-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10173b/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommend corrective actions to the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf177715-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10173b/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist in the presentation of State or affected Indian tribe and local perspectives to the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf177716-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10173b/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" participate in the planning for and the review of preoperational data on environmental, demographic, and socioeconomic conditions of the site and the local community.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf177717-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10173b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall promptly ","children":[{"tag":"ref","attrib":{"idref":"fn003947"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003947"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original."}],"tail":" make available promptly "},{"tag":"ref","attrib":{"idref":"fn003947"},"text":"1","children":[],"tail":" any information in the Secretary’s possession requested by the Panel or its Chairman."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf177718-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10173b/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chapter 10 of title 5","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The requirements of chapter 10 of title 5 shall not apply to a Review Panel established under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf177719-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/425/tI/s172"},"text":"Pub. L. 97–425, title I, § 172","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/202/s101/d/tIII/s300"},"text":"Pub. L. 100–202, § 101(d) [title III, § 300]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1329-104"},"text":"101 Stat. 1329–104","children":[],"tail":", 1329–121; "},{"tag":"ref","attrib":{"href":"/us/pl/100/203/tV/s5031"},"text":"Pub. L. 100–203, title V, § 5031","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1330-239"},"text":"101 Stat. 1330–239","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/272"},"text":"Pub. L. 117–286, § 4(a)(272)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4335"},"text":"136 Stat. 4335","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf17771a-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf17771b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbf17771c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/202"},"text":"Pub. L. 100–202","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/100/203"},"text":"Pub. L. 100–203","children":[],"tail":" added identical sections."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbf17771d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":" substituted “Chapter 10 of title 5” for “Federal Advisory Committee Act” in heading and “chapter 10 of title 5” for “the Federal Advisory Committee Act” in text."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
