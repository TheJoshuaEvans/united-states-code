{"tag":"section","attrib":{"id":"idb7c7ab4c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s669a"},"text":null,"children":[{"tag":"num","attrib":{"value":"669a"},"text":"§ 669a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonliability for financial institutions providing financial records to State child support enforcement agencies in child support cases","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb7c7ab4d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s669a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of Federal or State law, a financial institution shall not be liable under any Federal or State law to any person for disclosing any financial record of an individual to a State child support enforcement agency attempting to establish, modify, or enforce a child support obligation of such individual, or for disclosing any such record to the Federal Parent Locator Service pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s666/a/17/A"},"text":"section 666(a)(17)(A) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7c7ab4e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s669a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition of disclosure of financial record obtained by State child support enforcement agency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State child support enforcement agency which obtains a financial record of an individual from a financial institution pursuant to subsection (a) may disclose such financial record only for the purpose of, and to the extent necessary in, establishing, modifying, or enforcing a child support obligation of such individual.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7c7ab4f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s669a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil damages for unauthorized disclosure","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7c7ab50-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s669a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosure by State officer or employee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If any person knowingly, or by reason of negligence, discloses a financial record of an individual in violation of subsection (b), such individual may bring a civil action for damages against such person in a district court of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7c7ab51-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s669a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No liability for good faith but erroneous interpretation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No liability shall arise under this subsection with respect to any disclosure which results from a good faith, but erroneous, interpretation of subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7c7ab52-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s669a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Damages","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In any action brought under paragraph (1), upon a finding of liability on the part of the defendant, the defendant shall be liable to the plaintiff in an amount equal to the sum of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb7c7ab53-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s669a/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the greater of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb7c7ab54-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s669a/c/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $1,000 for each act of unauthorized disclosure of a financial record with respect to which such defendant is found liable; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb7c7ab55-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s669a/c/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the sum of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb7c7ab56-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s669a/c/3/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the actual damages sustained by the plaintiff as a result of such unauthorized disclosure; plus","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb7c7ab57-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s669a/c/3/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a willful disclosure or a disclosure which is the result of gross negligence, punitive damages; plus","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7c7ab58-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s669a/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the costs (including attorney’s fees) of the action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7c7ab59-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s669a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7c7ab5a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s669a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial institution","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “financial institution” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb7c7ab5b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s669a/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a depository institution, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1813/c"},"text":"section 1813(c) of title 12","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7c7ab5c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s669a/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an institution-affiliated party, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1813/u"},"text":"section 1813(u) of title 12","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7c7ab5d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s669a/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any Federal credit union or State credit union, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1752"},"text":"section 1752 of title 12","children":[],"tail":", including an institution-affiliated party of such a credit union, as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1786/r"},"text":"section 1786(r) of title 12","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7c7ab5e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s669a/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any benefit association, insurance company, safe deposit company, money-market mutual fund, or similar entity authorized to do business in the State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7c7ab5f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s669a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial record","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “financial record” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s3401"},"text":"section 3401 of title 12","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb7c7ab60-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title IV, § 469A, as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/193/tIII/s353"},"text":"Pub. L. 104–193, title III, § 353","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-22"},"text":"Aug. 22, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2240"},"text":"110 Stat. 2240","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/200/tIV/s406/c"},"text":"Pub. L. 105–200, title IV, § 406(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-07-16"},"text":"July 16, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/672"},"text":"112 Stat. 672","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb7c7ab61-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb7c7ab62-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb7c7ab63-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/200"},"text":"Pub. L. 105–200","children":[],"tail":" inserted “, or for disclosing any such record to the Federal Parent Locator Service pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s666/a/17/A"},"text":"section 666(a)(17)(A) of this title","children":[],"tail":"” before period at end."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb7c7ab64-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb7c7ab65-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For effective date of section, see section 395(a)–(c) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/193"},"text":"Pub. L. 104–193","children":[],"tail":", set out as an Effective Date of 1996 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s654"},"text":"section 654 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
