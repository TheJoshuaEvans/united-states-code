{"tag":"section","attrib":{"id":"idbb11577a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437bbb–8"},"text":null,"children":[{"tag":"num","attrib":{"value":"1437bbb–8"},"text":"§ 1437bbb–8.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this subchapter, the following definitions shall apply:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb11577b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437bbb–8/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Jurisdiction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “jurisdiction” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbb11577c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437bbb–8/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a unit of general local government (as such term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12704"},"text":"section 12704 of this title","children":[],"tail":") that has boundaries, for purposes of carrying out this subchapter, that—"}],"tail":null},{"tag":"clause","attrib":{"id":"idbb11577d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437bbb–8/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" wholly contain the area within which a public housing agency is authorized to operate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbb11577e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437bbb–8/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" do not contain any areas contained within the boundaries of any other participating jurisdiction; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb11577f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437bbb–8/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a consortia of such units of general local government, organized for purposes of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb115780-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437bbb–8/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Participating jurisdiction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “participating jurisdiction” means, with respect to a period for which such an agreement is made, a jurisdiction that has entered into an agreement under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1437bbb–5/b/3"},"text":"section 1437bbb–5(b)(3) of this title","children":[],"tail":" to receive assistance pursuant to this subchapter for such fiscal year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbb115781-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1937-09-01/ch896"},"text":"Sept. 1, 1937, ch. 896","children":[],"tail":", title IV, § 409, as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/276/tV/s561"},"text":"Pub. L. 105–276, title V, § 561","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2624"},"text":"112 Stat. 2624","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
