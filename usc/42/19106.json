{"tag":"section","attrib":{"id":"idc07ad74c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19106"},"text":null,"children":[{"tag":"num","attrib":{"value":"19106"},"text":"§ 19106.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisory committee","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc07ad74d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19106/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In accordance with the Federal Advisory Committee Act (5 U.S.C. App.) ","children":[{"tag":"ref","attrib":{"idref":"fn004391"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004391"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" the Director shall establish an advisory committee to assess, and make recommendations regarding, the activities carried out under this part."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc07ad74e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19106/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The advisory committee members shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc07ad74f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19106/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be individuals with relevant experience or expertise, including individuals from industry and national labs, educators, academic subject matter experts, including individuals with knowledge of key technology focus areas and their impact on United States national security and geostrategic leadership, the technical and social dimensions of science and technology, technology transfer experts, labor organizations, representatives of civil society, and other nongovernmental organizations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc07ad750-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19106/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consist of at least 10 members broadly representative of stakeholders, including no less than 3 members from the private sector, none of whom shall be an employee of the Federal Government, and no less than 1 member with significant expertise in United States national security and economic competitiveness.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc07ad751-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19106/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibilities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Committee’s responsibilities shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc07ad752-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19106/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reviewing and advising on activities carried out under this part;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc07ad753-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19106/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" proposing strategies for fulfilling the purposes in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s19102"},"text":"section 19102 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc07ad754-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19106/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" proposing potential areas of research, particularly as relevant to United States societal, national, and geostrategic challenges; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc07ad755-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19106/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other relevant issues as determined by the Director.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc07ad756-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/tIII/s10386"},"text":"Pub. L. 117–167, div. B, title III, § 10386","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1578"},"text":"136 Stat. 1578","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc07ad757-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc07ad758-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc07ad759-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Advisory Committee Act, referred to in subsec. (a), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/463"},"text":"Pub. L. 92–463","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-06"},"text":"Oct. 6, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/770"},"text":"86 Stat. 770","children":[],"tail":", which was set out in the Appendix to Title 5, Government Organization and Employees, and was substantially repealed and restated in chapter 10 (§ 1001 et seq.) of Title 5 by "},{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":", §§ 3(a), 7, "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4197"},"text":"136 Stat. 4197","children":[],"tail":", 4361. For disposition of sections of the Act into chapter 10 of Title 5, see Disposition Table preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s101"},"text":"section 101 of Title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
