{"tag":"section","attrib":{"id":"idb4a4245c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–4f"},"text":null,"children":[{"tag":"num","attrib":{"value":"247b–4f"},"text":"§ 247b–4f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research relating to preterm labor and delivery and the care, treatment, and outcomes of preterm and low birthweight infants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb4a4245d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–4f/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4a4245e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–4f/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Studies and activities on preterm birth","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4a4245f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–4f/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Health and Human Services, acting through the Director of the Centers for Disease Control and Prevention, may, subject to the availability of appropriations—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4a42460-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–4f/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct epidemiological studies on the factors relating to prematurity, such as clinical, biological, social, environmental, genetic, and behavioral factors, and other determinants that contribute to health disparities and are related to prematurity, as appropriate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4a42461-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–4f/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct activities to improve national data to facilitate tracking the burden of preterm birth; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4a42462-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–4f/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" continue efforts to prevent preterm birth, including late preterm birth, through the identification of opportunities for prevention and the assessment of the impact of such efforts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4a42463-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–4f/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2013-11-27"},"text":"November 27, 2013","children":[],"tail":", and every 2 years thereafter, the Secretary of Health and Human Services, acting through the Director of the Centers for Disease Control and Prevention, shall submit to the appropriate committees of Congress reports regarding activities and studies conducted under paragraph (1), including any applicable analyses of preterm birth. Such report shall be posted on the Internet website of the Department of Health and Human Services.."},{"tag":"ref","attrib":{"idref":"fn002042"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002042"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4a42464-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–4f/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pregnancy risk assessment monitoring survey","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Health and Human Services, acting through the Director of the Centers for Disease Control and Prevention, shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4a42465-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–4f/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" continue systems for the collection of maternal-infant clinical and biomedical information, including electronic health records, electronic databases, and biobanks, to link with the Pregnancy Risk Assessment Monitoring System (PRAMS) and other epidemiological studies of prematurity in order to track, to the extent practicable, all pregnancy outcomes and prevent preterm birth; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4a42466-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–4f/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide technical assistance, as appropriate, to support States in improving the collection of information pursuant to this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4a42467-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–4f/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation of existing tools and measures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Health and Human Services shall review existing tools and measures to ensure that such tools and measures include information related to the known risk factors of low birth weight and preterm birth.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4a42468-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–4f/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this section, $2,000,000 for each of fiscal years 2026 through 2030.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb4a42469-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/450/s3"},"text":"Pub. L. 109–450, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-22"},"text":"Dec. 22, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3341"},"text":"120 Stat. 3341","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/55/tI/s102"},"text":"Pub. L. 113–55, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-11-27"},"text":"Nov. 27, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/641"},"text":"127 Stat. 641","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/328/s2"},"text":"Pub. L. 115–328, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-18"},"text":"Dec. 18, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4471"},"text":"132 Stat. 4471","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/75/dJ/tV/s6507/a"},"text":"Pub. L. 119–75, div. J, title V, § 6507(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2026-02-03"},"text":"Feb. 3, 2026","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/140/693"},"text":"140 Stat. 693","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb4a4246a-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb4a4246b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb4a4246c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/450/s3"},"text":"section 3 of Pub. L. 109–450","children":[],"tail":". Subsec. (a) of "},{"tag":"ref","attrib":{"href":"/us/pl/109/450/s3"},"text":"section 3 of Pub. L. 109–450","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s241"},"text":"section 241 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Prematurity Research Expansion and Education for Mothers who deliver Infants Early Act or the PREEMIE Act, and not as part of the Public Health Service Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb4a4246d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2026—","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/75/s6507/a/2"},"text":"Pub. L. 119–75, § 6507(a)(2)","children":[],"tail":", made technical amendment to directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/115/328/s2"},"text":"Pub. L. 115–328, § 2","children":[],"tail":". See 2018 Amendment notes below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/75/s6507/a/1"},"text":"Pub. L. 119–75, § 6507(a)(1)","children":[],"tail":", substituted “fiscal years 2026 through 2030” for “fiscal years 2019 through 2023”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (b)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/328/s2/1/A"},"text":"Pub. L. 115–328, § 2(1)(A)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/119/75/s6507/a/2"},"text":"Pub. L. 119–75, § 6507(a)(2)","children":[],"tail":", substituted “factors relating to prematurity, such as clinical, biological, social, environmental, genetic, and behavioral factors, and other determinants that contribute to health disparities and are related” for “clinical, biological, social, environmental, genetic, and behavioral factors relating”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/328/s2/1/B"},"text":"Pub. L. 115–328, § 2(1)(B)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/119/75/s6507/a/2"},"text":"Pub. L. 119–75, § 6507(a)(2)","children":[],"tail":", substituted “regarding activities and studies conducted under paragraph (1), including any applicable analyses of preterm birth. Such report shall be posted on the Internet website of the Department of Health and Human Services.” for “concerning the progress and any results of studies conducted under paragraph (1)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/328/s2/2"},"text":"Pub. L. 115–328, § 2(2)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/119/75/s6507/a/2"},"text":"Pub. L. 119–75, § 6507(a)(2)","children":[],"tail":", added subsec. (c) and struck out former subsec. (c) which established a pregnancy risk assessment monitoring survey and authorized appropriations."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/328/s2/3"},"text":"Pub. L. 115–328, § 2(3)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/119/75/s6507/a/2"},"text":"Pub. L. 119–75, § 6507(a)(2)","children":[],"tail":", substituted “$2,000,000 for each of fiscal years 2019 through 2023” for “except for subsection (c), $1,880,000 for each of fiscal years 2014 through 2018”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/55/s102/a"},"text":"Pub. L. 113–55, § 102(a)","children":[],"tail":", added subsec. (b) and struck out former subsec. (b) which related to studies and reports on the relationship between prematurity and birth defects."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/55/s102/b"},"text":"Pub. L. 113–55, § 102(b)","children":[],"tail":", substituted “$1,880,000 for each of fiscal years 2014 through 2018.” for “$5,000,000 for each of fiscal years 2007 through 2011.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb4a4246e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb4a4246f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2025 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/75/dJ/tV/s6507/a/2"},"text":"Pub. L. 119–75, div. J, title V, § 6507(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2026-02-03"},"text":"Feb. 3, 2026","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/140/693"},"text":"140 Stat. 693","children":[],"tail":", provided that the amendment made by section 6507(a)(2) is effective as if included in the enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/115/328"},"text":"Pub. L. 115–328","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb4a42470-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Advisory Committee on Infant Mortality","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/55/tI/s104/b"},"text":"Pub. L. 113–55, title I, § 104(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-11-27"},"text":"Nov. 27, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/643"},"text":"127 Stat. 643","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/115/328/s4"},"text":"Pub. L. 115–328, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-18"},"text":"Dec. 18, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4473"},"text":"132 Stat. 4473","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/328/s4"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Health and Human Services (referred to in this section [enacting this note and repealing ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s247b–4g"},"text":"section 247b–4g of this title","children":[],"tail":"] as the ‘Secretary’) may establish an advisory committee known as the ‘Advisory Committee on Infant Mortality’ (referred to in this section as the ‘Advisory Committee’)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duties","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Advisory Committee shall provide advice, recommendations, or information to the Secretary as may be necessary to improve activities and programs to reduce severe maternal morbidity, maternal mortality, infant mortality, and preterm birth, which may include recommendations, advice, or information related to the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Programs of the Department of Health and Human Services that are directed at reducing infant mortality, preterm birth, and improving the health status of pregnant women and infants, and information on cost-effectiveness and outcomes of such programs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Strategies to coordinate the various Federal programs and activities with State, local, and private programs and efforts that address factors that affect infant mortality.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Healthy Start program under section 330H of the Public Health Service Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s254c–8"},"text":"42 U.S.C. 254c–8","children":[],"tail":") and Healthy People 2020 infant mortality objectives."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"“(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Implementation of Healthy People objectives related to maternal and infant health.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"“(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Strategies to reduce racial, ethnic, geographic, and other health disparities in birth outcomes, including by increasing awareness of Federal programs related to appropriate access to, or information regarding, prenatal care to address risk factors for preterm labor and delivery.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"“(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Strategies, including the implementation of such strategies, to address gaps in Federal research, programs, and education efforts related to the prevention of severe maternal morbidity, maternal mortality, infant mortality, and other adverse birth outcomes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Membership","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall ensure that the membership of the Advisory Committee includes the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Representatives provided for in the original charter of the Advisory Committee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A representative of the National Center for Health Statistics.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Biennial report","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after the date of enactment of the PREEMIE Reauthorization Act of 2018 [","children":[{"tag":"date","attrib":{"date":"2018-12-18"},"text":"Dec. 18, 2018","children":[],"tail":"], and every 2 years thereafter, the Advisory Committee shall—"}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" publish a report summarizing activities and recommendations of the Advisory Committee since the publication of the previous report;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit such report to the Secretary and the appropriate Committees of Congress; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" post such report on the Internet website of the Department of Health and Human Services.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb4a42471-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Purpose","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/450/s2"},"text":"Pub. L. 109–450, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-22"},"text":"Dec. 22, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3341"},"text":"120 Stat. 3341","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/450/s2"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“It is the purpose of this Act [enacting this section and sections 247b–4g and 280g–5 of this title and amending sections 241 and 280g–4 of this title] to—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reduce rates of preterm labor and delivery;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" work toward an evidence-based standard of care for pregnant women at risk of preterm labor or other serious complications, and for infants born preterm and at a low birthweight; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reduce infant mortality and disabilities caused by prematurity.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
