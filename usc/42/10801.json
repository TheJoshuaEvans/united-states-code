{"tag":"section","attrib":{"id":"idbf2f44aa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10801"},"text":null,"children":[{"tag":"num","attrib":{"value":"10801"},"text":"§ 10801.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional findings and statement of purpose","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf2f44ab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10801/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf2f44ac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10801/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" individuals with mental illness are vulnerable to abuse and serious injury;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf2f44ad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10801/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" family members of individuals with mental illness play a crucial role in being advocates for the rights of individuals with mental illness where the individuals are minors, the individuals are legally competent and choose to involve the family members, and the individuals are legally incompetent and the legal guardians, conservators, or other legal representatives are members of the family;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf2f44ae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10801/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" individuals with mental illness are subject to neglect, including lack of treatment, adequate nutrition, clothing, health care, and adequate discharge planning; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf2f44af-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10801/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State systems for monitoring compliance with respect to the rights of individuals with mental illness vary widely and are frequently inadequate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf2f44b0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10801/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The purposes of this chapter are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf2f44b1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10801/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to ensure that the rights of individuals with mental illness are protected; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf2f44b2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10801/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to assist States to establish and operate a protection and advocacy system for individuals with mental illness which will—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf2f44b3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10801/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protect and advocate the rights of such individuals through activities to ensure the enforcement of the Constitution and Federal and State statutes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf2f44b4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10801/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" investigate incidents of abuse and neglect of individuals with mental illness if the incidents are reported to the system or if there is probable cause to believe that the incidents occurred.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf2f44b5-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/319/tI/s101"},"text":"Pub. L. 99–319, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-05-23"},"text":"May 23, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/478"},"text":"100 Stat. 478","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/173"},"text":"Pub. L. 102–173","children":[],"tail":", §§ 3, 10(2), "},{"tag":"date","attrib":{"date":"1991-11-27"},"text":"Nov. 27, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1217"},"text":"105 Stat. 1217","children":[],"tail":", 1219.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf2f44b6-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf2f44b7-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbf2f44b8-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (b), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/319"},"text":"Pub. L. 99–319","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-05-23"},"text":"May 23, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/478"},"text":"100 Stat. 478","children":[],"tail":", which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note below and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbf2f44b9-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/173/s10/2"},"text":"Pub. L. 102–173, § 10(2)","children":[],"tail":", substituted “individuals with mental illness” for “mentally ill individuals” in three places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2) to (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/173/s3"},"text":"Pub. L. 102–173, § 3","children":[],"tail":", added par. (2) and redesignated former pars. (2) and (3) as (3) and (4), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/173/s10/2"},"text":"Pub. L. 102–173, § 10(2)","children":[],"tail":", substituted “individuals with mental illness” for “mentally ill individuals” in three places."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbf2f44ba-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idbf2f44bb-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1991 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/173/s1"},"text":"Pub. L. 102–173, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-11-27"},"text":"Nov. 27, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1217"},"text":"105 Stat. 1217","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/173/s1"},"text":"“This Act [amending this section and sections 10802 to 10807, 10821, 10824, 10826, 10827, 10841, and 10851 of this title] may be cited as the ‘Protection and Advocacy for Mentally Ill Individuals Amendments Act of 1991’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idbf2f44bc-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/509/s1"},"text":"Pub. L. 100–509, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-20"},"text":"Oct. 20, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2543"},"text":"102 Stat. 2543","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/509/s1"},"text":"“This Act [amending sections 10802, 10804 to 10806, 10821, 10822, 10825, and 10827 of this title and enacting a provision set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s10827"},"text":"section 10827 of this title","children":[],"tail":"] may be cited as the ‘Protection and Advocacy for Mentally Ill Individuals Amendments Act of 1988’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"idbf2f44bd-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/319/s1"},"text":"Pub. L. 99–319, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-05-23"},"text":"May 23, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/478"},"text":"100 Stat. 478","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/106/310/dB/tXXXII/s3206/a"},"text":"Pub. L. 106–310, div. B, title XXXII, § 3206(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-17"},"text":"Oct. 17, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1193"},"text":"114 Stat. 1193","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/310/dB/tXXXII/s3206/a"},"text":"“This Act [enacting this chapter and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s247a"},"text":"section 247a of this title","children":[],"tail":" and enacting provisions set out as a note below] may be cited as the ‘Protection and Advocacy for Individuals with Mental Illness Act’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbf2f44be-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Supersedure of Balanced Budget Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/319/tIV/s402"},"text":"Pub. L. 99–319, title IV, § 402","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-05-23"},"text":"May 23, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/490"},"text":"100 Stat. 490","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/319/tIV/s402"},"text":"“This Act [see Short Title note above] shall not be construed as superseding any of the balanced budget provisions set forth in section 3(7) of the Congressional Budget and Impoundment Control Act of 1974 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s622/7"},"text":"2 U.S.C. 622(7)","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
