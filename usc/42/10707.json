{"tag":"section","attrib":{"id":"idbf2f4455-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10707"},"text":null,"children":[{"tag":"num","attrib":{"value":"10707"},"text":"§ 10707.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restrictions on activities of the Institute","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf2f4456-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10707/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Litigation; interference with independence of State judiciary; funding of State judicial system activities other than pursuant to this chapter; legislative lobbying","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Institute shall not—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf2f4457-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10707/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" participate in litigation unless the Institute or a recipient of the Institute is a party, and shall not participate on behalf of any client other than itself;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf2f4458-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10707/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" interfere with the independent nature of any State judicial system or allow financial assistance to be used for the funding of regular judicial and administrative activities of any State judicial system other than pursuant to the terms of any grant, cooperative agreement, or contract with the Institute, consistent with the requirements of this chapter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf2f4459-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10707/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" undertake to influence the passage or defeat of any legislation by the Congress of the United States or by any State or local legislative body, except that personnel of the Institute may testify or make other appropriate communication—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf2f445a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10707/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" when formally requested to do so by a legislative body, committee, or a member thereof;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf2f445b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10707/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in connection with legislation or appropriations directly affecting the activities of the Institute; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf2f445c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10707/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in connection with legislation or appropriations dealing with improvements in the State judiciary, consistent with the provisions of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf2f445d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10707/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Issuance of shares of stock; declaration of dividends; compensation for services; reimbursement for expenses; political activities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf2f445e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10707/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Institute shall have no power to issue any shares of stock, or to declare or pay any dividends.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf2f445f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10707/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No part of the income or assets of the Institute shall enure to the benefit of any director, officer, or employee, except as reasonable compensation for services or reimbursement for expenses.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf2f4460-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10707/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Neither the Institute nor any recipient shall contribute or make available Institute funds or program personnel or equipment to any political party or association, or the campaign of any candidate for public or party office.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf2f4461-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10707/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Institute shall not contribute or make available Institute funds or program personnel or equipment for use in advocating or opposing any ballot measure, initiative, or referendum.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf2f4462-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10707/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Identification of Institute with political activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Officers and employees of the Institute or of recipients shall not at any time intentionally identify the Institute or the recipient with any partisan or nonpartisan political activity associated with a political party or association, or the campaign of any candidate for public or party office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf2f4463-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/620/tII/s208"},"text":"Pub. L. 98–620, title II, § 208","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-11-08"},"text":"Nov. 8, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3343"},"text":"98 Stat. 3343","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf2f4464-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf2f4465-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbf2f4466-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (a), was in the original “this title”, meaning title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/620"},"text":"Pub. L. 98–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-11-08"},"text":"Nov. 8, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3336"},"text":"98 Stat. 3336","children":[],"tail":", known as the State Justice Institute Act of 1984, which is classified principally to this chapter. For complete classification of title II to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s10701"},"text":"section 10701 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbf2f4467-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbf2f4468-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1985-10-01"},"text":"Oct. 1, 1985","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/620/s216"},"text":"section 216 of Pub. L. 98–620","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s10701"},"text":"section 10701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
