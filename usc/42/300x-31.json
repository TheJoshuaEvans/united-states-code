{"tag":"section","attrib":{"id":"idb66b9d36-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–31"},"text":null,"children":[{"tag":"num","attrib":{"value":"300x–31"},"text":"§ 300x–31.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restrictions on expenditure of grant","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb66b9d37-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–31/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb66b9d38-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–31/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain restrictions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A funding agreement for a grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x–21"},"text":"section 300x–21 of this title","children":[],"tail":" is that the State involved will not expend the grant—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb66b9d39-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–31/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide inpatient hospital services, except as provided in subsection (b);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb66b9d3a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–31/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to make cash payments to intended recipients of health services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb66b9d3b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–31/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to purchase or improve land, purchase, construct, or permanently improve (other than minor remodeling) any building or other facility, or purchase major medical equipment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb66b9d3c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–31/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to satisfy any requirement for the expenditure of non-Federal funds as a condition for the receipt of Federal funds;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb66b9d3d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–31/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide financial assistance to any entity other than a public or nonprofit private entity; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb66b9d3e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–31/a/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to carry out any program prohibited by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ee–5"},"text":"section 300ee–5 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb66b9d3f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–31/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on administrative expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A funding agreement for a grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x–21"},"text":"section 300x–21 of this title","children":[],"tail":" is that the State involved will not expend more than 5 percent of the grant to pay the costs of administering the grant."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb66b9d40-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–31/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation regarding penal and correctional institutions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A funding agreement for a State for a grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x–21"},"text":"section 300x–21 of this title","children":[],"tail":" is that, in expending the grant for the purpose of providing treatment services in penal or correctional institutions of the State, the State will not expend more than an amount equal to the amount expended for such purpose by the State from the grant made under section 300x–1a "},{"tag":"ref","attrib":{"idref":"fn002392"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002392"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title to the State for fiscal year 1991 (as section 300x–1a "},{"tag":"ref","attrib":{"idref":"fn002392"},"text":"1","children":[],"tail":" of this title was in effect for such fiscal year)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb66b9d41-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–31/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception regarding inpatient hospital services","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb66b9d42-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–31/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Medical necessity as precondition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to compliance with the agreement made under subsection (a), a State may expend a grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x–21"},"text":"section 300x–21 of this title","children":[],"tail":" to provide inpatient hospital services as treatment for substance use disorders only if it has been determined, in accordance with guidelines issued by the Secretary, that such treatment is a medical necessity for the individual involved, and that the individual cannot be effectively treated in a community-based, nonhospital, residential program of treatment."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb66b9d43-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–31/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rate of payment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of an individual for whom a grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x–21"},"text":"section 300x–21 of this title","children":[],"tail":" is expended to provide inpatient hospital services described in paragraph (1), a funding agreement for the grant for the State involved is that the daily rate of payment provided to the hospital for providing the services to the individual will not exceed the comparable daily rate provided for community-based, nonhospital, residential programs of treatment for substance use disorders."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb66b9d44-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–31/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver regarding construction of facilities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb66b9d45-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–31/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may provide to any State a waiver of the restriction established in subsection (a)(1)(C) for the purpose of authorizing the State to expend a grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x–21"},"text":"section 300x–21 of this title","children":[],"tail":" for the construction of a new facility or rehabilitation of an existing facility, but not for land acquisition."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb66b9d46-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–31/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standard regarding need for waiver","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may approve a waiver under paragraph (1) only if the State demonstrates to the Secretary that adequate treatment cannot be provided through the use of existing facilities and that alternative facilities in existing suitable buildings are not available.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb66b9d47-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–31/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In granting a waiver under paragraph (1), the Secretary shall allow the use of a specified amount of funds to construct or rehabilitate a specified number of beds for residential treatment and a specified number of slots for outpatient treatment, based on reasonable estimates by the State of the costs of construction or rehabilitation. In considering waiver applications, the Secretary shall ensure that the State has carefully designed a program that will minimize the costs of additional beds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb66b9d48-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–31/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matching funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may grant a waiver under paragraph (1) only if the State agrees, with respect to the costs to be incurred by the State in carrying out the purpose of the waiver, to make available non-Federal contributions in cash toward such costs in an amount equal to not less than $1 for each $1 of Federal funds provided under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x–21"},"text":"section 300x–21 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb66b9d49-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–31/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Date certain for acting upon request","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall act upon a request for a waiver under paragraph (1) not later than 120 days after the date on which the request is made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb66b9d4a-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XIX, § 1931, as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/321/tII/s202"},"text":"Pub. L. 102–321, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-10"},"text":"July 10, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/397"},"text":"106 Stat. 397","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/255/dB/tVIII/s8002/h"},"text":"Pub. L. 114–255, div. B, title VIII, § 8002(h)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-13"},"text":"Dec. 13, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1230"},"text":"130 Stat. 1230","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dFF/tI/s1241/a/7"},"text":"Pub. L. 117–328, div. FF, title I, § 1241(a)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5677"},"text":"136 Stat. 5677","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb66b9d4b-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb66b9d4c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb66b9d4d-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x–1a"},"text":"Section 300x–1a of this title","children":[],"tail":", referred to in subsec. (a)(3), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/102/321/tII/s201/2"},"text":"Pub. L. 102–321, title II, § 201(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-10"},"text":"July 10, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/378"},"text":"106 Stat. 378","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb66b9d4e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1931 of act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300y–21"},"text":"section 300y–21 of this title","children":[],"tail":" and subsequently omitted from the Code."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 1931 of act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300y–10"},"text":"section 300y–10 of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/99/280"},"text":"Pub. L. 99–280","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb66b9d4f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328"},"text":"Pub. L. 117–328","children":[],"tail":" substituted “substance use disorders” for “substance abuse”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255"},"text":"Pub. L. 114–255","children":[],"tail":" substituted “substance use disorders” for “substance abuse”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
