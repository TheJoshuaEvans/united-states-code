{"tag":"section","attrib":{"id":"idbb7f0e4a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1792"},"text":null,"children":[{"tag":"num","attrib":{"value":"1792"},"text":"§ 1792.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Promoting Federal food donation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbb7f0e4b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1792/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2008-06-20"},"text":"June 20, 2008","children":[],"tail":", the Federal Acquisition Regulation issued in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t41/s1303"},"text":"section 1303 of title 41","children":[],"tail":" shall be revised to provide that all contracts above $25,000 for the provision, service, or sale of food in the United States, or for the lease or rental of Federal property to a private entity for events at which food is provided in the United States, shall include a clause that—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb7f0e4c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1792/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourages the donation of excess, apparently wholesome food to nonprofit organizations that provide assistance to food-insecure people in the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb7f0e4d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1792/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" states the terms and conditions described in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb7f0e4e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1792/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms and conditions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb7f0e4f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1792/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In any case in which a contractor enters into a contract with an executive agency under which apparently wholesome food is donated to food-insecure people in the United States, the head of the executive agency shall not assume responsibility for the costs and logistics of collecting, transporting, maintaining the safety of, or distributing excess, apparently wholesome food to food-insecure people in the United States under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb7f0e50-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1792/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An executive agency (including an executive agency that enters into a contract with a contractor) and any contractor making donations pursuant to this section shall be exempt from civil and criminal liability to the extent provided under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1791"},"text":"section 1791 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbb7f0e51-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/247/s4"},"text":"Pub. L. 110–247, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-06-20"},"text":"June 20, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2314"},"text":"122 Stat. 2314","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbb7f0e52-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbb7f0e53-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbb7f0e54-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This section, referred to in subsec. (b), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/247"},"text":"Pub. L. 110–247","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-06-20"},"text":"June 20, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2314"},"text":"122 Stat. 2314","children":[],"tail":", which enacted this section and provisions set out as notes under this section and "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1771"},"text":"section 1771 of this title","children":[],"tail":". For complete classification of this Act to the Code, see Short Title of 2008 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1771"},"text":"section 1771 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbb7f0e55-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Federal Food Donation Act of 2008, and not as part of the Child Nutrition Act of 1966 which comprises this chapter.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsec. (a), “","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s1303"},"text":"section 1303 of title 41","children":[],"tail":"” substituted for “section 25 of the Office of Federal Procurement Policy Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t41/s421"},"text":"41 U.S.C. 421","children":[],"tail":")” on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/111/350/s6/c"},"text":"Pub. L. 111–350, § 6(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3854"},"text":"124 Stat. 3854","children":[],"tail":", which Act enacted Title 41, Public Contracts."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbb7f0e56-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbb7f0e57-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Purpose","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/247/s2"},"text":"Pub. L. 110–247, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-06-20"},"text":"June 20, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2314"},"text":"122 Stat. 2314","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/247/s2"},"text":"“The purpose of this Act [enacting this section and provisions set out as notes under this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1771"},"text":"section 1771 of this title","children":[],"tail":"] is to encourage executive agencies and contractors of executive agencies, to the maximum extent practicable and safe, to donate excess, apparently wholesome food to feed food-insecure people in the United States.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idbb7f0e58-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/247/s3"},"text":"Pub. L. 110–247, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-06-20"},"text":"June 20, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2314"},"text":"122 Stat. 2314","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/247/s3"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“In this Act [enacting this section and provisions set out as notes under this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1771"},"text":"section 1771 of this title","children":[],"tail":"]:"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Apparently wholesome food","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘apparently wholesome food’ has the meaning given the term in section 2(b) [probably means subsec. (b)] of the Bill Emerson Good Samaritan Food Donation Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1791/b"},"text":"42 U.S.C. 1791(b)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Excess","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term ‘excess’, when applied to food, means food that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not required to meet the needs of executive agencies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" would otherwise be discarded.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Food-insecure","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘food-insecure’ means inconsistent access to sufficient, safe, and nutritious food.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nonprofit organization","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term ‘nonprofit organization’ means any organization that is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" described in section 501(c) of the Internal Revenue Code of 1986 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s501/c"},"text":"26 U.S.C. 501(c)","children":[],"tail":"]; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exempt from tax under section 501(a) of that Code [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s501/a"},"text":"26 U.S.C. 501(a)","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
