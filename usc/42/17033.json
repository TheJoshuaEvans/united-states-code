{"tag":"section","attrib":{"id":"idc0203521-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17033"},"text":null,"children":[{"tag":"num","attrib":{"value":"17033"},"text":"§ 17033.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Biofuels and biorefinery information center","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc0203522-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17033/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, in cooperation with the Secretary of Agriculture, shall establish a biofuels and biorefinery information center to make available to interested parties information on—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0203523-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17033/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" renewable fuel feedstocks, including the varieties of fuel capable of being produced from various feedstocks;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0203524-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17033/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" biorefinery processing techniques related to various renewable fuel feedstocks;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0203525-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17033/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the distribution, blending, storage, and retail dispensing infrastructure necessary for the transport and use of renewable fuels;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0203526-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17033/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal and State laws and incentives related to renewable fuel production and use;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0203527-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17033/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" renewable fuel research and development advancements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0203528-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17033/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" renewable fuel development and biorefinery processes and technologies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0203529-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17033/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" renewable fuel resources, including information on programs and incentives for renewable fuels;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc020352a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17033/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" renewable fuel producers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc020352b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17033/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" renewable fuel users; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc020352c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17033/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" potential renewable fuel users.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc020352d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17033/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In administering the biofuels and biorefinery information center, the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc020352e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17033/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" continually update information provided by the center;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc020352f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17033/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make information available relating to processes and technologies for renewable fuel production;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0203530-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17033/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make information available to interested parties on the process for establishing a biorefinery; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0203531-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17033/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make information and assistance provided by the center available through a toll-free telephone number and website.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0203532-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17033/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination and nonduplication","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the maximum extent practicable, the Secretary shall ensure that the activities under this section are coordinated with, and do not duplicate the efforts of, centers at other government agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0203533-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17033/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums as are necessary to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc0203534-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/tII/s229"},"text":"Pub. L. 110–140, title II, § 229","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1535"},"text":"121 Stat. 1535","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc0203535-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc0203536-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc0203537-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the date that is 1 day after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/s1601"},"text":"section 1601 of Pub. L. 110–140","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1824"},"text":"section 1824 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
