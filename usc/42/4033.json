{"tag":"section","attrib":{"id":"idbcadf19b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4033"},"text":null,"children":[{"tag":"num","attrib":{"value":"4033"},"text":"§ 4033.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation of Flood Insurance Advocate","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbcadf19c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4033/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall designate a Flood Insurance Advocate to advocate for the fair treatment of policy holders under the National Flood Insurance Program and property owners in the mapping of flood hazards, the identification of risks from flood, and the implementation of measures to minimize the risk of flood.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcadf19d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4033/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties and responsibilities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The duties and responsibilities of the Flood Insurance Advocate designated under subsection (a) shall be to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbcadf19e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4033/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" educate property owners and policyholders under the National Flood Insurance Program on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbcadf19f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4033/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" individual flood risks;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcadf1a0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4033/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" flood mitigation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcadf1a1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4033/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" measures to reduce flood insurance rates through effective mitigation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcadf1a2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4033/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the flood insurance rate map review and amendment process; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcadf1a3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4033/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any changes in the flood insurance program as a result of any newly enacted laws (including this Act);","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcadf1a4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4033/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist policy holders under the National Flood Insurance Program and property owners to understand the procedural requirements related to appealing preliminary flood insurance rate maps and implementing measures to mitigate evolving flood risks;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcadf1a5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4033/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist in the development of regional capacity to respond to individual constituent concerns about flood insurance rate map amendments and revisions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcadf1a6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4033/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate outreach and education with local officials and community leaders in areas impacted by proposed flood insurance rate map amendments and revisions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcadf1a7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4033/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" aid potential policy holders under the National Flood Insurance Program in obtaining and verifying accurate and reliable flood insurance rate information when purchasing or renewing a flood insurance policy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbcadf1a8-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/89/s24"},"text":"Pub. L. 113–89, § 24","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-03-21"},"text":"Mar. 21, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1030"},"text":"128 Stat. 1030","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbcadf1a9-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbcadf1aa-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbcadf1ab-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in subsec. (b)(1)(E), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/89"},"text":"Pub. L. 113–89","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-03-21"},"text":"Mar. 21, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1020"},"text":"128 Stat. 1020","children":[],"tail":", known as the Homeowner Flood Insurance Affordability Act of 2014. For complete classification of this Act to the Code, see Short Title of 2014 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4001"},"text":"section 4001 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbcadf1ac-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Homeowner Flood Insurance Affordability Act of 2014, and not as part of the National Flood Insurance Act of 1968 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbcadf1ad-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idbcadf1ae-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definitions of terms used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4005"},"text":"section 4005 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
