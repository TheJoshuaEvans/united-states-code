{"tag":"section","attrib":{"id":"idbdc99a17-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6915"},"text":null,"children":[{"tag":"num","attrib":{"value":"6915"},"text":"§ 6915.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Administrator shall transmit to the Congress and the President, not later than ninety days after the end of each fiscal year, a comprehensive and detailed report on all activities of the Office during the preceding fiscal year. Each such report shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbdc99a18-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6915/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a statement of specific and detailed objectives for the activities and programs conducted and assisted under this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdc99a19-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6915/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" statements of the Administrator’s conclusions as to the effectiveness of such activities and programs in meeting the stated objectives and the purposes of this chapter, measured through the end of such fiscal year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdc99a1a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6915/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a summary of outstanding solid waste problems confronting the Administrator, in order of priority;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdc99a1b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6915/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommendations with respect to such legislation which the Administrator deems necessary or desirable to assist in solving problems respecting solid waste;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdc99a1c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6915/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all other information required to be submitted to the Congress pursuant to any other provision of this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdc99a1d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6915/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Administrator’s plans for activities and programs respecting solid waste during the next fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbdc99a1e-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/272/tII/s2006"},"text":"Pub. L. 89–272, title II, § 2006","children":[],"tail":", formerly § 2005, as added "},{"tag":"ref","attrib":{"href":"/us/pl/94/580/s2"},"text":"Pub. L. 94–580, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2805"},"text":"90 Stat. 2805","children":[],"tail":", and renumbered "},{"tag":"ref","attrib":{"href":"/us/pl/96/463/s4/a"},"text":"Pub. L. 96–463, § 4(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-15"},"text":"Oct. 15, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2056"},"text":"94 Stat. 2056","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/98/616/tV/s502/b"},"text":"Pub. L. 98–616, title V, § 502(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-11-08"},"text":"Nov. 8, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3276"},"text":"98 Stat. 3276","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbdc99a1f-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbdc99a20-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbdc99a21-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/272/s2006"},"text":"section 2006 of Pub. L. 89–272","children":[],"tail":" was renumbered section 2007 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s6916"},"text":"section 6916 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbdc99a22-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1984—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/616"},"text":"Pub. L. 98–616","children":[],"tail":" substituted “detailed” for “detail”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbdc99a23-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","a