{"tag":"section","attrib":{"id":"idbe0c6fb2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384t"},"text":null,"children":[{"tag":"num","attrib":{"value":"7384t"},"text":"§ 7384t.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Medical benefits","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbe0c6fb3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384t/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Medical benefits provided","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The United States shall furnish, to an individual receiving medical benefits under this section for an illness, the services, appliances, and supplies prescribed or recommended by a qualified physician for that illness, which the President considers likely to cure, give relief, or reduce the degree or the period of that illness.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe0c6fb4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384t/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Persons furnishing benefits","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe0c6fb5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384t/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" These services, appliances, and supplies shall be furnished by or on the order of United States medical officers and hospitals, or, at the individual’s option, by or on the order of physicians and hospitals designated or approved by the President.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe0c6fb6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384t/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The individual may initially select a physician to provide medical services, appliances, and supplies under this section in accordance with such regulations and instructions as the President considers necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe0c6fb7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384t/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transportation and expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The individual may be furnished necessary and reasonable transportation and expenses incident to the securing of such services, appliances, and supplies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe0c6fb8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384t/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commencement of benefits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An individual receiving benefits under this section shall be furnished those benefits as of the date on which that individual submitted the claim for those benefits in accordance with this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe0c6fb9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384t/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment from compensation fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The benefits provided under this section, when authorized or approved by the President, shall be paid from the compensation fund established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7384e"},"text":"section 7384e of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe0c6fba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384t/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall take effect on ","children":[{"tag":"date","attrib":{"date":"2001-07-31"},"text":"July 31, 2001","children":[],"tail":", unless Congress otherwise provides in an Act enacted before that date."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbe0c6fbb-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dC/tXXXVI/s3629"},"text":"Pub. L. 106–398, § 1 [div. C, title XXXVI, § 3629]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–507.)"}],"tail":"\n"}],"tail":null}
