{"tag":"section","attrib":{"id":"idbd310340-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5205a"},"text":null,"children":[{"tag":"num","attrib":{"value":"5205a"},"text":"§ 5205a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain recoupment prohibited","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd310341-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5205a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, the Agency shall deem any covered disaster assistance to have been properly procured, provided, and utilized, and shall restore any funding of covered disaster assistance previously provided but subsequently withdrawn or deobligated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd310342-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5205a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered disaster assistance defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “covered disaster assistance” means assistance—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd310343-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5205a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provided to a local government pursuant to section 5170b, 5172, or 5173 of this title; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd310344-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5205a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" with respect to which the inspector general of the Department of Homeland Security has determined, after an audit, that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd310345-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5205a/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Agency deployed to the local government a Technical Assistance Contractor to review field operations, provide eligibility advice, and assist with day-to-day decisions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd310346-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5205a/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Technical Assistance Contractor provided inaccurate information to the local government; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd310347-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5205a/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the local government relied on the inaccurate information to determine that relevant contracts were eligible, reasonable, and reimbursable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd310348-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5205a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall be effective on ","children":[{"tag":"date","attrib":{"date":"2018-10-05"},"text":"October 5, 2018","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd310349-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/dD/s1237"},"text":"Pub. L. 115–254, div. D, § 1237","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3464"},"text":"132 Stat. 3464","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd31034a-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd31034b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbd31034c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Disaster Recovery Reform Act of 2018 and as part of the FAA Reauthorization Act of 2018, and not as part of the Robert T. Stafford Disaster Relief and Emergency Assistance Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbd31034d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idbd31034e-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definition of “Agency” as used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/s1203"},"text":"section 1203 of Pub. L. 115–254","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5122"},"text":"section 5122 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
