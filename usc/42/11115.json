{"tag":"section","attrib":{"id":"idbf38e21c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11115"},"text":null,"children":[{"tag":"num","attrib":{"value":"11115"},"text":"§ 11115.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf38e21d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11115/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as specifically provided in this subchapter, nothing in this subchapter shall be construed as changing the liabilities or immunities under law or as preempting or overriding any State law which provides incentives, immunities, or protection for those engaged in a professional review action that is in addition to or greater than that provided by this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf38e21e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11115/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scope of clinical privileges","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subchapter shall be construed as requiring health care entities to provide clinical privileges to any or all classes or types of physicians or other licensed health care practitioners.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf38e21f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11115/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of nurses and other practitioners","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subchapter shall be construed as affecting, or modifying any provision of Federal or State law, with respect to activities of professional review bodies regarding nurses, other licensed health care practitioners, or other health professionals who are not physicians.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf38e220-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11115/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of patient malpractice claims","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter shall be construed as affecting in any manner the rights and remedies afforded patients under any provision of Federal or State law to seek redress for any harm or injury suffered as a result of negligent treatment or care by any physician, health care practitioner, or health care entity, or as limiting any defenses or immunities available to any physician, health care practitioner, or health care entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf38e221-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/660/tIV/s415"},"text":"Pub. L. 99–660, title IV, § 415","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3787"},"text":"100 Stat. 3787","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/177/tIV/s402/c"},"text":"Pub. L. 100–177, title IV, § 402(c)","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/239/tVI/s6103/e/6/A"},"text":"Pub. L. 101–239, title VI, § 6103(e)(6)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2208"},"text":"103 Stat. 2208","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf38e222-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf38e223-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbf38e224-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1989—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239"},"text":"Pub. L. 101–239","children":[],"tail":" added "},{"tag":"ref","attrib":{"href":"/us/pl/100/177/s402/c"},"text":"Pub. L. 100–177, § 402(c)","children":[],"tail":", see 1987 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/177/s402/c"},"text":"Pub. L. 100–177, § 402(c)","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/101/239"},"text":"Pub. L. 101–239","children":[],"tail":", inserted before period at end “or as preempting or overriding any State law which provides incentives, immunities, or protection for those engaged in a professional review action that is in addition to or greater than that provided by this subchapter”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbf38e225-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[