{"tag":"section","attrib":{"id":"idbaad3f76-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397m–5"},"text":null,"children":[{"tag":"num","attrib":{"value":"1397m–5"},"text":"§ 1397m–5.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Nothing in this division shall be construed as—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbaad3f77-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397m–5/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" limiting any cause of action or other relief related to obligations under this division that is available under the law of any State, or political subdivision thereof; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaad3f78-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397m–5/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" creating a private cause of action for a violation of this division.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbaad3f79-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title XX, § 2046, as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tVI/s6703/a/1/C"},"text":"Pub. L. 111–148, title VI, § 6703(a)(1)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/798"},"text":"124 Stat. 798","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
