{"tag":"section","attrib":{"id":"idbb6bfafd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1771"},"text":null,"children":[{"tag":"num","attrib":{"value":"1771"},"text":"§ 1771.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional declaration of purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In recognition of the demonstrated relationship between food and good nutrition and the capacity of children to develop and learn, based on the years of cumulative successful experience under the national school lunch program with its significant contributions in the field of applied nutrition research, it is hereby declared to be the policy of Congress that these efforts shall be extended, expanded, and strengthened under the authority of the Secretary of Agriculture as a measure to safeguard the health and well-being of the Nation’s children, and to encourage the domestic consumption of agricultural and other foods, by assisting States, through grants-in-aid and other means, to meet more effectively the nutritional needs of our children.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbb6bfafe-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/642/s2"},"text":"Pub. L. 89–642, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-10-11"},"text":"Oct. 11, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/885"},"text":"80 Stat. 885","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbb6bfaff-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbb6bfb00-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idbb6bfb01-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2022 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/129/s1"},"text":"Pub. L. 117–129, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-05-21"},"text":"May 21, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1225"},"text":"136 Stat. 1225","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/129/s1"},"text":"“This Act [amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1786"},"text":"section 1786 of this title","children":[],"tail":"] may be cited as the ‘Access to Baby Formula Act of 2022’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idbb6bfb02-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/247/s1"},"text":"Pub. L. 110–247, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-06-20"},"text":"June 20, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2314"},"text":"122 Stat. 2314","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/247/s1"},"text":"“This Act [enacting ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1792"},"text":"section 1792 of this title","children":[],"tail":" and provisions set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1792"},"text":"section 1792 of this title","children":[],"tail":"] may be cited as the ‘Federal Food Donation Act of 2008’.”"}],"tail":"\n"}],"tail":"\n"}],"tai