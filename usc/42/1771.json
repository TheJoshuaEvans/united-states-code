"tag":"quotedContent","attrib":{"origin":"/us/pl/89/642/s1"},"text":"“That this Act [enacting this chapter] may be cited as the ‘Child Nutrition Act of 1966’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
