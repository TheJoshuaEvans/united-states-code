{"tag":"section","attrib":{"id":"idb696a513-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–24"},"text":null,"children":[{"tag":"num","attrib":{"value":"300ff–24"},"text":"§ 300ff–24.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants for home- and community-based care","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb696a514-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–24/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uses","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A State may use amounts provided under a grant awarded under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–21"},"text":"section 300ff–21 of this title","children":[],"tail":" to make grants under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–22/b/3/J"},"text":"section 300ff–22(b)(3)(J) of this title","children":[],"tail":" to entities to—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb696a515-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–24/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide home- and community-based health services for individuals with HIV/AIDS pursuant to written plans of care prepared by a case management team, that shall include appropriate health care professionals, in such State for providing such services to such individuals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb696a516-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–24/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide outreach services to individuals with HIV/AIDS, including those individuals in rural areas; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb696a517-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–24/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for the coordination of the provision of services under this section with the provision of HIV-related health services, including specialty care and vaccinations for hepatitis co-infection, provided by public and private entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb696a518-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–24/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In awarding grants under subsection (a), a State shall give priority to entities that provide assurances to the State that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb696a519-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–24/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such entities will participate in HIV care consortia if such consortia exist within the State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb696a51a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–24/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such entities will utilize amounts provided under such grants for the provision of home- and community-based services to low-income individuals with HIV/AIDS.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb696a51b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–24/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Home- and community-based health services” defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As used in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–21"},"text":"section 300ff–21 of this title","children":[],"tail":", the term “home- and community-based health services”—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb696a51c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–24/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means, with respect to an individual with HIV/AIDS, skilled health services furnished to the individual in the individual’s home pursuant to a written plan of care established by a case management team, that shall include appropriate health care professionals, for the provision of such services and items described in paragraph (2);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb696a51d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–24/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb696a51e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–24/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" durable medical equipment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb696a51f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–24/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" home health aide services and personal care services furnished in the home of the individual;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb696a520-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–24/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" day treatment or other partial hospitalization services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb696a521-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–24/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" home intravenous and aerosolized drug therapy (including prescription drugs administered as part of such therapy);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb696a522-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–24/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" routine diagnostic testing administered in the home of the individual; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb696a523-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–24/c/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appropriate mental health, developmental, and rehabilitation services; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb696a524-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–24/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" does not include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb696a525-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–24/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inpatient hospital services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb696a526-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–24/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nursing home and other long term care facilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb696a527-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XXVI, § 2614, as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/381/tII/s201"},"text":"Pub. L. 101–381, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-08-18"},"text":"Aug. 18, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/589"},"text":"104 Stat. 589","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/415/tII"},"text":"Pub. L. 109–415, title II","children":[],"tail":", §§ 201(c)(2), 204(a), (b), title VII, §§ 702(3), 703, "},{"tag":"date","attrib":{"date":"2006-12-19"},"text":"Dec. 19, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2788"},"text":"120 Stat. 2788","children":[],"tail":", 2796, 2820; "},{"tag":"ref","attrib":{"href":"/us/pl/111/87/s2/a/1"},"text":"Pub. L. 111–87, § 2(a)(1)","children":[],"tail":", (3)(A), "},{"tag":"date","attrib":{"date":"2009-10-30"},"text":"Oct. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2885"},"text":"123 Stat. 2885","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb696a528-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb696a529-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb696a52a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2614 of act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", was successively renumbered by subsequent acts and transferred, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s238m"},"text":"section 238m of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb696a52b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2009—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/87"},"text":"Pub. L. 111–87","children":[],"tail":" repealed "},{"tag":"ref","attrib":{"href":"/us/pl/109/415/s703"},"text":"Pub. L. 109–415, § 703","children":[],"tail":", and revived the provisions of this section as in effect on "},{"tag":"date","attrib":{"date":"2009-09-30"},"text":"Sept. 30, 2009","children":[],"tail":". See 2006 Amendment note and Effective Date of 2009 Amendment; Revival of Section note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/415/s703"},"text":"Pub. L. 109–415, § 703","children":[],"tail":", which directed repeal of this section effective "},{"tag":"date","attrib":{"date":"2009-10-01"},"text":"Oct. 1, 2009","children":[],"tail":", was itself repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/111/87/s2/a/1"},"text":"Pub. L. 111–87, § 2(a)(1)","children":[],"tail":", effective "},{"tag":"date","attrib":{"date":"2009-09-30"},"text":"Sept. 30, 2009","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/415/s702/3"},"text":"Pub. L. 109–415, § 702(3)","children":[],"tail":", substituted “HIV/AIDS” for “HIV disease” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/415/s204/a"},"text":"Pub. L. 109–415, § 204(a)","children":[],"tail":", substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–21"},"text":"section 300ff–21 of this title","children":[],"tail":"” for “this part” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/415/s201/c/2/A"},"text":"Pub. L. 109–415, § 201(c)(2)(A)","children":[],"tail":", substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–22/b/3/J"},"text":"section 300ff–22(b)(3)(J) of this title","children":[],"tail":"” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–22/a/2"},"text":"section 300ff–22(a)(2) of this title","children":[],"tail":"” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/415/s204/b"},"text":"Pub. L. 109–415, § 204(b)","children":[],"tail":", inserted “, including specialty care and vaccinations for hepatitis co-infection,” after “health services”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/415/s204/a"},"text":"Pub. L. 109–415, § 204(a)","children":[],"tail":", substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–21"},"text":"section 300ff–21 of this title","children":[],"tail":"” for “this part” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/415/s201/c/2/B"},"text":"Pub. L. 109–415, § 201(c)(2)(B)","children":[],"tail":", struck out “homemaker or” before “home health”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb696a52c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb696a52d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2009 Amendment; Revival of Section","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions that repeal by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/87/s2/a/1"},"text":"section 2(a)(1) of Pub. L. 111–87","children":[],"tail":" of "},{"tag":"ref","attrib":{"href":"/us/pl/109/415/s703"},"text":"section 703 of Pub. L. 109–415","children":[],"tail":" be effective "},{"tag":"date","attrib":{"date":"2009-09-30"},"text":"Sept. 30, 2009","children":[],"tail":", and that the provisions of this section as in effect on "},{"tag":"date","attrib":{"date":"2009-09-30"},"text":"Sept. 30, 2009","children":[],"tail":", be revived, see section 2(a)(2), (3)(A) of "},{"tag":"ref","attrib":{"href":"/us/pl/111/87"},"text":"Pub. L. 111–87","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–11"},"text":"section 300ff–11 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
