":"date","attrib":{"date":"2020-07-13"},"text":"July 13, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/661"},"text":"134 Stat. 661","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/39/s2/a"},"text":"Pub. L. 117–39, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-08-31"},"text":"Aug. 31, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/336"},"text":"135 Stat. 336","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8222778-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8222779-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb822277a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/39"},"text":"Pub. L. 117–39","children":[],"tail":" substituted “fiscal years 2021 and 2022, the total amount of such assistance provided during each such fiscal year shall not exceed $10,000,000” for “fiscal year 2020, the total amount of such assistance provided during such fiscal year shall not exceed $10,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2020—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/148"},"text":"Pub. L. 116–148","children":[],"tail":" substituted “fiscal year 2020, the total amount of such assistance provided during such fiscal year shall not exceed $10,000,000.” for “fiscal years 2017 and 2018, the total amount of such assistance provided during each such fiscal year shall not exceed $25,000,000.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2017—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/57"},"text":"Pub. L. 115–57","children":[],"tail":" substituted “fiscal years 2017 and 2018” for “fiscal year 2010” and “each such fiscal year” for “that fiscal year”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/127"},"text":"Pub. L. 111–127","children":[],"tail":", which directed substitution of “"},{"tag":"date","attrib":{"date":"2009-09-30"},"text":"September 30, 2009","children":[],"tail":", except that, in the case of fiscal year 2010, the total amount of such assistance provided during that fiscal year shall not exceed $25,000,000.” for “September, 30, 2003” and all that follows through the end of subsec. (d), was executed by making the substitution for “"},{"tag":"date","attrib":{"date":"2003-09-30"},"text":"September 30, 2003","children":[],"tail":", except that, in the case of fiscal year 2006, the total amount of such assistance provided during that fiscal year shall not exceed $6,000,000.”, which did not contain a comma after “September”, to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/250"},"text":"Pub. L. 109–250","children":[],"tail":" inserted “, except that, in the case of fiscal year 2006, the total amount of such assistance provided during that fiscal year shall not exceed $6,000,000” after “2003”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/11"},"text":"Pub. L. 108–11","children":[],"tail":" substituted “2003” for “1991”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508/s5056/a/1"},"text":"Pub. L. 101–508, § 5056(a)(1)","children":[],"tail":", substituted “after "},{"tag":"date","attrib":{"date":"1991-09-30"},"text":"September 30, 1991","children":[],"tail":"” for “on or after "},{"tag":"date","attrib":{"date":"1989-10-01"},"text":"October 1, 1989","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/382"},"text":"Pub. L. 101–382","children":[],"tail":" amended subsec. (d) generally. Prior to amendment, subsec. (d) read as follows: “The total amount of temporary assistance provided under this section shall not exceed—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) $8,000,000 during the fiscal years ending ","children":[{"tag":"date","attrib":{"date":"1975-06-30"},"text":"June 30, 1975","children":[],"tail":", and "},{"tag":"date","attrib":{"date":"1976-06-30"},"text":"June 30, 1976","children":[],"tail":", and the succeeding calendar quarter, or"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) $300,000 during any fiscal year beginning on or after ","children":[{"tag":"date","attrib":{"date":"1976-10-01"},"text":"October 1, 1976","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508/s5056/a/2"},"text":"Pub. L. 101–508, § 5056(a)(2)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1975—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/44/s2"},"text":"Pub. L. 94–44, § 2","children":[],"tail":", set a 90-day limit for assistance following arrival in the United States with provision for furnishing of assistance beyond the 90-day limit upon a finding by the Secretary that the circumstances involved necessitate or justify the furnishing of assistance in that particular case."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/44/s1"},"text":"Pub. L. 94–44, § 1","children":[],"tail":", substituted provisions setting the maximum total amount of temporary assistance provided under this section for provisions prohibiting temporary assistance after "},{"tag":"date","attrib":{"date":"1973-06-30"},"text":"June 30, 1973","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1971—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/40"},"text":"Pub. L. 92–40","children":[],"tail":" extended termination date from "},{"tag":"date","attrib":{"date":"1971-06-30"},"text":"June 30, 1971","children":[],"tail":", to "},{"tag":"date","attrib":{"date":"1973-06-30"},"text":"June 30, 1973","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1969—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/41"},"text":"Pub. L. 91–41","children":[],"tail":" extended termination date from "},{"tag":"date","attrib":{"date":"1969-06-30"},"text":"June 30, 1969","children":[],"tail":", to "},{"tag":"date","attrib":{"date":"1971-06-30"},"text":"June 30, 1971","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1968—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/248"},"text":"Pub. L. 90–248","children":[],"tail":" extended termination date from "},{"tag":"date","attrib":{"date":"1968-06-30"},"text":"June 30, 1968","children":[],"tail":", to "},{"tag":"date","attrib":{"date":"1969-06-30"},"text":"June 30, 1969","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1967—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/36"},"text":"Pub. L. 90–36","children":[],"tail":" extended termination date from "},{"tag":"date","attrib":{"date":"1967-06-30"},"text":"June 30, 1967","children":[],"tail":", to "},{"tag":"date","attrib":{"date":"1968-06-30"},"text":"June 30, 1968","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1964—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/347"},"text":"Pub. L. 88–347","children":[],"tail":" extended termination date from "},{"tag":"date","attrib":{"date":"1964-06-30"},"text":"June 30, 1964","children":[],"tail":", to "},{"tag":"date","attrib":{"date":"1967-06-30"},"text":"June 30, 1967","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1962—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/543"},"text":"Pub. L. 87–543","children":[],"tail":" extended termination date from "},{"tag":"date","attrib":{"date":"1962-06-30"},"text":"June 30, 1962","children":[],"tail":", to "},{"tag":"date","attrib":{"date":"1964-06-30"},"text":"June 30, 1964","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb822277b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb822277c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1990 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508/tV/s5056/b"},"text":"Pub. L. 101–508, title V, § 5056(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-230"},"text":"104 Stat. 1388–230","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/508/tV/s5056/b"},"text":"“The amendments made by subsection (a) [amending this section] shall be effective for fiscal years beginning after ","children":[{"tag":"date","attrib":{"date":"1989-09-30"},"text":"September 30, 1989","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb822277d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Limit on Direct Contact With Repatriated Individuals During COVID–19 Emergency Period","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/148/s3"},"text":"Pub. L. 116–148, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-07-13"},"text":"July 13, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/661"},"text":"134 Stat. 661","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/148/s3"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“During the emergency period described in section 1135(g)(1)(B) of the Social Security Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320b–5/g/1/B"},"text":"42 U.S.C. 1320b–5(g)(1)(B)","children":[],"tail":"), in providing temporary assistance under section 1113 of such Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1313"},"text":"42 U.S.C. 1313","children":[],"tail":"), no employee of the Administration for Children and Families of the Department of Health and Human Services shall have direct, in-person contact with an individual specified in section 1113(a)(1) of such Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1313/a/1"},"text":"42 U.S.C. 1313(a)(1)","children":[],"tail":"), except in the case of a uniformed member of the Regular Corps or the Ready Reserve Corps of the Commissioned Corps of the Public Health Service (as described in section 203 of the Public Health Service Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s204"},"text":"42 U.S.C. 204","children":[],"tail":")) in an active duty status who, as determined by the Secretary of Health and Human Services, has—"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" received appropriate training on infection prevention and control; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" access to appropriate personal protective equipment.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
