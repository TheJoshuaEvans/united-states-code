{"tag":"section","attrib":{"id":"idbc17a4ea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2296b–4"},"text":null,"children":[{"tag":"num","attrib":{"value":"2296b–4"},"text":"§ 2296b–4.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual uranium purchase reports","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbc17a4eb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2296b–4/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"By January 1 of each year, the owner or operator of any civilian nuclear power reactor shall report to the Secretary, acting through the Administrator of the Energy Information Administration, for activities of the previous fiscal year—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc17a4ec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2296b–4/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the country of origin and the seller of any uranium or enriched uranium purchased or imported into the United States either directly or indirectly by such owner or operator; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc17a4ed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2296b–4/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the country of origin and the seller of any enrichment services purchased by such owner or operator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc17a4ee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2296b–4/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional access","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The information provided to the Secretary pursuant to this section shall be made available to the Congress by March 1 of each year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc17a4ef-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/tX/s1015"},"text":"Pub. L. 102–486, title X, § 1015","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2949"},"text":"106 Stat. 2949","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc17a4f0-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc17a4f1-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbc17a4f2-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Energy Policy Act of 1992, and not as part of the Atomic Energy Act of 1954 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
