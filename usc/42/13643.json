{"tag":"section","attrib":{"id":"idbfca4c14-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13643"},"text":null,"children":[{"tag":"num","attrib":{"value":"13643"},"text":"§ 13643.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary shall issue regulations necessary to carry out subtitles B through F of this title and the amendments made by such subtitles not later than the expiration of the 6-month period beginning on ","children":[{"tag":"date","attrib":{"date":"1992-10-28"},"text":"October 28, 1992","children":[],"tail":". The regulations shall be issued after notice and opportunity for public comment pursuant to the provisions of "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s553"},"text":"section 553 of title 5","children":[],"tail":" (notwithstanding subsections (a)(2), (b)(B), and (d)(3) of such section)."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbfca4c15-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550/tVI/s685"},"text":"Pub. L. 102–550, title VI, § 685","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3832"},"text":"106 Stat. 3832","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbfca4c16-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbfca4c17-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbfca4c18-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading