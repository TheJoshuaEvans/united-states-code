{"tag":"section","attrib":{"id":"idbc214179-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2373"},"text":null,"children":[{"tag":"num","attrib":{"value":"2373"},"text":"§ 2373.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer to governmental or other legal entity; determination of transferee","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbc21417a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2373/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Transfer may be made to one or more of the following, if the transferee has the legal authority to receive and operate the utility.","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc21417b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2373/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the city at the community;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc21417c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2373/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State in which the community is located;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc21417d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2373/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any political subdivision or agency of that State; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc21417e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2373/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any person, firm, corporation, or other legal entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc21417f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2373/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In determining the transferee for any utility, the Commission may consider the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc214180-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2373/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the pattern of ownership of the comparable utilities in the State in which the community is located;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc214181-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2373/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the ability of the transferee to operate the utility;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc214182-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2373/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the probable price of the sale of the utility, the ability of the transferee to pay that price, and any probable expense;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc214183-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2373/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the desires of the eligible voters of the community as directly expressed in any vote in any officially recognized procedure or in any procedure established by the Commission; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc214184-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2373/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the benefit to the United States in reducing possible requirements for local assistance as authorized in subchapters VII and VIII of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc214185-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1955-08-04/ch543"},"text":"Aug. 4, 1955, ch. 543","children":[],"tail":", ch. 7, § 73, "},{"tag":"ref","attrib":{"href":"/us/stat/69/480"},"text":"69 Stat. 480","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc214186-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbc214187-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"idbc214188-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Atomic Energy Commission abolished and functions transferred by sections 5814 and 5841 of this title. See also Transfer of Functions notes set out under those sections.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
