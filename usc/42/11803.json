{"tag":"section","attrib":{"id":"idbf57db46-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11803"},"text":null,"children":[{"tag":"num","attrib":{"value":"11803"},"text":"§ 11803.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval of applications","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In selecting among applications submitted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11802/a"},"text":"section 11802(a) of this title","children":[],"tail":", the Secretary shall give priority to applicants who propose to carry out projects and activities—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf57db47-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11803/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the purposes specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11801"},"text":"section 11801 of this title","children":[],"tail":" in geographical areas in which frequent and severe drug-related crimes are committed by gangs whose membership is composed primarily of youth, and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf57db48-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11803/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that the applicant demonstrates have the broad support of community based organizations in such geographical areas.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf57db49-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690/tIII/s3503"},"text":"Pub. L. 100–690, title III, § 3503","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4255"},"text":"102 Stat. 4255","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/204/tX/s1001/a"},"text":"Pub. L. 101–204, title X, § 1001(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-07"},"text":"Dec. 7, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1826"},"text":"103 Stat. 1826","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf57db4a-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf57db4b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbf57db4c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1989—Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/204"},"text":"Pub. L. 101–204","children":[],"tail":" substituted “have” for “that it has”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
