{"tag":"section","attrib":{"id":"idb6884d12-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–51"},"text":null,"children":[{"tag":"num","attrib":{"value":"300cc–51"},"text":"§ 300cc–51.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this subchapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6884d13-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–51/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “infection”, with respect to the etiologic agent for acquired immune deficiency syndrome, includes opportunistic cancers and infectious diseases and any other conditions arising from infection with such etiologic agent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6884d14-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–51/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “treatment”, with respect to the etiologic agent for acquired immune deficiency syndrome, includes primary and secondary prophylaxis.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb6884d15-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XXIII, § 2361, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/607/tII/s201/4"},"text":"Pub. L. 100–607, title II, § 201(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-04"},"text":"Nov. 4, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3078"},"text":"102 Stat. 3078","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/43/tXVIII/s1811/8"},"text":"Pub. L. 103–43, title XVIII, § 1811(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-06-10"},"text":"June 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/200"},"text":"107 Stat. 200","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb6884d16-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb6884d17-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb6884d18-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1993—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/43"},"text":"Pub. L. 103–43","children":[],"tail":" substituted provisions defining “infection” and “treatment” for former provisions which read as follows: “For purposes of this subchapter, the term ‘infection with the etiologic agent for acquired immune deficiency syndrome’ includes any condition arising from infection with such etiologic agent”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
