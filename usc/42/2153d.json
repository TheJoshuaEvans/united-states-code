{"tag":"section","attrib":{"id":"idbbef0d3b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2153d"},"text":null,"children":[{"tag":"num","attrib":{"value":"2153d"},"text":"§ 2153d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to continue agreements for cooperation entered into prior to ","children":[{"tag":"date","attrib":{"date":"1978-03-10"},"text":"March 10, 1978","children":[],"tail":null}],"tail":null},{"tag":"subsection","attrib":{"id":"idbbef0d3c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2153d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amendments to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2153"},"text":"section 2153 of this title","children":[],"tail":" made by this Act shall not affect the authority to continue cooperation pursuant to agreements for cooperation entered into prior to "},{"tag":"date","attrib":{"date":"1978-03-10"},"text":"March 10, 1978","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbbef0d3d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2153d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nothing in this Act shall affect the authority to include dispute settlement provisions, including arbitration, in any agreement made pursuant to an Agreement for Cooperation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbbef0d3e-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/242/tIV/s405"},"text":"Pub. L. 95–242, title IV, § 405","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-03-10"},"text":"Mar. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/148"},"text":"92 Stat. 148","children":[],"tail":".)"}],"tail":"\