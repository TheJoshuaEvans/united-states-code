{"tag":"section","attrib":{"id":"idb59c3f66-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–0b"},"text":null,"children":[{"tag":"num","attrib":{"value":"290aa–0b"},"text":"§ 290aa–0b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interdepartmental Serious Mental Illness Coordinating Committee","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb59c3f67-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–0b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb59c3f68-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–0b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, or the designee of the Secretary, shall establish a committee to be known as the Interdepartmental Serious Mental Illness Coordinating Committee (in this section referred to as the “Committee”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb59c3f69-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–0b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal Advisory Committee Act","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in this section, the provisions of the Federal Advisory Committee Act (5 U.S.C. App.) ","children":[{"tag":"ref","attrib":{"idref":"fn002219"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002219"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" shall apply to the Committee."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb59c3f6a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–0b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Committee shall meet not fewer than 2 times each year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb59c3f6b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–0b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibilities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than each of 1 year and 5 years after ","children":[{"tag":"date","attrib":{"date":"2022-12-29"},"text":"December 29, 2022","children":[],"tail":", the Committee shall submit to Congress and any other relevant Federal department or agency a report including—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb59c3f6c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–0b/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a summary of advances in serious mental illness and serious emotional disturbance research related to the prevention of, diagnosis of, intervention in, and treatment and recovery of serious mental illnesses, serious emotional disturbances, and advances in access to services and support for adults with a serious mental illness or children with a serious emotional disturbance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb59c3f6d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–0b/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an evaluation of the effect Federal programs related to serious mental illness have on public health, including outcomes such as—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb59c3f6e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–0b/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rates of suicide, suicide attempts, incidence and prevalence of serious mental illnesses, serious emotional disturbances, and substance use disorders, overdose, overdose deaths, emergency hospitalizations, emergency department boarding, preventable emergency department visits, interaction with the criminal justice system, homelessness, and unemployment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb59c3f6f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–0b/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increased rates of employment and enrollment in educational and vocational programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb59c3f70-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–0b/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" quality of mental and substance use disorders treatment services; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb59c3f71-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–0b/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other criteria as may be determined by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb59c3f72-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–0b/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specific recommendations for actions that agencies can take to better coordinate the administration of mental health services for adults with a serious mental illness or children with a serious emotional disturbance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb59c3f73-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–0b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb59c3f74-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–0b/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal members","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Committee shall be composed of the following Federal representatives, or the designees of such representatives—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb59c3f75-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–0b/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Health and Human Services, who shall serve as the Chair of the Committee;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb59c3f76-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–0b/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Assistant Secretary for Mental Health and Substance Use;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb59c3f77-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–0b/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Attorney General;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb59c3f78-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–0b/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Veterans Affairs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb59c3f79-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–0b/d/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Defense;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb59c3f7a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–0b/d/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Housing and Urban Development;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb59c3f7b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–0b/d/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb59c3f7c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–0b/d/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Labor;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb59c3f7d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–0b/d/1/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Administrator of the Centers for Medicare & Medicaid Services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb59c3f7e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–0b/d/1/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Administrator of the Administration for Community Living; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb59c3f7f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–0b/d/1/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Commissioner of Social Security.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb59c3f80-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–0b/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-Federal members","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Committee shall also include not less than 14 non-Federal public members appointed by the Secretary of Health and Human Services, of which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb59c3f81-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–0b/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least 2 members shall be an individual who has received treatment for a diagnosis of a serious mental illness;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb59c3f82-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–0b/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least 1 member shall be a parent or legal guardian of an adult with a history of a serious mental illness or a child with a history of a serious emotional disturbance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb59c3f83-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–0b/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least 1 member shall be a representative of a leading research, advocacy, or service organization for adults with a serious mental illness;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb59c3f84-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–0b/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" at least 2 members shall be—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb59c3f85-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–0b/d/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a licensed psychiatrist with experience in treating serious mental illnesses;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb59c3f86-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–0b/d/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a licensed psychologist with experience in treating serious mental illnesses or serious emotional disturbances;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb59c3f87-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–0b/d/2/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a licensed clinical social worker with experience treating serious mental illnesses or serious emotional disturbances; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb59c3f88-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–0b/d/2/D/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a licensed psychiatric nurse, nurse practitioner, or physician assistant with experience in treating serious mental illnesses or serious emotional disturbances;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb59c3f89-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–0b/d/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least 1 member shall be a licensed mental health professional with a specialty in treating children and adolescents with a serious emotional disturbance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb59c3f8a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–0b/d/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least 1 member shall be a mental health professional who has research or clinical mental health experience in working with minorities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb59c3f8b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–0b/d/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least 1 member shall be a mental health professional who has research or clinical mental health experience in working with medically underserved populations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb59c3f8c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–0b/d/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least 1 member shall be a State certified mental health peer support specialist;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb59c3f8d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–0b/d/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least 1 member shall be a judge with experience in adjudicating cases related to criminal justice or serious mental illness;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb59c3f8e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–0b/d/2/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least 1 member shall be a law enforcement officer or corrections officer with extensive experience in interfacing with adults with a serious mental illness, children with a serious emotional disturbance, or individuals in a mental health crisis; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb59c3f8f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–0b/d/2/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least 1 member shall have experience providing services for homeless individuals and working with adults with a serious mental illness, children with a serious emotional disturbance, or individuals in a mental health crisis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb59c3f90-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–0b/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A member of the Committee appointed under paragraph (2) shall serve for a term of 3 years, and may be reappointed for 1 or more additional 3-year terms. Any member appointed to fill a vacancy for an unexpired term shall be appointed for the remainder of such term. A member may serve after the expiration of the member’s term until a successor has been appointed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb59c3f91-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–0b/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Working groups","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out its functions, the Committee may establish working groups. Such working groups shall be composed of Committee members, or their designees, and may hold such meetings as are necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb59c3f92-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–0b/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sunset","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Committee shall terminate on ","children":[{"tag":"date","attrib":{"date":"2027-09-30"},"text":"September 30, 2027","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb59c3f93-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title V, § 501C, as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dFF/tI/s1121/c/1"},"text":"Pub. L. 117–328, div. FF, title I, § 1121(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5648"},"text":"136 Stat. 5648","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb59c3f94-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb59c3f95-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb59c3f96-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Advisory Committee Act, referred to in subsec. (a)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/463"},"text":"Pub. L. 92–463","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-06"},"text":"Oct. 6, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/770"},"text":"86 Stat. 770","children":[],"tail":", which was set out in the Appendix to Title 5, Government Organization and Employees, and was substantially repealed and restated in chapter 10 (§ 1001 et seq.) of Title 5 by "},{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":", §§ 3(a), 7, "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4197"},"text":"136 Stat. 4197","children":[],"tail":", 4361. For disposition of sections of the Act into chapter 10 of Title 5, see Disposition Table preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s101"},"text":"section 101 of Title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
