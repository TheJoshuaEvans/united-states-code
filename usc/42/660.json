{"tag":"section","attrib":{"id":"idb7c07ef9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s660"},"text":null,"children":[{"tag":"num","attrib":{"value":"660"},"text":"§ 660.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil action to enforce child support obligations; jurisdiction of district courts","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The district courts of the United States shall have jurisdiction, without regard to any amount in controversy, to hear and determine any civil action certified by the Secretary of Health and Human Services under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s652/a/8"},"text":"section 652(a)(8) of this title","children":[],"tail":". A civil action under this section may be brought in any judicial district in which the claim arose, the plaintiff resides, or the defendant resides."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb7c07efa-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title IV, § 460, as added "},{"tag":"ref","attrib":{"href":"/us/pl/93/647/s101/a"},"text":"Pub. L. 93–647, § 101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-04"},"text":"Jan. 4, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2358"},"text":"88 Stat. 2358","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dB/tVI/s2663/j/2/B/xi"},"text":"Pub. L. 98–369, div. B, title VI, § 2663(j)(2)(B)(xi)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1170"},"text":"98 Stat. 1170","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb7c07efb-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb7c07efc-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb7c07efd-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1984—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369"},"text":"Pub. L. 98–369","children":[],"tail":" substituted “Health and Human Services” for “Health, Education, and Welfare”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb7c07efe-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb7c07eff-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369"},"text":"Pub. L. 98–369","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", but not to be construed as changing or affecting any right, liability, status, or interpretation which existed (under the provisions of law involved) before that date, see "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/s2664/b"},"text":"section 2664(b) of Pub. L. 98–369","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s401"},"text":"section 401 of this title","children":[],"tail":"."}],"ta