{"tag":"section","attrib":{"id":"idbcc82fc9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4345"},"text":null,"children":[{"tag":"num","attrib":{"value":"4345"},"text":"§ 4345.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation with Citizens’ Advisory Committee on Environmental Quality and other representatives","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In exercising its powers, functions, and duties under this chapter, the Council shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbcc82fca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4345/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consult with the Citizens’ Advisory Committee on Environmental Quality established by Executive Order numbered 11472, dated ","children":[{"tag":"date","attrib":{"date":"1969-05-29"},"text":"May 29, 1969","children":[],"tail":", and with such representatives of science, industry, agriculture, labor, conservation organizations, State and local governments and other groups, as it deems advisable; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcc82fcb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4345/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" utilize, to the fullest extent possible, the services, facilities, and information (including statistical information) of public and private agencies and organizations, and individuals, in order that duplication of effort and expense may be avoided, thus assuring that the Council’s activities will not unnecessarily overlap or conflict with similar activities authorized by law and performed by established agencies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbcc82fcc-3a70-11f1-ae07-e4213316b5fa"},"