{"tag":"section","attrib":{"id":"idb587310c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s287d"},"text":null,"children":[{"tag":"num","attrib":{"value":"287d"},"text":"§ 287d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of Research on Women’s Health","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb587310d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s287d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established within the Office of the Director of NIH an office to be known as the Office of Research on Women’s Health (in this part referred to as the “Office”). The Office shall be headed by a director, who shall be appointed by the Director of NIH and who shall report directly to the Director.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb587310e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s287d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director of the Office shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb587310f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s287d/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify projects of research on women’s health that should be conducted or supported by the national research institutes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5873110-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s287d/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify multidisciplinary research relating to research on women’s health that should be so conducted or supported;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5873111-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s287d/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry out paragraphs (1) and (2) with respect to the aging process in women, with priority given to menopause;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5873112-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s287d/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote coordination and collaboration among entities conducting research identified under any of paragraphs (1) through (3);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5873113-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s287d/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage the conduct of such research by entities receiving funds from the national research institutes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5875824-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s287d/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommend an agenda for conducting and supporting such research;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5875825-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s287d/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote the sufficient allocation of the resources of the national research institutes for conducting and supporting such research;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5875826-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s287d/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist in the administration of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s289a–2"},"text":"section 289a–2 of this title","children":[],"tail":" with respect to the inclusion of women as subjects in clinical research; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5875827-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s287d/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prepare the report required in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s287d–2"},"text":"section 287d–2 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5875828-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s287d/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordinating Committee","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5875829-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s287d/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In carrying out subsection (b), the Director of the Office shall establish a committee to be known as the Coordinating Committee on Research on Women’s Health (in this subsection referred to as the “Coordinating Committee”).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb587582a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s287d/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Coordinating Committee shall be composed of the Directors of the national research institutes (or the senior-level staff designees of the Directors).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb587582b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s287d/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of the Office shall serve as the chair of the Coordinating Committee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb587582c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s287d/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" With respect to research on women’s health, the Coordinating Committee shall assist the Director of the Office in—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb587582d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s287d/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying the need for such research, and making an estimate each fiscal year of the funds needed to adequately support the research;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb587582e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s287d/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying needs regarding the coordination of research activities, including intramural and extramural multidisciplinary activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb587582f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s287d/c/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supporting the development of methodologies to determine the circumstances in which obtaining data specific to women (including data relating to the age of women and the membership of women in ethnic or racial groups) is an appropriate function of clinical trials of treatments and therapies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5875830-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s287d/c/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supporting the development and expansion of clinical trials of treatments and therapies for which obtaining such data has been determined to be an appropriate function; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5875831-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s287d/c/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encouraging the national research institutes to conduct and support such research, including such clinical trials.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5875832-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s287d/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisory Committee","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5875833-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s287d/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In carrying out subsection (b), the Director of the Office shall establish an advisory committee to be known as the Advisory Committee on Research on Women’s Health (in this subsection referred to as the “Advisory Committee”).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5877f44-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s287d/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Advisory Committee shall be composed of no fewer than 12, and not more than 18 individuals, who are not officers or employees of the Federal Government. The Director of NIH shall make appointments to the Advisory Committee from among physicians, practitioners, scientists, and other health professionals, whose clinical practice, research specialization, or professional expertise includes a significant focus on research on women’s health. A majority of the members of the Advisory Committee shall be women.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5877f45-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s287d/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of the Office shall serve as the chair of the Advisory Committee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5877f46-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s287d/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Advisory Committee shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5877f47-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s287d/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" advise the Director of the Office on appropriate research activities to be undertaken by the national research institutes with respect to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb5877f48-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s287d/d/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" research on women’s health;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5877f49-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s287d/d/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" research on gender differences in clinical drug trials, including responses to pharmacological drugs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5877f4a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s287d/d/4/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" research on gender differences in disease etiology, course, and treatment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5877f4b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s287d/d/4/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" research on obstetrical and gynecological health conditions, diseases, and treatments, including preventable maternal mortality and severe maternal morbidity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5877f4c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s287d/d/4/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" research on women’s health conditions which require a multidisciplinary approach;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5877f4d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s287d/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" report to the Director of the Office on such research;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5877f4e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s287d/d/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide recommendations to such Director regarding activities of the Office (including recommendations on the development of the methodologies described in subsection (c)(4)(C) and recommendations on priorities in carrying out research described in subparagraph (A)); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5877f4f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s287d/d/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist in monitoring compliance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s289a–2"},"text":"section 289a–2 of this title","children":[],"tail":" regarding the inclusion of women in clinical research."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5877f50-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s287d/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5877f51-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s287d/d/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Advisory Committee shall prepare a biennial report describing the activities of the Committee, including findings made by the Committee regarding—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb5877f52-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s287d/d/5/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compliance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s289a–2"},"text":"section 289a–2 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5877f53-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s287d/d/5/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent of expenditures made for research on women’s health by the agencies of the National Institutes of Health; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5877f54-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s287d/d/5/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the level of funding needed for such research.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5877f55-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s287d/d/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The report required in subparagraph (A) shall be submitted to the Director of NIH for inclusion in the report required in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s283"},"text":"section 283 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb587a666-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s287d/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Representation of women among researchers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Assistant Secretary for Personnel and in collaboration with the Director of the Office, shall determine the extent to which women are represented among senior physicians and scientists of the national research institutes and among physicians and scientists conducting research with funds provided by such institutes, and as appropriate, carry out activities to increase the extent of such representation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb587a667-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s287d/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this part:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb587a668-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s287d/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “women’s health conditions”, with respect to women of all age, ethnic, and racial groups, means all diseases, disorders, and conditions (including with respect to mental health)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb587a669-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s287d/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" unique to, more serious, or more prevalent in women;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb587a66a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s287d/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for which the factors of medical risk or types of medical intervention are different for women, or for which it is unknown whether such factors or types are different for women; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb587a66b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s287d/f/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to which there has been insufficient clinical research involving women as subjects or insufficient clinical data on women.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb587a66c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s287d/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “research on women’s health” means research on women’s health conditions, including research on preventing such conditions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb587a66d-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title IV, § 486, as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/43/tI/s141/a/3"},"text":"Pub. L. 103–43, title I, § 141(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-06-10"},"text":"June 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/136"},"text":"107 Stat. 136","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/340/tI/s106"},"text":"Pub. L. 105–340, title I, § 106","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-31"},"text":"Oct. 31, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3193"},"text":"112 Stat. 3193","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tIII/s3509/c"},"text":"Pub. L. 111–148, title III, § 3509(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/534"},"text":"124 Stat. 534","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/255/dA/tII/s2038/c"},"text":"Pub. L. 114–255, div. A, title II, § 2038(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-13"},"text":"Dec. 13, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1065"},"text":"130 Stat. 1065","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/103/dP/tI/s141/d"},"text":"Pub. L. 117–103, div. P, title I, § 141(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/798"},"text":"136 Stat. 798","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb587a66e-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb587a66f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":