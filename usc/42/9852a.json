{"tag":"section","attrib":{"id":"idbef87d04-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9852a"},"text":null,"children":[{"tag":"num","attrib":{"value":"9852a"},"text":"§ 9852a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Parental consent requirement for nonemergency intrusive physical examinations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbef87d05-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9852a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “nonemergency intrusive physical examination” means, with respect to a child, a physical examination that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbef87d06-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9852a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not immediately necessary to protect the health or safety of the child involved or the health or safety of another individual; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbef87d07-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9852a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requires incision or is otherwise invasive, or involves exposure of private body parts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbef87d08-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9852a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A Head Start agency shall obtain written parental consent before administration of any nonemergency intrusive physical examination of a child in connection with participation in a program under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbef87d09-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9852a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed to prohibit agencies from using established methods, for handling cases of suspected or known child abuse and neglect, that are in compliance with applicable Federal, State, or tribal law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbef87d0a-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35/tVI/s657A"},"text":"Pub. L. 97–35, title VI, § 657A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/134/s25"},"text":"Pub. L. 110–134, § 25","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-12"},"text":"Dec. 12, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1443"},"text":"121 Stat. 1443","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbef87d0b-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbef87d0c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbef87d0d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 9852a, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35/tVI/s657A"},"text":"Pub. L. 97–35, title VI, § 657A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/252/tI/s123"},"text":"Pub. L. 103–252, title I, § 123","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-05-18"},"text":"May 18, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/650"},"text":"108 Stat. 650","children":[],"tail":", related to consultation with Corporation for National and Community Service, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/105/285/tI/s118"},"text":"Pub. L. 105–285, title I, § 118","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-27"},"text":"Oct. 27, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2727"},"text":"112 Stat. 2727","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
