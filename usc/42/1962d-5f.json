{"tag":"section","attrib":{"id":"idbba9ee0a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1962d–5f"},"text":null,"children":[{"tag":"num","attrib":{"value":"1962d–5f"},"text":"§ 1962d–5f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Beach nourishment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbba9ee0b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1962d–5f/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of the Army, acting through the Chief of Engineers, is authorized to provide periodic beach nourishment in the case of each water resources development project where such nourishment has been authorized for a limited period for such additional period as he determines necessary but in no event shall such additional period extend beyond the fiftieth year which begins after the date of initiation of construction of such project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbba9ee0c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1962d–5f/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbba9ee0d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1962d–5f/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding subsection (a), the Secretary shall, at the request of the non-Federal interest, carry out a study to determine the feasibility of extending the period of nourishment described in subsection (a) for a period not to exceed 50 additional years beyond the maximum period described in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbba9ee0e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1962d–5f/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The additional years provided under paragraph (1) shall begin on the date of initiation of construction of congressionally authorized nourishment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbba9ee0f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1962d–5f/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plan for reducing risk to people and property","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbba9ee10-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1962d–5f/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As part of the review described in subsection (b), the non-Federal interest shall submit to the Secretary a plan for reducing risk to people and property during the life of the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbba9ee11-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1962d–5f/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusion of plan in recommendation to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall include the plan described in subsection (a) in the recommendations to Congress described in subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbba9ee12-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1962d–5f/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Upon completion of the review described in subsection (b), the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbba9ee13-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1962d–5f/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit to the Committee on Environment and Public Works of the Senate and the Committee on Transportation and Infrastructure of the House of Representatives any recommendations of the Secretary related to the review; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbba9ee14-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1962d–5f/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include in the subsequent annual report to Congress required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s2282d"},"text":"section 2282d of title 33","children":[],"tail":", any recommendations that require specific congressional authorization."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbba9ee15-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1962d–5f/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of this section, for any existing authorized water resources development project for which the maximum period for nourishment described in subsection (a) will expire within the 16-year period beginning on ","children":[{"tag":"date","attrib":{"date":"2014-06-10"},"text":"June 10, 2014","children":[],"tail":", that project shall remain eligible for nourishment for an additional 12 years after the expiration of such period."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbba9ee16-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/587/s156"},"text":"Pub. L. 94–587, § 156","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-22"},"text":"Oct. 22, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2933"},"text":"90 Stat. 2933","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/662/tIX/s934"},"text":"Pub. L. 99–662, title IX, § 934","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-17"},"text":"Nov. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/4197"},"text":"100 Stat. 4197","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/121/tI/s1037/a"},"text":"Pub. L. 113–121, title I, § 1037(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-06-10"},"text":"June 10, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1235"},"text":"128 Stat. 1235","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/322/tI/s1122/j"},"text":"Pub. L. 114–322, title I, § 1122(j)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1647"},"text":"130 Stat. 1647","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/270/tI/s1158"},"text":"Pub. L. 115–270, title I, § 1158","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-23"},"text":"Oct. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3794"},"text":"132 Stat. 3794","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dH/tLXXXI/s8129/a"},"text":"Pub. L. 117–263, div. H, title LXXXI, § 8129(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3717"},"text":"136 Stat. 3717","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbba9ee17-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbba9ee18-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbba9ee19-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Water Resources Development Act of 1976, and not as part of the Water Resources Planning Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbba9ee1a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s8129/a/1/A"},"text":"Pub. L. 117–263, § 8129(a)(1)(A)","children":[],"tail":", substituted “50” for “15”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s8129/a/1/B"},"text":"Pub. L. 117–263, § 8129(a)(1)(B)","children":[],"tail":", struck out “15” before “additional”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s8129/a/2"},"text":"Pub. L. 117–263, § 8129(a)(2)","children":[],"tail":", substituted “16-year period” for “10-year period” and “12 years” for “6 years”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/270/s1158/1"},"text":"Pub. L. 115–270, § 1158(1)","children":[],"tail":", designated existing provisions as par. (1), inserted heading, and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/270/s1158/2"},"text":"Pub. L. 115–270, § 1158(2)","children":[],"tail":", substituted “10-year period” for “5 year-period”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/322"},"text":"Pub. L. 114–322","children":[],"tail":" substituted “6 years” for “3 years”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/121"},"text":"Pub. L. 113–121","children":[],"tail":" designated existing provisions as subsec. (a), inserted heading, and added subsecs. (b) to (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/662"},"text":"Pub. L. 99–662","children":[],"tail":" substituted “fiftieth” for “fifteenth”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
