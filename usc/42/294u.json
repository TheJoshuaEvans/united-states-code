{"tag":"section","attrib":{"id":"idb5e88ae0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294u"},"text":null,"children":[{"tag":"num","attrib":{"value":"294u"},"text":"§ 294u.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Education and awareness initiative encouraging use of mental health and substance use disorder services by health care professionals","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5e88ae1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294u/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, in consultation with relevant stakeholders, including medical professional associations, shall establish a national evidence-based or evidence-informed education and awareness initiative—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5e88ae2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294u/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to encourage health care professionals to seek support and care for their mental health or substance use concerns, to help such professionals identify risk factors associated with suicide and mental health conditions, and to help such professionals learn how best to respond to such risks, with the goal of preventing suicide, mental health conditions, and substance use disorders; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5e88ae3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294u/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to address stigma associated with seeking mental health and substance use disorder services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5e88ae4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294u/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2022-03-18"},"text":"March 18, 2022","children":[],"tail":", and annually thereafter, the Secretary shall provide to the Committee on Health, Education, Labor, and Pensions of the Senate and the Committee on Energy and Commerce of the House of Representatives an update on the activities and outcomes of the initiative under subsection (a), including a description of quantitative and qualitative metrics used to evaluate such activities and outcomes."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5e88ae5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294u/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To carry out this section, there are authorized to be appropriated $10,000,000 for each of fiscal years 2026 through 2030.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5e88ae6-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/105/s3"},"text":"Pub. L. 117–105, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-03-18"},"text":"Mar. 18, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1118"},"text":"136 Stat. 1118","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/75/dJ/tV/s6508/b"},"text":"Pub. L. 119–75, div. J, title V, § 6508(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2026-02-03"},"text":"Feb. 3, 2026","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/140/695"},"text":"140 Stat. 695","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb5e88ae7-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb5e88ae8-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb5e88ae9-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Dr. Lorna Breen Health Care Provider Protection Act, and not as part of the Public Health Service Act which comprises this chapter.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s294t"},"text":"section 294t of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb5e88aea-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2026—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/75/s6508/b/1"},"text":"Pub. L. 119–75, § 6508(b)(1)","children":[],"tail":", inserted “and annually thereafter,” for “"},{"tag":"date","attrib":{"date":"2022-03-18"},"text":"March 18, 2022","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/75/s6508/b/2"},"text":"Pub. L. 119–75, § 6508(b)(2)","children":[],"tail":", substituted “2026 through 2030” for “2022 through 2024”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
