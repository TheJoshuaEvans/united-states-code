{"tag":"section","attrib":{"id":"idbf091e91-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9911"},"text":null,"children":[{"tag":"num","attrib":{"value":"9911"},"text":"§ 9911.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments to Indian tribes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf091e92-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9911/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reservation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If, with respect to any State, the Secretary—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf091e93-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9911/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" receives a request from the governing body of an Indian tribe or tribal organization within the State that assistance under this chapter be made directly to such tribe or organization; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf091e94-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9911/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determines that the members of such tribe or tribal organization would be better served by means of grants made directly to provide benefits under this chapter,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the Secretary shall reserve from amounts that would otherwise be allotted to such State under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s9906"},"text":"section 9906 of this title","children":[],"tail":" for the fiscal year the amount determined under subsection (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf091e95-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9911/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of reserved amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall reserve for the purpose of subsection (a) from amounts that would otherwise be allotted to such State, not less than 100 percent of an amount that bears the same ratio to the State allotment for the fiscal year involved as the population of all eligible Indians for whom a determination has been made under subsection (a) bears to the population of all individuals eligible for assistance through a community services block grant made under this chapter in such State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf091e96-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9911/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Awards","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The sums reserved by the Secretary on the basis of a determination made under subsection (a) shall be made available by grant to the Indian tribe or tribal organization serving the individuals for whom such a determination has been made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf091e97-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9911/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order for an Indian tribe or tribal organization to be eligible for a grant award for a fiscal year under this section, the tribe or organization shall submit to the Secretary a plan for such fiscal year that meets such criteria as the Secretary may prescribe by regulation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf091e98-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9911/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf091e99-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9911/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian tribe; tribal organization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “Indian tribe” and “tribal organization” mean a tribe, band, or other organized group recognized in the State in which the tribe, band, or group resides, or considered by the Secretary of the Interior, to be an Indian tribe or an Indian organization for any purpose.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf091e9a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9911/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Indian” means a member of an Indian tribe or of a tribal organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf091e9b-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35/tVI/s677"},"text":"Pub. L. 97–35, title VI, § 677","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/285/tII/s201"},"text":"Pub. L. 105–285, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-27"},"text":"Oct. 27, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2741"},"text":"112 Stat. 2741","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf091e9c-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf091e9d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbf091e9e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 9911, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35/tVI/s683"},"text":"Pub. L. 97–35, title VI, § 683","children":[],"tail":", formerly § 682, as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/501/tIV/s407/a"},"text":"Pub. L. 101–501, title IV, § 407(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-03"},"text":"Nov. 3, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1254"},"text":"104 Stat. 1254","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/171/s7/b"},"text":"Pub. L. 103–171, § 7(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-02"},"text":"Dec. 2, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1993"},"text":"107 Stat. 1993","children":[],"tail":"; renumbered § 683, "},{"tag":"ref","