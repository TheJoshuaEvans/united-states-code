{"tag":"section","attrib":{"id":"idb6753acd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300aa–5"},"text":null,"children":[{"tag":"num","attrib":{"value":"300aa–5"},"text":"§ 300aa–5.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Vaccine Advisory Committee","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb6753ace-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300aa–5/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is established the National Vaccine Advisory Committee. The members of the Committee shall be appointed by the Director of the Program, in consultation with the National Academy of Sciences, from among individuals who are engaged in vaccine research or the manufacture of vaccines or who are physicians, members of parent organizations concerned with immunizations, or representatives of State or local health agencies or public health organizations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6753acf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300aa–5/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Committee shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6753ad0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300aa–5/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" study and recommend ways to encourage the availability of an adequate supply of safe and effective vaccination products in the States,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6753ad1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300aa–5/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommend research priorities and other measures the Director of the Program should take to enhance the safety and efficacy of vaccines,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6753ad2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300aa–5/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advise the Director of the Program in the implementation of sections 300aa–2, 300aa–3, and 300aa–4 ","children":[{"tag":"ref","attrib":{"idref":"fn002400"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002400"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title, and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6753ad3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300aa–5/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify annually for the Director of the Program the most important areas of government and non-government cooperation that should be considered in implementing sections 300aa–2, 300aa–3, and 300aa–4 ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb6753ad4-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XXI, § 2105, as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/660/tIII/s311/a"},"text":"Pub. L. 99–660, title III, § 311(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3758"},"text":"100 Stat. 3758","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb6753ad5-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb6753ad6-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb6753ad7-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300aa–4"},"text":"Section 300aa–4 of this title","children":[],"tail":", referred to in subsec. (b)(3), (4), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/105/362/tVI/s601/a/1/H"},"text":"Pub. L. 105–362, title VI, § 601(a)(1)(H)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-10"},"text":"Nov. 10, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3285"},"text":"112 Stat. 3285","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb6753ad8-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 300aa–5, act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", § 2106, was successively renumbered by subsequent acts and transferred, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s238c"},"text":"section 238c of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior section 2105 of act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"te