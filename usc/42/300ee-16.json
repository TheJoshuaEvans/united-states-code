{"tag":"section","attrib":{"id":"idb68a9712-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–16"},"text":null,"children":[{"tag":"num","attrib":{"value":"300ee–16"},"text":"§ 300ee–16.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional required agreements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb68a9713-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–16/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may not, except as provided in subsection (b), make payments under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ee–11/a"},"text":"section 300ee–11(a) of this title","children":[],"tail":" for a fiscal year unless the State involved agrees that—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb68a9714-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–16/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all programs conducted or supported by the State with such payments will establish objectives for the program and will determine the extent to which the objectives are met;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb68a9715-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–16/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information provided under this part will be scientifically accurate and factually correct;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb68a9716-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–16/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in carrying out ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ee–11/b"},"text":"section 300ee–11(b) of this title","children":[],"tail":", the State will give priority to programs described in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ee–12/10"},"text":"section 300ee–12(10) of this title","children":[],"tail":" for individuals described in such section;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb68a9717-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–16/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to a State in which there is a substantial number of individuals who are intravenous substance abusers, the State will place priority on activities under this part directed at such substance abusers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb68a9718-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–16/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" with respect to a State in which there is a significant incidence of reported cases of acquired immune deficiency syndrome, the State will—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb68a9719-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–16/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for the purpose described in subsection (b) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ee–11"},"text":"section 300ee–11 of this title","children":[],"tail":", expend not less than 50 percent of payments received under subsection (a) of such section for a fiscal year—"}],"tail":null},{"tag":"clause","attrib":{"id":"idb68a971a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–16/a/5/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to make grants to public entities, to migrant health centers (as defined in section 254b(a) ","children":[{"tag":"ref","attrib":{"idref":"fn002418"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002418"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title), to community health centers (as defined in section 254c(a) "},{"tag":"ref","attrib":{"idref":"fn002418"},"text":"1","children":[],"tail":" of this title), and to nonprofit private entities concerned with acquired immune deficiency syndrome; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb68a971b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–16/a/5/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to enter into contracts with public and private entities; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb68a971c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–16/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of the amounts reserved for a fiscal year by the State for expenditures required in subparagraph (A), expend not less than 50 percent to carry out ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ee–12/10"},"text":"section 300ee–12(10) of this title","children":[],"tail":" through grants to nonprofit private entities, including minority entities, concerned with acquired immune deficiency syndrome located in and representative of communities and subpopulations reflecting the local incidence of such syndrome;"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb68a971d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–16/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" with respect to programs carried out pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ee–12/10"},"text":"section 300ee–12(10) of this title","children":[],"tail":", the State will ensure that any applicant for a grant under such section agrees—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb68a971e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–16/a/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that any educational or informational materials developed with a grant pursuant to such section will contain material, and be presented in a manner, that is specifically directed toward the group for which such materials are intended;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb68a971f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–16/a/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to provide a description of the manner in which the applicant has planned the program in consultation with, and of the manner in which such applicant will consult during the conduct of the program with—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb68a9720-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–16/a/6/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appropriate local officials and community groups for the area to be served by the program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb68a9721-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–16/a/6/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" organizations comprised of, and representing, the specific population to which the education or prevention effort is to be directed; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb68a9722-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–16/a/6/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" individuals having expertise in health education and in the needs of the population to be served;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb68a9723-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–16/a/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide information demonstrating that the applicant has continuing relationships, or will establish continuing relationships, with a portion of the population in the service area that is at risk of infection with the etiologic agent for acquired immune deficiency syndrome and with public and private entities in such area that provide health or other support services to individuals with such infection;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb68a9724-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–16/a/6/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to provide a description of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb68a9725-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–16/a/6/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the objectives established by the applicant for the conduct of the program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb68a9726-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–16/a/6/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the methods the applicant will use to evaluate the activities conducted under the program to determine if such objectives are met; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb68a9727-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–16/a/6/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other information as the Secretary may prescribe;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb68a9728-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–16/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" with respect to programs carried out pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ee–12/10"},"text":"section 300ee–12(10) of this title","children":[],"tail":", the State will give preference to any applicant for a grant pursuant to such section that is located in, has a history of service in, and will serve under the program, any geographic area in which—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb68a9729-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–16/a/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is a significant incidence of acquired immune deficiency syndrome;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb68a972a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–16/a/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there has been a significant increase in the incidence of such syndrome; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb68a972b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–16/a/7/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is a significant risk of becoming infected with the etiologic agent for such syndrome;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb68a972c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–16/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State will establish reasonable criteria to evaluate the effective performance of entities that receive funds from payments made to the State under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ee–11/a"},"text":"section 300ee–11(a) of this title","children":[],"tail":" and will establish procedures for procedural and substantive independent State review of the failure by the State to provide funds for any such entity;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb68a972d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–16/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State will permit and cooperate with Federal investigations undertaken in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ee–18/e"},"text":"section 300ee–18(e) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb68a972e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–16/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State will maintain State expenditures for services provided pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ee–11"},"text":"section 300ee–11 of this title","children":[],"tail":" at a level equal to not less than the average level of such expenditures maintained by the State for the 2-year period preceding the fiscal year for which the State is applying to receive payments."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb68a972f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–16/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Significant percentage” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of subsection (a)(5), the term “significant percentage” means at least a percentage of 1 percent of the number of reported cases of acquired immune deficiency syndrome in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb68a9730-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XXV, formerly title XV, § 2506, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/607/tII/s221"},"text":"Pub. L. 100–607, title II, § 221","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-04"},"text":"Nov. 4, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3097"},"text":"102 Stat. 3097","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tII/s2619/d"},"text":"Pub. L. 100–690, title II, § 2619(d) [(e)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4243"},"text":"102 Stat. 4243","children":[],"tail":"; renumbered title XXV, "},{"tag":"ref","attrib":{"href":"/us/pl/101/93/s5/e/1"},"text":"Pub. L. 101–93, § 5(e)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-08-16"},"text":"Aug. 16, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/612"},"text":"103 Stat. 612","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb68a9731-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb68a9732-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb68a9733-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Sections 254b and 254c of this title, referred to in subsec. (a)(5)(A)(i), were in the original references to sections 329 and 330, meaning sections 329 and 330 of act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", which were omitted in the general amendment of subpart I (§ 254b et seq.) of part D of subchapter II of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/104/299/s2"},"text":"Pub. L. 104–299, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3626"},"text":"110 Stat. 3626","children":[],"tail":". Sections 2 and 3(a) of "},{"tag":"ref","attrib":{"href":"/us/pl/104/299"},"text":"Pub. L. 104–299","children":[],"tail":" enacted new sections 330 and 330A of act "},{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", which are classified, respectively, to sections 254b and 254c of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb68a9734-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2506 of act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", was successively renumbered by subsequent acts, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s238e"},"text":"section 238e of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb68a9735-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690/s2619/d/1/s1"},"text":"Pub. L. 100–690, § 2619(d)(1) [(e)(1)]","children":[],"tail":", designated existing provisions as subsec. (a)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690/s2619/d/2/s2"},"text":"Pub. L. 100–690, § 2619(d)(2) [(e)(2)]","children":[],"tail":", struck out concluding provisions which read as follows: “(For purposes of this section, the term ‘significant percentage’ means at least a percentage of 1 percent of the number of reported cases of such syndrome in the United States);”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690/s2619/d/3/s3"},"text":"Pub. L. 100–690, § 2619(d)(3) [(e)(3)]","children":[],"tail":", substituted “funds from payments” for “funds from to payments” and struck out “and” after semicolon."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690/s2619/d/4/s4"},"text":"Pub. L. 100–690, § 2619(d)(4) [(e)(4)]","children":[],"tail":", substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ee–18/e"},"text":"section 300ee–18(e) of this title","children":[],"tail":"” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ee–19/e"},"text":"section 300ee–19(e) of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690/s2619/d/5/s5"},"text":"Pub. L. 100–690, § 2619(d)(5) [(e)(5)]","children":[],"tail":", added subsec. (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb68a9736-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb68a9737-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690"},"text":"Pub. L. 100–690","children":[],"tail":" effective immediately after enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/100/607"},"text":"Pub. L. 100–607","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"1988-11-04"},"text":"Nov. 4, 1988","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/s2600"},"text":"section 2600 of Pub. L. 100–690","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s242m"},"text":"section 242m of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb68a9738-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Reference to Community, Migrant, Public Housing, or Homeless Health Center Considered Reference to Health Center","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Reference to community health center, migrant health center, public housing health center, or homeless health center considered reference to health center, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/299/s4/c"},"text":"section 4(c) of Pub. L. 104–299","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s254b"},"text":"section 254b of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
