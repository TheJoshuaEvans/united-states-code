{"tag":"section","attrib":{"id":"idbc9f9888-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3939"},"text":null,"children":[{"tag":"num","attrib":{"value":"3939"},"text":"§ 3939.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of antitrust laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing contained herein shall affect the applicability of the Federal antitrust laws to the activities of the corporation and the partnership created under this chapter and of the persons participating therein or in partnerships, limited partnerships, or joint ventures with either of them.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbc9f9889-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/448/tIX/s909"},"text":"Pub. L. 90–448, title IX, § 909","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-08-01"},"text":"Aug. 1, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/550"},"text":"82 Stat. 550","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
