{"tag":"section","attrib":{"id":"idbcb9d77d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4126"},"text":null,"children":[{"tag":"num","attrib":{"value":"4126"},"text":"§ 4126.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any administrative expenses which may be sustained by the Federal Government in carrying out the flood insurance and floodplain management programs authorized under this chapter may be paid with amounts from the National Flood Insurance Fund (as provided under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4017/a/4"},"text":"section 4017(a)(4) of this title","children":[],"tail":"), subject to approval in appropriations Acts."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbcb9d77e-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/448/tXIII/s1375"},"text":"Pub. L. 90–448, title XIII, § 1375","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-08-01"},"text":"Aug. 1, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/589"},"text":"82 Stat. 589","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/tII/s2302/e/4"},"text":"Pub. L. 101–508, title II, § 2302(e)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-25"},"text":"104 Stat. 1388–25","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbcb9d77f-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbcb9d780-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","childr