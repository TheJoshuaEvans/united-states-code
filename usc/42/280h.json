{"tag":"section","attrib":{"id":"idb543e61a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280h"},"text":null,"children":[{"tag":"num","attrib":{"value":"280h"},"text":"§ 280h.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants to promote childhood nutrition and physical activity","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb543e61b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280h/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting though the Director of the Centers for Disease Control and Prevention, shall award competitive grants to States and political subdivisions of States for the development and implementation of State and community-based intervention programs to promote good nutrition and physical activity in children and adolescents.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb543e61c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280h/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to receive a grant under this section a State or political subdivision of a State shall prepare and submit to the Secretary an application at such time, in such manner, and containing such information as the Secretary may require, including a plan that describes—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb543e61d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280h/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how the applicant proposes to develop a comprehensive program of school- and community-based approaches to encourage and promote good nutrition and appropriate levels of physical activity with respect to children or adolescents in local communities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb543e61e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280h/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the manner in which the applicant shall coordinate with appropriate State and local authorities, such as State and local school departments, State departments of health, chronic disease directors, State directors of programs under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1786"},"text":"section 1786 of this title","children":[],"tail":", 5-a-day coordinators, governors councils for physical activity and good nutrition, and State and local parks and recreation departments; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb543e61f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280h/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the manner in which the applicant will evaluate the effectiveness of the program carried out under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb543e620-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280h/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A State or political subdivision of a State shall use amount received under a grant under this section to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb543e621-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280h/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop, implement, disseminate, and evaluate school- and community-based strategies in States to reduce inactivity and improve dietary choices among children and adolescents;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb543e622-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280h/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expand opportunities for physical activity programs in school- and community-based settings; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb543e623-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280h/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop, implement, and evaluate programs that promote good eating habits and physical activity including opportunities for children with cognitive and physical disabilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb543e624-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280h/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may set-aside an amount not to exceed 10 percent of the amount appropriated for a fiscal year under subsection (h) to permit the Director of the Centers for Disease Control and Prevention to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb543e625-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280h/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide States and political subdivisions of States with technical support in the development and implementation of programs under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb543e626-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280h/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disseminate information about effective strategies and interventions in preventing and treating obesity through the promotion of good nutrition and physical activity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb543e627-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280h/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on administrative costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not to exceed 10 percent of the amount of a grant awarded to the State or political subdivision under subsection (a) for a fiscal year may be used by the State or political subdivision for administrative expenses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb543e628-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280h/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A grant awarded under subsection (a) shall be for a term of 3 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb543e629-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280h/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “children and adolescents” means individuals who do not exceed 18 years of age.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb543e62a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280h/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this section such sums as may be necessary for each of the fiscal years 2001 through 2005.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb543e62b-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title III, § 399W, as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/310/dA/tXXIV/s2401"},"text":"Pub. L. 106–310, div. A, title XXIV, § 2401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-17"},"text":"Oct. 17, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1158"},"text":"114 Stat. 1158","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb543e62c-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb543e62d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb543e62e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another section 399W of act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", was renumbered section 399V–1 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s280g–12"},"text":"section 280g–12 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
