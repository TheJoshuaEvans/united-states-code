{"tag":"section","attrib":{"id":"idbf44c86f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11376"},"text":null,"children":[{"tag":"num","attrib":{"value":"11376"},"text":"§ 11376.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative provisions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf44c870-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11376/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 60 days after ","children":[{"tag":"date","attrib":{"date":"1987-07-22"},"text":"July 22, 1987","children":[],"tail":", the Secretary shall by notice establish such requirements as may be necessary to carry out the provisions of this part. Such requirements shall be subject to "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s553"},"text":"section 553 of title 5","children":[],"tail":". The Secretary shall issue requirements based on the initial notice before the expiration of the 12-month period following "},{"tag":"date","attrib":{"date":"1987-07-22"},"text":"July 22, 1987","children":[],"tail":". Prior to the issuance of such requirements in final form, the requirements established by the Secretary implementing the provisions of the emergency shelter grants program under the provisions made effective by "},{"tag":"ref","attrib":{"href":"/us/pl/99/500/s101/g"},"text":"section 101(g) of Public Law 99–500","children":[],"tail":" or "},{"tag":"ref","attrib":{"href":"/us/pl/99/591"},"text":"Public Law 99–591","children":[],"tail":" shall govern the emergency shelter grants program under this part."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf44c871-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11376/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial allocation of assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than the expiration of the 60-day period following the date of enactment of a law providing appropriations to carry out this part, the Secretary shall notify each State, metropolitan city, and urban county that is to receive a direct grant of its allocation of assistance under this part. Such assistance shall be allocated and may be used notwithstanding any failure of the Secretary to issue requirements under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf44c872-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11376/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum standards of habitability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall prescribe such minimum standards of habitability as the Secretary determines to be appropriate to ensure that emergency shelters assisted under this section are environments that provide appropriate privacy, safety, and sanitary and other health-related conditions for homeless persons and families. Grantees are authorized to establish standards of habitability in addition to those prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf473973-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/77/tIV/s417"},"text":"Pub. L. 100–77, title IV, § 417","children":[],"tail":", formerly § 416, "},{"tag":"date","attrib":{"date":"1987-07-22"},"text":"July 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/498"},"text":"101 Stat. 498","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/625/tVIII/s832/f/7"},"text":"Pub. L. 101–625, title VIII, § 832(f)(7)","children":[],"tail":", (g), "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4361"},"text":"104 Stat. 4361","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/330/tV/s506/a/6"},"text":"Pub. L. 104–330, title V, § 506(a)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-26"},"text":"Oct. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/4044"},"text":"110 Stat. 4044","children":[],"tail":"; renumbered § 417, "},{"tag":"ref","attrib":{"href":"/us/pl/111/22/dB/tII/s1201/3"},"text":"Pub. L. 111–22, div. B, title II, § 1201(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-05-20"},"text":"May 20, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1678"},"text":"123 Stat. 1678","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf473974-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf473975-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbf473976-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The emergency shelter grants program under the provisions made effective by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/500/s101/g"},"text":"section 101(g) of Public Law 99–500","children":[],"tail":" or "},{"tag":"ref","attrib":{"h