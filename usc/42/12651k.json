{"tag":"section","attrib":{"id":"idbf8ea2fe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651k"},"text":null,"children":[{"tag":"num","attrib":{"value":"12651k"},"text":"§ 12651k.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study of involvement of veterans","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf8ea2ff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651k/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study and report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Corporation shall conduct a study and submit a report to the authorizing committees, not later than 3 years after the effective date of the Serve America Act, on—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf8ea300-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651k/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of veterans serving in national service programs historically by year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf8ea301-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651k/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" strategies being undertaken to identify the specific areas of need of veterans, including any goals set by the Corporation for veterans participating in the service programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf8ea302-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651k/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the impact of the strategies described in paragraph (2) and the Veterans Corps on enabling greater participation by veterans in the national service programs carried out under the national service laws;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf8ea303-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651k/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how existing programs and activities carried out under the national service laws could be improved to serve veterans, veterans service organizations, families of active-duty military, including gaps in services to veterans;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf8ea304-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651k/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which existing programs and activities carried out under the national service laws are coordinated and recommendations to improve such coordination including the methods for ensuring the efficient financial organization of services directed towards veterans; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf8ea305-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651k/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how to improve utilization of veterans as resources and volunteers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf8ea306-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651k/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In conducting the studies and preparing the reports required under this subsection, the Corporation shall consult with veterans’ service organizations, the Secretary of Veterans Affairs, State veterans agencies, the Secretary of Defense, as appropriate, and other individuals and entities the Corporation considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf8ea307-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/610/tI/s196C"},"text":"Pub. L. 101–610, title I, § 196C","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/13/tI/s1709"},"text":"Pub. L. 111–13, title I, § 1709","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-04-21"},"text":"Apr. 21, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1549"},"text":"123 Stat. 1549","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf8ea308-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf8ea309-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbf8ea30a-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For the effective date of the Serve America Act, referred to in subsec. (a), as ","children":[{"tag":"date","attrib":{"date":"2009-10-01"},"text":"Oct. 1, 2009","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/111/13/s6101/a"},"text":"section 6101(a) of Pub. L. 111–13","children":[],"tail":", set out as an Effective Date of 2009 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4950"},"text":"section 4950 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbf8ea30b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbf8ea30c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2009-10-01"},"text":"Oct. 1, 2009","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/111/13/s6101/a"},"text":"section 6101(a) of Pub. L. 111–13","children":[],"tail":", set out as an Effective Date of 2009 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4950"},"text":"section 4950 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
