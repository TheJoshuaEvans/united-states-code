{"tag":"section","attrib":{"id":"idbfe6fbb3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15903"},"text":null,"children":[{"tag":"num","attrib":{"value":"15903"},"text":"§ 15903.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Marginal property production incentives","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfe6fbb4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15903/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of marginal property","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Until such time as the Secretary issues regulations under subsection (e) that prescribe a different definition, in this section, the term “marginal property” means an onshore unit, communitization agreement, or lease not within a unit or communitization agreement, that produces on average the combined equivalent of less than 15 barrels of oil per well per day or 90,000,000 British thermal units of gas per well per day calculated based on the average over the 3 most recent production months, including only wells that produce on more than half of the days during those 3 production months.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfe6fbb5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15903/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conditions for reduction of royalty rate","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Until such time as the Secretary issues regulations under subsection (e) that prescribe different standards or requirements, the Secretary shall reduce the royalty rate on—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfe6fbb6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15903/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" oil production from marginal properties as prescribed in subsection (c) if the spot price of West Texas Intermediate crude oil at Cushing, Oklahoma, is, on average, less than $15 per barrel (adjusted in accordance with the Consumer Price Index for all-urban consumers, United States city average, as published by the Bureau of Labor Statistics) for 90 consecutive trading days; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe6fbb7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15903/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" gas production from marginal properties as prescribed in subsection (c) if the spot price of natural gas delivered at Henry Hub, Louisiana, is, on average, less than $2.00 per million British thermal units (adjusted in accordance with the Consumer Price Index for all-urban consumers, United States city average, as published by the Bureau of Labor Statistics) for 90 consecutive trading days.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfe6fbb8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15903/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reduced royalty rate","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfe6fbb9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15903/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"When a marginal property meets the conditions specified in subsection (b), the royalty rate shall be the lesser of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfe6fbba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15903/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 5 percent; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfe6fbbb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15903/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the applicable rate under any other statutory or regulatory royalty relief provision that applies to the affected production.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe6fbbc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15903/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Period of effectiveness","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The reduced royalty rate under this subsection shall be effective beginning on the first day of the production month following the date on which the applicable condition specified in subsection (b) is met.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfe6fbbd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15903/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of reduced royalty rate","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A royalty rate prescribed in subsection (c)(1) shall terminate—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfe6fbbe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15903/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" with respect to oil production from a marginal property, on the first day of the production month following the date on which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfe6fbbf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15903/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the spot price of West Texas Intermediate crude oil at Cushing, Oklahoma, on average, exceeds $15 per barrel (adjusted in accordance with the Consumer Price Index for all-urban consumers, United States city average, as published by the Bureau of Labor Statistics) for 90 consecutive trading days; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfe6fbc0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15903/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the property no longer qualifies as a marginal property; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe6fbc1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15903/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" with respect to gas production from a marginal property, on the first day of the production month following the date on which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfe6fbc2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15903/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the spot price of natural gas delivered at Henry Hub, Louisiana, on average, exceeds $2.00 per million British thermal units (adjusted in accordance with the Consumer Price Index for all-urban consumers, United States city average, as published by the Bureau of Labor Statistics) for 90 consecutive trading days; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfe6fbc3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15903/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the property no longer qualifies as a marginal property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfe6fbc4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15903/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations prescribing different relief","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfe6fbc5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15903/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Discretionary regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may by regulation prescribe different parameters, standards, and requirements for, and a different degree or extent of, royalty relief for marginal properties in lieu of those prescribed in subsections (a) through (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe6fbc6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15903/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mandatory regulations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Unless a determination is made under paragraph (3), not later than 18 months after ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":", the Secretary shall by regulation—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfe6fbc7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15903/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prescribe standards and requirements for, and the extent of royalty relief for, marginal properties for oil and gas leases on the outer Continental Shelf; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfe6fbc8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15903/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" define what constitutes a marginal property on the outer Continental Shelf for purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe6fbc9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15903/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the extent the Secretary determines that it is not practicable to issue the regulations referred to in paragraph (2), the Secretary shall provide a report to Congress explaining such determination by not later than 18 months after ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe6fbca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15903/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Considerations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In issuing regulations under this subsection, the Secretary may consider—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfe6fbcb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15903/e/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" oil and gas prices and market trends;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfe6fbcc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15903/e/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" production costs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfe6fbcd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15903/e/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" abandonment costs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfe6fbce-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15903/e/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal and State tax provisions and the effects of those provisions on production economics;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfe6fbcf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15903/e/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other royalty relief programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfe6fbd0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15903/e/4/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" regional differences in average wellhead prices;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfe6fbd1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15903/e/4/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" national energy security issues; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfe6fbd2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15903/e/4/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other relevant matters, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfe6fbd3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15903/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Savings provision","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section prevents a lessee from receiving royalty relief or a royalty reduction pursuant to any other law (including a regulation) that provides more relief than the amounts provided by this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfe6fbd4-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tIII/s343"},"text":"Pub. L. 109–58, title III, § 343","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/700"},"text":"119 Stat. 700","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
