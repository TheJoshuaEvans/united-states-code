{"tag":"section","attrib":{"id":"idb5a0fa6f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–16"},"text":null,"children":[{"tag":"num","attrib":{"value":"290aa–16"},"text":"§ 290aa–16.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation of performance of Department of Health and Human Services programs","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5a0fa70-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–16/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluations","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5a0fa71-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–16/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 5 years after ","children":[{"tag":"date","attrib":{"date":"2016-07-22"},"text":"July 22, 2016","children":[],"tail":", except as otherwise provided in this section,"},{"tag":"ref","attrib":{"idref":"fn002223"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002223"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" the Secretary of Health and Human Services (in this section referred to as the “Secretary”) shall complete an evaluation of any program administered by the Secretary included in this Act (or an amendment made by this Act, excluding sections 703 through 707), including any grant administered by the Administrator of the Substance Abuse and Mental Health Services Administration under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s1536"},"text":"section 1536 of title 21","children":[],"tail":", that provides grants for the primary purpose of providing assistance in addressing problems pertaining to opioid abuse based upon the outcomes and metrics identified under paragraph (2)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5a0fa72-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–16/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to each evaluation completed under subparagraph (A), the Secretary shall, not later than 90 days after the date on which such evaluation is completed, publish the results of such evaluation and issue a report on such evaluation to the appropriate committees. Such report shall also be published along with the data used to make such evaluation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5a0fa73-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–16/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Metrics and outcomes","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5a0fa74-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–16/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2016-07-22"},"text":"July 22, 2016","children":[],"tail":", the Secretary shall identify—"}],"tail":null},{"tag":"clause","attrib":{"id":"idb5a0fa75-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–16/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" outcomes that are to be achieved by activities funded by the programs described in paragraph (1)(A); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5a0fa76-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–16/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the metrics by which the achievement of such outcomes shall be determined.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5a0fa77-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–16/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall, not later than 30 days after completion of the requirement under subparagraph (A), publish the outcomes and metrics identified under such subparagraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5a0fa78-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–16/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Metrics data collection","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall require grantees under the programs described in paragraph (1)(A) to collect, and annually report to the Secretary, data based upon the metrics identified under paragraph (2)(A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5a0fa79-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–16/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Independent evaluation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of paragraph (1), the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5a0fa7a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–16/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enter into an arrangement with the National Academy of Sciences; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5a0fa7b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–16/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" enter into a contract or cooperative agreement with an entity that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb5a0fa7c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–16/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not an agency of the Federal Government; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5a0fa7d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–16/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is qualified to conduct and evaluate research pertaining to opioid use and abuse and draw conclusions about overall opioid use and abuse on the basis of that research.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5a0fa7e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–16/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a program described in paragraph (1)(A) is subject to an evaluation similar to the evaluation required under such paragraph pursuant to another provision of Federal law, the Secretary may opt not to conduct an evaluation under such paragraph with respect to such program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5a0fa7f-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/198/tVII/s701/d"},"text":"Pub. L. 114–198, title VII, § 701(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-07-22"},"text":"July 22, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/739"},"text":"130 Stat. 739","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb5a0fa80-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb5a0fa81-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb5a0fa82-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This section, the first time appearing in par. (1)(A), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/198/s701"},"text":"section 701 of Pub. L. 114–198","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-07-22"},"text":"July 22, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/739"},"text":"130 Stat. 739","children":[],"tail":", which enacted this section, "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s290aa–15"},"text":"section 290aa–15 of this title","children":[],"tail":", sections 10706 and 10707 of Title 34, Crime Control and Law Enforcement, and provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s290aa–15"},"text":"section 290aa–15 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This Act, referred to in par. (1)(A), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/198"},"text":"Pub. L. 114–198","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-07-22"},"text":"July 22, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/695"},"text":"130 Stat. 695","children":[],"tail":", known as the Comprehensive Addiction and Recovery Act of 2016. Section 703 of the Act is not classified to the Code, and sections 704 to 707 of the Act enacted "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320a–7n"},"text":"section 1320a–7n of this title","children":[],"tail":", amended sections 1395w–101, 1395w–104, 1395w–152, 1395ddd, 1395iii, 1396a, 1396r–8, 1396w–1, and 1397bb of this title, and enacted provisions set out as notes under sections 1395w–101 and 1396r–8 of this title. For complete classification of this Act to the Code, see Short Title of 2016 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s201"},"text":"section 201 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb5a0fa83-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Comprehensive Addiction and Recovery Act of 2016, and not as part of the Public Health Service Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
