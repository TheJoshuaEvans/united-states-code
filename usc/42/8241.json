{"tag":"section","attrib":{"id":"idbe839b6f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8241"},"text":null,"children":[{"tag":"num","attrib":{"value":"8241"},"text":"§ 8241.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in the part—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe839b70-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8241/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “Federal agency” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbe839b71-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8241/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an Executive agency as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s105"},"text":"section 105 of title 5","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe839b72-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8241/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each entity specified in subparagraphs (B) through (I) of subsection (1) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5721"},"text":"section 5721 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe839b73-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8241/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Federal building” means any building or other structure owned in whole or part by the United States or any Federal agency, including any such structure occupied by a Federal agency under a lease-acquisition agreement under which the United States or a Federal agency will receive fee simple title under the terms of such agreement without further negotiation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe839b74-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8241/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “solar heating” means, with respect to any Federal building, the use of solar energy to meet all or part of the heating needs of such building (including hot water), or all or part of the needs of such building for hot water.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe839b75-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8241/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “solar heating and cooling” means the use of solar energy to provide all or part of the heating needs of a Federal building (including hot water) and all or part of the cooling needs of such building, or all or part of the needs of such building for hot water.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe839b76-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8241/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “solar energy equipment” means equipment for solar heating or solar heating and cooling.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe839b77-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8241/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Secretary” means the Secretary of Energy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbe839b78-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/619/tV/s521"},"text":"Pub. L. 95–619, title V, § 521","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-09"},"text":"Nov. 9, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3275"},"text":"92 Stat. 3275","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/161/dH/tI/s1303/b"},"text":"Pub. L. 110–161, div. H, title I, § 1303(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-26"},"text":"Dec. 26, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/2242"},"text":"121 Stat. 2242","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbe839b79-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbe839b7a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbe839b7b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2007—Par. (1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/161"},"text":"Pub. L. 110–161","children":[],"tail":" substituted “subparagraphs (B) through (I)” for “paragraphs (B) through (H)”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
