{"tag":"section","attrib":{"id":"idbc2140e7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2333"},"text":null,"children":[{"tag":"num","attrib":{"value":"2333"},"text":"§ 2333.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of priorities","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"No priority shall be transferable, except—","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbc2140e8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2333/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a husband and wife may exercise a priority in their joint names;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc2140e9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2333/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a religious organization may exercise the priority which would otherwise belong to its priest, minister, or rabbi, regardless of whether that position happens to be filled at the time of the exercise of the priority;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc2140ea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2333/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" two or more priority holders having a common interest in a building or location may assign their interests to a single assignee; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc2140eb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2333/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Commission may permit such other transfers as it finds to be fair and equitable.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc2140ec-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1955-08-04/ch543"},"text":"Aug. 4, 1955, ch. 543","children":[],"tail":", ch. 4, § 43, "},{"tag":"ref","attrib":{"href":"/us/stat/69/476"},"text":"69 Stat. 476","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc2140ed-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbc2140ee-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"idbc2140ef-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Atomic Energy Commission abolished and functions transferred by sections 5814 and 5841 of this title. See also Transfer of Functions notes set out under those sections.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
