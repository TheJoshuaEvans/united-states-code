{"tag":"section","attrib":{"id":"idc0465a0d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18021"},"text":null,"children":[{"tag":"num","attrib":{"value":"18021"},"text":"§ 18021.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified health plan defined","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc0465a0e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18021/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified health plan","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this title: ","children":[{"tag":"ref","attrib":{"idref":"fn004300"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004300"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0465a0f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18021/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “qualified health plan” means a health plan that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0465a10-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18021/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has in effect a certification (which may include a seal or other indication of approval) that such plan meets the criteria for certification described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s18031/c"},"text":"section 18031(c) of this title","children":[],"tail":" issued or recognized by each Exchange through which such plan is offered;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0465a11-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18021/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides the essential health benefits package described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s18022/a"},"text":"section 18022(a) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0465a12-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18021/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is offered by a health insurance issuer that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc0465a13-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18021/a/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is licensed and in good standing to offer health insurance coverage in each State in which such issuer offers health insurance coverage under this title; ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc0465a14-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18021/a/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" agrees to offer at least one qualified health plan in the silver level and at least one plan in the gold level in each such Exchange;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc0465a15-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18021/a/1/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" agrees to charge the same premium rate for each qualified health plan of the issuer without regard to whether the plan is offered through an Exchange or whether the plan is offered directly from the issuer or through an agent; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc0465a16-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18021/a/1/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" complies with the regulations developed by the Secretary under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s18031/d"},"text":"section 18031(d) of this title","children":[],"tail":" and such other requirements as an applicable Exchange may establish."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0465a17-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18021/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusion of CO–OP plans and multi-State qualified health plans","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any reference in this title ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" to a qualified health plan shall be deemed to include a qualified health plan offered through the CO–OP program under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s18042"},"text":"section 18042 of this title","children":[],"tail":", and a multi-State plan under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s18054"},"text":"section 18054 of this title","children":[],"tail":", unless specifically provided for otherwise."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0465a18-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18021/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of qualified direct primary care medical home plans","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Health and Human Services shall permit a qualified health plan to provide coverage through a qualified direct primary care medical home plan that meets criteria established by the Secretary, so long as the qualified health plan meets all requirements that are otherwise applicable and the services covered by the medical home plan are coordinated with the entity offering the qualified health plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0465a19-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18021/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Variation based on rating area","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A qualified health plan, including a multi-State qualified health plan, may as appropriate vary premiums by rating area (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300gg/a/2"},"text":"section 300gg(a)(2) of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0465a1a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18021/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms relating to health plans","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this title: ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0465a1b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18021/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Health plan","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0465a1c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18021/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “health plan” means health insurance coverage and a group health plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0465a1d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18021/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for self-insured plans and MEWAs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except to the extent specifically provided by this title,","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" the term “health plan” shall not include a group health plan or multiple employer welfare arrangement to the extent the plan or arrangement is not subject to State insurance regulation under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s1144"},"text":"section 1144 of title 29","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0465a1e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18021/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Health insurance coverage and issuer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “health insurance coverage” and “health insurance issuer” have the meanings given such terms by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300gg–91/b"},"text":"section 300gg–91(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0465a1f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18021/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Group health plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “group health plan” has the meaning given such term by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300gg–91/a"},"text":"section 300gg–91(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc0465a20-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/tI/s1301"},"text":"Pub. L. 111–148, title I, § 1301","children":[],"tail":", title X, § 10104(a), "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/162"},"text":"124 Stat. 162","children":[],"tail":", 896.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc0465a21-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc0465a22-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc0465a23-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This title, where footnoted in text, is title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148"},"text":"Pub. L. 111–148","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/130"},"text":"124 Stat. 130","children":[],"tail":", which enacted this chapter and enacted, amended, and transferred numerous other sections and notes in the Code. For complete classification of title I to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc0465a24-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (a)(2) to (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/s10104/a"},"text":"Pub. L. 111–148, § 10104(a)","children":[],"tail":", added pars. (2) to (4) and struck out former par. (2). Prior to amendment, text of par. (2) read as follows: “Any reference in this title to a qualified health plan shall be deemed to include a qualified health plan offered through the CO-OP program under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s18042"},"text":"section 18042 of this title","children":[],"tail":" or a community health insurance option under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s18043"},"text":"section 18043 of this title","children":[],"tail":", unless specifically provided for otherwise.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
