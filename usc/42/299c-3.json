{"tag":"section","attrib":{"id":"idb6078522-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299c–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"299c–3"},"text":"§ 299c–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dissemination of information","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb6078523-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299c–3/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6078524-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299c–3/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" without regard to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t44/s501"},"text":"section 501 of title 44","children":[],"tail":", promptly publish, make available, and otherwise disseminate, in a form understandable and on as broad a basis as practicable so as to maximize its use, the results of research, demonstration projects, and evaluations conducted or supported under this subchapter;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6078525-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299c–3/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that information disseminated by the Agency is science-based and objective and undertakes consultation as necessary to assess the appropriateness and usefulness of the presentation of information that is targeted to specific audiences;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6078526-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299c–3/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promptly make available to the public data developed in such research, demonstration projects, and evaluations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6078527-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299c–3/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide, in collaboration with the National Library of Medicine where appropriate, indexing, abstracting, translating, publishing, and other services leading to a more effective and timely dissemination of information on research, demonstration projects, and evaluations with respect to health care to public and private entities and individuals engaged in the improvement of health care delivery and the general public, and undertake programs to develop new or improved methods for making such information available; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6078528-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299c–3/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as appropriate, provide technical assistance to State and local government and health agencies and conduct liaison activities to such agencies to foster dissemination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6078529-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299c–3/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition against restrictions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subsection (c), the Director may not restrict the publication or dissemination of data from, or the results of, projects conducted or supported under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb607852a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299c–3/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on use of certain information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No information, if an establishment or person supplying the information or described in it is identifiable, obtained in the course of activities undertaken or supported under this subchapter may be used for any purpose other than the purpose for which it was supplied unless such establishment or person has consented (as determined under regulations of the Director) to its use for such other purpose. Such information may not be published or released in other form if the person who supplied the information or who is described in it is identifiable unless such person has consented (as determined under regulations of the Director) to its publication or release in other form.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb607852b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299c–3/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalty","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person who violates subsection (c) shall be subject to a civil monetary penalty of not more than $10,000 for each such violation involved. Such penalty shall be imposed and collected in the same manner as civil money penalties under subsection (a) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320a–7a"},"text":"section 1320a–7a of this title","children":[],"tail":" are imposed and collected."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb607852c-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title IX, § 944, formerly § 924, as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/129/s2/a"},"text":"Pub. L. 106–129, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-12-06"},"text":"Dec. 6, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1667"},"text":"113 Stat. 1667","children":[],"tail":"; renumbered § 934, "},{"tag":"ref","attrib":{"href":"/us/pl/109/41/s2/a/3"},"text":"Pub. L. 109–41, § 2(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-07-29"},"text":"July 29, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/424"},"text":"119 Stat. 424","children":[],"tail":"; renumbered § 944, "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tIII/s3013/a/2"},"text":"Pub. L. 111–148, title III, § 3013(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/381"},"text":"124 Stat. 381","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb607852d-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb607852e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb607852f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 299c–3, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373/tIX/s924"},"text":"act July 1, 1944, ch. 373, title IX, § 924","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/239/tVI/s6103/c"},"text":"Pub. L. 101–239, title VI, § 6103(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2202"},"text":"103 Stat. 2202","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/410/s9"},"text":"Pub. L. 102–410, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-13"},"text":"Oct. 13, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2100"},"text":"106 Stat. 2100","children":[],"tail":", related to additional provisions with respect to grants and contracts, prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/106/129"},"text":"Pub. L. 106–129","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s299c–4"},"text":"section 299c–4 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
