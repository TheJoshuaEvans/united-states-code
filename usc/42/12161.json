{"tag":"section","attrib":{"id":"idbf6151bd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12161"},"text":null,"children":[{"tag":"num","attrib":{"value":"12161"},"text":"§ 12161.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this subpart:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf6151be-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12161/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commuter authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “commuter authority” has the meaning given such term in section 24102(4) ","children":[{"tag":"ref","attrib":{"idref":"fn004029"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004029"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of title 49."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf6151bf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12161/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commuter rail transportation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “commuter rail transportation” has the meaning given the term “commuter rail passenger transportation” in section 24102(5) ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of title 49."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf6151c0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12161/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Intercity rail transportation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “intercity rail transportation” means transportation provided by the National Railroad Passenger Corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf6151c1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12161/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rail passenger car","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “rail passenger car” means, with respect to intercity rail transportation, single-level and bi-level coach cars, single-level and bi-level dining cars, single-level and bi-level sleeping cars, single-level and bi-level lounge cars, and food service cars.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf6151c2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12161/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsible person","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “responsible person” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf6151c3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12161/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a station more than 50 percent of which is owned by a public entity, such public entity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf6151c4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12161/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a station more than 50 percent of which is owned by a private party, the persons providing intercity or commuter rail transportation to such station, as allocated on an equitable basis by regulation by the Secretary of Transportation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf6151c5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12161/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in a case where no party owns more than 50 percent of a station, the persons providing intercity or commuter rail transportation to such station and the owners of the station, other than private party owners, as allocated on an equitable basis by regulation by the Secretary of Transportation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf6151c6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12161/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Station","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “station” means the portion of a property located appurtenant to a right-of-way on which intercity or commuter rail transportation is operated, where such portion is used by the general public and is related to the provision of such transportation, including passenger platforms, designated waiting areas, ticketing areas, restrooms, and, where a public entity providing rail transportation owns the property, concession areas, to the extent that such public entity exercises control over the selection, design, construction, or alteration of the property, but such term does not include flag stops.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf6151c7-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/336/tII/s241"},"text":"Pub. L. 101–336, title II, § 241","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-07-26"},"text":"July 26, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/346"},"text":"104 Stat. 346","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/287/s6/k"},"text":"Pub. L. 104–287, § 6(k)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3400"},"text":"110 Stat. 3400","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf6151c8-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf6151c9-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbf6151ca-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s24102"},"text":"Section 24102 of title 49","children":[],"tail":", referred to in pars. (1) and (2), was subsequently amended, and pars. (4) and (5) of section 24102 no longer define “commuter authority” and “commuter rail passenger transportation”, respectively. However, such terms are defined elsewhere in that section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbf6151cb-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In pars. (1) and (2), “","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s24102/4"},"text":"section 24102(4) of title 49","children":[],"tail":"” substituted for “section 103(8) of the Rail Passenger Service Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t45/s502/8"},"text":"45 U.S.C. 502(8)","children":[],"tail":")” and “"},{"tag":"ref","attrib":{"href":"/us/usc/t49/s24102/5"},"text":"section 24102(5) of title 49","children":[],"tail":"” substituted for “section 103(9) of the Rail Passenger Service Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t45/s502/9"},"text":"45 U.S.C. 502(9)","children":[],"tail":")” on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/103/272/s6/b"},"text":"Pub. L. 103–272, § 6(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1378"},"text":"108 Stat. 1378","children":[],"tail":", the first section of which enacted subtitles II, III, and V to X of Title 49, Transportation."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbf6151cc-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/287"},"text":"Pub. L. 104–287","children":[],"tail":" substituted “commuter rail passenger transportation” for “commuter service”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbf6151cd-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbf6151ce-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/336/tII/s246"},"text":"Pub. L. 101–336, title II, § 246","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-07-26"},"text":"July 26, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/353"},"text":"104 Stat. 353","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/336/tII/s246"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Rule","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in subsection (b), this part [part II (§§ 241–246) of subtitle B of title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/336"},"text":"Pub. L. 101–336","children":[],"tail":", enacting this subpart] shall become effective 18 months after the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"1990-07-26"},"text":"July 26, 1990","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Sections 242 and 244 [sections 12162 and 12164 of this title] shall become effective on the date of enactment of this Act.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
