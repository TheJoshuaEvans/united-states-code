0 Stat. 2689","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/193/tI/s110/a"},"text":"Pub. L. 104–193, title I, § 110(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-22"},"text":"Aug. 22, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2171"},"text":"110 Stat. 2171","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/220/tIII/s302/b"},"text":"Pub. L. 105–220, title III, § 302(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-07"},"text":"Aug. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1081"},"text":"112 Stat. 1081","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb7bb9ce8-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb7bb9ce9-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb7bb9cea-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s603a"},"text":"section 603a of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of the Social Security Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb7bb9ceb-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/220"},"text":"Pub. L. 105–220","children":[],"tail":" substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t29/s49b/b"},"text":"section 49b(b) of title 29","children":[],"tail":"” for “the third sentence of "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s49b/a"},"text":"section 49b(a) of title 29","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/193"},"text":"Pub. L. 104–193","children":[],"tail":" amended section catchline and text generally. Prior to amendment, text read as follows: “For purposes of "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s603"},"text":"section 603 of this title","children":[],"tail":", expenses incurred to reimburse State employment offices for furnishing information requested of such offices pursuant to the third sentence of "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s49b/a"},"text":"section 49b(a) of title 29","children":[],"tail":", by a State or local agency administering a State plan approved under part A of this subchapter shall be considered to constitute expenses incurred in the administration of such State plan; and for purposes of "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s655"},"text":"section 655 of this title","children":[],"tail":", expenses incurred to reimburse State employment offices for furnishing information so requested by a State or local agency charged with the duty of carrying out a State plan for child support approved under part D of this subchapter shall be considered to constitute expenses incurred in the administration of such State plan.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb7bb9cec-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendmen