{"tag":"section","attrib":{"id":"idbf663349-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12207"},"text":null,"children":[{"tag":"num","attrib":{"value":"12207"},"text":"§ 12207.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal wilderness areas","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf66334a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12207/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The National Council on Disability shall conduct a study and report on the effect that wilderness designations and wilderness land management practices have on the ability of individuals with disabilities to use and enjoy the National Wilderness Preservation System as established under the Wilderness Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1131"},"text":"16 U.S.C. 1131","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf66334b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12207/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission of report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"1990-07-26"},"text":"July 26, 1990","children":[],"tail":", the National Council on Disability shall submit the report required under subsection (a) to Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf66334c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12207/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specific wilderness access","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf66334d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12207/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Congress reaffirms that nothing in the Wilderness Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1131"},"text":"16 U.S.C. 1131","children":[],"tail":" et seq.] is to be construed as prohibiting the use of a wheelchair in a wilderness area by an individual whose disability requires use of a wheelchair, and consistent with the Wilderness Act no agency is required to provide any form of special treatment or accommodation, or to construct any facilities or modify any conditions of lands within a wilderness area in order to facilitate such use."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf66334e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12207/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Wheelchair” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of paragraph (1), the term “wheelchair” means a device designed solely for use by a mobility-impaired person for locomotion, that is suitable for use in an indoor pedestrian area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf66334f-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/336/tV/s508"},"text":"Pub. L. 101–336, title V, § 508","children":[],"tail":", formerly § 507, "},{"tag":"date","attrib":{"date":"1990-07-26"},"text":"July 26, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/372"},"text":"104 Stat. 372","children":[],"tail":"; renumbered § 508, "},{"tag":"ref","attrib":{"href":"/us/pl/110/325/s6/a/2"},"text":"Pub. L. 110–325, § 6(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-09-25"},"text":"Sept. 25, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3558"},"text":"122 Stat. 3558","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf663350-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf663351-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbf663352-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Wilderness Act, referred to in subsecs. (a) and (c)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/577"},"text":"Pub. L. 88–577","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-09-03"},"text":"Sept. 3, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/890"},"text":"78 Stat. 890","children":[],"tail":", which is classified generally to chapter 23 (§ 1131 et seq.) of Title 16, Conservation. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1131"},"text":"section 1131 of Title 16","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbf663353-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/336/s508"},"text":"section 508 of Pub. L. 101–336","children":[],"tail":" was renumbered section 509 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12208"},"text":"section 12208 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
