{"tag":"section","attrib":{"id":"idb5f200d4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s296a"},"text":null,"children":[{"tag":"num","attrib":{"value":"296a"},"text":"§ 296a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5f200d5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s296a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be eligible to receive a grant or contract under this subchapter, an eligible entity shall prepare and submit to the Secretary an application that meets the requirements of this section, at such time, in such manner, and containing such information as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5f200d6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s296a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An application submitted under this section shall contain the plan of the applicant for carrying out a project with amounts received under this subchapter. Such plan shall be consistent with relevant Federal, State, or regional program plans.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5f200d7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s296a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Performance outcome standards","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An application submitted under this section shall contain a specification by the applicant entity of performance outcome standards that the project to be funded under the grant or contract will be measured against. Such standards shall address relevant national nursing needs that the project will meet, and how such project aligns with the goals in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s296e/a"},"text":"section 296e(a) of this title","children":[],"tail":". The recipient of a grant or contract under this section shall meet the standards set forth in the grant or contract application."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5f200d8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s296a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Linkages","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An application submitted under this section shall contain a description of the linkages with relevant educational and health care entities, including training programs for other health professionals as appropriate, that the project to be funded under the grant or contract will establish.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5f200d9-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title VIII, § 802, as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/392/tI/s123/4"},"text":"Pub. L. 105–392, title I, § 123(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3564"},"text":"112 Stat. 3564","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/136/dA/tIII/s3404/a/2"},"text":"Pub. L. 116–136, div. A, title III, § 3404(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-03-27"},"text":"Mar. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/392"},"text":"134 Stat. 392","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb5f200da-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb5f200db-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb5f200dc-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 296a, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373/tVIII/s802"},"text":"act July 1, 1944, ch. 373, title VIII, § 802","children":[],"tail":", as added "},{"tag":"date","attrib":{"date":"1964-09-04"},"text":"Sept. 4, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/88/581/s2"},"text":"Pub. L. 88–581, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/909"},"text":"78 Stat. 909","children":[],"tail":"; amended "},{"tag":"date","attrib":{"date":"1968-08-16"},"text":"Aug. 16, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/90/490/tII/s201/b"},"text":"Pub. L. 90–490, title II, § 201(b)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/780"},"text":"82 Stat. 780","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1971-11-18"},"text":"Nov. 18, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/92/158"},"text":"Pub. L. 92–