{"tag":"section","attrib":{"id":"idbcf09f58-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5028"},"text":null,"children":[{"tag":"num","attrib":{"value":"5028"},"text":"§ 5028.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of Director","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbcf09f59-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5028/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director is authorized to make grants to or enter into contracts with public or nonprofit organizations, including organizations funded under part A, B, or C, for the purposes of demonstrating innovative activities involving older Americans as volunteers. The Director may support under this part both volunteers receiving stipends and volunteers not receiving stipends.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcf09f5a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5028/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An organization that receives a grant or enters into a contract under subsection (a) may use funds made available through the grant or contract for activities such as—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbcf09f5b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5028/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" linking youth groups and older American organizations in volunteer activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcf09f5c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5028/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" involving older volunteers in programs and activities different from programs and activities supported in the community; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcf09f5d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5028/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" testing whether older American volunteer programs may contribute to new objectives or certain national priorities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbcf09f5e-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/113/tII/s231"},"text":"Pub. L. 93–113, title II, § 231","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/tIII/s351"},"text":"Pub. L. 103–82, title III, § 351","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-09-21"},"text":"Sept. 21, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/906"},"text":"107 Stat. 906","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbcf09f5f-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbcf09f60-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbcf09f61-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1993-10-01"},"text":"Oct. 1, 1993","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/s392"},"text":"section 392 of Pub. L. 103–82","children":[],"tail":", set out as an Effective Date of 1993 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4951"},"text":"section 4951 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
