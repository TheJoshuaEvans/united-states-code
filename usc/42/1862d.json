{"tag":"section","attrib":{"id":"idbb8639f3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862d"},"text":null,"children":[{"tag":"num","attrib":{"value":"1862d"},"text":"§ 1862d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Set-aside for certain institutions","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Of the amounts appropriated to the Foundation for the Program, as authorized under section 101 of this Act, in each fiscal year, at least 12 percent shall be reserved for historically Black colleges or universities defined as “part B institutions” by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1061/2"},"text":"section 1061(2) of title 20","children":[],"tail":" and other institutions of higher education whose enrollment includes a substantial percentage of students who are Black Americans, Hispanic Americans, or Native Americans."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbb8639f4-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/570/tII/s205"},"text":"Pub. L. 100–570, title II, § 205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-31"},"text":"Oct. 31, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2877"},"text":"102 Stat. 2877","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbb8639f5-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbb8639f6-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbb8639f7-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 101 of this Act, referred to in text, is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/570/s101"},"text":"section 101 of Pub. L. 100–570","children":[],"tail":", title I, "},{"tag":"date","attrib":{"date":"1988-10-31"},"text":"Oct. 31, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2865"},"text":"102 Stat. 2865","children":[],"tail":", which is not classified to the Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbb8639f8-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Academic Research Facilities Modernization Act of 1988, and also as part of the National Science Foundation Authorization Act of 1988, and not as part of the National Science Foundation Act of 1950 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
