{"tag":"section","attrib":{"id":"idb67eb039-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300bb–8"},"text":null,"children":[{"tag":"num","attrib":{"value":"300bb–8"},"text":"§ 300bb–8.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb67eb03a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300bb–8/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Group health plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “group health plan” has the meaning given such term in 5000(b) ","children":[{"tag":"ref","attrib":{"idref":"fn002411"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002411"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be preceded by “section”."}],"tail":" of title 26. Such term shall not include any plan substantially all of the coverage under which is for qualified long-term care services (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s7702B/c"},"text":"section 7702B(c) of title 26","children":[],"tail":"). Such term shall not include any qualified small employer health reimbursement arrangement (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s9831/d/2"},"text":"section 9831(d)(2) of title 26","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb67eb03b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300bb–8/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered employee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “covered employee” means an individual who is (or was) provided coverage under a group health plan by virtue of the performance of services by the individual for 1 or more persons maintaining the plan (including as an employee defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s401/c/1"},"text":"section 401(c)(1) of title 26","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb67eb03c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300bb–8/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified beneficiary","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb67eb03d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300bb–8/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “qualified beneficiary” means, with respect to a covered employee under a group health plan, any other individual who, on the day before the qualifying event for that employee, is a beneficiary under the plan—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb67eb03e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300bb–8/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as the spouse of the covered employee, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb67eb03f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300bb–8/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as the dependent child of the employee.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Such term shall also include a child who is born to or placed for adoption with the covered employee during the period of continuation coverage under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb67eb040-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300bb–8/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule for terminations and reduced employment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a qualifying event described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300bb–3/2"},"text":"section 300bb–3(2) of this title","children":[],"tail":", the term “qualified beneficiary” includes the covered employee."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb67eb041-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300bb–8/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plan administrator","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “plan administrator” has the meaning given the term “administrator” by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1002/16/A"},"text":"section 1002(16)(A) of title 29","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb67eb042-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XXII, § 2208, as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/272/tX/s10003/a"},"text":