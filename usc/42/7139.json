{"tag":"section","attrib":{"id":"idbdf2305c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7139"},"text":null,"children":[{"tag":"num","attrib":{"value":"7139"},"text":"§ 7139.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of Science; establishment; appointment of Director; compensation; duties","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbdf2305d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7139/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There shall be within the Department an Office of Science to be headed by a Director, who shall be appointed by the President, by and with the advice and consent of the Senate, and who shall be compensated at the rate provided for level IV of the Executive Schedule under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5315"},"text":"section 5315 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdf2305e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7139/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties and responsibilities of Director","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It shall be the duty and responsibility of the Director—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbdf2305f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7139/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to advise the Secretary with respect to the physical research program transferred to the Department from the Energy Research and Development Administration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdf23060-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7139/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to monitor the Department’s energy research and development programs in order to advise the Secretary with respect to any undesirable duplication or gaps in such programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdf23061-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7139/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to advise the Secretary with respect to the well-being and management of the multipurpose laboratories under the jurisdiction of the Department, excluding laboratories that constitute part of the nuclear weapons complex;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdf23062-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7139/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to advise the Secretary with respect to education and training activities required for effective short- and long-term basic and applied research activities of the Department;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdf23063-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7139/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to advise the Secretary with respect to grants and other forms of financial assistance required for effective short- and long-term basic and applied research activities of the Department; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdf23064-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7139/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to carry out such additional duties assigned to the Office by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdf23065-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7139/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The mission of the Office of Science shall be the delivery of scientific discoveries, capabilities, and major scientific tools to transform the understanding of nature and to advance the energy, economic, and national security of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdf23066-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7139/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" User facilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall carry out the construction, operation, and maintenance of user facilities to support the mission described in subsection (c). As practicable, these facilities shall serve the needs of the Department, industry, the academic community, and other relevant entities for the purposes of advancing the missions of the Department, improving the competitiveness of the United States, protecting public health and safety, and addressing other national priorities including emergencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdf23067-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7139/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbdf23068-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7139/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbdf23069-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7139/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall ensure the coordination of the Office of Science with the other activities of the Department, including the transfer of knowledge, capabilities, and relevant technologies from basic research programs of the Department to applied research and development programs of the Department for the purpose of enabling development of mission-relevant technologies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbdf2306a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7139/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall support joint activities among the programs of the Department;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbdf2306b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7139/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall coordinate with other relevant Federal agencies operating under existing authorizations relating to subjects relating to the mission described in subsection (c) in supporting advancements in related research areas as appropriate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbdf2306c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7139/e/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may form partnerships to enhance the utilization of and ensure access to user facilities by other Federal agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdf2306d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7139/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of Science","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbdf2306e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7139/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall ensure the coordination of programs and activities carried out by the Office of Science; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbdf2306f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7139/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall direct all programs which have not recently completed a future planning roadmap consistent with the funding of such programs authorized under the Research and Development, Competition, and Innovation Act to complete such a roadmap.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbdf23070-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/91/tII/s209"},"text":"Pub. L. 95–91, title II, § 209","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-08-04"},"text":"Aug. 4, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/577"},"text":"91 Stat. 577","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/245/tIII/s309/a"},"text":"Pub. L. 105–245, title III, § 309(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1853"},"text":"112 Stat. 1853","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/58/tX/s1006/c/4"},"text":"Pub. L. 109–58, title X, § 1006(c)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/932"},"text":"119 Stat. 932","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/246/tIII/s302"},"text":"Pub. L. 115–246, title III, § 302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-09-28"},"text":"Sept. 28, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3140"},"text":"132 Stat. 3140","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/tI/s10101"},"text":"Pub. L. 117–167, div. B, title I, § 10101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1408"},"text":"136 Stat. 1408","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbdf23071-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbdf23072-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbdf23073-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Research and Development, Competition, and Innovation Act, referred to in subsec. (e)(2)(B), is div. B of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167"},"text":"Pub. L. 117–167","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1399"},"text":"136 Stat. 1399","children":[],"tail":", which enacted chapter 163 (§ 18901 et seq.) of this title and enacted, amended, and repealed numerous other sections and notes in the Code. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s18901"},"text":"section 18901 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbdf23074-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsecs. (d), (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167"},"text":"Pub. L. 117–167","children":[],"tail":" added subsecs. (d) and (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/246"},"text":"Pub. L. 115–246","children":[],"tail":" added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2005—Subsec. (b)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58"},"text":"Pub. L. 109–58","children":[],"tail":" added par. (6) and struck out former par. (6) which read as follows: “to carry out such additional duties assigned to the Office by the Secretary relating to basic and applied research, including but not limited to supervision or support of research activities carried out by any of the Assistant Secretaries designated by "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s7133"},"text":"section 7133 of this title","children":[],"tail":", as the Secretary considers advantageous.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/245"},"text":"Pub. L. 105–245","children":[],"tail":" substituted “Office of Science” for “Office of Energy Research” in section catchline and in subsec. (a)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbdf23075-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbdf23076-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Advisory Committees to the Office of Science","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/tI/s10113/f"},"text":"Pub. L. 117–167, div. B, title I, § 10113(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1468"},"text":"136 Stat. 1468","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/167/dB/tI/s10113/f"},"text":"“In order to improve the advice and guidance provided to the Office of Science, the Undersecretary for Science shall seek to ensure, to the maximum extent practicable, the robust participation of institutions of higher education (as defined in section 101 of the Higher Education Act of 1965 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"20 U.S.C. 1001","children":[],"tail":")) located in eligible jurisdictions (as defined in section 2203(b)(3)(A) of the Energy Policy Act of 1992 ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s13503/b/3/A"},"text":"42 U.S.C. 13503(b)(3)(A)","children":[],"tail":")) on the Office of Science Federal Advisory Committee.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
