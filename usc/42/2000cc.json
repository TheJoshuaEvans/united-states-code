{"tag":"section","attrib":{"id":"idbbc69ee9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000cc"},"text":null,"children":[{"tag":"num","attrib":{"value":"2000cc"},"text":"§ 2000cc.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protection of land use as religious exercise","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbbc69eea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000cc/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Substantial burdens","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbbc69eeb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000cc/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No government shall impose or implement a land use regulation in a manner that imposes a substantial burden on the religious exercise of a person, including a religious assembly or institution, unless the government demonstrates that imposition of the burden on that person, assembly, or institution—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbbc69eec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000cc/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is in furtherance of a compelling governmental interest; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbbc69eed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000cc/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is the least restrictive means of furthering that compelling governmental interest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbc69eee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000cc/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scope of application","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"This subsection applies in any case in which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbbc69eef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000cc/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the substantial burden is imposed in a program or activity that receives Federal financial assistance, even if the burden results from a rule of general applicability;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbbc69ef0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000cc/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the substantial burden affects, or removal of that substantial burden would affect, commerce with foreign nations, among the several States, or with Indian tribes, even if the burden results from a rule of general applicability; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbbc69ef1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000cc/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the substantial burden is imposed in the implementation of a land use regulation or system of land use regulations, under which a government makes, or has in place formal or informal procedures or practices that permit the government to make, individualized assessments of the proposed uses for the property involved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbbc69ef2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000cc/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Discrimination and exclusion","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbbc69ef3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000cc/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Equal terms","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No government shall impose or implement a land use regulation in a manner that treats a religious assembly or institution on less than equal terms with a nonreligious assembly or institution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbc69ef4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000cc/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nondiscrimination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No government shall impose or implement a land use regulation that discriminates against any assembly or institution on the basis of religion or religious denomination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbc69ef5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000cc/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusions and limits","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No government shall impose or implement a land use regulation that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbbc69ef6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000cc/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" totally excludes religious assemblies from a jurisdiction; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbbc8e7e7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000cc/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" unreasonably limits religious assemblies, institutions, or structures within a jurisdiction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbbc8e7e8-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/274/s2"},"text":"Pub. L. 106–274, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-09-22"},"text":"Sept. 22, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/803"},"text":"114 Stat. 803","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbbc8e7e9-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbbc8e7ea-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"idbbc8e7eb-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/274/s1"},"text":"Pub. L. 106–274, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-09-22"},"text":"Sept. 22, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/803"},"text":"114 Stat. 803","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/274/s1"},"text":"“This Act [enacting this chapter and amending sections 1988, 2000bb–2 and 2000bb–3 of this title] may be cited as the ‘Religious Land Use and Institutionalized Persons Act of 2000’ ”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
