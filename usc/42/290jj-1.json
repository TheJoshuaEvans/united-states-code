{"tag":"section","attrib":{"id":"idb5c7208f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290jj–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"290jj–1"},"text":"§ 290jj–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting requirement","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Each facility to which this part applies shall notify the appropriate State licensing or regulatory agency, as determined by the Secretary—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5c72090-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290jj–1/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of each death that occurs at each such facility. A notification under this section shall include the name of the resident and shall be provided not later than 24 hours after the time of the individuals ","children":[{"tag":"ref","attrib":{"idref":"fn002251"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002251"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “individual’s”."}],"tail":" death; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5c72091-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290jj–1/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of the use of seclusion or restraints in accordance with regulations promulgated by the Secretary, in consultation with the States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5c72092-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title V, § 595A, as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/310/dB/tXXXII/s3208"},"text":"Pub. L. 106–310, div. B, title XXXII, § 3208","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-17"},"text":"Oct. 17, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1199"},"text":"114 Stat. 1199","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
