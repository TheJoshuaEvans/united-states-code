{"tag":"section","attrib":{"id":"idb57aadf1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285o–4"},"text":null,"children":[{"tag":"num","attrib":{"value":"285o–4"},"text":"§ 285o–4.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Medication Development Program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb57aadf2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285o–4/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is established in the Institute a Medication Development Program through which the Director of such Institute shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb57aadf3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285o–4/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct periodic meetings with the Commissioner of Food and Drugs to discuss measures that may facilitate the approval process of drug abuse treatments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb57aadf4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285o–4/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage and promote (through grants, contracts, international collaboration, or otherwise) expanded research programs, investigations, experiments, community trials, and studies, into the development and use of medications to treat drug addiction;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb57aadf5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285o–4/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish or provide for the establishment of research facilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb57aadf6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285o–4/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" report on the activities of other relevant agencies relating to the development and use of pharmacotherapeutic treatments for drug addiction;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb57aadf7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285o–4/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collect, analyze, and disseminate data useful in the development and use of pharmacotherapeutic treatments for drug addiction and collect, catalog, analyze, and disseminate through international channels, the results of such research;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb57aadf8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285o–4/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" directly or through grants, contracts, or cooperative agreements, support training in the fundamental sciences and clinical disciplines related to the pharmacotherapeutic treatment of drug abuse, including the use of training stipends, fellowships, and awards where appropriate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb57aadf9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285o–4/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate the activities conducted under this section with related activities conducted within the National Institute on Alcohol Abuse and Alcoholism, the National Institute of Mental Health, and other appropriate institutes and shall consult with the Directors of such Institutes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb57aadfa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285o–4/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the activities described in subsection (a), the Director of the Institute—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb57aadfb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285o–4/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall collect and disseminate through publications and other appropriate means, information pertaining to the research and other activities under this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb57aadfc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285o–4/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall make grants to or enter into contracts and cooperative agreements with individuals and public and private entities to further the goals of the program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb57aadfd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285o–4/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may, in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s289e"},"text":"section 289e of this title","children":[],"tail":", and in consultation with the National Advisory Council on Drug Abuse, acquire, construct, improve, repair, operate, and maintain pharmacotherapeutic research centers, laboratories, and other necessary facilities and equipment, and such other real or personal property as the Director determines necessary, and may, in consultation with such Advisory Council, make grants for the construction or renovation of facilities to carry out the purposes of this section;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb57aadfe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285o–4/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may accept voluntary and uncompensated services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb57aadff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285o–4/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may accept gifts, or donations of services, money, or property, real, personal, or mixed, tangible or intangible; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb57aae00-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285o–4/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall take necessary action to ensure that all channels for the dissemination and exchange of scientific knowledge and information are maintained between the Institute and the other scientific, medical, and biomedical disciplines and organizations nationally and internationally.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb57aae01-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285o–4/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb57aae02-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285o–4/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"1992-12-31"},"text":"December 31, 1992","children":[],"tail":", and each December 31 thereafter, the Director of the Institute shall submit to the Office of National Drug Control Policy established under section 1501 "},{"tag":"ref","attrib":{"idref":"fn002202"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002202"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of title 21 a report, in accordance with paragraph (3), that describes the objectives and activities of the program assisted under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb57aae03-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285o–4/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Drug Control Strategy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of National Drug Control Policy shall incorporate, by reference or otherwise, each report submitted under this subsection in the National Drug Control Strategy submitted the following February 1 under section 1504 ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of title 21."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb57aae04-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285o–4/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Pharmacotherapeutics” defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “pharmacotherapeutics” means medications used to treat the symptoms and disease of drug abuse, including medications to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb57aae05-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285o–4/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" block the effects of abused drugs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb57aae06-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285o–4/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reduce the craving for abused drugs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb57aae07-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285o–4/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" moderate or eliminate withdrawal symptoms;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb57aae08-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285o–4/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" block or reverse the toxic effect of abused drugs; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb57aae09-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285o–4/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prevent relapse in persons who have been detoxified from drugs of abuse.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb57aae0a-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title IV, § 464P, as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/321/tI/s123/b"},"text":"Pub. L. 102–321, title I, § 123(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-10"},"text":"July 10, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/362"},"text":"106 Stat. 362","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/43/tXX/s2008/b/10"},"text":"Pub. L. 103–43, title XX, § 2008(b)(10)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-06-10"},"text":"June 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/211"},"text":"107 Stat. 211","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/482/tI/s103/b/35"},"text":"Pub. L. 109–482, title I, § 103(b)(35)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-01-15"},"text":"Jan. 15, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3688"},"text":"120 Stat. 3688","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb57aae0b-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb57aae0c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb57aae0d-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Sections 1501 and 1504 of title 21, referred to in subsec. (c), were repealed by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690/tI/s1009"},"text":"Pub. L. 100–690, title I, § 1009","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4188"},"text":"102 Stat. 4188","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb57aae0e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2007—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/482"},"text":"Pub. L. 109–482","children":[],"tail":" struck out heading and text of subsec. (e). Text read as follows: “For the purpose of carrying out this section, there are authorized to be appropriated $85,000,000 for fiscal year 1993, and $95,000,000 for fiscal year 1994.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (b)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/43"},"text":"Pub. L. 103–43","children":[],"tail":" substituted “Institute” for “Administration”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb57aae0f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb57aae10-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2007 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/482"},"text":"Pub. L. 109–482","children":[],"tail":" applicable only with respect to amounts appropriated for fiscal year 2007 or subsequent fiscal years, see "},{"tag":"ref","attrib":{"href":"/us/pl/109/482/s109"},"text":"section 109 of Pub. L. 109–482","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s281"},"text":"section 281 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb57aae11-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1992-10-01"},"text":"Oct. 1, 1992","children":[],"tail":", with provision for programs providing financial assistance, see section 801(c), (d) of "},{"tag":"ref","attrib":{"href":"/us/pl/102/321"},"text":"Pub. L. 102–321","children":[],"tail":", set out as an Effective Date of 1992 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s236"},"text":"section 236 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb57aae12-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Report by Institute on Medicine","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/321/tVII/s701"},"text":"Pub. L. 102–321, title VII, § 701","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-10"},"text":"July 10, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/436"},"text":"106 Stat. 436","children":[],"tail":", directed Secretary of Health and Human Services to enter into a contract with a public or nonprofit private entity to conduct a study concerning (1) role of the private sector in development of anti-addiction medications, including legislative proposals designed to encourage private sector development of such medications, (2) process by which anti-addiction medications receive marketing approval from Food and Drug Administration, including an assessment of feasibility of expediting marketing approval process in a manner consistent with maintaining safety and effectiveness of such medications, (3) with respect to pharmacotherapeutic treatments for drug addiction (A) recommendations with respect to a national strategy for developing such treatments and improvements in such strategy, (B) state of the scientific knowledge concerning such treatments, and (C) assessment of progress toward development of safe, effective pharmacological treatments for drug addiction, and (4) other related information determined appropriate by the authors of the study, and to submit to Congress a report of the results of such study not later than 18 months after "},{"tag":"date","attrib":{"date":"1992-07-10"},"text":"July 10, 1992","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
