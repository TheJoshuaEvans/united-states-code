{"tag":"section","attrib":{"id":"idb54b12a4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280j"},"text":null,"children":[{"tag":"num","attrib":{"value":"280j"},"text":"§ 280j.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National strategy for quality improvement in health care","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb54b12a5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280j/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of national strategy and priorities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb54b12a6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280j/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National strategy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, through a transparent collaborative process, shall establish a national strategy to improve the delivery of health care services, patient health outcomes, and population health.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb54b12a7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280j/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Identification of priorities","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb54b12a8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280j/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall identify national priorities for improvement in developing the strategy under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb54b12a9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280j/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall ensure that priorities identified under subparagraph (A) will—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb54b12aa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280j/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have the greatest potential for improving the health outcomes, efficiency, and patient-centeredness of health care for all populations, including children and vulnerable populations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb54b12ab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280j/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify areas in the delivery of health care services that have the potential for rapid improvement in the quality and efficiency of patient care;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb54b12ac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280j/a/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" address gaps in quality, efficiency, comparative effectiveness information (taking into consideration the limitations set forth in subsections (c) and (d) of section 1182 of the Social Security Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320e–1/c"},"text":"42 U.S.C. 1320e–1(c)","children":[],"tail":", (d)]), and health outcomes measures and data aggregation techniques;"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb54b12ad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280j/a/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve Federal payment policy to emphasize quality and efficiency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb54b12ae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280j/a/2/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhance the use of health care data to improve quality, efficiency, transparency, and outcomes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb54b12af-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280j/a/2/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" address the health care provided to patients with high-cost chronic diseases;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb54b12b0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280j/a/2/B/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve research and dissemination of strategies and best practices to improve patient safety and reduce medical errors, preventable admissions and readmissions, and health care-associated infections;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb54b12b1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280j/a/2/B/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reduce health disparities across health disparity populations (as defined in section 285t ","children":[{"tag":"ref","attrib":{"idref":"fn002156"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002156"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title) and geographic areas; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb54b12b2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280j/a/2/B/ix"},"text":null,"children":[{"tag":"num","attrib":{"value":"ix"},"text":"(ix)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" address other areas as determined appropriate by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb54b12b3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280j/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Considerations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In identifying priorities under subparagraph (A), the Secretary shall take into consideration the recommendations submitted by the entity with a contract under section 1890(a) of the Social Security Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395aaa/a"},"text":"42 U.S.C. 1395aaa(a)","children":[],"tail":"] and other stakeholders."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb54b12b4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280j/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with State agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall collaborate, coordinate, and consult with State agencies responsible for administering the Medicaid program under title XIX of the Social Security Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1396"},"text":"42 U.S.C. 1396","children":[],"tail":" et seq.] and the Children’s Health Insurance Program under title XXI of such Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1397aa"},"text":"42 U.S.C. 1397aa","children":[],"tail":" et seq.] with respect to developing and disseminating strategies, goals, models, and timetables that are consistent with the national priorities identified under subparagraph (A)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb54b12b5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280j/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Strategic plan","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb54b12b6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280j/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The national strategy shall include a comprehensive strategic plan to achieve the priorities described in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb54b12b7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280j/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The strategic plan shall include provisions for addressing, at a minimum, the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb54b12b8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280j/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Coordination among agencies within the Department, which shall include steps to minimize duplication of efforts and utilization of common quality measures, where available. Such common quality measures shall be measures identified by the Secretary under section 1139A or 1139B of the Social Security Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320b–9a"},"text":"42 U.S.C. 1320b–9a","children":[],"tail":", 1320b–9b] or endorsed under section 1890 of such Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395aaa"},"text":"42 U.S.C. 1395aaa","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb54b12b9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280j/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Agency-specific strategic plans to achieve national priorities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb54b12ba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280j/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Establishment of annual benchmarks for each relevant agency to achieve national priorities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb54b12bb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280j/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A process for regular reporting by the agencies to the Secretary on the implementation of the strategic plan.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb54b12bc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280j/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Strategies to align public and private payers with regard to quality and patient safety efforts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb54b12bd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280j/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Incorporating quality improvement and measurement in the strategic plan for health information technology required by the American Recovery and Reinvestment Act of 2009 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/5"},"text":"Public Law 111–5","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb54b12be-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280j/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Periodic update of national strategy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall update the national strategy not less than annually. Any such update shall include a review of short- and long-term goals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb54b12bf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280j/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission and availability of national strategy and updates","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb54b12c0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280j/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deadline for initial submission of national strategy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2011-01-01"},"text":"January 1, 2011","children":[],"tail":", the Secretary shall submit to the relevant committees of Congress the national strategy described in subsection (a)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb54b12c1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280j/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Updates","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb54b12c2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280j/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall submit to the relevant committees of Congress an annual update to the strategy described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb54b12c3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280j/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information submitted","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each update submitted under subparagraph (A) shall include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb54b12c4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280j/d/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a review of the short- and long-term goals of the national strategy and any gaps in such strategy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb54b12c5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280j/d/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an analysis of the progress, or lack of progress, in meeting such goals and any barriers to such progress;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb54b12c6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280j/d/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the information reported under section 1139A of the Social Security Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320b–9a"},"text":"42 U.S.C. 1320b–9a","children":[],"tail":"], consistent with the reporting requirements of such section; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb54b12c7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280j/d/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an update required to be submitted on or after ","children":[{"tag":"date","attrib":{"date":"2014-01-01"},"text":"January 1, 2014","children":[],"tail":", the information reported under section 1139B(b)(4) of the Social Security Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320b–9b/b/4"},"text":"42 U.S.C. 1320b–9b(b)(4)","children":[],"tail":"], consistent with the reporting requirements of such section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb54b12c8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280j/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Satisfaction of other reporting requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Compliance with the requirements of clauses (iii) and (iv) of subparagraph (B) shall satisfy the reporting requirements under sections 1139A(a)(6) and 1139B(b)(4), respectively, of the Social Security Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320b–9a/a/6"},"text":"42 U.S.C. 1320b–9a(a)(6)","children":[],"tail":", 1320b–9b(b)(4)]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb54b12c9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280j/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Health care quality Internet website","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2011-01-01"},"text":"January 1, 2011","children":[],"tail":", the Secretary shall create an Internet website to make public information regarding—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb54b12ca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280j/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the national priorities for health care quality improvement established under subsection (a)(2);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb54b12cb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280j/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the agency-specific strategic plans for health care quality described in subsection (b)(2)(B); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb54b12cc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280j/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other information, as the Secretary determines to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb54b12cd-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title III, § 399HH, as added and amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tIII/s3011"},"text":"Pub. L. 111–148, title III, § 3011","children":[],"tail":", title X, § 10302, "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/378"},"text":"124 Stat. 378","children":[],"tail":", 937.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb54b12ce-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb54b12cf-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb54b12d0-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s285t"},"text":"Section 285t of this title","children":[],"tail":", referred to in subsec. (a)(2)(B)(viii), was in the original “section 485E”, meaning section 485E of "},{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"act July 1, 1944, ch. 373","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/106/525/s101/a"},"text":"section 101(a) of Pub. L. 106–525","children":[],"tail":", which was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s287c–31"},"text":"section 287c–31 of this title","children":[],"tail":". Section 485E of act "},{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", was renumbered section 464z–3 by "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tX/s10334/c/1/D/i"},"text":"Pub. L. 111–148, title X, § 10334(c)(1)(D)(i)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/973"},"text":"124 Stat. 973","children":[],"tail":", and transferred to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s285t"},"text":"section 285t of this title","children":[],"tail":". The act "},{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", no longer contains a section 485E."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Social Security Act, referred to in subsec. (a)(2)(D), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"act Aug. 14, 1935, ch. 531","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/620"},"text":"49 Stat. 620","children":[],"tail":". Titles XIX and XXI of the Act are classified generally to subchapters XIX (§ 1396 et seq.) and XXI (§ 1397aa et seq.), respectively, of chapter 7 of this title. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1305"},"text":"section 1305 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The American Recovery and Reinvestment Act of 2009, referred to in subsec. (b)(2)(F), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/5"},"text":"Pub. L. 111–5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-02-17"},"text":"Feb. 17, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/115"},"text":"123 Stat. 115","children":[],"tail":". For complete classification of this Act to the Code, see Short Title of 2009 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1"},"text":"section 1 of Title 26","children":[],"tail":", Internal Revenue Code, and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb54b12d1-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (a)(2)(B)(iii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/s10302"},"text":"Pub. L. 111–148, § 10302","children":[],"tail":", inserted “(taking into consideration the limitations set forth in subsections (c) and (d) of section 1182 of the Social Security Act)” after “information”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb54b12d2-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb54b12d3-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Interagency Working Group on Health Care Quality","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/tIII/s3012"},"text":"Pub. L. 111–148, title III, § 3012","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/380"},"text":"124 Stat. 380","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/148/tIII/s3012"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The President shall convene a working group to be known as the Interagency Working Group on Health Care Quality (referred to in this section as the ‘Working Group’).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Goals","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The goals of the Working Group shall be to achieve the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Collaboration, cooperation, and consultation between Federal departments and agencies with respect to developing and disseminating strategies, goals, models, and timetables that are consistent with the national priorities identified under section 399HH(a)(2) of the Public Health Service Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s280j/a/2"},"text":"42 U.S.C. 280j(a)(2)","children":[],"tail":"] (as added by section 3011 [of "},{"tag":"ref","attrib":{"href":"/us/pl/111/148"},"text":"Pub. L. 111–148","children":[],"tail":"])."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Avoidance of inefficient duplication of quality improvement efforts and resources, where practicable, and a streamlined process for quality reporting and compliance requirements.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Assess alignment of quality efforts in the public sector with private sector initiatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Composition.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Working Group shall be composed of senior level representatives of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of Health and Human Services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Centers for Medicare & Medicaid Services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Institutes of Health;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"“(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Centers for Disease Control and Prevention;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"“(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Food and Drug Administration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"“(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Health Resources and Services Administration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"“(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Agency for Healthcare Research and Quality;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"“(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Office of the National Coordinator for Health Information Technology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"“(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Substance Abuse and Mental Health Services Administration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"“(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Administration for Children and Familie