ren":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"S"},"text":"“(S)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States Office of Personnel Management;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"T"},"text":"“(T)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of Defense;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"U"},"text":"“(U)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of Education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"“(V)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of Veterans Affairs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"W"},"text":"“(W)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Veterans Health Administration; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"X"},"text":"“(X)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other Federal agencies and departments with activities relating to improving health care quality and safety, as determined by the President.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Chair and vice-chair.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Chair","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Working Group shall be chaired by the Secretary of Health and Human Services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Vice chair","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Members of the Working Group, other than the Secretary of Health and Human Services, shall serve as Vice Chair of the Group on a rotating basis, as determined by the Group.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report to Congress","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2010-12-31"},"text":"December 31, 2010","children":[],"tail":", and annually thereafter, the Working Group shall submit to the relevant Committees of Congress, and make public on an Internet website, a report describing the progress and recommendations of the Working Group in meeting the goals described in subsection (b).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
