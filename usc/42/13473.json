{"tag":"section","attrib":{"id":"idbfc32119-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13473"},"text":null,"children":[{"tag":"num","attrib":{"value":"13473"},"text":"§ 13473.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civilian nuclear waste","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfc3211a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13473/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall conduct a study of the potential for minimizing the volume and toxic lifetime of nuclear waste, including an analysis of the viability of existing technologies and an assessment of the extent of research and development required for new technologies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfc3211b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13473/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Based on the results of the study required under subsection (a), the Secretary shall prepare and submit to Congress a 5-year program plan for carrying out a program of research and development on new technologies for minimizing the volume and toxic lifetime of, and thereby mitigating hazards associated with, nuclear waste.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfc3211c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13473/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to the Secretary for carrying out this section $4,700,000 for fiscal year 1993 and such sums as may be necessary for fiscal year 1994.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfc3211d-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/tXXI/s2113"},"text":"Pub. L. 102–486, title XXI, § 2113","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3073"},"text":"106 Stat. 3073","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
