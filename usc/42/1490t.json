out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1441"},"text":"section 1441 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
