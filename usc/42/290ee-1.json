{"tag":"section","attrib":{"id":"idb5bd8376-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"290ee–1"},"text":"§ 290ee–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" First responder training","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5bd8377-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program authorized","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall make grants to States, local governmental entities, and Indian Tribes and Tribal organizations (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304"},"text":"section 5304 of title 25","children":[],"tail":") to allow first responders and members of other key community sectors to administer a drug or device approved, cleared, or otherwise legally marketed under the Federal Food, Drug, and Cosmetic Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t21/s301"},"text":"21 U.S.C. 301","children":[],"tail":" et seq.] for emergency treatment of known or suspected overdose."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5bd8378-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5bd8379-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–1/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An entity seeking a grant under this section shall submit an application to the Secretary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5bd837a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–1/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that meets the criteria under paragraph (2); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5bd837b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–1/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at such time, in such manner, and accompanied by such information as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5bd837c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–1/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An entity, in submitting an application under paragraph (1), shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5bd837d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–1/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describe the evidence-based methodology and outcome measurements that will be used to evaluate the program funded with a grant under this section, and specifically explain how such measurements will provide valid measures of the impact of the program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5bd837e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–1/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describe how the program could be broadly replicated if demonstrated to be effective;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5bd837f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–1/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify the governmental and community agencies with which the entity will coordinate to implement the program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5bd8380-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–1/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describe how the entity will ensure that law enforcement agencies will coordinate with their corresponding State substance abuse and mental health agencies to identify protocols and resources that are available to overdose victims and families, including information on treatment and recovery resources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5bd8381-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An entity shall use a grant received under this section to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5bd8382-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–1/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make a drug or device approved, cleared, or otherwise legally marketed under the Federal Food, Drug, and Cosmetic Act for emergency treatment of known or suspected overdose available to be carried and administered by first responders and members of other key community sectors;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5bd8383-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–1/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" train and provide resources for first responders and members of other key community sectors on carrying and administering a drug or device approved, cleared, or otherwise legally marketed under the Federal Food, Drug, and Cosmetic Act for emergency treatment of known or suspected overdose;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5bd8384-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–1/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish processes, protocols, and mechanisms for referral to appropriate treatment, which may include an outreach coordinator or team to connect individuals receiving overdose reversal drugs to followup services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5bd8385-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–1/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" train and provide resources for first responders and members of other key community sectors on safety around fentanyl, carfentanil, and other dangerous licit and illicit drugs to protect themselves from exposure to such drugs and respond appropriately when exposure occurs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5bd8386-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–1/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall make a grant for the purpose of providing technical assistance and training on the use of a drug or device approved, cleared, or otherwise legally marketed under the Federal Food, Drug, and Cosmetic Act for emergency treatment of known or suspected overdose, mechanisms for referral to appropriate treatment, and safety around fentanyl, carfentanil, and other dangerous licit and illicit drugs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5bd8387-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–1/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Geographic distribution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In making grants under this section, the Secretary shall ensure that not less than 20 percent of grant funds are awarded to eligible entities that are not located in metropolitan statistical areas (as defined by the Office of Management and Budget). The Secretary shall take into account the unique needs of rural communities, including communities with an incidence of individuals with opioid use disorder that is above the national average and communities with a shortage of prevention and treatment services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5bd8388-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–1/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall conduct an evaluation of grants made under this section to determine—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5bd8389-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–1/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of first responders and members of other key community sectors equipped with a drug or device approved, cleared, or otherwise legally marketed under the Federal Food, Drug, and Cosmetic Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s301"},"text":"21 U.S.C. 301","children":[],"tail":" et seq.] for emergency treatment of known or suspected overdose;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5bd838a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–1/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of opioid, heroin, and other drug overdoses reversed by first responders and members of other key community sectors receiving training and supplies of a drug or device approved, cleared, or otherwise legally marketed under the Federal Food, Drug, and Cosmetic Act for emergency treatment of known or suspected overdose, through a grant received under this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5bd838b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–1/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of responses to requests for services by the entity or subgrantee, to overdose;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5bd838c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–1/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which overdose victims and families receive information about treatment services and available data describing treatment admissions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5bd838d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–1/f/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of first responders and members of other key community sectors trained on safety around fentanyl, carfentanil, and other dangerous licit and illicit drugs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5bd838e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–1/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other key community sectors","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “other key community sectors” includes substance use disorder treatment providers, emergency medical services agencies, agencies and organizations working with prison and jail populations and offender reentry programs, health care providers, harm reduction groups, pharmacies, community health centers, tribal health facilities, and mental health providers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5bd838f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–1/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To carry out this section, there are authorized to be appropriated $57,000,000 for each of fiscal years 2026 through 2030.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5bd8390-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title V, § 546, as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/198/tII/s202"},"text":"Pub. L. 114–198, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-07-22"},"text":"July 22, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/715"},"text":"130 Stat. 715","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/271/tVII/s7002"},"text":"Pub. L. 115–271, title VII, § 7002","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-24"},"text":"Oct. 24, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4007"},"text":"132 Stat. 4007","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/44/tI/s106"},"text":"Pub. L. 119–44, title I, § 106","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-01"},"text":"Dec. 1, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/674"},"text":"139 Stat. 674","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb5bd8391-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb5bd8392-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb5bd8393-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Food, Drug, and Cosmetic Act, referred to in subsecs. (a), (c)(1), (2), (d), and (f)(1), (2), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch675"},"text":"act June 25, 1938, ch. 675","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/52/1040"},"text":"52 Stat. 1040","children":[],"tail":", which is classified generally to chapter 9 (§ 301 et seq.) of Title 21, Food and Drugs. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s301"},"text":"section 301 of Title 21","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb5bd8394-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 290ee–1, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373/tV/s546"},"text":"act July 1, 1944, ch. 373, title V, § 546","children":[],"tail":", formerly "},{"tag":"ref","attrib":{"href":"/us/pl/92/255/tIV/s413"},"text":"Pub. L. 92–255, title IV, § 413","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-03-21"},"text":"Mar. 21, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/84"},"text":"86 Stat. 84","children":[],"tail":", as amended "},{"tag":"ref","attrib":{"href":"/us/pl/96/181/s8/a"},"text":"Pub. L. 96–181, § 8(a)","children":[],"tail":", (b)(1), "},{"tag":"date","attrib":{"date":"1980-01-02"},"text":"Jan. 2, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/1313"},"text":"93 Stat. 1313","children":[],"tail":", 1314; "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tIX/s973/e"},"text":"Pub. L. 97–35, title IX, § 973(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/598"},"text":"95 Stat. 598","children":[],"tail":"; renumbered § 525 of act "},{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", and amended "},{"tag":"date","attrib":{"date":"1983-04-26"},"text":"Apr. 26, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/98/24/s2/b/16/A"},"text":"Pub. L. 98–24, § 2(b)(16)(A)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/182"},"text":"97 Stat. 182","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/99/570/tVI/s6002/b/2"},"text":"Pub. L. 99–570, title VI, § 6002(b)(2)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3207-159"},"text":"100 Stat. 3207–159","children":[],"tail":"; renumbered § 546, "},{"tag":"date","attrib":{"date":"1987-07-22"},"text":"July 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/100/77/tVI/s611/2"},"text":"Pub. L. 100–77, title VI, § 611(2)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/516"},"text":"101 Stat. 516","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1988-11-04"},"text":"Nov. 4, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/100/607/tVIII/s813/4"},"text":"Pub. L. 100–607, title VIII, § 813(4)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3171"},"text":"102 Stat. 3171","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1988-11-07"},"text":"Nov. 7, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/100/628/tVI/s613/4"},"text":"Pub. L. 100–628, title VI, § 613(4)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3243"},"text":"102 Stat. 3243","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1989-08-16"},"text":"Aug. 16, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/101/93/s5/t/1"},"text":"Pub. L. 101–93, § 5(t)(1)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/615"},"text":"103 Stat. 615","children":[],"tail":", which related to drug abuse among government and other employees, was omitted in the general revision of this part by "},{"tag":"ref","attrib":{"href":"/us/pl/102/321"},"text":"Pub. L. 102–321","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb5bd8395-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/44/s106/1"},"text":"Pub. L. 119–44, § 106(1)","children":[],"tail":", (2), substituted “Tribes and Tribal” for “tribes and tribal” and “approved, cleared, or otherwise legally marketed” for “approved or cleared” and struck out “opioid” before “overdose”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/44/s106/2"},"text":"Pub. L. 119–44, § 106(2)","children":[],"tail":", wherever appearing, substituted “approved, cleared, or otherwise legally marketed” for “approved or cleared” and struck out “opioid” before “overdose”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/44/s106/3/A"},"text":"Pub. L. 119–44, § 106(3)(A)","children":[],"tail":", (B), substituted “approved, cleared, or otherwise legally marketed” for “approved or cleared” and struck out “opioid” before “overdose”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/44/s106/3/A"},"text":"Pub. L. 119–44, § 106(3)(A)","children":[],"tail":", (C), substituted “opioid, heroin, and other drug” for “opioid and heroin”, “approved, cleared, or otherwise legally marketed” for “approved or cleared”, and “overdose” for “opioid overdose”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/44/s106/3/D"},"text":"Pub. L. 119–44, § 106(3)(D)","children":[],"tail":", struck out “opioid and heroin” before “overdose”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/44/s106/4"},"text":"Pub. L. 119–44, § 106(4)","children":[],"tail":", substituted “$57,000,000 for each of fiscal years 2026 through 2030” for “$36,000,000 for each of fiscal years 2019 through 2023”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (c)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/271/s7002/1"},"text":"Pub. L. 115–271, § 7002(1)","children":[],"tail":", added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/271/s7002/2"},"text":"Pub. L. 115–271, § 7002(2)","children":[],"tail":", substituted “mechanisms for referral to appropriate treatment, and safety around fentanyl, carfentanil, and other dangerous licit and illicit drugs” for “and mechanisms for referral to appropriate treatment for an entity receiving a grant under this section”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/271/s7002/3"},"text":"Pub. L. 115–271, § 7002(3)","children":[],"tail":", added par. (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/271/s7002/5"},"text":"Pub. L. 115–271, § 7002(5)","children":[],"tail":", added subsec. (g). Former subsec. (g) redesignated (h)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/271/s7002/4"},"text":"Pub. L. 115–271, § 7002(4)","children":[],"tail":", (6), redesignated subsec. (g) as (h) and substituted “$36,000,000 for each of fiscal years 2019 through 2023” for “$12,000,000 for each of fiscal years 2017 through 2021”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
