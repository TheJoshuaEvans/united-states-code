{"tag":"section","attrib":{"id":"idb639912c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300i–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"300i–1"},"text":"§ 300i–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tampering with public water systems","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb639912d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300i–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tampering","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person who tampers with a public water system shall be imprisoned for not more than 20 years, or fined in accordance with title 18, or both.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb639912e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300i–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Attempt or threat","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person who attempts to tamper, or makes a threat to tamper, with a public drinking water system be imprisoned for not more than 10 years, or fined in accordance with title 18, or both.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb639912f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300i–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil penalty","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator may bring a civil action in the appropriate United States district court (as determined under the provisions of title 28) against any person who tampers, attempts to tamper, or makes a threat to tamper with a public water system. The court may impose on such person a civil penalty of not more than $1,000,000 for such tampering or not more than $100,000 for such attempt or threat.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6399130-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300i–1/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Tamper” defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “tamper” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6399131-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300i–1/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to introduce a contaminant into a public water system with the intention of harming persons; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6399132-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300i–1/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to otherwise interfere with the operation of a public water system with the intention of harming persons.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb6399133-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XIV, § 1432, as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/339/tI/s108"},"text":"Pub. L. 99–339, title I, § 108","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-06-19"},"text":"June 19, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/651"},"text":"100 Stat. 651","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/182/tV/s501/f/5"},"text":"Pub. L. 104–182, title V, § 501(f)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-06"},"text":"Aug. 6, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1692"},"text":"110 Stat. 1692","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/188/tIV/s403/3"},"text":"Pub. L. 107–188, title IV, § 403(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-06-12"},"text":"June 12, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/687"},"text":"116 Stat. 687","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb6399134-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb6399135-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb6399136-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/188/s403/3/A"},"text":"Pub. L. 107–188, § 403(3)(A)","children":[],"tail":", substituted “20 years” for “5 years”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/188/s403/3/B"},"text":"Pub. L. 107–188, § 403(3)(B)","children":[],"tail":", substituted “10 years” for “3 years”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/188/s403/3/C"},"text":"Pub. L. 107–188, § 403(3)(C)","children":[],"tail":", (D), substituted “$1,000,000” for “$50,000” and “$100,000” for “$20,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/182"},"text":"Pub. L. 104–182","children":[],"tail":" made technical amendment to section catchline and subsec. (a) designation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
