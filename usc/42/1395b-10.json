{"tag":"section","attrib":{"id":"idb8924e13-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395b–10"},"text":null,"children":[{"tag":"num","attrib":{"value":"1395b–10"},"text":"§ 1395b–10.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Addressing health care disparities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8924e14-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395b–10/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluating data collection approaches","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall evaluate approaches for the collection of data under this subchapter, to be performed in conjunction with existing quality reporting requirements and programs under this subchapter, that allow for the ongoing, accurate, and timely collection and evaluation of data on disparities in health care services and performance on the basis of race, ethnicity, and gender. In conducting such evaluation, the Secretary shall consider the following objectives:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8924e15-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395b–10/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Protecting patient privacy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8924e16-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395b–10/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Minimizing the administrative burdens of data collection and reporting on providers and health plans participating under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8924e17-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395b–10/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Improving Medicare program data on race, ethnicity, and gender.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8924e18-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395b–10/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports to Congress","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8924e19-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395b–10/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report on evaluation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 18 months after ","children":[{"tag":"date","attrib":{"date":"2008-07-15"},"text":"July 15, 2008","children":[],"tail":", the Secretary shall submit to Congress a report on the evaluation conducted under subsection (a). Such report shall, taking into consideration the results of such evaluation—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8924e1a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395b–10/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify approaches (including defining methodologies) for identifying and collecting and evaluating data on health care disparities on the basis of race, ethnicity, and gender for the original Medicare fee-for-service program under parts A and B, the Medicare Advantage program under part C, and the Medicare prescription drug program under part D; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8924e1b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395b–10/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include recommendations on the most effective strategies and approaches to reporting HEDIS quality measures as required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395w–22/e/3"},"text":"section 1395w–22(e)(3) of this title","children":[],"tail":" and other nationally recognized quality performance measures, as appropriate, on the basis of race, ethnicity, and gender."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8924e1c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395b–10/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports on data analyses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 4 years after ","children":[{"tag":"date","attrib":{"date":"2008-07-15"},"text":"July 15, 2008","children":[],"tail":", and 4 years thereafter, the Secretary shall submit to Congress a report that includes recommendations for improving the identification of health care disparities for Medicare beneficiaries based on analyses of the data collected under subsection (c)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8924e1d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395b–10/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementing effective approaches","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 24 months after ","children":[{"tag":"date","attrib":{"date":"2008-07-15"},"text":"July 15, 2008","children":[],"tail":", the Secretary shall implement the approaches identified in the report submitted under subsection (b)(1) for the ongoing, accurate, and timely collection and evaluation of data on health care disparities on the basis of race, ethnicity, and gender."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8924e1e-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title XVIII, § 1809, as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/275/tI/s185"},"text":"Pub. L. 110–275, title I, § 185","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-07-15"},"text":"July 15, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2587"},"text":"122 Stat. 2587","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
