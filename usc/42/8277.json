{"tag":"section","attrib":{"id":"idbe8d3854-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8277"},"text":null,"children":[{"tag":"num","attrib":{"value":"8277"},"text":"§ 8277.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisory committee","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbe8d3855-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8277/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is hereby established an advisory committee to assist the Secretary in the establishment and conduct of the programs established under this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe8d3856-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8277/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Such committee shall be composed of the Secretary of Defense, the Secretary of Housing and Urban Development, the Administrator of the National Aeronautics and Space Administration, the Administrator of the General Services Administration, the Secretary of Transportation, the Administrator of the Small Business Administration, the chairman of the Federal Trade Commission, the Postmaster General, and such other persons as the Secretary deems necessary. The Secretary shall appoint such other nongovernmental persons to the extent necessary to assure that the membership of the committee will be fairly balanced in terms of the point of view represented and the functions to be performed by the committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe8d3857-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8277/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The advisory committee shall terminate ","children":[{"tag":"date","attrib":{"date":"1981-10-01"},"text":"October 1, 1981","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbe8d3858-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/619/tV/s568"},"text":"Pub. L. 95–619, title V, § 568","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-09"},"text":"Nov. 9, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3281"},"text":"92 Stat. 3281","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
