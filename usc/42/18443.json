{"tag":"section","attrib":{"id":"idc0596cb0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18443"},"text":null,"children":[{"tag":"num","attrib":{"value":"18443"},"text":"§ 18443.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility for service of individual currently serving as Administrator of NASA","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The individual serving in the position of Administrator of the National Aeronautics and Space Administration as of ","children":[{"tag":"date","attrib":{"date":"2010-10-11"},"text":"October 11, 2010","children":[],"tail":", comes from civilian life and is therefore eligible to serve in such position, in conformance with "},{"tag":"ref","attrib":{"href":"/us/usc/t51/s20111"},"text":"section 20111 of title 51","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc0596cb1-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/267/tXII/s1204"},"text":"Pub. L. 111–267, title XII, § 1204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-11"},"text":"Oct. 11, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2842"},"text":"124 Stat. 2842","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc0596cb2-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc0596cb3-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idc0596cb4-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In te