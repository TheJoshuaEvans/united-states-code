{"tag":"section","attrib":{"id":"idc07f9307-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19134"},"text":null,"children":[{"tag":"num","attrib":{"value":"19134"},"text":"§ 19134.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisory committee on engineering biology research and development","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc07f9308-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19134/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The agency co-chair of the interagency committee established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s19133"},"text":"section 19133 of this title","children":[],"tail":" shall, in consultation with the Office of Science and Technology Policy, designate or establish an advisory committee on engineering biology research and development (in this section referred to as the “advisory committee”) to be composed of not fewer than 12 members, including representatives of research and academic institutions, industry, and nongovernmental entities, who are qualified to provide advice on the Initiative."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc07f9309-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19134/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The advisory committee shall assess the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc07f930a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19134/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The current state of United States competitiveness in engineering biology, including the scope and scale of United States investments in engineering biology research and development in the international context.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc07f930b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19134/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Current market barriers to commercialization of engineering biology products, processes, and tools in the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc07f930c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19134/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Progress made in implementing the Initiative.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc07f930d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19134/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The need to revise the Initiative.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc07f930e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19134/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The balance of activities and funding across the Initiative.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc07f930f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19134/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whether the strategic plan developed or updated by the interagency committee established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s19133"},"text":"section 19133 of this title","children":[],"tail":" is helping to maintain United States leadership in engineering biology."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc07f9310-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19134/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whether ethical, legal, environmental, safety, security, and other appropriate societal issues are adequately addressed by the Initiative.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc07f9311-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19134/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Beginning not later than two years after ","children":[{"tag":"date","attrib":{"date":"2022-08-09"},"text":"August 9, 2022","children":[],"tail":", and not less frequently than once every five years thereafter, the advisory committee shall submit to the President, the Committee on Science, Space, and Technology, the Committee on Energy and Commerce, and the Committee on Agriculture of the House of Representatives, and the Committee on Commerce, Science, and Transportation, the Committee on Health, Education, Labor, and Pensions, and the Committee on Agriculture, Nutrition, and Forestry of the Senate, a report on the following:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc07f9312-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19134/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The findings of the advisory committee’s assessment under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc07f9313-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19134/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The advisory committee’s recommendations for ways to improve the Initiative.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc07f9314-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19134/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of Federal Advisory Committee Act","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Section 14 of the Federal Advisory Committee Act (5 U.S.C. App.) ","children":[{"tag":"ref","attrib":{"idref":"fn004396"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004396"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" shall not apply to the advisory committee."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc07f9315-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19134/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The advisory committee established under subsection (a) shall terminate on the date that is 10 years after ","children":[{"tag":"date","attrib":{"date":"2022-08-09"},"text":"August 9, 2022","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":