{"tag":"section","attrib":{"id":"idbaaf8901-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397n–5"},"text":null,"children":[{"tag":"num","attrib":{"value":"1397n–5"},"text":"§ 1397n–5.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal Interagency Council on Social Impact Partnerships","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbaaf8902-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397n–5/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is established the Federal Interagency Council on Social Impact Partnerships (in this section referred to as the “Council”) to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbaaf8903-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397n–5/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate with the Secretary on the efforts of social impact partnership projects funded under this division;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaaf8904-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397n–5/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advise and assist the Secretary in the development and implementation of the projects;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaaf8905-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397n–5/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advise the Secretary on specific programmatic and policy matter related to the projects;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaaf8906-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397n–5/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide subject-matter expertise to the Secretary with regard to the projects;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaaf8907-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397n–5/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" certify to the Secretary that each State or local government that has entered into an agreement with the Secretary for a social impact partnership project under this division and each evaluator selected by the head of the relevant agency under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1397n–4"},"text":"section 1397n–4 of this title","children":[],"tail":" has access to Federal administrative data to assist the State or local government and the evaluator in evaluating the performance and outcomes of the project;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaaf8908-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397n–5/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" address issues that will influence the future of social impact partnership projects in the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaaf8909-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397n–5/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide guidance to the executive branch on the future of social impact partnership projects in the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaaf890a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397n–5/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prior to approval by the Secretary, certify that each State and local government application for a social impact partnership contains rigorous, independent data and reliable, evidence-based research methodologies to support the conclusion that the project will yield savings to the State or local government or the Federal Government if the project outcomes are achieved;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaaf890b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397n–5/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" certify to the Secretary, in the case of each approved social impact partnership that is expected to yield savings to the Federal Government, that the project will yield a projected savings to the Federal Government if the project outcomes are achieved, and coordinate with the relevant Federal agency to produce an after-action accounting once the project is complete to determine the actual Federal savings realized, and the extent to which actual savings aligned with projected savings; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaaf890c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397n–5/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide periodic reports to the Secretary and make available reports periodically to Congress and the public on the implementation of this division.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbaaf890d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397n–5/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Composition of Council","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Council shall have 11 members, as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbaaf890e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397n–5/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chair","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Chair of the Council shall be the Director of the Office of Management and Budget.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaaf890f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397n–5/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other members","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The head of each of the following entities shall designate one officer or employee of the entity to be a Council member:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbaaf8910-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397n–5/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of Labor.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaaf8911-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397n–5/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of Health and Human Services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaaf8912-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397n–5/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Social Security Administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaaf8913-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397n–5/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaaf8914-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397n–5/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of Justice.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaaf8915-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397n–5/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of Housing and Urban Development.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaaf8916-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397n–5/b/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of Education.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaaf8917-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397n–5/b/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of Veterans Affairs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaaf8918-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397n–5/b/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaaf8919-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397n–5/b/2/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Corporation for National and Community Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbaaf891a-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title XX, § 2056, as added "},{"tag":"ref","attrib":{"href":"/us/pl/115/123/dE/tVIII/s50802/2"},"text":"Pub. L. 115–123, div. E, title VIII, § 50802(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-02-09"},"text":"Feb. 9, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/278"},"text":"132 Stat. 278","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
