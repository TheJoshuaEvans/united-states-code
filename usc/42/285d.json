{"tag":"section","attrib":{"id":"idb56ec782-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285d"},"text":null,"children":[{"tag":"num","attrib":{"value":"285d"},"text":"§ 285d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose of Institute","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The general purpose of the National Institute of Arthritis and Musculoskeletal and Skin Diseases (hereafter in this subpart referred to as the “Institute”) is the conduct and support of research and training, the dissemination of health information, and other programs with respect to arthritis and musculoskeletal and skin diseases (including sports-related disorders), with particular attention to the effect of these diseases on children.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb56ec783-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title IV, § 435, as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/158/s2"},"text":"Pub. L. 99–158, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-11-20"},"text":"Nov. 20, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/848"},"text":"99 Stat. 848","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/43/tVII/s701/a"},"text":"Pub. L. 103–43, title VII, § 701(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-06-10"},"text":"June 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/162"},"text":"107 Stat. 162","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb56ec784-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb56ec785-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb56ec786-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1993—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/43"},"text":"Pub. L. 103–43","children":[],"tail":" substituted “(including sports-related disorders), with particular attention to the effect of these diseases on children” for “, including sports-related disorders”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
