{"tag":"section","attrib":{"id":"idb6240d63-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300e–12"},"text":null,"children":[{"tag":"num","attrib":{"value":"300e–12"},"text":"§ 300e–12.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on source of funding for health maintenance organizations","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"No funds appropriated under any provision of this chapter (except as provided in sections 254b ","children":[{"tag":"ref","attrib":{"idref":"fn002339"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002339"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" and 254b of this title) other than this subchapter may be used—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6240d64-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300e–12/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for grants or contracts for surveys or other activities to determine the feasibility of developing or expanding health maintenance organizations or other entities which provide, directly or indirectly, health services to a defined population on a prepaid basis;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6240d65-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300e–12/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for grants or contracts, or for payments under loan guarantees, for planning projects for the establishment or expansion of such organizations or entities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6240d66-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300e–12/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for grants or contracts, or for payments under loan guarantees, for projects for the initial development or expansion of such organizations or entities; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6240d67-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300e–12/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for loans, or for payments under loan guarantees, to assist in meeting the costs of the initial operation after establishment or expansion of such organizations or entities or in meeting the costs of such organizations in acquiring or constructing ambulatory health care facilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb6240d68-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XIII, § 1313, as added "},{"tag":"ref","attrib":{"href":"/us/pl/93/222/s2"},"text":"Pub. L. 93–222, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-12-29"},"text":"Dec. 29, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/932"},"text":"87 Stat. 932","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/95/559/s5/b"},"text":"Pub. L. 95–559, § 5(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-01"},"text":"Nov. 1, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2133"},"text":"92 Stat. 2133","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/626/tI/s107"},"text":"Pub. L. 95–626, title I, § 107","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-10"},"text":"Nov. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/st