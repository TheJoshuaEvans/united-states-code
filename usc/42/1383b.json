s as par. (1) and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/296/s107/a/4"},"text":"Pub. L. 103–296, § 107(a)(4)","children":[],"tail":", substituted “Commissioner of Social Security” for “Secretary” and “the Commissioner’s” for “his”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/296/s107/a/4"},"text":"Pub. L. 103–296, § 107(a)(4)","children":[],"tail":", substituted “Commissioner of Social Security” for “Secretary” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/296/s203/a"},"text":"Pub. L. 103–296, § 203(a)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/296/s107/a/4"},"text":"Pub. L. 103–296, § 107(a)(4)","children":[],"tail":", in subsec. (d) as added by "},{"tag":"ref","attrib":{"href":"/us/pl/103/296/s203/a"},"text":"Pub. L. 103–296, § 203(a)","children":[],"tail":", substituted “Commissioner of Social Security” for “Secretary” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/460"},"text":"Pub. L. 98–460","children":[],"tail":" added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1973—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/66/s214/1"},"text":"Pub. L. 93–66, § 214(1)","children":[],"tail":", (2), designated existing provisions as subsec. (a) and made the authority of the Secretary subject to subsec. (b) of this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/66/s214/3"},"text":"Pub. L. 93–66, § 214(3)","children":[],"tail":", added subsec. (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb88666b8-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb88666b9-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2006 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/171"},"text":"Pub. L. 109–171","children":[],"tail":" effective as if enacted on "},{"tag":"date","attrib":{"date":"2005-10-01"},"text":"Oct. 1, 2005","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/109/171/s7701"},"text":"section 7701 of Pub. L. 109–171","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s603"},"text":"section 603 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb88666ba-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1999 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/170"},"text":"Pub. L. 106–170","children":[],"tail":" effective with the first month following one year after "},{"tag":"date","attrib":{"date":"1999-12-17"},"text":"Dec. 17, 1999","children":[],"tail":", subject to "},{"tag":"ref","attrib":{"href":"/us/pl/106/170/s101/d"},"text":"section 101(d) of Pub. L. 106–170","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/106/170/s101/c"},"text":"section 101(c) of Pub. L. 106–170","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320b–19"},"text":"section 1320b–19 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb88666bb-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/296/s107/a/4"},"text":"section 107(a)(4) of Pub. L. 103–296","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1995-03-31"},"text":"Mar. 31, 1995","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/296/s110/a"},"text":"section 110(a) of Pub. L. 103–296","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s401"},"text":"section 401 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/296/tII/s203/b"},"text":"Pub. L. 103–296, title II, § 203(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-08-15"},"text":"Aug. 15, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1508"},"text":"108 Stat. 1508","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/296/tII/s203/b"},"text":"“The amendment made by subsection (a) [amending this section] shall take effect on ","children":[{"tag":"date","attrib":{"date":"1995-01-01"},"text":"January 1, 1995","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb88666bc-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/92/603/tIII/s301"},"text":"Pub. L. 92–603, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-30"},"text":"Oct. 30, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1465"},"text":"86 Stat. 1465","children":[],"tail":", provided that this section is effective "},{"tag":"date","attrib":{"date":"1974-01-01"},"text":"Jan. 1, 1974","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb88666bd-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Institution of Notification System","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions requiring the Secretary to institute the system of notification required by subsec. (c) of this section as soon as practicable after ","children":[{"tag":"date","attrib":{"date":"1984-10-09"},"text":"Oct. 9, 1984","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/460/s6/c"},"text":"section 6(c) of Pub. L. 98–460","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s421"},"text":"section 421 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb88666be-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Federal Program of Supplemental Security Income; Preference for Present State and Local Employees","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/93/66/tII/s213"},"text":"Pub. L. 93–66, title II, § 213","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-07-09"},"text":"July 9, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/158"},"text":"87 Stat. 158","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/93/66/tII/s213"},"text":"“The Secretary of Health, Education, and Welfare [now Health and Human Services] in the recruitment and selection for employment of personnel whose services will be utilized in the administration of the Federal program of supplemental security income for the aged, blind, and disabled (established by title XVI of the Social Security Act [this subchapter]), shall give a preference, as among applicants whose qualifications are reasonably equal (subject to any preferences conferred by law or regulation on individuals who have been Federal employees and have been displaced from such employment), to applicants for employment who are or were employed in the administration of any State program approved under title I, X, XIV, or XVI of such Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s301"},"text":"42 U.S.C. 301","children":[],"tail":" et seq., 1201 et seq., 1351 et seq., 1381 et seq.] and are or were involuntarily displaced from their employment as a result of the displacement of such State program by such Federal program.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb88666bf-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Application to Northern Mariana Islands","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For applicability of this section to the Northern Mariana Islands, see section 502(a)(1) of the Covenant to Establish a Commonwealth of the Northern Mariana Islands in Political Union with the United States of America and Proc. No. 4534, ","children":[{"tag":"date","attrib":{"date":"1977-10-24"},"text":"Oct. 24, 1977","children":[],"tail":", 42 F.R. 6593, set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t48/s1801"},"text":"section 1801 of Title 48","children":[],"tail":", Territories and Insular Possessions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb88666c0-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Puerto Rico, Guam, and Virgin Islands","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Enactment of provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/603"},"text":"Pub. L. 92–603","children":[],"tail":", eff. "},{"tag":"date","attrib":{"date":"1974-01-01"},"text":"Jan. 1, 1974","children":[],"tail":", not applicable to Puerto Rico, Guam, and the Virgin Islands, see "},{"tag":"ref","attrib":{"href":"/us/pl/92/603/s303/b"},"text":"section 303(b) of Pub. L. 92–603","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s301"},"text":"section 301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
