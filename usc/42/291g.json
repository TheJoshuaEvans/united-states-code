tat. 1041","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/act/1949-10-25/ch722/s4"},"text":"Oct. 25, 1949, ch. 722, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/900"},"text":"63 Stat. 900","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1954-07-12/ch471/s4/g"},"text":"July 12, 1954, ch. 471, § 4(g)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/466"},"text":"68 Stat. 466","children":[],"tail":", prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/88/443"},"text":"Pub. L. 88–443","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb5cbda80-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idb5cbda81-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Secretary of Health and Human Services” substituted for “Secretary of Health, Education, and Welfare” pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/88/s509/b"},"text":"section 509(b) of Pub. L. 96–88","children":[],"tail":", which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s3508/b"},"text":"section 3508(b) of Title 20","children":[],"tail":", Education."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idb5cbda82-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"idb5cbda83-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Office of Surgeon General abolished by section 3 of Reorg. Plan No. 3 of 1966, eff. ","children":[{"tag":"date","attrib":{"date":"1966-06-25"},"text":"June 25, 1966","children":[],"tail":", 31 F.R. 8855, "},{"tag":"ref","attrib":{"href":"/us/stat/80/1610"},"text":"80 Stat. 1610","children":[],"tail":", and functions thereof transferred to Secretary of Health, Education, and Welfare by section 1 of Reorg. Plan No. 3 of 1966, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s202"},"text":"section 202 of this title","children":[],"tail":". Office of Surgeon General reestablished within the Office of the Assistant Secretary for Health, see Notice of Department of Health and Human Services, Office of the Assistant Secretary for Health, "},{"tag":"date","attrib":{"date":"1987-03-30"},"text":"Mar. 30, 1987","children":[],"tail":", 52 F.R. 11754."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
