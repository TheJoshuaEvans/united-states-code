{"tag":"section","attrib":{"id":"idb5c99185-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s291g"},"text":null,"children":[{"tag":"num","attrib":{"value":"291g"},"text":"§ 291g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Withholding of payments; noncompliance with requirements","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Whenever the Surgeon General, after reasonable notice and opportunity for hearing to the State agency designated as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s291d/a/1"},"text":"section 291d(a)(1) of this title","children":[],"tail":", finds—"}],"tail":null},{"tag":"subsection","attrib":{"id":"idb5c99186-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s291g/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that the State agency is not complying substantially with the provisions required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s291d"},"text":"section 291d of this title","children":[],"tail":" to be included in its State plan; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5c99187-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s291g/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that any assurance required to be given in an application filed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s291e"},"text":"section 291e of this title","children":[],"tail":" is not being or cannot be carried out; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5c99188-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s291g/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that there is a substantial failure to carry out plans and specifications approved by the Surgeon General under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s291e"},"text":"section 291e of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5c99189-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s291g/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that adequate State funds are not being provided annually for the direct administration of the State plan,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the Surgeon General may forthwith notify the State agency that—","children":[],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5c9918a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s291g/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no further payments will be made to the State under this part, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5c9918b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s291g/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no further payments will be made from the allotments of such State from appropriations under any one or more subparagraphs or paragraphs of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s291a"},"text":"section 291a of this title","children":[],"tail":", or for any project or projects, designated by the Surgeon General as being affected by the action or inaction referred to in paragraph (a), (b), (c), or (d) of this section,"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"as the Surgeon General may determine to be appropriate under the circumstances; and, except with regard to any project for which the application has already been approved and which is not directly affected, further payments may be withheld, in whole or in part, until there is no longer any failure to comply (or carry out the assurance or plans and specifications or provide adequate State funds, as the case may be) or, if such compliance (or other action) is impossible, until the State repays or arranges for the repayment of Federal moneys to which the recipient was not entitled.","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5c9918c-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title VI, § 607, as added "},{"tag":"ref","attrib":{"href":"/us/pl/88/443/s3/a"},"text":"Pub. L. 88–443, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-08-18"},"text":"Aug. 18, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/455"},"text":"78 Stat. 455","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb5c9918d-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb5c9918e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb5c9918f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 291g, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373/tVI/s624"},"text":"act July 1, 1944, ch. 373, title VI, § 624","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/act/1946-08-13/ch958/s2"},"text":"Aug. 13, 1946, ch. 958, § 2","children":[