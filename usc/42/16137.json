{"tag":"section","attrib":{"id":"idbff52c4f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16137"},"text":null,"children":[{"tag":"num","attrib":{"value":"16137"},"text":"§ 16137.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbff52c50-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16137/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this part $100,000,000 for each of fiscal years 2012 through 2024, to remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff52c51-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16137/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management and oversight","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator may use not more than 1 percent of the amounts made available under subsection (a) for each fiscal year for management and oversight purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbff52c52-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tVII/s797"},"text":"Pub. L. 109–58, title VII, § 797","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/844"},"text":"119 Stat. 844","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/364/s2/e"},"text":"Pub. L. 111–