{"tag":"section","attrib":{"id":"idbbd9b12f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2021b"},"text":null,"children":[{"tag":"num","attrib":{"value":"2021b"},"text":"§ 2021b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of sections 2021b to 2021j of this title:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbbd9b130-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2021b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreement State","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “agreement State” means a State that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbbd9b131-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2021b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has entered into an agreement with the Nuclear Regulatory Commission under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2021"},"text":"section 2021 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbbd9b132-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2021b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has authority to regulate the disposal of low-level radioactive waste under such agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbd9b133-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2021b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “allocation” means the assignment of a specific amount of low-level radioactive waste disposal capacity to a commercial nuclear power reactor for which access is required to be provided by sited States subject to the conditions specified under sections 2021b to 2021j of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbd9b134-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2021b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commercial nuclear power reactor","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “commercial nuclear power reactor” means any unit of a civilian light-water moderated utilization facility required to be licensed under section 2133 or 2134(b) of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbd9b135-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2021b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compact","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “compact” means a compact entered into by two or more States pursuant to sections 2021b to 2021j of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbd9b136-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2021b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compact commission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “compact commission” means the regional commission, committee, or board established in a compact to administer such compact.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbd9b137-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2021b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compact region","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “compact region” means the area consisting of all States that are members of a compact.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbd9b138-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2021b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “disposal” means the permanent isolation of low-level radioactive waste pursuant to the requirements established by the Nuclear Regulatory Commission under applicable laws, or by an agreement State if such isolation occurs in such agreement State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbd9b139-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2021b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Generate","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “generate”, when used in relation to low-level radioactive waste, means to produce low-level radioactive waste.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbd9b13a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2021b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Low-level radioactive waste","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbbd9b13b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2021b/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “low-level radioactive waste” means radioactive material that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbbd9b13c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2021b/9/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not high-level radioactive waste, spent nuclear fuel, or byproduct material (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2014/e/2"},"text":"section 2014(e)(2) of this title","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbbd9b13d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2021b/9/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Nuclear Regulatory Commission, consistent with existing law and in accordance with paragraph (A), classifies as low-level radioactive waste.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbbd9b13e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2021b/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “low-level radioactive waste” does not include byproduct material (as defined in paragraphs (3) and (4) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2014/e"},"text":"section 2014(e) of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbd9b13f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2021b/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-sited compact region","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “non-sited compact region” means any compact region that is not a sited compact region.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbd9b140-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2021b/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regional disposal facility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “regional disposal facility” means a non-Federal low-level radioactive waste disposal facility in operation on ","children":[{"tag":"date","attrib":{"date":"1985-01-01"},"text":"January 1, 1985","children":[],"tail":", or subsequently established and operated under a compact."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbd9b141-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2021b/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of Energy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbd9b142-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2021b/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sited compact region","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “sited compact region” means a compact region in which there is located one of the regional disposal facilities at Barnwell, in the State of South Carolina; Richland, in the State of Washington; or Beatty, in the State of Nevada.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbd9b143-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2021b/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State” means any State of the United States, the District of Columbia, and the Commonwealth of Puerto Rico.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbbd9b144-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/573/s2"},"text":"Pub. L. 96–573, § 2","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/240/tI/s102"},"text":"Pub. L. 99–240, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-01-15"},"text":"Jan. 15, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1842"},"text":"99 Stat. 1842","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/58/tVI/s651/e/3/B"},"text":"Pub. L. 109–58, title VI, § 651(e)(3)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/808"},"text":"119 Stat. 808","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbbd9b145-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbbd9b146-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbbd9b147-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Low-Level Radioactive Waste Policy Act, and not as part of the Atomic Energy Act of 1954 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"constitutionality","id":"idbbd9b148-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Constitutionality","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For information regarding the constitutionality of certain provisions of Low-Level Radioactive Waste Policy Act (sections 2021b to 2021j of this title), see the Table of Laws Held Unconstitutional in Whole or in Part by the Supreme Court on the Constitution Annotated website, constitution.congress.gov.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbbd9b149-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2021b, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/573/s2"},"text":"Pub. L. 96–573, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-22"},"text":"Dec. 22, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3347"},"text":"94 Stat. 3347","children":[],"tail":", related to definitions respecting low-level radioactive waste policy as used in former sections 2021b to 2021d of this title, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/99/240/s102"},"text":"Pub. L. 99–240, § 102","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbbd9b14a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2005—Par. (9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58"},"text":"Pub. L. 109–58","children":[],"tail":" designated existing provisions as subpar. (A), inserted heading, redesignated former subpars. (A) and (B) as cls. (i) and (ii), respectively, and added subpar. (B)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbbd9b14b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idbbd9b14c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/240/tI/s101"},"text":"Pub. L. 99–240, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-01-15"},"text":"Jan. 15, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1842"},"text":"99 Stat. 1842","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/240/tI/s101"},"text":"“This Title [enacting this section and sections 2021c to 2021j of this title, repealing former sections 2021b to 2021d of this title, and enacting and repealing a provision set out as a note under this section] may be cited as the ‘Low-Level Radioactive Waste Policy Amendments Act of 1985’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"idbbd9b14d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/96/573/s1"},"text":"Pub. L. 96–573, § 1","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/99/240/tI/s102"},"text":"Pub. L. 99–240, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-01-15"},"text":"Jan. 15, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1842"},"text":"99 Stat. 1842","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/240/tI/s102"},"text":"“This Act [enacting sections 2021b to 2021j of this title] may be cited as the ‘Low-Level Radioactive Waste Policy Act’.”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/573/s1"},"text":"section 1 of Pub. L. 96–573","children":[],"tail":", which provided that "},{"tag":"ref","attrib":{"href":"/us/pl/96/573"},"text":"Pub. L. 96–573","children":[],"tail":" [enacting former sections 2021b to 2021d of this title] could be cited as the “Low-Level Radioactive Waste Policy Act”, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/99/240/tI/s102"},"text":"Pub. L. 99–240, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-01-15"},"text":"Jan. 15, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1842"},"text":"99 Stat. 1842","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
