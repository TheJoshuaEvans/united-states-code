{"tag":"section","attrib":{"id":"idbea50642-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8831"},"text":null,"children":[{"tag":"num","attrib":{"value":"8831"},"text":"§ 8831.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Municipal waste energy development plan","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbea50643-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8831/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preparation by Secretary of Energy; consultative requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Energy shall prepare a comprehensive plan for carrying out this subchapter. In the preparation of such plan, the Secretary shall consult with the Administrator of the Environmental Protection Agency, the Secretary of Commerce, and the head of such other Federal agencies as the Secretary deems appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbea50644-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8831/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transmittal to President and Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"1980-06-30"},"text":"June 30, 1980","children":[],"tail":", the Secretary shall transmit the comprehensive plan to the President and the Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbea50645-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8831/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required statements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The comprehensive plan under this section shall include a statement setting forth—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbea50646-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8831/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the anticipated research, development, demonstration, and commercialization objectives to be achieved;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbea50647-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8831/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the management structure and approach to be adopted to carry out such plan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbea50648-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8831/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the program strategies, including detailed milestone goals to be achieved;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbea50649-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8831/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the specific funding requirements for individual program elements and activities, including the total estimated construction costs of proposed projects; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbea5064a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8831/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the estimated relative financial contributions of the Federal Government and non-Federal participants in the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbea5064b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8831/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to President and Congress; contents","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"1982-01-01"},"text":"January 1, 1982","children":[],"tail":", the Secretary shall prepare and submit to the President and the Congress a report containing a complete description of any financial, institutional, environmental, and social barriers to the development and application of technologies for the recovery of energy from municipal wastes."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbea5064c-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/294/tII/s231"},"text":"Pub. L. 96–294, title II, § 231","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-06-30"},"text":"June 30, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/696"},"text":"94 Stat. 696","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
