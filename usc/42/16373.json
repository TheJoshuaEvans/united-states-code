{"tag":"section","attrib":{"id":"idc00f6c16-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16373"},"text":null,"children":[{"tag":"num","attrib":{"value":"16373"},"text":"§ 16373.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secured loans","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc00f6c17-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16373/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc00f6c18-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16373/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to paragraph (2), the Secretary may enter into agreements with 1 or more obligors to make secured loans, the proceeds of which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc00f6c19-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16373/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall be used—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc00f6c1a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16373/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to finance eligible project costs of any project selected under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16372"},"text":"section 16372 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc00f6c1b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16373/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to refinance interim construction financing of eligible project costs of any project selected under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16372"},"text":"section 16372 of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc00f6c1c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16373/a/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to refinance long-term project obligations or Federal credit instruments, if the refinancing provides additional funding capacity for the completion, enhancement, or expansion of any project that—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idc00f6c1d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16373/a/1/A/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is selected under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16372"},"text":"section 16372 of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc00f6c1e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16373/a/1/A/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" otherwise meets the requirements of that section; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00f6c1f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16373/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be used in accordance with subsection (b)(7) to pay any fees collected by the Secretary under subparagraph (B) of that subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00f6c20-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16373/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Risk assessment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Before entering into an agreement under this subsection, the Secretary, in consultation with the Director of the Office of Management and Budget, shall determine an appropriate credit subsidy amount for each secured loan, taking into account all relevant factors, including the creditworthiness factors under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16372/b/2"},"text":"section 16372(b)(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc00f6c21-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16373/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms and limitations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc00f6c22-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16373/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A secured loan under this section with respect to a project shall be on such terms and conditions and contain such covenants, representations, warranties, and requirements (including requirements for audits) as the Secretary determines to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00f6c23-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16373/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of a secured loan under this section shall not exceed an amount equal to 80 percent of the reasonably anticipated eligible project costs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00f6c24-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16373/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A secured loan under this section shall be payable, in whole or in part, from—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc00f6c25-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16373/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" user fees;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00f6c26-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16373/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" payments owing to the obligor under a public-private partnership; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00f6c27-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16373/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other revenue sources that also secure or fund the project obligations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00f6c28-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16373/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interest rate","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc00f6c29-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16373/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subparagraph (B), the interest rate on a secured loan under this section shall be not less than the interest rate reflected in the yield on United States Treasury securities of a similar maturity to the maturity of the secured loan on the date of execution of the loan agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00f6c2a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16373/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limited buydowns","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc00f6c2b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16373/b/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to clause (iii), the Secretary may lower the interest rate of a secured loan under this section to not lower than the interest rate described in clause (ii), if the interest rate has increased during the period—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idc00f6c2c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16373/b/4/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" beginning on, as applicable—","children":[],"tail":null},{"tag":"item","attrib":{"id":"idc00f6c2d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16373/b/4/B/i/I/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which an application acceptable to the Secretary is submitted for the applicable project; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idc00f6c2e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16373/b/4/B/i/I/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which the Secretary entered into a master credit agreement for the applicable project; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc00f6c2f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16373/b/4/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ending on the date on which the Secretary executes the Federal credit instrument for the applicable project that is the subject of the secured loan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc00f6c30-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16373/b/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Description of interest rate","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The interest rate referred to in clause (i) is the interest rate reflected in the yield on United States Treasury securities of a similar maturity to the maturity of the secured loan in effect, as applicable to the project that is the subject of the secured loan, on—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idc00f6c31-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16373/b/4/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date described in clause (i)(I)(aa); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc00f6c32-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16373/b/4/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date described in clause (i)(I)(bb).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc00f6c33-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16373/b/4/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The interest rate of a secured loan may not be lowered pursuant to clause (i) by more than 1½ percentage points (150 basis points).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00f6c34-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16373/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maturity date","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The final maturity date of the secured loan shall be the earlier of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc00f6c35-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16373/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date that is 35 years after the date of substantial completion of the project; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00f6c36-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16373/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the useful life of the capital asset being financed is of a lesser period, the date that is the end of the useful life of the asset.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00f6c37-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16373/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonsubordination","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc00f6c38-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16373/b/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subparagraph (B), the secured loan shall not be subordinated to the claims of any holder of project obligations in the event of bankruptcy, insolvency, or liquidation of the obligor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00f6c39-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16373/b/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preexisting indenture","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc00f6c3a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16373/b/6/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall waive the requirement under subparagraph (A) for a public agency borrower that is financing ongoing capital programs and has outstanding senior bonds under a preexisting indenture, if—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idc00f6c3b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16373/b/6/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the secured loan is rated in the A category or higher; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc00f6c3c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16373/b/6/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the secured loan is secured and payable from pledged revenues not affected by project performance, such as a tax-backed revenue pledge or a system-backed pledge of project revenues.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc00f6c3d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16373/b/6/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Secretary waives the nonsubordination requirement under this subparagraph—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idc00f6c3e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16373/b/6/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the maximum credit subsidy amount to be paid by the Federal Government shall be not more than 10 percent of the principal amount of the secured loan; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc00f6c3f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16373/b/6/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the obligor shall be responsible for paying the remainder of the subsidy amount, if any.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00f6c40-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16373/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fees","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc00f6c41-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16373/b/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may collect a fee on or after the date of the financial close of a Federal credit instrument under this section in an amount equal to not more than $3,000,000 to cover all or a portion of the costs to the Federal Government of providing the Federal credit instrument.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00f6c42-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16373/b/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amendment to add cost of fees to secured loan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary collects a fee from an obligor under subparagraph (A) to cover all or a portion of the costs to the Federal Government of providing a secured loan, the obligor and the Secretary may amend the terms of the secured loan to add to the principal of the secured loan an amount equal to the amount of the fee collected by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00f6c43-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16373/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum Federal involvement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The total Federal assistance provided for a project under the CIFIA program, including any grant provided under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16374"},"text":"section 16374 of this title","children":[],"tail":", shall not exceed an amount equal to 80 percent of the eligible project costs."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc00f6c44-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16373/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repayment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc00f6c45-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16373/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Schedule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall establish a repayment schedule for each secured loan under this section based on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc00f6c46-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16373/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the projected cash flow from project revenues and other repayment sources; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00f6c47-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16373/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the useful life of the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00f6c48-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16373/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commencement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Scheduled loan repayments of principal or interest on a secured loan under this section shall commence not later than 5 years after the date of substantial completion of the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00f6c49-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16373/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deferred payments","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc00f6c4a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16373/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If, at any time after the date of substantial completion of a project, the project is unable to generate sufficient revenues in excess of reasonable and necessary operating expenses to pay the scheduled loan repayments of principal and interest on the secured loan, the Secretary may, subject to subparagraph (C), allow the obligor to add unpaid principal and interest to the outstanding balance of the secured loan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00f6c4b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16373/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interest","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any payment deferred under subparagraph (A) shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc00f6c4c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16373/c/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" continue to accrue interest in accordance with subsection (b)(4) until fully repaid; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc00f6c4d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16373/c/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be scheduled to be amortized over the remaining term of the loan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00f6c4e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16373/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc00f6c4f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16373/c/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any payment deferral under subparagraph (A) shall be contingent on the project meeting criteria established by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc00f6c50-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16373/c/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repayment standards","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The criteria established pursuant to clause (i) shall include standards for the reasonable prospect of repayment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00f6c51-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16373/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prepayment","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc00f6c52-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16373/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of excess revenues","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any excess revenues that remain after satisfying scheduled debt service requirements on the project obligations and secured loan and all deposit requirements under the terms of any trust agreement, bond resolution, or similar agreement securing project obligations may be applied annually to prepay the secured loan, without penalty.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00f6c53-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16373/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of proceeds of refinancing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A secured loan may be prepaid at any time without penalty from the proceeds of refinancing from non-Federal funding sources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc00f6c54-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16373/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sale of secured loans","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc00f6c55-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16373/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (2), as soon as practicable after substantial completion of a project and after notifying the obligor, the Secretary may sell to another entity or reoffer into the capital markets a secured loan for the project if the Secretary determines that the sale or reoffering can be made on favorable terms.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00f6c56-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16373/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consent of obligor","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In making a sale or reoffering under paragraph (1), the Secretary may not change any original term or condition of the secured loan without the written consent of the obligor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc00f6c57-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16373/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loan guarantees","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc00f6c58-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16373/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may provide a loan guarantee to a lender in lieu of making a secured loan under this section if the Secretary determines that the budgetary cost of the loan guarantee is substantially the same as, or less than, that of a secured loan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00f6c59-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16373/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms of a loan guarantee under paragraph (1) shall be consistent with the terms required under this section for a secured loan, except that the rate on the guaranteed loan and any prepayment features shall be negotiated between the obligor and the lender, with the consent of the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc00f6c5a-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tIX/s999C"},"text":"Pub. L. 109–58, title IX, § 999C","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/dD/tIII/s40304/a"},"text":"Pub. L. 117–58, div. D, title III, § 40304(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/995"},"text":"135 Stat. 995","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc00f6c5b-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc00f6c5c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc00f6c5d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 16373, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tIX/s999C"},"text":"Pub. L. 109–58, title IX, § 999C","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/921"},"text":"119 Stat. 921","children":[],"tail":", related to additional requirements for awards, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/113/67/dA/tIII/s301/a"},"text":"Pub. L. 113–67, div. A, title III, § 301(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-12-26"},"text":"Dec. 26, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/1181"},"text":"127 Stat. 1181","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc00f6c5e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc00f6c5f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Wage Rate Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions relating to rates of wages to be paid to laborers and mechanics on projects for construction, alteration, or repair work funded under div. D or an amendment by div. D of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":", including authority of Secretary of Labor, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s18851"},"text":"section 18851 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
