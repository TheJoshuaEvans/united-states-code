{"tag":"section","attrib":{"id":"idbf25ced3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10367"},"text":null,"children":[{"tag":"num","attrib":{"value":"10367"},"text":"§ 10367.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Water data enhancement by United States Geological Survey","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf25ced4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10367/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal priority streamgage program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf25ced5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10367/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in consultation with the Advisory Committee and the Panel and consistent with this section, shall proceed with implementation of the Federal priority streamgage program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf25ced6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10367/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In conducting the Federal priority streamgage program, the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf25ced7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10367/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" measure streamflow and related environmental variables in nationally significant watersheds—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbf25ced8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10367/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in a reliable and continuous manner; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf25ced9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10367/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop a comprehensive source of information on which public and private decisions relating to the management of water resources may be based;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf25ceda-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10367/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for a better understanding of hydrologic extremes (including floods and droughts) through the conduct of intensive data collection activities during and following hydrologic extremes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf25cedb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10367/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" establish a base network that provides resources that are necessary for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbf25cedc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10367/a/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the monitoring of long-term changes in streamflow; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf25cedd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10367/a/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the conduct of assessments to determine the extent to which each long-term change monitored under clause (i) is related to global climate change;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf25cede-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10367/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" integrate the Federal priority streamgage program with data collection activities of Federal agencies and appropriate State water resource agencies (including the National Integrated Drought Information System)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbf25cedf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10367/a/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to enhance the comprehensive understanding of water availability;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf25cee0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10367/a/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to improve flood-hazard assessments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf25cee1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10367/a/2/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to identify any data gap with respect to water resources; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf25cee2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10367/a/2/D/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to improve hydrologic forecasting; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf25cee3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10367/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" incorporate principles of adaptive management in the conduct of periodic reviews of information collected under the Federal priority streamgage program to assess whether the objectives of the Federal priority streamgage program are being adequately addressed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf25cee4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10367/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Improved methodologies","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf25cee5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10367/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve methodologies relating to the analysis and delivery of data; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf25cee6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10367/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" investigate, develop, and implement new methodologies and technologies to estimate or measure streamflow in a more cost-efficient manner.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf25cee7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10367/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Network enhancement","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf25cee8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10367/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 10 years after ","children":[{"tag":"date","attrib":{"date":"2023-03-30"},"text":"March 30, 2023","children":[],"tail":", in accordance with subparagraph (B), the Secretary shall—"}],"tail":null},{"tag":"clause","attrib":{"id":"idbf25cee9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10367/a/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase the number of streamgages funded by the national streamflow information program to a quantity of not less than 4,700 sites; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf25ceea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10367/a/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure all streamgages are flood-hardened and equipped with precipitation water-quality sensors and modernized telemetry.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf25ceeb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10367/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements of sites","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each site described in subparagraph (A) shall conform with the Federal needs established through regular solicitation of feedback, such as that documented in the report titled “Re-prioritization of the U.S. Geological Survey Federal Priority streamgage program, 2022” ","children":[{"tag":"ref","attrib":{"idref":"fn003961"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003961"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “Re-Prioritization of the U.S. Geological Survey Federal Priority Streamgage Network, 2022”."}],"tail":" (Open-file Report 2023–1032)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf25ceec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10367/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal share of the Federal priority streamgage network established pursuant to this subsection shall be 100 percent of the cost of carrying out the Federal priority streamgage network.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf25ceed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10367/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf25ceee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10367/a/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subparagraph (B), there are authorized to be appropriated such sums as are necessary to operate the Federal priority streamgage program for the period of fiscal years 2009 through 2028, to remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf25ceef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10367/a/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Network enhancement funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out the network enhancements described in paragraph (4) $10,000,000 for each of fiscal years 2009 through 2028, to remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf25cef0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10367/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National groundwater resources monitoring","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf25cef1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10367/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall develop a systematic groundwater monitoring program for each major aquifer system located in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf25cef2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10367/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program elements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In developing the monitoring program described in paragraph (1), the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf25cef3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10367/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish appropriate criteria for monitoring wells to ensure the acquisition of long-term, high-quality data sets, including, to the maximum extent possible, the inclusion of real-time instrumentation and reporting;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf25cef4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10367/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in coordination with the Advisory Committee and State and local water resource agencies and Tribes—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbf25cef5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10367/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assess the current scope of groundwater monitoring based on the access availability and capability of each monitoring well in existence as of ","children":[{"tag":"date","attrib":{"date":"2009-03-30"},"text":"March 30, 2009","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf25cef6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10367/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop and carry out a monitoring plan that maximizes coverage for each major aquifer system that is located in the United States; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf25cef7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10367/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prior to initiating any specific monitoring activities within a State or Tribal lands after ","children":[{"tag":"date","attrib":{"date":"2009-03-30"},"text":"March 30, 2009","children":[],"tail":", consult and coordinate with the applicable State water resource agency or Tribe with jurisdiction over the aquifer that is the subject of the monitoring activities, and comply with all applicable laws (including regulations) of the State."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf25cef8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10367/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program objectives","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the monitoring program described in paragraph (1), the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf25cef9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10367/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide data that is necessary for the improvement of understanding with respect to surface water and groundwater interactions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf25cefa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10367/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by expanding the network of monitoring wells to reach each climate division, support the groundwater climate response network to improve the understanding of the effects of global climate change on groundwater recharge and availability; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf25cefb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10367/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support the objectives of the assessment program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf25cefc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10367/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Improved methodologies","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf25cefd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10367/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve methodologies relating to the analysis and delivery of data; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf25cefe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10367/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" investigate, develop, and implement new methodologies and technologies to estimate or measure groundwater recharge, discharge, and storage in a more cost-efficient manner.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf25ceff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10367/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal share of the monitoring program described in paragraph (1) may be 100 percent of the cost of carrying out the monitoring program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf25cf00-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10367/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In selecting monitoring activities consistent with the monitoring program described in paragraph (1), the Secretary shall give priority to those activities for which a State, a Tribe or local governmental entity agrees to provide for a substantial share of the cost of establishing or operating a monitoring well or other measuring device to carry out a monitoring activity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf25cf01-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10367/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated $4,000,000 per fiscal year to carry out this subsection for the period of fiscal years 2023 through 2028, to remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf25cf02-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10367/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Improved water estimation, measurement, and monitoring technologies","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf25cf03-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10367/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of Secretary","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may provide grants on a nonreimbursable basis to appropriate entities with expertise in water resource data acquisition and reporting, including Federal agencies, the Water Resources Research Institutes and other academic institutions, and private entities, to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf25cf04-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10367/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" investigate, develop, and implement new methodologies and technologies to estimate or measure water resources data in a cost-efficient manner; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf25cf05-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10367/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve methodologies relating to the analysis and delivery of data.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf25cf06-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10367/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In providing grants to appropriate entities under paragraph (1), the Secretary shall give priority to appropriate entities that propose the development of new methods and technologies for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf25cf07-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10367/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" predicting and measuring streamflows;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf25cf08-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10367/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" estimating changes in the storage of groundwater;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf25cf09-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10367/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improving data standards and methods of analysis (including the validation of data entered into geographic information system databases);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf25cf0a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10367/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" measuring precipitation and potential evapotranspiration; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf25cf0b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10367/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" water withdrawals, return flows, and consumptive use.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf25cf0c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10367/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Partnerships","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In recognition of the value of collaboration to foster innovation and enhance research and development efforts, the Secretary shall encourage partnerships, including public-private partnerships, between and among Federal agencies, academic institutions, and private entities to promote the objectives described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf25cf0d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10367/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this subsection $5,000,000 for each of fiscal years 2009 through 2028.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf25cf0e-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11/tIX/s9507"},"text":"Pub. L. 111–11, title IX, § 9507","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-03-30"},"text":"Mar. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1339"},"text":"123 Stat. 1339","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/174/s2"},"text":"Pub. L. 118–174, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2602"},"text":"138 Stat. 2602","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf25cf0f-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf25cf10-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbf25cf11-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/174/s2/1/A"},"text":"Pub. L. 118–174, § 2(1)(A)","children":[],"tail":", substituted “Federal priority streamgage program” for “National streamflow information program” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/174/s2/1/B"},"text":"Pub. L. 118–174, § 2(1)(B)","children":[],"tail":", substituted “Federal priority streamgage program” for “national streamflow information program, as reviewed by the National Research Council in 2004”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/174/s2/1/C"},"text":"Pub. L. 118–174, § 2(1)(C)","children":[],"tail":", substituted “Federal priority streamgage program” for “national streamflow information program” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/174/s2/1/D/i/I"},"text":"Pub. L. 118–174, § 2(1)(D)(i)(I)","children":[],"tail":", substituted “2023” for “2009” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4)(A)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/174/s2/1/D/i/II"},"text":"Pub. L. 118–174, § 2(1)(D)(i)(II)","children":[],"tail":", inserted “precipitation” before “water-quality sensors”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/174/s2/1/D/ii"},"text":"Pub. L. 118–174, § 2(1)(D)(ii)","children":[],"tail":", which directed the substitution of “Federal needs established through regular solicitation of feedback, such as that documented in the report titled ‘Re-prioritization of the U.S. Geological Survey Federal Priority streamgage program, 2022’ (Open-file Report 2023–1032).” for “National Streamflow Information Program as reviewed by the National Research Council.” was executed by making the substitution for “National Streamflow Information Program plan as reviewed by the National Research Council.”, to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/174/s2/1/E"},"text":"Pub. L. 118–174, § 2(1)(E)","children":[],"tail":", substituted “Federal priority streamgage network” for “national streamgaging network” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(6)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/174/s2/1/F/i"},"text":"Pub. L. 118–174, § 2(1)(F)(i)","children":[],"tail":", substituted “Federal priority streamgage program” for “national streamflow information program” and “2028” for “2023”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(6)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/174/s2/1/F/ii"},"text":"Pub. L. 118–174, § 2(1)(F)(ii)","children":[],"tail":", substituted “2028” for “2019”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/174/s2/2/A/i"},"text":"Pub. L. 118–174, § 2(2)(A)(i)","children":[],"tail":", inserted “and Tribes” after “agencies” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/174/s2/2/A/ii"},"text":"Pub. L. 118–174, § 2(2)(A)(ii)","children":[],"tail":", inserted “or Tribal lands” after “within a State” and “or Tribe” after “water resource agency”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/174/s2/2/B"},"text":"Pub. L. 118–174, § 2(2)(B)","children":[],"tail":", inserted “, a Tribe” after “a State”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/174/s2/2/C"},"text":"Pub. L. 118–174, § 2(2)(C)","children":[],"tail":", substituted “$4,000,000 per fiscal year” for “such sums as are necessary” and “2023 through 2028” for “2009 through 2023”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/174/s2/3"},"text":"Pub. L. 118–174, § 2(3)","children":[],"tail":", (4), redesignated subsec. (d) as (c) and struck out former subsec. (c) which related to brackish groundwater assessment study and report."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/174/s2/5"},"text":"Pub. L. 118–174, § 2(5)","children":[],"tail":", substituted “2028” for “2019”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/174/s2/4"},"text":"Pub. L. 118–174, § 2(4)","children":[],"tail":", redesignated subsec. (d) as (c)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
