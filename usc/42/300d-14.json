{"tag":"section","attrib":{"id":"idb615dc60-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–14"},"text":null,"children":[{"tag":"num","attrib":{"value":"300d–14"},"text":"§ 300d–14.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement of submission to Secretary of trauma plan and certain information","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb615dc61-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–14/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For each fiscal year, the Secretary may not make payments to a State under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300d–11/a"},"text":"section 300d–11(a) of this title","children":[],"tail":" unless, subject to subsection (b), the State submits to the Secretary the trauma care component of the State plan for the provision of emergency medical services, including any changes to the trauma care component and any plans to address deficiencies in the trauma care component."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb615dc62-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–14/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interim plan or description of efforts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For each fiscal year, if a State has not completed the trauma care component of the State plan described in subsection (a), the State may provide, in lieu of such completed component, an interim component or a description of efforts made toward the completion of the component.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb615dc63-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–14/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information received by State reporting and analysis system","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may not make payments to a State under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300d–11/a"},"text":"section 300d–11(a) of this title","children":[],"tail":" unless the State agrees that the State will, not less than once each year, provide to the Secretary the information received by the State pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300d–13/a/7"},"text":"section 300d–13(a)(7) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb615dc64-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–14/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of emergency medical services in rural areas","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may not make payments to a State under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300d–11/a"},"text":"section 300d–11(a) of this title","children":[],"tail":" unless—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb615dc65-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–14/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the State identifies any rural area in the State for which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb615dc66-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–14/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is no system of access to emergency medical services through the telephone number 911;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb615dc67-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–14/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is no basic life-support system; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb615dc68-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–14/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is no advanced life-support system; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb615dc69-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–14/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State submits to the Secretary a list of rural areas identified pursuant to paragraph (1) or, if there are no such areas, a statement that there are no such areas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb615dc6a-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XII, § 1214, as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/590/s3"},"text":"Pub. L. 101–590, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2922"},"text":"104 Stat. 2922","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/23/s8"},"text":"Pub. L. 110–23, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-05-03"},"text":"May 3, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/96"},"text":"121 Stat. 96","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb615dc6b-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb615dc6c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb615dc6d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2007—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/23"},"text":"Pub. L. 110–23","children":[],"tail":" amended section generally. Prior to amendment, section related to requirement of submission to Secretary of trauma plan and certain information for fiscal year 1991 and subsequent fiscal years."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
