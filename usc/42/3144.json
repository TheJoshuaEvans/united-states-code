{"tag":"section","attrib":{"id":"idbc7247d2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3144"},"text":null,"children":[{"tag":"num","attrib":{"value":"3144"},"text":"§ 3144.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost sharing","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbc7247d3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3144/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal share","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subsection (c), the Federal share of the cost of any project carried out under this subchapter shall not exceed—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc74b7d4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3144/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 60 percent; plus","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc74b7d5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3144/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an additional percent that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc74b7d6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3144/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not exceed 30 percent; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc74b7d7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3144/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is based on the relative needs of the area in which the project will be located, as determined in accordance with regulations promulgated by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc74b7d8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3144/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-Federal share","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc74b7d9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3144/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In determining the amount of the non-Federal share of the cost of a project, the Secretary may provide credit toward the non-Federal share for all contributions both in cash and in-kind, fairly evaluated, including contributions of space, equipment, assumptions of debt, and services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc74b7da-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3144/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regional Commission funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, any funds contributed by a Regional Commission for a project under this subchapter may be considered to be part of the non-Federal share of the costs of the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc74b7db-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3144/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Increase in Federal share","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc74b7dc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3144/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian tribes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a grant to an Indian tribe for a project under this subchapter, the Secretary may increase the Federal share above the percentage specified in subsection (a) up to 100 percent of the cost of the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc74b7dd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3144/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain States, political subdivisions, and nonprofit organizations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a grant to a State, or a political subdivision of a State, that the Secretary determines has exhausted the effective taxing and borrowing capacity of the State or political subdivision or can otherwise document that no local matching funds are reasonably obtainable, or in the case of a grant to a nonprofit organization that the Secretary determines has exhausted the effective borrowing capacity of the nonprofit organization, the Secretary may increase the Federal share above the percentage specified in subsection (a) up to 100 percent of the cost of the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc74b7de-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3144/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training, research, and technical assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a grant provided under section 3143 or 3147 of this title, the Secretary may increase the Federal share above the percentage specified in subsection (a) up to 100 percent of the cost of the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc74b7df-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3144/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Small communities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a grant to a political subdivision of a State (as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3122/6/A/iv"},"text":"section 3122(6)(A)(iv) of this title","children":[],"tail":") that has a population of fewer than 10,000 residents and meets 1 or more of the eligibility criteria described in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3161/a"},"text":"section 3161(a) of this title","children":[],"tail":", the Secretary may increase the Federal share under paragraph (1) up to 100 percent of the total cost of the project."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc74b7e0-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/136/tII/s204"},"text":"Pub. L. 89–136, title II, § 204","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/393/tI/s102/a"},"text":"Pub. L. 105–393, title I, § 102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3603"},"text":"112 Stat. 3603","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/373/tII/s202"},"text":"Pub. L. 108–373, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-27"},"text":"Oct. 27, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1759"},"text":"118 Stat. 1759","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/272/dB/tII/s2215"},"text":"Pub. L. 118–272, div. B, title II, § 2215","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/3181"},"text":"138 Stat. 3181","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc74b7e1-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc74b7e2-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbc74b7e3-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 3144, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/136/tII/s204"},"text":"Pub. L. 89–136, title II, § 204","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/94/487/tI/s109"},"text":"Pub. L. 94–487, title I, § 109","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-12"},"text":"Oct. 12, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2333"},"text":"90 Stat. 2333","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/96/470/tI/s201/d"},"text":"Pub. L. 96–470, title I, § 201(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-19"},"text":"Oct. 19, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2241"},"text":"94 Stat. 2241","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/506/s1/4"},"text":"Pub. L. 96–506, § 1(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-08"},"text":"Dec. 8, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2745"},"text":"94 Stat. 2745","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tXVIII/s1821/a/3"},"text":"Pub. L. 97–35, title XVIII, § 1821(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/766"},"text":"95 Stat. 766","children":[],"tail":", authorized interest free loans to carry out approved redevelopment area plans, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/105/393/s102/a"},"text":"Pub. L. 105–393, § 102(a)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbc74b7e4-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272/s2215/1"},"text":"Pub. L. 118–272, § 2215(1)","children":[],"tail":", substituted “60” for “50”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272/s2215/2"},"text":"Pub. L. 118–272, § 2215(2)","children":[],"tail":", designated existing provisions as par. (1), inserted heading, and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272/s2215/3/A"},"text":"Pub. L. 118–272, § 2215(3)(A)","children":[],"tail":", inserted “or can otherwise document that no local matching funds are reasonably obtainable” after “or political subdivision”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272/s2215/3/B"},"text":"Pub. L. 118–272, § 2215(3)(B)","children":[],"tail":", substituted “section 3143 or 3147 of this title” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3147"},"text":"section 3147 of this title","children":[],"tail":"” and “project.” for “project if the Secretary determines that the project funded by the grant merits, and is not feasible without, such an increase.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272/s2215/3/C"},"text":"Pub. L. 118–272, § 2215(3)(C)","children":[],"tail":", added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/373/s202/a"},"text":"Pub. L. 108–373, § 202(a)","children":[],"tail":", added subsec. (a) and struck out heading and text of former subsec. (a). Text read as follows: “Subject to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3145"},"text":"section 3145 of this title","children":[],"tail":", the amount of a grant for a project under this subchapter shall not exceed 50 percent of the cost of the project.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/373/s202/b"},"text":"Pub. L. 108–373, § 202(b)","children":[],"tail":", inserted “assumptions of debt,” after “equipment,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/373/s202/c"},"text":"Pub. L. 108–373, § 202(c)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbc74b7e5-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbc74b7e6-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1999-02-11"},"text":"Feb. 11, 1999","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/393/s105"},"text":"section 105 of Pub. L. 105–393","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3121"},"text":"section 3121 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
