{"tag":"section","attrib":{"id":"idbc724766-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3132"},"text":null,"children":[{"tag":"num","attrib":{"value":"3132"},"text":"§ 3132.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperation of Federal agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In accordance with applicable laws and subject to the availability of appropriations, each Federal agency shall exercise its powers, duties and functions, and shall cooperate with the Secretary, in such manner as will assist the Secretary in carrying out this subchapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbc724767-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/136/tI/s102"},"text":"Pub. L. 89–136, title I, § 102","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/393/tI/s102/a"},"text":"Pub. L. 105–393, title I, § 102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3601"},"text":"112 Stat. 3601","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc724768-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc724769-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbc72476a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 3132, ","children":[{"tag":"ref","attrib":{"href":"/us/p