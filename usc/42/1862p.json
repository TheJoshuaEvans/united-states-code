{"tag":"section","attrib":{"id":"idbb8fb06d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862p"},"text":null,"children":[{"tag":"num","attrib":{"value":"1862p"},"text":"§ 1862p.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Center for Science and Engineering Statistics","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbb8fb06e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862p/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established within the Foundation a National Center for Science and Engineering Statistics that shall serve as a central Federal clearinghouse for the collection, interpretation, analysis, and dissemination of objective data on science, engineering, technology, and research and development.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb8fb06f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862p/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out subsection (a) of this section, the Director, acting through the Center shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb8fb070-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862p/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" collect, acquire, analyze, report, and disseminate statistical data related to the science and engineering enterprise in the United States and other nations that is relevant and useful to practitioners, researchers, policymakers, and the public, including statistical data on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbb8fb071-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862p/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" research and development trends;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb8fb072-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862p/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the science and engineering workforce;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb8fb073-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862p/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" United States competitiveness in science, engineering, technology, and research and development; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb8fb074-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862p/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the condition and progress of United States STEM education;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb8fb075-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862p/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support research using the data it collects, and on methodologies in areas related to the work of the Center; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb8fb076-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862p/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support the education and training of researchers in the use of large-scale, nationally representative data sets.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb8fb077-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862p/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statistical reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director or the National Science Board, acting through the Center, shall issue regular, and as necessary, special statistical reports on topics related to the national and international science and engineering enterprise such as the biennial report required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1863/j/1"},"text":"section 1863(j)(1) of this title","children":[],"tail":" on indicators of the state of science and engineering in the United States."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbb8fb078-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/358/tV/s505"},"text":"Pub. L. 111–358, title V, § 505","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4007"},"text":"124 Stat. 4007","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbb8fb079-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbb8fb07a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbb8fb07b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the America COMPETES Reauthorization Act of 2010, also known as the America Creating Opportunities to Meaningfully Promote Excellence in Technology, Education, and Science Reauthorization Act of 2010, and also as part of the National Science Foundation Authorization Act of 2010, and not as part of the National Science Foundation Act of 1950 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbb8fb07c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbb8fb07d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Research on Efficiency of Skilled Technical Labor Markets","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/402/s4"},"text":"Pub. L. 115–402, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-31"},"text":"Dec. 31, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5346"},"text":"132 Stat. 5346","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/402/s4"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Efficiency of Skilled Technical Labor Markets","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Director of the National Science Foundation, working through the Directorate of Social, Behavioral & Economic Sciences, in coordination with the Secretary of Labor, shall support research on labor market analysis innovations, data and information sciences, electronic information tools and methodologies, and metrics.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Skilled Technical Workforce.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Review","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The National Center for Science and Engineering Statistics of the National Science Foundation shall consult and coordinate with other relevant Federal statistical agencies, including the Institute of Education Sciences of the Department of Education, and the Committee on Science, Technology, Engineering, and Mathematics Education of the National Science and Technology Council established under section 101 of the America COMPETES [Reauthorization] Act of 2010 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/358"},"text":"Public Law 111–358","children":[],"tail":") ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s6621"},"text":"42 U.S.C. 6621","children":[],"tail":"], to explore the feasibility of expanding its surveys to include the collection of objective data on the skilled technical workforce."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 1 year after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2018-12-31"},"text":"Dec. 31, 2018","children":[],"tail":"], the Director of the National Science Foundation shall submit to Congress a report on the progress made in expanding the National Center for Science and Engineering Statistics surveys to include the skilled technical workforce, including a plan for multi-agency collaboration to improve data collection and reporting of data on the skilled technical workforce."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition of skilled technical workforce","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘ “skilled technical workforce” ’ [sic] means workers with high school diplomas and two-year technical training or certifications who employ significant levels of STEM knowledge in their jobs.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idbb8fb07e-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definition of “STEM” as used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/358/s2"},"text":"section 2 of Pub. L. 111–358","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s6621"},"text":"section 6621 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/358/tV/s502"},"text":"Pub. L. 111–358, title V, § 502","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4005"},"text":"124 Stat. 4005","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/114/329/tI/s103/e/1"},"text":"Pub. L. 114–329, title I, § 103(e)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-01-06"},"text":"Jan. 6, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2975"},"text":"130 Stat. 2975","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/329/tI/s103/e/1"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“In this subtitle [subtitle A (§§ 501–527) of title V of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/358"},"text":"Pub. L. 111–358","children":[],"tail":", enacting this section and sections 1862p–1 to 1862p–15 of this title, amending sections 1862n–1a, 1862n–5, 1863, and 1869 of this title, and enacting provisions set out as notes under sections 1862p and 1869 of this title]:"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Director","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘Director’ means the Director of the National Science Foundation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"EPSCoR","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term ‘EPSCoR’ means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Established Program to Stimulate Competitive Research established by the Foundation; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a program similar to the Established Program to Stimulate Competitive Research at another Federal agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Foundation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘Foundation’ means the National Science Foundation established under section 2 of the National Science Foundation Act of 1950 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1861"},"text":"42 U.S.C. 1861","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Institution of higher education","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘institution of higher education’ has the meaning given such term in section 101(a) of the Higher Education Act of 1965 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001/a"},"text":"20 U.S.C. 1001(a)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"State","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘State’ means one of the several States, the District of Columbia, the Commonwealth of Puerto Rico, the Virgin Islands, Guam, American Samoa, the Commonwealth of the Northern Mariana Islands, or any other territory or possession of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"“(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"United States","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘United States’ means the several States, the District of Columbia, the Commonwealth of Puerto Rico, the Virgin Islands, Guam, American Samoa, the Commonwealth of the Northern Mariana Islands, and any other territory or possession of the United States.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
