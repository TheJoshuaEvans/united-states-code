{"tag":"section","attrib":{"id":"idbdeb04dc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6991k"},"text":null,"children":[{"tag":"num","attrib":{"value":"6991k"},"text":"§ 6991k.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Delivery prohibition","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbdeb04dd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6991k/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbdeb04de-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6991k/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition of delivery or deposit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Beginning 2 years after ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":", it shall be unlawful to deliver to, deposit into, or accept a regulated substance into an underground storage tank at a facility which has been identified by the Administrator or a State implementing agency to be ineligible for such delivery, deposit, or acceptance."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdeb04df-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6991k/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guidance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Within 1 year after ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":", the Administrator shall, in consultation with the States, underground storage tank owners, and product delivery industries, publish guidelines detailing the specific processes and procedures they will use to implement the provisions of this section. The processes and procedures include, at a minimum—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbdeb04e0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6991k/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the criteria for determining which underground storage tank facilities are ineligible for delivery, deposit, or acceptance of a regulated substance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbdeb04e1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6991k/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the mechanisms for identifying which facilities are ineligible for delivery, deposit, or acceptance of a regulated substance to the underground storage tank owning and fuel delivery industries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbdeb04e2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6991k/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the process for reclassifying ineligible facilities as eligible for delivery, deposit, or acceptance of a regulated substance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbdeb04e3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6991k/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one or more processes for providing adequate notice to underground storage tank owners and operators and supplier industries that an underground storage tank has been determined to be ineligible for delivery, deposit, or acceptance of a regulated substance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbdeb04e4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6991k/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a delineation of, or a process for determining, the specified geographic areas subject to paragraph (4).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdeb04e5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6991k/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compliance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"States that receive funding under this subchapter shall, at a minimum, comply with the processes and procedures published under paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdeb04e6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6991k/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consideration","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbdeb04e7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6991k/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rural and remote areas","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subparagraph (B), the Administrator or a State may consider not treating an underground storage tank as ineligible for delivery, deposit, or acceptance of a regulated substance if such treatment would jeopardize the availability of, or access to, fuel in any rural and remote areas unless an urgent threat to public health, as determined by the Administrator, exists.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbdeb04e8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6991k/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subparagraph (A) shall apply only during the 180-day period following the date of a determination by the Administrator or the appropriate State under subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdeb04e9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6991k/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect on State authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall affect or preempt the authority of a State to prohibit the delivery, deposit, or acceptance of a regulated substance to an underground storage tank.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdeb04ea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6991k/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Defense to violation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A person shall not be in violation of subsection (a)(1) if the person has not been provided with notice pursuant to subsection (a)(2)(D) of the ineligibility of a facility for delivery, deposit, or acceptance of a regulated substance as determined by the Administrator or a State, as appropriate, under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbdeb04eb-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/272/tII/s9012"},"text":"Pub. L. 89–272, title II, § 9012","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/58/tXV/s1527/a"},"text":"Pub. L. 109–58, title XV, § 1527(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1098"},"text":"119 Stat. 1098","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/168/s1/a/1"},"text":"Pub. L. 109–168, § 1(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-10"},"text":"Jan. 10, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3580"},"text":"119 Stat. 3580","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbdeb04ec-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbdeb04ed-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbdeb04ee-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (a)(2)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/168"},"text":"Pub. L. 109–168","children":[],"tail":" substituted “of a regulated” for “or a regulated”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
