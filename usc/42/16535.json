{"tag":"section","attrib":{"id":"idc01b5231-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16535"},"text":null,"children":[{"tag":"num","attrib":{"value":"16535"},"text":"§ 16535.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Discovery science and engineering innovation institutes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc01b5232-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16535/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall establish distributed, multidisciplinary institutes (referred to in this section as “Institutes”) centered at National Laboratories to apply fundamental science and engineering discoveries to technological innovations relating to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc01b5233-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16535/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the missions of the Department; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc01b5234-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16535/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the global competitiveness of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc01b5235-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16535/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Topical areas","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Institutes shall support scientific and engineering research and education activities on critical emerging technologies determined by the Secretary to be essential to global competitiveness, including activities relating to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc01b5236-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16535/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sustainable energy technologies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc01b5237-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16535/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" multiscale materials and processes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc01b5238-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16535/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" micro- and nano-engineering;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc01b5239-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16535/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" computational and information engineering; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc01b523a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16535/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" genomics and proteomics.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc01b523b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16535/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Partnerships","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out this section, the Secretary shall establish partnerships between the Institutes and—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc01b523c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16535/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" institutions of higher education—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc01b523d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16535/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to train undergraduate and graduate science and engineering students;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc01b523e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16535/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop innovative undergraduate and graduate educational curricula; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc01b523f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16535/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to conduct research within the topical areas described in subsection (b); and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc01b5240-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16535/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" private industry to develop innovative technologies within the topical areas described in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc01b5241-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16535/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc01b5242-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16535/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For each fiscal year, the Secretary may select not more than 3 Institutes to receive a grant under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc01b5243-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16535/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Merit-based selection","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The selection of Institutes under paragraph (1) shall be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc01b5244-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16535/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" merit-based; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc01b5245-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16535/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" made through an open, competitive selection process.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc01b5246-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16535/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An Institute shall receive a grant under this section for not more than 3 fiscal years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc01b5247-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16535/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall offer to enter into an agreement with the National Academy of Sciences under which the Academy shall, by not later than 3 years after ","children":[{"tag":"date","attrib":{"date":"2007-08-09"},"text":"August 9, 2007","children":[],"tail":"—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc01b5248-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16535/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review the performance of the Institutes under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc01b5249-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16535/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit to Congress and the Secretary a report describing the results of the review.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc01b524a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16535/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to provide grants to each Institute selected under this section $10,000,000 for each of fiscal years 2008 through 2010.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc01b524b-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/69/tV/s5008"},"text":"Pub. L. 110–69, title V, § 5008","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-08-09"},"text":"Aug. 9, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/618"},"text":"121 Stat. 618","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
