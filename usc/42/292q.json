{"tag":"section","attrib":{"id":"idb5d30795-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s292q"},"text":null,"children":[{"tag":"num","attrib":{"value":"292q"},"text":"§ 292q.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreements for operation of school loan funds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5d30796-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s292q/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fund agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to enter into an agreement for the establishment and operation of a student loan fund in accordance with this subpart with any public or other nonprofit school of medicine, osteopathic medicine, dentistry, pharmacy, podiatric medicine, optometry, or veterinary medicine.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5d30797-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s292q/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each agreement entered into under this section shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5d30798-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s292q/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for establishment of a student loan fund by the school;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5d30799-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s292q/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide for deposit in the fund of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5d3079a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s292q/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal capital contributions to the fund;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5d3079b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s292q/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an amount equal to not less than one-ninth of such Federal capital contributions, contributed by such institution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5d3079c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s292q/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collections of principal and interest on loans made from the fund;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5d3079d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s292q/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collections pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s292r/j"},"text":"section 292r(j) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5d3079e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s292q/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other earnings of the fund;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5d3079f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s292q/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide that the fund shall be used only for loans to students of the school in accordance with the agreement and for costs of collection of such loans and interest thereon;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5d307a0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s292q/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide that loans may be made from such funds only to students pursuing a full-time course of study at the school leading to a degree of doctor of medicine, doctor of dentistry or an equivalent degree, doctor of osteopathy, bachelor of science in pharmacy or an equivalent degree, doctor of pharmacy or an equivalent degree, doctor of podiatric medicine or an equivalent degree, doctor of optometry or an equivalent degree, or doctor of veterinary medicine or an equivalent degree;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5d307a1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s292q/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide that the school shall advise, in writing, each applicant for a loan from the student loan fund of the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s292r"},"text":"section 292r of this title","children":[],"tail":" under which outstanding loans from the student loan fund may be paid (in whole or in part) by the Secretary; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5d307a2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s292q/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contain such other provisions as are necessary to protect the financial interests of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5d307a3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s292q/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure of school to collect loans","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5d307a4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s292q/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any standard established by the Secretary by regulation for the collection by schools of medicine, osteopathic medicine, dentistry, pharmacy, podiatric medicine, optometry, or veterinary medicine of loans made pursuant to loan agreements under this subpart shall provide that the failure of any such school to collect such loans shall be measured in accordance with this subsection. This subsection may not be construed to require such schools to reimburse the student loan fund under this subpart for loans that became uncollectible prior to August 1985 or to penalize such schools with respect to such loans.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5d307a5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s292q/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extent of failure","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The measurement of a school’s failure to collect loans made under this subpart shall be the ratio (stated as a percentage) that the defaulted principal amount outstanding of such school bears to the matured loans of such school.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5d307a6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s292q/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5d307a7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s292q/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “default” means the failure of a borrower of a loan made under this subpart to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb5d307a8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s292q/c/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make an installment payment when due; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5d307a9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s292q/c/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" comply with any other term of the promissory note for such loan,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"except that a loan made under this subpart shall not be considered to be in default if the loan is discharged in bankruptcy or if the school reasonably concludes from written contracts with the borrower that the borrower intends to repay the loan.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5d307aa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s292q/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “defaulted principal amount outstanding” means the total amount borrowed from the loan fund of a school that has reached the repayment stage (minus any principal amount repaid or canceled) on loans—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb5d307ab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s292q/c/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" repayable monthly and in default for at least 120 days; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5d307ac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s292q/c/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" repayable less frequently than monthly and in default for at least 180 days;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5d307ad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s292q/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “grace period” means the period of one year beginning on the date on which the borrower ceases to pursue a full-time course of study at a school of medicine, osteopathic medicine, dentistry, pharmacy, podiatric medicine, optometry, or veterinary medicine; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5d307ae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s292q/c/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “matured loans” means the total principal amount of all loans made by a school under this subpart minus the total principal amount of loans made by such school to students who are—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb5d307af-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s292q/c/3/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enrolled in a full-time course of study at such school; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5d307b0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s292q/c/3/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in their grace period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5d307b1-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title VII, § 721, as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/408/tI/s102"},"text":"Pub. L. 102–408, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-13"},"text":"Oct. 13, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2011"},"text":"106 Stat. 2011","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb5d307b2-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb5d307b3-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb5d307b4-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 721 of act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s293a"},"text":"section 293a of this title","children":[],"tail":" prior to the general revision of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/102/408"},"text":"Pub. L. 102–408","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
