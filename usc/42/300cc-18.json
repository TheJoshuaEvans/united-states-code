{"tag":"section","attrib":{"id":"idb685dc2b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–18"},"text":null,"children":[{"tag":"num","attrib":{"value":"300cc–18"},"text":"§ 300cc–18.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Development of model protocols for clinical care of infected individuals","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb685dc2c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–18/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb685dc2d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–18/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary, acting through the Director of the National Institutes of Health and after consultation with the Director of the Agency for Healthcare Research and Quality, may make grants to public and nonprofit private entities for the establishment of projects to develop model protocols for the clinical care of individuals infected with the etiologic agent for acquired immune deficiency syndrome, including treatment and prevention of HIV infection and related conditions among women.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb685dc2e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–18/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary may not make a grant under paragraph (1) unless—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb685dc2f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–18/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the applicant for the grant is a provider of comprehensive primary care; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb685dc30-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–18/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the applicant for the grant agrees, with respect to the project carried out pursuant to paragraph (1), to enter into a cooperative arrangement with an entity that is a provider of comprehensive primary care.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb685dc31-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–18/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement of provision of certain services","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may not make a grant under subsection (a) unless the applicant for the grant agrees that, with respect to patients participating in the project carried out with the grant, services provided pursuant to the grant will include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb685dc32-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–18/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" monitoring, in clinical laboratories, of the condition of such patients;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb685dc33-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–18/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" clinical intervention for infection with the etiologic agent for acquired immune deficiency syndrome, including measures for the prevention of conditions arising from the infection;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb685dc34-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–18/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information and counseling on the availability of treatments for such infection approved by the Commissioner of Food and Drugs, on the availability of treatments for such infection not yet approved by the Commissioner, and on the reports issued by the AIDS Research Advisory Committee under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300cc–3/c/2/B"},"text":"section 300cc–3(c)(2)(B) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb685dc35-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–18/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support groups; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb685dc36-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–18/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information on, and referrals to, entities providing appropriate social support services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb685dc37-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–18/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on imposition of charges for services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may not make a grant under subsection (a) unless the applicant for the grant agrees that, if the applicant will routinely impose a charge for providing services pursuant to the grant, the applicant will not impose the charge on any individual seeking such services who is unable to pay the charge.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb685dc38-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–18/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation and reports","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb685dc39-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–18/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary may not make a grant under subsection (a) unless the applicant for the grant agrees, with respect to the project carried out pursuant to subsection (a), to submit to the Secretary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb685dc3a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–18/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information sufficient to assist in the replication of the model protocol developed pursuant to the project; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb685dc3b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–18/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such reports as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb685dc3c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–18/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall provide for evaluations of projects carried out pursuant to subsection (a) and shall annually submit to the Congress a report describing such projects. The report shall include the findings made as a result of such evaluations and may include any recommendations of the Secretary for appropriate administrative and legislative initiatives with respect to the program established in this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb685dc3d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–18/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of carrying out this section, there are authorized to be appropriated such sums as may be necessary for each of the fiscal years 1989 through 1991, and such sums as may be necessary for each of the fiscal years 1994 through 1996.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb685dc3e-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XXIII, § 2318, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/607/tII/s201/4"},"text":"Pub. L. 100–607, title II, § 201(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-04"},"text":"Nov. 4, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3073"},"text":"102 Stat. 3073","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/43/tXVIII/s1811/4"},"text":"Pub. L. 103–43, title XVIII, § 1811(4)","children":[],"tail":", title XX, § 2008(d)(5), "},{"tag":"date","attrib":{"date":"1993-06-10"},"text":"June 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/199"},"text":"107 Stat. 199","children":[],"tail":", 212; "},{"tag":"ref","attrib":{"href":"/us/pl/106/129/s2/b/2"},"text":"Pub. L. 106–129, § 2(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-12-06"},"text":"Dec. 6, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1670"},"text":"113 Stat. 1670","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb685dc3f-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb685dc40-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb685dc41-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1999—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/129"},"text":"Pub. L. 106–129","children":[],"tail":" substituted “Director of the Agency for Healthcare Research and Quality” for “Administrator for Health Care Policy and Research”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/43/s1811/4/A"},"text":"Pub. L. 103–43, § 1811(4)(A)","children":[],"tail":", inserted “, acting through the Director of the National Institutes of Health and after consultation with the Administrator for Health Care Policy and Research,” after “The Secretary” and “, including treatment and prevention of HIV infection and related conditions among women” after “syndrome”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/43/s2008/d/5"},"text":"Pub. L. 103–43, § 2008(d)(5)","children":[],"tail":", substituted “AIDS Research Advisory Committee” for “Clinical Research Review Committee”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/43/s1811/4/B"},"text":"Pub. L. 103–43, § 1811(4)(B)","children":[],"tail":", inserted before period at end “, and such sums as may be necessary for each of the fiscal years 1994 through 1996”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb685dc42-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb685dc43-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Reporting Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For termination, effective ","children":[{"tag":"date","attrib":{"date":"2000-05-15"},"text":"May 15, 2000","children":[],"tail":", of provisions in subsec. (d)(2) of this section relating to annual submission to Congress of reports describing projects carried out pursuant to subsec. (a) of this section, see "},{"tag":"ref","attrib":{"href":"/us/pl/104/66/s3003"},"text":"section 3003 of Pub. L. 104–66","children":[],"tail":", as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1113"},"text":"section 1113 of Title 31","children":[],"tail":", Money and Finance, and page 94 of House Document No. 103–7."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
