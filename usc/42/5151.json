{"tag":"section","attrib":{"id":"idbd0f99c4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5151"},"text":null,"children":[{"tag":"num","attrib":{"value":"5151"},"text":"§ 5151.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nondiscrimination in disaster assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd0f99c5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5151/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations for equitable and impartial relief operations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall issue, and may alter and amend, such regulations as may be necessary for the guidance of personnel carrying out Federal assistance functions at the site of a major disaster or emergency. Such regulations shall include provisions for insuring that the distribution of supplies, the processing of applications, and other relief and assistance activities shall be accomplished in an equitable and impartial manner, without discrimination on the grounds of race, color, religion, nationality, sex, age, disability, English proficiency, or economic status.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd0f99c6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5151/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compliance with regulations as prerequisite to participation by other bodies in relief operations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As a condition of participation in the distribution of assistance or supplies under this chapter or of receiving assistance under this chapter, governmental bodies and other organizations shall be required to comply with regulations relating to nondiscrimination promulgated by the President, and such other regulations applicable to activities within an area affected by a major disaster or emergency as he deems necessary for the effective coordination of relief efforts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd0f99c7-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/288/tIII/s308"},"text":"Pub. L. 93–288, title III, § 308","children":[],"tail":", formerly § 311, "},{"tag":"date","attrib":{"date":"1974-05-22"},"text":"May 22, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/150"},"text":"88 Stat. 150","children":[],"tail":"; renumbered § 308 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/707/tI/s105/f"},"text":"Pub. L. 100–707, title I, § 105(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-23"},"text":"Nov. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4691"},"text":"102 Stat. 4691","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/295/tVI/s689a"},"text":"Pub. L. 109–295, title VI, § 689a","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-04"},"text":"Oct. 4, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1449"},"text":"120 Stat. 1449","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd0f99c8-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd0f99c9-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbd0f99ca-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (b), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/288"},"text":"Pub. L. 93–288","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-05-22"},"text":"May 22, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/143"},"text":"88 Stat. 143","children":[],"tail":". For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5121"},"text":"section 5121 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbd0f99cb-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/288/s308"},"text":"section 308 of Pub. L. 93–288","children":[],"tail":" was renumbered section 305 by "},{"tag":"ref","attrib":{"href":"/us/pl/100/707"},"text":"Pub. L. 100–707","children":[],"tail":" and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5148"},"text":"section 5148 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd0f99cc-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/295"},"text":"Pub. L. 109–295","children":[],"tail":" inserted “disability, English proficiency,” after “age,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/707"},"text":"Pub. L. 100–707","children":[],"tail":" substituted “this chapter” for “section 5172 or 5174 of this title” after “assistance under”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
