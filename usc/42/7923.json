{"tag":"section","attrib":{"id":"idbe77b3af-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7923"},"text":null,"children":[{"tag":"num","attrib":{"value":"7923"},"text":"§ 7923.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation of contractual authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The authority under this subchapter to enter into contracts or other obligations requiring the United States to make outlays may be exercised only to the extent provided in advance in annual authorization and appropriation Acts.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbe77b3b0-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/604/tI/s113"},"text":"Pub. L. 95–604, title I, § 113","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-08"},"text":"Nov. 8, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3031"},"text":"92 Stat. 3031","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
