{"tag":"section","attrib":{"id":"idc06c806a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18841"},"text":null,"children":[{"tag":"num","attrib":{"value":"18841"},"text":"§ 18841.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Survey, analysis, and report on employment and demographics in the energy, energy efficiency, and motor vehicle sectors of the United States","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc06c806b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18841/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Energy Jobs Council","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc06c806c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18841/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a council, to be known as the “Energy Jobs Council” (referred to in this section as the “Council”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06c806d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18841/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Council shall be comprised of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc06c806e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18841/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to be appointed by the Secretary—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc06c806f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18841/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 or more representatives of the Energy Information Administration; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc06c8070-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18841/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 or more representatives of a State energy office that are serving as members of the State Energy Advisory Board established by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6325/g"},"text":"section 6325(g) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06c8071-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18841/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to be appointed by the Secretary of Commerce—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc06c8072-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18841/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 or more representatives of the Department of Commerce; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc06c8073-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18841/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 or more representatives of the Bureau of the Census;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06c8074-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18841/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 or more representatives of the Bureau of Labor Statistics, to be appointed by the Secretary of Labor; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06c8075-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18841/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 or more representatives of any other Federal agency the assistance of which is required to carry out this section, as determined by the Secretary, to be appointed by the head of the applicable agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc06c8076-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18841/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Survey and analysis","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc06c8077-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18841/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Council shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc06c8078-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18841/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct a survey of employers in the energy, energy efficiency, and motor vehicle sectors of the economy of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06c8079-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18841/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" perform an analysis of the employment figures and demographics in those sectors, including the number of personnel in each sector who devote a substantial portion of working hours, as determined by the Secretary, to regulatory compliance matters.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06c807a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18841/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Methodology","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In conducting the survey and analysis under paragraph (1), the Council shall employ a methodology that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc06c807b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18841/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was approved in 2016 by the Office of Management and Budget for use in the document entitled “OMB Control Number 1910–5179”;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06c807c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18841/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" uses a representative, stratified sampling of businesses in the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06c807d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18841/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is designed to elicit a comparable number of responses from businesses in each State and with the same North American Industry Classification System codes as were received for the 2016 and 2017 reports entitled “U.S. Energy and Employment Report”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06c807e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18841/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In conducting the survey and analysis under paragraph (1), the Council shall consult with key stakeholders, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc06c807f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18841/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" as the Council determines to be appropriate, the heads of relevant Federal agencies and offices, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc06c8080-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18841/b/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Commerce;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc06c8081-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18841/b/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Transportation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc06c8082-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18841/b/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Director of the Bureau of the Census;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc06c8083-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18841/b/3/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Commissioner of the Bureau of Labor Statistics; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc06c8084-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18841/b/3/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Administrator of the Environmental Protection Agency;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06c8085-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18841/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06c8086-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18841/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State Energy Advisory Board established by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6325/g"},"text":"section 6325(g) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06c8087-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18841/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" energy industry trade associations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc06c8088-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18841/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc06c8089-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18841/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2021-11-15"},"text":"November 15, 2021","children":[],"tail":", and annually thereafter, the Secretary shall—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc06c808a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18841/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make publicly available on the website of the Department a report, to be entitled the “U.S. Energy and Employment Report”, describing the employment figures and demographics in the energy, energy efficiency, and motor vehicle sectors of the United States, and the average number of hours devoted to regulatory compliance, based on the survey and analysis conducted under subsection (b); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06c808b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18841/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to the requirements of subchapter III of chapter 35 of title 44, make the data collected by the Council publicly available on the website of the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06c808c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18841/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc06c808d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18841/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The report under paragraph (1) shall include employment figures and demographic data for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc06c808e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18841/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the energy sector of the economy of the United States, including—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idc06c808f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18841/c/2/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the electric power generation and fuels sector; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc06c8090-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18841/c/2/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the transmission, storage, and distribution sector;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc06c8091-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18841/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the energy efficiency sector of the economy of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc06c8092-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18841/c/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the motor vehicle sector of the economy of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06c8093-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18841/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusion","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to each sector described in subparagraph (A), the report under paragraph (1) shall include employment figures and demographic data sorted by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc06c8094-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18841/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each technology, subtechnology, and fuel type of those sectors; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc06c8095-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18841/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" subject to the requirements of the Confidential Information Protection and Statistical Efficiency Act of 2002 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t44/s3501"},"text":"44 U.S.C. 3501","children":[],"tail":" note; "},{"tag":"ref","attrib":{"href":"/us/pl/107/347"},"text":"Public Law 107–347","children":[],"tail":")—"}],"tail":null},{"tag":"subclause","attrib":{"id":"idc06c8096-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18841/c/2/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc06c8097-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18841/c/2/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each territory of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc06c8098-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18841/c/2/B/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the District of Columbia; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc06c8099-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18841/c/2/B/ii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each county (or equivalent jurisdiction) in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc06c809a-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dD/tV/s40553"},"text":"Pub. L. 117–58, div. D, title V, § 40553","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1076"},"text":"135 Stat. 1076","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc06c809b-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc06c809c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc06c809d-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Confidential Information Protection and Statistical Efficiency Act of 2002, referred to in subsec. (c)(2)(B)(ii), is title V of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/347"},"text":"Pub. L. 107–347","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-17"},"text":"Dec. 17, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2962"},"text":"116 Stat. 2962","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t44/s3501"},"text":"section 3501 of Title 44","children":[],"tail":", Public Printing and Documents."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc06c809e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc06c809f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Wage Rate Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions relating to rates of wages to be paid to laborers and mechanics on projects for construction, alteration, or repair work funded under div. D or an amendment by div. D of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":", including authority of Secretary of Labor, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s18851"},"text":"section 18851 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
