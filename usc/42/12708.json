{"tag":"section","attrib":{"id":"idbf983f52-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12708"},"text":null,"children":[{"tag":"num","attrib":{"value":"12708"},"text":"§ 12708.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compliance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf983f53-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12708/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Performance reports","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf983f54-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12708/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each participating jurisdiction shall annually review and report, in a form acceptable to the Secretary, on the progress it has made in carrying out its housing strategy, which report shall include an evaluation of the jurisdiction’s progress in meeting its goal established in section 12705(b)(15) ","children":[{"tag":"ref","attrib":{"idref":"fn004104"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004104"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title, and information on the number and types of households served, including the number of very low-income, low-income, and moderate-income persons served and the racial and ethnic status of persons served that will be assisted with funds made available."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf983f55-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12708/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall (A) establish dates for submission of reports under this subsection, and (B) review such reports and make such recommendations as the Secretary deems appropriate to carry out the purposes of this Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf983f56-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12708/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a jurisdiction fails to submit a report satisfactory to the Secretary in a timely manner, assistance to the jurisdiction under subchapter II of this chapter or the other programs referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12706"},"text":"section 12706 of this title","children":[],"tail":" may be—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf983f57-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12708/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" suspended until a report satisfactory to the Secretary is submitted; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf983f58-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12708/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" withdrawn and reallocated if the Secretary finds, after notice and opportunity for a hearing, that the jurisdiction will not submit a satisfactory report.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf983f59-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12708/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Performance review by Secretary","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf983f5a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12708/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall ensure that activities of each jurisdiction required to submit a housing strategy under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12705"},"text":"section 12705 of this title","children":[],"tail":" are reviewed not less frequently than annually. Such review shall include, insofar as practicable, on-site visits by employees of the Department of Housing and Urban Development and shall include an assessment of the jurisdiction’s—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf983f5b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12708/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" management of funds made available under programs administered by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf983f5c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12708/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compliance with its housing strategy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf983f5d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12708/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accuracy in the preparation of performance reports under subsection (a); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf983f5e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12708/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" efforts to ensure that housing assisted under programs administered by the Secretary are in compliance with contractual agreements and the requirements of law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf983f5f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12708/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report by Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall report on the performance review in writing. The Secretary shall give the jurisdiction not less than 30 days to review and comment on the report. After taking into consideration the comments of the jurisdiction, the Secretary may revise the report and shall make the jurisdiction’s comments and the report, with any revisions, readily available to the public within 30 days after receipt of the jurisdiction’s comments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf9ab060-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12708/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review by courts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The adequacy of information submitted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12705/b/4"},"text":"section 12705(b)(4) of this title","children":[],"tail":" shall not be reviewable by any Federal, State, or other court. Review of a housing strategy by any Federal, State, or other court shall be limited to determining whether the process of development and the content of the strategy are in substantial compliance with the requirements of this Act. During the pendency of any action challenging the adequacy of a housing strategy or the action of the Secretary in approving a strategy, the court shall not have the authority to enjoin activities taken by the jurisdiction to implement an approved housing strategy. Any housing assisted during the pendency of such action shall not be subject to any order of the court resulting from such action."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf9ab061-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/625/tI/s108"},"text":"Pub. L. 101–625, title I, § 108","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4092"},"text":"104 Stat. 4092","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf9ab062-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf9ab063-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbf9ab064-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12705/b/15"},"text":"Section 12705(b)(15) of this title","children":[],"tail":", referred to in subsec. (a)(1), was redesignated "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12705/b/16"},"text":"section 12705(b)(16) of this title","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/102/550/tII/s220/c/1"},"text":"Pub. L. 102–550, title II, § 220(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3762"},"text":"106 Stat. 3762","children":[],"tail":", and was subsequently redesignated "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12705/b/18"},"text":"section 12705(b)(18) of this title","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/105/276/tV/s583/4/A"},"text":"Pub. L. 105–276, title V, § 583(4)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2644"},"text":"112 Stat. 2644","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This Act, referred to in subsecs. (a)(2) and (c), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/625"},"text":"Pub. L. 101–625","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4079"},"text":"104 Stat. 4079","children":[],"tail":", known as the Cranston-Gonzalez National Affordable Housing Act. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12701"},"text":"section 12701 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
