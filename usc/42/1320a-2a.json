{"tag":"section","attrib":{"id":"idb82bc455-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–2a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1320a–2a"},"text":"§ 1320a–2a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reviews of child and family services programs, and of foster care and adoption assistance programs, for conformity with State plan requirements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb82bc456-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–2a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, in consultation with the State agencies administering the State programs under parts B and E of subchapter IV, shall promulgate regulations for the review of such programs to determine whether such programs are in substantial conformity with—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb82bc457-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–2a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State plan requirements under such parts B and E,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb82bc458-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–2a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" implementing regulations promulgated by the Secretary, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb82bc459-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–2a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the relevant approved State plans.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb82bc45a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–2a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Elements of review system","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The regulations referred to in subsection (a) shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb82bc45b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–2a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" specify the timetable for conformity reviews of State programs, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb82bc45c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–2a/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an initial review of each State program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb82bc45d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–2a/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a timely review of a State program following a review in which such program was found not to be in substantial conformity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb82bc45e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–2a/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" less frequent reviews of State programs which have been found to be in substantial conformity, but such regulations shall permit the Secretary to reinstate more frequent reviews based on information which indicates that a State program may not be in conformity;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb82bc45f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–2a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specify the requirements subject to review (which shall include determining whether the State program is in conformity with the requirement of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s671/a/27"},"text":"section 671(a)(27) of this title","children":[],"tail":"), and the criteria to be used to measure conformity with such requirements and to determine whether there is a substantial failure to so conform;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb82bc460-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–2a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" specify the method to be used to determine the amount of any Federal matching funds to be withheld (subject to paragraph (4)) due to the State program’s failure to so conform, which ensures that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb82bc461-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–2a/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such funds will not be withheld with respect to a program, unless it is determined that the program fails substantially to so conform;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb82bc462-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–2a/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such funds will not be withheld for a failure to so conform resulting from the State’s reliance upon and correct use of formal written statements of Federal law or policy provided to the State by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb82bc463-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–2a/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of such funds withheld is related to the extent of the failure to so conform; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb82bc464-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–2a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" require the Secretary, with respect to any State program found to have failed substantially to so conform—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb82bc465-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–2a/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to afford the State an opportunity to adopt and implement a corrective action plan, approved by the Secretary, designed to end the failure to so conform;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb82bc466-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–2a/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to make technical assistance available to the State to the extent feasible to enable the State to develop and implement such a corrective action plan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb82bc467-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–2a/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to suspend the withholding of any Federal matching funds under this section while such a corrective action plan is in effect; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb82bc468-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–2a/b/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to rescind any such withholding if the failure to so conform is ended by successful completion of such a corrective action plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb82bc469-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–2a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provisions for administrative and judicial review","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The regulations referred to in subsection (a) shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb82bc46a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–2a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" require the Secretary, not later than 10 days after a final determination that a program of the State is not in conformity, to notify the State of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb82bc46b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–2a/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the basis for the determination; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb82bc46c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–2a/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of the Federal matching funds (if any) to be withheld from the State;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb82bc46d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–2a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" afford the State an opportunity to appeal the determination to the Departmental Appeals Board within 60 days after receipt of the notice described in paragraph (1) (or, if later, after failure to continue or to complete a corrective action plan); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb82bc46e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–2a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" afford the State an opportunity to obtain judicial review of an adverse decision of the Board, within 60 days after the State receives notice of the decision of the Board, by appeal to the district court of the United States for the judicial district in which the principal or headquarters office of the agency responsible for administering the program is located.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb82bc46f-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title XI, § 1123A, formerly § 1123, as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/432/tII/s203/a"},"text":"Pub. L. 103–432, title II, § 203(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-31"},"text":"Oct. 31, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4454"},"text":"108 Stat. 4454","children":[],"tail":"; renumbered § 1123A, "},{"tag":"ref","attrib":{"href":"/us/pl/104/193/tV/s504"},"text":"Pub. L. 104–193, title V, § 504","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-22"},"text":"Aug. 22, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2278"},"text":"110 Stat. 2278","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/432/dB/tIV/s405/c/1/B/ii"},"text":"Pub. L. 109–432, div. B, title IV, § 405(c)(1)(B)(ii)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-20"},"text":"Dec. 20, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2999"},"text":"120 Stat. 2999","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb82bc470-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb82bc471-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb82bc472-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320a–1a"},"text":"section 1320a–1a of this title","children":[],"tail":" prior to renumbering by "},{"tag":"ref","attrib":{"href":"/us/pl/104/193"},"text":"Pub. L. 104–193","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb82bc473-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/432"},"text":"Pub. L. 109–432","children":[],"tail":" inserted “(which shall include determining whether the State program is in conformity with the requirement of "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s671/a/27"},"text":"section 671(a)(27) of this title","children":[],"tail":")” after “review”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb82bc474-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb82bc475-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2006 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/432"},"text":"Pub. L. 109–432","children":[],"tail":" effective on the date that is 6 months after "},{"tag":"date","attrib":{"date":"2006-12-20"},"text":"Dec. 20, 2006","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/109/432/s405/c/1/B/iii"},"text":"section 405(c)(1)(B)(iii) of Pub. L. 109–432","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s671"},"text":"section 671 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb82bc476-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/432/tII/s203/c/1"},"text":"Pub. L. 103–432, title II, § 203(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-31"},"text":"Oct. 31, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4456"},"text":"108 Stat. 4456","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/432/tII/s203/c/1"},"text":"“The amendment made by subsection (a) [enacting this section] shall take effect on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1994-10-31"},"text":"Oct. 31, 1994","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb82bc477-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/432/tII/s203/c/3"},"text":"Pub. L. 103–432, title II, § 203(c)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-31"},"text":"Oct. 31, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4456"},"text":"108 Stat. 4456","children":[],"tail":", required the regulations referred to in subsec. (a) of this section to be promulgated no later than "},{"tag":"date","attrib":{"date":"1995-07-01"},"text":"July 1, 1995","children":[],"tail":", to take effect on "},{"tag":"date","attrib":{"date":"1996-04-01"},"text":"Apr. 1, 1996","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
