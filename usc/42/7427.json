{"tag":"section","attrib":{"id":"idbe2dda94-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7427"},"text":null,"children":[{"tag":"num","attrib":{"value":"7427"},"text":"§ 7427.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public notification","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbe2dda95-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7427/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Warning signs; television, radio, or press notices or information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each State plan shall contain measures which will be effective to notify the public during any calendar ","children":[{"tag":"ref","attrib":{"idref":"fn003621"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003621"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “calendar year”."}],"tail":" on a regular basis of instances or areas in which any national primary ambient air quality standard is exceeded or was exceeded during any portion of the preceding calendar year to advise the public of the health hazards associated with such pollution, and to enhance public awareness of the measures which can be taken to prevent such standards from being exceeded and the ways in which the public can participate in regulatory and other efforts to improve air quality. Such measures may include the posting of warning signs on interstate highway access points to metropolitan areas or television, radio, or press notices or information."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe2dda96-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7427/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator is authorized to make grants to States to assist in carrying out the requirements of subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbe2dda97-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1955-07-14/ch360"},"text":"July 14, 1955, ch. 360","children":[],"tail":", title I, § 127, as added "},{"tag":"ref","attrib":{"href":"/us/pl/95/95/tI/s124"},"text":"Pub. L. 95–95, title I, § 124","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-08-07"},"text":"Aug. 7, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/725"},"text":"91 Stat. 725","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbe2dda98-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbe2dda99-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbe2dda9a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1977-08-07"},"text":"Aug. 7, 1977","children":[],"tail":", except as otherwise expressly provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/95/95/s406/d"},"text":"section 406(d) of Pub. L. 95–95","children":[],"tail":", set out as an Effective Date of 1977 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s7401"},"text":"section 7401 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
