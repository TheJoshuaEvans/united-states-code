{"tag":"section","attrib":{"id":"idbf6aeedb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12353"},"text":null,"children":[{"tag":"num","attrib":{"value":"12353"},"text":"§ 12353.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of National Center on Family Resource and Support Programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf6aeedc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12353/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commissioner shall establish, through grant or contract, a national center for the collection and provision of programmatic information and technical assistance that relates to all types of family resource and support programs, to be known as the “National Center on Family Resource and Support Programs”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf6aeedd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12353/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The national center established under subsection (a) shall serve as a national information and data clearinghouse, training, technical assistance, and material development source for family resource and support programs. Such center shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf6aeede-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12353/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop and maintain a system for disseminating information on all types of family resource and support programs and on the state of family resource and support program development, including information concerning the most effective model programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf6aeedf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12353/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop and sponsor a variety of training institutes and curricula for family resource and support program staff;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf6aeee0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12353/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify several programs representing the various types of family resource and support programs to develop technical assistance materials and activities to assist other agencies in establishing family resource and support programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf6aeee1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12353/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop State-wide networks of family resource and support programs for the purpose of sharing and disseminating information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf6aeee2-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/501/tIX/s958"},"text":"Pub. L. 101–501, title IX, § 958","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-03"},"text":"Nov. 3, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1279"},"text":"104 Stat. 1279","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/252/tIV/s403/a"},"text":"Pub. L. 103–252, title IV, § 403(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-05-18"},"text":"May 18, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/673"},"text":"108 Stat. 673","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf6aeee3-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf6aeee4-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbf6aeee5-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/252"},"text":"Pub. L. 103–252","children":[],"tail":" substituted “several programs” for “several model programs”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbf6aeee6-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbf6aeee7-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1990-10-01"},"text":"Oct. 1, 1990","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/101/501/s1001/a"},"text":"section 1001(a) of Pub. L. 101–501","children":[],"tail":", set out as an Effective Date of 1990 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s8621"},"text":"section 8621 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
