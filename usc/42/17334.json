{"tag":"section","attrib":{"id":"idc0359146-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17334"},"text":null,"children":[{"tag":"num","attrib":{"value":"17334"},"text":"§ 17334.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Actions by United States International Development Finance Corporation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc0359147-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17334/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sense of Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is the sense of Congress that the United States International Development Finance Corporation should promote greater investment in clean and efficient energy technologies by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0359148-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17334/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" proactively reaching out to United States companies that are interested in investing in clean and efficient energy technologies in countries that are significant contributors to global greenhouse gas emissions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0359149-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17334/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" giving preferential treatment to the evaluation and awarding of projects that involve the investment or utilization of clean and efficient energy technologies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc035914a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17334/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing greater flexibility in supporting projects that involve the investment or utilization of clean and efficient energy technologies, including financing, insurance, and other assistance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc035914b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17334/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The United States International Development Finance Corporation shall include in its annual report required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s9653"},"text":"section 9653 of title 22","children":[],"tail":"—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc035914c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17334/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the activities carried out to implement this section; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc035914d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17334/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the Corporation did not carry out any activities to implement this section, an explanation of the reasons therefor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc035914e-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/tIX/s914"},"text":"Pub. L. 110–140, title IX, § 914","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19