{"tag":"section","attrib":{"id":"idc016969d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16453"},"text":null,"children":[{"tag":"num","attrib":{"value":"16453"},"text":"§ 16453.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State access to books and records","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc016969e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16453/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Upon the written request of a State commission having jurisdiction to regulate a public-utility company in a holding company system, the holding company or any associate company or affiliate thereof, other than such public-utility company, wherever located, shall produce for inspection books, accounts, memoranda, and other records that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc016969f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16453/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have been identified in reasonable detail in a proceeding before the State commission;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc01696a0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16453/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State commission determines are relevant to costs incurred by such public-utility company; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc01696a1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16453/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are necessary for the effective discharge of the responsibilities of the State commission with respect to such proceeding.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc01696a2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16453/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsection (a) does not apply to any person that is a holding company solely by reason of ownership of one or more qualifying facilities under the Public Utility Regulatory Policies Act of 1978 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s2601"},"text":"16 U.S.C. 2601","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc01696a3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16453/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Confidentiality of information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The production of books, accounts, memoranda, and other records under subsection (a) shall be subject to such terms and conditions as may be necessary and appropriate to safeguard against unwarranted disclosure to the public of any trade secrets or sensitive commercial information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc01696a4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16453/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect on State law","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall preempt applicable State law concerning the provision of books, accounts, memoranda, and other records, or in any way limit the rights of any State to obtain books, accounts, memoranda, and other records under any other Federal law, contract, or otherwise.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc01696a5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16453/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Court jurisdiction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any United States district court located in the State in which the State commission referred to in subsection (a) is located shall have jurisdiction to enforce compliance with this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc01696a6-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tXII/s1265"},"text":"Pub. L. 109–58, title XII, § 1265","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/975"},"text":"119 Stat. 975","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc01696a7-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc01696a8-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc01696a9-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Public Utility Regulatory Policies Act of 1978, referred to in subsec. (b), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/617"},"text":"Pub. L. 95–617","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-09"},"text":"Nov. 9, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3117"},"text":"92 Stat. 3117","children":[],"tail":". For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s2601"},"text":"section 2601 of Title 16","children":[],"tail":", Conservation, and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
