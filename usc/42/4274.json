{"tag":"section","attrib":{"id":"idbcbc224b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4274"},"text":null,"children":[{"tag":"num","attrib":{"value":"4274"},"text":"§ 4274.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Organization of Commission","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbcbc224c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4274/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial meeting","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall convene the Commission within ninety days following ","children":[{"tag":"date","attrib":{"date":"1959-09-24"},"text":"September 24, 1959","children":[],"tail":" at such time and place as he may designate for the Commission’s initial meeting."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcbc224d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4274/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chairman and Vice Chairman","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall designate a Chairman and a Vice Chairman from among members of the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcbc224e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4274/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vacancies in membership","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any vacancy in the membership of the Commission shall be filed in the same manner in which the original appointment was made; except that where the number of vacancies is fewer than the number of members specified in paragraphs (4), (5), (6), and (7) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4273/a"},"text":"section 4273(a) of this title","children":[],"tail":", each panel of names submitted in accordance with the aforementioned paragraphs shall contain at least two names for each vacancy."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcbc224f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4274/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of service in official position from which originally appointed","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Where any member ceases to serve in the official position from which originally appointed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4273/a"},"text":"section 4273(a) of this title","children":[],"tail":", his place on the Commission shall be deemed to be vacant."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcbc2250-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4274/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quorum","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Thirteen members of the Commission shall constitute a quorum, but two or more members shall constitute a quorum for the purpose of conducting hearings.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbcbc2251-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/380/s4"},"text":"Pub. L. 86–380, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1959-09-24"},"text":"Sept. 24, 1959","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/73/705"},"text":"73 Stat. 705","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbcbc2252-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbcbc2253-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbcbc2254-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s2374"},"text":"section 2374 of Title 5","children":[],"tail":" prior to the general revision and enactment of Title 5, Government Organization and Employees, by "},{"tag":"ref","attrib":{"href":"/us/pl/89/554/s1"},"text":"Pub. L. 89–554, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/378"},"text":"80 Stat. 378","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
