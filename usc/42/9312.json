{"tag":"section","attrib":{"id":"idbeb35e4c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9312"},"text":null,"children":[{"tag":"num","attrib":{"value":"9312"},"text":"§ 9312.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations; contract authority","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbeb35e4d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9312/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is hereby authorized to be appropriated to the Secretary, for the fiscal year ending ","children":[{"tag":"date","attrib":{"date":"1981-09-30"},"text":"September 30, 1981","children":[],"tail":", such sums as are provided in the annual authorization Act pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s7270"},"text":"section 7270 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbeb35e4e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9312/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In carrying out the provisions of this chapter, the Secretary is authorized to enter into contracts only to such extent or in such amounts as may be provided in advance in appropriations Acts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbeb35e4f-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/386/s13"},"text":"Pub. L. 96–386, § 13","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-07"},"text":"Oct. 7, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1544"},"text":"94 Stat. 1544","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
