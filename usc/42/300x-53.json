{"tag":"section","attrib":{"id":"idb66e0edb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–53"},"text":null,"children":[{"tag":"num","attrib":{"value":"300x–53"},"text":"§ 300x–53.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional requirements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb66e0edc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–53/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A funding agreement for a grant under section 300x or 300x–21 of this title is that the State involved will—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb66e0edd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–53/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb66e0ede-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–53/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the fiscal year for which the grant involved is provided, provide for independent peer review to assess the quality, appropriateness, and efficacy of treatment services provided in the State to individuals under the program involved; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb66e0edf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–53/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that, in the conduct of such peer review, not fewer than 5 percent of the entities providing services in the State under such program are reviewed (which 5 percent is representative of the total population of such entities);","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb66e0ee0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–53/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" permit and cooperate with Federal investigations undertaken in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x–55"},"text":"section 300x–55 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb66e0ee1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–53/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide to the Secretary any data required by the Secretary pursuant to subsections (c) and (d) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s290aa–4"},"text":"section 290aa–4 of this title","children":[],"tail":" and will cooperate with the Secretary in the development of uniform criteria for the collection of data pursuant to such section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb66e0ee2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–53/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Patient records","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may make a grant under section 300x or 300x–21 of this title only if the State involved has in effect a system to protect from inappropriate disclosure patient records maintained by the State in connection with an activity funded under the program involved or by any entity which is receiving amounts from the grant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail