e under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s402"},"text":"section 402 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb9000462-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1973 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/233"},"text":"Pub. L. 93–233","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1974-01-01"},"text":"Jan. 1, 1974","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/93/233/s18"},"text":"Pub. L. 93–233, § 18","children":[],"tail":"(z–3)(1), "},{"tag":"date","attrib":{"date":"1973-12-31"},"text":"Dec. 31, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/974"},"text":"87 Stat. 974","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb9000463-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination Period for Certain Individuals Covered Pursuant to State Agreements","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/96/499/tIX/s947/e"},"text":"Pub. L. 96–499, title IX, § 947(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-05"},"text":"Dec. 5, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2643"},"text":"94 Stat. 2643","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/96/499/tIX/s947/e"},"text":"“The coverage period under part B of title XVIII of the Social Security Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395j"},"text":"42 U.S.C. 1395j","children":[],"tail":" et seq.] of an individual whose coverage period attributable to a State agreement under section 1843 of such Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395v"},"text":"42 U.S.C. 1395v","children":[],"tail":"] is terminated and who has filed notice before the end of the third calendar month beginning after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1980-12-05"},"text":"Dec. 5, 1980","children":[],"tail":"] that he no longer wishes to participate in the insurance program established by part B of title XVIII shall terminate on the earlier of (1) the day specified in section 1838 ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395q"},"text":"42 U.S.C. 1395q","children":[],"tail":"] without the amendments made by this section, or (2) (unless the individual files notice before the day specified in this clause that he wishes his coverage period to terminate as provided in clause (1)) the day on which his coverage period would terminate if the individual filed notice in the fourth calendar month beginning after the date of the enactment of this Act.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb9000464-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"District of Columbia; Agreement of Commissioner With Secretary for Supplementary Medical Insurance","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/90/227/s2"},"text":"Pub. L. 90–227, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-12-27"},"text":"Dec. 27, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/745"},"text":"81 Stat. 745","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/90/227/s2"},"text":"“The Commissioner [now Mayor of District of Columbia] may enter into an agreement (and any modifications of such agreement) with the Secretary under section 1843 of the Social Security Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395v"},"text":"42 U.S.C. 1395v","children":[],"tail":"] pursuant to which (1) eligible individuals (as defined in section 1836 of the Social Security Act) ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395"},"text":"42 U.S.C. 1395","children":[],"tail":null},{"tag":"i","attrib":{},"text":"o","children":[],"tail":"] who are eligible to receive medical assistance under the District of Columbia’s plan for medical assistance approved under title XIX of the Social Security Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1396"},"text":"42 U.S.C. 1396","children":[],"tail":" et seq.] will be enrolled in the supplementary medical insurance program established under part B of title XVIII of the Social Security Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395"},"text":"42 U.S.C. 1395","children":[],"tail":" et seq.], and (2) provisions will be made for payment of the monthly premiums of such individuals for such program.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
