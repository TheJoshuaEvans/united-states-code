t":"102 Stat. 749","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/485/tVI/s608/d/14/H"},"text":"Pub. L. 100–485, title VI, § 608(d)(14)(H)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-13"},"text":"Oct. 13, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2416"},"text":"102 Stat. 2416","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/239/tVI/s6013/b"},"text":"Pub. L. 101–239, title VI, § 6013(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2164"},"text":"103 Stat. 2164","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/tIV/s4501/d"},"text":"Pub. L. 101–508, title IV, § 4501(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-165"},"text":"104 Stat. 1388–165","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9000456-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb9000457-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb9000458-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Railroad Retirement Act of 1974, referred to in subsec. (d)(3)(B), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-29/ch812"},"text":"act Aug. 29, 1935, ch. 812","children":[],"tail":", as amended generally by "},{"tag":"ref","attrib":{"href":"/us/pl/93/445/tI/s101