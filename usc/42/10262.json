{"tag":"section","attrib":{"id":"idbf1c31bb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10262"},"text":null,"children":[{"tag":"num","attrib":{"value":"10262"},"text":"§ 10262.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nuclear Waste Technical Review Board","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf1c31bc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10262/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established a Nuclear Waste Technical Review Board that shall be an independent establishment within the executive branch.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf1c31bd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10262/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Members","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf1c31be-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10262/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Board shall consist of 11 members who shall be appointed by the President not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"1987-12-22"},"text":"December 22, 1987","children":[],"tail":", from among persons nominated by the National Academy of Sciences in accordance with paragraph (3)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf1c31bf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10262/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The President shall designate a member of the Board to serve as chairman.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf1c31c0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10262/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf1c31c1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10262/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The National Academy of Sciences shall, not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"1987-12-22"},"text":"December 22, 1987","children":[],"tail":", nominate not less than 22 persons for appointment to the Board from among persons who meet the qualifications described in subparagraph (C)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf1c31c2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10262/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The National Academy of Sciences shall nominate not less than 2 persons to fill any vacancy on the Board from among persons who meet the qualifications described in subparagraph (C).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf1c31c3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10262/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbf1c31c4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10262/b/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Each person nominated for appointment to the Board shall be—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbf1c31c5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10262/b/3/C/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" eminent in a field of science or engineering, including environmental sciences; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbf1c31c6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10262/b/3/C/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" selected solely on the basis of established records of distinguished service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf1c31c7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10262/b/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The membership of the Board shall be representative of the broad range of scientific and engineering disciplines related to activities under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf1c31c8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10262/b/3/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" No person shall be nominated for appointment to the Board who is an employee of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbf1c31c9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10262/b/3/C/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of Energy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbf1c31ca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10262/b/3/C/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a national laboratory under contract with the Department of Energy; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbf1c31cb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10262/b/3/C/iii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an entity performing high-level radioactive waste or spent nuclear fuel activities under contract with the Department of Energy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf1c31cc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10262/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any vacancy on the Board shall be filled by the nomination and appointment process described in paragraphs (1) and (3).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf1c31cd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10262/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Members of the Board shall be appointed for terms of 4 years, each such term to commence 120 days after ","children":[{"tag":"date","attrib":{"date":"1987-12-22"},"text":"December 22, 1987","children":[],"tail":", except that of the 11 members first appointed to the Board, 5 shall serve for 2 years and 6 shall serve for 4 years, to be designated by the President at the time of appointment."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf1c31ce-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/425/tV/s502"},"text":"Pub. L. 97–425, title V, § 502","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/202/s101/d/tIII"},"text":"Pub. L. 100–202, § 101(d) [title III]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1329-104"},"text":"101 Stat. 1329–104","children":[],"tail":", 1329–121; "},{"tag":"ref","attrib":{"href":"/us/pl/100/203/tV/s5051"},"text":"Pub. L. 100–203, title V, § 5051","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1330-248"},"text":"101 Stat. 1330–248","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf1c31cf-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf1c31d0-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbf1c31d1-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/202"},"text":"Pub. L. 100–202","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/100/203"},"text":"Pub. L. 100–203","children":[],"tail":" added identical sections."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbf1c31d2-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbf1c31d3-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Continued Board Service After Expiration of Term","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/46/tV/s503"},"text":"Pub. L. 104–46, title V, § 503","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-11-13"},"text":"Nov. 13, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/419"},"text":"109 Stat. 419","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/46/tV/s503"},"text":"“Without fiscal year limitation and notwithstanding section 502(b)(5) of the Nuclear Waste Policy Act, as amended [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s10262/b/5"},"text":"42 U.S.C. 10262(b)(5)","children":[],"tail":"], or any other provision of law, a member of the Nuclear Waste Technical Review Board whose term has expired may continue to serve as a member of the Board until such member’s successor has taken office.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
