{"tag":"section","attrib":{"id":"idb4a8df31-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–10"},"text":null,"children":[{"tag":"num","attrib":{"value":"247b–10"},"text":"§ 247b–10.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compilation of data on asthma","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb4a8df32-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–10/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, acting through the Director of the Centers for Disease Control and Prevention, shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4a8df33-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–10/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct local asthma surveillance activities to collect data on the prevalence and severity of asthma and the quality of asthma management;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4a8df34-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–10/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compile and annually publish data on the prevalence of children suffering from asthma in each State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4a8df35-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–10/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent practicable, compile and publish data on the childhood mortality rate associated with asthma nationally.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4a8df36-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–10/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Surveillance activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the Centers for Disease Control and Prevention, acting through the representative of the Director on the National Asthma Education Prevention Program Coordinating Committee, shall, in carrying out subsection (a), provide an update on surveillance activities at each Committee meeting.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4a8df37-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–10/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collaborative efforts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The activities described in subsection (a)(1) may be conducted in collaboration with eligible entities awarded a grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s280g"},"text":"section 280g of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4a8df38-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–10/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of carrying out this section, there are authorized to be appropriated such sums as may be necessary for each of the fiscal years 2001 through 2005.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb4a8df39-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title III, § 317I, as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/310/dA/tV/s531"},"text":"Pub. L. 106–310, div. A, title V, § 531","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-17"},"text":"Oct. 17, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1117"},"text":"114 Stat. 1117","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
