{"tag":"section","attrib":{"id":"idbfc59255-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13504"},"text":null,"children":[{"tag":"num","attrib":{"value":"13504"},"text":"§ 13504.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Math and science education program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfc59256-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13504/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall enter into contracts with existing qualified entities to conduct science and mathematics education programs that supplement the Special Programs for Students from Disadvantaged Backgrounds carried out by the Secretary of Education under sections 1070d through 1070d–1d of title 20.","children":[{"tag":"ref","attrib":{"idref":"fn004174"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004174"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfc59257-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13504/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfc59258-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13504/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The purpose of the programs shall be to provide support to Federal, State, and private programs designed to promote the participation of low-income and first generation college students as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070d"},"text":"section 1070d of title 20","children":[],"tail":" "},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" in post-secondary science and mathematics education."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc59259-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13504/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Support activities may include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfc5925a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13504/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development of educational materials;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfc5925b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13504/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the training of teachers and counselors;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfc5925c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13504/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the establishment of student internships;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfc5925d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13504/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development of seminars on mathematics and science;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfc5925e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13504/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" tutoring in mathematics and science;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfc5925f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13504/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" academic counseling;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfc59260-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13504/b/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development of opportunities for research; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfc59261-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13504/b/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other activities that may promote the participation of low-income and first generation college students in post-secondary science and mathematics education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfc59262-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13504/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Support","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfc59263-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13504/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In carrying out the purpose of this section, the entities may provide support under subsection (b)(2) to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfc59264-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13504/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" low-income and first generation college students; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfc59265-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13504/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" institutions of higher education, public and private agencies and organizations, and secondary and middle schools that principally benefit low-income students.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc59266-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13504/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The qualified entities shall, to the extent practicable, coordinate support activities under this section with the Secretary of Education and the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfc59267-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13504/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperation with qualified entities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall cooperate with qualified entities and, to the extent practicable, make available to the entities such personnel, facilities, and other resources of the Department of Energy as may be necessary to carry out the duties of the entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfc59268-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13504/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than October 1 of each year, the entities shall report to the Secretary, the Secretary of Education, and the Congress on—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfc59269-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13504/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" progress made to promote the participation of low-income and first generation college students in post-secondary science and mathematics education by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfc5926a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13504/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the qualified entities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfc5926b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13504/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other mathematics and science education programs of the Department of Energy; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfc5926c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13504/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Special Programs for Students from Disadvantaged Backgrounds of the Department of Education; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc5926d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13504/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommendations for such additional actions as may be needed to promote the participation of low-income students in post-secondary science and mathematics education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfc5926e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13504/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect on existing programs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The programs in this section shall supplement and be developed in cooperation with the current mathematics and science education programs of the Department of Energy and the Department of Education but shall not supplant them.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfc5926f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13504/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Qualified entity” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “qualified entity” means a nonprofit corporation, association, or institution that has demonstrated special knowledge of, and experience with, the education of low-income and first generation college students and whose primary mission is the operation of national programs that focus on low-income students and provide training and other services to educators.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfc59270-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13504/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums as may be necessary, to be derived from ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s13503/e"},"text":"section 13503(e) of this title","children":[],"tail":" and the Environmental Restoration and Waste Management program, to carry out the purposes of this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfc59271-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/tXXII/s2204"},"text":"Pub. L. 102–486, title XXII, § 2204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3089"},"text":"106 Stat. 3089","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbfc59272-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbfc59273-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbfc59274-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Sections 1070d through 1070d–1d of title 20, referred to in subsec. (a), and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070d"},"text":"section 1070d of title 20","children":[],"tail":", referred to in subsec. (b)(1), were repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/102/325/tIV/s402/a/1"},"text":"Pub. L. 102–325, title IV, § 402(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-23"},"text":"July 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/482"},"text":"106 Stat. 482","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
