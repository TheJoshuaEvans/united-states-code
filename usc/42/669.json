{"tag":"section","attrib":{"id":"idb7c7ab3b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s669"},"text":null,"children":[{"tag":"num","attrib":{"value":"669"},"text":"§ 669.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collection and reporting of child support enforcement data","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb7c7ab3c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s669/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to each type of service described in subsection (b), the Secretary shall collect and maintain up-to-date statistics, by State, and on a fiscal year basis, on—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7c7ab3d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s669/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of cases in the caseload of the State agency administering the plan approved under this part in which the service is needed; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7c7ab3e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s669/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of such cases in which the service has actually been provided.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7c7ab3f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s669/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Types of services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The statistics required by subsection (a) shall be separately stated with respect to paternity establishment services and child support obligation establishment services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7c7ab40-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s669/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Types of service recipients","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The statistics required by subsection (a) shall be separately stated with respect to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7c7ab41-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s669/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recipients of assistance under a State program funded under part A or of payments or services under a State plan approved under part E; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7c7ab42-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s669/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" individuals who are not such recipients.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7c7ab43-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s669/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of interpretation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of subsection (a)(2), a service has actually been provided when the task described by the service has been accomplished.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb7c7ab44-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title IV, § 469, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/485/tI/s129"},"text":"Pub. L. 100–485, title I, § 129","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-13"},"text":"Oct. 13, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2356"},"text":"102 Stat. 2356","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tVIII/s8105/6"},"text":"Pub. L. 100–647, title VIII, § 8105(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3797"},"text":"102 Stat. 3797","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/193/tI/s108/c/16"},"text":"Pub. L. 104–193, title I, § 108(c)(16)","children":[],"tail":", title III, § 395(d)(2)(E), "},{"tag":"date","attrib":{"date":"1996-08-22"},"text":"Aug. 22, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2166"},"text":"110 Stat. 2166","children":[],"tail":", 2260; "},{"tag":"ref","attrib":{"href":"/us/pl/105/200/tIV/s407/a"},"text":"Pub. L. 105–200, title IV, § 407(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-07-16"},"text":"July 16, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/672"},"text":"112 Stat. 672","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb7c7ab45-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb7c7ab46-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"c