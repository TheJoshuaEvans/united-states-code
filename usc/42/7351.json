{"tag":"section","attrib":{"id":"idbe05436a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7351"},"text":null,"children":[{"tag":"num","attrib":{"value":"7351"},"text":"§ 7351.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission of comprehensive review","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"1982-01-15"},"text":"January 15, 1982","children":[],"tail":", the President shall prepare and submit to the Congress a comprehensive review of each program of the Department. Each such review shall be made available to the committee or committees of the Senate and House of Representatives having jurisdiction with respect to the annual authorization of funds, pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s7270"},"text":"section 7270 of this title","children":[],"tail":", for such programs for the fiscal year beginning "},{"tag":"date","attrib":{"date":"1982-10-01"},"text":"October 1, 1982","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbe05436b-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/91/tX/s1001"},"text":"Pub. L. 95–91, title X, § 1001","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-08-04"},"text":"Aug. 4, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/612"},"text":"91 Stat. 612","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
