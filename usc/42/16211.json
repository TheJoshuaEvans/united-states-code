{"tag":"section","attrib":{"id":"idbffa0e8b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16211"},"text":null,"children":[{"tag":"num","attrib":{"value":"16211"},"text":"§ 16211.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distributed energy and electric energy systems","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbffa0e8c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16211/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall carry out programs of research, development, demonstration, and commercial application on distributed energy resources and systems reliability and efficiency, to improve the reliability and efficiency of distributed energy resources and systems, integrating advanced energy technologies with grid connectivity, including activities described in this part. The programs shall address advanced energy technologies and systems and advanced grid reliability technologies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbffa0e8d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16211/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbffa0e8e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16211/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distributed energy and electric energy systems activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated to the Secretary to carry 