{"tag":"section","attrib":{"id":"idbcca79c5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370a"},"text":null,"children":[{"tag":"num","attrib":{"value":"4370a"},"text":"§ 4370a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistant Administrators of Environmental Protection Agency; appointment; duties","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbcca79c6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The President, by and with the advice and consent of the Senate, may appoint three Assistant Administrators of the Environmental Protection Agency in addition to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbcca79c7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the five Assistant Administrators provided for in section 1(d) of Reorganization Plan Numbered 3 of 1970 (5 U.S.C. Appendix);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcca79c8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Assistant Administrator provided by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2625/g"},"text":"section 2625(g) of title 15","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcca79c9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Assistant Administrator provided by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6911a"},"text":"section 6911a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcca79ca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each Assistant Administrator appointed under subsection (a) shall perform such duties as the Administrator of the Environmental Protection Agency may prescribe.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbcca79cb-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/80/s1"},"text":"Pub. L. 98–80, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-08-23"},"text":"Aug. 23, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/485"},"text":"97 Stat. 485","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbcca79cc-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbcca79cd-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbcca79ce-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Reorganization Plan Numbered 3 of 1970, referred to in subsec. (a)(1), is set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"section 4321 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbcca79cf-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of the National Environmental Policy Act of 1969 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
