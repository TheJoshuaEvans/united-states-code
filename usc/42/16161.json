{"tag":"section","attrib":{"id":"idbff52d4e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16161"},"text":null,"children":[{"tag":"num","attrib":{"value":"16161"},"text":"§ 16161.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Solar and wind technologies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbff52d4f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16161/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Solar energy technologies","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbff52d50-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16161/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prepare a detailed roadmap for carrying out the provisions in this subchapter related to solar energy technologies and for implementing the recommendations related to solar energy technologies that are included in the report transmitted under subsection (e);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff52d51-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16161/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for the establishment of 5 projects in geographic areas that are regionally and climatically diverse to demonstrate the production of hydrogen at solar energy facilities, including one demonstration project at a National Laboratory or institution of higher education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff52d52-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16161/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" establish a program—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbff52d53-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16161/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop optimized concentrating solar power devices that may be used for the production of both electricity and hydrogen; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff52d54-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16161/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to evaluate the use of thermochemical cycles for hydrogen production at the temperatures attainable with concentrating solar power devices;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff52d55-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16161/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate with activities sponsored by the Department’s Office of Nuclear Energy, Science, and Technology on high-temperature materials, thermochemical cycles, and economic issues related to solar energy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff52d56-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16161/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for the construction and operation of new concentrating solar power devices or solar power cogeneration facilities that produce hydrogen either concurrently with, or independently of, the production of electricity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff52d57-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16161/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support existing facilities and programs of study related to concentrating solar power devices; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff52d58-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16161/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" establish a program—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbff52d59-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16161/a/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop methods that use electricity from photovoltaic devices for the onsite production of hydrogen, such that no intermediate transmission or distribution infrastructure is required or used and future demand growth may be accommodated;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff52d5a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16161/a/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to evaluate the economics of small-scale electrolysis for hydrogen production; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff52d5b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16161/a/7/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to study the potential of modular photovoltaic devices for the development of a hydrogen infrastructure, the security implications of a hydrogen infrastructure, and the benefits potentially derived from a hydrogen infrastructure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff52d5c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16161/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Wind energy technologies","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbff52d5d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16161/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prepare a detailed roadmap for carrying out the provisions in this subchapter related to wind energy technologies and for implementing the recommendations related to wind energy technologies that are included in the report transmitted under subsection (e); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff52d5e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16161/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for the establishment of 5 projects in geographic areas that are regionally and climatically diverse to demonstrate the production of hydrogen at existing wind energy facilities, including one demonstration project at a National Laboratory or institution of higher education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff52d5f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16161/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program support","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall support programs at institutions of higher education for the development of solar energy technologies and wind energy technologies for the production of hydrogen. The programs supported under this subsection shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbff52d60-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16161/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhance fellowship and faculty assistance programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff52d61-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16161/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide support for fundamental research;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff52d62-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16161/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage collaborative research among industry, National Laboratories, and institutions of higher education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff52d63-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16161/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support communication and outreach; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff52d64-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16161/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to the greatest extent possible—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbff52d65-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16161/c/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be located in geographic areas that are regionally and climatically diverse; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff52d66-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16161/c/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be located at part B institutions, minority institutions, and institutions of higher education located in States participating in the Experimental Program to Stimulate Competitive Research of the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff52d67-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16161/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Institutions of higher education and National Laboratory interactions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In conjunction with the programs supported under this section, the Secretary shall develop sabbatical, fellowship, and visiting scientist programs to encourage National Laboratories and institutions of higher education to share and exchange personnel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff52d68-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16161/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall transmit to the Congress not later than 120 days after ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":", a report containing detailed summaries of the roadmaps prepared under subsections (a)(1) and (b)(1), descriptions of the Secretary’s progress in establishing the projects and other programs required under this section, and recommendations for promoting the availability of advanced solar and wind energy technologies for the production of hydrogen."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff52d69-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16161/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbff52d6a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16161/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “concentrating solar power devices” means devices that concentrate the power of the sun by reflection or refraction to improve the efficiency of a photovoltaic or thermal generation process;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff52d6b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16161/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “minority institution” has the meaning given to that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1067k"},"text":"section 1067k of title 20","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff52d6c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16161/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “part B institution” has the meaning given to that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1061"},"text":"section 1061 of title 20","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff52d6d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16161/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “photovoltaic devices” means devices that convert light directly into electricity through a solid-state, semiconductor process.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff52d6e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16161/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated such sums as are necessary for carrying out the activities under this section for each of fiscal years 2006 through 2020.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbff52d6f-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tVIII/s812"},"text":"Pub. L. 109–58, title VIII, § 812","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/853"},"text":"119 Stat. 853","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
