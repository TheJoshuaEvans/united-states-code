{"tag":"section","attrib":{"id":"idb543e62f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280h–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"280h–1"},"text":"§ 280h–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applied research program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb543e630-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280h–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, acting through the Centers for Disease Control and Prevention and in consultation with the Director of the National Institutes of Health, shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb543e631-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280h–1/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct research to better understand the relationship between physical activity, diet, and health and factors that influence health-related behaviors;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb543e632-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280h–1/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop and evaluate strategies for the prevention and treatment of obesity to be used in community-based interventions and by health professionals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb543e633-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280h–1/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop and evaluate strategies for the prevention and treatment of eating disorders, such as anorexia and bulimia;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb543e634-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280h–1/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct research to establish the prevalence, consequences, and costs of childhood obesity and its effects in adulthood;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb543e635-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280h–1/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify behaviors and risk factors that contribute to obesity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb543e636-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280h–1/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluate materials and programs to provide nutrition education to parents and teachers of children in child care or pre-school and the food service staff of such child care and pre-school entities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb543e637-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280h–1/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluate materials and programs that are designed to educate and encourage physical activity in child care and pre-school facilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb543e638-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280h–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this section such sums as may be necessary for each of the fiscal years 2001 through 2005.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb543e639-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title III, § 399X, as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/310/dA/tXXIV/s2401"},"text":"Pub. L. 106–310, div. A, title XXIV, § 2401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-17"},"text":"Oct. 17, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1159"},"text":"114 Stat. 1159","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
