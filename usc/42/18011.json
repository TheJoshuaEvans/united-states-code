{"tag":"section","attrib":{"id":"idc043e8ab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18011"},"text":null,"children":[{"tag":"num","attrib":{"value":"18011"},"text":"§ 18011.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preservation of right to maintain existing coverage","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc043e8ac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18011/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No changes to existing coverage","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc043e8ad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18011/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this Act (or an amendment made by this Act) shall be construed to require that an individual terminate coverage under a group health plan or health insurance coverage in which such individual was enrolled on ","children":[{"tag":"date","attrib":{"date":"2010-03-23"},"text":"March 23, 2010","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc043e8ae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18011/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continuation of coverage","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (3), with respect to a group health plan or health insurance coverage in which an individual was enrolled on ","children":[{"tag":"date","attrib":{"date":"2010-03-23"},"text":"March 23, 2010","children":[],"tail":", this subtitle and subtitle A (and the amendments made by such subtitles) shall not apply to such plan or coverage, regardless of whether the individual renews such coverage after "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"March 23, 2010","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc043e8af-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18011/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of certain provisions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provisions of sections 2715 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300gg–15"},"text":"42 U.S.C. 300gg–15","children":[],"tail":"] and 2718 ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300gg–18"},"text":"42 U.S.C. 300gg–18","children":[],"tail":"] of the Public Health Service Act (as added by subtitle A) shall apply to grandfathered health plans for plan years beginning on or after "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"March 23, 2010","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc043e8b0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18011/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of certain provisions","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc043e8b1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18011/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The following provisions of the Public Health Service Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s201"},"text":"42 U.S.C. 201","children":[],"tail":" et seq.] (as added by this title) "},{"tag":"ref","attrib":{"idref":"fn004297"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004297"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" shall apply to grandfathered health plans for plan years beginning with the first plan year to which such provisions would otherwise apply:"}],"tail":null},{"tag":"clause","attrib":{"id":"idc043e8b2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18011/a/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 2708 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300gg–7"},"text":"42 U.S.C. 300gg–7","children":[],"tail":"] (relating to excessive waiting periods)."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc043e8b3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18011/a/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Those provisions of section 2711 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300gg–11"},"text":"42 U.S.C. 300gg–11","children":[],"tail":"] relating to lifetime limits."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc043e8b4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18011/a/4/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 2712 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300gg–12"},"text":"42 U.S.C. 300gg–12","children":[],"tail":"] (relating to rescissions)."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc043e8b5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18011/a/4/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 2714 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300gg–14"},"text":"42 U.S.C. 300gg–14","children":[],"tail":"] (relating to extension of dependent coverage)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc043e8b6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18011/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provisions applicable only to group health plans","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc043e8b7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18011/a/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provisions described","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Those provisions of section 2711 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300gg–11"},"text":"42 U.S.C. 300gg–11","children":[],"tail":"] relating to annual limits and the provisions of section 2704 ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300gg–3"},"text":"42 U.S.C. 300gg–3","children":[],"tail":"] (relating to pre-existing condition exclusions) of the Public Health Service Act (as added by this subtitle) shall apply to grandfathered health plans that are group health plans for plan years beginning with the first plan year to which such provisions otherwise apply."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc043e8b8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18011/a/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adult child coverage","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For plan years beginning before ","children":[{"tag":"date","attrib":{"date":"2014-01-01"},"text":"January 1, 2014","children":[],"tail":", the provisions of section 2714 of the Public Health Service Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300gg–14"},"text":"42 U.S.C. 300gg–14","children":[],"tail":"] (as added by this subtitle) shall apply in the case of an adult child with respect to a grandfathered health plan that is a group health plan only if such adult child is not eligible to enroll in an eligible employer-sponsored health plan (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s5000A/f/2"},"text":"section 5000A(f)(2) of title 26","children":[],"tail":") other than such grandfathered health plan."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc043e8b9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18011/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of additional provisions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Sections 300gg–111, 300gg–112, and 300gg–117 of this title shall apply to grandfathered health plans for plan years beginning on or after ","children":[{"tag":"date","attrib":{"date":"2022-01-01"},"text":"January 1, 2022","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc043e8ba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18011/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allowance for family members to join current coverage","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to a group health plan or health insurance coverage in which an individual was enrolled on ","children":[{"tag":"date","attrib":{"date":"2010-03-23"},"text":"March 23, 2010","children":[],"tail":", and which is renewed after such date, family members of such individual shall be permitted to enroll in such plan or coverage if such enrollment is permitted under the terms of the plan in effect as of "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"March 23, 2010","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc043e8bb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18011/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allowance for new employees to join current plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A group health plan that provides coverage on ","children":[{"tag":"date","attrib":{"date":"2010-03-23"},"text":"March 23, 2010","children":[],"tail":", may provide for the enrolling of new employees (and their families) in such plan, and this subtitle and subtitle A (and the amendments made by such subtitles) shall not apply with respect to such plan and such new employees (and their families)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc043e8bc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18011/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect on collective bargaining agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of health insurance coverage maintained pursuant to one or more collective bargaining agreements between employee representatives and one or more employers that was ratified before ","children":[{"tag":"date","attrib":{"date":"2010-03-23"},"text":"March 23, 2010","children":[],"tail":", the provisions of this subtitle and subtitle A (and the amendments made by such subtitles) shall not apply until the date on which the last of the collective bargaining agreements relating to the coverage terminates. Any coverage amendment made pursuant to a collective bargaining agreement relating to the coverage which amends the coverage solely to conform to any requirement added by this subtitle or subtitle A (or amendments) shall not be treated as a termination of such collective bargaining agreement."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc043e8bd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18011/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this title,","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" the term “grandfathered health plan” means any group health plan or health insurance coverage to which this section applies."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc043e8be-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/tI/s1251"},"text":"Pub. L. 111–148, title I, § 1251","children":[],"tail":", title X, § 10103(d), "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/161"},"text":"124 Stat. 161","children":[],"tail":", 895; "},{"tag":"ref","attrib":{"href":"/us/pl/111/152/tII/s2301/a"},"text":"Pub. L. 111–152, title II, § 2301(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-30"},"text":"Mar. 30, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1081"},"text":"124 Stat. 1081","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dBB/tI/s102/d/2"},"text":"Pub. L. 116–260, div. BB, title I, § 102(d)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2797"},"text":"134 Stat. 2797","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc043e8bf-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc043e8c0-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc043e8c1-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in subsec. (a)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148"},"text":"Pub. L. 111–148","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/119"},"text":"124 Stat. 119","children":[],"tail":", known as the Patient Protection and Affordable Care Act. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s18001"},"text":"section 18001 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This subtitle, referred to in subsecs. (a)(2), (4)(B), (c), and (d), is subtitle C (§§ 1201–1255) of title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148"},"text":"Pub. L. 111–148","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/154"},"text":"124 Stat. 154","children":[],"tail":", which enacted this subchapter and sections 300gg to 300gg–2 and 300gg–4 to 300gg–7 of this title, transferred "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300gg"},"text":"section 300gg of this title","children":[],"tail":" to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300gg–3"},"text":"section 300gg–3 of this title","children":[],"tail":", amended sections 300gg–1 and 300gg–4 of this title, and enacted provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300gg"},"text":"section 300gg of this title","children":[],"tail":". For complete classification of subtitle C to the Code, see Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subtitle A, referred to in subsecs. (a)(2), (3), (c), and (d), is subtitle A (§§ 1001–1004) of title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148"},"text":"Pub. L. 111–148","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/130"},"text":"124 Stat. 130","children":[],"tail":", which enacted sections 300gg–11 to 300gg–19, 300gg–93, and 300gg–94 of this title, transferred sections 300gg–4 to 300gg–7 and 300gg–13 of this title to sections 300gg–25 to 300gg–28 and 300gg–9 of this title, respectively, amended sections 300gg–11, 300gg–12, and 300gg–21 to 300gg–23 of this title, and enacted provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300gg–11"},"text":"section 300gg–11 of this title","children":[],"tail":". For complete classification of subtitle A to the Code, see Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Public Health Service Act, referred to in subsec. (a)(4)(A), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"act July 1, 1944, ch. 373","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/58/682"},"text":"58 Stat. 682","children":[],"tail":", which is classified generally to chapter 6A (§ 201 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s201"},"text":"section 201 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This title, referred to in subsecs. (a)(4)(A) and (e), is title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148"},"text":"Pub. L. 111–148","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/130"},"text":"124 Stat. 130","children":[],"tail":", which enacted this chapter and enacted, amended, and transferred numerous other sections and notes in the Code. For complete classification of title I to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc043e8c2-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—Subsec. (a)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Pub. L. 116–260","children":[],"tail":" added par. (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/s10103/d/1"},"text":"Pub. L. 111–148, § 10103(d)(1)","children":[],"tail":", substituted “Except as provided in paragraph (3), with” for “With”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/s10103/d/2"},"text":"Pub. L. 111–148, § 10103(d)(2)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/152"},"text":"Pub. L. 111–152","children":[],"tail":" added par. (4)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc043e8c3-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc043e8c4-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2020 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Pub. L. 116–260","children":[],"tail":" applicable with respect to plan years beginning on or after "},{"tag":"date","attrib":{"date":"2022-01-01"},"text":"Jan. 1, 2022","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dBB/s102/e"},"text":"section 102(e) of div. BB of Pub. L. 116–260","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8902"},"text":"section 8902 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc043e8c5-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/s1255/1"},"text":"section 1255(1) of Pub. L. 111–148","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300gg"},"text":"section 300gg of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
