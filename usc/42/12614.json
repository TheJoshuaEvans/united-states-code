{"tag":"section","attrib":{"id":"idbf807280-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12614"},"text":null,"children":[{"tag":"num","attrib":{"value":"12614"},"text":"§ 12614.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Summer national service program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf807281-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12614/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Under the summer national service program of the National Civilian Community Corps Program authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12612/a"},"text":"section 12612(a) of this title","children":[],"tail":", a diverse group of youth aged 14 through 18 years who are from urban or rural areas shall work in teams on National Civilian Community Corps projects."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf807282-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12614/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Necessary participants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the extent practicable, at least 50 percent of the participants in the summer national service program shall be from economically and ethnically diverse backgrounds, including youth who are in foster care.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf807283-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12614/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Seasonal program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The training and service of Corps members under the summer national service program in each year shall be conducted after April 30 and before October 1 of that year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf807284-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/610/tI/s154"},"text":"Pub. L. 101–610, title I, § 154","children":[],"tail":", formerly § 195C, as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/484/dA/tX/s1092/a/1"},"text":"Pub. L. 102–484, div. A, title X, § 1092(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2524"},"text":"106 Stat. 2524","children":[],"tail":"; renumbered § 154 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/tI/s104/b"},"text":"Pub. L. 103–82, title I, § 104(b)","children":[],"tail":", (e)(2)(B), "},{"tag":"date","attrib":{"date":"1993-09-21"},"text":"Sept. 21, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/840"},"text":"107 Stat. 840","children":[],"tail":", 847; "},{"tag":"ref","attrib":{"href":"/us/pl/111/13/tI/s1504"},"text":"Pub. L. 111–13, title I, § 1504","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-04-21"},"text":"Apr. 21, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1522"},"text":"123 Stat. 1522","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf807285-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf807286-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib"