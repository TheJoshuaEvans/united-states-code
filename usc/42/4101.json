ears following such date”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/181/s451/d/1"},"text":"Pub. L. 98–181, § 451(d)(1)","children":[],"tail":", substituted “Director” for “Secretary” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/181/s451/d/7"},"text":"Pub. L. 98–181, § 451(d)(7)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1973—","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/234"},"text":"Pub. L. 93–234","children":[],"tail":" designated existing provisions as subsec. (a) and added subsecs. (b) and (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbcb2abac-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbcb2abad-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 120 days following ","children":[{"tag":"date","attrib":{"date":"1968-08-01"},"text":"Aug. 1, 1968","children":[],"tail":", or such later date prescribed by the Secretary but in no event more than 180 days following "},{"tag":"date","attrib":{"date":"1968-08-01"},"text":"Aug. 1, 1968","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/90/448/s1377"},"text":"section 1377 of Pub. L. 90–448","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4001"},"text":"section 4001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"idbcb2abae-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of all functions, personnel, assets, components, authorities, grant programs, and liabilities of the Federal Emergency Management Agency, including the functions of the Under Secretary for Federal Emergency Management relating thereto, to the Federal Emergency Management Agency, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s315/a/1"},"text":"section 315(a)(1) of Title 6","children":[],"tail":", Domestic Security."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of functions, personnel, assets, and liabilities of the Federal Emergency Management Agency, including the functions of the Director of the Federal Emergency Management Agency relating thereto, to the Secretary of Homeland Security, and for treatment of related references, see former section 313(1) and sections 551(d), 552(d), and 557 of Title 6, Domestic Security, and the Department of Homeland Security Reorganization Plan of ","children":[{"tag":"date","attrib":{"date":"2002-11-25"},"text":"November 25, 2002","children":[],"tail":", as modified, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s542"},"text":"section 542 of Title 6","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbcb2abaf-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Flood Protection Structure Accreditation Task Force","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141/dF/tII/s100226"},"text":"Pub. L. 112–141, div. F, title II, § 100226","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-06"},"text":"July 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/942"},"text":"126 Stat. 942","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/141/dF/tII/s100226"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term ‘flood protection structure accreditation requirements’ means the requirements established under section 65.10 of title 44, Code of Federal Regulations, for levee systems to be recognized on maps created for purposes of the National Flood Insurance Program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term ‘National Committee on Levee Safety’ means the Committee on Levee Safety established under section 9003 of the National Levee Safety Act of 2007 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s3302"},"text":"33 U.S.C. 3302","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term ‘task force’ means the Flood Protection Structure Accreditation Task Force established under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator and the Secretary of the Army, acting through the Chief of Engineers, in cooperation with the National Committee on Levee Safety, shall jointly establish a Flood Protection Structure Accreditation Task Force.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duties.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Developing process","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The task force shall develop a process to better align the information and data collected by or for the Corps of Engineers under the Inspection of Completed Works Program with the flood protection structure accreditation requirements so that—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information and data collected for either purpose can be used interchangeably; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information and data collected by or for the Corps of Engineers under the Inspection of Completed Works Program is sufficient to satisfy the flood protection structure accreditation requirements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Gathering recommendations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The task force shall gather, and consider in the process developed under subparagraph (A), recommendations from interested persons in each region relating to the information, data, and accreditation requirements described in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Considerations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In developing the process under paragraph (2), the task force shall consider changes to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the information and data collected by or for the Corps of Engineers under the Inspection of Completed Works Program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the flood protection structure accreditation requirements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rule of construction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this section shall be construed to require a reduction in the level of public safety and flood control provided by accredited levees, as determined by the Administrator for purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Implementation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator and the Secretary of the Army, acting through the Chief of Engineers, shall implement the process developed by the task force under subsection (b) not later than 1 year after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2012-07-06"},"text":"July 6, 2012","children":[],"tail":"] and shall complete the process under subsection (b) not later than 2 years after the date of enactment of this Act."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reports","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator and the Secretary of the Army, acting through the Chief of Engineers, in cooperation with the National Committee on Levee Safety, shall jointly submit to the Committee on Banking, Housing, and Urban Affairs and the Committee on Environment and Public Works of the Senate and the Committee on Financial Services, the Committee on Transportation and Infrastructure, and the Committee on Natural Resources of the House of Representatives reports concerning the activities of the task force and the implementation of the process developed by the task force under subsection (b), including—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an interim report, not later than 180 days after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2012-07-06"},"text":"July 6, 2012","children":[],"tail":"]; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a final report, not later than 1 year after the date of enactment of this Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"“(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Termination","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The task force shall terminate on the date of submission of the report under subsection (d)(2).”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[For definitions of terms used in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141/s100226"},"text":"section 100226 of Pub. L. 112–141","children":[],"tail":", set out above, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4004"},"text":"section 4004 of this title","children":[],"tail":".]"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbcb2abb0-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Geospatial Digital Flood Hazard Data","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/264/tI/s107"},"text":"Pub. L. 108–264, title I, § 107","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-06-30"},"text":"June 30, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/724"},"text":"118 Stat. 724","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/264/tI/s107"},"text":"“For the purposes of flood insurance and floodplain management activities conducted pursuant to the National Flood Insurance Program under the National Flood Insurance Act of 1968 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4001"},"text":"42 U.S.C. 4001","children":[],"tail":" et seq.), geospatial digital flood hazard data distributed by the Federal Emergency Management Agency, or its designee, or the printed products derived from that data, are interchangeable and legally equivalent for the determination of the location of 1 in 100 year and 1 in 500 year flood planes [sic], provided that all other geospatial data shown on the printed product meets or exceeds any accuracy standard promulgated by the Federal Emergency Management Agency.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbcb2abb1-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Reiteration of FEMA Responsibility to Map Mudslides","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/264/tI/s109"},"text":"Pub. L. 108–264, title I, § 109","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-06-30"},"text":"June 30, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/725"},"text":"118 Stat. 725","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/109/295/tVI/s612/c"},"text":"Pub. L. 109–295, title VI, § 612(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-04"},"text":"Oct. 4, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1410"},"text":"120 Stat. 1410","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/295/tVI/s612/c"},"text":"“As directed in section 1360(b) of the National Flood Insurance Act of 1968 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4101/b"},"text":"42 U.S.C. 4101(b)","children":[],"tail":"), the Administrator of the Federal Emergency Management Agency is again directed to accelerate the identification of risk zones within flood-prone and mudslide-prone areas, as provided by subsection (a)(2) of such section 1360, in order to make known the degree of hazard within each such zone at the earliest possible date.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbcb2abb2-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Technical Mapping Advisory Council","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/325/tV/s576"},"text":"Pub. L. 103–325, title V, § 576","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-23"},"text":"Sept. 23, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2280"},"text":"108 Stat. 2280","children":[],"tail":", established the Technical Mapping Advisory Council to help improve flood insurance rate maps and provided for its termination 5 years after the appointment of all its members."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
