{"tag":"section","attrib":{"id":"idb575f3c0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285l–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"285l–3"},"text":"§ 285l–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interagency Coordinating Committee on the Validation of Alternative Methods","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb575f3c1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285l–3/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to the interagency coordinating committee that is known as the Interagency Coordinating Committee on the Validation of Alternative Methods (referred to in sections 285","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":"–2 to 285"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"–5 of this title as “ICCVAM”) and that was established by the Director of the National Institute of Environmental Health Sciences for purposes of section 285"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"–1(b) of this title, the Director of the Institute shall designate such committee as a permanent interagency coordinating committee of the Institute under the National Toxicology Program Interagency Center for the Evaluation of Alternative Toxicological Methods. Sections 285"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"–2 to 285"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"–5 of this title may not be construed as affecting the authorities of such Director regarding ICCVAM that were in effect on the day before "},{"tag":"date","attrib":{"date":"2000-12-19"},"text":"December 19, 2000","children":[],"tail":", except to the extent inconsistent with sections 285"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"–2 to 285"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"–5 of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb575f3c2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285l–3/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of the ICCVAM shall be to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb575f3c3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285l–3/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase the efficiency and effectiveness of Federal agency test method review;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb575f3c4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285l–3/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" eliminate unnecessary duplicative efforts and share experiences between Federal regulatory agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb575f3c5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285l–3/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" optimize utilization of scientific expertise outside the Federal Government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb575f3c6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285l–3/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that new and revised test methods are validated to meet the needs of Federal agencies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb575f3c7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285l–3/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reduce, refine, or replace the use of animals in testing, where feasible.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb575f3c8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285l–3/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Composition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The ICCVAM shall be composed of the heads of the following Federal agencies (or their designees):","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb575f3c9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285l–3/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Agency for Toxic Substances and Disease Registry.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb575f3ca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285l–3/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Consumer Product Safety Commission.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb575f3cb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285l–3/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Department of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb575f3cc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285l–3/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb575f3cd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285l–3/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Department of Energy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb575f3ce-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285l–3/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Department of the Interior.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb575f3cf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285l–3/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Department of Transportation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb575f3d0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285l–3/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Environmental Protection Agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb575f3d1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285l–3/c/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Food and Drug Administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb575f3d2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285l–3/c/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" National Institute for Occupational Safety and Health.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb575f3d3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285l–3/c/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" National Institutes of Health.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb575f3d4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285l–3/c/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" National Cancer Institute.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb575f3d5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285l–3/c/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" National Institute of Environmental Health Sciences.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb575f3d6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285l–3/c/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" National Library of Medicine.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb575f3d7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285l–3/c/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Occupational Safety and Health Administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb575f3d8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285l–3/c/16"},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"(16)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other agency that develops, or employs tests or test data using animals, or regulates on the basis of the use of animals in toxicity testing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb575f3d9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285l–3/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scientific Advisory Committee","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb575f3da-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285l–3/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the National Institute of Environmental Health Sciences shall establish a Scientific Advisory Committee (referred to in sections 285","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":"–2 to 285"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"–5 of this title as the “SAC”) to advise ICCVAM and the National Toxicology Program Interagency Center for the Evaluation of Alternative Toxicological Methods regarding ICCVAM activities. The activities of the SAC shall be subject to provisions of chapter 10 of title 5."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb575f3db-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285l–3/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb575f3dc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285l–3/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The SAC shall be composed of the following voting members:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb575f3dd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285l–3/d/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" At least one knowledgeable representative having a history of expertise, development, or evaluation of new or revised or alternative test methods from each of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb575f3de-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285l–3/d/2/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the personal care, pharmaceutical, industrial chemicals, or agriculture industry;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb575f3df-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285l–3/d/2/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other industry that is regulated by the Federal agencies specified in subsection (c); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb575f3e0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285l–3/d/2/A/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a national animal protection organization established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s501/c/3"},"text":"section 501(c)(3) of title 26","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb575f3e1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285l–3/d/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Representatives (selected by the Director of the National Institute of Environmental Health Sciences) from an academic institution, a State government agency, an international regulatory body, or any corporation developing or marketing new or revised or alternative test methodologies, including contract laboratories.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb575f3e2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285l–3/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonvoting ex officio members","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The membership of the SAC shall, in addition to voting members under subparagraph (A), include as nonvoting ex officio members the agency heads specified in subsection (c) (or their designees).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb575f3e3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285l–3/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The ICCVAM shall, consistent with the purposes described in subsection (b), carry out the following functions:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb575f3e4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285l–3/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Review and evaluate new or revised or alternative test methods, including batteries of tests and test screens, that may be acceptable for specific regulatory uses, including the coordination of technical reviews of proposed new or revised or alternative test methods of interagency interest.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb575f3e5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285l–3/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Facilitate appropriate interagency and international harmonization of acute or chronic toxicological test protocols that encourage the reduction, refinement, or replacement of animal test methods.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb575f3e6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285l–3/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Facilitate and provide guidance on the development of validation criteria, validation studies and processes for new or revised or alternative test methods and help facilitate the acceptance of such scientifically valid test methods and awareness of accepted test methods by Federal agencies and other stakeholders.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb575f3e7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285l–3/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Submit ICCVAM test recommendations for the test method reviewed by the ICCVAM, through expeditious transmittal by the Secretary of Health and Human Services (or the designee of the Secretary), to each appropriate Federal agency, along with the identification of specific agency guidelines, recommendations, or regulations for a test method, including batteries of tests and test screens, for chemicals or class of chemicals within a regulatory framework that may be appropriate for scientific improvement, while seeking to reduce, refine, or replace animal test methods.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb57863e8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285l–3/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Consider for review and evaluation, petitions received from the public that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb57863e9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285l–3/e/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify a specific regulation, recommendation, or guideline regarding a regulatory mandate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb57863ea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285l–3/e/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommend new or revised or alternative test methods and provide valid scientific evidence of the potential of the test method.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb57863eb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285l–3/e/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Make available to the public final ICCVAM test recommendations to appropriate Federal agencies and the responses from the agencies regarding such recommendations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb57863ec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285l–3/e/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Prepare reports to be made available to the public on its progress under sections 285","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":"–2 to 285"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"–5 of this title. The first report shall be completed not later than 12 months after "},{"tag":"date","attrib":{"date":"2000-12-19"},"text":"December 19, 2000","children":[],"tail":", and subsequent reports shall be completed biennially thereafter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb57863ed-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/545/s3"},"text":"Pub. L. 106–545, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-19"},"text":"Dec. 19, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2721"},"text":"114 Stat. 2721","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/235"},"text":"Pub. L. 117–286, § 4(a)(235)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4331"},"text":"136 Stat. 4331","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb57863ee-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb57863ef-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb57863f0-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the ICCVAM Authorization Act of 2000, and not as part of the Public Health Service Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb57863f1-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":" substituted “chapter 10 of title 5.” for “the Federal Advisory Committee Act.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb57863f2-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb57863f3-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Advisory Committees","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Advisory committees established after ","children":[{"tag":"date","attrib":{"date":"1973-01-05"},"text":"Jan. 5, 1973","children":[],"tail":", to terminate not later than the expiration of the 2-year period beginning on the date of their establishment, unless, in the case of a committee established by the President or an officer of the Federal Government, such committee is renewed by appropriate action prior to the expiration of such 2-year period, or in the case of a committee established by the Congress, its duration is otherwise provided by law. See "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s1013"},"text":"section 1013 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/93/641/s6"},"text":"Pub. L. 93–641, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-04"},"text":"Jan. 4, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2275"},"text":"88 Stat. 2275","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s217a"},"text":"section 217a of this title","children":[],"tail":", provided that an advisory committee established pursuant to the Public Health Service Act shall terminate at such time as may be specifically prescribed by an Act of Congress enacted after "},{"tag":"date","attrib":{"date":"1975-01-04"},"text":"Jan. 4, 1975","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
