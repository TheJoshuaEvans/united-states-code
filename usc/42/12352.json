{"tag":"section","attrib":{"id":"idbf6aeed3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12352"},"text":null,"children":[{"tag":"num","attrib":{"value":"12352"},"text":"§ 12352.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Family resource and support programs” defined","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this part, the term “family resource and support programs” means community-based services that offer sustained assistance to families at various stages in their development. Such services shall promote parental competencies and behaviors that will lead to the healthy and positive personal development of parents and children through—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf6aeed4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12352/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the provision of assistance to build family skills and assist parents in improving their capacities to be supportive and nurturing parents;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf6aeed5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12352/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the provision of assistance to families to enable such families to use other formal and informal resources and opportunities for assistance that are available within the communities of such families; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf6aeed6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12352/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the creation of supportive networks to enhance the childrearing capacity of parents and assist in compensating for the increased social isolation and vulnerability of families.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf6aeed7-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/501/tIX/s957"},"text":"Pub. L. 101–501, title IX, § 957","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-03"},"text":"Nov. 3, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1278"},"text":"104 Stat. 1278","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf6aeed8-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbf6aeed9-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbf6aeeda-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1990-10-01"},"text":"Oct. 1, 1990","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/101/501/s1001/a"},"text":"section 1001(a) of Pub. L. 101–501","children":[],"tail":", set out as an Effective Date of 1990 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s8621"},"text":"section 8621 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
