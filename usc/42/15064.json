{"tag":"section","attrib":{"id":"idbfdd5f29-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15064"},"text":null,"children":[{"tag":"num","attrib":{"value":"15064"},"text":"§ 15064.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfdd5f2a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15064/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications for core Center grants","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfdd5f2b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15064/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be eligible to receive a grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s15061/a"},"text":"section 15061(a) of this title","children":[],"tail":" for a Center, an entity shall submit to the Secretary, and obtain approval of, an application at such time, in such manner, and containing such information, as the Secretary may require."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfdd5f2c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15064/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application contents","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each application described in paragraph (1) shall describe a 5-year plan, including a projected goal related to 1 or more areas of emphasis for each of the core functions described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s15063/a"},"text":"section 15063(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfdd5f2d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15064/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assurances","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The application shall be approved by the Secretary only if the application contains or is supported by reasonable assurances that the entity designated as the Center will—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfdd5f2e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15064/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meet regulatory standards as established by the Secretary for Centers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfdd5f2f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15064/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" address the projected goals, and carry out goal-related activities, based on data driven strategic planning and in a manner consistent with the objectives of this part, that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbfdd5f30-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15064/a/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are developed in collaboration with the consumer advisory committee established pursuant to subparagraph (E);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbfdd5f31-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15064/a/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are consistent with, and to the extent feasible complement and further, the Council goals contained in the State plan submitted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s15024"},"text":"section 15024 of this title","children":[],"tail":" and the system goals established under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s15043"},"text":"section 15043 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbfdd5f32-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15064/a/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will be reviewed and revised annually as necessary to address emerging trends and needs;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfdd5f33-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15064/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use the funds made available through the grant to supplement, and not supplant, the funds that would otherwise be made available for activities described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s15063/a"},"text":"section 15063(a) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfdd5f34-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15064/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protect, consistent with the policy specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s15001/c"},"text":"section 15001(c) of this title","children":[],"tail":" (relating to rights of individuals with developmental disabilities), the legal and human rights of all individuals with developmental disabilities (especially those individuals under State guardianship) who are involved in activities carried out under programs assisted under this part;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfdd5f35-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15064/a/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" establish a consumer advisory committee—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbfdd5f36-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15064/a/3/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of which a majority of the members shall be individuals with developmental disabilities and family members of such individuals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbfdd5f37-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15064/a/3/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" that is comprised of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbfdd5f38-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15064/a/3/E/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" individuals with developmental disabilities and related disabilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbfdd5f39-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15064/a/3/E/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" family members of individuals with developmental disabilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbfdd5f3a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15064/a/3/E/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a representative of the State protection and advocacy system;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbfdd5f3b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15064/a/3/E/ii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a representative of the State Council on Developmental Disabilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbfdd5f3c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15064/a/3/E/ii/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a representative of a self-advocacy organization described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s15024/c/4/A/ii/I"},"text":"section 15024(c)(4)(A)(ii)(I) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbfdd5f3d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15064/a/3/E/ii/VI"},"text":null,"children":[{"tag":"num","attrib":{"value":"VI"},"text":"(VI)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" representatives of organizations that may include parent training and information centers assisted under section 1471 or 1472 of title 20, entities carrying out activities authorized under section 3003 or 3004 of title 29, relevant State agencies, and other community groups concerned with the welfare of individuals with developmental disabilities and their families;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbfdd5f3e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15064/a/3/E/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that reflects the racial and ethnic diversity of the State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbfdd5f3f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15064/a/3/E/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" that shall—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbfdd5f40-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15064/a/3/E/iv/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consult with the Director of the Center regarding the development of the 5-year plan, and shall participate in an annual review of, and comment on, the progress of the Center in meeting the projected goals contained in the plan, and shall make recommendations to the Director of the Center regarding any proposed revisions of the plan that might be necessary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbfdd5f41-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15064/a/3/E/iv/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meet as often as necessary to carry out the role of the committee, but at a minimum twice during each grant year;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfdd5f42-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15064/a/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent possible, utilize the infrastructure and resources obtained through funds made available under the grant to leverage additional public and private funds to successfully achieve the projected goals developed in the 5-year plan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfdd5f43-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15064/a/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbfdd5f44-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15064/a/3/G/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have a director with appropriate academic credentials, demonstrated leadership, expertise regarding developmental disabilities, significant experience in managing grants and contracts, and the ability to leverage public and private funds; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbfdd5f45-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15064/a/3/G/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allocate adequate staff time to carry out activities related to each of the core functions described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s15063/a"},"text":"section 15063(a) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfdd5f46-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15064/a/3/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" educate, and disseminate information related to the purpose of this subchapter to, the legislature of the State in which the Center is located, and to Members of Congress from such State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfdd5f47-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15064/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supplemental grant applications pertaining to national training initiatives in critical and emerging needs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be eligible to receive a supplemental grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s15061/b"},"text":"section 15061(b) of this title","children":[],"tail":", a Center may submit a supplemental application to the Secretary at such time, in such manner, and containing such information as the Secretary may require, pursuant to the terms and conditions set by the Secretary consistent with "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s15063/b"},"text":"section 15063(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfdd5f48-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15064/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Peer review","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfdd5f49-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15064/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall require that all applications submitted under this part be subject to technical and qualitative review by peer review groups established under paragraph (2). The Secretary may approve an application under this part only if such application has been recommended by a peer review group that has conducted the peer review required under this paragraph. In conducting the review, the group may conduct onsite visits or inspections of related activities as necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfdd5f4a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15064/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of peer review groups","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfdd5f4b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15064/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, acting through the Commissioner of the Administration on Developmental Disabilities, may, notwithstanding—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbfdd5f4c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15064/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the provisions of title 5 concerning appointments to the competitive service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbfdd5f4d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15064/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the provisions of chapter 51, and subchapter III of chapter 53 of title 5 concerning classification and General Schedule pay rates;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"establish such peer review groups and appoint and set the rates of pay of members of such groups.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfdd5f4e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15064/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Composition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each peer review group shall include such individuals with disabilities and parents, guardians, or advocates of or for individuals with developmental disabilities, as are necessary to carry out this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfdd5f4f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15064/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waivers of approval","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may waive the provisions of paragraph (1) with respect to review and approval of an application if the Secretary determines that exceptional circumstances warrant such a waiver.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfdd5f50-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15064/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal share","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfdd5f51-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15064/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal share of the cost of administration or operation of a Center, or the cost of carrying out a training initiative, supported by a grant made under this part may not be more than 75 percent of the necessary cost of such project, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfdd5f52-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15064/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Urban or rural poverty areas","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a project whose activities or products target individuals with developmental disabilities who live in an urban or rural poverty area, as determined by the Secretary, the Federal share of the cost of the project may not be more than 90 percent of the necessary costs of the project, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfdd5f53-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15064/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant expenditures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of determining the Federal share with respect to the project, expenditures on that project by a political subdivision of a State or by a public or private entity shall, subject to such limitations and conditions as the Secretary may by regulation prescribe under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s15004/b"},"text":"section 15004(b) of this title","children":[],"tail":", be considered to be expenditures made by a Center under this part."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfdd5f54-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15064/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each Center shall annually prepare and transmit to the Secretary a report containing—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfdd5f55-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15064/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" information on progress made in achieving the projected goals of the Center for the previous year, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfdd5f56-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15064/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which the goals were achieved;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfdd5f57-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15064/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the strategies that contributed to achieving the goals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfdd5f58-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15064/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent to which the goals were not achieved, a description of factors that impeded the achievement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfdd5f59-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15064/e/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an accounting of the manner in which funds paid to the Center under this part for a fiscal year were expended;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfdd5f5a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15064/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information on proposed revisions to the goals; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfdd5f5b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15064/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of successful efforts to leverage funds, other than funds made available under this part, to pursue goals consistent with this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfdd5f5c-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/402/tI/s154"},"text":"Pub. L. 106–402, title I, § 154","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1722"},"text":"114 Stat. 1722","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/364/s3/a/4"},"text":"Pub. L. 108–364, § 3(a)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-25"},"text":"Oct. 25, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1737"},"text":"118 Stat. 1737","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/446/tIII/s305/n/2"},"text":"Pub. L. 108–446, title III, § 305(n)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-03"},"text":"Dec. 3, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2806"},"text":"118 Stat. 2806","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbfdd5f5d-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbfdd5f5e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbfdd5f5f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—Subsec. (a)(3)(E)(ii)(VI). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/446"},"text":"Pub. L. 108–446","children":[],"tail":" substituted “section 1471 or 1472 of title 20” for “section 1482 or 1483 of title 20”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/364"},"text":"Pub. L. 108–364","children":[],"tail":" substituted “section 3003 or 3004 of title 29” for “section 3011 or 3012 of title 29”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
