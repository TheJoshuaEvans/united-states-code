{"tag":"section","attrib":{"id":"idbbb5d56b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000c–8"},"text":null,"children":[{"tag":"num","attrib":{"value":"2000c–8"},"text":"§ 2000c–8.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Personal suits for relief against discrimination in public education","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing in this subchapter shall affect adversely the right of any person to sue for or obtain relief in any court against discrimination in public education.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbbb5d56c-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/352/tIV/s409"},"text":"Pub. L. 88–352, title IV, § 409","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-07-02"},"text":"July 2, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/249"},"text":"78 Stat. 249","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
