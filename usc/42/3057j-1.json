{"tag":"section","attrib":{"id":"idbc68aa90-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3057j–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"3057j–1"},"text":"§ 3057j–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distribution of funds among organizations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Subject to the availability of appropriations to carry out this part, the amount of the grant (if any) made under this part to an organization for fiscal year 1992 and for each subsequent fiscal year shall be not less than the amount of the grant made under this part to the organization for fiscal year 1991.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbc68aa91-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/73/tVI/s624A"},"text":"Pub. L. 89–73, title VI, § 624A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/375/tVI/s604"},"text":"Pub. L. 102–375, title VI, § 604","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-09-30"},"text":"Sept. 30, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1270"},"text":"106 Stat. 1270","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
