{"tag":"section","attrib":{"id":"idb5ce4c43-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s291m–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"291m–1"},"text":"§ 291m–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loans for certain hospital experimentation projects","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5ce4c44-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s291m–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other public or private sources unavailable for alleviation of hardship due to increased construction costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to alleviate hardship on any recipient of a grant under section 291n ","children":[{"tag":"ref","attrib":{"idref":"fn002255"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002255"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title (as in effect immediately before "},{"tag":"date","attrib":{"date":"1964-08-18"},"text":"August 18, 1964","children":[],"tail":") for a project for the construction of an experimental or demonstration facility having as its specific purpose the application of novel means for the reduction of hospital costs with respect to which there has been a substantial increase in the cost of such construction (over the estimated cost of such project on the basis of which such grant was made) through no fault of such recipient, the Secretary is authorized to make a loan to such recipient not exceeding 66⅔ per centum of such increased costs, as determined by the Secretary, if the Secretary determines that such recipient is unable to obtain such an amount for such purpose from other public or private sources."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5ce4c45-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s291m–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application; form; information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any such loan shall be made only on the basis of an application submitted to the Secretary in such form and containing such information and assurances as he may prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5ce4c46-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s291m–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interest; repayment period","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each such loan shall bear interest at the rate of 2½ per centum per annum on the unpaid balance thereof and shall be repayable over a period determined by the Secretary to be appropriate, but not exceeding fifty years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5ce4c47-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s291m–1/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are hereby authorized to be appropriated $3,500,000 to carry out the provisions of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5ce4c48-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title VI, § 643A, formerly § 623A, as added "},{"tag":"ref","attrib":{"href":"/us/pl/90/174/s11"},"text":"Pub. L. 90–174, § 11","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-12-05"},"text":"Dec. 5, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/541"},"text":"81 Stat. 541","children":[],"tail":", and renumbered § 643A, "},{"tag":"ref","attrib":{"href":"/us/pl/91/296/tII/s201"},"text":"Pub. L. 91–296, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-06-30"},"text":"June 30, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/344"},"text":"84 Stat. 344","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb5ce4c49-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb5ce4c4a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb5ce4c4b-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s291n"},"text":"Section 291n of this title","children":[],"tail":", referred to in subsec. (a), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/90/174/s3/b/1"},"text":"Pub. L. 90–174, § 3(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-12-05"},"text":"Dec. 5, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/535"},"text":"81 Stat. 535","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
