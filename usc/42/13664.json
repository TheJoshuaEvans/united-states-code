{"tag":"section","attrib":{"id":"idbfca4c4d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13664"},"text":null,"children":[{"tag":"num","attrib":{"value":"13664"},"text":"§ 13664.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfca4c4e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13664/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"idref":"fn004183"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004183"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. No subsec. (b) has been enacted."}],"tail":" Definitions"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subchapter, the following definitions shall apply:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfca4c4f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13664/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Drug-related criminal activity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “drug-related criminal activity” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1437a/b"},"text":"section 1437a(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfca4c50-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13664/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federally assisted housing","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “federally assisted housing” means a dwelling unit—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfca4c51-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13664/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in public housing (as such term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1437a/b"},"text":"section 1437a(b) of this title","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfca4c52-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13664/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assisted with tenant-based assistance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1437f"},"text":"section 1437f of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfca4c53-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13664/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in housing that is provided project-based assistance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1437f"},"text":"section 1437f of this title","children":[],"tail":", including new construction and substantial rehabilitation projects;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfca4c54-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13664/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in housing that is assisted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1701q"},"text":"section 1701q of title 12","children":[],"tail":" (as amended by section 801 of the Cranston-Gonzalez National Affordable Housing Act);"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfca4c55-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13664/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in housing that is assisted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1701q"},"text":"section 1701q of title 12","children":[],"tail":", as such section existed before the enactment of the Cranston-Gonzalez National Affordable Housing Act ["},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"November 28, 1990","children":[],"tail":"];"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfca4c56-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13664/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in housing that is assisted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s8013"},"text":"section 8013 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfca4c57-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13664/a/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in housing financed by a loan or mortgage insured under section 1715","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":"(d)(3) of title 12 that bears interest at a rate determined under the proviso of section 1715"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"(d)(5) of title 12;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfca4c58-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13664/a/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in housing insured, assisted, or held by the Secretary or a State or State agency under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1715z–1"},"text":"section 1715z–1 of title 12","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfca4c59-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13664/a/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in housing assisted under section 1484 or 1485 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfca4c5a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13664/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Owner","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “owner” means, with respect to federally assisted housing, the entity or private person (including a cooperative or public housing agency) that has the legal right to lease or sublease dwelling units in such housing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfca4c5b-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/276/tV/s579"},"text":"Pub. L. 105–276, title V, § 579","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2642"},"text":"112 Stat. 2642","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbfca4c5c-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbfca4c5d-3a70-11f1-ae07-e4213316b5fa"},"text":