vision of this section before such date, except to extent otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/105/276/s503"},"text":"section 503 of Pub. L. 105–276","children":[],"tail":", set out as an Effective Date of 1998 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1437"},"text":"section 1437 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
