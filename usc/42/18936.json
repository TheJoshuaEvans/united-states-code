{"tag":"section","attrib":{"id":"idc0713b09-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18936"},"text":null,"children":[{"tag":"num","attrib":{"value":"18936"},"text":"§ 18936.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Neutron scattering","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc0713b0a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18936/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Strategic plan for the Institute neutron reactor","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director shall develop a strategic plan for the future of the NIST Center for Neutron Research after the current neutron reactor is decommissioned, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0713b0b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18936/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a succession plan for the reactor, including a roadmap with timeline and milestones;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0713b0c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18936/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conceptual design of a new reactor and accompanying facilities, as appropriate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0713b0d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18936/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a plan to minimize disruptions to the user community during the transition.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0713b0e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18936/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with the Department of Energy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Director, shall coordinate with the Secretary of Energy on issues related to Federal support for neutron science, including estimation of long-term needs for research using neutron sources, and planning efforts for future facilities to meet such needs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0713b0f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18936/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 30 months after ","children":[{"tag":"date","attrib":{"date":"2022-08-09"},"text":"August 9, 2022","children":[],"tail":", the Director shall submit to Congress the plan required under subsection (a), and shall notify Congress of any substantial updates to such plan in subsequent years."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc0713b10-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/tII/s10231"},"text":"Pub. L. 117–167, div. B, title II, § 10231","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1483"},"text":"136 Stat. 1483","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
