{"tag":"section","attrib":{"id":"idc0203515-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17032"},"text":null,"children":[{"tag":"num","attrib":{"value":"17032"},"text":"§ 17032.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants for biofuel production research and development in certain States","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc0203516-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17032/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide grants to eligible entities for research, development, demonstration, and commercial application of biofuel production technologies in States with low rates of ethanol production, including low rates of production of cellulosic biomass ethanol, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0203517-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17032/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to receive a grant under this section, an entity shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0203518-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17032/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0203519-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17032/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be an institution of higher education (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s15801"},"text":"section 15801 of this title","children":[],"tail":"), including tribally controlled colleges or universities, located in a State described in subsection (a); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc020351a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17032/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be a consortium including at least 1 such institution of higher education and industry, State agencies, Indian tribal agencies, National Laboratories, or local government agencies located in the State; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc020351b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17032/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have proven experience and capabilities with relevant technologies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc020351c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17032/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to the Secretary to carry out this section $25,000,000 for each of fiscal years 2008 through 2010.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc020351d-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/tII/s223"},"text":"Pub. L. 110–140, title II, § 223","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1533"},"text":"121 Stat. 1533","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc020351e-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc020351f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc0203520-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the date that is 1 day after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/s1601"},"text":"section 1601 of Pub. L. 110–140","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1824"},"text":"section 1824 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
