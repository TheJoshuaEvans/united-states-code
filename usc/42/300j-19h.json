{"tag":"section","attrib":{"id":"idb64ca3ed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19h"},"text":null,"children":[{"tag":"num","attrib":{"value":"300j–19h"},"text":"§ 300j–19h.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advanced drinking water technologies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb64ca3ee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19h/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb64ca3ef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19h/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the availability of appropriations, not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2021-11-15"},"text":"November 15, 2021","children":[],"tail":", the Administrator shall carry out a study that examines the state of existing and potential future technology, including technology that could address cybersecurity vulnerabilities, that enhances or could enhance the treatment, monitoring, affordability, efficiency, and safety of drinking water provided by a public water system."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb64ca3f0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19h/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall submit to the Committee on Environment and Public Works of the Senate and the Committee on Energy and Commerce of the House of Representatives a report that describes the results of the study under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb64ca3f1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19h/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advanced drinking water technology grant program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb64ca3f2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19h/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb64ca3f3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19h/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible entity” means the owner or operator of a public water system that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb64ca3f4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19h/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" serves—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb64ca3f5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19h/b/1/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a population of not more than 100,000 people; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb64ca3f6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19h/b/1/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a community described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300j–19a/c/2"},"text":"section 300j–19a(c)(2) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb64ca3f7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19h/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has plans to identify or has identified opportunities in the operations of the public water system to employ new, existing, or emerging, yet proven, technologies, including technology that could address cybersecurity vulnerabilities, as determined by the Administrator, that enhance treatment, monitoring, affordability, efficiency, or safety of the drinking water provided by the public water system, including technologies not identified in the study conducted under subsection (a)(1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb64ca3f8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19h/b/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has expressed an interest in the opportunities in the operation of the public water system to employ new, existing, or emerging, yet proven, technologies, including technology that could address cybersecurity vulnerabilities, as determined by the Administrator, that enhance treatment, monitoring, affordability, efficiency, or safety of the drinking water provided by the public water system, including technologies not identified in the study conducted under subsection (a)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb64ca3f9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19h/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “program” means the competitive grant program established under paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb64ca3fa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19h/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall establish a competitive grant program under which the Administrator shall award grants to eligible entities for the purpose of identifying, deploying, or identifying and deploying technologies described in paragraph (1)(A)(ii).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb64ca3fb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19h/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb64ca3fc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19h/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be eligible to receive a grant under the program, an eligible entity shall submit to the Administrator an application at such time, in such manner, and containing such information as the Administrator may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb64ca3fd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19h/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal share","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb64ca3fe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19h/b/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to clause (ii), the Federal share of the cost of a project carried out using a grant under the program shall not exceed 90 percent of the total cost of the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb64ca3ff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19h/b/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator may increase the Federal share under clause (i) to 100 percent if the Administrator determines that an eligible entity is unable to pay, or would experience significant financial hardship if required to pay, the non-Federal share.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb64ca400-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19h/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 2 years after the date on which the Administrator first awards a grant under the program, and annually thereafter, the Administrator shall submit to Congress a report describing—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb64ca401-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19h/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each recipient of a grant under the program during the previous 1-year period; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb64ca402-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19h/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a summary of the activities carried out using grants awarded under the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb64ca403-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19h/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb64ca404-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19h/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out the program $10,000,000 for each of fiscal years 2022 through 2026, to remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb64ca405-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19h/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not more than 2 percent of the amount made available for a fiscal year under subparagraph (A) to carry out the program may be used by the Administrator for the administrative costs of carrying out the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb64ca406-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XIV, § 1459G, as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/dE/tI/s50112"},"text":"Pub. L. 117–58, div. E, title I, § 50112","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1154"},"text":"135 Stat. 1154","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
