{"tag":"section","attrib":{"id":"idbeb35e11-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9304"},"text":null,"children":[{"tag":"num","attrib":{"value":"9304"},"text":"§ 9304.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Comprehensive program management plan; submittal to Congressional committees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbeb35e12-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9304/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall prepare a comprehensive program management plan for the conduct of the research, development, and demonstration activities under this chapter. Such plan shall include at a minimum—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbeb35e13-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9304/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a presentation of the program strategy which will be used to achieve the purposes of this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbeb35e14-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9304/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a five-year program implementation schedule, including identification of detailed milestone goals, with associated budget and program resources requirements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbeb35e15-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9304/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" risk assessments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbeb35e16-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9304/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supporting research and development needed to solve problems which may inhibit or limit development of magnetic fusion energy systems; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbeb35e17-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9304/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an analysis of institutional, environmental, and economic considerations which are limiting the national magnetic fusion program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbeb35e18-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9304/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall transmit the comprehensive program management plan to the Committee on Science and Technology of the House of Representatives and the Committee on Energy and Natural Resources of the Senate not later than ","children":[{"tag":"date","attrib":{"date":"1982-01-01"},"text":"January 1, 1982","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbeb35e19-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/386/s5"},"text":"Pub. L. 96–386, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-07"},"text":"Oct. 7, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1541"},"text":"94 Stat. 1541","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbeb35e1a-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbeb35e1b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idbeb35e1c-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Science and Technology of House of Representatives changed to Committee on Science, Space, and Technology of House of Representatives by House Resolution No. 5, One Hundred Twelfth Congress, ","children":[{"tag":"date","attrib":{"date":"2011-01-05"},"text":"Jan. 5, 2011","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
