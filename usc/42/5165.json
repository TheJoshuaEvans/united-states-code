{"tag":"section","attrib":{"id":"idbd120a66-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5165"},"text":null,"children":[{"tag":"num","attrib":{"value":"5165"},"text":"§ 5165.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mitigation planning","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd120a67-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5165/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement of mitigation plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As a condition of receipt of an increased Federal share for hazard mitigation measures under subsection (e), a State, local, or tribal government shall develop and submit for approval to the President a mitigation plan that outlines processes for identifying the natural hazards, risks, and vulnerabilities of the area under the jurisdiction of the government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd120a68-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5165/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Local and tribal plans","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each mitigation plan developed by a local or tribal government shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd120a69-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5165/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describe actions to mitigate hazards, risks, and vulnerabilities identified under the plan; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd120a6a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5165/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish a strategy to implement those actions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd120a6b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5165/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State plans","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The State process of development of a mitigation plan under this section shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd120a6c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5165/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify the natural hazards, risks, and vulnerabilities of areas in the State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd120a6d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5165/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support development of local mitigation plans;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd120a6e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5165/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for technical assistance to local and tribal governments for mitigation planning; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd120a6f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5165/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify and prioritize mitigation actions that the State will support, as resources become available.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd120a70-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5165/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd120a71-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5165/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Federal contributions under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5170c"},"text":"section 5170c of this title","children":[],"tail":" may be used to fund the development and updating of mitigation plans under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd120a72-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5165/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum Federal contribution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to any mitigation plan, a State, local, or tribal government may use an amount of Federal contributions under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5170c"},"text":"section 5170c of this title","children":[],"tail":" not to exceed 7 percent of the amount of such contributions available to the government as of a date determined by the government."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd120a73-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5165/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Increased Federal share for hazard mitigation measures","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd120a74-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5165/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If, at the time of the declaration of a major disaster or event under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5187"},"text":"section 5187 of this title","children":[],"tail":", a State has in effect an approved mitigation plan under this section, the President may increase to 20 percent, with respect to the major disaster or event under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5187"},"text":"section 5187 of this title","children":[],"tail":", the maximum percentage specified in the last sentence of "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5170c/a"},"text":"section 5170c(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd120a75-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5165/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Factors for consideration","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In determining whether to increase the maximum percentage under paragraph (1), the President shall consider whether the State has established—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd120a76-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5165/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" eligibility criteria for property acquisition and other types of mitigation measures;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd120a77-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5165/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requirements for cost effectiveness that are related to the eligibility criteria;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd120a78-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5165/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a system of priorities that is related to the eligibility criteria; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd120a79-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5165/e/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a process by which an assessment of the effectiveness of a mitigation action may be carried out after the mitigation action is complete.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd120a7a-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/288/tIII/s322"},"text":"Pub. L. 93–288, title III, § 322","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/390/tI/s104/a"},"text":"Pub. L. 106–390, title I, § 104(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1558"},"text":"114 Stat. 1558","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/254/dD/s1204/b/2"},"text":"Pub. L. 115–254, div. D, § 1204(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3439"},"text":"132 Stat. 3439","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd120a7b-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd120a7c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd120a7d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254"},"text":"Pub. L. 115–254","children":[],"tail":" inserted “or event under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5187"},"text":"section 5187 of this title","children":[],"tail":"” after “major disaster” in two places."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbd120a7e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbd120a7f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254"},"text":"Pub. L. 115–254","children":[],"tail":" applicable to each major disaster and emergency declared by the President on or after "},{"tag":"date","attrib":{"date":"2017-08-01"},"text":"Aug. 1, 2017","children":[],"tail":", and authorities provided under div. D of "},{"tag":"ref","attrib":{"href":"/us/pl/115/254"},"text":"Pub. L. 115–254","children":[],"tail":" applicable to each major disaster and emergency declared by the President on or after "},{"tag":"date","attrib":{"date":"2016-01-01"},"text":"Jan. 1, 2016","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/254/s1202"},"text":"section 1202 of Pub. L. 115–254","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5121"},"text":"section 5121 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
