{"tag":"section","attrib":{"id":"idbb481eeb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1754"},"text":null,"children":[{"tag":"num","attrib":{"value":"1754"},"text":"§ 1754.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nutrition promotion","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbb481eec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1754/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the availability of funds made available under subsection (g), the Secretary shall make payments to State agencies for each fiscal year, in accordance with this section, to promote nutrition in food service programs under this chapter and the school breakfast program established under the Child Nutrition Act of 1966 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1771"},"text":"42 U.S.C. 1771","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb481eed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1754/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Total amount for each fiscal year","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The total amount of funds available for a fiscal year for payments under this section shall equal not more than the product obtained by multiplying—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb481eee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1754/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ½ cent; by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb481eef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1754/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of lunches reimbursed through food service programs under this chapter during the second preceding fiscal year in schools, institutions, and service institutions that participate in the food service programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb481ef0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1754/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments to States","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb481ef1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1754/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to paragraph (2), from the amount of funds available under subsection (g) for a fiscal year, the Secretary shall allocate to each State agency an amount equal to the greater of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbb481ef2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1754/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a uniform base amount established by the Secretary; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb481ef3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1754/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an amount determined by the Secretary, based on the ratio that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbb481ef4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1754/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of lunches reimbursed through food service programs under this chapter in schools, institutions, and service institutions in the State that participate in the food service programs; bears to","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbb481ef5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1754/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of lunches reimbursed through the food service programs in schools, institutions, and service institutions in all States that participate in the food service programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb481ef6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1754/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reductions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall reduce allocations to State agencies qualifying for an allocation under paragraph (1)(B), in a manner determined by the Secretary, to the extent necessary to ensure that the total amount of funds allocated under paragraph (1) is not greater than the amount appropriated under subsection (g).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb481ef7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1754/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of payments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb481ef8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1754/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use by State agencies","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A State agency may reserve, to support dissemination and use of nutrition messages and material developed by the Secretary, up to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbb481ef9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1754/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 5 percent of the payment received by the State for a fiscal year under subsection (c); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb481efa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1754/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a small State (as determined by the Secretary), a higher percentage (as determined by the Secretary) of the payment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb481efb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1754/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disbursement to schools and institutions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (3), the State agency shall disburse any remaining amount of the payment to school food authorities and institutions participating in food service programs described in subsection (a) to disseminate and use nutrition messages and material developed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb481efc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1754/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Summer food service program for children","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In addition to any amounts reserved under paragraph (1), in the case of the summer food service program for children established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1761"},"text":"section 1761 of this title","children":[],"tail":", the State agency may—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbb481efd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1754/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" retain a portion of the funds made available under subsection (c) (as determined by the Secretary); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb481efe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1754/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use the funds, in connection with the program, to disseminate and use nutrition messages and material developed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb481eff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1754/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Documentation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State agency, school food authority, and institution receiving funds under this section shall maintain documentation of nutrition promotion activities conducted under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb481f00-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1754/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reallocation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may reallocate, to carry out this section, any amounts made available to carry out this section that are not obligated or expended, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb481f01-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1754/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums as are necessary to carry out this section, to remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbb481f02-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-06-04/ch281/s5"},"text":"June 4, 1946, ch. 281, § 5","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/265/tI/s101"},"text":"Pub. L. 108–265, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-06-30"},"text":"June 30, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/730"},"text":"118 Stat. 730","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbb481f03-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbb481f04-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbb481f05-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Child Nutrition Act of 1966, referred to in subsec. (a), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/642"},"text":"Pub. L. 89–642","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-10-11"},"text":"Oct. 11, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/885"},"text":"80 Stat. 885","children":[],"tail":", which is classified generally to chapter 13A (§ 1771 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1771"},"text":"section 1771 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbb481f06-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1754, acts ","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-06-04/ch281/s5"},"text":"June 4, 1946, ch. 281, § 5","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/60/231"},"text":"60 Stat. 231","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1952-07-12/ch699/s1/b"},"text":"July 12, 1952, ch. 699, § 1(b)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/66/591"},"text":"66 Stat. 591","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1962-09-25"},"text":"Sept. 25, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/87/688/s3/a"},"text":"Pub. L. 87–688, § 3(a)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/587"},"text":"76 Stat. 587","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1962-10-15"},"text":"Oct. 15, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/87/823/s3/a"},"text":"Pub. L. 87–823, § 3(a)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/945"},"text":"76 Stat. 945","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1977-11-10"},"text":"Nov. 10, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/95/166/s3"},"text":"Pub. L. 95–166, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1332"},"text":"91 Stat. 1332","children":[],"tail":", related to amount, apportionment, etc., for food service equipment assistance, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tVIII"},"text":"Pub. L. 97–35, title VIII","children":[],"tail":", §§ 805(a), 820(a)(4), "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/527"},"text":"95 Stat. 527","children":[],"tail":", 534, effective "},{"tag":"date","attrib":{"date":"1981-10-01"},"text":"Oct. 1, 1981","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbb481f07-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbb481f08-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/265/tV/s502"},"text":"Pub. L. 108–265, title V, § 502","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-06-30"},"text":"June 30, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/789"},"text":"118 Stat. 789","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/108/447/dA/tVII/s788/f"},"text":"Pub. L. 108–447, div. A, title VII, § 788(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-08"},"text":"Dec. 8, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2851"},"text":"118 Stat. 2851","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/447/dA/tVII/s788/f"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as otherwise provided in this Act [see Short Title of 2004 Amendment note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1751"},"text":"section 1751 of this title","children":[],"tail":"], this Act and the amendments made by this Act take effect on the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"2004-06-30"},"text":"June 30, 2004","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Special Effective Dates.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":null,"children":[{"tag":"date","attrib":{"date":"2004-07-01"},"text":"July 1, 2004","children":[],"tail":null}],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendments made by sections 106, 107, 126(c), and 201 [amending sections 1758, 1773, and 1776 of this title] take effect on ","children":[{"tag":"date","attrib":{"date":"2004-07-01"},"text":"July 1, 2004","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":null,"children":[{"tag":"date","attrib":{"date":"2004-10-01"},"text":"October 1, 2004","children":[],"tail":null}],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendments made by sections 119(c), 119(g), 202(a), 203(a), 203(b), 203(c)(1), 203(c)(5), 203(e)(8), 203(e)(10), 203(e)(13), 203(f), 203(h)(1), and 203(h)(2) [amending sections 1766, 1776, and 1786 of this title] take effect on ","children":[{"tag":"date","attrib":{"date":"2004-10-01"},"text":"October 1, 2004","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":null,"children":[{"tag":"date","attrib":{"date":"2005-01-01"},"text":"January 1, 2005","children":[],"tail":null}],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendments made by sections 116(f)(1) and 116(f)(3) [amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1769"},"text":"section 1769 of this title","children":[],"tail":"] take effect on "},{"tag":"date","attrib":{"date":"2005-01-01"},"text":"January 1, 2005","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":null,"children":[{"tag":"date","attrib":{"date":"2005-07-01"},"text":"July 1, 2005","children":[],"tail":null}],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendments made by sections 102, 104 (other than section 104(a)(1)), 105, 111, and 126(b) [amending sections 1396a, 1758, 1759a, and 1769c of this title and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2020"},"text":"section 2020 of Title 7","children":[],"tail":", Agriculture] take effect on "},{"tag":"date","attrib":{"date":"2005-07-01"},"text":"July 1, 2005","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":null,"children":[{"tag":"date","attrib":{"date":"2005-10-01"},"text":"October 1, 2005","children":[],"tail":null}],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendments made by sections 116(d) and 203(e)(9) [amending sections 1761 and 1786 of this title] take effect on ","children":[{"tag":"date","attrib":{"date":"2005-10-01"},"text":"October 1, 2005","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
