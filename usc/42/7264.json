{"tag":"section","attrib":{"id":"idbdfe1777-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7264"},"text":null,"children":[{"tag":"num","attrib":{"value":"7264"},"text":"§ 7264.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Seal of Department","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary shall cause a seal of office to be made for the Department of such design as he shall approve and judicial notice shall be taken of such seal.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbdfe1778-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/91/tVI/s654"},"text":"Pub. L. 95–91, title VI, § 654","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-08-04"},"text":"Aug. 4, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/602"},"text":"91 Stat. 602","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
