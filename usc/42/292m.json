{"tag":"section","attrib":{"id":"idb5d30766-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s292m"},"text":null,"children":[{"tag":"num","attrib":{"value":"292m"},"text":"§ 292m.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repayment by Secretary of loans of deceased or disabled borrowers","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"If a borrower who has received a loan dies or becomes permanently and totally disabled (as determined in accordance with regulations of the Secretary), the Secretary shall discharge the borrower’s liability on the loan by repaying the amount owed on the loan from the account established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s292i"},"text":"section 292i of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb5d30767-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title VII, § 714, as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/408/tI/s102"},"text":"Pub. L. 102–408, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-13"},"text":"Oct. 13, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2008"},"text":"106 Stat. 2008","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
