{"tag":"section","attrib":{"id":"idbf091f23-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9921"},"text":null,"children":[{"tag":"num","attrib":{"value":"9921"},"text":"§ 9921.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Discretionary authority of Secretary","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf091f24-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9921/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants, contracts, arrangements, loans, and guarantees","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf091f25-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9921/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall, from funds reserved under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s9903/b/3"},"text":"section 9903(b)(3) of this title","children":[],"tail":", make grants, loans, or guarantees to States and public agencies and private, nonprofit organizations, or enter into contracts or jointly financed cooperative arrangements with States and public agencies and private, nonprofit organizations (and for-profit organizations, to the extent specified in paragraph (2)(E)) for each of the objectives described in paragraphs (2) through (4)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf091f26-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9921/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Community economic development","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf091f27-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9921/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Economic development activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall make grants described in paragraph (1) on a competitive basis to private, nonprofit organizations that are community development corporations to provide technical and financial assistance for economic development activities designed to address the economic needs of low-income individuals and families by creating employment and business development opportunities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf091f28-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9921/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall exercise the authority provided under subparagraph (A) after consultation with other relevant Federal officials.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf091f29-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9921/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Governing boards","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For a community development corporation to receive funds to carry out this paragraph, the corporation shall be governed by a board that shall consist of residents of the community and business and civic leaders and shall have as a principal purpose planning, developing, or managing low-income housing or community development projects.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf091f2a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9921/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Geographic distribution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In making grants to carry out this paragraph, the Secretary shall take into consideration the geographic distribution of funding among States and the relative proportion of funding among rural and urban areas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf091f2b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9921/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reservation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the amounts made available to carry out this paragraph, the Secretary may reserve not more than 1 percent for each fiscal year to make grants to private, nonprofit organizations or to enter into contracts with private, nonprofit or for-profit organizations to provide technical assistance to aid community development corporations in developing or implementing activities funded to carry out this paragraph and to evaluate activities funded to carry out this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf091f2c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9921/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rural community development activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall provide the assistance described in paragraph (1) for rural community development activities, which shall include providing—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf091f2d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9921/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" grants to private, nonprofit corporations to enable the corporations to provide assistance concerning home repair to rural low-income families and concerning planning and developing low-income rural rental housing units; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf091f2e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9921/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" grants to multistate, regional, private, nonprofit organizations to enable the organizations to provide training and technical assistance to small, rural communities concerning meeting their community facility needs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf091f2f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9921/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Neighborhood innovation projects","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide the assistance described in paragraph (1) for neighborhood innovation projects, which shall include providing grants to neighborhood-based private, nonprofit organizations to test or assist in the development of new approaches or methods that will aid in overcoming special problems identified by communities or neighborhoods or otherwise assist in furthering the purposes of this chapter, and which may include providing assistance for projects that are designed to serve low-income individuals and families who are not being effectively served by other programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf091f30-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9921/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall require all activities receiving assistance under this section to be evaluated for their effectiveness. Funding for such evaluations shall be provided as a stated percentage of the assistance or through a separate grant awarded by the Secretary specifically for the purpose of evaluation of a particular activity or group of activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf091f31-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9921/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall compile an annual report containing a summary of the evaluations required in subsection (b) and a listing of all activities assisted under this section. The Secretary shall annually submit the report to the Chairperson of the Committee on Education and the Workforce of the House of Representatives and the Chairperson of the Committee on Labor and Human Resources of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf091f32-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35/tVI/s680"},"text":"Pub. L. 97–35, title VI, § 680","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/285/tII/s201"},"text":"Pub. L. 105–285, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-27"},"text":"Oct. 27, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2750"},"text":"112 Stat. 2750","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf091f33-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf091f34-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbf091f35-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35/s680"},"text":"section 680 of Pub. L. 97–35","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s9909"},"text":"section 9909 of this title","children":[],"tail":", prior to the general amendment of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/105/285"},"text":"Pub. L. 105–285","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbf091f36-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idbf091f37-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Labor and Human Resources of Senate changed to Committee on Health, Education, Labor, and Pensions of Senate by Senate Resolution No. 20, One Hundred Sixth Congress, ","children":[{"tag":"date","attrib":{"date":"1999-01-19"},"text":"Jan. 19, 1999","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbf091f38-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Procedures To Permit Grant Funds or Intangible Property Acquired by Grant Funds To Become Sole Property of Grantees","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/75/dB/tII"},"text":"Pub. L. 119–75, div. B, title II","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2026-02-03"},"text":"Feb. 3, 2026","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/140/277"},"text":"140 Stat. 277","children":[],"tail":", provided in part: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/75/dB/tII"},"text":"“That the Secretary [of Health and Human Services] shall establish procedures regarding the disposition of intangible assets and program income that permit such assets acquired with, and program income derived from, grant funds authorized under section 680 of the CSBG Act [Community Services Block Grant Act, ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s9921"},"text":"42 U.S.C. 9921","children":[],"tail":"] to become the sole property of such grantees after a period of not more than 12 years after the end of the grant period for any activity consistent with section 680(a)(2)(A) of the CSBG Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s9921/a/2/A"},"text":"42 U.S.C. 9921(a)(2)(A)","children":[],"tail":"]: "},{"tag":"i","attrib":{},"text":"Provided further","children":[],"tail":", That intangible assets in the form of loans, equity investments and other debt instruments, and program income may be used by grantees for any eligible purpose consistent with section 680(a)(2)(A) of the CSBG Act: "},{"tag":"i","attrib":{},"text":"Provided further","children":[],"tail":", That these procedures shall apply to such grant funds made available after "},{"tag":"date","attrib":{"date":"1999-11-29"},"text":"November 29, 1999","children":[],"tail":"”."}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Similar provisions were contained in the following prior appropriation acts:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/47/dD/tII"},"text":"Pub. L. 118–47, div. D, title II","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-03-23"},"text":"Mar. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/666"},"text":"138 Stat. 666","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/dH/tII"},"text":"Pub. L. 117–328, div. H, title II","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4873"},"text":"136 Stat. 4873","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/dH/tII"},"text":"Pub. L. 117–103, div. H, title II","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/460"},"text":"136 Stat. 460","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dH/tII"},"text":"Pub. L. 116–260, div. H, title II","children":[],"tail":