{"tag":"section","attrib":{"id":"idbff52c58-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16138"},"text":null,"children":[{"tag":"num","attrib":{"value":"16138"},"text":"§ 16138.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" EPA authority to accept diesel emissions reduction Supplemental Environmental Projects","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Administrator of the Environmental Protection Agency (hereinafter, the “Agency”) may accept (notwithstanding sections 3302 and 1301 of title 31) diesel emissions reduction Supplemental Environmental Projects if the projects, as part of a settlement of any alleged violations of environmental law—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbff52c59-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16138/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protect human health or the environment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff52c5a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16138/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are related to the underlying alleged violations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff52c5b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16138/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" do not constitute activities that the defendant would otherwise be legally required to perform; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff52c5c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16138/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" do not provide funds for the staff of the Agency or for contractors to carry out the Agency’s internal operations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbff52c5d-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/255/s1"},"text":"Pub. L. 110–255, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-06-30"},"text":"June 30, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2423"},"text":"122 Stat. 2423","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbff52c5e-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbff52c5f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbff52c60-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of the Energy Policy Act of 2005 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
