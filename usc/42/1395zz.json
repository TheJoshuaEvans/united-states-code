ed on or after "},{"tag":"date","attrib":{"date":"1989-01-01"},"text":"Jan. 1, 1989","children":[],"tail":", and to oxygen and oxygen equipment furnished on or after "},{"tag":"date","attrib":{"date":"1989-06-01"},"text":"June 1, 1989","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idba019538-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2003—Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/173/s921/d/1"},"text":"Pub. L. 108–173, § 921(d)(1)","children":[],"tail":", added subsecs. (b) and (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/173/s921/e/1"},"text":"Pub. L. 108–173, § 921(e)(1)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (e) to (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/173/s921/f/1"},"text":"Pub. L. 108–173, § 921(f)(1)","children":[],"tail":", added subsecs. (e) to (g)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idba019539-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idba01953a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2003 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/173/tIX/s921/d/2"},"text":"Pub. L. 108–173, title IX, § 921(d)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-08"},"text":"Dec. 8, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2391"},"text":"117 Stat. 2391","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/173/tIX/s921/d/2"},"text":"“The amendment made by paragraph (1) [amending this section] shall take effect on ","children":[{"tag":"date","attrib":{"date":"2004-10-01"},"text":"October 1, 2004","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/173/tIX/s921/e/2"},"text":"Pub. L. 108–173, title IX, § 921(e)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-08"},"text":"Dec. 8, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2391"},"text":"117 Stat. 2391","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/173/tIX/s921/e/2"},"text":"“The amendment made by paragraph (1) [amending this section] shall take effect on ","children":[{"tag":"date","attrib":{"date":"2004-10-01"},"text":"October 1, 2004","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/173/tIX/s921/f/2"},"text":"Pub. L. 108–173, title IX, § 921(f)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-08"},"text":"Dec. 8, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2392"},"text":"117 Stat. 2392","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/173/tIX/s921/f/2"},"text":"“The amendment made by paragraph (1) [amending this section] shall take effect on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2003-12-08"},"text":"Dec. 8, 2003","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idba01953b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/173/tIX/s921/a/2"},"text":"Pub. L. 108–173, title IX, § 921(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-08"},"text":"Dec. 8, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2388"},"text":"117 Stat. 2388","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/173/tIX/s921/a/2"},"text":"“The amendment made by paragraph (1) [enacting this section] shall take effect on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2003-12-08"},"text":"Dec. 8, 2003","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idba01953c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Small Provider Technical Assistance Demonstration Program","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/173/tIX/s922"},"text":"Pub. L. 108–173, title IX, § 922","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-08"},"text":"Dec. 8, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2392"},"text":"117 Stat. 2392","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/173/tIX/s922"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary [of Health and Human Services] shall establish a demonstration program (in this section referred to as the ‘demonstration program’) under which technical assistance described in paragraph (2) is made available, upon request and on a voluntary basis, to small providers of services or suppliers in order to improve compliance with the applicable requirements of the programs under medicare program under title XVIII of the Social Security Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395"},"text":"42 U.S.C. 1395","children":[],"tail":" et seq.] (including provisions of title XI of such Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1301"},"text":"42 U.S.C. 1301","children":[],"tail":" et seq.] insofar as they relate to such title and are not administered by the Office of the Inspector General of the Department of Health and Human Services)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Forms of technical assistance","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The technical assistance described in this paragraph is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluation and recommendations regarding billing and related systems; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information and assistance regarding policies and procedures under the medicare program, including coding and reimbursement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Small providers of services or suppliers","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term ‘small providers of services or suppliers’ means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a provider of services with fewer than 25 full-time-equivalent employees; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a supplier with fewer than 10 full-time-equivalent employees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Qualification of Contractors","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In conducting the demonstration program, the Secretary shall enter into contracts with qualified organizations (such as peer review [now “quality improvement”] organizations or entities described in section 1889(g)(2) of the Social Security Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395zz/g/2"},"text":"42 U.S.C. 1395zz(g)(2)","children":[],"tail":"], as inserted by section 921(f)(1)) with appropriate expertise with billing systems of the full range of providers of services and suppliers to provide the technical assistance. In awarding such contracts, the Secretary shall consider any prior investigations of the entity’s work by the Inspector General of Department of Health and Human Services or the Comptroller General of the United States."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Description of Technical Assistance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The technical assistance provided under the demonstration program shall include a direct and in-person examination of billing systems and internal controls of small providers of services or suppliers to determine program compliance and to suggest more efficient or effective means of achieving such compliance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" GAO ","children":[{"tag":"inline","attrib":{},"text":"Evaluation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 2 years after the date the demonstration program is first implemented, the Comptroller General, in consultation with the Inspector General of the Department of Health and Human Services, shall conduct an evaluation of the demonstration program. The evaluation shall include a determination of whether claims error rates are reduced for small providers of services or suppliers who participated in the program and the extent of improper payments made as a result of the demonstration program. The Comptroller General shall submit a report to the Secretary and the Congress on such evaluation and shall include in such report recommendations regarding the continuation or extension of the demonstration program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"“(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Financial Participation by Providers","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The provision of technical assistance to a small provider of services or supplier under the demonstration program is conditioned upon the small provider of services or supplier paying an amount estimated (and disclosed in advance of a provider’s or supplier’s participation in the program) to be equal to 25 percent of the cost of the technical assistance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"“(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorization of Appropriations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There are authorized to be appropriated, from amounts not otherwise appropriated in the Treasury, such sums as may be necessary to carry out this section.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
