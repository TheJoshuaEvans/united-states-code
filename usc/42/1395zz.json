{"tag":"section","attrib":{"id":"idba019520-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395zz"},"text":null,"children":[{"tag":"num","attrib":{"value":"1395zz"},"text":"§ 1395zz.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provider education and technical assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idba019521-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395zz/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination of education funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall coordinate the educational activities provided through medicare contractors (as defined in subsection (g), including under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395ddd"},"text":"section 1395ddd of this title","children":[],"tail":") in order to maximize the effectiveness of Federal education efforts for providers of services and suppliers."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idba019522-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395zz/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enhanced education and training","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idba019523-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395zz/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional resources","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to the Secretary (in appropriate part from the Federal Hospital Insurance Trust Fund and the Federal Supplementary Medical Insurance Trust Fund) such sums as may be necessary for fiscal years beginning with fiscal year 2005.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idba019524-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395zz/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The funds made available under paragraph (1) shall be used to increase the conduct by medicare contractors of education and training of providers of services and suppliers regarding billing, coding, and other appropriate items and may also be used to improve the accuracy, consistency, and timeliness of contractor responses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idba019525-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395zz/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tailoring education and training activities for small providers or suppliers","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idba019526-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395zz/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Insofar as a medicare contractor conducts education and training activities, it shall tailor such activities to meet the special needs of small providers of services or suppliers (as defined in paragraph (2)). Such education and training activities for small providers of services and suppliers may include the provision of technical assistance (such as review of billing systems and internal controls to determine program compliance and to suggest more efficient and effective means of achieving such compliance).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idba019527-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395zz/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Small provider of services or supplier","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection, the term “small provider of services or supplier” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idba019528-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395zz/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a provider of services with fewer than 25 full-time-equivalent employees; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idba019529-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395zz/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a supplier with fewer than 10 full-time-equivalent employees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idba01952a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395zz/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Internet websites; FAQs","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, and each medicare contractor insofar as it provides services (including claims processing) for providers of services or suppliers, shall maintain an Internet website which—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idba01952b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395zz/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides answers in an easily accessible format to frequently asked questions, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idba01952c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395zz/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes other published materials of the contractor,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"that relate to providers of services and suppliers under the programs under this subchapter (and subchapter XI insofar as it relates to such programs).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idba01952d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395zz/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Encouragement of participation in education program activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A medicare contractor may not use a record of attendance at (or failure to attend) educational activities or other information gathered during an educational program conducted under this section or otherwise by the Secretary to select or track providers of services or suppliers for the purpose of conducting any type of audit or prepayment review.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idba01952e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395zz/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this section or ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395ddd/g"},"text":"section 1395ddd(g) of this title","children":[],"tail":" shall be construed as providing for disclosure by a medicare contractor—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idba01952f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395zz/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of the screens used for identifying claims that will be subject to medical review; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idba019530-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395zz/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of information that would compromise pending law enforcement activities or reveal findings of law enforcement-related audits.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idba019531-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395zz/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “medicare contractor” includes the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idba019532-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395zz/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A medicare administrative contractor with a contract under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395kk–1"},"text":"section 1395kk–1 of this title","children":[],"tail":", including a fiscal intermediary with a contract under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395h"},"text":"section 1395h of this title","children":[],"tail":" and a carrier with a contract under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395u"},"text":"section 1395u of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idba019533-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395zz/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An eligible entity with a contract under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395ddd"},"text":"section 1395ddd of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Such term does not include, with respect to activities of a specific provider of services or supplier an entity that has no authority under this subchapter or subchapter IX with respect to such activities and such provider of services or supplier.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idba019534-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title XVIII, § 1889, as added and amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/173/tIX/s921/a/1"},"text":"Pub. L. 108–173, title IX, § 921(a)(1)","children":[],"tail":", (d)(1), (e)(1), (f)(1), "},{"tag":"date","attrib":{"date":"2003-12-08"},"text":"Dec. 8, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2388"},"text":"117 Stat. 2388","children":[],"tail":", 2391.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idba019535-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[