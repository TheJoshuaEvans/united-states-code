{"tag":"section","attrib":{"id":"idba0d7be0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395hhh"},"text":null,"children":[{"tag":"num","attrib":{"value":"1395hhh"},"text":"§ 1395hhh.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Health care infrastructure improvement program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idba0d7be1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395hhh/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a loan program that provides loans to qualifying hospitals for payment of the capital costs of projects described in subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idba0d7be2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395hhh/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No loan may be provided under this section to a qualifying hospital except pursuant to an application that is submitted and approved in a time, manner, and form specified by the Secretary. A loan under this section shall be on such terms and conditions and meet such requirements as the Secretary determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idba0d7be3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395hhh/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection criteria","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idba0d7be4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395hhh/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish criteria for selecting among qualifying hospitals that apply for a loan under this section. Such criteria shall consider the extent to which the project for which loan is sought is nationally or regionally significant, in terms of expanding or improving the health care infrastructure of the United States or the region or in terms of the medical benefit that the project will have.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idba0d7be5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395hhh/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifying hospital defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “qualifying hospital” means a hospital or an entity described in paragraph (3) that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idba0d7be6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395hhh/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is engaged in research in the causes, prevention, and treatment of cancer; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idba0d7be7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395hhh/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is designated as a cancer center for the National Cancer Institute or is designated by the State legislature as the official cancer institute of the State and such designation by the State legislature occurred prior to ","children":[{"tag":"date","attrib":{"date":"2003-12-08"},"text":"December 8, 2003","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idba0d7be8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395hhh/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Entity described","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An entity described in this paragraph is an entity that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idba0d7be9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395hhh/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is described in section 501(c)(3) of the Internal Revenue Code of 1986 and exempt from tax under section 501(a) of such Code;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idba0d7bea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395hhh/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has at least 1 existing memorandum of understanding or affiliation agreement with a hospital located in the State in which the entity is located; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idba0d7beb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395hhh/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" retains clinical outpatient treatment for cancer on site as well as lab research and education and outreach for cancer in the same facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idba0d7bec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395hhh/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Projects","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A project described in this subsection is a project of a qualifying hospital that is designed to improve the health care infrastructure of the hospital, including construction, renovation, or other capital improvements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idba0d7bed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395hhh/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State and local permits","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The provision of a loan under this section with respect to a project shall not—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idba0d7bee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395hhh/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" relieve any recipient of the loan of any obligation to obtain any required State or local permit or approval with respect to the project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idba0d7bef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395hhh/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" limit the right of any unit of State or local government to approve or regulate any rate of return on private equity invested in the project; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idba0d7bf0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395hhh/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" otherwise supersede any State or local law (including any regulation) applicable to the construction or operation of the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idba0d7bf1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395hhh/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Forgiveness of indebtedness","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may forgive a loan provided to a qualifying hospital under this section under terms and conditions that are analogous to the loan forgiveness provision for student loans under part D of title IV of the Higher Education Act of 1965 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1087a"},"text":"20 U.S.C. 1087a","children":[],"tail":" et seq.), except that the Secretary shall condition such forgiveness on the establishment by the hospital of—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idba0d7bf2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395hhh/f/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an outreach program for cancer prevention, early diagnosis, and treatment that provides services to a substantial majority of the residents of a State or region, including residents of rural areas;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idba0d7bf3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395hhh/f/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an outreach program for cancer prevention, early diagnosis, and treatment that provides services to multiple Indian tribes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idba0d7bf4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395hhh/f/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idba0d7bf5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395hhh/f/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" unique research resources (such as population databases); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idba0d7bf6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395hhh/f/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an affiliation with an entity that has unique research resources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idba0d7bf7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395hhh/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idba0d7bf8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395hhh/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are appropriated, out of amounts in the Treasury not otherwise appropriated, to carry out this section, $200,000,000, to remain available during the period beginning on ","children":[{"tag":"date","attrib":{"date":"2004-07-01"},"text":"July 1, 2004","children":[],"tail":", and ending on "},{"tag":"date","attrib":{"date":"2008-09-30"},"text":"September 30, 2008","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idba0d7bf9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395hhh/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"From funds made available under paragraph (1), the Secretary may use, for the administration of this section, not more than $2,000,000 for each of fiscal years 2004 through 2008.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idba0d7bfa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395hhh/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts appropriated under this section shall be available for obligation on ","children":[{"tag":"date","attrib":{"date":"2004-07-01"},"text":"July 1, 2004","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idba0d7bfb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395hhh/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 4 years after ","children":[{"tag":"date","attrib":{"date":"2003-12-08"},"text":"December 8, 2003","children":[],"tail":", the Secretary shall submit to Congress a report on the projects for which loans are provided under this section and a recommendation as to whether the Congress should authorize the Secretary to continue loans under this section beyond fiscal year 2008."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idba0d7bfc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395hhh/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There shall be no administrative or judicial review of any determination made by the Secretary under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idba0d7bfd-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title XVIII, § 1897, as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/173/tX/s1016"},"text":"Pub. L. 108–173, title X, § 1016","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-08"},"text":"Dec. 8, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2447"},"text":"117 Stat. 2447","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/13/dA/tVI/s6045/a"},"text":"Pub. L. 109–13, div. A, title VI, § 6045(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2005-05-11"},"text":"May 11, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/294"},"text":"119 Stat. 294","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idba0d7bfe-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idba0d7bff-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idba0d7c00-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Internal Revenue Code of 1986, referred to in subsec. (c)(3)(A), is classified generally to Title 26, Internal Revenue Code.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Higher Education Act of 1965, referred to in subsec. (f), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329"},"text":"Pub. L. 89–329","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-11-08"},"text":"Nov. 8, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/1219"},"text":"79 Stat. 1219","children":[],"tail":". Part D of title IV of the Act is classified generally to part D (§ 1087a et seq.) of subchapter IV of chapter 28 of Title 20, Education. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/pl/89/329/s1"},"text":"section 1 of Pub. L. 89–329","children":[],"tail":", set out as a Short Title note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of Title 20","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idba0d7c01-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2005—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/13/s6045/a/1/A"},"text":"Pub. L. 109–13, § 6045(a)(1)(A)","children":[],"tail":", inserted “or an entity described in paragraph (3)” after “means a hospital” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/13/s6045/a/1/B"},"text":"Pub. L. 109–13, § 6045(a)(1)(B)","children":[],"tail":", inserted “legislature” after “designated by the State” and “and such designation by the State legislature occurred prior to "},{"tag":"date","attrib":{"date":"2003-12-08"},"text":"December 8, 2003","children":[],"tail":"” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/13/s6045/a/2"},"text":"Pub. L. 109–13, § 6045(a)(2)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/13/s6045/b"},"text":"Pub. L. 109–13, § 6045(b)","children":[],"tail":", added subsec. (i)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idba0d7c02-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idba0d7c03-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2005 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/13/dA/tVI/s6045/c"},"text":"Pub. L. 109–13, div. A, title VI, § 6045(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-05-11"},"text":"May 11, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/295"},"text":"119 Stat. 295","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/13/dA/tVI/s6045/c"},"text":"“The amendments made by this section [amending this section] shall take effect as if included in the enactment of section 1016 of the Medicare Prescription Drug, Improvement, and Modernization Act of 2003 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/173"},"text":"Public Law 108–173","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/117/2447"},"text":"117 Stat. 2447","children":[],"tail":").”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
