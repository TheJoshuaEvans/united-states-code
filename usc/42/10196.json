{"tag":"section","attrib":{"id":"idbf19e77c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10196"},"text":null,"children":[{"tag":"num","attrib":{"value":"10196"},"text":"§ 10196.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal agency actions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf19e77d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10196/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperation and coordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Federal agencies shall assist the Secretary by cooperating and coordinating with the Secretary in the preparation of any necessary reports under this subchapter and the mission plan under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s10221"},"text":"section 10221 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf19e77e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10196/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Environmental review","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf19e77f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10196/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No action of the Secretary or any other Federal agency required by this subchapter or ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s10221"},"text":"section 10221 of this title","children":[],"tail":" with respect to a test and evaluation facility to be taken prior to the initiation of onsite construction of a test and evaluation facility shall require the preparation of an environmental impact statement under section 102(2)(C) of the Environmental Policy Act of 1969 ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4332/2/C"},"text":"42 U.S.C. 4332(2)(C)","children":[],"tail":"), or to require the preparation of environmental reports, except as otherwise specifically provided for in this subchapter."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf19e780-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10196/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary and the heads of all other Federal agencies shall, to the maximum extent possible, avoid duplication of efforts in the preparation of reports under the National Environmental Policy Act of 1969 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"42 U.S.C. 4321","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf19e781-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/425/tII/s216"},"text":"Pub. L. 97–425, title II, § 216","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-07"},"text":"Jan. 7, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2248"},"text":"96 Stat. 2248","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf19e782-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf19e783-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbf19e784-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The National Environmental Policy Act of 1969, referred to in subsec. (b)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/190"},"text":"Pub. L. 91–190","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-01-01"},"text":"Jan. 1, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/852"},"text":"83 Stat. 852","children":[],"tail":", which is classified generally to chapter 55 (§ 4321 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"section 4321 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
