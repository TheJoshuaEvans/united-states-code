{"tag":"section","attrib":{"id":"idc06a0ecb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18774"},"text":null,"children":[{"tag":"num","attrib":{"value":"18774"},"text":"§ 18774.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data collection on electric vehicle integration with the electricity grids","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc06a0ecc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18774/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2021-11-15"},"text":"November 15, 2021","children":[],"tail":", the Administrator shall develop and implement measures to expand data collection with respect to electric vehicle integration with the electricity grids."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc06a0ecd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18774/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sources of data","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The sources of the data collected pursuant to subsection (a) may include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc06a0ece-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18774/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" host-owned or charging-network-owned electric vehicle charging stations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06a0ecf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18774/b/2"},"text":null,"chil