{"tag":"section","attrib":{"id":"idbdf23077-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7140"},"text":null,"children":[{"tag":"num","attrib":{"value":"7140"},"text":"§ 7140.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Leasing Liaison Committee; establishment; composition","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There is established a Leasing Liaison Committee which shall be composed of an equal number of members appointed by the Secretary and the Secretary of the Interior.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbdf23078-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/91/tII/s210"},"text":"Pub. L. 95–91, title II, § 210","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-08-04"},"text":"Aug. 4, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/577"},"text":"91 Stat. 577","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
