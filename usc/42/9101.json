{"tag":"section","attrib":{"id":"idbea9c0c4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9101"},"text":null,"children":[{"tag":"num","attrib":{"value":"9101"},"text":"§ 9101.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional declaration of policy","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbea9c0c5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9101/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" It is declared to be the purposes of the Congress in this chapter to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbea9c0c6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9101/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" authorize and regulate the construction, location, ownership, and operation of ocean thermal energy conversion facilities connected to the United States by pipeline or cable, or located in whole or in part between the highwater mark and the seaward boundary of the territorial sea of the United States consistent with the Convention on the High Seas, and general principles of international law;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbea9c0c7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9101/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" authorize and regulate the construction, location, ownership, and operation of ocean thermal energy conversion plantships documented under the laws of the United States, consistent with the Convention on the High Seas and general principles of international law;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbea9c0c8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9101/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" authorize and regulate the construction, location, ownership, and operation of ocean thermal energy conversion plantships by United States citizens, consistent with the Convention on the High Seas and general principles of international law;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbea9c0c9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9101/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish a legal regime which will permit and encourage the development of ocean thermal energy conversion as a commercial energy technology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbea9c0ca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9101/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for the protection of the marine and coastal environment, and consideration of the interests of ocean users, to prevent or minimize any adverse impact which might occur as a consequence of the development of such ocean thermal energy conversion facilities or plantships;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbea9c0cb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9101/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make applicable certain provisions of the Merchant Marine Act, 1936 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s1177"},"text":"46 U.S.C. 1177","children":[],"tail":" et seq.) "},{"tag":"ref","attrib":{"idref":"fn003857"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003857"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" to assist in financing of ocean thermal energy conversion facilities and plantships;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbea9c0cc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9101/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protect the interests of the United States in the location, construction, and operation of ocean thermal energy conversion facilities and plantships; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbea9c0cd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9101/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protect the rights and responsibilities of adjacent coastal States in ensuring that Federal actions are consistent with approved State coastal zone management programs and other applicable State and local laws.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbea9c0ce-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9101/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Congress declares that nothing in this chapter shall be construed to affect the legal status of the high seas, the superjacent airspace, or the seabed and subsoil, including the Continental Shelf.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbea9c0cf-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/320/s2"},"text":"Pub. L. 96–320, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-08-03"},"text":"Aug. 3, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/974"},"text":"94 Stat. 974","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/623/tVI/s602/a/1"},"text":"Pub. L. 98–623, title VI, § 602(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-11-08"},"text":"Nov. 8, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3410"},"text":"98 Stat. 3410","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbea9c0d0-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbea9c0d1-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbea9c0d2-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/320"},"text":"Pub. L. 96–320","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-08-03"},"text":"Aug. 3, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/974"},"text":"94 Stat. 974","children":[],"tail":", known as the Ocean Thermal Energy Conversion Act of 1980, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out below and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Merchant Marine Act, 1936, referred to in subsec. (a)(6), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1936-06-29/ch858"},"text":"act June 29, 1936, ch. 858","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/1985"},"text":"49 Stat. 1985","children":[],"tail":", which was classified principally to chapter 27 (§ 1101 et seq.) of the former Appendix to Title 46, Shipping. The Act, with the exception of title V, most of title VI, and sections 301, 801, 802, 809(a), and 909 thereof, was repealed and restated, mainly in subtitle V of Title 46, by "},{"tag":"ref","attrib":{"href":"/us/pl/109/304"},"text":"Pub. L. 109–304","children":[],"tail":", §§ 8, 19, "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1555"},"text":"120 Stat. 1555","children":[],"tail":", 1710. Title V and sections 301 and 909 of the Act are set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s53101"},"text":"section 53101 of Title 46","children":[],"tail":". Those portions of title VI not repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/109/304"},"text":"Pub. L. 109–304","children":[],"tail":" and sections 802 and 809(a) of the Act were repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/114/120/tIII/s313/a"},"text":"Pub. L. 114–120, title III, § 313(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-08"},"text":"Feb. 8, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/58"},"text":"130 Stat. 58","children":[],"tail":". Section 801 of the Act was transferred to "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s57522"},"text":"section 57522 of Title 46","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/114/120/tIII/s313/c/1/A"},"text":"Pub. L. 114–120, title III, § 313(c)(1)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-08"},"text":"Feb. 8, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/58"},"text":"130 Stat. 58","children":[],"tail":". For complete classification of the Act to the Code, see Tables. For disposition of sections of the former Appendix to Title 46, see Disposition Table preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s101"},"text":"section 101 of Title 46","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbea9c0d3-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1984—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/623"},"text":"Pub. L. 98–623","children":[],"tail":" substituted “located in whole or in part between the highwater mark and the seaward boundary of the territorial sea” for “located in the territorial sea”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbea9c0d4-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"idbea9c0d5-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/96/320/s1"},"text":"Pub. L. 96–320, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-08-03"},"text":"Aug. 3, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/974"},"text":"94 Stat. 974","children":[],"tail":", provided: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/96/320/s1"},"text":"“That this Act [enacting this chapter and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s1279c"},"text":"section 1279c of Title 46","children":[],"tail":", Appendix, Shipping, amending sections 1271, 1273, and 1274 of Title 46, Appendix, and enacting provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s1273"},"text":"section 1273 of Title 46","children":[],"tail":", Appendix] may be cited as the ‘Ocean Thermal Energy Conversion Act of 1980’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idbea9c0d6-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbea9c0d7-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Territorial Sea of United States","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For extension of territorial sea of United States, see Proc. No. 5928, set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1331"},"text":"section 1331 of Title 43","children":[],"tail":", Public Lands."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
