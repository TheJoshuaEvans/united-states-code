{"tag":"section","attrib":{"id":"idbfb27e23-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13211"},"text":null,"children":[{"tag":"num","attrib":{"value":"13211"},"text":"§ 13211.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this subchapter, subchapter II, and subchapter III (unless otherwise specified)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfb27e24-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13211/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Administrator” means the Administrator of the Environmental Protection Agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfb27e25-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13211/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “alternative fuel” means methanol, denatured ethanol, and other alcohols; mixtures containing 85 percent or more (or such other percentage, but not less than 70 percent, as determined by the Secretary, by rule, to provide for requirements relating to cold start, safety, or vehicle functions) by volume of methanol, denatured ethanol, and other alcohols with gasoline or other fuels; natural gas, including liquid fuels domestically produced from natural gas; liquefied petroleum gas; hydrogen; coal-derived liquid fuels; fuels (other than alcohol) derived from biological materials; electricity (including electricity from solar energy); and any other fuel the Secretary determines, by rule, is substantially not petroleum and would yield substantial energy security benefits and substantial environmental benefits;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfb27e26-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13211/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Alternative fueled vehicle.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfb27e27-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13211/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “alternative fueled vehicle” means a dedicated vehicle or a dual fueled vehicle;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfb27e28-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13211/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inclusions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “alternative fueled vehicle” includes—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbfb27e29-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13211/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a new qualified fuel cell motor vehicle (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s30B/b/3"},"text":"section 30B(b)(3) of title 26","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbfb27e2a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13211/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a new advanced lean burn technology motor vehicle (as defined in section 30B(c)(3) of that title);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbfb27e2b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13211/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a new qualified hybrid motor vehicle (as defined in section 30B(d)(3) of that title); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbfb27e2c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13211/3/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other type of vehicle that the Administrator demonstrates to the Secretary would achieve a significant reduction in petroleum consumption.","children":[{"tag":"ref","attrib":{"idref":"fn004152"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004152"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The period probably should be a semicolon."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfb27e2d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13211/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “comparable conventionally fueled motor vehicle” means a motor vehicle which is, as determined by the Secretary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfb27e2e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13211/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" commercially available at the time the comparability of the vehicle is being assessed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfb27e2f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13211/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" powered by an internal combustion engine that utilizes gasoline or diesel fuel as its fuel source; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfb27e30-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13211/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides passenger capacity or payload capacity the same or similar to the alternative fueled vehicle to which it is being compared;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfb27e31-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13211/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “covered person” means a person that owns, operates, leases, or otherwise controls—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfb27e32-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13211/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a fleet that contains at least 20 motor vehicles that are centrally fueled or capable of being centrally fueled, and are used primarily within a metropolitan statistical area or a consolidated metropolitan statistical area, as established by the Bureau of the Census, with a 1980 population of 250,000 or more; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfb27e33-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13211/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least 50 motor vehicles within the United States;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfb27e34-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13211/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “dedicated vehicle” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfb27e35-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13211/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a dedicated automobile, as such term is defined in section 32901(a)(7) ","children":[{"tag":"ref","attrib":{"idref":"fn004153"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004153"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" See References in Text note below."}],"tail":" of title 49; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfb27e36-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13211/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a motor vehicle, other than an automobile, that operates solely on alternative fuel;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfb27e37-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13211/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “domestic” means derived from resources within the several States, the District of Columbia, the Commonwealth of Puerto Rico, the United States Virgin Islands, Guam, American Samoa, the Commonwealth of the Northern Mariana Islands, or any other Commonwealth, territory, or possession of the United States, including the outer Continental Shelf, as such term is defined in the Outer Continental Shelf Lands Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1331"},"text":"43 U.S.C. 1331","children":[],"tail":" et seq.], or from resources within a Nation with which there is in effect a free trade agreement requiring national treatment for trade;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfb27e38-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13211/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “dual fueled vehicle” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfb27e39-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13211/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" dual fueled automobile, as such term is defined in section 32901(a)(8) ","children":[{"tag":"sup","attrib":{},"text":"2","children":[],"tail":" of title 49; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfb27e3a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13211/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a motor vehicle, other than an automobile, that is capable of operating on alternative fuel and is capable of operating on gasoline or diesel fuel;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfb27e3b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13211/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “fleet” means a group of 20 or more light duty motor vehicles, used primarily in a metropolitan statistical area or consolidated metropolitan statistical area, as established by the Bureau of the Census, with a 1980 population of more than 250,000, that are centrally fueled or capable of being centrally fueled and are owned, operated, leased, or otherwise controlled by a governmental entity or other person who owns, operates, leases, or otherwise controls 50 or more such vehicles, by any person who controls such person, by any person controlled by such person, and by any person under common control with such person, except that such term does not include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfb27e3c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13211/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" motor vehicles held for lease or rental to the general public;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfb27e3d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13211/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" motor vehicles held for sale by motor vehicle dealers, including demonstration motor vehicles;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfb27e3e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13211/9/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" motor vehicles used for motor vehicle manufacturer product evaluations or tests;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfb27e3f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13211/9/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" law enforcement motor vehicles;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfb27e40-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13211/9/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" emergency motor vehicles, including vehicles directly used in the emergency repair of transmission lines and in the restoration of electricity service following power outages, as determined by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfb27e41-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13211/9/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" motor vehicles acquired and used for military purposes that the Secretary of Defense has certified to the Secretary must be exempt for national security reasons;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfb27e42-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13211/9/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nonroad vehicles, including farm and construction motor vehicles; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfb27e43-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13211/9/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" motor vehicles which under normal operations are garaged at personal residences at night;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfb27e44-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13211/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “fuel supplier” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfb27e45-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13211/10/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any person engaged in the importing, refining, or processing of crude oil to produce motor fuel;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfb27e46-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13211/10/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any person engaged in the importation, production, storage, transportation, distribution, or sale of motor fuel; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfb27e47-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13211/10/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any person engaged in generating, transmitting, importing, or selling at wholesale or retail electricity;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfb27e48-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13211/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “light duty motor vehicle” means a light duty truck or light duty vehicle, as such terms are defined under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7550/7"},"text":"section 7550(7) of this title","children":[],"tail":", of less than or equal to 8,500 pounds gross vehicle weight rating;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfb27e49-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13211/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “motor fuel” means any substance suitable as a fuel for a motor vehicle;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfb27e4a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13211/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “motor vehicle” has the meaning given such term under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7550/2"},"text":"section 7550(2) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfb27e4b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13211/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “replacement fuel” means the portion of any motor fuel that is methanol, ethanol, or other alcohols, natural gas, liquefied petroleum gas, hydrogen, coal derived liquid fuels, fuels (other than alcohol) derived from biological materials, electricity (including electricity from solar energy), ethers, or any other fuel the Secretary determines, by rule, is substantially not petroleum and would yield substantial energy security benefits and substantial environmental benefits.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfb27e4c-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/tIII/s301"},"text":"Pub. L. 102–486, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2866"},"text":"106 Stat. 2866","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/4/dB/tI/s122"},"text":"Pub. L. 106–554, § 1(a)(4) [div. B, title I, § 122]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–229; "},{"tag":"ref","attrib":{"href":"/us/pl/109/58/tVII/s707"},"text":"Pub. L. 109–58, title VII, § 707","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/818"},"text":"119 Stat. 818","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/dB/tXXVIII/s2862"},"text":"Pub. L. 110–181, div. B, title XXVIII, § 2862","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/559"},"text":"122 Stat. 559","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbfb27e4d-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbfb27e4e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbfb27e4f-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This subchapter, referred to in introductory provisions, was in the original “this title”, meaning title III of ","children":[{"