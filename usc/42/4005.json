{"tag":"section","attrib":{"id":"idbc9f98e5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4005"},"text":null,"children":[{"tag":"num","attrib":{"value":"4005"},"text":"§ 4005.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions applicable to Homeowner Flood Insurance Affordability Act of 2014","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this title,","children":[{"tag":"ref","attrib":{"idref":"fn003334"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003334"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" the following definitions shall apply:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc9f98e6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4005/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrator","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Administrator” means the Administrator of the Federal Emergency Management Agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc9f98e7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4005/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Flood Insurance Program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “National Flood Insurance Program” means the program established under the National Flood Insurance Act of 1968 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4001"},"text":"42 U.S.C. 4001","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc9f98e8-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/89/s2"},"text":"Pub. L. 113–89, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-03-21"},"text":"Mar. 21, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1020"},"text":"128 Stat. 1020","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc9f98e9-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc9f98ea-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbc9f98eb-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This title, referred to in text, probably should read “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/89"},"text":"Pub. L. 113–89","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-03-21"},"text":"Mar. 21, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1020"},"text":"128 Stat. 1020","children":[],"tail":", known as the Homeowner Flood Insurance Affordability Act of 2014, which does not contain titles. For complete classification of this Act to the Code, see Short Title of 2014 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4001"},"text":"section 4001 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The National Flood Insurance Act of 1968, referred to in par. (2), is title XIII of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/448"},"text":"Pub. L. 90–448","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-08-01"},"text":"Aug. 1, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/572"},"text":"82 Stat. 572","children":[],"tail":", which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4001"},"text":"section 4001 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbc9f98ec-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Homeowner Flood Insurance Affordability Act of 2014, and not as part of the National Flood Insurance Act of 1968 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
