{"tag":"section","attrib":{"id":"idbfe21afa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15811"},"text":null,"children":[{"tag":"num","attrib":{"value":"15811"},"text":"§ 15811.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Voluntary commitments to reduce industrial energy intensity","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfe21afb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15811/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of energy intensity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “energy intensity” means the primary energy consumed for each unit of physical output in an industrial process.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfe21afc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15811/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Voluntary agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may enter into voluntary agreements with one or more persons in industrial sectors that consume significant quantities of primary energy for each unit of physical output to reduce the energy intensity of the production activities of the persons.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfe21afd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15811/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Goal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Voluntary agreements under this section shall have as a goal the reduction of energy intensity by not less than 2.5 percent each year during the period of calendar years 2007 through 2016.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfe21afe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15811/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recognition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in cooperation with other appropriate Federal agencies, shall develop mechanisms to recognize and publicize the achievements of participants in voluntary agreements under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfe21aff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15811/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A person that enters into an agreement under this section and continues to make a good faith effort to achieve the energy efficiency goals specified in the agreement shall be eligible to receive from the Secretary a grant or technical assistance, as appropriate, to assist in the achievement of those goals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfe21b00-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15811/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than each of ","children":[{"tag":"date","attrib":{"date":"2012-06-30"},"text":"June 30, 2012","children":[],"tail":", and "},{"tag":"date","attrib":{"date":"2017-06-30"},"text":"June 30, 2017","children":[],"tail":", the Secretary shall submit to Congress a report that—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfe48b01-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15811/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluates the success of the voluntary agreements under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe48b02-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15811/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides independent verification of a sample of the energy savings estimates provided by participating firms.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfe48b03-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tI/s106"},"text":"Pub. L. 109–58, title I, § 106","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/611"},"text":"119 Stat. 611","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
