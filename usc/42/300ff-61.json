{"tag":"section","attrib":{"id":"idb6a01a8b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–61"},"text":null,"children":[{"tag":"num","attrib":{"value":"300ff–61"},"text":"§ 300ff–61.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Confidentiality and informed consent","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb6a01a8c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–61/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Confidentiality","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may not make a grant under this part unless, in the case of any entity applying for a grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–51"},"text":"section 300ff–51 of this title","children":[],"tail":", the entity agrees to ensure that information regarding the receipt of early intervention services pursuant to the grant is maintained confidentially in a manner not inconsistent with applicable law."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6a01a8d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–61/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Informed consent","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may not make a grant under this part unless the applicant for the grant agrees that, in testing an individual for HIV/AIDS, the applicant will test an individual only after the individual confirms that the decision of the individual with respect to undergoing such testing is voluntarily made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb6a01a8e-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XXVI, § 2661, as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/381/tIII/s301/a"},"text":"Pub. L. 101–381, title III, § 301(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-08-18"},"text":"Aug. 18, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/609"},"text":"104 Stat. 609","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/345/tIII/s301/b/2"},"text":"Pub. L. 106–345, title III, § 301(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-20"},"text":"Oct. 20, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1345"},"text":"114 Stat. 1345","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/415/tIII/s304"},"text":"Pub. L. 109–415, title III, § 304","children":[],"tail":", title VII, § 703, "},{"tag":"date","attrib":{"date":"2006-12-19"},"text":"Dec. 19, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2807"},"text":"120 Stat. 2807","children":[],"tail":", 2820; "},{"tag":"ref","attrib":{"href":"/us/pl/111/87/s2/a/1"},"text":"Pub. L. 111–87, § 2(a)(1)","children":[],"tail":", (3)(A), "},{"tag":"date","attrib":{"date":"2009-10-30"},"text":"Oct. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2885"},"text":"123 Stat. 2885","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb6a01a8f-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb6a01a90-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb6a01a91-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2009—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/87"},"text":"Pub. L. 111–87","children":[],"tail":" repealed "},{"tag":"ref","attrib":{"href":"/us/pl/109/415/s703"},"text":"Pub. L. 109–415, § 703","children":[],"tail":", and revived the provisions of this section as in effect on "},{"tag":"date","attrib":{"date":"2009-09-30"},"text":"Sept. 30, 2009","children":[],"tail":". See 2006 Amendment note and Effective Date of 2009 Amendment; Revival of Section note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/415/s703"},"text":"Pub. L. 109–415, § 703","children":[],"tail":", which directed repeal of this section effective "},{"tag":"date","attrib":{"date":"2009-10-01"},"text":"Oct. 1, 2009","children":[],"tail":", was itself repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/111/87/s2/a/1"},"text":"Pub. L. 111–87, § 2(a)(1)","children":[],"tail":", effective "},{"tag":"date","attrib":{"date":"2009-09-30"},"text":"Sept. 30, 2009","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/415/s304"},"text":"Pub. L. 109–415, § 304","children":[],"tail":", reenacted section catchline without change and amended text generally, substituting provisions relating to confidentiality and informed consent for provisions relating to confidentiality, informed written consent, and anonymous testing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/345"},"text":"Pub. L. 106–345","children":[],"tail":" struck out par. (1) and par. (2) designation. Prior to amendment, par. (1) read as follows: “in the case of any State applying for a grant under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–41"},"text":"section 300ff–41 of this title","children":[],"tail":", the State agrees to ensure that information regarding the receipt of early intervention services is maintained confidentially pursuant to law or regulations in a manner not inconsistent with applicable law; and”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb6a01a92-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb6a01a93-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2009 Amendment; Revival of Section","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions that repeal by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/87/s2/a/1"},"text":"section 2(a)(1) of Pub. L. 111–87","children":[],"tail":" of "},{"tag":"ref","attrib":{"href":"/us/pl/109/415/s703"},"text":"section 703 of Pub. L. 109–415","children":[],"tail":" be effective "},{"tag":"date","attrib":{"date":"2009-09-30"},"text":"Sept. 30, 2009","children":[],"tail":", and that the provisions of this section as in effect on "},{"tag":"date","attrib":{"date":"2009-09-30"},"text":"Sept. 30, 2009","children":[],"tail":", be revived, see section 2(a)(2), (3)(A) of "},{"tag":"ref","attrib":{"href":"/us/pl/111/87"},"text":"Pub. L. 111–87","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–11"},"text":"section 300ff–11 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
