{"tag":"section","attrib":{"id":"idbe7ee01a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8103"},"text":null,"children":[{"tag":"num","attrib":{"value":"8103"},"text":"§ 8103.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Board of Directors","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbe7ee01b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8103/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The corporation shall be under the direction of a board of directors made up of the following members:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe7ee01c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8103/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Chairman of the Federal Home Loan Bank Board or a member of the Federal Home Loan Bank Board to be designated by the Chairman;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe7ee01d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8103/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Housing and Urban Development;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe7ee01e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8103/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Chairman of the Board of Governors of the Federal Reserve System, or a member of the Board of Governors of the Federal Reserve System to be designated by the Chairman;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe7ee01f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8103/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Chairman of the Federal Deposit Insurance Corporation or the appointive member of the Board of Directors of the Federal Deposit Insurance Corporation if so designated by the Chairman;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe7ee020-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8103/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Comptroller of the Currency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe7ee021-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8103/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Chairman of the National Credit Union Administration or a member of the Board of the National Credit Union Administration to be designated by the Chairman.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe7ee022-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8103/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election of chairman","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall elect from among its members a chairman who shall serve for a term of two years, except that the Chairman of the Federal Home Loan Bank Board shall serve as Chairman of the Board of Directors for the first such two-year term.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe7ee023-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8103/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms of office","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each director of the corporation shall serve ex officio during the period he holds the office to which he is appointed by the President.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe7ee024-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8103/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation and expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The directors of the corporation, as full-time officers of the United States, shall serve without additional compensation but shall be reimbursed for travel, subsistence, and other necessary expenses incurred in the performance of their duties as directors of the corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe7ee025-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8103/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bylaws, policies and administrative provisions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The directors of the corporation shall adopt such bylaws, policies, and administrative provisions as are necessary to the functioning of the corporation and consistent with the provisions of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe7ee026-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8103/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director absences; designated representatives","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A director who is necessarily absent from a meeting of the board, or of a committee of the board, may participate in such meeting through a duly designated representative who is serving, pursuant to appointment by the President of the United States, by and with the advice and consent of the Senate, in the same department, agency, corporation, or instrumentality as the absent director, or in the case of the Comptroller of the Currency, through a duly designated Deputy Comptroller.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe7ee027-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8103/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quorum","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The presence of a majority of the board members, or their representatives as provided in subsection (f), shall constitute a quorum.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe7ee028-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8103/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of other laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The corporation shall be subject to the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552"},"text":"section 552 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe7ee029-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8103/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings of board","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All meetings of the board of directors will be conducted in accordance with the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552b"},"text":"section 552b of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbe7ee02a-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/557/tVI/s604"},"text":"Pub. L. 95–557, title VI, § 604","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-31"},"text":"Oct. 31, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2115"},"text":"92 Stat. 2115","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/320/tVII/s710/a"},"text":"Pub. L. 97–320, title VII, § 710(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-15"},"text":"Oct. 15, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1544"},"text":"96 Stat. 1544","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/242/tV/s520/a"},"text":"Pub. L. 100–242, title V, § 520(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-02-05"},"text":"Feb. 5, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1938"},"text":"101 Stat. 1938","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/628/tX/s1085"},"text":"Pub. L. 100–628, title X, § 1085","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-07"},"text":"Nov. 7, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3278"},"text":"102 Stat. 3278","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbe7ee02b-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbe7ee02c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbe7ee02d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/242/s520/a/1"},"text":"Pub. L. 100–242, § 520(a)(1)","children":[],"tail":", inserted “or a member of the Federal Home Loan Bank Board to be designated by the Chairman” before semicolon."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/242/s520/a/2"},"text":"Pub. L. 100–242, § 520(a)(2)","children":[],"tail":", added par. (3) and struck out former par. (3) which read as follows: “a member of the Board of Governors of the Federal Reserve System, to be designated by the Chairman of the Board of Governors of the Federal Reserve System;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/242/s520/a/3"},"text":"Pub. L. 100–242, § 520(a)(3)","children":[],"tail":", inserted “or the appointive member of the Board of Directors of the Federal Deposit Insurance Corporation if so designated by the Chairman” before semicolon."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/628"},"text":"Pub. L. 100–628","children":[],"tail":" struck out second of the two periods at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/242/s520/a/4"},"text":"Pub. L. 100–242, § 520(a)(4)","children":[],"tail":", substituted “Chairman” for “Administrator” and inserted “or a member of the Board of the National Credit Union Administration to be designated by the Chairman.” before period."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—Subsecs. (f) to (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/320"},"text":"Pub. L. 97–320","children":[],"tail":" added subsec. (f), redesignated former subsecs. (f) to (h) as (g) to (i), respectively, and in subsec. (g) inserted “, or their representatives as provided in subsection (f),”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbe7ee02e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"idbe7ee02f-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Federal Home Loan Bank Board abolished and functions transferred, see sections 401 to 406 of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/73"},"text":"Pub. L. 101–73","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1437"},"text":"section 1437 of Title 12","children":[],"tail":", Banks and Banking."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
