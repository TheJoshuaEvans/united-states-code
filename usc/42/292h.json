{"tag":"section","attrib":{"id":"idb5d3072d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s292h"},"text":null,"children":[{"tag":"num","attrib":{"value":"292h"},"text":"§ 292h.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office for Health Education Assistance Loan Default Reduction","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5d3072e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s292h/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish, within the Division of Student Assistance of the Bureau of Health Professions, an office to be known as the Office for Health Education Assistance Loan Default Reduction (in this section referred to as the “Office”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5d3072f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s292h/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose and functions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It shall be the purpose of the Office to achieve a reduction in the number and amounts of defaults on loans guaranteed under this subpart. In carrying out such purpose the Office shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5d30730-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s292h/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct analytical and evaluative studies concerning loans and loan defaults;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5d30731-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s292h/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry out activities designed to reduce loan defaults;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5d30732-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s292h/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" respond to special circumstances that may exist in the financial lending environment that may lead to loan defaults;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5d30733-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s292h/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" coordinate with other Federal entities that are involved with student loan programs, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5d30734-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s292h/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to the Department of Education, in the development of a single student loan application form, a single student loan deferment form, a single disability form, and a central student loan database; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5d30735-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s292h/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to the Department of Justice, in the recovery of payments from health professionals who have defaulted on loans guaranteed under this subpart; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5d30736-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s292h/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide technical assistance to borrowers, lenders, holders, and institutions concerning deferments and collection activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5d30737-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s292h/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In conjunction with the report submitted under subsection (b), the Office shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5d30738-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s292h/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compile, and publish in the Federal Register, a list of the borrowers who are in default under this subpart; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5d30739-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s292h/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" send the report and notices of default with respect to these borrowers to relevant Federal agencies and to schools, school associations, professional and specialty associations, State licensing boards, hospitals with which such borrowers may be associated, and any other relevant organizations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5d3073a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s292h/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation of funds for Office","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of amounts reserved under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s292i/a/2/B"},"text":"section 292i(a)(2)(B) of this title","children":[],"tail":" for obligation under this subsection, the Secretary may obligate the amounts for the purpose of administering the Office, including 7 full-time equivalent employment positions for such Office. With respect to such purpose, amounts made available under the preceding sentence are in addition to amounts made available to the Health Resources and Services Administration for program management for the fiscal year involved. With respect to such employment positions, the positions are in addition to the number of full-time equivalent employment positions that otherwise is authorized for the Department of Health and Human Services for the fiscal year involved."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5d3073b-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title VII, § 709, as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/408/tI/s102"},"text":"Pub. L. 102–408, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-13"},"text":"Oct. 13, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2006"},"text":"106 Stat. 2006","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/392/tI/s141/b"},"text":"Pub. L. 105–392, title I, § 141(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3579"},"text":"112 Stat. 3579","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb5d3073c-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb5d3073d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb5d3073e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 292h, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373/tVII/s708"},"text":"act July 1, 1944, ch. 373, title VII, § 708","children":[],"tail":", as added "},{"tag":"date","attrib":{"date":"1976-10-12"},"text":"Oct. 12, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/94/484/tII/s206"},"text":"Pub. L. 94–484, title II, § 206","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2250"},"text":"90 Stat. 2250","children":[],"tail":"; amended "},{"tag":"date","attrib":{"date":"1977-08-01"},"text":"Aug. 1, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/95/83/tIII/s307/a"},"text":"Pub. L. 95–83, title III, § 307(a)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/389"},"text":"91 Stat. 389","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1978-11-09"},"text":"Nov. 9, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/95/623/s12/a"},"text":"Pub. L. 95–623, § 12(a)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3457"},"text":"92 Stat. 3457","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1980-12-11"},"text":"Dec. 11, 1980","childr