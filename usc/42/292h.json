02–408","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s295k"},"text":"section 295k of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 292h, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373/tVII/s709"},"text":"act July 1, 1944, ch. 373, title VII, § 709","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/act/1956-07-30/ch779/s2"},"text":"July 30, 1956, ch. 779, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/720"},"text":"70 Stat. 720","children":[],"tail":"; amended "},{"tag":"date","attrib":{"date":"1963-09-24"},"text":"Sept. 24, 1963","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/88/129/s2/a"},"text":"Pub. L. 88–129, § 2(a)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/77/164"},"text":"77 Stat. 164","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1971-11-18"},"text":"Nov. 18, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/92/157/tI/s102/k/2/C"},"text":"Pub. L. 92–157, title I, § 102(k)(2)(C)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/437"},"text":"85 Stat. 437","children":[],"tail":", provided for issuance of general, administrative, and other regulations for implementation of grants for construction of health research facilities, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/94/484/tII/s201/a"},"text":"Pub. L. 94–484, title II, § 201(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-12"},"text":"Oct. 12, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2246"},"text":"90 Stat. 2246","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior section 709 of act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s292i"},"text":"section 292i of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tXXVII/s2720/a"},"text":"Pub. L. 97–35, title XXVII, § 2720(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/915"},"text":"95 Stat. 915","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb5d3073f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/392"},"text":"Pub. L. 105–392","children":[],"tail":" inserted “and” at end of par. (4)(B), substituted a period for “; and” at end of par. (5), and struck out par. (6) which read as follows: “prepare and submit a report not later than "},{"tag":"date","attrib":{"date":"1993-03-31"},"text":"March 31, 1993","children":[],"tail":", and annually, thereafter, to the Committee on Labor and Human Resources of the Senate and the Committee on Energy and Commerce of the House of Representatives concerning—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) the default rates for each—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(i) institution described in section 292","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":"(1) of this title that is participating in the loan programs under this subpart;"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(ii) lender participating in the loan program under this subpart; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(iii) loan holder under this subpart;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) the total amounts recovered pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s292f/b"},"text":"section 292f(b) of this title","children":[],"tail":" during the preceding fiscal year; and"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(C) a plan for improving the extent of such recoveries during the current fiscal year.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
