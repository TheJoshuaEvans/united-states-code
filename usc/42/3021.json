{"tag":"section","attrib":{"id":"idbc476724-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3021"},"text":null,"children":[{"tag":"num","attrib":{"value":"3021"},"text":"§ 3021.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose and program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbc476725-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3021/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional declaration of purpose","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc476726-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3021/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" It is the purpose of this subchapter to encourage and assist State agencies and area agencies on aging to concentrate resources in order to develop greater capacity and foster the development and implementation of comprehensive and coordinated systems to serve older individuals by entering into new cooperative arrangements in each State with the persons described in paragraph (2), for the planning, and for the provision of, supportive services, and multipurpose senior centers, in order to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc476727-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3021/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" secure and maintain maximum independence and dignity in a home environment for older individuals capable of self care with appropriate supportive services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc476728-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3021/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" remove individual and social barriers to economic and personal independence for older individuals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc476729-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3021/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide a continuum of care for vulnerable older individuals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc47672a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3021/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" secure the opportunity for older individuals to receive managed in-home and community-based long-term care services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc47672b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3021/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" measure impacts related to social determinants of health of older individuals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc47672c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3021/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The persons referred to in paragraph (1) include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc47672d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3021/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State agencies and area agencies on aging;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc47672e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3021/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other State agencies, including agencies that administer home and community care programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc47672f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3021/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Indian tribes, tribal organizations, and Native Hawaiian organizations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc476730-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3021/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the providers, including voluntary organizations or other private sector organizations, of supportive services, nutrition services, and multipurpose senior centers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc476731-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3021/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" organizations representing or employing older individuals or their families; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc476732-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3021/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" organizations that have experience in providing training, placement, and stipends for volunteers or participants who are older individuals (such as organizations carrying out Federal service programs administered by the Corporation for National and Community Service), in community service settings.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc476733-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3021/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration of program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc476734-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3021/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In order to effectively carry out the purpose of this subchapter, the Assistant Secretary shall administer programs under this subchapter through the Administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc476735-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3021/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In carrying out the provisions of this subchapter, the Assistant Secretary may request the technical assistance and cooperation of the Department of Education, the Department of Labor, the Department of Housing and Urban Development, the Department of Transportation, the Office of Community Services, the Department of Veterans Affairs, the Substance Abuse and Mental Health Services Administration,,","children":[{"tag":"ref","attrib":{"idref":"fn003300"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003300"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original."}],"tail":" and such other agencies and departments of the Federal Government as may be appropriate."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc476736-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3021/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ombudsman program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Assistant Secretary shall provide technical assistance and training (by contract, grant, or otherwise) to State long-term care ombudsman programs established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3027/a/9"},"text":"section 3027(a)(9) of this title","children":[],"tail":" in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3058g"},"text":"section 3058g of this title","children":[],"tail":", and to individuals within such programs designated under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3058g"},"text":"section 3058g of this title","children":[],"tail":" to be representatives of a long-term care ombudsman, in order to enable such ombudsmen and such representatives to carry out the ombudsman program effectively."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc476737-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3021/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc476738-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3021/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any funds received under an allotment as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3024/a"},"text":"section 3024(a) of this title","children":[],"tail":", or funds contributed toward the non-Federal share under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3024/d"},"text":"section 3024(d) of this title","children":[],"tail":", shall be used only for activities and services to benefit older individuals and other individuals as specifically provided for in this subchapter."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc476739-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3021/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No provision of this subchapter shall be construed as prohibiting a State agency or area agency on aging from providing services by using funds from sources not described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc47673a-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/73/tIII/s301"},"text":"Pub. L. 89–73, title III, § 301","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/95/478/tI/s103/b"},"text":"Pub. L. 95–478, title I, § 103(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-18"},"text":"Oct. 18, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1516"},"text":"92 Stat. 1516","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/97/115/s3/a"},"text":"Pub. L. 97–115, § 3(a)","children":[],"tail":", (d), "},{"tag":"date","attrib":{"date":"1981-12-29"},"text":"Dec. 29, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1596"},"text":"95 Stat. 1596","children":[],"tail":", 1597; "},{"tag":"ref","attrib":{"href":"/us/pl/98/459/tIII/s301"},"text":"Pub. L. 98–459, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-09"},"text":"Oct. 9, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1771"},"text":"98 Stat. 1771","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/175/tI"},"text":"Pub. L. 100–175, title I","children":[],"tail":", §§ 104(b), 105(c), 121, 129(a), "},{"tag":"date","attrib":{"date":"1987-11-29"},"text":"Nov. 29, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/929"},"text":"101 Stat. 929","children":[],"tail":", 930, 933, 934; "},{"tag":"ref","attrib":{"href":"/us/pl/100/628/tVII/s705/3"},"text":"Pub. L. 100–628, title VII, § 705(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-07"},"text":"Nov. 7, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3247"},"text":"102 Stat. 3247","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/54/s13/q/9/B"},"text":"Pub. L. 102–54, § 13(q)(9)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-06-13"},"text":"June 13, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/281"},"text":"105 Stat. 281","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/321/tI/s163/c/2/B"},"text":"Pub. L. 102–321, title I, § 163(c)(2)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-10"},"text":"July 10, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/377"},"text":"106 Stat. 377","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/375/tI/s102/b/1/A"},"text":"Pub. L. 102–375, title I, § 102(b)(1)(A)","children":[],"tail":", title III, § 301, title VII, § 708(a)(2)(B), "},{"tag":"date","attrib":{"date":"1992-09-30"},"text":"Sept. 30, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1200"},"text":"106 Stat. 1200","children":[],"tail":", 1219, 1292; "},{"tag":"ref","attrib":{"href":"/us/pl/103/171/s3/a/13"},"text":"Pub. L. 103–171, § 3(a)(13)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-02"},"text":"Dec. 2, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1990"},"text":"107 Stat. 1990","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/501/tIII/s301"},"text":"Pub. L. 106–501, title III, § 301","children":[],"tail":", title VIII, § 801(c)(1), "},{"tag":"date","attrib":{"date":"2000-11-13"},"text":"Nov. 13, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2238"},"text":"114 Stat. 2238","children":[],"tail":", 2292; "},{"tag":"ref","attrib":{"href":"/us/pl/109/365/tIII/s301"},"text":"Pub. L. 109–365, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2538"},"text":"120 Stat. 2538","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/131/tII/s201"},"text":"Pub. L. 116–131, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-03-25"},"text":"Mar. 25, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/254"},"text":"134 Stat. 254","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc47673b-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc47673c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbc47673d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 3021, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/73/tIII/s301"},"text":"Pub. L. 89–73, title III, § 301","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/93/29/tIII/s301"},"text":"Pub. L. 93–29, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-05-03"},"text":"May 3, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/36"},"text":"87 Stat. 36","children":[],"tail":", related to the purpose of this subchapter, prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/95/478"},"text":"Pub. L. 95–478","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 3021, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/73/tIII/s301"},"text":"Pub. L. 89–73, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-07-14"},"text":"July 14, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/220"},"text":"79 Stat. 220","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/42/s2/a"},"text":"Pub. L. 90–42, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-07-01"},"text":"July 1, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/106"},"text":"81 Stat. 106","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/69/s2/a"},"text":"Pub. L. 91–69, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-09-17"},"text":"Sept. 17, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/108"},"text":"83 Stat. 108","children":[],"tail":", related to a description of activities and authorized appropriations for fiscal years ending "},{"tag":"date","attrib":{"date":"1966-06-30"},"text":"June 30, 1966","children":[],"tail":", through 1972, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/93/29/tIII/s301"},"text":"Pub. L. 93–29, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-05-03"},"text":"May 3, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/36"},"text":"87 Stat. 36","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbc47673e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—Subsec. (a)(1)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/131"},"text":"Pub. L. 116–131","children":[],"tail":" added subpar. (E)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (a)(2)(F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/365"},"text":"Pub. L. 109–365","children":[],"tail":" added subpar. (F)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/501/s801/c/1"},"text":"Pub. L. 106–501, § 801(c)(1)","children":[],"tail":", substituted “3027(a)(9)” for “3027(a)(12)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/501/s301"},"text":"Pub. L. 106–501, § 301","children":[],"tail":", added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/171"},"text":"Pub. L. 103–171","children":[],"tail":" substituted “Assistant Secretary” for “Commissioner” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/375/s301"},"text":"Pub. L. 102–375, § 301","children":[],"tail":", amended subsec. (a) generally. Prior to amendment, subsec. (a) read as follows: “It is the purpose of this subchapter to encourage and assist State and area agencies to concentrate resources in order to develop greater capacity and foster the development and implementation of comprehensive and coordinated service systems to serve older individuals by entering into new cooperative arrangements in each State with State and area agencies, with Indian tribes, tribal organizations, and Native Hawaiian organizations, and with the providers, including voluntary organizations, of supportive services, including nutrition services and multipurpose senior centers, for the planning, and for the provision of, supportive services, nutrition services, and multipurpose senior centers, in order to—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) secure and maintain maximum independence and dignity in a home environment for older individuals capable of self care with appropriate supportive services;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) remove individual and social barriers to economic and personal independence for older individuals; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) provide a continuum of care for the vulnerable elderly.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/375/s102/b/1/A"},"text":"Pub. L. 102–375, § 102(b)(1)(A)","children":[],"tail":", substituted “Administration” for “Administration on Aging”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/321"},"text":"Pub. L. 102–321","children":[],"tail":" substituted “the Substance Abuse and Mental Health Services Administration” for “the Alcohol, Drug Abuse, and Mental Health Administration”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/375/s708/a/2/B"},"text":"Pub. L. 102–375, § 708(a)(2)(B)","children":[],"tail":", substituted “in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3058g"},"text":"section 3058g of this title","children":[],"tail":", and to individuals within such programs designated under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3058g"},"text":"section 3058g of this title","children":[],"tail":"” for “, and to individuals designated under such section”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/54"},"text":"Pub. L. 102–54","children":[],"tail":" substituted “Department of Veterans Affairs” for “Veterans’ Administration”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/628"},"text":"Pub. L. 100–628","children":[],"tail":" substituted “Native Hawaiian organizations,” for “Native Hawaiian organizations,,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/175/s121"},"text":"Pub. L. 100–175, § 121","children":[],"tail":", inserted “, with Indian tribes, tribal organizations, and Native Hawaiian organizations,” after second reference to “agencies”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/175/s105/c"},"text":"Pub. L. 100–175, § 105(c)","children":[],"tail":", inserted “the Alcohol, Drug Abuse, and Mental Health Administration,” after “Veterans’ Administration,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/175/s104/b"},"text":"Pub. L. 100–175, § 104(b)","children":[],"tail":", inserted “, the Veterans’ Administration,” after “Office of Community Services”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/175/s129/a"},"text":"Pub. L. 100–175, § 129(a)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/459"},"text":"Pub. L. 98–459","children":[],"tail":" substituted “area agencies” for “local agencies” in two places, inserted “and implementation”, inserted “, including voluntary organizations,”, and struck out “for the provision of” after “planning”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/115/s3/d"},"text":"Pub. L. 97–115, § 3(d)","children":[],"tail":", substituted “supportive services” for “social services” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/115/s3/a"},"text":"Pub. L. 97–115, § 3(a)","children":[],"tail":", substituted “cooperation of the Department of Education, the Department of Labor, the Department of Housing and Urban Development, the Department of Transportation, the Office of Community Services, and such other agencies and departments” for “cooperation of the Department of Labor, the Community Services Administration, the Department of Housing and Urban Development, the Department of Transportation, and such other agencies and departments”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbc47673f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbc476740-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1992 Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/375/s708/a/2/B"},"text":"section 708(a)(2)(B) of Pub. L. 102–375","children":[],"tail":" inapplicable with respect to fiscal year 1993, see "},{"tag":"ref","attrib":{"href":"/us/pl/103/171/s4/b"},"text":"section 4(b) of Pub. L. 103–171","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl