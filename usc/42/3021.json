b":{"href":"/us/pl/100/175"},"text":"Pub. L. 100–175","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbc476742-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/459"},"text":"Pub. L. 98–459","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1984-10-09"},"text":"Oct. 9, 1984","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/459/s803/a"},"text":"section 803(a) of Pub. L. 98–459","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbc476743-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective at close of ","children":[{"tag":"date","attrib":{"date":"1978-09-30"},"text":"Sept. 30, 1978","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/478/s504"},"text":"section 504 of Pub. L. 95–478","children":[],"tail":", set out as an Effective Date of 1978 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbc476744-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Coordination and Consolidation of Services Under Chapter","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/478/tI/s103/a"},"text":"Pub. L. 95–478, title I, § 103(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-18"},"text":"Oct. 18, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1516"},"text":"92 Stat. 1516","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/95/478/tI/s103/a"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Congress finds that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" approximately 3 percent of the eligible population is presently served under community services programs authorized under the Older Americans Act of 1965 [this chapter], 17 percent of whom are minority group members;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" approximately 1 percent of the eligible population is presently served by the nutrition program authorized under the Older Americans Act of 1965 [this chapter], 21 percent of whom are minority group members;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is program fragmentation at the national, State, and local levels which inhibits effective use of existing resources; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"“(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordination and consolidation of services provided under the Older Americans Act of 1965 [this chapter] allowing greater local determination to assess the need for services will facilitate achieving the goals of the Older Americans Act of 1965.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" It is the purpose of the amendments made by subsection (b) [amending sections 3021 to 3029 of this title and enacting sections 3030 to 3030g of this title] to combine within a consolidated title, subject to the modifications imposed by the provisions and requirements of the amendments made by subsection (b), the programs authorized by title III, title V, and title VII of the Older Americans Act of 1965 [former subchapters III, V, and VII of this chapter, respectively, as in effect prior to their revision by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/478"},"text":"Pub. L. 95–478","children":[],"tail":"] in the fiscal year 1978, and funds appropriated to carry out such consolidated title shall be used solely for the purposes and for the assistance of the same types of programs authorized under the provisions of such titles.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
