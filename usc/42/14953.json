{"tag":"section","attrib":{"id":"idbfd63391-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14953"},"text":null,"children":[{"tag":"num","attrib":{"value":"14953"},"text":"§ 14953.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relationship to other laws","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfd63392-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14953/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preemption of inconsistent State law","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Convention and this chapter shall not be construed to preempt any provision of the law of any State or political subdivision thereof, or prevent a State or political subdivision thereof from enacting any provision of law with respect to the subject matter of the Convention or this chapter, except to the extent that such provision of State law is inconsistent with the Convention or this chapter, and then only to the extent of the inconsistency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfd63393-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14953/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of the Indian Child Welfare Act","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Convention and this chapter shall not be construed to affect the application of the Indian Child Welfare Act of 1978 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1901"},"text":"25 U.S.C. 1901","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfd63394-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14953/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relationship to other laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Sections 3506(c), 3507, and 3512 of title 44 shall not apply to information collection for purposes of sections 14914, 14922(b)(4), and 14932(d) of this title or for use as a Convention record as defined in this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfd63395-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/279/tV/s503"},"text":"Pub. L. 106–279, title V, § 503","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-06"},"text":"Oct. 6, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/843"},"text":"114 Stat. 843","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbfd63396-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbfd63397-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbfd63398-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/279"},"text":"Pub. L. 106–279","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-06"},"text":"Oct. 6, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/825"},"text":"114 Stat. 825","children":[],"tail":", known as the Intercountry Adoption Act of 2000, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s14901"},"text":"section 14901 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Indian Child Welfare Act of 1978, referred to in subsec. (b), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/608"},"text":"Pub. L. 95–608","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-08"},"text":"Nov. 8, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3069"},"text":"92 Stat. 3069","children":[],"tail":", which is classified principally to chapter 21 (§ 1901 et seq.) of Title 25, Indians. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s1901"},"text":"section 1901 of Title 25","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbfd63399-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbfd6339a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2000-10-06"},"text":"Oct. 6, 2000","children":[],"tail":", with transition rule, see section 505(a)(1), (b) of "},{"tag":"ref","attrib":{"href":"/us/pl/106/279"},"text":"Pub. L. 106–279","children":[],"tail":", set out as an Effective Dates; Transition Rule note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s14901"},"text":"section 14901 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
