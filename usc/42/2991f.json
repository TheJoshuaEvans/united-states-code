{"tag":"section","attrib":{"id":"idbc31e256-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2991f"},"text":null,"children":[{"tag":"num","attrib":{"value":"2991f"},"text":"§ 2991f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission of plans to State and local officials","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbc31e257-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2991f/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission to governing body of Indian reservation or Alaska Native village","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No financial assistance may be provided to any project under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2991b"},"text":"section 2991b of this title","children":[],"tail":" or any research, demonstration, or pilot project under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2991d"},"text":"section 2991d of this title","children":[],"tail":", which is to be carried out on or in an Indian reservation or Alaska Native village, unless a plan setting forth the project has been submitted to the governing body of that reservation or village and the plan has not been disapproved by the governing body within thirty days of its submission."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc31e258-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2991f/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification to chief executive officer of State or Territory","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No financial assistance may be provided to any project under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2991b"},"text":"section 2991b of this title","children":[],"tail":" or any research, demonstration, or pilot project under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2991d"},"text":"section 2991d of this title","children":[],"tail":", which is to be carried out in a State or Territory other than on or in an Indian reservation or Alaska Native village or Hawaiian Homestead, unless the Commissioner has notified the chief executive officer of the State or Territory of the decision of the Commissioner to provide that assistance."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc31e259-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2991f/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification to local governing officials of political subdivision","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No financial assistance may be provided to any project under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2991b"},"text":"section 2991b of this title","children":[],"tail":" or any research, demonstration, or pilot project under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2991d"},"text":"section 2991d of this title","children":[],"tail":", which is to be carried out in a city, county, or other major political subdivision of a State or Territory, other than on or in an Indian reservation or Alaska Native village, or Hawaiian Homestead, unless the Commissioner has notified the local governing officials of the political subdivision of the decision of the Commissioner to provide that assistance."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc31e25a-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/452/tVIII/s808"},"text":"Pub. L. 88–452, title VIII, § 808","children":[],"t