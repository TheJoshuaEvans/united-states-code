\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe054416-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381c–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Education partnership","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall require the director of each National Laboratory, and may require the head of any science facility, to increase the participation of historically Black colleges or universities, Hispanic-serving institutions, or tribal colleges in any activity that increases the capacity of the historically Black colleges or universities, Hispanic-serving institutions, or tribal colleges to train personnel in science or engineering.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe054417-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381c–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An activity described in subsection (b) includes—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe054418-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381c–1/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collaborative research;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe054419-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381c–1/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" equipment transfer;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe05441a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381c–1/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" training activities carried out at a National Laboratory or science facility; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe05441b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381c–1/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" mentoring activities carried out at a National Laboratory or science facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe05441c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381c–1/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":", the Secretary shall submit to Congress a report describing the activities carried out under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbe05441d-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510/dC/tXXXI/s3167"},"text":"Pub. L. 101–510, div. C, title XXXI, § 3167","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/58/tXI/s1105/b/2"},"text":"Pub. L. 109–58, title XI, § 1105(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/940"},"text":"119 Stat. 940","children":[],"tail":"; amended "},{"tag":"re