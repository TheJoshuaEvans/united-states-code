{"tag":"section","attrib":{"id":"idc00d21fc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16352"},"text":null,"children":[{"tag":"num","attrib":{"value":"16352"},"text":"§ 16352.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost sharing","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc00d21fd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16352/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, in carrying out a research, development, demonstration, or commercial application program or activity that is initiated after ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":", the Secretary shall require cost-sharing in accordance with this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc00d21fe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16352/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research and development","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc00d21ff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16352/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraphs (2), (3), and (4) and subsection (f), the Secretary shall require not less than 20 percent of the cost of a research or development activity described in subsection (a) to be provided by a non-Federal source.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00d2200-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16352/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraph (1) shall not apply to a research or development activity described in subsection (a) that is of a basic or fundamental nature, as determined by the appropriate officer of the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00d2201-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16352/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reduction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may reduce or eliminate the requirement of paragraph (1) for a research and development activity of an applied nature if the Secretary determines that the reduction is necessary and appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00d2202-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16352/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption for institutions of higher education and other nonprofit institutions","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc00d2203-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16352/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraph (1) shall not apply to a research or development activity performed by an institution of higher education or nonprofit institution (as defined in section 4 of the Stevenson-Wydler Technology Innovation Act of 1980 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s3703"},"text":"15 U.S.C. 3703","children":[],"tail":"))."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00d2204-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16352/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The exemption under subparagraph (A) shall apply during the 2-year period beginning on ","children":[{"tag":"date","attrib":{"date":"2022-08-09"},"text":"August 9, 2022","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc00d2205-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16352/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Demonstration and commercial application","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc00d2206-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16352/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2) and subsection (f), the Secretary shall require that not less than 50 percent of the cost of a demonstration or commercial application activity described in subsection (a) to ","children":[{"tag":"ref","attrib":{"idref":"fn004225"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004225"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The word “to” probably should not appear."}],"tail":" be provided by a non-Federal source."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00d2207-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16352/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reduction of non-Federal share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may reduce the non-Federal share required under paragraph (1) if the Secretary determines the reduction to be necessary and appropriate, taking into consideration any technological risk relating to the activity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc00d2208-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16352/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Calculation of amount","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In calculating the amount of a non-Federal contribution under this section, the Secretary—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc00d2209-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16352/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" may include allowable costs in accordance with the applicable cost principles, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc00d220a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16352/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cash;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00d220b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16352/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" personnel costs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00d220c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16352/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the value of a service, other resource, or third party in-kind contribution determined in accordance with the applicable circular of the Office of Management and Budget;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00d220d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16352/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" indirect costs or facilities and administrative costs; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00d220e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16352/d/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any funds received under the power program of the Tennessee Valley Authority (except to the extent that such funds are made available under an annual appropriation Act); and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00d220f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16352/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall not include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc00d2210-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16352/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" revenues or royalties from the prospective operation of an activity beyond the time considered in the award;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00d2211-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16352/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" proceeds from the prospective sale of an asset of an activity; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00d2212-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16352/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other appropriated Federal funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc00d2213-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16352/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repayment of Federal share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall not require repayment of the Federal share of a cost-shared activity under this section as a condition of making an award.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc00d2214-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16352/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"This section shall not apply to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc00d2215-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16352/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a cooperative research and development agreement under the Stevenson-Wydler Technology Innovation Act of 1980 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s3701"},"text":"15 U.S.C. 3701","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00d2216-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16352/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a fee charged for the use of a Department facility; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00d2217-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16352/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an award under—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc00d2218-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16352/f/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the small business innovation research program under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s638"},"text":"section 638 of title 15","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00d2219-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16352/f/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the small business technology transfer program under that section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc00d221a-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tIX/s988"},"text":"Pub. L. 109–58, title IX, § 988","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/910"},"text":"119 Stat. 910","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/246/tI/s108/a"},"text":"Pub. L. 115–246, title I, § 108(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-09-28"},"text":"Sept. 28, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3134"},"text":"132 Stat. 3134","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/tVI/s10725/a"},"text":"Pub. L. 117–167, div. B, title VI, § 10725(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1709"},"text":"136 Stat. 1709","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc00d221b-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc00d221c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc00d221d-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Stevenson-Wydler Technology Innovation Act of 1980, referred to in subsec. (f)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/480"},"text":"Pub. L. 96–480","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-21"},"text":"Oct. 21, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2311"},"text":"94 Stat. 2311","children":[],"tail":", which is classified generally to chapter 63 (§ 3701 et seq.) of Title 15, Commerce and Trade. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s3701"},"text":"section 3701 of Title 15","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc00d221e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (b)(4)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167"},"text":"Pub. L. 117–167","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"August 9, 2022","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2018-09-28"},"text":"September 28, 2018","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/246/s108/a/1"},"text":"Pub. L. 115–246, § 108(a)(1)","children":[],"tail":", substituted “Except as provided in paragraphs (2), (3), and (4)” for “Except as provided in paragraphs (2) and (3)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/246/s108/a/2"},"text":"Pub. L. 115–246, § 108(a)(2)","children":[],"tail":", added par. (4)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
