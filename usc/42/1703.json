{"tag":"section","attrib":{"id":"idbb411a54-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1703"},"text":null,"children":[{"tag":"num","attrib":{"value":"1703"},"text":"§ 1703.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Contractor with the United States” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"As used in this subchapter, the term “contractor with the United States” includes any subcontractor or subordinate subcontractor with respect to the contract of such contractor.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbb411a55-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1942-12-02/ch668"},"text":"Dec. 2, 1942, ch. 668","children":[],"tail":", title I, § 103, "},{"tag":"ref","attrib":{"href":"/us/stat/56/1031"},"text":"56 Stat. 1031","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
