{"tag":"section","attrib":{"id":"idb67eafea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300bb–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"300bb–3"},"text":"§ 300bb–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifying event","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this subchapter, the term “qualifying event” means, with respect to any covered employee, any of the following events which, but for the continuation coverage required under this subchapter, would result in the loss of coverage of a qualified beneficiary:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb67eafeb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300bb–3/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The death of the covered employee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb67eafec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300bb–3/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The termination (other than by reason of such employee’s gross misconduct), or reduction of hours, of the covered employee’s employment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb67eafed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300bb–3/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The divorce or legal separation of the covered employee from the employee’s spouse.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb67eafee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300bb–3/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The covered employee becoming entitled to benefits under title XVIII of the Social Security Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395"},"text":"42 U.S.C. 1395","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb67eafef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300bb–3/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A dependent child ceasing to be a dependent child under the generally applicable requirements of the plan.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb67eaff0-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XXII, § 2203, as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/272/tX/s10003/a"},"text":"Pub. L. 99–272, title X, § 10003(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-04-07"},"text":"Apr. 7, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/234"},"text":"100 Stat. 234","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb67eaff1-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb67eaff2-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb67eaff3-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Social Security Act, referred to in par. (4), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"act Aug. 14, 1935, ch. 531","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/620"},"text":"49 Stat. 620","children":[],"tail":". Title XVIII of the Social Security Act is classified generally to subchapter XVIII (§ 1395 et seq.) of chapter 7 of this title. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1305"},"text":"section 1305 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
