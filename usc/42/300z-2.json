{"tag":"section","attrib":{"id":"idb672c8f7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300z–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"300z–2"},"text":"§ 300z–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Demonstration projects; grant authorization, etc.","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb672c8f8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300z–2/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may make grants to further the purposes of this subchapter to eligible grant recipients which have submitted an application which the Secretary finds meets the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300z–5"},"text":"section 300z–5 of this title","children":[],"tail":" for demonstration projects which the Secretary determines will help communities provide appropriate care and prevention services in easily accessible locations. Demonstration projects shall, as appropriate, provide, supplement, or improve the quality of such services. Demonstration projects shall use such methods as will strengthen the capacity of families to deal with the sexual behavior, pregnancy, or parenthood of adolescents and to make use of support systems such as other family members, friends, religious and charitable organizations, and voluntary associations."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb672c8f9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300z–2/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Grants under this subchapter for demonstration projects may be for the provision of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb672c8fa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300z–2/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" care services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb672c8fb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300z–2/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prevention services; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb672c8fc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300z–2/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a combination of care services and prevention services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb672c8fd-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XX, § 2003, as added "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tIX/s955/a"},"text":"Pub. L. 97–35, title IX, § 955(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/582"},"text":"95 Stat. 582","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
