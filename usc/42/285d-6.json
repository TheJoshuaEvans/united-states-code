{"tag":"section","attrib":{"id":"idb57137b8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285d–6"},"text":null,"children":[{"tag":"num","attrib":{"value":"285d–6"},"text":"§ 285d–6.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Multipurpose arthritis and musculoskeletal diseases centers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb57137b9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285d–6/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Development, modernization, and operation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the Institute shall, after consultation with the advisory council for the Institute, provide for the development, modernization, and operation (including staffing and other operating costs such as the costs of patient care required for research) of new and existing centers for arthritis and musculoskeletal diseases. For purposes of this section, the term “modernization” means the alteration, remodeling, improvement, expansion, and repair of existing buildings and the provision of equipment for such buildings to the extent necessary to make them suitable for use as centers described in the preceding sentence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb57137ba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285d–6/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties and functions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each center assisted under this section shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb57137bb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285d–6/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb57137bc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285d–6/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use the facilities of a single institution or a consortium of cooperating institutions, and (B) meet such qualifications as may be prescribed by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb57137bd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285d–6/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" conduct—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb57137be-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285d–6/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" basic and clinical research into the cause, diagnosis, early detection, prevention, control, and treatment of and rehabilitation from arthritis and musculoskeletal diseases and complications resulting from arthritis and musculoskeletal diseases, including research into implantable biomaterials and biomechanical and other orthopedic procedures;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb57137bf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285d–6/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" training programs for physicians, scientists, and other health and allied health professionals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb57137c0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285d–6/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information and continuing education programs for physicians and other health and allied health professionals who provide care for patients with arthritis and musculoskeletal diseases; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb57137c1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285d–6/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" programs for the dissemination to the general public of information—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb57137c2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285d–6/b/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on the importance of early detection of arthritis and musculoskeletal diseases, of seeking prompt treatment, and of following an appropriate regimen; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb57137c3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285d–6/b/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to discourage the promotion and use of unapproved and ineffective diagnostic, preventive, treatment, and control methods and unapproved and ineffective drugs and devices.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"A center may use funds provided under subsection (a) to provide stipends for health professionals enrolled in training programs described in paragraph (2)(B).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb57137c4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285d–6/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Optional programs","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each center assisted under this section may conduct programs to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb57137c5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285d–6/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish the effectiveness of new and improved methods of detection, referral, and diagnosis of individuals with a risk of developing arthritis and musculoskeletal diseases;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb57137c6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285d–6/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disseminate the results of research, screening, and other activities, and develop means of standardizing patient data and recordkeeping; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb57137c7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285d–6/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop community consultative services to facilitate the referral of patients to centers for treatment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb57137c8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285d–6/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Geographical distribution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the Institute shall, insofar as practicable, provide for an equitable geographical distribution of centers assisted under this section. The Director shall give appropriate consideration to the need for centers especially suited to meeting the needs of children affected by arthritis and musculoskeletal diseases.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb57137c9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285d–6/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Period of support; additional periods","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Support of a center under this section may be for a period of not to exceed five years. Such period may be extended by the Director of the Institute for one or more additional periods of not more than five years if the operations of such center have been reviewed by an appropriate technical and scientific peer review group established by the Director and if such group has recommended to the Director that such period should be extended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb57137ca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285d–6/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment and rehabilitation of children","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"1993-10-01"},"text":"October 1, 1993","children":[],"tail":", the Director shall establish a multipurpose arthritis and musculoskeletal disease center for the purpose of expanding the level of research into the cause, diagnosis, early detection, prevention, control, and treatment of, and rehabilitation of children with arthritis and musculoskeletal diseases."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb57137cb-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title IV, § 441, as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/158/s2"},"text":"Pub. L. 99–158, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-11-20"},"text":"Nov. 20, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/851"},"text":"99 Stat. 851","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/607/tI/s137"},"text":"Pub. L. 100–607, title I, § 137","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-04"},"text":"Nov. 4, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3056"},"text":"102 Stat. 3056","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/43/tVII/s701/c"},"text":"Pub. L. 103–43, title VII, § 701(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-06-10"},"text":"June 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/162"},"text":"107 Stat. 162","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb57137cc-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb57137cd-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb57137ce-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1993—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/43"},"text":"Pub. L. 103–43","children":[],"tail":" added subsec. (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (b)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/607"},"text":"Pub. L. 100–607","children":[],"tail":" inserted “and rehabilitation from” after “and treatment of”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
