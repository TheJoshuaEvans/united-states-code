{"tag":"section","attrib":{"id":"idbfb00cda-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13105"},"text":null,"children":[{"tag":"num","attrib":{"value":"13105"},"text":"§ 13105.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Source Reduction Clearinghouse","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfb00cdb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13105/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall establish a Source Reduction Clearinghouse to compile information including a computer data base which contains information on management, technical, and operational approaches to source reduction. The Administrator shall use the clearinghouse to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfb00cdc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13105/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serve as a center for source reduction technology transfer;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfb00cdd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13105/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" mount active outreach and education programs by the States to further the adoption of source reduction technologies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfb00cde-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13105/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collect and compile information reported by States receiving grants under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s13104"},"text":"section 13104 of this title","children":[],"tail":" on the operation and success of State source reduction programs."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfb00cdf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13105/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall make available to the public such information on source reduction as is gathered pursuant to this chapter and such other pertinent information and analysis regarding source reduction as may be available to the Administrator. The data base shall permit entry and retrieval of information to any person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfb00ce0-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508/tVI/s6606"},"text":"Pub. L. 101–508, title VI, § 6606","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-324"},"text":"104 Stat. 1388–324","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
