{"tag":"section","attrib":{"id":"idbb0ee76a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437bbb–6"},"text":null,"children":[{"tag":"num","attrib":{"value":"1437bbb–6"},"text":"§ 1437bbb–6.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary, in consultation with representatives of public and assisted housing interests, may provide training and technical assistance relating to providing assistance under this subchapter and may conduct detailed evaluations of up to 30 jurisdictions for the purpose of identifying replicable program models that are successful at carrying out the purposes of this subchapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbb0ee76b-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1937-09-01/ch896"},"text":"Sept. 1, 1937, ch. 896","children":[],"tail":", title IV, § 407, as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/276/tV/s561"},"text":"Pub. L. 105–276, title V, § 561","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2623"},"text":"112 Stat. 2623","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
