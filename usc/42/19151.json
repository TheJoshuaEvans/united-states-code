{"tag":"section","attrib":{"id":"idc07f9341-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19151"},"text":null,"children":[{"tag":"num","attrib":{"value":"19151"},"text":"§ 19151.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal research agency policies for caregivers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc07f9342-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19151/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" OSTP guidance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 12 months after ","children":[{"tag":"date","attrib":{"date":"2022-08-09"},"text":"August 9, 2022","children":[],"tail":", the Director, in consultation with the heads of relevant agencies, shall provide guidance to each Federal research agency to establish policies that—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc081dc33-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19151/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" apply to all—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc081dc34-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19151/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" research awards granted by such agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc081dc35-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19151/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" principal investigators of such research and their trainees, including postdoctoral researchers and graduate students, who have caregiving responsibilities, including care for a newborn or newly adopted child and care for an immediate family member who has a disability or a serious health condition; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc081dc36-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19151/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide, to the extent feasible—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc081dc37-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19151/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" flexibility in timing for the initiation of approved research awards granted by such agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc081dc38-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19151/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no-cost extensions of such research awards;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc081dc39-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19151/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" award supplements, as appropriate, to research awards to sustain research activities conducted under such awards; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc081dc3a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19151/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other appropriate accommodations at the discretion of the director of each such agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc081dc3b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19151/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uniformity of guidance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In providing guidance under subsection (a), the Director shall encourage uniformity, to the extent practicable, and consistency in the policies established pursuant to such guidance across all Federal research agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc081dc3c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19151/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of policies","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Consistent, to the extent practicable, with the guidance under subsection (a), Federal research agencies shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc081dc3d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19151/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain or develop and implement policies for individuals described in paragraph (1)(B) of such subsection; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc081dc3e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19151/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" broadly disseminate in easily accessible formats such policies to current and potential award recipients.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc081dc3f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19151/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data on usage","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Federal research agencies shall consider—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc081dc40-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19151/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collecting data, including demographic data that can be disaggregated by sex, geographic location, and socioeconomic indicators, which may include employment status, occupation, educational attainment, parental education, and income, on the usage of the policies under subsection (c), at both institutions of higher education and Federal laboratories; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc081dc41-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19151/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reporting such data on an annual basis to the Director in such form as required by the Director.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc081dc42-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/tV/s10501"},"text":"Pub. L. 117–167, div. B, title V, § 10501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1609"},"text":"136 Stat. 1609","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
