{"tag":"section","attrib":{"id":"idb55e2574-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s283q"},"text":null,"children":[{"tag":"num","attrib":{"value":"283q"},"text":"§ 283q.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eureka prize competitions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb55e2575-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s283q/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Pursuant to the authorities and processes established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s3719"},"text":"section 3719 of title 15","children":[],"tail":", the Director of the National Institutes of Health shall support prize competitions for one or both of the following goals:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb55e2576-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s283q/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Identifying and funding areas of biomedical science that could realize significant advancements through a prize competition.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55e2577-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s283q/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Improving health outcomes, particularly with respect to human diseases and conditions—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb55e2578-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s283q/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for which public and private investment in research is disproportionately small relative to Federal Government expenditures on prevention and treatment activities with respect to such diseases and conditions, such that Federal expenditures on health programs would be reduced;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb55e2579-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s283q/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that are serious and represent a significant disease burden in the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb55e257a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s283q/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for which there is potential for significant return on investment to the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb55e257b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s283q/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tracking; reporting","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director of the National Institutes of Health shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb55e257c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s283q/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" collect information on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb55e257d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s283q/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effect of innovations funded through the prize competitions under this section in advancing biomedical science or improving health outcomes pursuant to subsection (a); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb55e257e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s283q/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effect of the innovations on Federal expenditures; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55e257f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s283q/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include the information collected under paragraph (1) in the triennial report under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s283"},"text":"section 283 of this title","children":[],"tail":" (as amended by section 2032)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb55e2580-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255/dA/tII/s2002"},"text":"Pub. L. 114–255, div. A, title II, § 2002","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-13"},"text":"Dec. 13, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1047"},"text":"130 Stat. 1047","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb55e2581-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb55e2582-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb55e2583-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 2032, referred to in subsec. (b)(2), means ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255/s2032"},"text":"section 2032 of Pub. L. 114–255","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb55e2584-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the 21st Century Cures Act, and not as part of the Public Health Service Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
