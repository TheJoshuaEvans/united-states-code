{"tag":"section","attrib":{"id":"idbf89e7da-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651b"},"text":null,"children":[{"tag":"num","attrib":{"value":"12651b"},"text":"§ 12651b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorities and duties of the Board of Directors","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf89e7db-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall meet not less often than 3 times each year. The Board shall hold additional meetings at the call of the Chairperson of the Board, or if 6 members of the Board request such meetings in writing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf89e7dc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quorum","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A majority of the appointed members of the Board shall constitute a quorum.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf89e7dd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorities of officers","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf89e7de-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651b/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chairperson","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Chairperson of the Board may call and conduct meetings of the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf89e7df-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651b/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vice Chairperson","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Vice Chairperson of the Board may conduct meetings of the Board in the absence of the Chairperson.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf89e7e0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"While away from their homes or regular places of business on the business of the Board, members of such Board shall be allowed travel expenses, including per diem in lieu of subsistence, at rates authorized for employees of agencies under subchapter I of chapter 57 of title 5 for persons employed intermittently in the Government service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf89e7e1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651b/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special Government employees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of the provisions of chapter 11 of part I of title 18, and any other provision of Federal law, a member of the Board (to whom such provisions would not otherwise apply except for this subsection) shall be a special Government employee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf89e7e2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651b/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Status of members","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf89e7e3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651b/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tort claims","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purposes of the tort claims provisions of chapter 171 of title 28, a member of the Board shall be considered to be a Federal employee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf89e7e4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651b/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other claims","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A member of the Board shall have no personal liability under Federal law with respect to any claim arising out of or resulting from any act or omission by such person, within the scope of the service of the member on the Board, in connection with any transaction involving the provision of financial assistance by the Corporation. This paragraph shall not be construed to limit personal liability for criminal acts or omissions, willful or malicious misconduct, acts or omissions for private gain, or any other act or omission outside the scope of the service of such member on the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf89e7e5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651b/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect on other law","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"This subsection shall not be construed—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf89e7e6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651b/f/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to affect any other immunities and protections that may be available to such member under applicable law with respect to such transactions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf89e7e7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651b/f/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to affect any other right or remedy against the Corporation, against the United States under applicable law, or against any person other than a member of the Board participating in such transactions; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf89e7e8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651b/f/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to limit or alter in any way the immunities that are available under applicable law for Federal officials and employees not described in this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf89e7e9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651b/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Board shall have responsibility for setting overall policy for the Corporation and shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf89e7ea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651b/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review and approve the strategic plan described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12651d/b/1"},"text":"section 12651d(b)(1) of this title","children":[],"tail":", and annual updates of the plan, and review the budget proposal in advance of submission to the Office of Management and Budget;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf89e7eb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651b/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review and approve the proposal described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12651d/b/2/A"},"text":"section 12651d(b)(2)(A) of this title","children":[],"tail":", with respect to the grants, allotments, contracts, financial assistance, payment, and positions referred to in such section;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf89e7ec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651b/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review and approve the proposal described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12651d/b/3/A"},"text":"section 12651d(b)(3)(A) of this title","children":[],"tail":", regarding the regulations, standards, policies, procedures, programs, and initiatives referred to in such section;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf89e7ed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651b/g/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review and approve the evaluation plan described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12651d/b/4/A"},"text":"section 12651d(b)(4)(A) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf89e7ee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651b/g/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf89e7ef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651b/g/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review, and advise the Chief Executive Officer regarding, the actions of the Chief Executive Officer with respect to the personnel of the Corporation, and with respect to such standards, policies, procedures, programs, and initiatives as are necessary or appropriate to carry out the national service laws;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf8c57f0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651b/g/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inform the Chief Executive Officer of any aspects of the actions of the Chief Executive Officer that are not in compliance with the annual strategic plan referred to in paragraph (1), the proposals referred to in paragraphs (2) and (3), or the plan referred to in paragraph (4), or are not consistent with the objectives of the national service laws; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf8c57f1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651b/g/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review the performance of the Chief Executive Officer annually and forward a report on that review to the President;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf8c57f2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651b/g/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" receive any report as provided under subsection (b), (c), or (d) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s414"},"text":"section 414 of title 5","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf8c57f3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651b/g/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make recommendations relating to a program of research for the Corporation with respect to national and community service programs, including service-learning programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf8c57f4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651b/g/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advise the President and the authorizing committees concerning developments in national and community service that merit the attention of the President and the authorizing committees;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf8c57f5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651b/g/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure effective dissemination of information regarding the programs and initiatives of the Corporation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf8c57f6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651b/g/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" notwithstanding any other provision of law—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf8c57f7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651b/g/10/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make grants to or contracts with Federal and other public departments or agencies, and private nonprofit organizations, for the assignment or referral of volunteers under the provisions of title I of the Domestic Volunteer Service Act of 1973 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4951"},"text":"42 U.S.C. 4951","children":[],"tail":" et seq.] (except as provided in section 108 of such Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4958"},"text":"42 U.S.C. 4958","children":[],"tail":"]), which may provide that the agency or organization shall pay all or a part of the costs of the program; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf8c57f8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651b/g/10/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" enter into agreements with other Federal agencies or private nonprofit organizations for the support of programs under the national service laws, which—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbf8c57f9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651b/g/10/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may provide that the agency or organization shall pay all or a part of the costs of the program, except as is provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12571/b"},"text":"section 12571(b) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf8c57fa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651b/g/10/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall provide that the program (including any program operated by another Federal agency) will comply with all requirements related to evaluation, performance, and other goals applicable to similar programs under the national service laws, as determined by the Corporation,","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf8c57fb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651b/g/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prepare and make recommendations to the authorizing committees and the President for changes in the national service laws resulting from the studies and demonstrations the Chief Executive Officer is required to carry out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12651d/b/11"},"text":"section 12651d(b)(11) of this title","children":[],"tail":", which recommendations shall be submitted to the authorizing committees and President not later than "},{"tag":"date","attrib":{"date":"2012-01-01"},"text":"January 1, 2012","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf8c57fc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651b/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Chapter 10 of title 5 shall not apply with respect to the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf8c57fd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651b/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on participation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All employees and officers of the Corporation shall recuse themselves from decisions that would constitute conflicts of interest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf8c57fe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651b/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with other Federal activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As part of the agenda of meetings of the Board under subsection (a), the Board shall review projects and programs conducted or funded by the Corporation under the national service laws to improve the coordination between such projects and programs, and the activities of other Federal agencies that deal with the individuals and communities participating in or benefiting from such projects and programs. The ex officio members of the Board specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12651a/a/3"},"text":"section 12651a(a)(3) of this title","children":[],"tail":" shall jointly plan, implement, and fund activities in connection with projects and programs conducted under the national service laws to ensure that Federal efforts attempt to address the total needs of participants in such programs and projects, their communities, and the persons and communities the participants serve."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf8c57ff-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/610/tI/s192A"},"text":"Pub. L. 101–610, title I, § 192A","children":[],"tail":", as added and amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/tII"},"text":"Pub. L. 103–82, title II","children":[],"tail":", §§ 202(a), 203(a)(1)(B), (2), "},{"tag":"date","attrib":{"date":"1993-09-21"},"text":"Sept. 21, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/875"},"text":"107 Stat. 875","children":[],"tail":", 891; "},{"tag":"ref","attrib":{"href":"/us/pl/111/13/tI/s1702"},"text":"Pub. L. 111–13, title I, § 1702","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-04-21"},"text":"Apr. 21, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1544"},"text":"123 Stat. 1544","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/275"},"text":"Pub. L. 117–286, § 4(a)(275)","children":[],"tail":", (b)(85), "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4336"},"text":"136 Stat. 4336","children":[],"tail":", 4352.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf8c5800-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf8c5801-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbf8c5802-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Domestic Volunteer Service Act of 1973, referred to in subsec. (g)(10)(A), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/113"},"text":"Pub. L. 93–113","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-10-01"},"text":"Oct. 1, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/394"},"text":"87 Stat. 394","children":[],"tail":". Title I of the Act is classified generally to subchapter I (§ 4951 et seq.) of chapter 66 of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4950"},"text":"section 4950 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbf8c5803-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (g)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/b/85"},"text":"Pub. L. 117–286, § 4(b)(85)","children":[],"tail":", substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t5/s414"},"text":"section 414 of title 5","children":[],"tail":";” for “section 8E of the Inspector General Act of 1978;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/275"},"text":"Pub. L. 117–286, § 4(a)(275)","children":[],"tail":", substituted “