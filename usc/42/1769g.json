{"tag":"section","attrib":{"id":"idbb6bfab8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769g"},"text":null,"children":[{"tag":"num","attrib":{"value":"1769g"},"text":"§ 1769g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information clearinghouse","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbb6bfab9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769g/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall enter into a contract with a nongovernmental organization described in subsection (b) to establish and maintain a clearinghouse to provide information to nongovernmental groups located throughout the United States that assist low-income individuals or communities regarding food assistance, self-help activities to aid individuals in becoming self-reliant, and other activities that empower low-income individuals or communities to improve the lives of low-income individuals and reduce reliance on Federal, State, or local governmental agencies for food or other assistance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb6bfaba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769g/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nongovernmental organization","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The nongovernmental organization referred to in subsection (a) shall be selected on a competitive basis and shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb6bfabb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769g/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be experienced in the gathering of first-hand information in all the States through onsite visits to grassroots organizations in each State that fight hunger and poverty or that assist individuals in becoming self-reliant;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb6bfabc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769g/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be experienced in the establishment of a clearinghouse similar to the clearinghouse described in subsection (a);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb6bfabd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769g/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" agree to contribute in-kind resources towards the establishment and maintenance of the clearinghouse and agree to provide clearinghouse information, free of charge, to the Secretary, States, counties, cities, antihunger groups, and grassroots organizations that assist individuals in becoming self-sufficient and self-reliant;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb6bfabe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769g/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" be sponsored by an organization, or be an organization, that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbb6bfabf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769g/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has helped combat hunger for at least 10 years;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb6bfac0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769g/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is committed to reinvesting in the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb6bfac1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769g/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is knowledgeable regarding Federal nutrition programs;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb6bfac2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769g/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be experienced in communicating the purpose of the clearinghouse through the media, including the radio and print media, and be able to provide access to the clearinghouse information through computer or telecommunications technology, as well as through the mails; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb6bfac3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769g/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be able to provide examples, advice, and guidance to States, counties, cities, communities, antihunger groups, and local organizations regarding means of assisting individuals and communities to reduce reliance on government programs, reduce hunger, improve nutrition, and otherwise assist low-income individuals and communities become more self-sufficient.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb6bfac4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769g/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Audits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish fair and reasonable auditing procedures regarding the expenditures of funds to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb6bfac5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769g/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Out of any moneys in the Treasury not otherwise appropriated, the Secretary of the Treasury shall pay to the Secretary to provide to the organization selected under this section, to establish and maintain the information clearinghouse, $200,000 for each of fiscal years 1995 and 1996, $150,000 for fiscal year 1997, $100,000 for fiscal year 1998, $166,000 for each of fiscal years 1999 through 2004, and $250,000 for each of fiscal years 2010 through 2027. The Secretary shall be entitled to receive the funds and shall accept the funds, without further appropriation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbb6bfac6-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-06-04/ch281/s26"},"text":"June 4, 1946, ch. 281, § 26","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/448/tI/s123"},"text":"Pub. L. 103–448, title I, § 123","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-11-02"},"text":"Nov. 2, 1994","children"