ttrib":{"href":"/us/pl/118/42"},"text":"Pub. L. 118–42","children":[],"tail":" substituted “2010 through 2025” for “2010 through 2024”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2022—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328"},"text":"Pub. L. 117–328","children":[],"tail":" substituted “2010 through 2024” for “2010 through 2023”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103"},"text":"Pub. L. 117–103","children":[],"tail":" substituted “2010 through 2023” for “2010 through 2022”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2020—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Pub. L. 116–260","children":[],"tail":" substituted “2010 through 2022” for “2010 through 2021”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2019—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94"},"text":"Pub. L. 116–94","children":[],"tail":" substituted “2010 through 2021” for “2010 through 2019”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/6"},"text":"Pub. L. 116–6","children":[],"tail":" substituted “2010 through 2019” for “2010 through 2018”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141"},"text":"Pub. L. 115–141","children":[],"tail":" substituted “2010 through 2018” for “2010 through 2017”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2017—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/31"},"text":"Pub. L. 115–31","children":[],"tail":", which directed substitution of “2010 through 2017” for “2010 through 2016” in first sentence, could not be executed because of the prior identical amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/114/223/s148"},"text":"Pub. L. 114–223, § 148","children":[],"tail":". See 2016 Amendment note below."}],"tail":"\n"},{"tag":"p","attri