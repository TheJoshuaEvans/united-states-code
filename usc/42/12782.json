{"tag":"section","attrib":{"id":"idbf9f6c47-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12782"},"text":null,"children":[{"tag":"num","attrib":{"value":"12782"},"text":"§ 12782.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priorities for capacity development","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"To carry out ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12781"},"text":"section 12781 of this title","children":[],"tail":", the Secretary shall provide assistance under this part to—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf9f6c48-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12782/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitate the exchange of information that would help participating jurisdictions carry out the purposes of this subchapter, including information on program design, housing finance, land use controls, and building construction techniques;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf9f6c49-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12782/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve the ability of States and units of general local government to design and implement comprehensive housing affordability strategies, particularly those States and units of general local government that are relatively inexperienced in the development of affordable housing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf9f6c4a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12782/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage private lenders and for-profit developers of low-income housing to participate in public-private partnerships to achieve the purposes of this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf9f6c4b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12782/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve the ability of States and units of general local government, community housing development organizations, private lenders, and for-profit developers of low-income housing to incorporate energy efficiency into the planning, design, financing, construction, and operation of affordable housing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfa1b53c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12782/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitate the establishment and efficient operation of employer-assisted housing programs through research, technical assistance and demonstration projects; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfa1b53d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12782/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitate the establishment and efficient operation of land bank programs, under which title to vacant and abandoned parcels of real estate located in or causing blighted neighborhoods is cleared for use consistent with the purposes of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfa1b53e-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/625/tII/s242"},"text":"Pub. L. 101–625, title II, § 242","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"t