{"tag":"section","attrib":{"id":"idc056fc43-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18384"},"text":null,"children":[{"tag":"num","attrib":{"value":"18384"},"text":"§ 18384.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Decadal results","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"NASA shall take into account the current decadal surveys from the National Academies’ Space Studies Board when submitting the President’s budget request to the Congress.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc056fc44-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/267/tVIII/s805"},"text":"Pub. L. 111–267, title VIII, § 805","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-11"},"text":"Oct. 11, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2833"},"text":"124 Stat. 2833","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
