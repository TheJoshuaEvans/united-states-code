{"tag":"section","attrib":{"id":"idb5334552-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280f–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"280f–1"},"text":"§ 280f–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Strengthening capacity and education for fetal alcohol spectrum disorders","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5334553-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280f–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall award grants, contracts, or cooperative agreements, as the Secretary determines appropriate, to public or nonprofit private entities with demonstrated expertise in the field of fetal alcohol spectrum disorders (referred to in this section as “FASD”). Such awards shall be for the purposes of building local, Tribal, State, and nationwide capacities to prevent the occurrence of FASD by carrying out the programs described in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5334554-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280f–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Programs","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An entity receiving an award under subsection (a) may use such award for the following purposes:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5334555-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280f–1/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Developing and supporting public education and outreach activities to raise public awareness of the risks associated with alcohol consumption during pregnancy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5334556-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280f–1/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Acting as a clearinghouse for evidence-based resources on FASD prevention, identification, and culturally and linguistically appropriate best practices to help inform systems of care for individuals with FASD across their lifespan.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5334557-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280f–1/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Increasing awareness and understanding of efficacious, evidence-based screening tools and culturally and linguistically appropriate evidence-based intervention services and best practices, which may include improving the capacity for State, Tribal, and local affiliates.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5334558-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280f–1/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Providing technical assistance to recipients of grants, cooperative agreements, or contracts under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s280f"},"text":"section 280f of this title","children":[],"tail":", as appropriate."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5334559-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280f–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be eligible for a grant, contract, or cooperative agreement under this section, an entity shall submit to the Secretary an application at such time, in such manner, and containing such information as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb533455a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280f–1/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subcontracting","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A public or private nonprofit entity may carry out the following activities required under this section through contracts or cooperative agreements with other public and private nonprofit entities with demonstrated expertise in FASD:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb533455b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280f–1/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Resource development and dissemination.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb533455c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280f–1/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Intervention services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb533455d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280f–1/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Training and technical assistance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb533455e-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title III, § 399I, as added "},{"tag":"ref","attrib":{"href":"/us/pl/119/44/tI/s104/a"},"text":"Pub. L. 119–44, title I, § 104(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-01"},"text":"Dec. 1, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/673"},"text":"139 Stat. 673","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb533455f-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb5334560-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb5334561-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 280f–1, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373/tIII/s399I"},"text":"act July 1, 1944, ch. 373, title III, § 399I","children":[],"tail":", formerly § 399H, as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/392/tIV/s419/d"},"text":"Pub. L. 105–392, title IV, § 419(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3594"},"text":"112 Stat. 3594","children":[],"tail":"; renumbered § 399I, "},{"tag":"ref","attrib":{"href":"/us/pl/106/310/dA/tV/s502/4/A"},"text":"Pub. L. 106–310, div. A, title V, § 502(4)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-17"},"text":"Oct. 17, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1115"},"text":"114 Stat. 1115","children":[],"tail":", provided eligibility criteria for receiving a grant or entering into a cooperative agreement or contract under this part, prior to the general amendment of this part by "},{"tag":"ref","attrib":{"href":"/us/pl/119/44"},"text":"Pub. L. 119–44","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
