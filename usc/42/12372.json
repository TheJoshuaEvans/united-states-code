{"tag":"section","attrib":{"id":"idbf6aef0e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12372"},"text":null,"children":[{"tag":"num","attrib":{"value":"12372"},"text":"§ 12372.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of President and Secretary; final report","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf6aef0f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12372/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Calling of Conference","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall call a White House Conference on Children, Youth, and Families in 1993 in order to develop recommendations for further action in the field of children, youth, and families which will further the policy set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12371/b"},"text":"section 12371(b) of this title","children":[],"tail":". The Conference shall be planned and conducted under the direction of the Secretary in cooperation with the Commissioner and with the heads of such other Federal departments and agencies as are appropriate. Such assistance may include the assignment of personnel."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf6aef10-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12372/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes of Conference","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of the Conference shall be—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf6aef11-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12372/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to increase the public awareness of the value and needs of young individuals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf6aef12-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12372/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to examine the well-being of young individuals as well as the problems which they face;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf6aef13-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12372/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to describe the extent to which young individuals with identified needs do not receive services to meet such needs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf6aef14-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12372/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to determine the reasons why young individuals are not receiving needed services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf6aef15-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12372/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop such specific and comprehensive recommendations for executive and legislative action as may be appropriate to improve the well-being of youth and their families.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf6aef16-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12372/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conference participants and delegates","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf6aef17-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12372/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Participants","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In order to carry out the purposes of the Conference, the Conference shall bring together—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf6aef18-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12372/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" representatives of Federal, State, and local governments, including representatives of the Government Accountability Office;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf6aef19-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12372/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" professionals who are working in the field of children, youth, and families; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf6aef1a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12372/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" representatives of the general public, particularly young individuals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf6aef1b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12372/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection of delegates","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The delegates to attend the Conference shall be selected without regard to political affiliation or past partisan activity and shall, to the best of the appointing authority’s ability, be representative of the spectrum of thought in the field of children, youth, and families.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf6aef1c-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/501/tIX/s983"},"text":"Pub. L. 101–501, title IX, § 983","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-03"},"text":"Nov. 3, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1280"},"text":"104 Stat. 1280","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/271/s8/b"},"text":"Pub. L. 108–271, § 8(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-07-07"},"text":"July 7, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/814"},"text":"118 Stat. 814","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf6aef1d-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf6aef1e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbf6aef1f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—Subsec. (c)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/271"},"text":"Pub. L. 108–271","children":[],"tail":" substituted “Government Accountability Office” for “General Accounting Office”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbf6aef20-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbf6aef21-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1990-10-01"},"text":"Oct. 1, 1990","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/101/501/s1001/a"},"text":"section 1001(a) of Pub. L. 101–501","children":[],"tail":", set out as an Effective Date of 1990 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s8621"},"text":"section 8621 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
