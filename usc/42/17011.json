{"tag":"section","attrib":{"id":"idc01dc517-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17011"},"text":null,"children":[{"tag":"num","attrib":{"value":"17011"},"text":"§ 17011.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transportation electrification","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc01dc518-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17011/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc01dc519-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17011/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrator","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Administrator” means the Administrator of the Environmental Protection Agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc01dc51a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17011/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Battery","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “battery” means an electrochemical energy storage system powered directly by electrical current.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc01dc51b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17011/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Electric transportation technology","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “electric transportation technology” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc01dc51c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17011/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" technology used in vehicles that use an electric motor for all or part of the motive power of the vehicles, including battery electric, hybrid electric, plug-in hybrid electric, fuel cell, and plug-in fuel cell vehicles, or rail transportation; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc01dc51d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17011/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" equipment relating to transportation or mobile sources of air pollution that use an electric motor to replace an internal combustion engine for all or part of the work of the equipment, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc01dc51e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17011/a/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" corded electric equipment linked to transportation or mobile sources of air pollution; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc01dc51f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17011/a/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" electrification technologies at airports, ports, truck stops, and material-handling facilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc01dc520-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17011/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonroad vehicle","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “nonroad vehicle” means a vehicle—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc01dc521-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17011/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" powered—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc01dc522-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17011/a/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by a nonroad engine, as that term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7550"},"text":"section 7550 of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc01dc523-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17011/a/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fully or partially by an electric motor powered by a fuel cell, a battery, or an off-board source of electricity; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc01dc524-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17011/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is not a motor vehicle or a vehicle used solely for competition.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc01dc525-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17011/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plug-in electric drive vehicle","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “plug-in electric drive vehicle” means a vehicle that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc01dc526-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17011/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" draws motive power from a battery with a capacity of at least 4 kilowatt-hours;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc01dc527-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17011/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" can be recharged from an external source of electricity for motive power; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc01dc528-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17011/a/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a light-, medium-, or heavy-duty motor vehicle or nonroad vehicle (as those terms are defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7550"},"text":"section 7550 of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc01dc529-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17011/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified electric transportation project","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “qualified electric transportation project” means an electric transportation technology project that would significantly reduce emissions of criteria pollutants, greenhouse gas emissions, and petroleum, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc01dc52a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17011/a/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shipside or shoreside electrification for vessels;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc01dc52b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17011/a/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" truck-stop electrification;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc01dc52c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17011/a/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" electric truck refrigeration units;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc01dc52d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17011/a/6/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" battery-powered auxiliary power units for trucks;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc01dc52e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17011/a/6/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" electric airport ground support equipment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc01dc52f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17011/a/6/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" electric material and cargo handling equipment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc01dc530-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17011/a/6/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" electric or dual-mode electric rail;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc01dc531-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17011/a/6/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any distribution upgrades needed to supply electricity to the project; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc01dc532-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17011/a/6/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any ancillary infrastructure, including panel upgrades, battery chargers, in-situ transformers, and trenching.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc01dc533-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17011/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plug-in electric drive vehicle program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc01dc534-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17011/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a competitive program to provide grants on a cost-shared basis to State governments, local governments, metropolitan transportation authorities, air pollution control districts, private or nonprofit entities, or combinations of those governments, authorities, districts, and entities, to carry out one or more projects to encourage the use of plug-in electric drive vehicles or other emerging electric vehicle technologies, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc01dc535-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17011/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall, in consultation with the Secretary of Transportation and the Administrator, establish requirements for applications for grants under this section, including reporting of data to be summarized for dissemination to grantees and the public, including safety, vehicle, and component performance, and vehicle and component life cycle costs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc01dc536-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17011/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In making awards under this subsection, the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc01dc537-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17011/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" give priority consideration to applications that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc01dc538-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17011/b/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage early widespread use of vehicles described in paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc01dc539-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17011/b/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are likely to make a significant contribution to the advancement of the production of the vehicles in the United States; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc01dc53a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17011/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure, to the maximum extent practicable, that the program established under this subsection includes a variety of applications, manufacturers, and end-uses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc020343b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17011/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall require a grant recipient under this subsection to submit to the Secretary, on an annual basis, data relating to safety, vehicle performance, life cycle costs, and emissions of vehicles demonstrated under the grant, including emissions of greenhouse gases.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc020343c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17011/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost sharing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16352"},"text":"Section 16352 of this title","children":[],"tail":" shall apply to a grant made under this subsection."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc020343d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17011/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this subsection $90,000,000 for each of fiscal years 2008 through 2012, of which not less than ⅓ of the total amount appropriated shall be available each fiscal year to make grants to local and municipal governments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc020343e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17011/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Near-term transportation sector electrification program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc020343f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17011/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"December 19, 2007","children":[],"tail":", the Secretary, in consultation with the Secretary of Transportation and the Administrator, shall establish a program to provide grants for the conduct of qualified electric transportation projects."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0203440-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17011/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In providing grants under this subsection, the Secretary shall give priority to large-scale projects and large-scale aggregators of projects.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0203441-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17011/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost sharing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16352"},"text":"Section 16352 of this title","children":[],"tail":" shall apply to a grant made under this subsection."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0203442-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17011/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this subsection $95,000,000 for each of fiscal years 2008 through 2013.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0203443-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17011/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Education program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0203444-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17011/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall develop a nationwide electric drive transportation technology education program under which the Secretary shall provide—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0203445-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17011/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" teaching materials to secondary schools and high schools; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0203446-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17011/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assistance for programs relating to electric drive system and component engineering to institutions of higher education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0203447-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17011/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Electric vehicle competition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The program established under paragraph (1) shall include a plug-in hybrid electric vehicle competition for institutions of higher education, which shall be known as the “Dr. Andrew Frank Plug-In Electric Vehicle Competition”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0203448-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17011/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Engineers","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the program established under paragraph (1), the Secretary shall provide financial assistance to institutions of higher education to create new, or support existing, degree programs to ensure the availability of trained electrical and mechanical engineers with the skills necessary for the advancement of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0203449-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17011/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" plug-in electric drive vehicles; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc020344a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17011/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other forms of electric drive transportation technology vehicles.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc020344b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17011/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums as may be necessary to carry out this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc020344c-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/tI/s131"},"text":"Pub. L. 110–140, title I, § 131","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1508"},"text":"121 Stat. 1508","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc020344d-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc020344e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc020344f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the date that is 1 day after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/s1601"},"text":"section 1601 of Pub. L. 110–140","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1824"},"text":"section 1824 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
