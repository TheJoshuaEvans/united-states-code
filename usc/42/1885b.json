{"tag":"section","attrib":{"id":"idbba077e6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1885b"},"text":null,"children":[{"tag":"num","attrib":{"value":"1885b"},"text":"§ 1885b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Participation in science and engineering of minorities and persons with disabilities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbba077e7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1885b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Foundation is authorized (1) to undertake or support a comprehensive science and engineering education program to increase the participation of minorities in science and engineering, and (2) to support activities to initiate research at minority institutions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbba077e8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1885b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Foundation is authorized to undertake or support programs and activities to encourage the participation of persons with disabilities in the science and engineering professions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbba077e9-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/516/s34"},"text":"Pub. L. 96–516, § 34","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3012"},"text":"94 Stat. 3012","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/159/tI/s111/b/7"},"text":"Pub. L. 99–159, title I, § 111(b)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-11-22"},"text":"Nov. 22, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/892"},"text":"99 Stat. 892","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/207/tII/s202/d/1"},"text":"Pub. L. 105–207, title II, § 202(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-07-29"},"text":"July 29, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/874"},"text":"112 Stat. 874","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbba077ea-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbba077eb-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbba077ec-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Science and Engineering Equal Opportunities Act, and not as part of the National Science Foundation Act of 1950 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbba077ed-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/207/s202/d/1/A"},"text":"Pub. L. 105–207, § 202(d)(1)(A)","children":[],"tail":", substituted section catchline for former section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/207/s202/d/1/B"},"text":"Pub. L. 105–207, § 202(d)(1)(B)","children":[],"tail":", added subsec. (b) and struck out former subsec. (b), which read as follows: “By "},{"tag":"date","attrib":{"date":"1981-09-30"},"text":"September 30, 1981","children":[],"tail":", the Director, with the advice and assistance of the Committee on Equal Opportunities in Science and Technology established in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1885c"},"text":"section 1885c of this title","children":[],"tail":", shall prepare and transmit to the Committee on Labor and Human Resources of the Senate and the Committee on Science and Technology of the House of Representatives a report proposing a comprehensive and continuing program at the Foundation to promote the full participation of minorities in science and engineering. Such report shall contain budgetary and legislative recommendations for the carrying out of such program by the Foundation.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1985—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/159/s111/b/7"},"text":"Pub. L. 99–159, § 111(b)(7)","children":[],"tail":", substituted “science and engineering education” for “science education” and “engineering” for “technology”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/159/s111/b/7/B"},"text":"Pub. L. 99–159, § 111(b)(7)(B)","children":[],"tail":", substituted “engineering” for “technology”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
