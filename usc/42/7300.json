{"tag":"section","attrib":{"id":"idbe02d332-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7300"},"text":null,"children":[{"tag":"num","attrib":{"value":"7300"},"text":"§ 7300.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress; effect on personnel","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Civil Service Commission shall, as soon as practicable but not later than one year after ","children":[{"tag":"date","attrib":{"date":"1977-10-01"},"text":"October 1, 1977","children":[],"tail":", prepare and transmit to the Congress a report on the effects on employees of the reorganization under this chapter which shall include—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe02d333-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7300/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an identification of any position within the Department or elsewhere in the executive branch, which it considers unnecessary due to consolidation of functions under this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe02d334-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7300/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a statement of the number of employees entitled to pay savings by reason of the reorganization under this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe02d335-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7300/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a statement of the number of employees who are voluntarily or involuntarily separated by reason of such reorganization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe02d336-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7300/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an estimate of the personnel costs associated with such reorganization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe02d337-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7300/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effects of such reorganization on labor management relations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe02d338-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7300/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such legislative and administrative recommendations for improvements in personnel management within the Department as the Commission considers necessary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbe02d339-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/91/tVII/s712"},"text":"Pub. L. 95–91, title VII, § 712","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-08-04"},"text":"Aug. 4, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/609"},"text":"91 Stat. 609","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbe02d33a-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbe02d33b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tai