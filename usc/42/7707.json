{"tag":"section","attrib":{"id":"idbe72f9a7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7707"},"text":null,"children":[{"tag":"num","attrib":{"value":"7707"},"text":"§ 7707.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advanced National Seismic System","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbe72f9a8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7707/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the United States Geological Survey shall establish and operate an Advanced National Seismic System. The purpose of such system shall be to organize, modernize, standardize, and stabilize the national, regional, and urban seismic monitoring systems in the United States, including sensors, recorders, and data analysis centers, into a coordinated system that will measure and record the full range of frequencies and amplitudes exhibited by seismic waves, in order to enhance earthquake research and warning capabilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe72f9a9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7707/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"2000-11-13"},"text":"November 13, 2000","children":[],"tail":", the Director of the United States Geological Survey shall transmit to the Congress a 5-year management plan for establishing and operating the Advanced National Seismic System. The plan shall include annual cost estimates for both modernization and operation, milestones, standards, and performance goals, as well as plans for securing the participation of all existing networks in the Advanced National Seismic System and for establishing new, or enhancing existing, partnerships to leverage resources."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbe72f9aa-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/124/s13"},"text":"Pub. L. 95–124, § 13","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/503/tII/s204"},"text":"Pub. L. 106–503, title II, § 204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-13"},"text":"Nov. 13, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2305"},"text":"114 Stat. 2305","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/360/tI/s104/b"},"text":"Pub. L. 108–360, title I, § 104(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-25"},"text":"Oct. 25, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1675"},"text":"118 Stat. 1675","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/307/s8/b"},"text":"Pub. L. 115–307, § 8(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-11"},"text":"Dec. 11, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4417"},"text":"132 Stat. 4417","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbe72f9ab-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbe72f9ac-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbe72f9ad-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/307"},"text":"Pub. L. 115–307","children":[],"tail":" substituted “Advanced National Seismic System” for “Advanced National Seismic Research and Monitoring System” in section catchline and wherever appearing in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/360"},"text":"Pub. L. 108–360","children":[],"tail":" struck out subsec. (c) which related to authorization of appropriations."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
