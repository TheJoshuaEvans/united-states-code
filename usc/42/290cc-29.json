{"tag":"section","attrib":{"id":"idb5b8c841-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290cc–29"},"text":null,"children":[{"tag":"num","attrib":{"value":"290cc–29"},"text":"§ 290cc–29.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement of application","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary may not make payments under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s290cc–21"},"text":"section 290cc–21 of this title","children":[],"tail":" unless the State involved—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5b8c842-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290cc–29/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submits to the Secretary an application for the payments containing agreements and information in accordance with this part;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5b8c843-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290cc–29/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the agreements are made through certification from the chief executive officer of the State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5b8c844-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290cc–29/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the application otherwise is in such form, is made in such manner, and contains such agreements, assurances, and information as the Secretary determines to be necessary to carry out this part.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5b8c845-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"h