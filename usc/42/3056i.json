{"tag":"section","attrib":{"id":"idbc63f035-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3056i"},"text":null,"children":[{"tag":"num","attrib":{"value":"3056i"},"text":"§ 3056i.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with the Workforce Innovation and Opportunity Act","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbc63f036-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3056i/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Partners","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Grantees under this subchapter shall be one-stop partners as described in subparagraphs (A) and (B)(v) of section 121(b)(1) of the Workforce Innovation and Opportunity Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3151/b/1"},"text":"29 U.S.C. 3151(b)(1)","children":[],"tail":"] in the one-stop delivery system established under section 121(e) of such Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t29/s3151/e"},"text":"29 U.S.C. 3151(e)","children":[],"tail":"] for the appropriate local workforce development areas, and shall carry out the responsibilities relating to such partners."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc63f037-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3056i/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In local workforce investment areas where more than 1 grantee under this subchapter provides services, the grantees shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc63f038-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3056i/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate their activities related to the one-stop delivery systems; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc63f039-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3056i/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be signatories of the memorandum of understanding established under section 121(c) of the Workforce Innovation and Opportunity Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3151/c"},"text":"29 U.S.C. 3151(c)","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc63f03a-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/73/tV/s511"},"text":"Pub. L. 89–73, title V, § 511","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/365/tV/s501"},"text":"Pub. L. 109–365, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2580"},"text":"120 Stat. 2580","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/113/128/tV/s512/w/7"},"text":"Pub. L. 113–128, title V, § 512(w)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1716"},"text":"128 Stat. 1716","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/144/s6/c"},"text":"Pub. L. 114–144, § 6(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-04-19"},"text":"Apr. 19, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/343"},"text":"130 Stat. 343","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"