{"tag":"section","attrib":{"id":"idbaa1587a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1396w–1"},"text":"§ 1396w–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Medicaid Improvement Fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbaa1587b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish under this subchapter a Medicaid Improvement Fund (in this section referred to as the “Fund”) which shall be available to the Secretary to improve the management of the Medicaid program by the Centers for Medicare & Medicaid Services, including oversight of contracts and contractors and evaluation of demonstration projects, and, in accordance with subsection (b)(3), for the purposes of subparagraph (B) of such subsection. Payments made for activities under this subsection shall be in addition to payments that would otherwise be made for such activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbaa1587c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbaa1587d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w–1/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There shall be available to the Fund, for expenditures from the Fund for fiscal year 2023 and thereafter, $0.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaa1587e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w–1/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts in the Fund pursuant to paragraph (1) shall be available in advance of appropriations but only if the total amount obligated from the Fund does not exceed the amount available to the Fund under paragraph (1). Amounts in the Fund pursuant to paragraph (3) shall be available in advance of appropriations but only if the total amount obligated from the Fund does not exceed the amount available to the Fund under such paragraph (3). The Secretary may obligate funds from the Fund only if the Secretary determines (and the Chief Actuary of the Centers for Medicare & Medicaid Services and the appropriate budget officer certify) that there are available in the Fund sufficient amounts to cover all such obligations incurred consistent with the previous sentences.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaa1587f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w–1/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional funding for State activities relating to mechanized claims systems","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbaa15880-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w–1/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to the amount made available under paragraph (1), there shall be available to the Fund, for expenditures from the Fund in accordance with subparagraph (B), for fiscal year 2028 and thereafter, $0, to remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaa15881-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w–1/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall use amounts made available to the Fund under subparagraph (A) to pay to each State which has a plan approved under this subchapter, for each quarter beginning during or after fiscal year 2025 an amount equal to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbaa15882-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w–1/b/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 100 percent minus the percent specified in clause (i) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1396b/a/3/A"},"text":"section 1396b(a)(3)(A) of this title","children":[],"tail":" of so much of the sums expended by the State during such quarter as are attributable to the activities described in such clause;"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbaa15883-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w–1/b/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 100 percent minus the Federal medical assistance percentage applied under clause (iii) of such section of so much of the sums expended during such quarter (as found necessary by the Secretary under such clause) by the State as are attributable to the activities described in such clause; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbaa15884-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w–1/b/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 100 percent minus the percent specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1396b/a/3/B"},"text":"section 1396b(a)(3)(B) of this title","children":[],"tail":" of so much of the sums expended by the State during such quarter as are attributable to the activities described in such section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbaa15885-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title XIX, § 1941, as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/252/tVII/s7002/b"},"text":"Pub. L. 110–252, title VII, § 7002(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-06-30"},"text":"June 30, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2395"},"text":"122 Stat. 2395","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/8/dF/tII/s226"},"text":"Pub. L. 111–8, div. F, title II, § 226","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-03-11"},"text":"Mar. 11, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/784"},"text":"123 Stat. 784","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/127/s4"},"text":"Pub. L. 111–127, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-01-27"},"text":"Jan. 27, 2010","children":[],"tail":", "},{"tag":"ref",