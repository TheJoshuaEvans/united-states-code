stituted “$3,464,000,000” for “$3,446,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/159/s2602/2"},"text":"Pub. L. 116–159, § 2602(2)","children":[],"tail":", substituted “$3,446,000,000” for “$1,960,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2019—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/59/s1604/1"},"text":"Pub. L. 116–59, § 1604(1)","children":[],"tail":", substituted “$0” for “$1,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/29"},"text":"Pub. L. 116–29","children":[],"tail":" substituted “$1,000,000” for “$6,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/3"},"text":"Pub. L. 116–3","children":[],"tail":" substituted “$6,000,000” for “$31,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/59/s1604/2/A"},"text":"Pub. L. 116–59, § 1604(2)(A)","children":[],"tail":", substituted “2025” for “2023” in subpars. (A) and (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/69"},"text":"Pub. L. 116–69","children":[],"tail":" substituted “$1,960,000,000” for “$2,387,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/59/s1604/2/B"},"text":"Pub. L. 116–59, § 1604(2)(B)","children":[],"tail":", substituted “$2,387,000,000” for “$0”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/120/s3006/1"},"text":"Pub. L. 115–120, § 3006(1)","children":[],"tail":", inserted before period at end of first sentence “, and, in accordance with subsection (b)(3), for the purposes of subparagraph (B) of such subsection”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/271"},"text":"Pub. L. 115–271","children":[],"tail":" substituted “$31,000,000” for “$0”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/123/s53105/1"},"text":"Pub. L. 115–123, § 53105(1)","children":[],"tail":", substituted “$0” for “$5,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/120/s3006/2/A"},"text":"Pub. L. 115–120, § 3006(2)(A)","children":[],"tail":", inserted “pursuant to paragraph (1)” after “in the Fund” in first sentence and “Amounts in the Fund pursuant to paragraph (3) shall be available in advance of appropriations but only if the total amount obligated from the Fund does not exceed the amount available to the Fund under such paragraph (3).” after first sentence and substituted “the previous sentences” for “the previous sentence” in last sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/120/s3006/2/B"},"text":"Pub. L. 115–120, § 3006(2)(B)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/123/s53105/2"},"text":"Pub. L. 115–123, § 53105(2)","children":[],"tail":", substituted “$0” for “$980,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/198"},"text":"Pub. L. 114–198","children":[],"tail":" amended par. (1) generally. Prior to amendment, text read as follows: “There shall be available to the Fund, for expenditures from the Fund—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) for fiscal year 2014, $0; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) for each of fiscal years 2015 through 2018, $0.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—Subsec. (b)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/s2007/b/1"},"text":"Pub. L. 111–148, § 2007(b)(1)","children":[],"tail":", which directed substitution of “$0” for “$100,000,000”, was executed by making the substitution for “$10,000,000”, to reflect the probable intent of Congress and intervening amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/111/127"},"text":"Pub. L. 111–127","children":[],"tail":". See below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/127"},"text":"Pub. L. 111–127","children":[],"tail":" substituted “$10,000,000” for “$100,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/s2007/b/2"},"text":"Pub. L. 111–148, § 2007(b)(2)","children":[],"tail":", substituted “$0” for “$150,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2009—Subsec. (b)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/8"},"text":"Pub. L. 111–8","children":[],"tail":" inserted “each of” after “for”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
