ding death) of an illness, disability, injury, or condition referred to above which illness, disability, injury, or condition arose within the time period prescribed","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"Not applicable","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"II.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"Measles, mumps, rubella, or any vaccine containing any of the foregoing as a component; DT; Td; or Tetanus Toxoid.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"A. Anaphylaxis or anaphylactic shock","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"24 hours","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"B. Encephalopathy (or encephalitis)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"15 days (for mumps, rubella, measles, or any vaccine containing any of the foregoing as a component). 3 days (for DT, Td, or tetanus toxoid).","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"C. Residual seizure disorder in accordance with subsection (b)(2)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"15 days (for mumps, rubella, measles, or any vaccine containing any of the foregoing as a component). 3 days (for DT, Td, or tetanus toxoid).","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"D. Any acute complication or sequela (including death) of an illness, disability, injury, or condition referred to above which illness, disability, injury, or condition arose within the time period prescribed","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"Not applicable","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"III.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"Polio Vaccines (other than Inactivated Polio Vaccine).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"A. Paralytic polio","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"—in a non-immunodeficient recipient","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"30 days","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"—in an immunodeficient recipient","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" 6 months","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"—in a vaccine-associated community case","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"Not applicable","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"B. Any acute complication or sequela (including death) of an illness, disability, injury, or condition referred to above which illness, disability, injury, or condition arose within the time period prescribed","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"Not applicable","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"IV.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"Inactivated Polio Vaccine.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"A. Anaphylaxis or anaphylactic shock","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"24 hours","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"B. Any acute complication or sequela (including death) of an illness, disability, injury, or condition referred to above which illness, disability, injury, or condition arose within the time period prescribed","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"Not applicable","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6778481-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300aa–14/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifications and aids to interpretation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The following qualifications and aids to interpretation shall apply to the Vaccine Injury Table in subsection (a):","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6778482-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300aa–14/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A shock-collapse or a hypotonic-hyporesponsive collapse may be evidenced by indicia or symptoms such as decrease or loss of muscle tone, paralysis (partial or complete), hemiplegia or hemiparesis, loss of color or turning pale white or blue, unresponsiveness to environmental stimuli, depression of consciousness, loss of consciousness, prolonged sleeping with difficulty arousing, or cardiovascular or respiratory arrest.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6778483-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300aa–14/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A petitioner may be considered to have suffered a residual seizure disorder if the petitioner did not suffer a seizure or convulsion unaccompanied by fever or accompanied by a fever of less than 102 degrees Fahrenheit before the first seizure or convulsion after the administration of the vaccine involved and if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6778484-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300aa–14/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a measles, mumps, or rubella vaccine or any combination of such vaccines, the first seizure or convulsion occurred within 15 days after administration of the vaccine and 2 or more seizures or convulsions occurred within 1 year after the administration of the vaccine which were unaccompanied by fever or accompanied by a fever of less than 102 degrees Fahrenheit, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6778485-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300aa–14/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of any other vaccine, the first seizure or convulsion occurred within 3 days after administration of the vaccine and 2 or more seizures or convulsions occurred within 1 year after the administration of the vaccine which were unaccompanied by fever or accompanied by a fever of less than 102 degrees Fahrenheit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6778486-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300aa–14/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6778487-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300aa–14/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “encephalopathy” means any significant acquired abnormality of, or injury to, or impairment of function of the brain. Among the frequent manifestations of encephalopathy are focal and diffuse neurologic signs, increased intracranial pressure, or changes lasting at least 6 hours in level of consciousness, with or without convulsions. The neurological signs and symptoms of encephalopathy may be temporary with complete recovery, or may result in various degrees of permanent impairment. Signs and symptoms such as high pitched and unusual screaming, persistent unconsolable crying, and bulging fontanel are compatible with an encephalopathy, but in and of themselves are not conclusive evidence of encephalopathy. Encephalopathy usually can be documented by slow wave activity on an electroencephalogram.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6778488-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300aa–14/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If in a proceeding on a petition it is shown by a preponderance of the evidence that an encephalopathy was caused by infection, toxins, trauma, or metabolic disturbances the encephalopathy shall not be considered to be a condition set forth in the table. If at the time a judgment is entered on a petition filed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300aa–11"},"text":"section 300aa–11 of this title","children":[],"tail":" for a vaccine-related injury or death it is not possible to determine the cause, by a preponderance of the evidence, of an encepha­lopathy, the encephalopathy shall be considered to be a condition set forth in the table. In determining whether or not an encepha­lopathy is a condition set forth in the table, the court shall consider the entire medical record."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6778489-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300aa–14/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of paragraphs (2) and (3), the terms “seizure” and “convulsion” include grand mal, petit mal, absence, myoclonic, tonic-clonic, and focal motor seizures and signs. If a provision of the table to which paragraph (1), (2), (3), or (4) applies is revised under subsection (c) or (d), such paragraph shall not apply to such provision after the effective date of the revision unless the revision specifies that such paragraph is to continue to apply.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb677848a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300aa–14/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative revision of table","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb677848b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300aa–14/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may promulgate regulations to modify in accordance with paragraph (3) the Vaccine Injury Table. In promulgating such regulations, the Secretary shall provide for notice and opportunity for a public hearing and at least 180 days of public comment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb677848c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300aa–14/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Any person (including the Advisory Commission on Childhood Vaccines) may petition the Secretary to propose regulations to amend the Vaccine Injury Table. Unless clearly frivolous, or initiated by the Commission, any such petition shall be referred to the Commission for its recommendations. Following—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb677848d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300aa–14/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" receipt of any recommendation of the Commission, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb677848e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300aa–14/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 180 days after the date of the referral to the Commission,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"whichever occurs first, the Secretary shall conduct a rulemaking proceeding on the matters proposed in the petition or publish in the Federal Register a statement of reasons for not conducting such proceeding.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb677848f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300aa–14/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A modification of the Vaccine Injury Table under paragraph (1) may add to, or delete from, the list of injuries, disabilities, illnesses, conditions, and deaths for which compensation may be provided or may change the time periods for the first symptom or manifestation of the onset or the significant aggravation of any such injury, disability, illness, condition, or death.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6778490-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300aa–14/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any modification under paragraph (1) of the Vaccine Injury Table shall apply only with respect to petitions for compensation under the Program which are filed after the effective date of such regulation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6778491-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300aa–14/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Role of Commission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except with respect to a regulation recommended by the Advisory Commission on Childhood Vaccines, the Secretary may not propose a regulation under subsection (c) or any revision thereof, unless the Secretary has first provided to the Commission a copy of the proposed regulation or revision, requested recommendations and comments by the Commission, and afforded the Commission at least 90 days to make such recommendations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6778492-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300aa–14/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional vaccines","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6778493-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300aa–14/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vaccines recommended before ","children":[{"tag":"date","attrib":{"date":"1993-08-01"},"text":"August 1, 1993","children":[],"tail":null}],"tail":null},{"tag":"chapeau","attrib":{},"text":"By ","children":[{"tag":"date","attrib":{"date":"1995-08-01"},"text":"August 1, 1995","children":[],"tail":", the Secretary shall revise the Vaccine Injury Table included in subsection (a) to include—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6778494-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300aa–14/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" vaccines which are recommended to the Secretary by the Centers for Disease Control and Prevention before ","children":[{"tag":"date","attrib":{"date":"1993-08-01"},"text":"August 1, 1993","children":[],"tail":", for routine administration to children,"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6778495-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300aa–14/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the injuries, disabilities, illnesses, conditions, and deaths associated with such vaccines, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6778496-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300aa–14/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the time period in which the first symptoms or manifestations of onset or other significant aggravation of such injuries, disabilities, illnesses, conditions, and deaths associated with such vaccines may occur.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6778497-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300aa–14/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vaccines recommended after ","children":[{"tag":"date","attrib":{"date":"1993-08-01"},"text":"August 1, 1993","children":[],"tail":null}],"tail":null},{"tag":"chapeau","attrib":{},"text":"When after ","children":[{"tag":"date","attrib":{"date":"1993-08-01"},"text":"August 1, 1993","children":[],"tail":", the Centers for Disease Control and Prevention recommends a vaccine to the Secretary for routine administration to children, the Secretary shall, within 2 years of such recommendation, amend the Vaccine Injury Table included in subsection (a) to include—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6778498-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300aa–14/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" vaccines which were recommended for routine administration to children,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6778499-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300aa–14/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the injuries, disabilities, illnesses, conditions, and deaths associated with such vaccines, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb677849a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300aa–14/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the time period in which the first symptoms or manifestations of onset or other significant aggravation of such injuries, disabilities, illnesses, conditions, and deaths associated with such vaccines may occur.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb677849b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300aa–14/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vaccines recommended for use in pregnant women","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall revise the Vaccine Injury Table included in subsection (a), through the process described in subsection (c), to include vaccines recommended by the Centers for Disease Control and Prevention for routine administration in pregnant women and the information described in subparagraphs (B) and (C) of paragraph (2) with respect to such vaccines.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb677849c-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XXI, § 2114, as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/660/tIII/s311/a"},"text":"Pub. L. 99–660, title III, § 311(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3764"},"text":"100 Stat. 3764","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/239/tVI/s6601/k"},"text":"Pub. L. 101–239, title VI, § 6601(k)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2290"},"text":"103 Stat. 2290","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/66/tXIII/s13632/a/2"},"text":"Pub. L. 103–66, title XIII, § 13632(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-10"},"text":"Aug. 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/645"},"text":"107 Stat. 645","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/255/dA/tIII/s3093/c/1"},"text":"Pub. L. 114–255, div. A, title III, § 3093(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-13"},"text":"Dec. 13, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1152"},"text":"130 Stat. 1152","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb677849d-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb677849e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb677849f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 300aa–14, act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", § 2115, was successively renumbered by subsequent acts and transferred, see section 238"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":" of this title."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior section 2114 of act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", was successively renumbered by subsequent acts and transferred, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s238k"},"text":"section 238k of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb67784a0-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Subsec. (e)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255"},"text":"Pub. L. 114–255","children":[],"tail":" added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/66"},"text":"Pub. L. 103–66","children":[],"tail":" amended heading and text of subsec. (e) generally. Prior to amendment, text read as follows: “The Secretary may recommend to Congress revisions of the table to change the vaccines covered by the table.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239/s6601/k/1"},"text":"Pub. L. 101–239, § 6601(k)(1)","children":[],"tail":", substituted “(b)(2)” for “(c)(2)” in items I.D. and II.C. in table."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239/s6601/k/2"},"text":"Pub. L. 101–239, § 6601(k)(2)","children":[],"tail":", substituted “300aa–11 of this title” for “300aa–11(b) of this title”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb67784a1-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb67784a2-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1989 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For applicability of amendments by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239"},"text":"Pub. L. 101–239","children":[],"tail":" to petitions filed after "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", petitions currently pending in which the evidentiary record is closed, and petitions currently pending in which the evidentiary record is not closed, with provision for an immediate suspension for 30 days of all pending cases, see "},{"tag":"ref","attrib":{"href":"/us/pl/101/239/s6601/s/1"},"text":"section 6601(s)(1) of Pub. L. 101–239","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300aa–10"},"text":"section 300aa–10 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb67784a3-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Revisions of Vaccine Injury Table","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Vaccine Injury Table as modified by regulations promulgated by the Secretary of Health and Human Services is set out at 42 CFR 100.3.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/66/tXIII/s13632/a/3"},"text":"Pub. L. 103–66, title XIII, § 13632(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-10"},"text":"Aug. 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/646"},"text":"107 Stat. 646","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/66/tXIII/s13632/a/3"},"text":"“A revision by the Secretary under section 2114(e) of the Public Health Service Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300aa–14/e"},"text":"42 U.S.C. 300aa–14(e)","children":[],"tail":") (as amended by paragraph (2)) shall take effect upon the effective date of a tax enacted to provide funds for compensation paid with respect to the vaccine to be added to the vaccine injury table in section 2114(a) of the Public Health Service Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300aa–14/a"},"text":"42 U.S.C. 300aa–14(a)","children":[],"tail":").”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
