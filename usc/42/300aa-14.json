{"tag":"section","attrib":{"id":"idb677847e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300aa–14"},"text":null,"children":[{"tag":"num","attrib":{"value":"300aa–14"},"text":"§ 300aa–14.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vaccine Injury Table","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb677847f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300aa–14/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial table","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The following is a table of vaccines, the injuries, disabilities, illnesses, conditions, and deaths resulting from the administration of such vaccines, and the time period in which the first symptom or manifestation of onset or of the significant aggravation of such injuries, disabilities, illnesses, conditions, and deaths is to occur after vaccine administration for purposes of receiving compensation under the Program:","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb6778480-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":"VACCINE INJURY TABLE","children":[],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"I.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"DTP; P; DTP/Polio Combination; or Any Other Vaccine Containing Whole Cell Pertussis Bacteria, Extracted or Partial Cell Bacteria, or Specific Pertussis Antigen(s).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"Illness, disability, injury, or condition covered:","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"Time period for first symptom or manifestation of onset or of significant aggravation after vaccine administration:","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"A. Anaphylaxis or anaphylactic shock","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"24 hours","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","c