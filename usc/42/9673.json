{"tag":"section","attrib":{"id":"idbed983a8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9673"},"text":null,"children":[{"tag":"num","attrib":{"value":"9673"},"text":"§ 9673.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Risk retention groups","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbed983a9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9673/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in this section, a risk retention group shall be exempt from the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbed983aa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9673/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A State law, rule, or order which makes unlawful, or regulates, directly or indirectly, the operation of a risk retention group.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbed983ab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9673/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A State law, rule, or order which requires or permits a risk retention group to participate in any insurance insolvency guaranty association to which an insurer licensed in the State is required to belong.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbed983ac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9673/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A State law, rule, or order which requires any insurance policy issued to a risk retention group or any member of the group to be countersigned by an insurance agent or broker residing in the State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbed983ad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9673/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A State law, rule, or order which otherwise discriminates against a risk retention group or any of its members.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbed983ae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9673/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbed983af-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9673/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State laws generally applicable","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in subsection (a) shall be construed to affect the applicability of State laws generally applicable to persons or corporations. The State in which a risk retention group is chartered may regulate the formation and operation of the group.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbed983b0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9673/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State regulations not subject to exemption","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsection (a) shall not apply to any State law which requires a risk retention group to do any of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbed983b1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9673/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Comply with the unfair claim settlement practices law of the State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbed983b2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9673/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Pay, on a nondiscriminatory basis, applicable premium and other taxes which are levied on admitted insurers and surplus line insurers, brokers, or policyholders under the laws of the State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbed983b3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9673/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Participate, on a nondiscriminatory basis, in any mechanism established or authorized under the law of the State for the equitable apportionment among insurers of pollution liability insurance losses and expenses incurred on policies written through such mechanism.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbed983b4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9673/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Submit to the appropriate authority reports and other information required of licensed insurers under the laws of a State relating solely to pollution liability insurance losses and expenses.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbed983b5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9673/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Register with and designate the State insurance commissioner as its agent solely for the purpose of receiving service of legal documents or process.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbed983b6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9673/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Furnish, upon request, such commissioner a copy of any financial report submitted by the risk retention group to the commissioner of the chartering or licensing jurisdiction.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbed983b7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9673/b/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Submit to an examination by the State insurance commissioner in any State in which the group is doing business to determine the group’s financial condition, if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbed983b8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9673/b/2/G/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the commissioner has reason to believe the risk retention group is in a financially impaired condition; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbed983b9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9673/b/2/G/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the commissioner of the jurisdiction in which the group is chartered has not begun or has refused to initiate an examination of the group.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbed983ba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9673/b/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Comply with a lawful order issued in a delinquency proceeding commenced by the State insurance commissioner if the commissioner of the jurisdiction in which the group is chartered has failed to initiate such a proceeding after notice of a finding of financial impairment under subparagraph (G).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbed983bb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9673/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of exemptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The exemptions specified in subsection (a) apply to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbed983bc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9673/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" pollution liability insurance coverage provided by a risk retention group for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbed983bd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9673/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such group; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbed983be-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9673/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any person who is a member of such group;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbed983bf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9673/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the sale of pollution liability insurance coverage for a risk retention group; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbed983c0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9673/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the provision of insurance related services or management services for a risk retention group or any member of such a group.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbed983c1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9673/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agents or brokers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State may require that a person acting, or offering to act, as an agent or broker for a risk retention group obtain a license from that State, except that a State may not impose any qualification or requirement which discriminates against a nonresident agent or broker.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbed983c2-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/510/tIV/s403"},"text":"Pub. L. 96–510, title IV, § 403","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/499/tII/s210/a"},"text":"Pub. L. 99–499, title II, § 210(a)","children":[],"tail":", formerly § 210, "},{"tag":"date","attrib":{"date":"1986-10-17"},"text":"Oct. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1717"},"text":"100 Stat. 1717","children":[],"tail":"; renumbered § 210(a), "},{"tag":"ref","attrib":{"href":"/us/pl/99/563/s11/c/1"},"text":"Pub. L. 99–563, § 11(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3177"},"text":"100 Stat. 3177","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
