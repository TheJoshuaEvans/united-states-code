{"tag":"section","attrib":{"id":"idb7932e7f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s612"},"text":null,"children":[{"tag":"num","attrib":{"value":"612"},"text":"§ 612.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Direct funding and administration by Indian tribes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb7932e80-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s612/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants for Indian tribes","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7932e81-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s612/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tribal family assistance grant","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb7932e82-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s612/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For each of fiscal years 2017 and 2018, the Secretary shall pay to each Indian tribe that has an approved tribal family assistance plan a tribal family assistance grant for the fiscal year in an amount equal to the amount determined under subparagraph (B), which shall be reduced for a fiscal year, on a pro rata basis for each quarter, in the case of a tribal family assistance plan approved during a fiscal year for which the plan is to be in effect, and shall reduce the grant payable under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s603/a/1"},"text":"section 603(a)(1) of this title","children":[],"tail":" to any State in which lies the service area or areas of the Indian tribe by that portion of the amount so determined that is attributable to expenditures by the State."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7932e83-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s612/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount determined","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb7932e84-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s612/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount determined under this subparagraph is an amount equal to the total amount of the Federal payments to a State or States under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s603"},"text":"section 603 of this title","children":[],"tail":" (as in effect during such fiscal year) for fiscal year 1994 attributable to expenditures (other than child care expenditures) by the State or States under parts A and F (as so in effect) for fiscal year 1994 for Indian families residing in the service area or areas identified by the Indian tribe pursuant to subsection (b)(1)(C) of this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb7932e85-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s612/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of State submitted data","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb7957776-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s612/a/1/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall use State submitted data to make each determination under clause (i).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb7957777-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s612/a/1/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disagreement with determination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If an Indian tribe or tribal organization disagrees with State submitted data described under subclause (I), the Indian tribe or tribal organization may submit to the Secretary such additional information as may be relevant to making the determination under clause (i) and the Secretary may consider such information before making such determination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7957778-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s612/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants for Indian tribes that received jobs funds","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb7957779-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s612/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For each of fiscal years 2017 and 2018, the Secretary shall pay to each eligible Indian tribe that proposes to operate a program described in subparagraph (C) a grant in an amount equal to the amount received by the Indian tribe in fiscal year 1994 under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s682/i"},"text":"section 682(i) of this title","children":[],"tail":" (as in effect during fiscal year 1994)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb795777a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s612/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible Indian tribe","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of subparagraph (A), the term “eligible Indian tribe” means an Indian tribe or Alaska Native organization that conducted a job opportunities and basic skills training program in fiscal year 1995 under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s682/i"},"text":"section 682(i) of this title","children":[],"tail":" (as in effect during fiscal year 1995)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb795777b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s612/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of grant","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each Indian tribe to which a grant is made under this paragraph shall use the grant for the purpose of operating a program to make work activities available to such population and such service area or areas as the tribe specifies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb795777c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s612/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Out of any money in the Treasury of the United States not otherwise appropriated, there are appropriated $7,633,287 for each fiscal year specified in subparagraph (A) for grants under subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb795777d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s612/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Welfare-to-work grants","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb795777e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s612/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Labor shall award a grant in accordance with this paragraph to an Indian tribe for each fiscal year specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s603/a/5/H"},"text":"section 603(a)(5)(H) of this title","children":[],"tail":" for which the Indian tribe is a welfare-to-work tribe, in such amount as the Secretary of Labor deems appropriate, subject to subparagraph (B) of this paragraph."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb795777f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s612/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Welfare-to-work tribe","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An Indian tribe shall be considered a welfare-to-work tribe for a fiscal year for purposes of this paragraph if the Indian tribe meets the following requirements:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb7957780-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s612/a/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Indian tribe has submitted to the Secretary of Labor a plan which describes how, consistent with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s603/a/5"},"text":"section 603(a)(5) of this title","children":[],"tail":", the Indian tribe will use any funds provided under this paragraph during the fiscal year. If the Indian tribe has a tribal family assistance plan, the plan referred to in the preceding sentence shall be in the form of an addendum to the tribal family assistance plan."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb7957781-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s612/a/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Indian tribe is operating a program under a tribal family assistance plan approved by the Secretary of Health and Human Services, a program described in paragraph (2)(C), or an employment program funded through other sources under which substantial services are provided to recipients of assistance under a program funded under this part.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb7957782-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s612/a/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Indian tribe has provided the Secretary of Labor with an estimate of the amount that the Indian tribe intends to expend during the fiscal year (excluding tribal expenditures described in section 609(a)(7)(B)(iv) (other than subclause (III) thereof) of this title) pursuant to this paragraph.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb7957783-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s612/a/3/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Indian tribe has agreed to negotiate in good faith with the Secretary of Health and Human Services with respect to the substance and funding of any evaluation under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s613/j"},"text":"section 613(j) of this title","children":[],"tail":", and to cooperate with the conduct of any such evaluation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7957784-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s612/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on use of funds","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb7957785-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s612/a/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s603/a/5/C"},"text":"Section 603(a)(5)(C) of this title","children":[],"tail":" shall apply to funds provided to Indian tribes under this paragraph in the same manner in which such section applies to funds provided under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s603/a/5"},"text":"section 603(a)(5) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb7957786-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s612/a/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Labor may waive or modify the application of a provision of section 603(a)(5)(C) (other than clause (viii) thereof) of this title with respect to an Indian tribe to the extent necessary to enable the Indian tribe to operate a more efficient or effective program with the funds provided under this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb7957787-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s612/a/3/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Within 90 days after ","children":[{"tag":"date","attrib":{"date":"1997-08-05"},"text":"August 5, 1997","children":[],"tail":", the Secretary of Labor, after consultation with the Secretary of Health and Human Services and the Secretary of Housing and Urban Development, shall prescribe such regulations as may be necessary to implement this paragraph."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7957788-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s612/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" 3-year tribal family assistance plan","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7957789-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s612/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any Indian tribe that desires to receive a tribal family assistance grant shall submit to the Secretary a 3-year tribal family assistance plan that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb795778a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s612/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" outlines the Indian tribe’s approach to providing welfare-related services for the 3-year period, consistent with this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb795778b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s612/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specifies whether the welfare-related services provided under the plan will be provided by the Indian tribe or through agreements, contracts, or compacts with intertribal consortia, States, or other entities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb795778c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s612/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifies the population and service area or areas to be served by such plan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb795778d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s612/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides that a family receiving assistance under the plan may not receive duplicative assistance from other State or tribal programs funded under this part;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb795778e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s612/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifies the employment opportunities in or near the service area or areas of the Indian tribe and the manner in which the Indian tribe will cooperate and participate in enhancing such opportunities for recipients of assistance under the plan consistent with any applicable State standards; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb795778f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s612/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" applies the fiscal accountability provisions of section 5(f)(1) of the Indian Self-Determination and Education Assistance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s450c/f/1"},"text":"25 U.S.C. 450c(f)(1)","children":[],"tail":"),"},{"tag":"ref","attrib":{"idref":"fn002610"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002610"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" relating to the submission of a single-agency audit report required by chapter 75 of title 31."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7957790-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s612/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall approve each tribal family assistance plan submitted in accordance with paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7957791-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s612/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consortium of tribes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall preclude the development and submission of a single tribal family assistance plan by the participating Indian tribes of an intertribal consortium.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7957792-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s612/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum work participation requirements and time limits","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, with the participation of Indian tribes, shall establish for each Indian tribe receiving a grant under this section minimum work participation requirements, appropriate time limits for receipt of welfare-related services under the grant, and penalties against individuals—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7957793-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s612/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consistent with the purposes of this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7957794-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s612/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consistent with the economic conditions and resources available to each tribe; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7957795-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s612/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" similar to comparable provisions in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s607/e"},"text":"section 607(e) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7957796-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s612/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emergency assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall preclude an Indian tribe from seeking emergency assistance from any Federal loan program or emergency fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7957797-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s612/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Accountability","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this section shall be construed to limit the ability of the Secretary to maintain program funding accountability consistent with—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7957798-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s612/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" generally accepted accounting principles; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7957799-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s612/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the requirements of the Indian Self-Determination and Education Assistance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s450"},"text":"25 U.S.C. 450","children":[],"tail":" et seq.)."},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb795779a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s612/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility for Federal loans","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s606"},"text":"Section 606 of this title","children":[],"tail":" shall apply to an Indian tribe with an approved tribal assistance plan in the same manner as such section applies to a State, except that "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s606/c"},"text":"section 606(c) of this title","children":[],"tail":" shall be applied by substituting “section 612(a)” for “section 603(a)”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb795779b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s612/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalties","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb795779c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s612/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subsections (a)(1), (a)(6), (b), and (c) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s609"},"text":"section 609 of this title","children":[],"tail":", shall apply to an Indian tribe with an approved tribal assistance plan in the same manner as such subsections apply to a State."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb795779d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s612/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s609/a/3"},"text":"Section 609(a)(3) of this title","children":[],"tail":" shall apply to an Indian tribe with an approved tribal assistance plan by substituting “meet minimum work participation requirements established under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s612/c"},"text":"section 612(c) of this title","children":[],"tail":"” for “comply with "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s607/a"},"text":"section 607(a) of this title","children":[],"tail":"”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb795779e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s612/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data collection and reporting","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s611"},"text":"Section 611 of this title","children":[],"tail":" shall apply to an Indian tribe with an approved tribal family assistance plan."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb795779f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s612/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule for Indian tribes in Alaska","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb79577a0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s612/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of this section, and except as provided in paragraph (2), an Indian tribe in the State of Alaska that receives a tribal family assistance grant under this section shall use the grant to operate a program in accordance with requirements comparable to the requirements applicable to the program of the State of Alaska funded under this part. Comparability of programs shall be established on the basis of program criteria developed by the Secretary in consultation with the State of Alaska and such Indian tribes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb79577a1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s612/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An Indian tribe described in paragraph (1) may apply to the appropriate State authority to receive a waiver of the requirement of paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb79577a2-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title IV, § 412, as added "},{"tag":"ref","attrib":{"href":"/us/pl/