{"tag":"section","attrib":{"id":"idc081dc54-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19154"},"text":null,"children":[{"tag":"num","attrib":{"value":"19154"},"text":"§ 19154.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collection of data on demographics of faculty","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc081dc55-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19154/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collection of data","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc081dc56-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19154/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 5 years after ","children":[{"tag":"date","attrib":{"date":"2022-08-09"},"text":"August 9, 2022","children":[],"tail":", and at least every five years thereafter, the Director of the National Science Foundation shall carry out a survey to collect data from award recipients on the demographics of STEM faculty, by broad fields of STEM, at different types of institutions of higher education that receive Federal research funding."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc081dc57-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19154/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Survey considerations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To the extent practicable, the Director of the National Science Foundation shall survey, by sex, race, socioeconomic indicators, which may include employment status, occupation, educational attainment, parental education, and income, geographic location, ethnicity, citizenship status, and years since completion of doctoral degree—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc081dc58-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19154/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number and percentage of faculty;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc081dc59-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19154/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number and percentage of faculty at each rank;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc081dc5a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19154/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number and percentage of faculty who are in nontenure-track positions, including teaching and research;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc081dc5b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19154/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number and percentage of faculty who are reviewed for promotion, including tenure, and the percentage of that number who are promoted, including being awarded tenure;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc081dc5c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19154/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" faculty years in rank;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc081dc5d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19154/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number and percentage of faculty to leave tenure-track positions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc081dc5e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19154/a/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number and percentage of faculty hired, by rank; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc081dc5f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19154/a/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number and percentage of faculty in leadership positions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc081dc60-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19154/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Existing surveys","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director of the National Science Foundation, may, in modifying or expanding existing Federal surveys of higher education (as necessary)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc081dc61-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19154/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take into account the considerations under subsection (a)(2) by collaborating with statistical centers at other Federal agencies; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc081dc62-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19154/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make an award to an institution of higher education or nonprofit organization (or consortia thereof) to take such considerations into account.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc081dc63-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19154/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting data","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the National Science Foundation shall publish statistical summary data collected under this section, including as part of the National Science Foundation’s report required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1885d"},"text":"section 1885d of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc081dc64-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19154/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to the Director of the National Science Foundation $4,000,000 in each of fiscal years 2023 through 2025 to develop and carry out the initial survey required under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc081dc65-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/tV/s10504"},"text":"Pub. L. 117–167, div. B, title V, § 10504","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1611"},"text":"136 Stat. 1611","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
