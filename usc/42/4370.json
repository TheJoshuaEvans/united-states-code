{"tag":"section","attrib":{"id":"idbcca79bd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370"},"text":null,"children":[{"tag":"num","attrib":{"value":"4370"},"text":"§ 4370.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimbursement for use of facilities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbcca79be-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to allow outside groups or individuals to use research and test facilities; reimbursement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator is authorized to allow appropriate use of special Environmental Protection Agency research and test facilities by outside groups or individuals and to receive reimbursement or fees for costs incurred thereby when he finds this to be in the public interest. Such reimbursement or fees are to be used by the Agency to defray the costs of use by outside groups or individuals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcca79bf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules and regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator may promulgate regulations to cover such use of Agency facilities in accordance with generally accepted accounting, safety, and laboratory practices.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcca79c0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver of reimbursement by Administrator","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"When he finds it is in the public interest the Administrator may waive reimbursement or fees for outside use of Agency facilities by nonprofit private or public entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbcca79c1-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/229/s5"},"text":"Pub. L. 96–229, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-04-07"},"text":"Apr. 7, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/328"},"text":"94 Stat. 328","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbcca79c2-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbcca79c3-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbcca79c4-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Environmental Research, Development, and Demonstration Authorization Act of 1980, and not as part of the National Environmental Policy Act of 1969 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
