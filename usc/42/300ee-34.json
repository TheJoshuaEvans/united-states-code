{"tag":"section","attrib":{"id":"idb68d07c4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–34"},"text":null,"children":[{"tag":"num","attrib":{"value":"300ee–34"},"text":"§ 300ee–34.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb68d07c5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–34/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of carrying out sections 300ee–31 through 300ee–33 of this title, there are authorized to be appropriated $105,000,000 for fiscal year 1989 and such sums as may be necessary for each of the fiscal years 1990 and 1991.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb68d07c6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–34/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb68d07c7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–34/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Of the amounts appropriated pursuant to subsection (a), the Secretary shall make available $45,000,000 to carry out ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ee–32"},"text":"section 300ee–32 of this title","children":[],"tail":" and $30,000,000 to carry out this part through financial assistance to minority entities for the provision of services to minority populations."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb68d07c8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–34/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" After consultation with the Director of the Office of Minority Health and with the Indian Health Service, the Secretary, acting through the Director of the Centers for Disease Control and Prevention, shall, not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"1988-11-04"},"text":"November 4, 1988","children":[],"tail":", publish guidelines to provide procedures for applications for funding pursuant to paragraph (1) and for public comment."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb68d07c9-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XXV, formerly title XV, § 2524, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/607/tII/s221"},"text":"Pub. L. 100–607, title II, § 221","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-04"},"text":"Nov. 4, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3103"},"text":"102 Stat. 3103","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tII/s2619/i"},"text":"Pub. L. 100–690, title II, § 2619(i) [(j)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4244"},"text":"102 Stat. 4244","children":[],"tail":"; renumbered title XXV, "},{"tag":"ref","attrib":{"href":"/us/pl/101/93/s5/e/1"},"text":"Pub. L. 101–93, § 5(e)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-08-16"},"text":"Aug. 16, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/612"},"text":"103 Stat. 612","children":[],"tail":"; "},{"tag":"re