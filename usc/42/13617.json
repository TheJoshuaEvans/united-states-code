{"tag":"section","attrib":{"id":"idbfca4bc5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13617"},"text":null,"children":[{"tag":"num","attrib":{"value":"13617"},"text":"§ 13617.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of covered section 8 housing not subject to elderly preference","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"If an owner of any covered section 8 housing project designed primarily for occupancy by elderly families does not give preference in occupancy to elderly families as authorized in this subchapter, then elderly families (as such term was defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1437a"},"text":"section 1437a of this title","children":[],"tail":" before "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"October 28, 1992","children":[],"tail":") shall be eligible for occupancy in such housing to the same extent that such families were eligible before "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"October 28, 1992","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbfca4bc6-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550/tVI/s657"},"text":"Pub. L. 102–550, title VI, § 657","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3825"},"text":"106 Stat. 3825","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbfca4bc7-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbfca4bc8-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"