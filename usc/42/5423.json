{"tag":"section","attrib":{"id":"idbd54b87d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5423"},"text":null,"children":[{"tag":"num","attrib":{"value":"5423"},"text":"§ 5423.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants to States","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd54b87e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5423/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary is authorized to make grants to the States which have designated a State agency under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5422"},"text":"section 5422 of this title","children":[],"tail":" to assist them—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd54b87f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5423/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in identifying their needs and responsibilities in the area of manufactured home construction and safety standards; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd54b880-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5423/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in developing State plans under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5422"},"text":"section 5422 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd54b881-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5423/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation by Governor of State agency for receipt of grant","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Governor of each State shall designate the appropriate State agency for receipt of any grant made by the Secretary under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd54b882-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5423/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission of application by State agency to Secretary; review by Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any State agency designated by the Governor of a State desiring a grant under this section shall submit an application therefor to the Secretary. The Secretary shall review and either accept or reject such application.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd54b883-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5423/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of Federal share; equality of distribution of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal share for each State grant under subsection (a) of this section may not exceed 90 per centum of the total cost to the State in identifying its needs and developing its plan. In the event the Federal share for all States under such subsection is not the same, the differences among the States shall be established on the basis of objective criteria.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd54b884-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/383/tVI/s624"},"text":"Pub. L. 93–383, title VI, § 624","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-08-22"},"text":"Aug. 22, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/713"},"text":"88 Stat. 713","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/399/tIII/s308/c/4"},"text":"Pub. L. 96–399, title III, § 308(c)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-08"},"text":"Oct. 8, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1641"},"text":"94 Stat. 1641","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd54b885-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd54b886-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd54b887-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1980—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/399"},"text":"Pub. L. 96–399","children":[],"tail":" substituted “manufactured home” for “mobile home”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbd54b888-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbd54b889-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective upon the expiration of 180 days following ","children":[{"tag":"date","attrib":{"date":"1974-08-22"},"text":"Aug. 22, 1974","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/93/383/s627"},"text":"section 627 of Pub. L. 93–383","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5401"},"text":"section 5401 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
