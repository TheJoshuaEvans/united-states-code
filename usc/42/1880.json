{"tag":"section","attrib":{"id":"idbb9b966e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1880"},"text":null,"children":[{"tag":"num","attrib":{"value":"1880"},"text":"§ 1880.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Medal of Science","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There is established a National Medal of Science (hereinafter referred to as the “medal”), which shall be of such design and materials and bear such inscriptions as the President, on the basis of recommendations submitted by the National Science Foundation, may prescribe, and shall be awarded as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1881"},"text":"section 1881 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbb9b966f-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/209/s1"},"text":"Pub. L. 86–209, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1959-08-25"},"text":"Aug. 25, 1959","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/73/431"},"text":"73 Stat. 431","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbb9b9670-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbb9b9671-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbb9b9672-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of the National Science Foundation Act of 1950 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
