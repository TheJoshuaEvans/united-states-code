{"tag":"section","attrib":{"id":"idbd8e17f5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6309"},"text":null,"children":[{"tag":"num","attrib":{"value":"6309"},"text":"§ 6309.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd8e17f6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6309/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorizations for Secretary","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated to the Secretary not more than the following amounts to carry out his responsibilities under this part—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd8e17f7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6309/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $1,700,000 for fiscal year 1976;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd8e17f8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6309/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $1,500,000 for fiscal year 1977;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd8e17f9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6309/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $3,300,000 for fiscal year 1978; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd8e17fa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6309/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $10,000,000 for fiscal year 1979.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Amounts authorized for such purposes under paragraph (3) shall be in addition to amounts otherwise authorized and appropriated for such purposes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd8e17fb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6309/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorizations for Commission","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated to the Commission not more than the following amounts to carry out its responsibilities under this part—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd8e17fc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6309/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $650,000 for fiscal year 1976;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd8e17fd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6309/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $700,000 for fiscal year 1977;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd8e17fe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6309/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $700,000 for fiscal year 1978; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd8e17ff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6309/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"idref":"fn003467"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003467"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be designated “(4)”."}],"tail":" $2,000,000 for fiscal year 1979."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd8e1800-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6309/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other authorizations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated to the Secretary to be allocated not more than the following amounts—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd8e1801-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6309/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $1,100,000 for fiscal year 1976;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd8e1802-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6309/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $2,500,000 for fiscal year 1977; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd8e1803-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6309/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $1,800,000 for fiscal year 1978.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Such amounts shall, and any amounts authorized to be appropriated under subsection (a), may be allocated by the Secretary to the National Institute of Standards and Technology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd8e1804-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/163/tIII/s339"},"text":"Pub. L. 94–163, title III, § 339","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-12-22"},"text":"Dec. 22, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/932"},"text":"89 Stat. 932","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/70/s3"},"text":"Pub. L. 95–70, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-07-21"},"text":"July 21, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/276"},"text":"91 Stat. 276","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/619/tIV/s426"},"text":"Pub. L. 95–619, title IV, § 426","children":[],"tail":", title VI, § 691(b)(2), "},{"tag":"date","attrib":{"date":"1978-11-09"},"text":"Nov. 9, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3267"},"text":"92 Stat. 3267","children":[],"tail":", 3288; "},{"tag":"ref","attrib":{"href":"/us/pl/100/12/s11/b/8"},"text":"Pub. L. 100–12, § 11(b)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-03-17"},"text":"Mar. 17, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/126"},"text":"101 Stat. 126","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/418/tV/s5115/c"},"text":"Pub. L. 100–418, title V, § 5115(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1433"},"text":"102 Stat. 1433","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd8e1805-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd8e1806-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd8e1807-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418"},"text":"Pub. L. 100–418","children":[],"tail":" substituted “National Institute of Standards and Technology” for “National Bureau of Standards” in closing provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/12"},"text":"Pub. L. 100–12","children":[],"tail":" inserted headings for subsecs. (a) to (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/619"},"text":"Pub. L. 95–619","children":[],"tail":", §§ 426(a), 691(b)(2), substituted “Secretary” for “Administrator”, meaning Administrator of the Federal Energy Administration, in text preceding par. (1), “$3,300,000” for “$1,500,000” in par. (3), added par. (4), and provided that amounts authorized under par. (3) would be in addition to amounts otherwise authorized and appropriated."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/619/s426/b"},"text":"Pub. L. 95–619, § 426(b)","children":[],"tail":", added second par. (3) relating to fiscal year 1979."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/619/s691/b/2"},"text":"Pub. L. 95–619, § 691(b)(2)","children":[],"tail":", substituted “Secretary” for “Administrator”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1977—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/70/s3/a"},"text":"Pub. L. 95–70, § 3(a)","children":[],"tail":", substituted “$2,500,000” for “$700,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/70/s3/b"},"text":"Pub. L. 95–70, § 3(b)","children":[],"tail":", substituted “$1,800,000” for “$700,000”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
