{"tag":"section","attrib":{"id":"idb5655163-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284p"},"text":null,"children":[{"tag":"num","attrib":{"value":"284p"},"text":"§ 284p.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities of the National Institutes of Health with respect to research with implications for enhancing daily function for persons with paralysis","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5655164-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284p/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director, pursuant to the general authority of the Director, may make awards of grants to public or private entities to pay all or part of the costs of planning, establishing, improving, and providing basic operating support to multicenter networks of clinical sites that will collaborate to design clinical rehabilitation intervention protocols and measures of outcomes on one or more forms of paralysis that result from central nervous system trauma, disorders, or stroke, or any combination of such conditions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5655165-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284p/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A multicenter network of clinical sites funded through this section may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5655166-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284p/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" focus on areas of key scientific concern, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5655167-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284p/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improving functional mobility;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5655168-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284p/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promoting behavioral adaptation to functional losses, especially to prevent secondary complications;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5655169-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284p/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assessing the efficacy and outcomes of medical rehabilitation therapies and practices and assisting technologies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb565516a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284p/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing improved assistive technology to improve function and independence; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb565516b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284p/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" understanding whole body system responses to physical impairments, disabilities, and societal and functional limitations; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb565516c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284p/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" replicate the findings of network members or other researchers for scientific and translation purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb565516d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284p/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination of clinical trials networks; reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director may, as appropriate, provide for the coordination of information among networks funded through this section and ensure regular communication among members of the networks, and may require the periodic preparation of reports on the activities of the networks and submission of reports to the Director.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb565516e-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11/tXIV/s14201"},"text":"Pub. L. 111–11, title XIV, § 14201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-03-30"},"text":"Mar. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1453"},"text":"123 Stat. 1453","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb565516f-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb5655170-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb5655171-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Christopher and Dana Reeve Paralysis Act, and also as part of the Omnibus Public Land Management Act of 2009, and not as part of the Public Health Service Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb5655172-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idb5655173-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definition of “Director”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Director” as meaning the Director of the National Institutes of Health, see section 284","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":"(a) of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
