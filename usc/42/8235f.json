{"tag":"section","attrib":{"id":"idbe839b30-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8235f"},"text":null,"children":[{"tag":"num","attrib":{"value":"8235f"},"text":"§ 8235f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of other laws","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbe839b31-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8235f/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lack of immunity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No provision contained in this part—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe839b32-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8235f/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall restrict any agency of the United States or any State from exercising its powers under any law to prevent unfair methods of competition and unfair or deceptive acts or practices;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe839b33-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8235f/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall provide to any person any immunity from civil or criminal liability;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe839b34-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8235f/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall create any defenses to actions brought under the antitrust laws; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe839b35-3a70-11f1-ae07-e4213316b5fa","i