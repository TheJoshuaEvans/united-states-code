original. Probably should be “sections”."}],"tail":" 1176 and 1177 of the Social Security Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320d–5"},"text":"42 U.S.C. 1320d–5","children":[],"tail":", 1320d–6]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc03f2dec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17939/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date; regulations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc03f2ded-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17939/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amendments made by subsection (a) shall apply to penalties imposed on or after the date that is 24 months after ","children":[{"tag":"date","attrib":{"date":"2009-02-17"},"text":"February 17, 2009","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc03f2dee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17939/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than 18 months after ","children":[{"tag":"date","attrib":{"date":"2009-02-17"},"text":"February 17, 2009","children":[],"tail":", the Secretary of Health and Human Services shall promulgate regulations to implement such amendments."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc03f2def-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17939/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distribution of certain civil monetary penalties collected","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc03f2df0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17939/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the regulation promulgated pursuant to paragraph (3), any civil monetary penalty or monetary settlement collected with respect to an offense punishable under this subchapter or section 1176 of the Social Security Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320d–5"},"text":"42 U.S.C. 1320d–5","children":[],"tail":") insofar as such section relates to privacy or security shall be transferred to the Office for Civil Rights of the Department of Health and Human Services to be used for purposes of enforcing the provisions of this subchapter and subparts C and E of part 164 of title 45, Code of Federal Regulations, as such provisions are in effect as of "},{"tag":"date","attrib":{"date":"2009-02-17"},"text":"February 17, 2009","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc03f2df1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17939/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" GAO report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 18 months after ","children":[{"tag":"date","attrib":{"date":"2009-02-17"},"text":"February 17, 2009","children":[],"tail":", the Comptroller General shall submit to the Secretary a report including recommendations for a methodology under which an individual who is harmed by an act that constitutes an offense referred to in paragraph (1) may receive a percentage of any civil monetary penalty or monetary settlement collected with respect to such offense."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc03f2df2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17939/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of methodology to distribute percentage of CMPS collected to harmed individuals","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 3 years after ","children":[{"tag":"date","attrib":{"date":"2009-02-17"},"text":"February 17, 2009","children":[],"tail":", the Secretary shall establish by regulation and based on the recommendations submitted under paragraph (2), a methodology under which an individual who is harmed by an act that constitutes an offense referred to in paragraph (1) may receive a percentage of any civil monetary penalty or monetary settlement collected with respect to such offense."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc03f2df3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17939/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of methodology","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The methodology under paragraph (3) shall be applied with respect to civil monetary penalties or monetary settlements imposed on or after the effective date of the regulation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc03f2df4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17939/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tiered increase in amount of civil monetary penalties","children