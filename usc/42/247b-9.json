{"tag":"section","attrib":{"id":"idb4a8df0f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–9"},"text":null,"children":[{"tag":"num","attrib":{"value":"247b–9"},"text":"§ 247b–9.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Diabetes in children and youth","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb4a8df10-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–9/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Surveillance on juvenile diabetes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Director of the Centers for Disease Control and Prevention, shall develop a sentinel system to collect data on juvenile diabetes, including with respect to incidence and prevalence, and shall establish a national database for such data.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4a8df11-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–9/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Type 2 diabetes in youth","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall implement a national public health effort to address type 2 diabetes in youth, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4a8df12-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–9/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhancing surveillance systems and expanding research to better assess the prevalence and incidence of type 2 diabetes in youth and determine the extent to which type 2 diabetes is incorrectly diagnosed as type 1 diabetes among children; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4a8df13-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–9/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing and improving laboratory methods to assist in diagnosis, treatment, and prevention of diabetes including, but not limited to, developing noninvasive ways to monitor blood glucose to prevent hypoglycemia and improving existing glucometers that measure blood glucose.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4a8df14-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–9/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of carrying out this section, there are authorized to be appropriated such sums as may be necessary for each of the fiscal years 2001 through 2005.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb4a8df15-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title III, § 317H, as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/310/dA/tIV/s401"},"text":"Pub. L. 106–310, div. A, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-17"},"text":"Oct. 17, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1112"},"text":"114 Stat. 1112","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
