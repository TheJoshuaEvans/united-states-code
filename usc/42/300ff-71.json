{"tag":"section","attrib":{"id":"idb6a01b14-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–71"},"text":null,"children":[{"tag":"num","attrib":{"value":"300ff–71"},"text":"§ 300ff–71.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants for coordinated services and access to research for women, infants, children, and youth","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb6a01b15-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–71/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Administrator of the Health Resources and Services Administration, shall award grants to public and nonprofit private entities (including a health facility operated by or pursuant to a contract with the Indian Health Service) for the purpose of providing family-centered care involving outpatient or ambulatory care (directly or through contracts or memoranda of understanding) for women, infants, children, and youth with HIV/AIDS.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6a01b16-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–71/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional services for patients and families","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Funds provided under grants awarded under subsection (a) may be used for the following support services:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6a01b17-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–71/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Family-centered care including case management.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6a01b18-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–71/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Referrals for additional services including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6a01b19-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–71/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" referrals for inpatient hospital services, treatment for substance abuse, and mental health services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6a01b1a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–71/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" referrals for other social and support services, as appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6a01b1b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–71/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Additional services necessary to enable the patient and the family to participate in the program established by the applicant pursuant to such subsection including services designed to recruit and retain youth with HIV.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6a01b1c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–71/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The provision of information and education on opportunities to participate in HIV/AIDS-related clinical research.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6a01b1d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–71/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with other entities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A grant awarded under subsection (a) may be made only if the applicant provides an agreement that includes the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6a01b1e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–71/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The applicant will coordinate activities under the grant with other providers of health care services under this chapter, and under title V of the Social Security Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s701"},"text":"42 U.S.C. 701","children":[],"tail":" et seq.], including programs promoting the reduction and elimination of risk of HIV/AIDS for youth."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6a01b1f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–71/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The applicant will participate in the statewide coordinated statement of need under part B (where it has been initiated by the public health agency responsible for administering grants under part B) and in revisions of such statement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6a01b20-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–71/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The applicant will every 2 years submit to the lead State agency under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–27/b/4"},"text":"section 300ff–27(b)(4) of this title","children":[],"tail":" audits regarding funds expended in accordance with this subchapter and shall include necessary client-level data to complete unmet need calculations and Statewide coordinated statements of need process."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6a01b21-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–71/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration; application","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A grant may only be awarded to an entity under subsection (a) if an application for the grant is submitted to the Secretary and the application is in such form, is made in such manner, and contains such agreements, assurances, and information as the Secretary determines to be necessary to carry out this section. Such application shall include the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6a01b22-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–71/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Information regarding how the expected expenditures of the grant are related to the planning process for localities funded under part A (including the planning process outlined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–12"},"text":"section 300ff–12 of this title","children":[],"tail":") and for States funded under part B (including the planning process outlined in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–27/b"},"text":"section 300ff–27(b) of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6a01b23-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–71/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A specification of the expected expenditures and how those expenditures will improve overall patient outcomes, as outlined as part of the State plan (under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–27/b"},"text":"section 300ff–27(b) of this title","children":[],"tail":") or through additional outcome measures."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6a01b24-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–71/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual review of programs; evaluations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6a01b25-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–71/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review regarding access to and participation in programs","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to a grant under subsection (a) for an entity for a fiscal year, the Secretary shall, not later than 180 days after the end of the fiscal year, provide for the conduct and completion of a review of the operation during the year of the program carried out under such subsection by the entity. The purpose of such review shall be the development of recommendations, as appropriate, for improvements in the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6a01b26-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–71/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Procedures used by the entity to allocate opportunities and services under subsection (a) among patients of the entity who are women, infants, children, or youth.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6a01b27-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–71/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Other procedures or policies of the entity regarding the participation of such individuals in such program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6a01b28-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–71/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall, directly or through contracts with public and private entities, provide for evaluations of programs carried out pursuant to subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6a01b29-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–71/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative expenses","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6a01b2a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–71/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A grantee may not use more than 10 percent of amounts received under a grant awarded under this section for administrative expenses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6a01b2b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–71/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Clinical quality management program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A grantee under this section shall implement a clinical quality management program to assess the extent to which HIV health services provided to patients under the grant are consistent with the most recent Public Health Service guidelines for the treatment of HIV/AIDS and related opportunistic infection, and as applicable, to develop strategies for ensuring that such services are consistent with the guidelines for improvement in the access to and quality of HIV health services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6a01b2c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–71/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training and technical assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"From the amounts appropriated under subsection (j) for a fiscal year, the Secretary may use not more than 5 percent to provide, directly or through contracts with public and private entities (which may include grantees under subsection (a)), training and technical assistance to assist applicants and grantees under subsection (a) in complying with the requirements of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6a01b2d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–71/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6a01b2e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–71/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “administrative expenses” means funds that are to be used by grantees for grant management and monitoring activities, including costs related to any staff or activity unrelated to services or indirect costs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6a01b2f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–71/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indirect costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “indirect costs” means costs included in a Federally negotiated indirect rate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6a01b30-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–71/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Services","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “services” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6a01b31-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–71/h/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" services that are provided to clients to meet the goals and objectives of the program under this section, including the provision of professional, diagnostic, and therapeutic services by a primary care provider or a referral to and provision of specialty care; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6a01b32-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–71/h/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" services that sustain program activity and contribute to or help improve services under subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6a01b33-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–71/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application to primary care services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this part shall be construed as requiring funds under this part to be used for primary care services when payments are available for such services from other sources (including under titles XVIII, XIX, and XXI of the Social Security Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395"},"text":"42 U.S.C. 1395","children":[],"tail":" et seq., 1396 et seq., 1397aa et seq.])."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6a01b34-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–71/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of carrying out this section, there are authorized to be appropriated, $71,800,000 for each of the fiscal years 2007 through 2009, $75,390,000 for fiscal year 2010, $79,160,000 for fiscal year 2011, $83,117,000 for fiscal year 2012, and $87,273,000 for fiscal year 2013.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb6a01b35-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XXVI, § 2671, as added and amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/415/tIV/s401"},"text":"Pub. L. 109–415, title IV, § 401","children":[],"tail":", title VII, § 703, "},{"tag":"date","attrib":{"date":"2006-12-19"},"text":"Dec. 19, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2810"},"text":"120 Stat. 2810","children":[],"tail":", 2820; "},{"tag":"ref","attrib":{"href":"/us/pl/111/87"},"text":"Pub. L. 111–87","children":[],"tail":", §§ 2(a)(1), (3)(A), (e), 11, "},{"tag":"date","attrib":{"date":"2009-10-30"},"text":"Oct. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2885"},"text":"123 Stat. 2885","children":[],"tail":", 2886, 2895.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb6a01b36-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb6a01b37-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb6a01b38-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Social Security Act, referred to in subsecs. (c)(1) and (i), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"act Aug. 14, 1935, ch. 531","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/620"},"text":"49 Stat. 620","children":[],"tail":". Titles V, XVIII, XIX, and XXI of the Act are classified generally to subchapters V (§ 701 et seq.), XVIII (§ 1395 et seq.), XIX (§ 1396 et seq.), and XXI (§ 1397aa et seq.), respectively, of chapter 7 of this title. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1305"},"text":"section 1305 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb6a01b39-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Prior sections 300ff–71 to 300ff–78 were omitted in the general amendment of this part by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/415"},"text":"Pub. L. 109–415","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 300ff–71, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373/tXXVI/s2671"},"text":"act July 1, 1944, ch. 373, title XXVI, § 2671","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/381/tIV/s401"},"text":"Pub. L. 101–381, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-08-18"},"text":"Aug. 18, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/617"},"text":"104 Stat. 617","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/146/s3/e"},"text":"Pub. L. 104–146, § 3(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-05-20"},"text":"May 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1358"},"text":"110 Stat. 1358","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/345/tIV/s401"},"text":"Pub. L. 106–345, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-20"},"text":"Oct. 20, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1347"},"text":"114 Stat. 1347","children":[],"tail":", related to grants for coordinated services and access to research for women, infants, children, and youth."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 300ff–72, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373/tXXVI/s2672"},"text":"act July 1, 1944, ch. 373, title XXVI, § 2672","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/381/tIV/s401"},"text":"Pub. L. 101–381, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-08-18"},"text":"Aug. 18, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/618"},"text":"104 Stat. 618","children":[],"tail":", contained provisions relating to blood banks."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 300ff–73, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373/tXXVI/s2673"},"text":"act July 1, 1944, ch. 373, title XXVI, § 2673","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/381/tIV/s401"},"text":"Pub. L. 101–381, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-08-18"},"text":"Aug. 18, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/619"},"text":"104 Stat. 619","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/345/tV/s503/a/2"},"text":"Pub. L. 106–345, title V, § 503(a)(2)","children":[