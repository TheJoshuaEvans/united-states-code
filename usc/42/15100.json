{"tag":"section","attrib":{"id":"idbfdfd006-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15100"},"text":null,"children":[{"tag":"num","attrib":{"value":"15100"},"text":"§ 15100.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Projects of national significance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfdfd007-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15100/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study by the Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall review Federal programs to determine the extent to which such programs facilitate or impede access to, provision of, and funding for family support services for families of children with disabilities, consistent with the policies described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s15091"},"text":"section 15091 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfdfd008-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15100/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Projects of national significance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall make grants or enter into contracts for projects of national significance to support the development of national and State policies and practices related to the development and implementation, or expansion and enhancement, of family-centered and family-directed systems of family support services for families of children with disabilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfdfd009-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/402/tII/s211"},"text":"Pub. L. 106–402, title II, § 211","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1733"},"text":"114 Stat. 1733","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
