{"tag":"section","attrib":{"id":"idc05240a4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18122"},"text":null,"children":[{"tag":"num","attrib":{"value":"18122"},"text":"§ 18122.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction regarding health care providers","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc05240a5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18122/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (3), the development, recognition, or implementation of any guideline or other standard under any Federal health care provision shall not be construed to establish the standard of care or duty of care owed by a health care provider to a patient in any medical malpractice or medical product liability action or claim.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc05240a6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18122/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc05240a7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18122/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal health care provision","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Federal health care provision” means any provision of the Patient Protection and Affordable Care Act (","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148"},"text":"Public Law 111–148","children":[],"tail":"), title I or subtitle B of title II of the Health Care and Education Reconciliation Act of 2010 ("},{"tag":"ref","attrib":{"href":"/us/pl/111/152"},"text":"Public Law 111–152","children":[],"tail":"), or title XVIII or XIX of the Social Security Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395"},"text":"42 U.S.C. 1395","children":[],"tail":" et seq., "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1396"},"text":"42 U.S.C. 1396","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc05240a8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18122/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Health care provider","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “health care provider” means any individual, group practice, corporation of health care professionals, or hospital—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc05240a9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18122/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" licensed, registered, or certified under Federal or State laws or regulations to provide health care services; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc05240aa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18122/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" required to be so licensed, registered, or certified but that is exempted by other statute or regulation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc05240ab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18122/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Medical malpractice or medical product liability action or claim","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “medical malpractice or medical product liability action or claim” means a medical malpractice action or claim (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11151/7"},"text":"section 11151(7) of this title","children":[],"tail":") and includes a liability action or claim relating to a health care provider’s prescription or provision of a drug, device, or biological product (as such terms are defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s321"},"text":"section 321 of title 21","children":[],"tail":" or "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s262"},"text":"section 262 of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc05240ac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18122/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State” includes the District of Columbia, Puerto Rico, and any other commonwealth, possession, or territory of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc05240ad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18122/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No preemption","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in paragraph (1) or any provision of the Patient Protection and Affordable Care Act (","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148"},"text":"Public Law 111–148","children":[],"tail":"), title I or subtitle B of title II of the Health Care and Education Reconciliation Act of 2010 ("},{"tag":"ref","attrib":{"href":"/us/pl/111/152"},"text":"Public Law 111–152","children":[],"tail":"), or title XVIII or XIX of the Social Security Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395"},"text":"42 U.S.C. 1395","children":[],"tail":" et seq., "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1396"},"text":"42 U.S.C. 1396","children":[],"tail":" et seq.) shall be construed to preempt any State or common law governing medical professional or medical product liability actions or claims."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc05240ae-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/10/tI/s106/d"},"text":"Pub. L. 114–10, title I, § 106(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-04-16"},"text":"Apr. 16, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/142"},"text":"129 Stat. 142","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc05240af-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc05240b0-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc05240b1-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Patient Protection and Affordable Care Act, referred to in pars. (2)(A) and (3), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148"},"text":"Pub. L. 111–148","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/119"},"text":"124 Stat. 119","children":[],"tail":". For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s18001"},"text":"section 18001 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Health Care and Education Reconciliation Act of 2010, referred to in pars. (2)(A) and (3), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/152"},"text":"Pub. L. 111–152","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-30"},"text":"Mar. 30, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1029"},"text":"124 Stat. 1029","children":[],"tail":". For complete classification of this Act to the Code, see Short Title of 2010 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1305"},"text":"section 1305 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Social Security Act, referred to in pars. (2)(A) and (3), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"act Aug. 14, 1935, ch. 531","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/620"},"text":"49 Stat. 620","children":[],"tail":". Titles XVIII and XIX of the Act are classified generally to subchapters XVIII (§ 1395 et seq.) and XIX (§ 1396 et seq.), respectively, of chapter 7 of this title. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1305"},"text":"section 1305 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idc05240b2-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Medicare Access and CHIP Reauthorization Act of 2015, and not as part of the Patient Protection and Affordable Care Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
