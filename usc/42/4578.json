 year ending "},{"tag":"date","attrib":{"date":"1982-09-30"},"text":"September 30, 1982","children":[],"tail":", at least 25 per centum of the funds shall be obligated for such grants."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbcd6602b-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/616/tIII/s312"},"text":"Pub. L. 91–616, title III, § 312","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/94/371/s4/c/3"},"text":"Pub. L. 94–371, § 4(c)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-07-26"},"text":"July 26, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1036"},"text":"90 Stat. 1036","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/96/180/s12"},"text":"Pub. L. 96–180, § 12","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-01-02"},"text":"Jan. 2, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/1304"},"text":"93 Stat. 1304","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tIX/s964"},"text":"Pub. L. 97–35, title IX, § 964","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/594"},"text":"95 Stat. 594","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbcd6602c-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbcd6602d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbcd6602e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":n