{"tag":"section","attrib":{"id":"idbfb4c879-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13214"},"text":null,"children":[{"tag":"num","attrib":{"value":"13214"},"text":"§ 13214.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal agency promotion, education, and coordination","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfb4c87a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13214/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Promotion and education","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, in cooperation with the Administrator of General Services, shall promote programs and educate officials and employees of Federal agencies on the merits of alternative fueled vehicles. The Secretary, in cooperation with the Administrator of General Services, shall provide and disseminate information to Federal agencies on—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfb4c87b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13214/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the location of refueling and maintenance facilities available to alternative fueled vehicles in the Federal fleet;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfb4c87c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13214/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the range and performance capabilities of alternative fueled vehicles;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfb4c87d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13214/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State and local government and commercial alternative fueled vehicle programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfb4c87e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13214/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal alternative fueled vehicle purchases and placements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfb4c87f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13214/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the operation and maintenance of alternative fueled vehicles in accordance with the manufacturer’s standards and recommendations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfb4c880-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13214/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" incentive programs established pursuant to sections 13215 ","children":[{"tag":"ref","attrib":{"idref":"fn004155"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004155"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" and 13216 of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfb4c881-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13214/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance in procurement and placement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in cooperation with the Administrator of General Services, shall provide guidance, coordination and technical assistance to Federal agencies in the procurement and geographic location of alternative fueled vehicles purchased through the Administrator of General Services. The procurement and geographic location of such vehicles shall comply with the purchase requirements under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s13212"},"text":"section 13212 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfb4c882-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/tIII/s305"},"text":"Pub. L. 102–486, title III, § 305","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2872"},"text":"106 Stat. 2872","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbfb4c883-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbfb4c884-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbfb4c885-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s13215"},"text":"Section 13215 of this title","children":[],"tail":", referred to in subsec. (a)(6), was omitted from the Code since the section ceased to be effective after "},{"tag":"date","attrib":{"date":"1995-10-24"},"text":"Oct. 24, 1995","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
