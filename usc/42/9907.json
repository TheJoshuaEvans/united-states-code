{"tag":"section","attrib":{"id":"idbf06d501-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9907"},"text":null,"children":[{"tag":"num","attrib":{"value":"9907"},"text":"§ 9907.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uses of funds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf06d502-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9907/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants to eligible entities and other organizations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf06d503-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9907/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not less than 90 percent of the funds made available to a State under section 9905 or 9906 of this title shall be used by the State to make grants for the purposes described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s9901"},"text":"section 9901 of this title","children":[],"tail":" to eligible entities."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf06d504-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9907/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Obligational authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds distributed to eligible entities through grants made in accordance with paragraph (1) for a fiscal year shall be available for obligation during that fiscal year and the succeeding fiscal year, subject to paragraph (3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf06d505-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9907/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recapture and redistribution of unobligated funds","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf06d506-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9907/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Beginning on ","children":[{"tag":"date","attrib":{"date":"2000-10-01"},"text":"October 1, 2000","children":[],"tail":", a State may recapture and redistribute funds distributed to an eligible entity through a grant made under paragraph (1) that are unobligated at the end of a fiscal year if such unobligated funds exceed 20 percent of the amount so distributed to such eligible entity for such fiscal year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf06d507-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9907/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Redistribution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In redistributing funds recaptured in accordance with this paragraph, States shall redistribute such funds to an eligible entity, or require the original recipient of the funds to redistribute the funds to a private, nonprofit organization, located within the community served by the original recipient of the funds, for activities consistent with the purposes of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf06d508-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9907/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statewide activities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf06d509-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9907/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of remainder","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a State uses less than 100 percent of the grant or allotment received under section 9905 or 9906 of this title to make grants under subsection (a), the State shall use the remainder of the grant or allotment under section 9905 or 9906 of this title (subject to paragraph (2)) for activities that may include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf06d50a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9907/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing training and technical assistance to those entities in need of such training and assistance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf06d50b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9907/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinating State-operated programs and services, and at the option of the State, locally-operated programs and services, targeted to low-income children and families with services provided by eligible entities and other organizations funded under this chapter, including detailing appropriate employees of State or local agencies to entities funded under this chapter, to ensure increased access to services provided by such State or local agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf06d50c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9907/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supporting statewide coordination and communication among eligible entities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf06d50d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9907/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" analyzing the distribution of funds made available under this chapter within the State to determine if such funds have been targeted to the areas of greatest need;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf06d50e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9907/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supporting asset-building programs for low-income individuals, such as programs supporting individual development accounts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf06d50f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9907/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supporting innovative programs and activities conducted by community action agencies or other neighborhood-based organizations to eliminate poverty, promote self-sufficiency, and promote community revitalization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf06d510-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9907/b/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supporting State charity tax credits as described in subsection (c); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf06d511-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9907/b/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supporting other activities, consistent with the purposes of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf06d512-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9907/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative cap","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No State may spend more than the greater of $55,000, or 5 percent, of the grant received under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s9905"},"text":"section 9905 of this title","children":[],"tail":" or State allotment received under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s9906"},"text":"section 9906 of this title","children":[],"tail":" for administrative expenses, including monitoring activities. Funds to be spent for such expenses shall be taken from the portion of the grant under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s9905"},"text":"section 9905 of this title","children":[],"tail":" or State allotment that remains after the State makes grants to eligible entities under subsection (a). The cost of activities conducted under paragraph (1)(A) shall not be considered to be administrative expenses. The startup cost and cost of administrative activities conducted under subsection (c) shall be considered to be administrative expenses."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf06d513-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9907/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Charity tax credit","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf06d514-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9907/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (2), if there is in effect under State law a charity tax credit, the State may use for any purpose the amount of the allotment that is available for expenditure under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf06d515-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9907/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The aggregate amount a State may use under paragraph (1) during a fiscal year shall not exceed 100 percent of the revenue loss of the State during the fiscal year that is attributable to the charity tax credit, as determined by the Secretary of the Treasury without regard to any such revenue loss occurring before ","children":[{"tag":"date","attrib":{"date":"1999-01-01"},"text":"January 1, 1999","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf06d516-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9907/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions and rules","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf06d517-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9907/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Charity tax credit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “charity tax credit” means a nonrefundable credit against State income tax (or, in the case of a State that does not impose an income tax, a comparable benefit) that is allowable for contributions, in cash or in kind, to qualified charities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf06d518-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9907/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified charity","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbf06d519-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9907/c/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “qualified charity” means any organization—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbf06d51a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9907/c/3/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" that is—","children":[],"tail":null},{"tag":"item","attrib":{"id":"idbf06d51b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9907/c/3/B/i/I/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s501/c/3"},"text":"section 501(c)(3) of title 26","children":[],"tail":" and exempt from tax under section 501(a) of such title;"}],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idbf06d51c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9907/c/3/B/i/I/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an eligible entity; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idbf06d51d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9907/c/3/B/i/I/cc"},"text":null,"children":[{"tag":"num","attrib":{"value":"cc"},"text":"(cc)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a public housing agency as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1437a/b/6"},"text":"section 1437a(b)(6) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbf06d51e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9907/c/3/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is certified by the appropriate State authority as meeting the requirements of clauses (iii) and (iv); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbf06d51f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9907/c/3/B/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if such organization is otherwise required to file a return under section 6033 of such title, that elects to treat the information required to be furnished by clause (v) as being specified in section 6033(b) of such title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf06d520-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9907/c/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain contributions to collection organizations treated as contributions to qualified charity","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbf06d521-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9907/c/3/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A contribution to a collection organization shall be treated as a contribution to a qualified charity if the donor designates in writing that the contribution is for the qualified charity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbf06d522-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9907/c/3/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collection organization","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “collection organization” means an organization described in section 501(c)(3) of such title and exempt from tax under section 501(a) of such title—","children":[],"tail":null},{"tag":"item","attrib":{"id":"idbf06d523-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9907/c/3/B/ii/II/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that solicits and collects gifts and grants that, by agreement, are distributed to qualified charities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idbf06d524-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9907/c/3/B/ii/II/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that distributes to qualified charities at least 90 percent of the gifts and grants the organization receives that are designated for such qualified charities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idbf06d525-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9907/c/3/B/ii/II/cc"},"text":null,"children":[{"tag":"num","attrib":{"value":"cc"},"text":"(cc)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that meets the requirements of clause (vi).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf06d526-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9907/c/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Charity must primarily assist poor individuals","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbf06d527-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9907/c/3/B/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An organization meets the requirements of this clause only if the appropriate State authority reasonably expects that the predominant activity of such organization will be the provision of direct services within the United States to individuals and families whose annual incomes generally do not exceed 185 percent of the poverty line in order to prevent or alleviate poverty among such individuals and families.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbf06d528-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9907/c/3/B/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No recordkeeping in certain cases","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An organization shall not be required to establish or maintain records with respect to the incomes of individuals and families for purposes of subclause (I) if such individuals or families are members of groups that are generally recognized as including substantially only individuals and families described in subclause (I).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbf06d529-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9907/c/3/B/iii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Food aid and homeless shelters","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as otherwise provided by the appropriate State authority, for purposes of subclause (I), services to individuals in the form of—","children":[],"tail":null},{"tag":"item","attrib":{"id":"idbf06d52a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9907/c/3/B/iii/III/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" donations of food or meals; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idbf06d52b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9907/c/3/B/iii/III/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" temporary shelter to homeless individuals;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"  shall be treated as provided to individuals described in subclause (I) if the location and provision of such services are such that the service provider may reasonably conclude that the beneficiaries of such services are predominantly individuals described in subclause (I).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf06d52c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9907/c/3/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum expense requirement","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbf06d52d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9907/c/3/B/iv/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An organization meets the requirements of this clause only if the appropriate State authority reasonably expects that the annual poverty program expenses of such organization will not be less than 75 percent of the annual aggregate expenses of such organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbf06d52e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9907/c/3/B/iv/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Poverty program expense","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subclause (I)—","children":[],"tail":null},{"tag":"item","attrib":{"id":"idbf06d52f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9907/c/3/B/iv/II/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “poverty program expense” means any expense in providing direct services referred to in clause (iii).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idbf06d530-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9907/c/3/B/iv/II/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Such term shall not include any management or general expense, any expense for the purpose of influencing legislation (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s4911/d"},"text":"section 4911(d) of title 26","children":[],"tail":"), any expense for the purpose of fundraising, any expense for a legal service provided on behalf of any individual referred to in clause (iii), any expense for providing tuition assistance relating to compulsory school attendance, and any expense that consists of a payment to an affiliate of the organization."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf06d531-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9907/c/3/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting requirement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The information required to be furnished under this clause about an organization is—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbf06d532-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9907/c/3/B/v/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the percentages determined by dividing the following categories of the organization’s expenses for the year by the total expenses of the organization for the year: expenses for direct services, management expenses, general expenses, fundraising expenses, and payments to affiliates; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbf06d533-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9907/c/3/B/v/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the category or categories (including food, shelter, education, substance abuse prevention or treatment, job training, or other) of services that constitute predominant activities of the organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf06d534-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9907/c/3/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional requirements for collection organizations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The requirements of this clause are met if the organization—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbf06d535-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9907/c/3/B/vi/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintains separate accounting for revenues and expenses; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbf06d536-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9907/c/3/B/vi/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" makes available to the public information on the administrative and fundraising costs of the organization, and information as to the organizations receiving funds from the organization and the amount of such funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf06d537-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9907/c/3/B/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule for States requiring tax uniformity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a State—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbf06d538-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9907/c/3/B/vii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that has a constitutional requirement of tax uniformity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbf06d539-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9907/c/3/B/vii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" that, as of ","children":[{"tag":"date","attrib":{"date":"1997-12-31"},"text":"December 31, 1997","children":[],"tail":", imposed a tax on personal income with—"}],"tail":null},{"tag":"item","attrib":{"id":"idbf06d53a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9907/c/3/B/vii/II/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a single flat rate applicable to all earned and unearned income (except insofar as any amount is not taxed pursuant to tax forgiveness provisions); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idbf06d53b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9907/c/3/B/vii/II/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no generally available exemptions or deductions to individuals;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":" the requirement of paragraph (2) shall be treated as met if the amount of the credit described in paragraph (2) is limited to a uniform percentage (but not greater than 25 percent) of State personal income tax liability (determined without regard to credits).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf06d53c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9907/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on use of funds for startup and administrative activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except to the extent provided in subsection (b)(2), no part of the aggregate amount a State uses under paragraph (1) may be used to pay for the cost of the startup and administrative activities conducted under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf06d53d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9907/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on use of funds for legal services or tuition assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No part of the aggregate amount a State uses under paragraph (1) may be used to provide legal services or to provide tuition assistance related to compulsory education requirements (not including tuition assistance for tutoring, camps, skills development, or other supplemental services or training).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf06d53e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9907/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on supplanting funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No part of the aggregate amount a State uses under paragraph (1) may be used to supplant non-Federal funds that would be available, in the absence of Federal funds, to offset a revenue loss of the State attributable to a charity tax credit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf06d53f-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35/tVI/s675C"},"text":"Pub. L. 97–35, title VI, § 675C","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/285/tII/s201"},"text":"Pub. L. 105–285, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-27"},"text":"Oct. 27, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2731"},"text":"112 Stat. 2731","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf06d540-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf06d541-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbf06d542-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 9907, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35/tVI/s678"},"text":"Pub. L. 97–35, title VI, § 678","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/516"},"text":"95 Stat. 516","children":[],"tail":", related to payments to States, prior to the general amendment of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/105/285"},"text":"Pub. L. 105–285","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
