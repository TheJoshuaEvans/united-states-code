{"tag":"section","attrib":{"id":"idb6884d61-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300dd–32"},"text":null,"children":[{"tag":"num","attrib":{"value":"300dd–32"},"text":"§ 300dd–32.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement of provision of certain counseling services","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb6884d62-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300dd–32/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Counseling before testing","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may not make a grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300dd–31"},"text":"section 300dd–31 of this title","children":[],"tail":" to a State unless the State agrees that, before testing an individual pursuant to such section, the State will provide to the individual appropriate counseling with respect to acquired immune deficiency syndrome (based on the most recent scientific data relating to such syndrome), including—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6884d63-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300dd–32/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" measures for the prevention of exposure to, and the transmission of, the etiologic agent for such syndrome;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6884d64-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300dd–32/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the accuracy and reliability of the results of such testing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6884d65-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300dd–32/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the significance of the results of such testing, including the potential for developing acquired immune deficiency syndrome; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6884d66-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300dd–32/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encouraging individuals, as appropriate, to undergo testing for such etiologic agent and providing information on the benefits of such testing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6884d67-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300dd–32/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Counseling of individuals with negative test results","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may not make a grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300dd–31"},"text":"section 300dd–31 of this title","children":[],"tail":" to a State unless the State agrees that, if the results of testing conducted pursuant to such section indicate that an individual is not infected with the etiologic agent for acquired immune deficiency syndrome, the State will review for the individual the information provided pursuant to subsection (a) with respect to such syndrome, including—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6884d68-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300dd–32/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the information described in paragraphs (1) through (3) of such subsection; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6884d69-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300dd–32/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the appropriateness of further counseling, testing, and education of the individual with respect to acquired immune deficiency syndrome.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6884d6a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300dd–32/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Counseling of individuals with positive test results","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may not make a grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300dd–31"},"text":"section 300dd–31 of this title","children":[],"tail":" to a State unless the State agrees that, if the results of testing conducted pursuant to such section indicate that an individual is infected with the etiologic agent for acquired immune deficiency syndrome, the State will provide to the individual appropriate counseling with respect to such syndrome, including—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6884d6b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300dd–32/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reviewing the information described in paragraphs (1) through (3) of subsection (a);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6884d6c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300dd–32/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reviewing the appropriateness of further counseling, testing, and education of the individual with respect to acquired immune deficiency syndrome;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6884d6d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300dd–32/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the importance of not exposing others to the etiologic agent for acquired immune deficiency syndrome;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6884d6e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300dd–32/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the availability in the geographic area of any appropriate services with respect to health care, including mental health care and social and support services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6884d6f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300dd–32/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the benefits of locating and counseling any individual by whom the infected individual may have been exposed to the etiologic agent for acquired immune deficiency syndrome and any individual whom the infected individual may have exposed to such etiologic agent; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6884d70-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300dd–32/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the availability, if any, of the services of public health authorities with respect to locating and counseling any individual described in paragraph (5).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6884d71-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300dd–32/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction with respect to counseling without testing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Agreements entered into pursuant to subsections (a) through (c) may not be construed to prohibit any grantee under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300dd–31"},"text":"section 300dd–31 of this title","children":[],"tail":" from expending the grant for the purpose of providing counseling services described in such subsections to an individual who will not undergo testing described in such section as a result of the grantee or the individual determining that such testing of the individual is not appropriate."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6884d72-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300dd–32/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6884d73-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300dd–32/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The purpose of this subpart ","children":[{"tag":"ref","attrib":{"idref":"fn002415"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002415"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “part”."}],"tail":" is to provide for counseling and testing services to prevent and reduce exposure to, and transmission of, the etiologic agent for acquired immune deficiency syndrome."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6884d74-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300dd–32/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" All individuals receiving counseling pursuant to this subpart ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" are to be counseled about the harmful effects of promiscuous sexual activity and intravenous substance abuse, and the benefits of abstaining from such activities."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6884d75-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300dd–32/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" None of the fund appropriated to carry out this subpart ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" may be used to provide counseling that is designed to promote or encourage, directly, homosexual or heterosexual sexual activity or intravenous drug abuse."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6884d76-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300dd–32/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Paragraph (3) may not be construed to prohibit a counselor who has already performed the counseling of an individual required by paragraph (2), to provide accurate information about means to reduce an individual’s risk of exposure to, or the transmission of, the etiologic agent for acquired immune deficiency syndrome, provided that any informational materials used are not obscene.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb6884d77-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XXIV, § 2432, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/607/tII/s211"},"text":"Pub. L. 100–607, title II, § 211","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-04"},"text":"Nov. 4, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3090"},"text":"102 Stat. 3090","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tII/s2618/i"},"text":"Pub. L. 100–690, title II, § 2618(i)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4242"},"text":"102 Stat. 4242","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/321/tI/s118/b/1/B"},"text":"Pub. L. 102–321, title I, § 118(b)(1)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-10"},"text":"July 10, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/348"},"text":"106 Stat. 348","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb6884d78-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb6884d79-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb6884d7a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/321"},"text":"Pub. L. 102–321","children":[],"tail":", which directed the substitution of “part” for “subpart” wherever appearing in subsec. (a), could not be executed because the word “subpart” does not appear in subsec. (a)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690/s2618/i/1"},"text":"Pub. L. 100–690, § 2618(i)(1)","children":[],"tail":", substituted “indicate that an individual” for “indicate that the individual” in introductory provisions and “paragraph (5)” for “paragraph (4)” in par. (6)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1) to (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690/s2618/i/2"},"text":"Pub. L. 100–690, § 2618(i)(2)","children":[],"tail":", substituted “subpart” for “part”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb6884d7b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb6884d7c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1992 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/321"},"text":"Pub. L. 102–321","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1992-10-01"},"text":"Oct. 1, 1992","children":[],"tail":", with provision for programs providing financial assistance, see section 801(c), (d) of "},{"tag":"ref","attrib":{"href":"/us/pl/102/321"},"text":"Pub. L. 102–321","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s236"},"text":"section 236 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb6884d7d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690"},"text":"Pub. L. 100–690","children":[],"tail":" effective immediately after enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/100/607"},"text":"Pub. L. 100–607","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"1988-11-04"},"text":"Nov. 4, 1988","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/s2600"},"text":"section 2600 of Pub. L. 100–690","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s242m"},"text":"section 242m of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
