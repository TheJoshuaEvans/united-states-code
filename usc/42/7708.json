{"tag":"section","attrib":{"id":"idbe72f9ae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7708"},"text":null,"children":[{"tag":"num","attrib":{"value":"7708"},"text":"§ 7708.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Network for Earthquake Engineering Simulation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbe72f9af-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7708/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the National Science Foundation shall establish the George E. Brown, Jr. Network for Earthquake Engineering Simulation that will upgrade, link, and integrate a system of geographically distributed experimental facilities for earthquake engineering testing of full-sized structures and their components and partial-scale physical models. The system shall be integrated through networking software so that integrated models and databases can be used to create model-based simulation, and the components of the system shall be interconnected with a computer network and allow for remote access, information sharing, and collaborative research.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe72f9b0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7708/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In addition to amounts appropriated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7706/c"},"text":"section 7706(c) of this title","children":[],"tail":", there are authorized to be appropriated to the National Science Foundation for the George E. Brown, Jr. Network for Earthquake Engineering Simulation—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe72f9b1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7708/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $28,200,000 for fiscal year 2001;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe72f9b2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7708/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $24,400,000 for fiscal year 2002;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe72f9b3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7708/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $4,500,000 for fiscal year 2003;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe72f9b4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7708/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $17,000,000 for fiscal year 2004;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe72f9b5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7708/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $20,000,000 for fiscal year 2005, all of which shall be available for operations and maintenance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe72f9b6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7708/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $20,400,000 for fiscal year 2006, all of which shall be available for operations and maintenance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe72f9b7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7708/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $20,870,000 for fiscal year 2007, all of which shall be available for operations and maintenance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe72f9b8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7708/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $21,390,000 for fiscal year 2008, all of which shall be available for operations and maintenance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe72f9b9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7708/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $21,930,000 for fiscal year 2009, all of which shall be available for operations and maintenance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbe72f9ba-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/124/s14"},"text":"Pub. L. 95–124, § 14","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/503/tII/s205"},"text":"Pub. L. 106–503, title II, § 205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-13"},"text":"Nov. 13, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2306"},"text":"114 Stat. 2306","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/360/tI/s104/c"},"text":"Pub