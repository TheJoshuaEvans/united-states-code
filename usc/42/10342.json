{"tag":"section","attrib":{"id":"idbf2113be-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10342"},"text":null,"children":[{"tag":"num","attrib":{"value":"10342"},"text":"§ 10342.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research program","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Director of the National Science Foundation shall establish a basic research program on membranes and membrane processes. Such program may be carried out through awarding grants, entering into contracts or cooperative agreements, or direct research.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbf2113bf-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/490/s3"},"text":"Pub. L. 102–490, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3142"},"text":"106 Stat. 3142","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
