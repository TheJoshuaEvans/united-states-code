{"tag":"section","attrib":{"id":"idbe0c702f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385e"},"text":null,"children":[{"tag":"num","attrib":{"value":"7385e"},"text":"§ 7385e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification of treatment of payments under other laws","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Compensation or benefits provided to an individual under this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe0c7030-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be treated for purposes of the internal revenue laws of the United States as damages for human suffering; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe0c7031-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not be included as income or resources for purposes of determining eligibility to receive benefits described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3803/c/2/C"},"text":"section 3803(c)(2)(C) of title 31","children":[],"tail":" or the amount of such benefits."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbe0c7032-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dC/tXXXVI/s3646"},"text":"Pub. L. 106–398, § 1 [div. C, title XXXVI, § 3646]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–510; "},{"tag":"ref","attrib":{"href":"/us/pl/108/375/dC/tXXXI/s3162/e"},"text":"Pub. L. 108–375, div. C, title XXXI, § 3162(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-28"},"text":"Oct. 28, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2186"},"text":"118 Stat. 2186","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbe0c7033-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbe0c7034-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbe0c7035-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375"},"text":"Pub. L. 108–375","children":[],"tail":" substituted “this subchapter” for “part B”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
