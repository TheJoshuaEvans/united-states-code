{"tag":"section","attrib":{"id":"idba0d7c04-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"1395iii"},"text":"§ 1395iii.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Medicare Improvement Fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idba0d7c05-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395iii/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish under this subchapter a Medicare Improvement Fund (in this section referred to as the “Fund”) which shall be available to the Secretary to make improvements under the original Medicare fee-for-service program under parts A and B for individuals entitled to, or enrolled for, benefits under part ","children":[{"tag":"ref","attrib":{"idref":"fn002974"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002974"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original."}],"tail":" or enrolled under part B including adjustments to payments for items and services furnished by providers of services and suppliers under such original Medicare fee-for-service program."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idba0d7c06-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395iii/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idba0d7c07-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395iii/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There shall be available to the Fund, for expenditures from the Fund for services furnished during and after fiscal year 2027, $2,062,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idba0d7c08-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395iii/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment from Trust Funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount specified under paragraph (1) shall be available to the Fund, as expenditures are made from the Fund, from the Federal Hospital Insurance Trust Fund and the Federal Supplementary Medical Insurance Trust Fund in such proportion as the Secretary determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idba0d7c09-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395iii/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts in the Fund shall be available in advance of appropriations but only if the total amount obligated from the Fund does not exceed the amount available to the Fund under paragraph (1). The Secretary may obligate funds from the Fund only if the Secretary determines (and the Chief Actuary of the Centers for Medicare & Medicaid Services and the appropriate budget officer certify) that there are available in the Fund sufficient amounts to cover all such obligations incurred consistent with the previous sentence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idba0fc5fa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395iii/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No effect on payments in subsequent years","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case that expenditures from the Fund are applied to, or otherwise affect, a payment rate for an item or service under this subchapter for a year, the payment rate for such item or service shall be computed for a subsequent year as if such application or effect had never occurred.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idba0fc5fb-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title XVIII, § 1898, as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/252/tVII/s7002/a"},"text":"Pub. L. 110–252, title VII, § 7002(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-06-30"},"text":"June 30, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2394"},"text":"122 Stat. 2394","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/275/tI/s188/a/2/B"},"text":"Pub. L. 110–275, title I, § 188(a)(2)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-07-15"},"text":"July 15, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2589"},"text":"122 Stat. 2589","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/379/s6"},"text":"Pub. L. 110–379, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-08"},"text":"Oct. 8, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/12