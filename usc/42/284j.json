{"tag":"section","attrib":{"id":"idb562dfb6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284j"},"text":null,"children":[{"tag":"num","attrib":{"value":"284j"},"text":"§ 284j.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Muscular dystrophy research","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb562dfb7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284j/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination of activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of NIH shall expand and increase coordination in the activities of the National Institutes of Health with respect to research on muscular dystrophies, including Duchenne muscular dystrophy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb562dfb8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284j/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration of program; collaboration among agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of NIH shall carry out this section through the appropriate institutes, including the National Institute of Neurological Disorders and Stroke and in collaboration with any other agencies that the Director determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb562dfb9-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title IV, § 409F, as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/310/dA/tXXII/s2201"},"text":"Pub. L. 106–310, div. A, title XXII, § 2201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-17"},"text":"Oct. 17, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1157"},"text":"114 Stat. 1157","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/482/tI/s103/b/12"},"text":"Pub. L. 109–482, title I, § 103(b)(12)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-01-15"},"text":"Jan. 15, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3687"},"text":"120 Stat. 3687","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb562dfba-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb562dfbb-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb562dfbc-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2007—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/482"},"text":"Pub. L. 109–482","children":[],"tail":" struck out heading and text of subsec. (c). Text read as follows: “There are authorized to be appropriated such sums as may be necessary to carry out this section for each of the fiscal years 2001 through 2005. Amounts appropriated under this subsection shall be in addition to any other amounts appropriated for such purpose.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb562dfbd-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries",