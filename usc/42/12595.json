{"tag":"section","attrib":{"id":"idbf7e006f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12595"},"text":null,"children":[{"tag":"num","attrib":{"value":"12595"},"text":"§ 12595.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National service educational awards","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf7e0070-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12595/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility generally","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A participant in a national service program carried out using assistance provided to an applicant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12571"},"text":"section 12571 of this title","children":[],"tail":" shall be eligible for the national service educational award described in division D if the participant—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf7e0071-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12595/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serves in an approved national service position; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf7e0072-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12595/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" satisfies the eligibility requirements specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12602"},"text":"section 12602 of this title","children":[],"tail":" with respect to service in that approved national service position."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf7e0073-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12595/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule for VISTA volunteers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A VISTA volunteer who serves in an approved national service position shall be ineligible for a national service educational award if the VISTA volunteer accepts the stipend authorized under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4955/a/1"},"text":"section 4955(a)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf7e0074-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/610/tI/s141"},"text":"Pub. L. 101–610, title I, § 141","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/tI/s101/b"},"text":"Pub. L. 103–82, title I, § 101(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-09-21"},"text":"Sept. 21, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/814"},"text":"107 Stat. 814","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf7e0075-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf7e0076-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbf7e0077-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/610/s141"},"text":"section 141 of Pub. L. 101–610","chi