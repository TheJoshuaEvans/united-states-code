{"tag":"section","attrib":{"id":"idbb8d65e8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862n–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"1862n–2"},"text":"§ 1862n–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of centers for research on mathematics and science learning and education improvement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbb8d65e9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862n–2/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb8d65ea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862n–2/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbb8d65eb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862n–2/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director shall award grants to institutions of higher education or eligible nonprofit organizations (or consortia thereof) to establish multidisciplinary Centers for Research on Learning and Education Improvement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb8d65ec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862n–2/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Grants shall be awarded under this paragraph on a competitive, merit-reviewed basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb8d65ed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862n–2/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The purpose of the Centers shall be to conduct and evaluate research in cognitive science, education, and related fields and to develop ways in which the results of such research can be applied in elementary school and secondary school classrooms to improve the teaching of mathematics and science.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb8d65ee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862n–2/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Focus","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbb8d65ef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862n–2/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each Center shall be focused on a different challenge faced by elementary school or secondary school teachers of mathematics and science. In determining the research focus of the Centers, the Director shall consult with the National Academy of Sciences and the Secretary of Education and take into account the extent to which other Federal programs support research on similar questions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb8d65f0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862n–2/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The proposal solicitation issued by the Director shall state the focus of each Center and applicants shall apply for designation as a specific Center.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb8d65f1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862n–2/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" At least one Center shall focus on developing ways in which the results of research described in paragraph (2) can be applied, duplicated, and scaled up for use in low-performing elementary schools and secondary schools to improve the teaching and student achievement levels in mathematics and science.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb8d65f2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862n–2/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To the extent practicable and relevant to its focus, every Center shall include, as part of its research, work designed to quantitatively assess and improve the ways that information technology is used in the teaching of mathematics and science.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb8d65f3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862n–2/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection process","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb8d65f4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862n–2/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An institution of higher education or an eligible nonprofit organization (or a consortium thereof) seeking funding under this section shall submit an application to the Director at such time, in such manner, and containing such information as the Director may require. The application shall include, at a minimum, a description of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbb8d65f5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862n–2/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the initial research projects that will be undertaken by the Center and the process by which new projects will be identified;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb8d65f6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862n–2/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how the Center will work with other research institutions and schools to broaden the national research agenda on learning and teaching;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb8d65f7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862n–2/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how the Center will promote active collaboration among physical, biological, and social science researchers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb8d65f8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862n–2/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how the Center will promote active participation by elementary and secondary mathematics and science teachers and administrators; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb8d65f9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862n–2/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how the results of the Center’s research can be incorporated into educational practices, and how the Center will assess the success of those practices.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb8d65fa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862n–2/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review of applications","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In evaluating the applications submitted under paragraph (1), the Director shall consider, at a minimum—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbb8d65fb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862n–2/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the ability of the applicant to effectively carry out the research program, including the activities described in paragraph (1)(E);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb8d65fc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862n–2/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the experience of the applicant in conducting research on the science of teaching and learning and the capacity of the applicant to foster new multidisciplinary collaborations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb8d65fd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862n–2/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the capacity of the applicant to attract elementary school and secondary school teachers from a diverse array of schools, and with diverse professional experiences, for participation in Center activities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb8d65fe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862n–2/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the capacity of the applicant to attract and provide adequate support for graduate students to pursue research at the intersection of educational practice and basic research on human cognition and learning.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb8d65ff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862n–2/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Awards","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall ensure, to the extent practicable, that the Centers funded under this section conduct research and develop educational practices designed to improve the educational performance of a broad range of students, including individuals identified in section 1885a or 1885b of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb8d6600-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862n–2/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual conference","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall convene an annual meeting of the Centers to foster collaboration among the Centers and to further disseminate the results of the Centers’ activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb8d6601-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862n–2/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director shall coordinate with the Secretary of Education in—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb8d6602-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862n–2/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disseminating the results of the research conducted pursuant to grants awarded under this section to elementary school teachers and secondary school teachers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb8d6603-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862n–2/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" providing programming, guidance, and support to ensure that such teachers—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbb8d6604-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862n–2/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" understand the implications of the research disseminated under paragraph (1) for classroom practice; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb8d6605-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862n–2/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" can use the research to improve such teachers’ performance in the classroom.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbb8d6606-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/368/s11"},"text":"Pub. L. 107–368, § 11","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-19"},"text":"Dec. 19, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/3053"},"text":"116 Stat. 3053","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/69/tVII/s7006/b"},"text":"Pub. L. 110–69, title VII, § 7006(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-08-09"},"text":"Aug. 9, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/679"},"text":"121 Stat. 679","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbb8d6607-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbb8d6608-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbb8d6609-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the National Science Foundation Authorization Act of 2002, and not as part of the National Science Foundation Act of 1950 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbb8d660a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2007—Subsec. (a)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/69/s7006/b/1"},"text":"Pub. L. 110–69, § 7006(b)(1)","children":[],"tail":", inserted “or eligible nonprofit organizations” after “institutions of higher education”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/69/s7006/b/2"},"text":"Pub. L. 110–69, § 7006(b)(2)","children":[],"tail":", (3), in introductory provisions, inserted “or an eligible nonprofit organization” after “institution of higher education” and substituted “thereof” for “of such institutions”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbb8d660b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbb8d660c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Funding for Centers","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/69/tVII/s7006/a"},"text":"Pub. L. 110–69, title VII, § 7006(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-08-09"},"text":"Aug. 9, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/679"},"text":"121 Stat. 679","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/69/tVII/s7006/a"},"text":"“The Director [of the National Science Foundation] shall continue to carry out the program of Centers for Research on Learning and Education Improvement as established in section 11 of the National Science Foundation Authorization Act of 2002 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1862n–2"},"text":"42 U.S.C. 1862n–2","children":[],"tail":").”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idbb8d660d-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definitions of terms used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/368/s4"},"text":"section 4 of Pub. L. 107–368","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1862n"},"text":"section 1862n of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
