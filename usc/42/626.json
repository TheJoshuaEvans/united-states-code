{"tag":"section","attrib":{"id":"idb79ca3e7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s626"},"text":null,"children":[{"tag":"num","attrib":{"value":"626"},"text":"§ 626.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research, training, or demonstration projects","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb79ca3e8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s626/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are hereby authorized to be appropriated for each fiscal year such sums as the Congress may determine—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb79ca3e9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s626/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for grants by the Secretary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb79ca3ea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s626/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to public or other nonprofit institutions of higher learning, and to public or other nonprofit agencies and organizations engaged in research or child-welfare activities, for special research or demonstration projects in the field of child welfare which are of regional or national significance and for special projects for the demonstration of new methods or facilities which show promise of substantial contribution to the advancement of child welfare;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb79ca3eb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s626/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to State or local public agencies responsible for administering, or supervising the administration of, the plan under this part, for projects for the demonstration of the utilization of research (including findings resulting therefrom) in the field of child welfare in order to encourage experimental and special types of welfare services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb79ca3ec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s626/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to public or other nonprofit institutions of higher learning for special projects for training personnel for work in the field of child welfare, including traineeships described in section 628a ","children":[{"tag":"ref","attrib":{"idref":"fn002616"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002616"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title with such stipends and allowances as may be permitted by the Secretary; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb79ca3ed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s626/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for contracts or jointly financed cooperative arrangements with States and public and other organizations and agencies for the conduct of research, special projects, or demonstration projects relating to such matters.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb79ca3ee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s626/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments; advances or reimbursements; installments; conditions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Payments of grants or under contracts or cooperative arrangements under this section may be made in advance or by way of reimbursement, and in such installments, as the Secretary may determine; and shall be made on such conditions as the Secretary finds necessary to carry out the purposes of the grants, contracts, or other arrangements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb79ca3ef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s626/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Child welfare traineeships","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may approve an application for a grant to a public or nonprofit institution for higher learning to provide traineeships with stipends under subsection (a)(1)(C) only if the application—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb79ca3f0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s626/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provides assurances that each individual who receives a stipend with such traineeship (in this section referred to as a “recipient”) will enter into an agreement with the institution under which the recipient agrees—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb79ca3f1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s626/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to participate in training at a public or private nonprofit child welfare agency on a regular basis (as determined by the Secretary) for the period of the traineeship;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb79ca3f2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s626/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to be employed for a period of years equivalent to the period of the traineeship, in a public or private nonprofit child welfare agency in any State, within a period of time (determined by the Secretary in accordance with regulations) after completing the postsecondary education for which the traineeship was awarded;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb79ca3f3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s626/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to furnish to the institution and the Secretary evidence of compliance with subparagraphs (A) and (B); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb79ca3f4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s626/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the recipient fails to comply with subparagraph (A) or (B) and does not qualify for any exception to this subparagraph which the Secretary may prescribe in regulations, to repay to the Secretary all (or an appropriately prorated part) of the amount of the stipend, plus interest, and, if applicable, reasonable collection fees (in accordance with regulations promulgated by the Secretary);","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb79ca3f5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s626/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provides assurances that the institution will—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb79ca3f6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s626/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enter into agreements with child welfare agencies for onsite training of recipients;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb79ca3f7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s626/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" permit an individual who is employed in the field of child welfare services to apply for a traineeship with a stipend if the traineeship furthers the progress of the individual toward the completion of degree requirements; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb79ca3f8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s626/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop and implement a system that, for the 3-year period that begins on the date any recipient completes a child welfare services program of study, tracks the employment record of the recipient, for the purpose of determining the percentage of recipients who secure employment in the field of child welfare services and remain employed in the field.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb79ca3f9-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title IV, § 426, as added "},{"tag":"ref","attrib":{"href":"/us/pl/90/248/tII/s240/c"},"text":"Pub. L. 90–248, title II, § 240(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-01-02"},"text":"Jan. 2, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/915"},"text":"81 Stat. 915","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/203/tIX/s9137"},"text":"Pub. L. 100–203, title IX, § 9137","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1330-319"},"text":"101 Stat. 1330–319","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/432/tII/s205/b"},"text":"Pub. L. 103–432, title II, § 205(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-31"},"text":"Oct. 31, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4457"},"text":"108 Stat. 4457","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/288"},"text":"Pub. L. 109–288","children":[],"tail":", §§ 6(f)(2), 11(b), "},{"tag":"date","attrib":{"date":"2006-09-28"},"text":"Sept. 28, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1247"},"text":"120 Stat. 1247","children":[],"tail":", 1255.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb79ca3fa-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb79ca3fb-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb79ca3fc-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s628a"},"text":"Section 628a of this title","children":[],"tail":", referred to in subsec. (a)(1)(C), was transferred and redesignated as subsec. (c) of this section by "},{"tag":"ref","attrib":{"href":"/us/pl/109/288/s6/f/2"},"text":"Pub. L. 109–288, § 6(f)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-09-28"},"text":"Sept. 28, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1247"},"text":"120 Stat. 1247","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb79ca3fd-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s628a"},"text":"Section 628a of this title","children":[],"tail":", which was transferred and redesignated as subsec. (c) of this section by "},{"tag":"ref","attrib":{"href":"/us/pl/109/288"},"text":"Pub. L. 109–288","children":[],"tail":", was based on "},{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531/tIV/s429"},"text":"act Aug. 14, 1935, ch. 531, title IV, § 429","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/432/tII/s205/a"},"text":"Pub. L. 103–432, title II, § 205(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-31"},"text":"Oct. 31, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4456"},"text":"108 Stat. 4456","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb79ca3fe-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/288/s11/b"},"text":"Pub. L. 109–288, § 11(b)","children":[],"tail":", redesignated subsec. (c) as (b) and struck out former subsec. (b) which related to appropriations for demonstration projects for development of alternate care arrangements for infants not requiring hospitalization."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/288/s6/f/2"},"text":"Pub. L. 109–288, § 6(f)(2)","children":[],"tail":", amended section as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/109/288/s11/b"},"text":"Pub. L. 109–288, § 11(b)","children":[],"tail":", by transferring "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s628a"},"text":"section 628a of this title","children":[],"tail":" and redesignating it as subsec. (c) of this section. See Codification note above."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/288/s11/b"},"text":"Pub. L. 109–288, § 11(b)","children":[],"tail":", redesignated subsec. (c) as (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (a)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/432"},"text":"Pub. L. 103–432","children":[],"tail":" inserted “described in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s628a"},"text":"section 628a of this title","children":[],"tail":"” after “including traineeships”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/203"},"text":"Pub. L. 100–203","children":[],"tail":" added subsec. (b) and redesignated former subsec. (b) as (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb79ca3ff-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb79ca400-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2006 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/288"},"text":"Pub. L. 109–288","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2006-10-01"},"text":"Oct. 1, 2006","children":[],"tail":", and applicable to payments under this part and part E of this subchapter for calendar quarters beginning on or after such date, without regard to whether implementing regulations have been promulgated, and with delay permitted if State legislation is required to meet additional requirements, see section 12(a), (b) of "},{"tag":"ref","attrib":{"href":"/us/pl/109/288"},"text":"Pub. L. 109–288","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s621"},"text":"section 621 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb79ca401-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/432/tII/s205/c"},"text":"Pub. L. 103–432, title II, § 205(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-31"},"text":"Oct. 31, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4457"},"text":"108 Stat. 4457","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/432/tII/s205/c"},"text":"“The amendments made by this section [enacting ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s628a"},"text":"section 628a of this title","children":[],"tail":" and amending this section] shall apply to grants awarded on or after "},{"tag":"date","attrib":{"date":"1995-10-01"},"text":"October 1, 1995","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb79ca402-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Appropriations or Grants","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/90/248/tII/s240/g"},"text":"Pub. L. 90–248, title II, § 240(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-01-02"},"text":"Jan. 2, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/916"},"text":"81 Stat. 916","children":[],"tail":", provided that any appropriations or grants made pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s726"},"text":"section 726 of this title","children":[],"tail":", as in effect prior to "},{"tag":"date","attrib":{"date":"1968-01-02"},"text":"Jan. 2, 1968","children":[],"tail":", were to be deemed to have been appropriated or made under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
