{"tag":"section","attrib":{"id":"idb5cbdb24-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s291k"},"text":null,"children":[{"tag":"num","attrib":{"value":"291k"},"text":"§ 291k.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal Hospital Council","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5cbdb25-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s291k/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership; qualifications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In administering this subchapter, the Surgeon General shall consult with a Federal Hospital Council consisting of the Surgeon General, who shall serve as Chairman ex officio, and twelve members appointed by the Secretary of Health and Human Services. Six of the twelve appointed members shall be persons who are outstanding in fields pertaining to medical facility and health activities, and three of these six shall be authorities in matters relating to the operation of hospitals or other medical facilities, one of them shall be an authority in matters relating to individuals with intellectual disabilities, and one of them shall be an authority in matters relating to mental health, and the other six members shall be appointed to represent the consumers of the services provided by such facilities and shall be persons familiar with the need for such services in urban or rural areas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5ce4c26-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s291k/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term of membership","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each appointed member shall hold office for a term of four years, except that any member appointed to fill a vacancy occurring prior to the expiration of the term for which his predecessor was appointed shall be appointed for the remainder of such term. An appointed member shall not be eligible to serve continuously for more than two terms (whether beginning before or after ","children":[{"tag":"date","attrib":{"date":"1964-08-18"},"text":"August 18, 1964","children":[],"tail":") but shall be eligible for reappointment if he has not served immediately preceding his reappointment."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5ce4c27-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s291k/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings; annual or by call of Surgeon General","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Council shall meet as frequently as the Surgeon General deems necessary, but not less than once each year. Upon request by three or more members, it shall be the duty of the Surgeon General to call a meeting of the Council.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5ce4c28-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s291k/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisory or technical committees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Council is authorized to appoint such special advisory or technical committees as may be useful in carrying out its functions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5ce4c29-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title VI, § 641, formerly § 621, as added "},{"tag":"ref","attrib":{"href":"/us/pl/88/443/s3/a"},"text":"Pub. L. 88–443, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-08-18"},"text":"Aug. 18, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/458"},"text":"78 Stat. 458","children":[],"tail":", renumbered § 641, "},{"tag":"ref","attrib":{"href":"/us/pl/91/296/tII/s201"},"text":"Pub. L. 91–296, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-06-30"},"text":"June 30, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/344"},"text":"84 Stat. 344","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/91/515/tVI/s601/b/2"},"text":"Pub. L. 91–515, title VI, § 601(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-10-30"},"text":"Oct. 30, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1311"},"text":"84 Stat. 1311","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/88/tV/s509/b"},"text":"Pub. L. 96–88, title V, § 509(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-10-17"},"text":"Oct. 17, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/695"},"text":"93 Stat. 695","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/256/s2/f/4"},"text":"Pub. L. 111–256, § 2(f)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-05"},"text":"Oct. 5, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2644"},"text":"124 Stat. 2644","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb5ce4c2a-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"