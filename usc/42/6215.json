{"tag":"section","attrib":{"id":"idbd716821-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6215"},"text":null,"children":[{"tag":"num","attrib":{"value":"6215"},"text":"§ 6215.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Major fuel burning stationary source","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd716822-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6215/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restrictions on issuance of orders or rules by Governor pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7425"},"text":"section 7425 of this title","children":[],"tail":null}],"tail":null},{"tag":"chapeau","attrib":{},"text":"No Governor of a State may issue any order or rule pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7425"},"text":"section 7425 of this title","children":[],"tail":" to any major fuel burning stationary source (or class or category thereof)—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd716823-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6215/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prohibiting such source from using fuels other than locally or regionally available coal or coal derivatives, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd716824-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6215/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requiring such source to enter into a contract (or contracts) for supplies of locally or regionally available coal or coal derivatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd716825-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6215/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Petition to President","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd716826-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6215/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Governor of any State may petition the President to exercise the President’s authorities pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7425"},"text":"section 7425 of this title","children":[],"tail":" with respect to any major fuel burning stationary source located in such State."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd716827-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6215/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Any petition under paragraph (1) shall include documentation which could support a finding that significant local or regional economic disruption or unemployment would result from use by such source of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd716828-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6215/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coal or coal derivatives other than locally or regionally available coal,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd716829-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6215/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" petroleum products,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd71682a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6215/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" natural gas, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd71682b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6215/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any combination of fuels referred to in subparagraphs (A) through (C), to comply with the requirements of a State implementation plan pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7410"},"text":"section 7410 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd71682c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6215/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Action to be taken by President","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Within 90 days after the submission of a Governor’s petition under subsection (b), the President shall either issue an order or rule pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7425"},"text":"section 7425 of this title","children":[],"tail":" or deny such petition, stating in writing his reasons for such denial. In making his determination to issue such an order or rule pursuant to this subsection, the President must find that such order or rule would—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd71682d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6215/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be consistent with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7425"},"text":"section 7425 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd71682e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6215/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" result in no significant increase in the consumption of energy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd71682f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6215/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not subject the ultimate consumer to significantly higher energy costs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd716830-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6215/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not violate any contractual relationship between such source and any supplier or transporter of fuel to such source.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd716831-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6215/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect on authority of President to allocate coal or coal derivatives","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in subsection (a) or (b) of this section shall affect the authority of the President or the Secretary of the Department of Energy to allocate coal or coal derivatives under any provision of law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd716832-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6215/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “major fuel burning stationary source (or class or category thereof)” and “locally or regionally available coal or coal derivatives” shall have the meanings assigned to them for the purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7425"},"text":"section 7425 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd716833-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/163/tI/s107"},"text":"Pub. L. 94–163, title I, § 107","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/95/619/tVI/s661"},"text":"Pub. L. 95–619, title VI, § 661","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-09"},"text":"Nov. 9, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3285"},"text":"92 Stat. 3285","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/469/tVI/s605/b/2"},"text":"Pub. L. 106–469, title VI, § 605(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-09"},"text":"Nov. 9, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2043"},"text":"114 Stat. 2043","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd716834-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd716835-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd716836-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/469"},"text":"Pub. L. 106–469","children":[],"tail":" inserted section catchline."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
