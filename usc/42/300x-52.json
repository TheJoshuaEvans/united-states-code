{"tag":"section","attrib":{"id":"idb66e0ece-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–52"},"text":null,"children":[{"tag":"num","attrib":{"value":"300x–52"},"text":"§ 300x–52.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement of reports and audits by States","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb66e0ecf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–52/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A funding agreement for a grant under section 300x or 300x–21 of this title is that the State involved will submit to the Secretary a report in such form and containing such information as the Secretary determines (after consultation with the States) to be necessary for securing a record and a description of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb66e0ed0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–52/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the purposes for which the grant received by the State for the preceding fiscal year under the program involved were expended and a description of the activities of the State under the program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb66e0ed1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–52/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the recipients of amounts provided in the grant; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb66e0ed2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–52/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount provided to each recipient in the previous fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb66e0ed3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–52/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Audits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A funding agreement for a grant under section 300x or 300x–21 of this title is that the State will, with respect to the grant, comply with chapter 75 of title 31.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb66e0ed4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–52/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability to public","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A funding agreement for a grant under section 300x or 300x–21 of this title is that the State involved will—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb66e0ed5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–52/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make copies of the reports and audits described in this section available for public inspection within the State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb66e0ed6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–52/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide copies of the report under subsection (a), upon request, to any interested person (including any public agency).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb66e0ed7-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XIX, § 1942, as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/321/tII/s203/a"},"text":"Pub. L. 102–321, title II, § 203(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-10"},"text":"July 10, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/403"},"text":"106 Stat. 403","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/316/tI/s122/e"},"text":"Pub. L. 104–316, title I, § 122(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-19"},"text":"Oct. 19, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3837"},"text":"110 Stat. 3837","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dFF/tI/s1246"},"text":"Pub. L. 117–328, div. FF, title I, § 1246","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5679"},"text":"136 Stat. 5679","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb66e0ed8-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb66e0ed9-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb66e0eda-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328"},"text":"Pub. L. 117–328","children":[],"tail":" added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/316"},"text":"Pub. L. 104–316","children":[],"tail":" struck out “and the Comptroller General” after “with the States” in introductory provisions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
