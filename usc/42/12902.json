{"tag":"section","attrib":{"id":"idbfab5269-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12902"},"text":null,"children":[{"tag":"num","attrib":{"value":"12902"},"text":"§ 12902.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfab526a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12902/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “acquired immunodeficiency syndrome and related diseases” or “AIDS” means the disease of acquired immunodeficiency syndrome or any conditions arising from the etiologic agent for acquired immunodeficiency syndrome.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfab526b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12902/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “applicant” means a State, a unit of general local government, or a nonprofit organization eligible to receive assistance under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfab526c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12902/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “low-income individual” means any individual or family whose incomes do not exceed 80 percent of the median income for the area, as determined by the Secretary of Housing and Urban Development, with adjustments for smaller and larger families, except that the Secretary may establish income ceilings higher or lower than 80 percent of the median income for the area if the Secretary finds that such variations are necessary because of prevailing levels of construction costs or unusually high or low family incomes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfab526d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12902/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “grantee” means a State or unit of general local government receiving grants from the Secretary under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfab526e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12902/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “metropolitan statistical area” means a metropolitan statistical area as established by the Office of Management and Budget. Such term includes the District of Columbia.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfab526f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12902/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “locality” means the geographical area within the jurisdiction of a local government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfab5270-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12902/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “recipient” means a grantee or other applicant receiving funds under this chapter.","children":[{"tag":"ref","attrib":{"idref":"fn004136"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004136"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfab5271-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12902/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Secretary” means the Secretary of Housing and Urban Development.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfab5272-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12902/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “State” means a State of the United States, the District of Columbia, and the Commonwealth of Puerto Rico, or any agency or instrumentality thereof that is established pursuant to legislation and designated by the chief executive to act on behalf of the jurisdiction with regard to provisions of this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfab5273-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12902/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “unit of general local government” has the same meaning as in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12704"},"text":"section 12704 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfab5274-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12902/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “city” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5302/a"},"text":"section 5302(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfab5275-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12902/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “eligible person” means a person with acquired immunodeficiency syndrome or a related disease and the family of such person.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfab5276-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12902/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “nonprofit organization” means any nonprofit organization (including a State or locally chartered, nonprofit organization) that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfab5277-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12902/13/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is organized under State or local laws;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfab5278-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12902/13/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has no part of its net earnings inuring to the benefit of any member, founder, contributor, or individual;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfab5279-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12902/13/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" complies with standards of financial accountability acceptable to the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfab527a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12902/13/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has among its purposes significant activities related to providing services or housing to persons with acquired immunodeficiency syndrome or related diseases.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfab527b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12902/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “project sponsor” means a nonprofit organization or a housing agency of a State or unit of general local government that contracts with a grantee to receive assistance under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfab527c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12902/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “HIV” means infection with the human immunodeficiency virus.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfab527d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12902/16"},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"(16)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “individuals living with HIV or AIDS” means, with respect to the counting of cases in a geographic area during a period of time, the sum of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfab527e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12902/16/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of living non-AIDS cases of HIV in the area; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfab527f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12902/16/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of living cases of AIDS in the area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfab5280-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/625/tVIII/s853"},"text":"Pub. L. 101–625, title VIII, § 853","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4375"},"text":"104 Stat. 4375","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/550/tVI/s606/c"},"text":"Pub. L. 102–550, title VI, § 606(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3807"},"text":"106 Stat. 3807","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/201/tVII/s701/b"},"text":"Pub. L. 114–201, title VII, § 701(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-07-29"},"text":"July 29, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/814"},"text":"130 Stat. 814","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbfab5281-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbfab5282-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbfab5283-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in par. (7), was in the original “this title”, and was translated as reading “this subtitle”, meaning subtitle D (§§ 851–863) of title VIII of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/625"},"text":"Pub. L. 101–625","children":[],"tail":", to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbfab5284-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/201/s701/b/1"},"text":"Pub. L. 114–201, § 701(b)(1)","children":[],"tail":", inserted “or ‘AIDS’ ” before “means”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (15), (16). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/201/s701/b/2"},"text":"Pub. L. 114–201, § 701(b)(2)","children":[],"tail":", added pars. (15) and (16)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550/s606/c/1"},"text":"Pub. L. 102–550, § 606(c)(1)","children":[],"tail":", substituted “organization eligible to receive assistance under this chapter” for “sponsor receiving assistance from a grantee”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550/s606/c/2"},"text":"Pub. L. 102–550, § 606(c)(2)","children":[],"tail":", substituted “term ‘metropolitan statistical area’ means” for “term ‘metropolitan area’ means”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (11) to (14). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550/s606/c/3"},"text":"Pub. L. 102–550, § 606(c)(3)","children":[],"tail":", added pars. (11) to (14)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
