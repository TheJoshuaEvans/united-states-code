{"tag":"section","attrib":{"id":"idbbaea984-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1975a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1975a"},"text":"§ 1975a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties of Commission","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbbaea985-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1975a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Generally","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commission—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbbaea986-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1975a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall investigate allegations in writing under oath or affirmation relating to deprivations—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbbaea987-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1975a/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" because of color, race, religion, sex, age, disability, or national origin; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbbaea988-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1975a/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as a result of any pattern or practice of fraud;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"of the right of citizens of the United States to vote and have votes counted; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbaea989-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1975a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbbaea98a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1975a/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" study and collect information relating to;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbbaea98b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1975a/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make appraisals of the laws and policies of the Federal Government with respect to;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbbaea98c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1975a/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serve as a national clearinghouse for information relating to; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbbaea98d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1975a/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prepare public service announcements and advertising campaigns to discourage;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"discrimination or denials of equal protection of the laws under the Constitution of the United States because of color, race, religion, sex, age, disability, or national origin, or in the administration of justice.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbbaea98e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1975a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on investigatory duties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter or any other Act shall be construed as authorizing the Commission, its advisory committees, or any person under its supervision or control, to inquire into or investigate any membership practices or internal operations of any fraternal organization, any college or university fraternity or sorority, any private club, or any religious organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbbaea98f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1975a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbbaea990-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1975a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall submit to the President and Congress at least one report annually that monitors Federal civil rights enforcement efforts in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbaea991-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1975a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other reports generally","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall submit such other reports to the President and the Congress as the Commission, the Congress, or the President shall deem appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbbaea992-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1975a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisory committees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission may constitute such advisory committees as it deems advisable. The Commission shall establish at least one such committee in each State and the District of Columbia composed of citizens of that State or District.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbbaea993-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1975a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hearings and ancillary matters","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbbaea994-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1975a/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Power to hold hearings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission, or on the authorization of the Commission, any subcommittee of two or more members of the Commission, at least one of whom shall be of each major political party, may, for the purpose of carrying out this chapter, hold such hearings and act at such times and places as the Commission or such authorized subcommittee deems advisable. Each member of the Commission shall have the power to administer oaths and affirmations in connection with the proceedings of the Commission. The holding of a hearing by the Commission or the appointment of a subcommittee to hold a hearing pursuant to this paragraph must be approved by a majority of the Commission, or by a majority of the members present at a meeting when a quorum is present.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbaea995-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1975a/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Power to issue subpoenas","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission may issue subpoenas for the attendance of witnesses and the production of written or other matter. Such a subpoena may not require the presence of a witness more than 100 miles outside the place wherein the witness is found or resides or is domiciled or transacts business, or has appointed an agent for receipt of service of process. In case of contumacy or refusal to obey a subpoena, the Attorney General may in a Federal court of appropriate jurisdiction obtain an appropriate order to enforce the subpoena.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbaea996-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1975a/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Witness fees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A witness attending any proceeding of the Commission shall be paid the same fees and mileage that are paid witnesses in the courts of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbaea997-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1975a/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Depositions and interrogatories","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission may use depositions and written interrogatories to obtain information and testimony about matters that are the subject of a Commission hearing or report.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbbaea998-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1975a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation relating to abortion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter or any other Act shall be construed as authorizing the Commission, its advisory committees, or any other person under its supervision or control to study and collect, make appraisals of, or serve as a clearinghouse for any information about laws and policies of the Federal Government or any other governmental authority in the United States, with respect to abortion.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbbaea999-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/183/s3"},"text":"Pub. L. 98–183, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-11-30"},"text":"Nov. 30, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/1302"},"text":"97 Stat. 1302","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/167/s5"},"text":"Pub. L. 102–167, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-11-26"},"text":"Nov. 26, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1101"},"text":"105 Stat. 1101","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/419/s2"},"text":"Pub. L. 103–419, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-25"},"text":"Oct. 25, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4339"},"text":"108 Stat. 4339","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbbaea99a-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbbaea99b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbbaea99c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1975a, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/315"},"text":"Pub. L. 85–315","children":[],"tail":", pt. I, § 102, "},{"tag":"date","attrib":{"date":"1957-09-09"},"text":"Sept. 9, 1957","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/71/634"},"text":"71 Stat. 634","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/88/352/tV/s501"},"text":"Pub. L. 88–352, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-07-02"},"text":"July 2, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/249"},"text":"78 Stat. 249","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/521/s4"},"text":"Pub. L. 91–521, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-11-25"},"text":"Nov. 25, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1357"},"text":"84 Stat. 1357","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/92/496/s1"},"text":"Pub. L. 92–496, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-14"},"text":"Oct. 14, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/813"},"text":"86 Stat. 813","children":[],"tail":", established rules of procedure for Commission. See Codification note set out preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1975"},"text":"section 1975 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbbaea99d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/419"},"text":"Pub. L. 103–419","children":[],"tail":" amended section generally, substituting provisions relating to duties of Commission for provisions relating to rules of procedure of Commission hearings."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsecs. (a), (d), (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/167"},"text":"Pub. L. 102–167","children":[],"tail":" substituted “Chairperson” for “Chairman” wherever appearing."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
