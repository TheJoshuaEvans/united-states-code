ef":"/us/pl/96/372/s6/e"},"text":"Pub. L. 96–372, § 6(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-03"},"text":"Oct. 3, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1365"},"text":"94 Stat. 1365","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/399/tV"},"text":"Pub. L. 96–399, title V","children":[],"tail":", §§ 501(d), 507(e), "},{"tag":"date","attrib":{"date":"1980-10-08"},"text":"Oct. 8, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1668"},"text":"94 Stat. 1668","children":[],"tail":", 1670; "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tIII/s351/e"},"text":"Pub. L. 97–35, title III, § 351(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/421"},"text":"95 Stat. 421","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/289/s3/c"},"text":"Pub. L. 97–289, § 3(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-06"},"text":"Oct. 6, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1231"},"text":"96 Stat. 1231","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/35/s3/c"},"text":"Pub. L. 98–35, § 3(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-05-26"},"text":"May 26, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/198"},"text":"97 Stat. 198","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/109/s4/c"},"text":"Pub. L. 98–109, § 4(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-10-01"},"text":"Oct. 1, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/746"},"text":"97 Stat. 746","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/181/tI"},"text":"Pub. L. 98–181, title I","children":[],"tail":" [title V, § 511(d), (e)], "},{"tag":"date","attrib":{"d