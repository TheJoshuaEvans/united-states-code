{"tag":"section","attrib":{"id":"idb49aadad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s244b"},"text":null,"children":[{"tag":"num","attrib":{"value":"244b"},"text":"§ 244b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities relating to cardiomyopathy","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb49aadae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s244b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report on CDC national cardiomyopathy activities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb49aadaf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s244b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 18 months after ","children":[{"tag":"date","attrib":{"date":"2024-12-23"},"text":"December 23, 2024","children":[],"tail":", the Secretary, acting through the Director of the Centers for Disease Control and Prevention, shall submit to Congress a report on findings generated from existing activities conducted by the Centers for Disease Control and Prevention to improve the understanding of the prevalence and epidemiology of cardiomyopathy across the lifespan, from birth to adulthood, with particular interest in the following:"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb49aadb0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s244b/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The natural history of individuals with cardiomyopathy, in both the pediatric and adult population.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb49aadb1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s244b/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Estimates of cardiomyopathy-related emergency department visits and hospitalizations, in both the pediatric and adult population.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb49aadb2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s244b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public access","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (3), the report submitted under this subsection shall be made available to the public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb49aadb3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s244b/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Privacy protections","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall ensure that this subsection is carried out in a manner that complies with all applicable privacy laws under Federal and State law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb49aadb4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s244b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Improving risk assessments for individuals with cardiomyopathy","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb49aadb5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s244b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall develop and make publicly available a cardiomyopathy risk assessment for health care providers and individuals. Such risk assessment shall, at a minimum, include the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb49aadb6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s244b/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Background information on the prevalence, incidence, and health impact of cardiomyopathy, including all forms of cardiomyopathy and their effects on pediatric, adolescent, and adult individuals.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb49aadb7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s244b/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A worksheet with variables and conditions for an individual or health care provider to use in assessing whether an individual is at risk for cardiomyopathy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb49aadb8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s244b/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A worksheet with variables and stages of progression for an individual or health care provider to use in assessing whether and to what extent cardiomyopathy has progressed in an individual.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb49aadb9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s244b/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Guidelines on cardiomyopathy screenings for individuals who are at risk for, or have a family history of, cardiomyopathy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb49aadba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s244b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Stakeholder input","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out paragraph (1), the Director of the Centers for Disease Control and Prevention shall seek input from external stakeholders including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb49aadbb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s244b/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" representatives from national patient advocacy organizations expert in all forms of cardiomyopathy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb49aadbc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s244b/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" representatives from medical professional societies that specialize in the care of adults and pediatrics with cardiomyopathy; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb49aadbd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s244b/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" representatives from other relevant Federal agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb49aadbe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s244b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “cardiomyopathy” has the meaning given to such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s244a"},"text":"section 244a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb49aadbf-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title III, § 312B, as added "},{"tag":"ref","attrib":{"href":"/us/pl/118/176/s2/a"},"text":"Pub. L. 118–176, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2607"},"text":"138 Stat. 2607","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
