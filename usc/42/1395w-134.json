{"tag":"section","attrib":{"id":"idb95cf0ec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–134"},"text":null,"children":[{"tag":"num","attrib":{"value":"1395w–134"},"text":"§ 1395w–134.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination requirements for plans providing prescription drug coverage","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb95cf0ed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–134/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of benefit coordination requirements to additional plans","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb95cf0ee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–134/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall apply the coordination requirements established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395w–133/a"},"text":"section 1395w–133(a) of this title","children":[],"tail":" to Rx plans described in subsection (b) in the same manner as such requirements apply to a State Pharmaceutical Assistance Program."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95cf0ef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–134/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application to treatment of certain out-of-pocket expenditures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the extent specified by the Secretary, the requirements referred to in paragraph (1) shall apply to procedures established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395w–102/b/4/D"},"text":"section 1395w–102(b)(4)(D) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95cf0f0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–134/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" User fees","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb95cf0f1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–134/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may impose user fees for the transmittal of information necessary for benefit coordination under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395w–102/b/4/D"},"text":"section 1395w–102(b)(4)(D) of this title","children":[],"tail":" in a manner similar to the manner in which user fees are imposed under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395u/h/3/B"},"text":"section 1395u(h)(3)(B) of this title","children":[],"tail":", except that the Secretary may retain a portion of such fees to defray the Secretary’s costs in carrying out procedures under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395w–102/b/4/D"},"text":"section 1395w–102(b)(4)(D) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb95cf0f2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–134/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A user fee may not be imposed under subparagraph (A) with respect to a State Pharmaceutical Assistance Program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb95cf0f3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–134/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rx Plan","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An Rx plan described in this subsection is any of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb95cf0f4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–134/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Medicaid programs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State plan under subchapter XIX, including such a plan operating under a waiver under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1315"},"text":"section 1315 of this title","children":[],"tail":", if it meets the requirements of "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395w–133/b/2"},"text":"section 1395w–133(b)(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95cf0f5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–134/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Group health plans","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An employer group health plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95cf0f6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–134/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" FEHBP","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal employees health benefits plan under chapter 89 of title 5.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95cf0f7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–134/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Military coverage (including TRICARE)","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Coverage under chapter 55 of title 10.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95cf0f8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–134/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other prescription drug coverage","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Such other health benefit plans or programs that provide coverage or financial assistance for the purchase or provision of prescription drug coverage on behalf of part D eligible individuals as the Secretary may specify.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb95cf0f9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–134/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relation to other provisions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb95cf0fa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–134/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of cost management tools","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The requirements of this section shall not impair or prevent a PDP sponsor or MA organization from applying cost management tools (including differential payments) under all methods of operation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95cf0fb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–134/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No affect ","children":[{"tag":"ref","attrib":{"idref":"fn002884"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002884"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “effect”."}],"tail":" on treatment of certain out-of-pocket expenditures"}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The requirements of this section shall not affect the application of the procedures established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395w–102/b/4/D"},"text":"section 1395w–102(b)(4)(D) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb95cf0fc-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title XVIII, § 1860D–24, as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/173/tI/s101/a/2"},"text":"Pub. L. 108–173, title I, § 101(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-08"},"text":"Dec. 8, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2130"},"text":"117 Stat. 2130","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
