{"tag":"section","attrib":{"id":"idbdfe1742-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7260"},"text":null,"children":[{"tag":"num","attrib":{"value":"7260"},"text":"§ 7260.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Field offices","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to establish, alter, consolidate or discontinue and to maintain such State, regional, district, local or other field offices as he may deem to be necessary to carry out functions vested in him.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbdfe1743-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/91/tVI/s650"},"text":"Pub. L. 95–91, title VI, § 650","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-08-04"},"text":"Aug. 4, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/601"},"text":"91 Stat. 601","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
