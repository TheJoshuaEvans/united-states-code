{"tag":"section","attrib":{"id":"idbd526e43-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5419"},"text":null,"children":[{"tag":"num","attrib":{"value":"5419"},"text":"§ 5419.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to collect fee","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd526e44-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5419/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out inspections under this chapter, in developing standards and regulations pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5403"},"text":"section 5403 of this title","children":[],"tail":", and in facilitating the acceptance of the affordability and availability of manufactured housing within the Department, the Secretary may—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd54b835-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5419/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" establish and collect from manufactured home manufacturers a reasonable fee, as may be necessary to offset the expenses incurred by the Secretary in connection with carrying out the responsibilities of the Secretary under this chapter, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd54b836-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5419/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conducting inspections and monitoring;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd54b837-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5419/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing funding to States for the administration and implementation of approved State plans under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5422"},"text":"section 5422 of this title","children":[],"tail":", including reasonable funding for cooperative educational and training programs designed to facilitate uniform enforcement under this chapter, which funds may be paid directly to the States or may be paid or provided to any person or entity designated to receive and disburse such funds by cooperative agreements among participating States, provided that such person or entity is not otherwise an agent of the Secretary under this chapter;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd54b838-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5419/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing the funding for a noncareer administrator within the Department to administer the manufactured housing program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd54b839-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5419/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing the funding for salaries and expenses of employees of the Department to carry out the manufactured housing program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd54b83a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5419/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" administering the consensus committee as set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5403"},"text":"section 5403 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd54b83b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5419/a/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitating the acceptance of the quality, durability, safety, and affordability of manufactured housing within the Department; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd54b83c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5419/a/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the administration and enforcement of the installation standards authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5404"},"text":"section 5404 of this title","children":[],"tail":" in States in which the Secretary is required to implement an installation program after the expiration of the 5-year period set forth in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5404/c/2/B"},"text":"section 5404(c)(2)(B) of this title","children":[],"tail":", and the administration and enforcement of a dispute resolution program described in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5422/c/12"},"text":"section 5422(c)(12) of this title","children":[],"tail":" in States in which the Secretary is required to implement such a program after the expiration of the 5-year period set forth in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5422/g/2"},"text":"section 5422(g)(2) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd54b83d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5419/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to subsection (e), use amounts from any fee collected under paragraph (1) of this subsection to pay expenses referred to in that paragraph, which shall be exempt and separate from any limitations on the Department regarding full-time equivalent positions and travel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd54b83e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5419/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contractors","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In using amounts from any fee collected under this section, the Secretary shall ensure that separate and independent contractors are retained to carry out monitoring and inspection work and any other work that may be delegated to a contractor under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd54b83f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5419/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibited use","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No amount from any fee collected under this section may be used for any purpose or activity not specifically authorized by this chapter, unless such activity was already engaged in by the Secretary prior to ","children":[{"tag":"date","attrib":{"date":"2000-12-27"},"text":"December 27, 2000","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd54b840-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5419/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Modification","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Beginning on ","children":[{"tag":"date","attrib":{"date":"2000-12-27"},"text":"December 27, 2000","children":[],"tail":", the amount of any fee collected under this section may only be modified—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd54b841-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5419/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as specifically authorized in advance in an annual appropriations Act; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd54b842-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5419/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pursuant to rulemaking in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s553"},"text":"section 553 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd54b843-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5419/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriation and deposit of fees","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd54b844-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5419/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established in the Treasury of the United States a fund to be known as the “Manufactured Housing Fees Trust Fund” for deposit of amounts from any fee collected under this section. Such amounts shall be held in trust for use only as provided in this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd54b845-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5419/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts from any fee collected under this section shall be available for expenditure only to the extent approved in advance in an annual appropriations Act. Any change in the expenditure of such amounts shall be specifically authorized in advance in an annual appropriations Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd54b846-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5419/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments to States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On and after the effective date of the Manufactured Housing Improvement Act of 2000, the Secretary shall continue to fund the States having approved State plans in the amounts which are not less than the allocated amounts, based on the fee distribution system in effect on the day before such effective date.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd54b847-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/383/tVI/s620"},"text":"Pub. L. 93–383, title VI, § 620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-08-22"},"text":"Aug. 22, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/712"},"text":"88 Stat. 712","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/153/tIII/s320"},"text":"Pub. L. 96–153, title III, § 320","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-12-21"},"text":"Dec. 21, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/1119"},"text":"93 Stat. 1119","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/399/tIII/s308/c/4"},"text":"Pub. L. 96–399, title III, § 308(c)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-08"},"text":"Oct. 8, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1641"},"text":"94 Stat. 1641","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/569/tVI/s609"},"text":"Pub. L. 106–569, title VI, § 609","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-27"},"text":"Dec. 27, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/3010"},"text":"114 Stat. 3010","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd54b848-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd54b849-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbd54b84a-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For the effective date of the Manufactured Housing Improvement Act of 2000, referred to in subsec. (e)(3), see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/569/s612"},"text":"section 612 of Pub. L. 106–569","children":[],"tail":", set out as an Effective Date of 2000 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5401"},"text":"section 5401 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd54b84b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/569"},"text":"Pub. L. 106–569","children":[],"tail":" amended section catchline and text generally. Prior to amendment, text read as follows: “In carrying out the inspections required under this chapter, the Secretary may establish and impose on manufactured home manufacturers, distributors, and dealers such reasonable fees as may be necessary to offset the expenses incurred by him in conducting such inspections, and the Secretary may use any fees so collected to pay expenses incurred in connection with such inspections, except that this section shall not apply in any State which has in effect a State plan under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5422"},"text":"section 5422 of this title","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/399"},"text":"Pub. L. 96–399","children":[],"tail":" substituted “manufactured home” for “mobile home”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1979—","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/153"},"text":"Pub. L. 96–153","children":[],"tail":" substituted “conducting such inspections, and the Secretary may use any fees so collected to pay expenses incurred in connection with such inspections, except” for “conducting such inspections, except”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbd54b84c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbd54b84d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2000 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/569"},"text":"Pub. L. 106–569","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2000-12-27"},"text":"Dec. 27, 2000","children":[],"tail":", except that amendment has no effect on any order or interpretative bulletin issued under this chapter and published as a proposed rule pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s553"},"text":"5 U.S.C. 553","children":[],"tail":" on or before "},{"tag":"date","attrib":{"date":"2000-12-27"},"text":"Dec. 27, 2000","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/106/569/s612"},"text":"section 612 of Pub. L. 106–569","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5401"},"text":"section 5401 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbd54b84e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective upon the expiration of 180 days following ","children":[{"tag":"date","attrib":{"date":"1974-08-22"},"text":"Aug. 22, 1974","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/93/383/s627"},"text":"section 627 of Pub. L. 93–383","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5401"},"text":"section 5401 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbd54b84f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Final Rulemaking on Manufactured Housing Payments","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94/dH/tII"},"text":"Pub. L. 116–94, div. H, title II","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/2994"},"text":"133 Stat. 2994","children":[],"tail":", provided in part: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/94/dH/tII"},"text":"“That the Secretary of Housing and Urban Development shall issue a final rule to complete rulemaking initiated by the proposed rule entitled ‘Manufactured Housing Program: Minimum Payments to the States’ published in the Federal Register on ","children":[{"tag":"date","attrib":{"date":"2016-12-16"},"text":"December 16, 2016","children":[],"tail":" (81 Fed. Reg. 91083)”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbd54b850-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Manufactured Housing","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/18/s1"},"text":"Pub. L. 107–18, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-07-05"},"text":"July 5, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/152"},"text":"115 Stat. 152","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/18/s1"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Availability of Fees","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding section 620(e)(2) of the National Manufactured Housing Construction and Safety Standards Act of 1974 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5419/e/2"},"text":"42 U.S.C. 5419(e)(2)","children":[],"tail":"), any fees collected under that Act, including any fees collected before the date of enactment of the American Homeownership and Economic Opportunity Act of 2000 ("},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1701"},"text":"12 U.S.C. 1701","children":[],"tail":" note) ["},{"tag":"date","attrib":{"date":"2000-12-27"},"text":"Dec. 27, 2000","children":[],"tail":"] and remaining unobligated on the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"2001-07-05"},"text":"July 5, 2001","children":[],"tail":"], shall be available for expenditure to offset the expenses incurred by the Secretary under the National Manufactured Housing Construction and Safety Standards Act of 1974 ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5401"},"text":"42 U.S.C. 5401","children":[],"tail":" et seq.), otherwise in accordance with section 620 of that Act."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duration","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The authority for the use of fees provided for in subsection (a) shall remain in effect during the period beginning in fiscal year 2001 and ending on the effective date of the first appropriations Act referred to in section 620(e)(2) of the National Manufactured Housing Construction and Safety Standards Act of 1974 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5419/e/2"},"text":"42 U.S.C. 5419(e)(2)","children":[],"tail":") that is enacted with respect to a fiscal year after fiscal year 2001.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
