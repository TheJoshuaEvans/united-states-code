{"tag":"section","attrib":{"id":"idbf400db6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11332"},"text":null,"children":[{"tag":"num","attrib":{"value":"11332"},"text":"§ 11332.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Local boards","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf400db7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11332/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each locality designated by the National Board shall constitute a local board for the purpose of determining how program funds allotted to the locality will be distributed. The local board shall consist, to the extent practicable, of representatives of the same organizations as the National Board, except that the mayor or other appropriate heads of government will replace the Federal members, and except that each local board administering program funds for a locality within which is located a reservation (as such term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1452/d"},"text":"section 1452(d) of title 25","children":[],"tail":","},{"tag":"ref","attrib":{"idref":"fn003999"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003999"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. A closing parenthesis probably should precede the punctuation."}],"tail":" or a portion thereof, shall include a board member who is a member of an Indian tribe (as such term is defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5302/a/17"},"text":"section 5302(a)(17) of this title","children":[],"tail":"."},{"tag":"ref","attrib":{"idref":"fn003999"},"text":"1","children":[],"tail":" The chairperson of the local board shall be elected by a majority of the members of the local board. Local boards are encouraged to expand participation of other private nonprofit organizations on the local board."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf4256a8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11332/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibilities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each local board shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf4256a9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11332/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determine which private nonprofit organizations or public organizations of the local government in the individual locality shall receive grants to act as service providers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf4256aa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11332/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" monitor recipient service providers for program compliance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf4256ab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11332/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reallocate funds among service providers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf4256ac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11332/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure proper reporting; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf4256ad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11332/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate with other Federal, State, and local government assistance programs available in the locality.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf4256ae-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/77/tIII/s302"},"text":"Pub. L. 100–77, title III, § 302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-07-22"},"text":"July 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/490"},"text":"101 Stat. 490","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/645/tII/s202/a"},"text":"Pub. L. 101–645, title II, § 202(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4675"},"text":"104 Stat. 4675","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf4256af-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf4256b0-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbf4256b1-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1990—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/645"},"text":"Pub. L. 101–645","children":[],"tail":" inserted before period at end of second sentence “, and except that each local board administering program funds for a locality within which is located a reservation (as such term is defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s1452/d"},"text":"section 1452(d) of title 25","children":[],"tail":", or a portion thereof, shall include a board member who is a member of an Indian tribe (as such term is defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5302/a/17"},"text":"section 5302(a)(17) of this title","children":[],"tail":"”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbf4256b2-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbf4256b3-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Implementation of 1990 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/645/tII/s202/b"},"text":"Pub. L. 101–645, title II, § 202(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4675"},"text":"104 Stat. 4675","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/645/tII/s202/b"},"text":"“Each local board under the Emergency Food and Shelter Program whose membership shall include a member of an Indian tribe by reason of the amendment made by subsection (a) [amending this section] shall comply with the requirement made by such amendment not later than the expiration of the 30-day period beginning on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
