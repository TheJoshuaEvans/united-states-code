{"tag":"section","attrib":{"id":"idc07ad739-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19105"},"text":null,"children":[{"tag":"num","attrib":{"value":"19105"},"text":"§ 19105.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistant Director","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc07ad73a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19105/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall appoint an Assistant Director responsible for the management of the Directorate established under this part, in the same manner as other Assistant Directors of the Foundation are appointed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc07ad73b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19105/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifications","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Assistant Director shall be an individual, who by reason of professional background and experience, is specially qualified to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc07ad73c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19105/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advise the Director on all matters pertaining to use-inspired and translational research, development, and commercialization at the Foundation, including partnership with the private sector and other users of Foundation funded research; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc07ad73d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19105/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop and implement the necessary policies and procedures to promote a culture of use-inspired and translational research within the Directorate and across the Foundation and carry out the responsibilities under subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc07ad73e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19105/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibilities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The responsibilities of the Assistant Director shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc07ad73f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19105/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advising the Director on all matters pertaining to use-inspired and translational research and development activities at the Foundation, including effective practices for convergence research, and the potential impact of Foundation research on United States societal, national and geostrategic challenges;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc07ad740-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19105/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" identifying opportunities for and facilitating coordination and collaboration, where appropriate, on use-inspired and translational research, development, adoption, and commercialization—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc07ad741-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19105/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" among the offices, directorates, and divisions within the Foundation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc07ad742-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19105/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" between the Foundation and stakeholders in academia, the private sector, including non-profit entities, labor organizations, Federal or State agencies, and international entities, as appropriate;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc07ad743-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19105/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensuring that the activities carried out under this part do not substantially and unnecessarily duplicate activities supported by other parts of the Foundation or other relevant Federal agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc07ad744-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19105/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" approving all new programs within the Directorate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc07ad745-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19105/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing and testing diverse merit-review models and mechanisms for selecting and providing awards for use-inspired and translational research and development at different scales, from individual investigator awards to large multi-institution collaborations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc07ad746-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19105/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assessing the success of programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc07ad747-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19105/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" administering awards to achieve the purposes described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s19102"},"text":"section 19102 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc07ad748-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19105/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" performing other such duties pertaining to the purposes in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s19102"},"text":"section 19102 of this title","children":[],"tail":" as are required by the Director."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc07ad749-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19105/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relationship to the Director","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Assistant Director shall report to the Director.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc07ad74a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19105/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relationship to other programs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No other directorate within the Foundation shall report to the Assistant Director.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc07ad74b-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/tIII/s10385"},"text":"Pub. L. 117–167, div. B, title III, § 10385","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1577"},"text":"136 Stat. 1577","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
