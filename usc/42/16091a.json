{"tag":"section","attrib":{"id":"idbff07251-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091a"},"text":null,"children":[{"tag":"num","attrib":{"value":"16091a"},"text":"§ 16091a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Clean school bus program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbff07252-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the following definitions apply:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbff07253-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrator","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Administrator” means the Administrator of the Environmental Protection Agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff07254-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Alternative fuel","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “alternative fuel” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbff07255-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091a/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" liquefied natural gas, compressed natural gas, liquefied petroleum gas, hydrogen, or propane;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff07256-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091a/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" methanol or ethanol at no less than 85 percent by volume; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff07257-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091a/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" biodiesel conforming with standards published by the American Society for Testing and Materials as of ","children":[{"tag":"date","attrib":{"date":"2005-08-10"},"text":"August 10, 2005","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff07258-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Clean school bus","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “clean school bus” means a school bus with a gross vehicle weight of greater than 14,000 pounds that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbff07259-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091a/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is powered by a heavy duty engine; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff0725a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091a/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is operated solely on an alternative fuel or ultra-low sulfur diesel fuel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff0725b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091a/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible recipient","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbff0725c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091a/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subparagraph (B), the term “eligible recipient” means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbff0725d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091a/a/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one or more local or State governmental entities responsible for providing school bus service to one or more public school systems or the purchase of school buses;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbff0725e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091a/a/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one or more contracting entities that provide school bus service to one or more public school systems; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbff0725f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091a/a/4/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a nonprofit school transportation association.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff07260-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091a/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of eligible recipients identified under clauses (ii) and (iii) of subparagraph (A), the Administrator shall establish timely and appropriate requirements for notice and may establish timely and appropriate requirements for approval by the public school systems that would be served by buses purchased or retrofit using grant funds made available under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff07261-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091a/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retrofit technology","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “retrofit technology” means a particulate filter or other emissions control equipment that is verified or certified by the Administrator or the California Air Resources Board as an effective emission reduction technology when installed on an existing school bus.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff07262-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091a/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of Energy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff07263-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091a/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ultra-low sulfur diesel fuel","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “ultra-low sulfur diesel fuel” means diesel fuel that contains sulfur at not more than 15 parts per million.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff07264-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program for retrofit or replacement of certain existing school buses with clean school buses","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbff07265-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbff07266-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091a/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator, in consultation with the Secretary and other appropriate Federal departments and agencies, shall establish a program for awarding grants on a competitive basis to eligible recipients for the replacement of, retrofit (including repowering, aftertreatment, and remanufactured engines) of, or purchase of alternative fuels for, certain existing school buses. The awarding of grants for the purchase of alternative fuels should be consistent with the historic funding levels of the program for such purchase.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff07267-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091a/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Balancing","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In awarding grants under this section, the Administrator shall achieve, to the maximum extent practicable, achieve ","children":[{"tag":"ref","attrib":{"idref":"fn004205"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004205"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The word “achieve” probably should not appear."}],"tail":" an appropriate balance between awarding grants—"}],"tail":null},{"tag":"clause","attrib":{"id":"idbff07268-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091a/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to replace school buses;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbff07269-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091a/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to install retrofit technologies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbff0726a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091a/b/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to purchase and use alternative fuel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff0726b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority of grant applications","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbff0726c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091a/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Replacement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of grant applications to replace school buses, the Administrator shall give priority to applicants that propose to replace school buses manufactured before model year 1977.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff0726d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091a/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retrofitting","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of grant applications to retrofit school buses, the Administrator shall give priority to applicants that propose to retrofit school buses manufactured in or after model year 1991.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff0726e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of school bus fleet","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbff0726f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091a/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All school buses acquired or retrofitted with funds provided under this section shall be operated as part of the school bus fleet for which the grant was made for not less than 5 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff07270-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091a/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maintenance, operation, and fueling","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"New school buses and retrofit technology shall be maintained, operated, and fueled according to manufacturer recommendations or State requirements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff07271-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retrofit grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator may award grants under this section for up to 100 percent of the retrofit technologies and installation costs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff07272-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091a/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Replacement grants","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbff07273-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091a/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility for 50 percent grants","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator may award grants under this section for replacement of school buses in the amount of up to one-half of the acquisition costs (including fueling infrastructure) for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbff07274-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091a/b/5/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" clean school buses with engines manufactured in model year 2005 or 2006 that emit not more than—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbff07275-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091a/b/5/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1.8 grams per brake horsepower-hour of non-methane hydrocarbons and oxides of nitrogen; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbff07276-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091a/b/5/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" .01 grams per brake horsepower-hour of particulate matter; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbff07277-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091a/b/5/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" clean school buses with engines manufactured in model year 2007, 2008, or 2009 that satisfy regulatory requirements established by the Administrator for emissions of oxides of nitrogen and particulate matter to be applicable for school buses manufactured in model year 2010.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff07278-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091a/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility for 25 percent grants","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator may award grants under this section for replacement of school buses in the amount of up to one-fourth of the acquisition costs (including fueling infrastructure) for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbff07279-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091a/b/5/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" clean school buses with engines manufactured in model year 2005 or 2006 that emit not more than—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbff0727a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091a/b/5/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 2.5 grams per brake horsepower-hour of non-methane hydrocarbons and oxides of nitrogen; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbff0727b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091a/b/5/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" .01 grams per brake horsepower-hour of particulate matter; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbff0727c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091a/b/5/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" clean school buses with engines manufactured in model year 2007 or thereafter that satisfy regulatory requirements established by the Administrator for emissions of oxides of nitrogen and particulate matter from school buses manufactured in that model year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff0727d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091a/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ultra-low sulfur diesel fuel","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbff0727e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091a/b/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"idref":"fn004206"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004206"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. No subpar. (B) was enacted."}],"tail":" In general"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a grant recipient receiving a grant for the acquisition of ultra-low sulfur diesel fuel school buses with engines manufactured in model year 2005 or 2006, the grant recipient shall provide, to the satisfaction of the Administrator—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbff0727f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091a/b/6/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" documentation that diesel fuel containing sulfur at not more than 15 parts per million is available for carrying out the purposes of the grant; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbff07280-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091a/b/6/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a commitment by the applicant to use that fuel in carrying out the purposes of the grant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff07281-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091a/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deployment and distribution","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator, to the maximum extent practicable, shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbff07282-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091a/b/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" achieve nationwide deployment of clean school buses through the program under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff07283-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091a/b/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure a broad geographic distribution of grant awards, with no State receiving more than 10 percent of the grant funding made available under this section during a fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff07284-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091a/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbff07285-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091a/b/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"sup","attrib":{},"text":"2","children":[],"tail":" In general"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than January 31 of each year, the Administrator shall submit to Congress a report that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbff07286-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091a/b/8/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluates the implementation of this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbff07287-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091a/b/8/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" describes—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbff07288-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091a/b/8/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total number of grant applications received;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbff07289-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091a/b/8/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number and types of alternative fuel school buses, ultra-low sulfur diesel fuel school buses, and retrofitted buses requested in grant applications;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbff0728a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091a/b/8/A/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" grants awarded and the criteria used to select the grant recipients;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbff0728b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091a/b/8/A/ii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" certified engine emission levels of all buses purchased or retrofitted under this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbff0728c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091a/b/8/A/ii/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an evaluation of the in-use emission level of buses purchased or retrofitted under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbff0728d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091a/b/8/A/ii/VI"},"text":null,"children":[{"tag":"num","attrib":{"value":"VI"},"text":"(VI)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other information the Administrator considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff0728e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Education","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbff0728f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"2005-08-10"},"text":"August 10, 2005","children":[],"tail":", the Administrator shall develop an education outreach program to promote and explain the grant program."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff07290-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with stakeholders","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The outreach program shall be designed and conducted in conjunction with national school bus transportation associations and other stakeholders.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff07291-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Components","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The outreach program shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbff07292-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091a/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inform potential grant recipients on the process of applying for grants;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff07293-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091a/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describe the available technologies and the benefits of the technologies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff07294-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091a/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" explain the benefits of participating in the grant program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff07295-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091a/c/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include, as appropriate, information from the annual report required under subsection (b)(8).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff07296-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated to the Administrator to carry out this section, to remain available until expended—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbff07297-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $55,000,000 for each of fiscal years 2006 and 2007; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff07298-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such sums as are necessary for each of fiscal years 2008, 2009, and 2010.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbff07299-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/tVI/s6015"},"text":"Pub. L. 109–59, title VI, § 6015","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-10"},"text":"Aug. 10, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1884"},"text":"119 Stat. 1884","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbff0729a-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbff0729b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbff0729c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Safe, Accountable, Flexible, Efficient Transportation Equity Act: A Legacy for Users or the SAFETEA–LU, and not as part of the Energy Policy Act of 2005 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
