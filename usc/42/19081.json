{"tag":"section","attrib":{"id":"idc07866c3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19081"},"text":null,"children":[{"tag":"num","attrib":{"value":"19081"},"text":"§ 19081.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Facility operation and maintenance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc07866c4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19081/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall continue the Facility Operation Transition pilot program for a total of 5 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc07866c5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19081/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost sharing","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Facility Operation Transition program shall provide funding for 10 to 50 percent of the operations and maintenance costs for major research facilities that are within the first five years of operation, where the share is determined based on—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc07866c6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19081/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the operations and maintenance costs of the major research facility; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc07866c7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19081/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the capacity of the managing directorate or division to absorb such costs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc07866c8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19081/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"After the fifth year of the pilot program, the Director shall transmit a report to Congress that includes—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc07866c9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19081/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an assessment, that includes feedback from the research community, of the effectiveness of the pilot program for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc07866ca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19081/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supporting research directorates and divisions in balancing investments in research grants and funding for the initial operation and maintenance of major facilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc07866cb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19081/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" incentivizing the development of new world-class facilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc07866cc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19081/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitating interagency and international partnerships;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc07866cd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19081/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" funding core elements of multi-disciplinary facilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc07866ce-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19081/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supporting facility divestment costs; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc07866cf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19081/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if deemed effective, a plan for permanent implementation of the pilot program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc07866d0-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/tIII/s10371"},"text":"Pub. L. 117–167, div. B, title III, § 10371","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1570"},"text":"136 Stat. 1570","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
