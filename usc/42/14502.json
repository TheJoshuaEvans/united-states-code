{"tag":"section","attrib":{"id":"idbfcf0783-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14502"},"text":null,"children":[{"tag":"num","attrib":{"value":"14502"},"text":"§ 14502.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preemption and election of State nonapplicability","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfcf0784-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14502/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preemption","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This chapter preempts the laws of any State to the extent that such laws are inconsistent with this chapter, except that this chapter shall not preempt any State law that provides additional protection from liability relating to volunteers or to any category of volunteers in the performance of services for a nonprofit organization or governmental entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfcf0785-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14502/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election of State regarding nonapplicability","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"This chapter shall not apply to any civil action in a State court against a volunteer in which all parties are citizens of the State if such State enacts a statute in accordance with State requirements for enacting legislation—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfcf0786-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14502/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" citing the authority of this subsection;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfcf0787-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14502/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" declaring the election of such State that this chapter shall not apply, as of a date certain, to such civil action in the State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfcf0788-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14502/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" containing no other provisions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfcf0789-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/19/s3"},"text":"Pub. L. 105–19, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-06-18"},"text":"June 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/219"},"text":"111 Stat. 219","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
