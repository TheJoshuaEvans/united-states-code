],"tail":null},{"tag":"content","attrib":{},"text":" the term “Advisory Committee” means the Advisory Committee on Reactor Safeguards established by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2039"},"text":"section 2039 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbed983f5-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/567/s3"},"text":"Pub. L. 96–567, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-22"},"text":"Dec. 22, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3329"},"text":"94 Stat. 3329","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
