{"tag":"section","attrib":{"id":"idbdfba6e8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7256c"},"text":null,"children":[{"tag":"num","attrib":{"value":"7256c"},"text":"§ 7256c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Milestone-based demonstration projects","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbdfba6e9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7256c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Acting under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7256/g"},"text":"section 7256(g) of this title","children":[],"tail":", notwithstanding paragraph (10) of such section, the Secretary of Energy (in this section referred to as the “Secretary”) may carry out demonstration projects as a milestone-based demonstration project that requires particular technical and financial milestones to be met before a participant is awarded grants by the Department through a competitive award process."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdfba6ea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7256c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out milestone-based demonstration projects under the authority in paragraph (1), the Secretary shall, for each relevant project—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbdfba6eb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7256c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" request proposals from eligible entities, as determined by the Secretary, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbdfba6ec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7256c/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a business plan, that may include a plan for scalable manufacturing and a plan for addressing supply chain gaps;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbdfba6ed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7256c/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a plan for raising private sector investment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbdfba6ee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7256c/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" proposed technical and financial milestones, including estimated project timelines and total costs; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdfba6ef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7256c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" award funding of a predetermined amount to projects that successfully meet proposed milestones under paragraph (1)(C) or for expenses deemed reimbursable by the Secretary, in accordance with terms negotiated for an individual award;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdfba6f0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7256c/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require cost sharing in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16352"},"text":"section 16352 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdfba6f1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7256c/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" communicate regularly with selected eligible entities and, if the Secretary deems appropriate, exercise small amounts of flexibility for technical and financial milestones as projects mature.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdfba6f2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7256c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Awards","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the program established under subsection (a)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbdfba6f3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7256c/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an award recipient shall be responsible for all costs until milestones are achieved, or reimbursable expenses are reviewed and verified by the Department; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdfba6f4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7256c/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" should an awardee not meet the milestones described in subsection (a), the Secretary or their designee may end the partnership with an award recipient and use the remaining funds in the ended agreement for new or existing projects carried out under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdfba6f5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7256c/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Project management","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out projects under this program and assessing the completion of their milestones in accordance with subsection (b), the Secretary shall consult with experts that represent diverse perspectives and professional experiences, including those from the private sector, to ensure a complete and thorough review.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdfba6f6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7256c/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16391a/a"},"text":"section 16391a(a) of this title","children":[],"tail":", the Secretary shall report annually on any demonstration projects carried out using the authorities under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbdfba6f7-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dZ/tIX/s9005"},"text":"Pub. L. 116–260, div. Z, title IX, § 9005","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2599"},"text":"134 Stat. 2599","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbdfba6f8-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbdfba6f9-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbdfba6fa-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Energy Act of 2020, and not as part of the Department of Energy Organization Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
