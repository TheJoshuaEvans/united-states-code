b":{"href":"/us/pl/89/290/s4/d"},"text":"Pub. L. 89–290, § 4(d)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/1057"},"text":"79 Stat. 1057","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1966-11-03"},"text":"Nov. 3, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/89/751/s5/c/2"},"text":"Pub. L. 89–751, § 5(c)(2)","children":[],"tail":", (3), "},{"tag":"ref","attrib":{"href":"/us/stat/80/1233"},"text":"80 Stat. 1233","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1968-08-16"},"text":"Aug. 16, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/90/490/tI/s121/c"},"text":"Pub. L. 90–490, title I, § 121(c)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/778"},"text":"82 Stat. 778","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1971-07-09"},"text":"July 9, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/92/52/s1/b"},"text":"Pub. L. 92–52, § 1(b)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/144"},"text":"85 Stat. 144","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1971-11-18"},"text":"Nov. 18, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/92/157/tI/s105/e/2"},"text":"Pub. L. 92–157, title I, § 105(e)(2)","children":[],"tail":", (f)(2), "},{"tag":"ref","attrib":{"href":"/us/stat/85/451"},"text":"85 Stat. 451","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1976-10-12"},"text":"Oct. 12, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/94/484/tIV"},"text":"Pub. L. 94–484, title IV","children":[],"tail":", §§ 405, 406(e), "},{"tag":"ref","attrib":{"href":"/us/stat/90/2267"},"text":"90 Stat. 2267","children":[],"tail":", 2268, which related to the distribution of assets from loan funds, was transferred to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s294p"},"text":"section 294p of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb5deed80-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/136"},"text":"Pub. L. 116–136","children":[],"tail":" amended section generally. Prior to amendment, section consisted of subsecs. (a) to (e) which related to geriatric education centers, geriatric training regarding physicians and dentists, geriatric faculty fellowships, geriatric workforce development, and geriatric career incentive awards, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(7)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Pub. L. 116–260","children":[],"tail":", in introductory provisions, substituted “Coronavirus Aid, Relief, and Economic Security Act” for “Title VII Health Care Workforce Reauthorization Act of 2019” in the original, and accordingly, “the date of enactment of the Coronavirus Aid, Relief, and Economic Security Act” was translated to “"},{"tag":"date","attrib":{"date":"2020-03-27"},"text":"March 27, 2020","children":[],"tail":"”. The Coronavirus Aid, Relief, and Economic Security Act, "},{"tag":"ref","attrib":{"href":"/us/pl/116/136"},"text":"Pub. L. 116–136","children":[],"tail":", was approved "},{"tag":"date","attrib":{"date":"2020-03-27"},"text":"Mar. 27, 2020","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—Subsec. (b)(2)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/256"},"text":"Pub. L. 111–256","children":[],"tail":" substituted “elderly individuals with intellectual disabilities” for “elderly mentally retarded individuals”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2) to (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/s5305/b/2"},"text":"Pub. L. 111–148, § 5305(b)(2)","children":[],"tail":", added pars. (2) to (4) and struck out former pars. (2) and (3) which described eligible individuals and limitations for Geriatric Academic Career Awards. Former par. (4) redesignated (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/s5305/b/1"},"text":"Pub. L. 111–148, § 5305(b)(1)","children":[],"tail":", redesignated par. (4) as (5). Former par. (5) redesignated (6)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(5)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/s5305/b/3/A"},"text":"Pub. L. 111–148, § 5305(b)(3)(A)","children":[],"tail":", inserted “for individuals who are physicians” before “shall equal” and inserted at end “The Secretary shall determine the amount of an Award under this section for individuals who are not physicians.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(5)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/s5305/b/3/B"},"text":"Pub. L. 111–148, § 5305(b)(3)(B)","children":[],"tail":", added subpar. (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/s5305/b/1"},"text":"Pub. L. 111–148, § 5305(b)(1)","children":[],"tail":", redesignated par. (5) as (6)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (d), (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/s5305/a"},"text":"Pub. L. 111–148, § 5305(a)","children":[],"tail":", added subsecs. (d) and (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/205"},"text":"Pub. L. 107–205","children":[],"tail":" substituted “, and "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s296/2"},"text":"section 296(2) of this title","children":[],"tail":",” for “, and "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s298b/2"},"text":"section 298b(2) of this title","children":[],"tail":",”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb5deed81-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb5deed82-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2020 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dBB/tIII/s331/d"},"text":"Pub. L. 116–260, div. BB, title III, § 331(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2938"},"text":"134 Stat. 2938","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/260/dBB/tIII/s331/d"},"text":"“The amendments made by subsections (a), (b), and (c) [amending this section and sections 297n–1 and 297t of this title] shall take effect as if included in the enactment of the Coronavirus Aid, Relief, and Economic Security Act (","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/136"},"text":"Public Law 116–136","children":[],"tail":").”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idb5deed83-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For meaning of references to an intellectual disability and to individuals with intellectual disabilities in provisions amended by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/256/s2"},"text":"section 2 of Pub. L. 111–256","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/111/256/s2/k"},"text":"section 2(k) of Pub. L. 111–256","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1400"},"text":"section 1400 of Title 20","children":[],"tail":", Education."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
