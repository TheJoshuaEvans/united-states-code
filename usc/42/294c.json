{"tag":"section","attrib":{"id":"idb5deed45-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294c"},"text":null,"children":[{"tag":"num","attrib":{"value":"294c"},"text":"§ 294c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Education and training relating to geriatrics","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5deed46-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Geriatrics Workforce Enhancement Program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5deed47-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294c/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall award grants, contracts, or cooperative agreements under this subsection to entities described in paragraph (1), (3), or (4) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s295p"},"text":"section 295p of this title","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s296/2"},"text":"section 296(2) of this title","children":[],"tail":", or "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s298/d"},"text":"section 298(d) of this title","children":[],"tail":", or other health professions schools or programs approved by the Secretary, for the establishment or operation of Geriatrics Workforce Enhancement Programs that meet the requirements of paragraph (2)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5deed48-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294c/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5deed49-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294c/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A Geriatrics Workforce Enhancement Program receiving an award under this section shall support the training of health professionals in geriatrics, including traineeships or fellowships. Such programs shall emphasize, as appropriate, patient and family engagement, integration of geriatrics with primary care and other appropriate specialties, and collaboration with community partners to address gaps in health care for older adults.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5deed4a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294c/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Activities conducted by a program under this section may include the following:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb5deed4b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294c/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Clinical training on providing integrated geriatrics and primary care delivery services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5deed4c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294c/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Interprofessional training to practitioners from multiple disciplines and specialties, including training on the provision of care to older adults.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5deed4d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294c/a/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Establishing or maintaining training-related community-based programs for older adults and caregivers to improve health outcomes for older adults.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5deed4e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294c/a/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Providing education on Alzheimer’s disease and related dementias to families and caregivers of older adults, direct care workers, and health professions students, faculty, and providers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5deed4f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294c/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each grant, contract, or cooperative agreement or contract awarded under paragraph (1) shall be for a period not to exceed 5 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5deed50-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294c/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be eligible to receive a grant, contract, or cooperative agreement under paragraph (1), an entity described in such paragraph shall submit to the Secretary an application at such time, in such manner, and containing such information as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5deed51-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294c/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program requirements","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5deed52-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294c/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In awarding grants, contracts, and cooperative agreements under paragraph (1), the Secretary—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb5deed53-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294c/a/5/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall give priority to programs that demonstrate coordination with another Federal or State program or another public or private entity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5deed54-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294c/a/5/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall give priority to applicants with programs or activities that are expected to substantially benefit rural or medically underserved populations of older adults, or serve older adults in Indian Tribes or Tribal organizations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5deed55-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294c/a/5/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" may give priority to any program that—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb5deed56-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294c/a/5/A/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" integrates geriatrics into primary care practice;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb5deed57-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294c/a/5/A/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides training to integrate geriatric care into other specialties across care settings, including practicing clinical specialists, health care administrators, faculty without backgrounds in geriatrics, and students from all health professions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb5deed58-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294c/a/5/A/iii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" emphasizes integration of geriatric care into existing service delivery locations and care across settings, including primary care clinics, medical homes, Federally qualified health centers, ambulatory care clinics, critical access hospitals, emergency care, assisted living and nursing facilities, and home- and community-based services, which may include adult daycare;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb5deed59-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294c/a/5/A/iii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supports the training and retraining of faculty, primary care providers, other direct care providers, and other appropriate professionals on geriatrics;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb5deed5a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294c/a/5/A/iii/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" emphasizes education and engagement of family caregivers on disease management and strategies to meet the needs of caregivers of older adults; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb5deed5b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294c/a/5/A/iii/VI"},"text":null,"children":[{"tag":"num","attrib":{"value":"VI"},"text":"(VI)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" proposes to conduct outreach to communities that have a shortage of geriatric workforce professionals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5deed5c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294c/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special consideration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In awarding grants, contracts, and cooperative agreements under this section, the Secretary shall give special consideration to entities that provide services in areas with a shortage of geriatric workforce professionals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5deed5d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294c/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may provide awardees with additional support for activities in areas of demonstrated need, which may include education and training for home health workers, family caregivers, and direct care workers on care for older adults.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5deed5e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294c/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5deed5f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294c/a/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports from entities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each entity awarded a grant, contract, or cooperative agreement under this section shall submit an annual report to the Secretary on the activities conducted under such grant, contract, or cooperative agreement, which may include information on the number of trainees, the number of professions and disciplines, the number of partnerships with health care delivery sites, the number of faculty and practicing professionals who participated in such programs, and other information, as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5deed60-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294c/a/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 4 years after ","children":[{"tag":"date","attrib":{"date":"2020-03-27"},"text":"March 27, 2020","children":[],"tail":", and every 5 years thereafter, the Secretary shall submit to the Committee on Health, Education, Labor, and Pensions of the Senate and the Committee on Energy and Commerce of the House of Representatives a report that provides a summary of the activities and outcomes associated with grants, contracts, and cooperative agreements made under this section. Such reports shall include—"}],"tail":null},{"tag":"clause","attrib":{"id":"idb5deed61-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294c/a/7/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information on the number of trainees, faculty, and professionals who participated in programs under this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5deed62-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294c/a/7/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information on the impact of the program conducted under this section on the health status of older adults, including in areas with a shortage of health professionals; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5deed63-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294c/a/7/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information on outreach and education provided under this section to families and caregivers of older adults.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5deed64-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294c/a/7/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall make reports submitted under paragraph (B) publically available on the internet website of the Department of Health and Human Services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5deed65-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Geriatric academic career awards","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5deed66-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall, as appropriate, establish or maintain a program to provide geriatric academic career awards to eligible entities applying on behalf of eligible individuals to promote the career development of such individuals as academic geriatricians or other academic geriatrics health professionals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5deed67-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5deed68-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294c/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection, the term “eligible entity” means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb5deed69-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294c/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an entity described in paragraph (1), (3), or (4) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s295p"},"text":"section 295p of this title","children":[],"tail":" or "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s296/2"},"text":"section 296(2) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5deed6a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294c/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" another accredited health professions school or graduate program approved by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5deed6b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294c/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible individual","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection, the term “eligible individual” means an individual who—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb5deed6c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294c/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb5deed6d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294c/b/2/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is board certified or board eligible in internal medicine, family practice, psychiatry, or licensed dentistry, or has completed required training in a discipline and is employed in an accredited health professions school or graduate program that is approved by the Secretary; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb5deed6e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294c/b/2/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has completed an approved fellowship program in geriatrics, or has completed specialty training in geriatrics as required by the discipline and any additional geriatrics training as required by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5deed6f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294c/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a junior, nontenured, faculty appointment at an accredited health professions school or graduate program in geriatrics or a geriatrics health profession.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5deed70-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294c/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Clarification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If an eligible individual is promoted during the period of an award under this subsection and thereby no longer meets the criteria of subparagraph (B)(ii), the individual shall continue to be treated as an eligible individual through the term of the award.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5deed71-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294c/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In order to receive an award under paragraph (1), an eligible entity, on behalf of an eligible individual, shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5deed72-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294c/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit to the Secretary an application, at such time, in such manner, and containing such information as the Secretary may require;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5deed73-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294c/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide, in such form and manner as the Secretary may require, assurances that the eligible individual will meet the service requirement described in paragraph (6); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5deed74-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294c/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide, in such form and manner as the Secretary may require, assurances that the individual has a full-time faculty appointment in a health professions institution and documented commitment from such eligible entity that the individual will spend 75 percent of the individual’s time that is supported by the award on teaching and developing skills in interdisciplinary education in geriatrics.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5deed75-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294c/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Equitable distribution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In making awards under this subsection, the Secretary shall seek to ensure geographical distribution among award recipients, including among rural or medically underserved areas of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5deed76-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294c/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount and duration","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5deed77-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294c/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of an award under this subsection shall be at least $75,000 for fiscal year 2021, adjusted for subsequent years in accordance with the consumer price index. The Secretary shall determine the amount of an award under this subsection for individuals who are not physicians.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5deed78-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294c/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall make awards under paragraph (1) for a period not to exceed 5 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5deed79-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294c/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Service requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An individual who receives an award under this subsection shall provide training in clinical geriatrics, including the training of interprofessional teams of health care professionals. The provision of such training shall constitute at least 75 percent of the obligations of such individual under the award.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5deed7a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonapplicability of provision","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of this subchapter, ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s295j/a"},"text":"section 295j(a) of this title","children":[],"tail":" shall not apply to awards made under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5deed7b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294c/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated $40,737,000 for each of fiscal years 2021 through 2025 for purposes of carrying out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5deed7c-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title VII, § 753, as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/392/tI/s103"},"text":"Pub. L. 105–392, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3544"},"text":"112 Stat. 3544","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/205/tII/s202/b"},"text":"Pub. L. 107–205, title II, § 202(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-01"},"text":"Aug. 1, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/817"},"text":"116 Stat. 817","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tV/s5305/a"},"text":"Pub. L. 111–148, title V, § 5305(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/622"},"text":"124 Sta