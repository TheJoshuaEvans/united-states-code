{"tag":"section","attrib":{"id":"idbeac3253-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9116"},"text":null,"children":[{"tag":"num","attrib":{"value":"9116"},"text":"§ 9116.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Diligence requirements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbeac3254-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9116/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules and regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall promulgate regulations requiring each licensee to pursue diligently the construction and operation of the ocean thermal energy conversion facility or plantship to which the license applies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbeac3255-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9116/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of license","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Administrator determines that a licensee is not pursuing diligently the construction and operation of the ocean thermal energy conversion facility or plantship to which the license applies, or that the project has apparently been abandoned, the Administrator shall cause proceedings to be instituted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s9121"},"text":"section 9121 of this title","children":[],"tail":" to terminate the license."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbeac3256-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/320/tI/s106"},"text":"Pub. L. 96–320, title I, § 106","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-08-03"},"text":"Aug. 3, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/984"},"text":"94 Stat. 984","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
