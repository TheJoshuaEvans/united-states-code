{"tag":"section","attrib":{"id":"idc0203556-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17051"},"text":null,"children":[{"tag":"num","attrib":{"value":"17051"},"text":"§ 17051.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Renewable fuel dispenser requirements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc0203557-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17051/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Market penetration reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in consultation with the Secretary of Transportation, shall determine and report to Congress annually on the market penetration for flexible-fuel vehicles in use within geographic regions to be established by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0203558-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17051/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dispenser feasibility study","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 24 months after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"December 19, 2007","children":[],"tail":", the Secretary, in consultation with the Department of Transportation, shall report to the Congress on the feasibility of requiring motor fuel retailers to install E–85 compatible dispensers and related systems at retail fuel facilities in regions where flexible-fuel vehicle market penetration has reached 15 percent of motor vehicles. In conducting such study, the Secretary shall consider and report on the following factors:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0203559-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17051/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The commercial availability of E–85 fuel and the number of competing E–85 wholesale suppliers in a given region.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc020355a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17051/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The level of financial assistance provided on an annual basis by the Federal Government, State governments, and nonprofit entities for the installation of E–85 compatible infrastructure.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc020355b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17051/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of retailers whose retail locations are unable to support more than 2 underground storage tank dispensers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc020355c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17051/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The expense incurred by retailers in the installation and sale of E–85 compatible dispensers and related systems and any potential effects on the price of motor vehicle fuel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc020355d-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/tII/s242"},"text":"Pub. L. 110–140, title II, § 242","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1540"},"text":"121 Stat. 1540","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc020355e-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc020355f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc0203560-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the date that is 1 day after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/s1601"},"text":"section 1601 of Pub. L. 110–140","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1824"},"text":"section 1824 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
