{"tag":"section","attrib":{"id":"idbf38e192-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11046"},"text":null,"children":[{"tag":"num","attrib":{"value":"11046"},"text":"§ 11046.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil actions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf38e193-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11046/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to bring civil actions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf38e194-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11046/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Citizen suits","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subsection (e), any person may commence a civil action on his own behalf against the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf38e195-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11046/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An owner or operator of a facility for failure to do any of the following:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbf38e196-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11046/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Submit a followup emergency notice under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11004/c"},"text":"section 11004(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf38e197-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11046/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Submit a material safety data sheet or a list under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11021/a"},"text":"section 11021(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf38e198-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11046/a/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Complete and submit an inventory form under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11022/a"},"text":"section 11022(a) of this title","children":[],"tail":" containing tier I information as described in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s11022/d/1"},"text":"section 11022(d)(1) of this title","children":[],"tail":" unless such requirement does not apply by reason of the second sentence of "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s11022/a/2"},"text":"section 11022(a)(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf38e199-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11046/a/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Complete and submit a toxic chemical release form under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11023/a"},"text":"section 11023(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf38e19a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11046/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Administrator for failure to do any of the following:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbf38e19b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11046/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Publish inventory forms under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11022/g"},"text":"section 11022(g) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf38e19c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11046/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Respond to a petition to add or delete a chemical under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11023/e/1"},"text":"section 11023(e)(1) of this title","children":[],"tail":" within 180 days after receipt of the petition."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf38e19d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11046/a/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Publish a toxic chemical release form under 11023(g) ","children":[{"tag":"ref","attrib":{"idref":"fn003986"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003986"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be preceded by “section”."}],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf38e19e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11046/a/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Establish a computer database in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11023/j"},"text":"section 11023(j) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf38e19f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11046/a/1/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Promulgate trade secret regulations under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11042/c"},"text":"section 11042(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf38e1a0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11046/a/1/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Render a decision in response to a petition under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11042/d"},"text":"section 11042(d) of this title","children":[],"tail":" within 9 months after receipt of the petition."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf38e1a1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11046/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Administrator, a State Governor, or a State emergency response commission, for failure to provide a mechanism for public availability of information in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11044/a"},"text":"section 11044(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf38e1a2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11046/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A State Governor or a State emergency response commission for failure to respond to a request for tier II information under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11022/e/3"},"text":"section 11022(e)(3) of this title","children":[],"tail":" within 120 days after the date of receipt of the request."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf38e1a3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11046/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State or local suits","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf38e1a4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11046/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Any State or local government may commence a civil action against an owner or operator of a facility for failure to do any of the following:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbf38e1a5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11046/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Provide notification to the emergency response commission in the State under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11002/c"},"text":"section 11002(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf38e1a6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11046/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Submit a material safety data sheet or a list under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11021/a"},"text":"section 11021(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf38e1a7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11046/a/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Make available information requested under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11021/c"},"text":"section 11021(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf38e1a8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11046/a/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Complete and submit an inventory form under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11022/a"},"text":"section 11022(a) of this title","children":[],"tail":" containing tier I information unless such requirement does not apply by reason of the second sentence of "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s11022/a/2"},"text":"section 11022(a)(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf38e1a9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11046/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any State emergency response commission or local emergency planning committee may commence a civil action against an owner or operator of a facility for failure to provide information under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11003/d"},"text":"section 11003(d) of this title","children":[],"tail":" or for failure to submit tier II information under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s11022/e/1"},"text":"section 11022(e)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf38e1aa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11046/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any State may commence a civil action against the Administrator for failure to provide information to the State under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11042/g"},"text":"section 11042(g) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf38e1ab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11046/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Venue","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf38e1ac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11046/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any action under subsection (a) against an owner or operator of a facility shall be brought in the district court for the district in which the alleged violation occurred.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf38e1ad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11046/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any action under subsection (a) against the Administrator may be brought in the United States District Court for the District of Columbia.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf38e1ae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11046/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relief","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The district court shall have jurisdiction in actions brought under subsection (a) against an owner or operator of a facility to enforce the requirement concerned and to impose any civil penalty provided for violation of that requirement. The district court shall have jurisdiction in actions brought under subsection (a) against the Administrator to order the Administrator to perform the act or duty concerned.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf38e1af-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11046/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf38e1b0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11046/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No action may be commenced under subsection (a)(1)(A) prior to 60 days after the plaintiff has given notice of the alleged violation to the Administrator, the State in which the alleged violation occurs, and the alleged violator. Notice under this paragraph shall be given in such manner as the Administrator shall prescribe by regulation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf38e1b1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11046/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No action may be commenced under subsection (a)(1)(B) or (a)(1)(C) prior to 60 days after the date on which the plaintiff gives notice to the Administrator, State Governor, or State emergency response commission (as the case may be) that the plaintiff will commence the action. Notice under this paragraph shall be given in such manner as the Administrator shall prescribe by regulation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf38e1b2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11046/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No action may be commenced under subsection (a) against an owner or operator of a facility if the Administrator has commenced and is diligently pursuing an administrative order or civil action to enforce the requirement concerned or to impose a civil penalty under this Act with respect to the violation of the requirement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf38e1b3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11046/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The court, in issuing any final order in any action brought pursuant to this section, may award costs of litigation (including reasonable attorney and expert witness fees) to the prevailing or the substantially prevailing party whenever the court determines such an award is appropriate. The court may, if a temporary restraining order or preliminary injunction is sought, require the filing of a bond or equivalent security in accordance with the Federal Rules of Civil Procedure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf38e1b4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11046/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other rights","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall restrict or expand any right which any person (or class of persons) may have under any Federal or State statute or common law to seek enforcement of any requirement or to seek any other relief (including relief against the Administrator or a State agency).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf38e1b5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11046/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Intervention","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf38e1b6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11046/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" By the United States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In any action under this section the United States or the State, or both, if not a party, may intervene as a matter of right.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf38e1b7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11046/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" By persons","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In any action under this section, any person may intervene as a matter of right when such person has a direct interest which is or may be adversely affected by the action and the disposition of the action may, as a practical matter, impair or impede the person’s ability to protect that interest unless the Administrator or the State shows that the person’s interest is adequately represented by existing parties in the action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf38e1b8-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/499/tIII/s326"},"text":"Pub. L. 99–499, title III, § 326","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-17"},"text":"Oct. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1755"},"text":"100 Stat. 1755","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf38e1b9-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf38e1ba-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbf38e1bb-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in subsec. (e), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/499"},"text":"Pub. L. 99–499","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-17"},"text":"Oct. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1613"},"text":"100 Stat. 1613","children":[],"tail":", known as the Superfund Amendments and Reauthorization Act of 1986. For complete classification of this Act to the Code, see Short Title of 1986 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s9601"},"text":"section 9601 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Federal Rules of Civil Procedure, referred to in subsec. (f), are set out in the Appendix to Title 28, Judiciary and Judicial Procedure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
