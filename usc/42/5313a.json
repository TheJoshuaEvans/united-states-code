{"tag":"section","attrib":{"id":"idbd4687c6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5313a"},"text":null,"children":[{"tag":"num","attrib":{"value":"5313a"},"text":"§ 5313a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duplication of benefits","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish procedures to prevent recipients from receiving any duplication of benefits and report annually to the Committees on Appropriations with regard to all steps taken to prevent fraud and abuse of funds made available under this heading including duplication of benefits.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbd4687c7-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/329/dB/tI"},"text":"Pub. L. 110–329, div. B, title I","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-09-30"},"text":"Sept. 30, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3601"},"text":"122 Stat. 3601","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/76/dL/tII/s236"},"text":"Pub. L. 113–76, div. L, title II, § 236","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-01-17"},"text":"Jan. 17, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/635"},"text":"128 Stat. 635","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd4687c8-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd4687c9-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbd4687ca-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This heading, referred to in text, refers to the headings “","children":[{"tag":"inline","attrib":{},"text":"Community Planning and Development","children":[],"tail":"” and “"},{"tag":"inline","attrib":{},"text":"community development fund","children":[],"tail":"” of title I of div. B of "},{"tag":"ref","attrib":{"href":"/us/pl/110/329"},"text":"Pub. L. 110–329","children":[],"tail":", known as the Disaster Relief and Recovery Supplemental Appropriations Act, 2008."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbd4687cb-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Disaster Relief and Recovery Supplemental Appropriations Act, 2008, and also as part of the Consolidated Security, Disaster Assistance, and Continuing Appropriations Act, 2009, and not as part of title I of the Housing and Community Development Act of 1974 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbd4687cc-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"similarProvisions","id":"idbd4687cd-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Similar Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Similar provisions were contained in the following prior appropriation acts:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/252/tIII