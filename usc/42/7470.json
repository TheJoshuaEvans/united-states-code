{"tag":"section","attrib":{"id":"idbe302478-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7470"},"text":null,"children":[{"tag":"num","attrib":{"value":"7470"},"text":"§ 7470.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional declaration of purpose","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purposes of this part are as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe302479-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7470/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to protect public health and welfare from any actual or potential adverse effect which in the Administrator’s judgment may reasonably be anticipate ","children":[{"tag":"ref","attrib":{"idref":"fn003626"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003626"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “anticipated”."}],"tail":" to occur from air pollution or from exposures to pollutants in other media, which pollutants originate as emissions to the ambient air) "},{"tag":"ref","attrib":{"idref":"fn003627"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003627"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Section was enacted without an opening parenthesis."}],"tail":", notwithstanding attainment and maintenance of all national ambient air quality standards;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe30247a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7470/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to preserve, protect, and enhance the air quality in national parks, national wilderness areas, national monuments, national seashores, and other areas of special national or regional natural, recreational, scenic, or historic value;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe30247b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7470/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to insure that economic growth will occur in a manner consistent with the preservation of existing clean air resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe30247c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7470/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assure that emissions from any source in any State will not interfere with any portion of the applicable implementation plan to prevent significant deterioration of air quality for any other State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe30247d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7470/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assure that any decision to permit increased air pollution in any area to which this section applies is made only after careful evaluation of all the consequences of such a decision and after adequate procedural opportunities for informed public participation in the decisionmaking process.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbe30247e-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1955-07-14/ch360"},"text":"July 14, 1955, ch. 360","children":[],"tail":", title I, § 160, as added "},{"tag":"ref","attrib":{"href":"/us/pl/95/95/tI/s127/a"},"text":"Pub. L. 95–95, title I, § 127(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-08-07"},"text":"Aug. 7, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/731"},"text":"91 Stat. 731","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbe30247f-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbe302480-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbe302481-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Subpart effective ","children":[{"tag":"date","attrib":{"date":"1977-08-07"},"text":"Aug. 7, 1977","children":[],"tail":", except as otherwise expressly provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/95/95/s406/d"},"text":"section 406(d) of Pub. L. 95–95","children":[],"tail":", set out as an Effective Date of 1977 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s7401"},"text":"section 7401 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbe302482-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Guidance Document","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/95/tI/s127/c"},"text":"Pub. L. 95–95, title I, § 127(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-08-07"},"text":"Aug. 7, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/741"},"text":"91 Stat. 741","children":[],"tail":", required Administrator, not later than 1 year after "},{"tag":"date","attrib":{"date":"1977-08-07"},"text":"Aug. 7, 1977","children":[],"tail":", to publish a guidance document to assist States in carrying out their functions under part C of title I of the Clean Air Act (this part) with respect to pollutants for which national ambient air quality standards are promulgated."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbe302483-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Study and Report on Progress Made in Program Relating to Significant Deterioration of Air Quality","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/95/tI/s127/d"},"text":"Pub. L. 95–95, title I, § 127(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-08-07"},"text":"Aug. 7, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/742"},"text":"91 Stat. 742","children":[],"tail":", directed Administrator, not later than 2 years after "},{"tag":"date","attrib":{"date":"1977-08-07"},"text":"Aug. 7, 1977","children":[],"tail":", to complete a study and report to Congress on progress made in carrying out part C of title I of the Clean Air Act (this part) and the problems associated in carrying out such section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
