ildren":[],"tail":null},{"tag":"p","attrib":{},"text":"1989—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239"},"text":"Pub. L. 101–239","children":[],"tail":" substituted “the Vaccine Injury Compensation Trust Fund established under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s9510"},"text":"section 9510 of title 26","children":[],"tail":"” for “the trust fund which has been established to provide compensation under the Program”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/203"},"text":"Pub. L. 100–203","children":[],"tail":" struck out par. (1) designation before “Upon” and struck out par. (2) which read as follows: “In any case in which it deems such action appropriate, a district court of the United States may, after entry of a final judgment providing for compensation to be paid under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300aa–15"},"text":"section 300aa–15 of this title","children":[],"tail":" for a vaccine-related injury or death, refer the record of such proceeding to the Secretary and the Attorney General with such recommendation as the court deems appropriate with respect to the investigation or commencement of a civil action by the Secretary under paragraph (1).”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb679f5fb-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb679f5fc-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1989 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For applicability of amendments by ","children":[{"tag":"ref","attrib":{"href":"/us/