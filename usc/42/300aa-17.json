{"tag":"section","attrib":{"id":"idb679f5f4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300aa–17"},"text":null,"children":[{"tag":"num","attrib":{"value":"300aa–17"},"text":"§ 300aa–17.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subrogation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb679f5f5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300aa–17/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon payment of compensation to any petitioner under the Program, the trust fund which has been established to provide such compensation shall be subrograted ","children":[{"tag":"ref","attrib":{"idref":"fn002405"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002405"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “subrogated”."}],"tail":" to all rights of the petitioner with respect to the vaccine-related injury or death for which compensation was paid, except that the trust fund may not recover under such rights an amount greater than the amount of compensation paid to the petitioner."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb679f5f6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300aa–17/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposition of amounts recovered","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts recovered under subsection (a) shall be collected on behalf of, and deposited in, the Vaccine Injury Compensation Trust Fund established under ","children":[{