{"tag":"section","attrib":{"id":"idbea9c07f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9003"},"text":null,"children":[{"tag":"num","attrib":{"value":"9003"},"text":"§ 9003.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research and development","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbea9c080-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9003/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initiation of research","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall initiate research or accelerate existing research in areas in which the lack of knowledge limits development of ocean thermal energy conversion systems in order to achieve the purposes of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbea9c081-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9003/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluations, tests, and dissemination of information, data, and materials","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall conduct evaluations, arrange for tests, and disseminate to developers information, data, and materials necessary to support the design efforts undertaken pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s9004"},"text":"section 9004 of this title","children":[],"tail":". Specific technical areas to be addressed shall include, but not be limited to—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbea9c082-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9003/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" interface requirements between the platform and cold water pipe;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbea9c083-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9003/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cold water pipe deployment techniques;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbea9c084-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9003/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" heat exchangers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbea9c085-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9003/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" control system simulation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbea9c086-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9003/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" stationkeeping requirements; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbea9c087-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9003/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" energy delivery systems, such as electric cable or energy product transport.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbea9c088-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9003/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consideration of new or improved technologies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall, for the purpose of performing his responsibilities pursuant to this chapter, solicit proposals and evaluate any reasonable new or improved technology, a description of which is submitted to the Secretary in writing, which could lead or contribute to the development of ocean thermal energy conversion system technology.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbea9c089-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/310/s4"},"text":"Pub. L. 96–310, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-07-17"},"text":"July 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/943"},"text":"94 Stat. 943","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
