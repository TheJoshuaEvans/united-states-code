{"tag":"section","attrib":{"id":"idb482b8f5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s238j"},"text":null,"children":[{"tag":"num","attrib":{"value":"238j"},"text":"§ 238j.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation of programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb482b8f6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s238j/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Such portion as the Secretary shall determine, but not less than 0.2 percent nor more than 1 percent, of any amounts appropriated for programs authorized under this chapter shall be made available for the evaluation (directly, or by grants of contracts) of the implementation and effectiveness of such programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb482b8f7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s238j/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report on evaluations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than February 1 of each year, the Secretary shall prepare and submit to the Committee on Labor and Human Resources of the Senate and the Committee on Energy and Commerce of the House of Representatives a report summarizing the findings of the evaluations conducted under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb482b8f8-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", titl