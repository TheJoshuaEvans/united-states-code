{"tag":"section","attrib":{"id":"idb5bd8396-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"290ee–2"},"text":"§ 290ee–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Building communities of recovery","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5bd8397-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–2/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “recovery community organization” means an independent nonprofit organization that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5bd8398-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–2/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" mobilizes resources within and outside of the recovery community, which may include through a peer support network, to increase the prevalence and quality of long-term recovery from substance use disorders; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5bd8399-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–2/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is wholly or principally governed by people in recovery for substance use disorders who reflect the community served.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5bd839a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–2/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants authorized","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall award grants to recovery community organizations to enable such organizations to develop, expand, and enhance recovery services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5bd839b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–2/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal share of the costs of a program funded by a grant under this section may not exceed 85 percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5bd839c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–2/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Grants awarded under subsection (b)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5bd839d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–2/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be used to develop, expand, and enhance community and statewide recovery support services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5bd839e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–2/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" may be used to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5bd839f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–2/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" build connections between recovery networks, including between recovery community organizations and peer support networks, and with other recovery support services, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb5bd83a0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–2/d/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" behavioral health providers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5bd83a1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–2/d/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" primary care providers and physicians;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5bd83a2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–2/d/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" educational and vocational schools;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5bd83a3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–2/d/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" employers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5bd83a4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–2/d/2/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" housing services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5bd83a5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–2/d/2/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" child welfare agencies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5bd83a6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–2/d/2/A/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other recovery support services that facilitate recovery from substance use disorders, including non-clinical community services;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5bd83a7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–2/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reduce stigma associated with substance use disorders; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5bd83a8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–2/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" conduct outreach on issues relating to substance use disorders and recovery, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb5bd83a9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–2/d/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying the signs of substance use disorder;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5bd83aa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–2/d/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the resources available to individuals with substance use disorder and to families of an individual with a substance use disorder, including programs that mentor and provide support services to children;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5bd83ab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–2/d/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the resources available to help support individuals in recovery; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5bd83ac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–2/d/2/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" related medical outcomes of substance use disorders, the potential of acquiring an infection commonly associated with illicit drug use, and neonatal abstinence syndrome among infants exposed to opioids during pregnancy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5bd83ad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–2/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special consideration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out this section, the Secretary shall give special consideration to the unique needs of rural areas, including areas with an age-adjusted rate of drug overdose deaths that is above the national average and areas with a shortage of prevention and treatment services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5bd83ae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–2/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this section $17,000,000 for each of fiscal years 2026 through 2030.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5bd83af-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title V, § 547, as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/198/tIII/s302"},"text":"Pub. L. 114–198, title III, § 302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-07-22"},"text":"July 22, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/719"},"text":"130 Stat. 719","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/271/tVII/s7151"},"text":"Pub. L. 115–271, title VII, § 7151","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-24"},"text":"Oct. 24, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4057"},"text":"132 Stat. 4057","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/44/tIII/s301"},"text":"Pub. L. 119–44, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-01"},"text":"Dec. 1, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/684"},"text":"139 Stat. 684","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb5bd83b0-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb5bd83b1-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb5bd83b2-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 290ee–2, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373/tV/s547"},"text":"act July 1, 1944, ch. 373, title V, § 547","children":[],"tail":", formerly "},{"tag":"ref","attrib":{"href":"/us/pl/92/255/tIV/s407"},"text":"Pub. L. 92–255, title IV, § 407","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-03-21"},"text":"Mar. 21, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/78"},"text":"86 Stat. 78","children":[],"tail":", as amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/237/s6/a"},"text":"Pub. L. 94–237, § 6(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-03-19"},"text":"Mar. 19, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/244"},"text":"90 Stat. 244","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/581/tI/s111/c/2"},"text":"Pub. L. 94–581, title I, § 111(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2852"},"text":"90 Stat. 2852","children":[],"tail":"; renumbered § 526 of act "},{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-04-26"},"text":"Apr. 26, 1983","children":[],"tail":". "},{"tag":"ref","attrib":{"href":"/us/pl/98/24/s2/b/16/B"},"text":"Pub. L. 98–24, § 2(b)(16)(B)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/182"},"text":"97 Stat. 182","children":[],"tail":"; renumbered § 547, "},{"tag":"date","attrib":{"date":"1987-07-22"},"text":"July 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/100/77/tVI/s611/2"},"text":"Pub. L. 100–77, title VI, § 611(2)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/516"},"text":"101 Stat. 516","children":[],"tail":", which related to admission of drug abusers to private and public hospitals, was omitted in the general revision of this part by "},{"tag":"ref","attrib":{"href":"/us/pl/102/321"},"text":"Pub. L. 102–321","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb5bd83b3-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/44"},"text":"Pub. L. 119–44","children":[],"tail":" substituted “$17,000,000 for each of fiscal years 2026 through 2030” for “$5,000,000 for each of fiscal years 2019 through 2023”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/271"},"text":"Pub. L. 115–271","children":[],"tail":" amended section generally. Prior to amendment, section authorized the Secretary to award grants to recovery community organizations to enable such organizations to develop, expand, and enhance recovery services, set the Federal share of program costs at no more than 50 percent, and appropriated $1,000,000 for each of fiscal years 2017 through 2021."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
