{"tag":"section","attrib":{"id":"idbff2e40d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16133"},"text":null,"children":[{"tag":"num","attrib":{"value":"16133"},"text":"§ 16133.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State grant, rebate, and loan programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbff2e40e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16133/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the availability of adequate appropriations, the Administrator shall use 30 percent of the funds made available for a fiscal year under this part to support grant, rebate, and loan programs administered by States that are designed to achieve significant reductions in diesel emissions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff2e40f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16133/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbff2e410-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16133/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide to States guidance for use in applying for grant, rebate, or loan funds under this section, including information regarding—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbff2e411-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16133/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the process and forms for applications;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff2e412-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16133/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" permissible uses of funds received; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff2e413-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16133/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cost-effectiveness of various emission reduction technologies eligible to be carried out using funds provided under this section; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff2e414-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16133/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" establish, for applications described in paragraph (1)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbff2e415-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16133/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an annual deadline for submission of the applications;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff2e416-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16133/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a process by which the Administrator shall approve or disapprove each application; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff2e417-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16133/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a streamlined process by which a State may renew an application described in paragraph (1) for subsequent fiscal years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff2e418-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16133/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation of funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbff2e419-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16133/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For each fiscal year, the Administrator shall allocate among States for which applications are approved by the Administrator under subsection (b)(2)(B) funds made available to carry out this section for the fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff2e41a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16133/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbff2e41b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16133/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subparagraphs (B) and (C), using not more than 20 percent of the funds made available to carry out this part for a fiscal year, the Administrator shall provide to each State qualified for an allocation for the fiscal year an allocation equal to ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":"⁄"},{"tag":"sub","attrib":{},"text":"53","children":[],"tail":" of the funds made available for that fiscal year for distribution to States under this paragraph."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff2e41c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16133/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain territories","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbff2e41d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16133/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in clause (ii), Guam, the United States Virgin Islands, American Samoa, and the Commonwealth of the Northern Mariana Islands shall collectively receive an allocation equal to ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":"⁄"},{"tag":"sub","attrib":{},"text":"53","children":[],"tail":" of the funds made available for that fiscal year for distribution to States under this subsection, divided equally among those 4 States."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbff2e41e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16133/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If any State described in clause (i) does not qualify for an allocation under this paragraph, the share of funds otherwise allocated for that State under clause (i) shall be reallocated pursuant to subparagraph (C).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff2e41f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16133/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reallocation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If any State does not qualify for an allocation under this paragraph, the share of funds otherwise allocated for that State under this paragraph shall be reallocated to each remaining qualified State in an amount equal to the product obtained by multiplying—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbff2e420-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16133/c/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the proportion that the population of the State bears to the population of all States described in paragraph (1); by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbff2e421-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16133/c/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount otherwise allocatable to the nonqualifying State under this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff2e422-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16133/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State matching incentive","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbff2e423-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16133/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a State agrees to match the allocation provided to the State under paragraph (2) for a fiscal year, the Administrator shall provide to the State for the fiscal year an additional amount equal to 50 percent of the allocation of the State under paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff2e424-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16133/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A State—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbff2e425-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16133/c/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not use funds received under this part to pay a matching share required under this subsection; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbff2e426-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16133/c/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not be required to provide a matching share for any additional amount received under subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff2e427-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16133/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unclaimed funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any funds that are not claimed by a State for a fiscal year under this subsection shall be used to carry out ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16132"},"text":"section 16132 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff2e428-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16133/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbff2e429-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16133/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraphs (2) and (3) and, to the extent practicable, the priority areas listed in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16132/c/3"},"text":"section 16132(c)(3) of this title","children":[],"tail":", a State shall use any funds provided under this section to develop and implement such grant, rebate, and low-cost revolving loan programs in the State as are appropriate to meet State needs and goals relating to the reduction of diesel emissions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff2e42a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16133/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Apportionment of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The chief executive of a State that receives funding under this section may determine the portion of funds to be provided as grants, rebates, or loans.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff2e42b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16133/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A grant, rebate, or loan provided under this section shall be used for a project relating to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbff2e42c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16133/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a certified engine configuration; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff2e42d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16133/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a verified technology.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff2e42e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16133/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In providing grants, rebates, and loans under this section, a State shall use the priorities in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16132/c/4"},"text":"section 16132(c)(4) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff2e42f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16133/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public notification","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 60 days after the date of the award of a grant, rebate, or loan by a State, the State shall publish on the Web site of the State—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbff2e430-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16133/d/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for rebates, grants, and loans provided to the owner of a diesel vehicle or fleet, the total number and dollar amount of rebates, grants, or loans provided, as well as a breakdown of the technologies funded through the rebates, grants, or loans; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff2e431-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16133/d/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for other rebates, grants, and loans, a description of each application for which the grant, rebate, or loan is provided.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbff2e432-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tVII/s793"},"text":"Pub. L. 109–58, title VII, § 793","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/841"},"text":"119 Stat. 841","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/255/s3/b"},"text":"Pub. L. 110–255, § 3(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-06-30"},"text":"June 30, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2424"},"text":"122 Stat. 2424","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/364/s2/c"},"text":"Pub. L. 111–364, § 2(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4059"},"text":"124 Stat. 4059","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbff2e433-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbff2e434-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbff2e435-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2011—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/364/s2/c/1"},"text":"Pub. L. 111–364, § 2(c)(1)","children":[],"tail":", inserted “, rebate,” after “grant” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/364/s2/c/2"},"text":"Pub. L. 111–364, § 2(c)(2)","children":[],"tail":", inserted “, rebate,” after “grant”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/364/s2/c/3"},"text":"Pub. L. 111–364, § 2(c)(3)","children":[],"tail":", inserted “, rebate,” after “grant” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/364/s2/c/4"},"text":"Pub. L. 111–364, § 2(c)(4)","children":[],"tail":", amended par. (2) generally. Prior to amendment, par. (2) related to allocation of funds."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/364/s2/c/5/A"},"text":"Pub. L. 111–364, § 2(c)(5)(A)","children":[],"tail":", inserted “, rebate,” after “grant”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/364/s2/c/5/B"},"text":"Pub. L. 111–364, § 2(c)(5)(B)","children":[],"tail":", inserted “, rebates,” after “grants”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/364/s2/c/5/C"},"text":"Pub. L. 111–364, § 2(c)(5)(C)","children":[],"tail":", substituted “grant, rebate, or loan provided under this section shall be used” for “grant or loan provided under this section may be used” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(4), (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/364/s2/c/5/D"},"text":"Pub. L. 111–364, § 2(c)(5)(D)","children":[],"tail":", added pars. (4) and (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (c)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/255/s3/b/2"},"text":"Pub. L. 110–255, § 3(b)(2)","children":[],"tail":", substituted “51” for “50” and “1.96 percent” for “2 percent”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/255/s3