{"tag":"section","attrib":{"id":"idbc5808eb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3030d–21"},"text":null,"children":[{"tag":"num","attrib":{"value":"3030d–21"},"text":"§ 3030d–21.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purposes of this part are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc5808ec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3030d–21/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to reduce hunger, food insecurity, and malnutrition;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc5808ed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3030d–21/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to promote socialization of older individuals; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc5808ee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3030d–21/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to promote the health and well-being of older individuals by assisting such individuals to gain access to nutrition and other disease prevention and health promotion services to delay the onset of adverse health conditions resulting from poor nutritional health or sedentary behavior.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc5808ef-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/73/tIII/s330"},"text":"Pub. L. 89–73, title III, § 330","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/365/tIII/s312"},"text":"Pub. L. 109–365, title III, 