{"tag":"section","attrib":{"id":"idb5cbdb1d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s291j–8"},"text":null,"children":[{"tag":"num","attrib":{"value":"291j–8"},"text":"§ 291j–8.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In order to assist in the provision of adequate emergency room service in various communities of the Nation for treatment of accident victims and handling of other medical emergencies through special project grants for the construction or modernization of emergency rooms of general hospitals, there are authorized to be appropriated $20,000,000 each for the fiscal year ending ","children":[{"tag":"date","attrib":{"date":"1971-06-30"},"text":"June 30, 1971","children":[],"tail":", and the next two fiscal years."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb5cbdb1e-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title VI, § 631, as added "},{"tag":"ref","attrib":{"href":"/us/pl/91/296/tIII/s301"},"text":"Pub. L. 91–296, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-06-30"},"text":"June 30, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/351"},"text":"84 Stat. 351","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
