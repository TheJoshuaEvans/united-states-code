{"tag":"section","attrib":{"id":"idbd1df0a8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189e"},"text":null,"children":[{"tag":"num","attrib":{"value":"5189e"},"text":"§ 5189e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Essential service providers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd1df0a9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “essential service provider” means an entity that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd1df0aa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189e/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd1df0ab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189e/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provides","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbd1df0ac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189e/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" wireline or mobile telephone service, Internet access service, radio or television broadcasting, cable service, or direct broadcast satellite service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd1df0ad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189e/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" electrical power;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd1df0ae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189e/a/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" natural gas;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd1df0af-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189e/a/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" water and sewer services; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd1df0b0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189e/a/1/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other essential service, as determined by the President; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd1df0b1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189e/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a tower owner or operator;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd1df0b2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189e/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd1df0b3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189e/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a municipal entity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd1df0b4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189e/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a nonprofit entity; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd1df0b5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189e/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a private, for profit entity; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd1df0b6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189e/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is contributing to efforts to respond to an emergency or major disaster.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd1df0b7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization for accessibility","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Unless exceptional circumstances apply, in an emergency or major disaster, the head of a Federal agency, to the greatest extent practicable, shall not—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd1df0b8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189e/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deny or impede access to the disaster site to an essential service provider whose access is necessary to restore and repair an essential service; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd1df0b9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189e/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" impede the restoration or repair of the services described in subsection (a)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd1df0ba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189e/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In implementing this section, the head of a Federal agency shall follow all applicable Federal laws, regulations, and policies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd1df0bb-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/288/tIV/s427"},"text":"Pub. L. 93–288, title IV, § 427","children":[],"tail":", formerly § 425, as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/347/tVI/s607"},"text":"Pub. L. 109–347, title VI, § 607","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-13"},"text":"Oct. 13, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1941"},"text":"120 Stat. 1941","children":[],"tail":"; renumbered § 427, "},{"tag":"ref","attrib":{"href":"/us/pl/113/2/dB/s1102/1"},"text":"Pub. L. 113–2, div. B, § 1102(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-29"},"text":"Jan. 29, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/39"},"text":"127 Stat. 39","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dP/tIII/s302"},"text":"Pub. L. 115–141, div. P, title III, § 302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1087"},"text":"132 Stat. 1087","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd1df0bc-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd1df0bd-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd1df0be-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141"},"text":"Pub. L. 115–141","children":[],"tail":" designated existing provisions as subpar. (A), redesignated former subpars. (A) to (E) as cls. (i) to (v), respectively, of subpar. (A), substituted “wireline or mobile telephone service, Internet access service, radio or television broadcasting, cable service, or direct broadcast satellite service” for “telecommunications service” in cl. (i), and added subpar. (B)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
