{"tag":"section","attrib":{"id":"idb6cd6bf6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–10b"},"text":null,"children":[{"tag":"num","attrib":{"value":"300hh–10b"},"text":"§ 300hh–10b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Advisory Committee on Children and Disasters","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb6cd6bf7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–10b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in consultation with the Secretary of Homeland Security, shall establish an advisory committee to be known as the “National Advisory Committee on Children and Disasters” (referred to in this section as the “Advisory Committee”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6cd6bf8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–10b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Advisory Committee shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6cd6bf9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–10b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide advice and consultation with respect to the activities carried out pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300hh–16"},"text":"section 300hh–16 of this title","children":[],"tail":", as applicable and appropriate;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6cd6bfa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–10b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluate and provide input with respect to the medical, mental, behavioral, developmental, and public health needs of children as they relate to preparation for, response to, and recovery from all-hazards emergencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6cd6bfb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–10b/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide advice and consultation with respect to State emergency preparedness and response activities and children, including related drills and exercises pursuant to the preparedness goals under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300hh–1/b"},"text":"section 300hh–1(b) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6cd6bfc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–10b/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide advice and consultation with respect to continuity of care and education for all children and supporting parents and caregivers during all-hazards emergencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6cd6bfd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–10b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional duties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Advisory Committee may provide advice and recommendations to the Secretary with respect to children and the medical and public health grants and cooperative agreements as applicable to preparedness and response activities authorized under this subchapter and subchapter II.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6cd6bfe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–10b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6cd6bff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–10b/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in consultation with such other Secretaries as may be appropriate, shall appoint not to exceed 25 members to the Advisory Committee. In appointing such members, the Secretary shall ensure that the total membership of the Advisory Committee is an odd number.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6cd6c00-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–10b/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required non-Federal members","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, in consultation with such other heads of Federal agencies as may be appropriate, shall appoint to the Advisory Committee under paragraph (1) at least 13 individuals, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6cd6c01-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–10b/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least 2 non-Federal professionals with expertise in pediatric medical disaster planning, preparedness, response, or recovery;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6cd6c02-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–10b/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least 2 representatives from State, local, Tribal, or territorial agencies with expertise in pediatric disaster planning, preparedness, response, or recovery;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6cd6c03-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–10b/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least 4 members representing health care professionals, which may include members with expertise in pediatric emergency medicine; pediatric trauma, critical care, or surgery; the treatment of pediatric patients affected by chemical, biological, radiological, or nuclear agents, including emerging infectious diseases; pediatric mental or behavioral health related to children affected by a public health emergency; or pediatric primary care;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6cd6c04-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–10b/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least 4 non-Federal members representing child care settings, State or local educational agencies, individuals with expertise in children with disabilities, and parents; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6cd6c05-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–10b/d/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" other members as the Secretary determines appropriate, of whom—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb6cd6c06-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–10b/d/2/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least one such member shall represent a children’s hospital;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6cd6c07-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–10b/d/2/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least one such member shall be an individual with expertise in children and youth with special health care needs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6cd6c08-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–10b/d/2/E/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least one such member shall be an individual with expertise in the needs of parents or family caregivers, including the parents or caregivers of children with disabilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6cd6c09-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–10b/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal members","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Advisory Committee under paragraph (1) shall include the following Federal members or their designees (who may be nonvoting members, as determined by the Secretary):","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6cd6c0a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–10b/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Assistant Secretary for Preparedness and Response.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6cd6c0b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–10b/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of the Biomedical Advanced Research and Development Authority.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6cd6c0c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–10b/d/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of the Centers for Disease Control and Prevention.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6cd6c0d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–10b/d/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Commissioner of Food and Drugs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6cd6c0e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–10b/d/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of the National Institutes of Health.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6cd6c0f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–10b/d/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Assistant Secretary of the Administration for Children and Families.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6cd6c10-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–10b/d/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Administrator of the Health Resources and Services Administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6cd6c11-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–10b/d/3/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Administrator of the Federal Emergency Management Agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6cd6c12-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–10b/d/3/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Administrator of the Administration for Community Living.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6cd6c13-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–10b/d/3/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Education.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6cd6c14-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–10b/d/3/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Representatives from such Federal agencies (such as the Substance Abuse and Mental Health Services Administration and the Department of Homeland Security) as the Secretary determines appropriate to fulfill the duties of the Advisory Committee under subsections (b) and (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6cd6c15-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–10b/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term of appointment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each member of the Advisory Committee appointed under paragraph (2) shall serve for a term of 3 years, except that the Secretary may adjust the terms of the Advisory Committee appointees serving on ","children":[{"tag":"date","attrib":{"date":"2019-06-24"},"text":"June 24, 2019","children":[],"tail":", or appointees who are initially appointed after such date, in order to provide for a staggered term of appointment for all members."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6cd6c16-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–10b/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consecutive appointments; maximum terms","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A member appointed under paragraph (2) may serve not more than 3 terms on the Advisory Committee, and not more than two of such terms may be served consecutively.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6cd6c17-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–10b/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Advisory Committee shall meet not less than biannually. At least one meeting per year shall be an in-person meeting.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6cd6c18-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–10b/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall coordinate duties and activities authorized under this section in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300hh–10e"},"text":"section 300hh–10e of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6cd6c19-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–10b/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sunset","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Advisory Committee shall terminate on ","children":[{"tag":"date","attrib":{"date":"2026-12-31"},"text":"December 31, 2026","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb6cd6c1a-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XXVIII, § 2811A, as added "},{"tag":"ref","attrib":{"href":"/us/pl/113/5/tI/s103"},"text":"Pub. L. 113–5, title I, § 10