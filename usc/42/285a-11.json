{"tag":"section","attrib":{"id":"idb56a0b86-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–11"},"text":null,"children":[{"tag":"num","attrib":{"value":"285a–11"},"text":"§ 285a–11.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pediatric cancer research, awareness, and survivorship","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb56a0b87-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–11/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Children’s cancer biorepositories","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb56a0b88-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–11/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Award","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Director of NIH, may make awards to an entity or entities described in paragraph (4) to build upon existing research efforts to collect biospecimens and clinical and demographic information of children, adolescents, and young adults with selected cancer subtypes (and their recurrences) for which current treatments are least effective, in order to achieve a better understanding of the causes of such cancer subtypes (and their recurrences), and the effects and outcomes of treatments for such cancers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56a0b89-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–11/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Amounts received under an award under paragraph (1) may be used to carry out the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb56a0b8a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–11/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Collect and store high-quality, donated biospecimens and associated clinical and demographic information on children, adolescents, and young adults diagnosed with cancer in the United States, focusing on children, adolescents, and young adults with cancer enrolled in clinical trials for whom current treatments are least effective. Activities under this subparagraph may include storage of biospecimens and associated clinical and demographic data at existing biorepositories supported by the National Cancer Institute, such as collected samples of both solid tumor cancer and paired samples.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb56a0b8b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–11/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Maintain an interoperable, secure, and searchable database on stored biospecimens and associated clinical and demographic data from children, adolescents, and young adults with cancer for the purposes of research by scientists and qualified health care professionals.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb56a0b8c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–11/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Establish and implement procedures for evaluating applications for access to such biospecimens and clinical and demographic data from researchers and other qualified health care professionals.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb56a0b8d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–11/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Provide access to biospecimens and clinical and demographic data from children, adolescents, and young adults with cancer to researchers and qualified health care professionals for peer-reviewed research—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb56a0b8e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–11/a/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consistent with the procedures established pursuant to subparagraph (C);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb56a0b8f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–11/a/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" only to the extent permitted by applicable Federal and State law; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb56a0b90-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–11/a/2/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in a manner that protects personal privacy to the extent required by applicable Federal and State privacy law, at minimum.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56a0b91-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–11/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No child, adolescent, or young adult with cancer shall be required under this subsection to contribute a specimen to a biorepository or share clinical or demographic data.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56a0b92-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–11/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application; considerations","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb56a0b93-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–11/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be eligible to receive an award under paragraph (1) an entity shall submit an application to the Secretary at such a time, in such manner, and containing such information as the Secretary may reasonably require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb56a0b94-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–11/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Considerations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In evaluating applications submitted under subparagraph (A), the Secretary shall consider the existing infrastructure of the entity that would allow for the timely capture of biospecimens and related clinical and demographic information for children, adolescents, and young adults with cancer for whom current treatments are least effective.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56a0b95-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–11/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Privacy protections and informed consent","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb56a0b96-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–11/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may not make an award under paragraph (1) to an entity unless the Secretary ensures that such entity—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb56a0b97-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–11/a/5/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collects biospecimens and associated clinical and demographic information only from participants who have given their informed consent in accordance with Federal and State law; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb56a0b98-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–11/a/5/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protects personal privacy to the extent required by applicable Federal and State law, at minimum.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb56a0b99-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–11/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Informed consent","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall ensure biospecimens and associated clinical and demographic information are collected with informed consent, as described in subparagraph (A)(i).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56a0b9a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–11/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guidelines and oversight","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall develop and disseminate appropriate guidelines for the development and maintenance of the biorepositories supported under this subsection, including appropriate oversight, to facilitate further research on select cancer subtypes (and their recurrences) in children, adolescents, and young adults with such cancers (and their recurrences).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56a0b9b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–11/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To encourage the greatest possible efficiency and effectiveness of federally supported efforts with respect to the activities described in this subsection, the Secretary shall ensure the appropriate coordination of programs supported under this section with existing federally supported cancer registry programs and the activities under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s280e–3a"},"text":"section 280e–3a of this title","children":[],"tail":", as appropriate."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56a0b9c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–11/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supplement not supplant","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds provided under this subsection shall be used to supplement, and not supplant, Federal and non-Federal funds available for carrying out the activities described in this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56a0b9d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–11/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 4 years after ","children":[{"tag":"date","attrib":{"date":"2023-01-05"},"text":"January 5, 2023","children":[],"tail":", the Secretary shall submit to Congress a report on—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb56a0b9e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–11/a/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of biospecimens and corresponding clinical demographic data collected through the biospecimen research efforts supported under paragraph (1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb56a0b9f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–11/a/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of biospecimens and corresponding clinical demographic data requested for use by researchers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb56a0ba0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–11/a/9/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" barriers to the collection of biospecimens and corresponding clinical demographic data;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb56a0ba1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–11/a/9/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" barriers experienced by researchers or health care professionals in accessing the biospecimens and corresponding clinical demographic data necessary for use in research; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb56a0ba2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–11/a/9/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommendations with respect to improving the biospecimen and biorepository research efforts under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56a0ba3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–11/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report on researcher access to children’s cancer biorepository samples","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2023-01-05"},"text":"January 5, 2023","children":[],"tail":", the Director of NIH shall—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb56a0ba4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–11/a/10/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct a review of the procedures established under paragraph (2)(C) and other policies or procedures related to researcher access to such biospecimens to identify any opportunities to reduce administrative burden, consistent with paragraph (2)(D), in a manner that protects personal privacy to the extent required by applicable Federal and State privacy law, at a minimum; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb56a0ba5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–11/a/10/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit to the Committee on Health, Education, Labor, and Pensions of the Senate and the Committee on Energy and Commerce of the House of Representatives a report on the findings of the review under subparagraph (A) and whether the Director of NIH plans to make any changes to the policies or procedures considered in such review, based on such findings.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56a0ba6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–11/a/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb56a0ba7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–11/a/11/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Award","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “award” includes a grant, contract, or cooperative agreement determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb56a0ba8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–11/a/11/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Biospecimen","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “biospecimen” includes—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb56a0ba9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–11/a/11/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" solid tumor tissue or bone marrow;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb56a0baa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–11/a/11/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" normal or control tissue;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb56a0bab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–11/a/11/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" blood and plasma;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb56a0bac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–11/a/11/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" DNA and RNA extractions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb56a0bad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–11/a/11/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" familial DNA; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb56a0bae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–11/a/11/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other sample relevant to cancer research, as required by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb56a0baf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–11/a/11/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Clinical and demographic information","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “clinical and demographic information” includes—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb56a0bb0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–11/a/11/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" date of diagnosis;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb56a0bb1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–11/a/11/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" age at diagnosis;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb56a0bb2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–11/a/11/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the patient’s sex, race, ethnicity, and environmental exposures;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb56a0bb3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–11/a/11/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" extent of disease at enrollment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb56a0bb4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–11/a/11/C/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" site of metastases;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb56a0bb5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–11/a/11/C/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" location of primary tumor coded;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb56a0bb6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–11/a/11/C/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" histologic diagnosis;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb56a0bb7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–11/a/11/C/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" tumor marker data when available;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb56a0bb8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–11/a/11/C/ix"},"text":null,"children":[{"tag":"num","attrib":{"value":"ix"},"text":"(ix)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" treatment and outcome data;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb56a0bb9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–11/a/11/C/x"},"text":null,"children":[{"tag":"num","attrib":{"value":"x"},"text":"(x)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information related to specimen quality; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb56a0bba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–11/a/11/C/xi"},"text":null,"children":[{"tag":"num","attrib":{"value":"xi"},"text":"(xi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other applicable information required by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb56a0bbb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–11/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Improving care for pediatric cancer survivors","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb56a0bbc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–11/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research on pediatric cancer survivorship","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director of NIH, in coordination with ongoing research activities, may continue to conduct or support pediatric cancer survivorship research including in any of the following areas:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb56a0bbd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–11/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Outcomes of pediatric cancer survivors, including within minority or other medically underserved populations and with respect to health disparities of such outcomes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb56a0bbe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–11/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Barriers to follow-up care for pediatric cancer survivors, including within minority or other medically underserved populations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb56a0bbf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–11/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The impact of relevant factors, which may include familial, socioeconomic, and other environmental factors, on treatment outcomes and survivorship.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb56a0bc0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–11/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The development of indicators used for long-term follow-up and analysis of the late effects of cancer treatment for pediatric cancer survivors.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb56a0bc1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–11/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The identification of, as applicable—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb56a0bc2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–11/b/1/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" risk factors associated with the late effects of cancer treatment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb56a0bc3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–11/b/1/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" predictors of adverse neurocognitive and psychosocial outcomes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb56a0bc4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–11/b/1/E/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the molecular basis of long-term complications.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb56a0bc5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–11/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The development of targeted interventions to reduce the burden of morbidity borne by cancer survivors in order to protect such cancer survivors from the late effects of cancer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56a0bc6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–11/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Balanced approach","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In conducting or supporting research under paragraph (1)(A)(i) on pediatric cancer survivors within minority or other medically underserved populations, the Director of NIH shall ensure that such research addresses both the physical and the psychological needs of such survivors, as appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb56a0bc7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–11/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed as being inconsistent with the goals and purposes of the Minority Health and Health Disparities Research and Education Act of 2000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb56a0bc8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–11/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of carrying out this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s280e–3a"},"text":"section 280e–3a of this title","children":[],"tail":", there are authorized to be appropriated $30,000,000 for each of fiscal years 2024 through 2028. Funds appropriated under this subsection shall remain available until expended."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb56a0bc9-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title IV, § 417E, as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/285/s4/a"},"text":"Pub. L. 110–285, § 4(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-07-29"},"text":"July 29, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2629"},"text":"122 Stat. 2629","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/180/tI"},"text":"Pub. L. 115–180, title I","children":[],"tail":", §§ 101, 102(b), title II, § 202, "},{"tag":"date","attrib":{"date":"2018-06-05"},"text":"June 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1383"},"text":"132 Stat. 1383","children":[],"tail":", 1386, 1389; "},{"tag":"ref","attrib":{"href":"/us/pl/117/350/s2/a"},"text":"Pub. L. 117–350, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-01-05"},"text":"Jan. 5, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/6262"},"text":"136 Stat. 6262","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb56a0bca-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb56a0bcb-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb56a0bcc-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Minority Health and Health Disparities Research and Education Act of 2000, referred to in subsec. (c), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/525"},"text":"Pub. L. 106–525","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-22"},"text":"Nov. 22, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2495"},"text":"114 Stat. 2495","children":[],"tail":". For complete classification of this Act to the Code, see Short Title of 2000 Amendments note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s201"},"text":"section 201 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb56a0bcd-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2023—Subsec. (a)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/350/s2/a/1/A"},"text":"Pub. L. 117–350, § 2(a)(1)(A)","children":[],"tail":", inserted “, such as collected samples of both solid tumor cancer and paired samples” after “National Cancer Institute”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/350/s2/a/1/B"},"text":"Pub. L. 117–350, § 2(a)(1)(B)","children":[],"tail":", substituted “"},{"tag":"date","attrib":{"date":"2023-01-05"},"text":"January 5, 2023","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2018-06-05"},"text":"June 5, 2018","children":[],"tail":"” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(10), (11). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/350/s2/a/1/C"},"text":"Pub. L. 117–350, § 2(a)(1)(C)","children":[],"tail":", (D), added par. (10) and redesignated former par. (10) as (11)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/350/s2/a/2"},"text":"Pub. L. 117–350, § 2(a)(2)","children":[],"tail":", substituted “2024 through 2028” for “2019 through 2023”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/180/s101/1"},"text":"Pub. L. 115–180, § 101(1)","children":[],"tail":", substituted “research, awareness, and survivorship” for “research and awareness” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/180/s101/2"},"text":"Pub. L. 115–180, § 101(2)","children":[],"tail":", added subsec. (a) and struck out former subsec. (a). Prior to amendment, text read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) ","children":[{"tag":"inline","attrib":{},"text":"Programs of research excellence in pediatric cancer","children":[],"tail":".—The Secretary, in collaboration with the Director of NIH and other Federal agencies with interest in prevention and treatment of pediatric cancer, shall continue to enhance, expand, and intensify pediatric cancer research and other activities related to pediatric cancer, including therapeutically applicable research to generate effective treatments, pediatric preclinical testing, and pediatric clinical trials through National Cancer Institute-supported pediatric cancer clinical trial groups and their member institutions. In enhancing, expanding, and intensifying such research and other activities, the Secretary is encouraged to take into consideration the application of such research and other activities for minority, health disparity, and medically underserved communities. For purposes of this section, the term ‘pediatric cancer research’ means research on the causes, prevention, diagnosis, recognition, treatment, and long-term effects of pediatric cancer."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) ","children":[{"tag":"inline","attrib":{},"text":"Peer review requirements","children":[],"tail":".—All grants awarded under this subsection shall be awarded in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s289a"},"text":"section 289a of this title","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/180/s202"},"text":"Pub. L. 115–180, § 202","children":[],"tail":", added subsec. (b) and struck out former subsec. (b) which related to public awareness of pediatric cancers and available treatments and research."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/180/s101/3"},"text":"Pub. L. 115–180, § 101(3)","children":[],"tail":", struck out “("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s202"},"text":"42 U.S.C. 202","children":[],"tail":" note)” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/180/s102/b"},"text":"Pub. L. 115–180, § 102(b)","children":[],"tail":", substituted “2019 through 2023” for “2009 through 2013” and struck out “Such authorization of appropriations is in addition to the authorization of appropriations established in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s282a"},"text":"section 282a of this title","children":[],"tail":" with respect to such purpose.” before “Funds appropriated”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb56a0bce-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb56a0bcf-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Reporting on Childhood Cancer Research Projects","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/180/tI/s121"},"text":"Pub. L. 115–180, title I, § 121","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-06-05"},"text":"June 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1387"},"text":"132 Stat. 1387","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/180/tI/s121"},"text":"“The Director of the National Institutes of Health shall ensure that childhood cancer research projects conducted or supported by the National Institutes of Health are included in appropriate reports to Congress, which may include the Pediatric Research Initiative report.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
