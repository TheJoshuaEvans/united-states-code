{"tag":"section","attrib":{"id":"idbe481913-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7544"},"text":null,"children":[{"tag":"num","attrib":{"value":"7544"},"text":"§ 7544.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State grants","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Administrator is authorized to make grants to appropriate State agencies in an amount up to two-thirds of the cost of developing and maintaining effective vehicle emission devices and systems inspection and emission testing and control programs, except that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe481914-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7544/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no such grant shall be made for any part of any State vehicle inspection program which does not directly relate to the cost of the air pollution control aspects of such a program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe481915-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7544/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no such grant shall be made unless the Secretary of Transportation has certified to the Administrator that such program is consistent with any highway safety program developed pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t23/s402"},"text":"section 402 of title 23","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe481916-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7544/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no such grant shall be made unless the program includes provisions designed to insure that emission control devices and systems on vehicles in actual use have not been discontinued or rendered inoperative.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Grants may be made under this section by way of reimbursement in any case in which amounts have been expended by the State before the date on which any such grant was made.","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbe481917-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1955-07-14/ch360"},"text":"July 14, 1955, ch. 360","children":[],"tail":", title II, § 210, formerly § 209, as added "},{"tag":"ref","attrib":{"href":"/us/pl/90/148/s2"},"text":"Pub. L. 90–148, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-11-21"},"text":"Nov. 21, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/502"},"text":"81 Stat. 502","children":[],"tail":"; renumbered and amended "},{"tag":"ref","attrib":{"href":"/us/pl/91/604"},"text":"Pub. L. 91–604","children":[],"tail":", §§ 8(a), 10(b), "},{"tag":"date","attrib":{"date":"1970-12-31"},"text":"Dec. 31, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1694"},"text":"84 Stat. 1694","children":[],"tail":", 1700; "},{"tag":"ref","attrib":{"href":"/us/pl/95/95/tII/s204"},"text":"Pub. L. 95–95, title II, § 204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-08-07"},"text":"Aug. 7, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/754"},"text":"91 Stat. 754","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbe481918-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbe481919-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbe48191a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1857f–6b"},"text":"section 1857f–6b of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbe48191b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 210 of act ","children":[{"tag":"date","attrib":{"date":"1955-07-14"},"text":"July 14, 1955","children":[],"tail":", was renumbered section 211 by "},{"tag":"ref","attrib":{"href":"/us/pl/91/604"},"text":"Pub. L. 91–604","children":[],"tail":" and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s7545"},"text":"section 7545 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbe48191c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1977—","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/95"},"text":"Pub. L. 95–95","children":[],"tail":" inserted provision allowing grants to be made by way of reimbursement in any case in which amounts have been expended by States before the date on which the grants were made."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1970—","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/604/s10/b"},"text":"Pub. L. 91–604, § 10(b)","children":[],"tail":", substituted provisions authorizing the Administrator to make grants to appropriate State agencies for the development and maintenance of effective vehicle emission devices and systems inspection and emission testing and control programs, for provisions authorizing the Secretary to make grants to appropriate State air pollution control agencies for the development of meaningful uniform motor vehicle emission device inspection and emission testing programs."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbe48191d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbe48191e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1977 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/95"},"text":"Pub. L. 95–95","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1977-08-07"},"text":"Aug. 7, 1977","children":[],"tail":", except as otherwise expressly provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/95/95/s406/d"},"text":"section 406(d) of Pub. L. 95–95","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s7401"},"text":"section 7401 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
