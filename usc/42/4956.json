{"tag":"section","attrib":{"id":"idbcebe406-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4956"},"text":null,"children":[{"tag":"num","attrib":{"value":"4956"},"text":"§ 4956.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Participation of program beneficiaries","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"To the maximum extent practicable, the people of the communities to be served by volunteers under this subchapter shall participate in planning, developing, and implementing programs thereunder, and the Director, after consultation with sponsoring agencies (including volunteers assigned to them) and the people served by such agencies, shall establish in regulations, a continuing mechanism for the meaningful participation of such program beneficiaries.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbcebe407-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/113/tI/s106"},"text":"Pub. L. 93–113, title I, § 106","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-10-01"},"text":"Oct. 1, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/398"},"text":"87 Stat. 398","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/288/s7"},"text":"Pub. L. 98–288, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-05-21"},"text":"May 21, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/191"},"text":"98 Stat. 191","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbcebe408-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbcebe409-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbcebe40a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1984—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/288"},"text":"Pub. L. 98–288","children":[],"tail":" substituted “establish in regulations” for “take all necessary steps to establish, in regulations he shall prescribe”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
