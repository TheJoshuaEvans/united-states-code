{"tag":"section","attrib":{"id":"idb69daa52-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–53"},"text":null,"children":[{"tag":"num","attrib":{"value":"300ff–53"},"text":"§ 300ff–53.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preferences in making grants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb69daa53-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–53/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In making grants under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–51"},"text":"section 300ff–51 of this title","children":[],"tail":", the Secretary shall give preference to any qualified applicant experiencing an increase in the burden of providing services regarding HIV/AIDS, as indicated by the factors specified in subsection (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb69daa54-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–53/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specification of factors","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb69daa55-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–53/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of the geographic area with respect to which the entity involved is applying for a grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–51"},"text":"section 300ff–51 of this title","children":[],"tail":", the factors referred to in subsection (a), as determined for the period specified in paragraph (2), are—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb69daa56-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–53/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of cases of HIV/AIDS;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb69daa57-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–53/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the rate of increase in such cases;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb69daa58-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–53/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the lack of availability of early intervention services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb69daa59-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–53/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of other cases of sexually transmitted diseases, and ","children":[{"tag":"ref","attrib":{"idref":"fn002436"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002436"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The word “and” probably should not appear."}],"tail":" the number of cases of tuberculosis and of drug abuse "},{"tag":"ref","attrib":{"idref":"fn002437"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002437"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. A comma probably should appear."}],"tail":" and the number of cases of individuals co-infected with HIV/AIDS and hepatitis B or C;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb69daa5a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–53/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the rate of increase in each of the cases specified in subparagraph (D);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb69daa5b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–53/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the lack of availability of primary health services from providers other than such applicant; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb69daa5c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–53/b/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the distance between such area and the nearest community that has an adequate level of availability of appropriate HIV-related services, and the length of time required to travel such distance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb69daa5d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–53/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relevant period of time","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The period referred to in paragraph (1) is the 2-year period preceding the fiscal year for which the entity involved is applying to receive a grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–51"},"text":"section 300ff–51 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb69daa5e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–53/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Equitable allocations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In providing preferences for purposes of subsection (b), the Secretary shall equitably allocate the preferences among urban and rural areas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb69daa5f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–53/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain areas","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Of the applicants who qualify for preference under this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb69daa60-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–53/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary shall give preference to applicants that will expend the grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–51"},"text":"section 300ff–51 of this title","children":[],"tail":" to provide early intervention under such section in rural areas; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb69daa61-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–53/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary shall give preference to areas that are underserved with respect to such services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb69daa62-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XXVI, § 2653, as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/381/tIII/s301/a"},"text":"Pub. L. 101–381, title III, § 301(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-08-18"},"text":"Aug. 18, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/608"},"text":"104 Stat. 608","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/345/tIII/s311"},"text":"Pub. L. 106–345, title III, § 311","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-20"},"text":"Oct. 20, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1345"},"text":"114 Stat. 1345","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/415/tIII/s302/b"},"text":"Pub. L. 109–415, title III, § 302(b)","children":[],"tail":", title VII, §§ 702(3), 703, "},{"tag":"date","attrib":{"date":"2006-12-19"},"text":"Dec. 19, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2806"},"text":"120 Stat. 2806","children":[],"tail":", 2820; "},{"tag":"ref","attrib":{"href":"/us/pl/111/87/s2/a/1"},"text":"Pub. L. 111–87, § 2(a)(1)","children":[],"tail":", (3)(A), "},{"tag":"date","attrib":{"date":"2009-10-30"},"text":"Oct. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2885"},"text":"123 Stat. 2885","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb69daa63-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb69daa64-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb69daa65-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2009—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/87"},"text":"Pub. L. 111–87","children":[],"tail":" repealed "},{"tag":"ref","attrib":{"href":"/us/pl/109/415/s703"},"text":"Pub. L. 109–415, § 703","children":[],"tail":", and revived the provisions of this section as in effect on "},{"tag":"date","attrib":{"date":"2009-09-30"},"text":"Sept. 30, 2009","children":[],"tail":". See 2006 Amendment note and Effective Date of 2009 Amendment; Revival of Section note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/415/s703"},"text":"Pub. L. 109–415, § 703","children":[],"tail":", which directed repeal of this section effective "},{"tag":"date","attrib":{"date":"2009-10-01"},"text":"Oct. 1, 2009","children":[],"tail":", was itself repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/111/87/s2/a/1"},"text":"Pub. L. 111–87, § 2(a)(1)","children":[],"tail":", effective "},{"tag":"date","attrib":{"date":"2009-09-30"},"text":"Sept. 30, 2009","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/415/s702/3"},"text":"Pub. L. 109–415, § 702(3)","children":[],"tail":", substituted “HIV/AIDS” for “HIV disease”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/415/s302/b/1/A"},"text":"Pub. L. 109–415, § 302(b)(1)(A)","children":[],"tail":", substituted “HIV/AIDS” for “acquired immune deficiency syndrome”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/415/s302/b/1/B"},"text":"Pub. L. 109–415, § 302(b)(1)(B)","children":[],"tail":", inserted “and the number of cases of individuals co-infected with HIV/AIDS and hepatitis B or C” before semicolon at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/415/s302/b/2"},"text":"Pub. L. 109–415, § 302(b)(2)","children":[],"tail":", substituted “preference” for “special consideration”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/345"},"text":"Pub. L. 106–345","children":[],"tail":" added subsec. (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb69daa66-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb69daa67-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2009 Amendment; Revival of Section","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions that repeal by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/87/s2/a/1"},"text":"section 2(a)(1) of Pub. L. 111–87","children":[],"tail":" of "},{"tag":"ref","attrib":{"href":"/us/pl/109/415/s703"},"text":"section 703 of Pub. L. 109–415","children":[],"tail":" be effective "},{"tag":"date","attrib":{"date":"2009-09-30"},"text":"Sept. 30, 2009","children":[],"tail":", and that the provisions of this section as in effect on "},{"tag":"date","attrib":{"date":"2009-09-30"},"text":"Sept. 30, 2009","children":[],"tail":", be revived, see section 2(a)(2), (3)(A) of "},{"tag":"ref","attrib":{"href":"/us/pl/111/87"},"text":"Pub. L. 111–87","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–11"},"text":"section 300ff–11 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
