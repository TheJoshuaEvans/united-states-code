{"tag":"section","attrib":{"id":"idbedbcd91-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9811"},"text":null,"children":[{"tag":"num","attrib":{"value":"9811"},"text":"§ 9811.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on assistance","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"No financial assistance shall be provided under this part unless the Secretary determines that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbedbcd92-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9811/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any cooperative association receiving assistance has a minimum of fifteen active members, a majority of which are low-income rural persons;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbedbcd93-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9811/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adequate technical assistance is made available and committed to the programs being supported;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbedbcd94-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9811/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such financial assistance will materially further the purposes of this part; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbedbcd95-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9811/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the applicant is fulfilling or will fulfill a need for services, supplies, or facilities which is otherwise not being met.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbedbcd96-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35/tVI/s622"},"text":"Pub. L. 97–35, title VI, § 622","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/494"},"text":"95 Stat. 494","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
