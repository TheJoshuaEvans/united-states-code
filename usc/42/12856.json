{"tag":"section","attrib":{"id":"idbfa6979c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12856"},"text":null,"children":[{"tag":"num","attrib":{"value":"12856"},"text":"§ 12856.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Board of Directors shall submit to the Congress, not later than the expiration of the 90-day period beginning on the date of the termination of the Trust under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12859"},"text":"section 12859 of this title","children":[],"tail":", a report containing a description of the activities of the Trust and an analysis of the effectiveness of the Trust in assisting first-time homebuyers."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbfa6979d-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/625/tIII/s307"},"text":"Pub. L. 101–625, title III, § 307","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4133"},"text":"104 Stat. 4133","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
