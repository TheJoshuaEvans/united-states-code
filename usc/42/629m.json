{"tag":"section","attrib":{"id":"idb7aafb1a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629m"},"text":null,"children":[{"tag":"num","attrib":{"value":"629m"},"text":"§ 629m.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data exchange standards for improved interoperability","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb7aafb1b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629m/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall, in consultation with an interagency work group established by the Office of Management and Budget and considering State government perspectives, by rule, designate data exchange standards to govern, under this part and part E—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7aafb1c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629m/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" necessary categories of information that State agencies operating programs under State plans approved under this part are required under applicable Federal law to electronically exchange with another State agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7aafb1d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629m/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal reporting and data exchange required under applicable Federal law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7aafb1e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629m/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The data exchange standards required by paragraph (1) shall, to the extent practicable—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7aafb1f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629m/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" incorporate a widely accepted, non-proprietary, searchable, computer-readable format, such as the Extensible Markup Language;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7aafb20-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629m/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contain interoperable standards developed and maintained by intergovernmental partnerships, such as the National Information Exchange Model;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7aafb21-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629m/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" incorporate interoperable standards developed and maintained by Federal entities with authority over contracting and financial assistance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7aafb22-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629m/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be consistent with and implement applicable accounting principles;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7aafb23-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629m/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be implemented in a manner that is cost-effective and improves program efficiency and effectiveness; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7aafb24-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629m/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be capable of being continually upgraded as necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7aafb25-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629m/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subsection ","children":[{"tag":"ref","attrib":{"idref":"fn002624"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002624"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original."}],"tail":" shall be construed to require a change to existing data exchange standards found to be effective and efficient."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb7aafb26-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title IV, § 443, formerly § 440, as added "},{"tag":"ref","attrib":{"href":"/us/pl/112/34/tI/s105/a"},"text":"Pub. L. 112–34, title I, § 105(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-09-30"},"text":"Sept. 30, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/376"},"text":"125 Stat. 376","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/123/dE/tVII/s50771/a"},"text":"Pub. L. 115–123, div. E, title VII, § 50771(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-02-09"},"text":"Feb. 9, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/267"},"text":"132 Stat. 267","children":[],"tail":"; renumbered § 443, "},{"tag":"ref","attrib":{"href":"/us/pl/118/258/tI/s106/f/1"},"text":"Pub. L. 118–258, title I, § 106(f)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2952"},"text":"138 Stat. 2952","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb7aafb27-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb7aafb28-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb7aafb29-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 440 of act ","children":[{"tag":"date","attrib":{"date":"1935-08-14"},"text":"Aug. 14, 1935","children":[],"tail":", was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s640"},"text":"section 640 of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/100/485"},"text":"Pub. L. 100–485","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb7aafb2a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/123"},"text":"Pub. L. 115–123","children":[],"tail":" amended section generally. Prior to amendment, section required Secretary of Health and Human Services to designate standard data elements for any category of information required to be reported under this part and designate data reporting standards to govern the reporting required under this part."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb7aafb2b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb7aafb2c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/34/tI/s105/b"},"text":"Pub. L. 112–34, title I, § 105(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-09-30"},"text":"Sept. 30, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/377"},"text":"125 Stat. 377","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/34/tI/s105/b"},"text":"“The amendment made by subsection (a) [enacting this section] shall take effect on ","children":[{"tag":"date","attrib":{"date":"2012-10-01"},"text":"October 1, 2012","children":[],"tail":", and shall apply with respect to information required to be reported on or after such date.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb7aafb2d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Regulation","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/123/dE/tVII/s50771/b"},"text":"Pub. L. 115–123, div. E, title VII, § 50771(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-02-09"},"text":"Feb. 9, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/268"},"text":"132 Stat. 268","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/123/dE/tVII/s50771/b"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Not later than the date that is 24 months after the date of the enactment of this section [","children":[{"tag":"date","attrib":{"date":"2018-02-09"},"text":"Feb. 9, 2018","children":[],"tail":"], the Secretary of Health and Human Services shall issue a proposed rule that—"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifies federally required data exchanges, include [sic] specification and timing of exchanges to be standardized, and address [sic] the factors used in determining whether and when to standardize data exchanges; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specifies State implementation options and describes future milestones.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
