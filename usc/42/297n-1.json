{"tag":"section","attrib":{"id":"idb5fb9d54-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s297n–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"297n–1"},"text":"§ 297n–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nurse faculty loan program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5fb9d55-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s297n–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" School of nursing student loan fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Administrator of the Health Resources and Services Administration, may enter into an agreement with any accredited school of nursing for the establishment and operation of a student loan fund in accordance with this section, to increase the number of qualified nursing faculty.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5fb9d56-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s297n–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each agreement entered into under subsection (a) shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5fb9d57-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s297n–1/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for the establishment of a student loan fund by the school involved;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5fb9d58-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s297n–1/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide for deposit in the fund of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5fb9d59-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s297n–1/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal capital contributions to the fund;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5fb9d5a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s297n–1/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an amount equal to not less than one-ninth of such Federal capital contributions, contributed by such school;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5fb9d5b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s297n–1/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collections of principal and interest on loans made from the fund; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5fb9d5c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s297n–1/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other earnings of the fund;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5fb9d5d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s297n–1/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide that the fund will be used only for loans to students of the school in accordance with subsection (c) and for costs of collection of such loans and interest thereon;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5fb9d5e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s297n–1/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide that loans may be made from such fund only to students pursuing a full-time course of study or, at the discretion of the Secretary, a part-time course of study in an advanced degree program described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s296j/b"},"text":"section 296j(b) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5fb9d5f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s297n–1/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contain such other provisions as are necessary to protect the financial interests of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5fb9d60-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s297n–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loan provisions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Loans from any student loan fund established by a school pursuant to an agreement under subsection (a) shall be made to an individual on such terms and conditions as the school may determine, except that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5fb9d61-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s297n–1/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such terms and conditions are subject to any conditions, limitations, and requirements prescribed by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5fb9d62-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s297n–1/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of any individual, the total of the loans for any academic year made by schools of nursing from loan funds established pursuant to agreements under subsection (a) may not exceed $35,500,","children":[{"tag":"ref","attrib":{"idref":"fn002301"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002301"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The comma probably should not appear."}],"tail":" during fiscal years 2010 and 2011 fiscal years "},{"tag":"ref","attrib":{"idref":"fn002302"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002302"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original."}],"tail":" (after fiscal year 2011, such amounts shall be adjusted to provide for a cost-of-attendance increase for the yearly loan rate and the aggregate loan; "},{"tag":"ref","attrib":{"idref":"fn002303"},"text":"3","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002303"},"text":null,"children":[{"tag":"num","attrib":{},"text":"3","children":[],"tail":" So in original. A closing parenthesis probably should appear before the semicolon."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5fb9d63-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s297n–1/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an amount up to 85 percent of any such loan (plus interest thereon) shall be canceled by the school as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5fb9d64-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s297n–1/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" upon completion by the individual of each of the first, second, and third year of full-time employment, required by the loan agreement entered into under this subsection, as a faculty member in an accredited a ","children":[{"tag":"ref","attrib":{"idref":"fn002304"},"text":"4","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002304"},"text":null,"children":[{"tag":"num","attrib":{},"text":"4","children":[],"tail":" So in original. The word “a” probably should not appear."}],"tail":" school of nursing, the school shall cancel 20 percent of the principle "},{"tag":"ref","attrib":{"idref":"fn002305"},"text":"5","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002305"},"text":null,"children":[{"tag":"num","attrib":{},"text":"5","children":[],"tail":" So in original. Probably should be “principal”."}],"tail":" of, and the interest on, the amount of such loan unpaid on the first day of such employment; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5fb9d65-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s297n–1/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" upon completion by the individual of the fourth year of full-time employment, required by the loan agreement entered into under this subsection, as a faculty member in a school of nursing, the school shall cancel 25 percent of the principle ","children":[{"tag":"sup","attrib":{},"text":"5","children":[],"tail":" of, and the interest on, the amount of such loan unpaid on the first day of such employment;"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5fb9d66-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s297n–1/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such a loan may be used to pay the cost of tuition, fees, books, laboratory expenses, and other reasonable education expenses;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5fb9d67-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s297n–1/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such a loan shall be repayable in equal or graduated periodic installments (with the right of the borrower to accelerate repayment) over the 10-year period that begins 9 months after the individual ceases to pursue a course of study at a school of nursing; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5fb9d68-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s297n–1/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" such a loan shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5fb9d69-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s297n–1/c/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" beginning on the date that is 3 months after the individual ceases to pursue a course of study at a school of nursing, bear interest on the unpaid balance of the loan at the rate of 3 percent per annum; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5fb9d6a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s297n–1/c/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to subsection (e), if the school of nursing determines that the individual will not complete such course of study or serve as a faculty member as required under the loan agreement under this subsection, bear interest on the unpaid balance of the loan at the prevailing market rate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5fb9d6b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s297n–1/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment of proportionate share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Where all or any part of a loan, or interest, is canceled under this section, the Secretary shall pay to the school an amount equal to the school’s proportionate share of the canceled portion, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5fb9d6c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s297n–1/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review by Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"At the request of the individual involved, the Secretary may review any determination by an accredited school of nursing under subsection (c)(6)(B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5fb9d6d-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title VIII, § 846A, as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/205/tII/s203"},"text":"Pub. L. 107–205, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-01"},"text":"Aug. 1, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/817"},"text":"116 Stat. 817","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tV/s5311/a"},"text":"Pub. L. 111–148, title V, § 5311(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/631"},"text":"124 Stat. 631","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/136/dA/tIII/s3404/a/9"},"text":"Pub. L. 116–136, div. A, title III, § 3404(a)(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-03-27"},"text":"Mar. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/394"},"text":"134 Stat. 394","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dBB/tIII/s331/c"},"text":"Pub. L. 116–260, div. BB, title III, § 331(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2938"},"text":"134 Stat. 2938","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb5fb9d6e-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb5fb9d6f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb5fb9d70-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/136/s3404/a/9"},"text":"Pub. L. 116–136, § 3404(a)(9)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/s331/c"},"text":"Pub. L. 116–260, § 331(c)","children":[],"tail":", struck out subsec. (f). Text read as follows: “There are authorized to be appropriated to carry out this section such sums as may be necessary for each of fiscal years 2010 through 2014.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/s5311/a/1"},"text":"Pub. L. 111–148, § 5311(a)(1)","children":[],"tail":", substituted “School of nursing student loan fund” for “Establishment” in heading and inserted “accredited” before “school” in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/s5311/a/2/A"},"text":"Pub. L. 111–148, § 5311(a)(2)(A)","children":[],"tail":", substituted “$35,500, during fiscal years 2010 and 2011 fiscal years (after fiscal year 2011, such amounts shall be adjusted to provide for a cost-of-attendance increase for the yearly loan rate and the aggregate loan;” for “$30,000, plus any amount determined by the Secretary on an annual basis to reflect inflation;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/s5311/a/2/B"},"text":"Pub. L. 111–148, § 5311(a)(2)(B)","children":[],"tail":", inserted “an accredited” before “a school of nursing”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/s5311/a/3"},"text":"Pub. L. 111–148, § 5311(a)(3)","children":[],"tail":", substituted “an accredited school” for “a school”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/s5311/a/4"},"text":"Pub. L. 111–148, § 5311(a)(4)","children":[],"tail":", substituted “2010 through 2014” for “2003 through 2007”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb5fb9d71-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb5fb9d72-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2020 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Pub. L. 116–260","children":[],"tail":" effective as if included in the enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/116/136"},"text":"Pub. L. 116–136","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dBB/s331/d"},"text":"section 331(d) of div. BB of Pub. L. 116–260","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s294c"},"text":"section 294c of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
