{"tag":"section","attrib":{"id":"idbd120a1a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5156"},"text":null,"children":[{"tag":"num","attrib":{"value":"5156"},"text":"§ 5156.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standards and reviews","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The President shall establish comprehensive standards which shall be used to assess the efficiency and effectiveness of Federal major disaster and emergency assistance programs administered under this chapter. The President shall conduct annual reviews of the activities of Federal agencies and State and local governments in major disaster and emergency preparedness and in providing major disaster and emergency assistance in order to assure maximum coordination and effectiveness of such programs and consistency in policies for reimbursement of States under this chapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbd120a1b-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/288/tIII/s313"},"text":"Pub. L. 93–288, title III, § 313","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/707/tI/s105/j"},"text":"Pub. L. 100–707, title I, § 105(j)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-23"},"text":"Nov. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4694"},"text":"102 Stat. 4694","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd120a1c-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd120a1d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"