{"tag":"section","attrib":{"id":"idbdc75093-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6906"},"text":null,"children":[{"tag":"num","attrib":{"value":"6906"},"text":"§ 6906.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial disclosure","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbdc75094-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6906/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each officer or employee of the Administrator who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbdc75095-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6906/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" performs any function or duty under this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdc75096-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6906/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has any known financial interest in any person who applies for or receives financial assistance under this chapter","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall, beginning on ","children":[{"tag":"date","attrib":{"date":"1977-02-01"},"text":"February 1, 1977","children":[],"tail":", annually file with the Administrator a written statement concerning all such interests held by such officer or employee during the preceding calendar year. Such statement shall be available to the public."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdc75097-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6906/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Action by Administrator","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbdc75098-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6906/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" act within ninety days after ","children":[{"tag":"date","attrib":{"date":"1976-10-21"},"text":"October 21, 1976","children":[],"tail":"—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbdc75099-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6906/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to define the term “known financial interest” for purposes of subsection (a) of this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbdc7509a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6906/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to establish the methods by which the requirement to file written statements specified in subsection (a) of this section will be monitored and enforced, including appropriate provision for the filing by such officers and employees of such statements and the review by the Administrator of such statements; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdc7509b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6906/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" report to the Congress on ","children":[{"tag":"date","attrib":{"date":"1978-06-01"},"text":"June 1, 1978","children":[],"tail":", and of each succeeding calendar year with respect to such disclosures and the actions taken in regard thereto during the preceding calendar year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdc7509c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6906/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the rules prescribed under subsection (b) of this section, the Administrator may identify specific positions within the Environmental Protection Agency which are of a nonpolicy-making nature and provide that officers or employees occupying such positions shall be exempt from the requirements of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdc7509d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6906/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalty","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any officer or employee who is subject to, and knowingly violates, this section shall be fined not more than $2,500 or imprisoned not more than one year, or both.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbdc7509e-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/272/tII/s1007"},"text":"Pub. L. 89–272, title II, § 1007","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/94/580/s2"},"text":"Pub. L. 94–580, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2802"},"text":"90 Stat. 2802","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbdc7509f-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbdc750a0-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbdc750a1-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Reporting Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For termination, effective ","children":[{"tag":"date","attrib":{"date":"2000-05-15"},"text":"May 15, 2000","children":[],"tail":", of reporting provisions in subsec. (b)(2) of this section, see "},{"tag":"ref","attrib":{"href":"/us/pl/104/66/s3003"},"text":"section 3003 of Pub. L. 104–66","children":[],"tail":", as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1113"},"text":"section 1113 of Title 31","children":[],"tail":", Money and Finance, and the 14th item on page 164 of House Document No. 103–7."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idbdc750a2-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"idbdc750a3-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of certain enforcement functions of Administrator or other official of Environmental Protection Agency under this chapter to Federal Inspector, Office of Federal Inspector for the Alaska Natural Gas Transportation System, and subsequent transfer to Secretary of Energy, then to Federal Coordinator for Alaska Natural Gas Transportation Projects, see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6903"},"text":"section 6903 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
