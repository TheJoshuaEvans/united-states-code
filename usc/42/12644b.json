{"tag":"section","attrib":{"id":"idbf879e4f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12644b"},"text":null,"children":[{"tag":"num","attrib":{"value":"12644b"},"text":"§ 12644b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consolidated application and reporting requirements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf879e50-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12644b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To promote efficiency and eliminate duplicative requirements, the Corporation shall consolidate or modify application procedures and reporting requirements for programs, projects, and activities funded under the national service laws.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf879e51-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12644b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 18 months after the effective date of the Serve America Act, the Corporation shall submit to the authorizing committees a report containing information on the actions taken to consolidate or modify the application procedures and reporting requirements for programs, projects, and activities funded under the national service laws, including a description of the procedures for consultation with recipients of the funding.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf879e52-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attr