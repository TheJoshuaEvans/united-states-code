{"tag":"section","attrib":{"id":"idb42815dc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s211c"},"text":null,"children":[{"tag":"num","attrib":{"value":"211c"},"text":"§ 211c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Promotion credit for medical officers in assistant grade","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Any medical officer of the Regular Corps of the Public Health Service who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb42815dd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s211c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb42815de-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s211c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was appointed to the assistant grade in the Regular Corps and whose service in such Corps has been continuous from the date of appointment or (B) may hereafter be appointed to the assistant grade in the Regular Corps, and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb42815df-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s211c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" had or will have completed a medical internship on the date of such appointment,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be credited with one year for purposes of promotion and seniority in grade, except that no such credit shall be authorized if the officer has received or will receive similar credit for his internship under other provisions of law. In the case of an officer on active duty on the effective date of this section who is entitled to the credit authorized herein, the one year shall be added to the promotion and seniority-in-grade credits with which he is credited on such date.","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb42815e0-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title II, § 220, as added "},{"tag":"ref","attrib":{"href":"/us/act/1956-04-30/ch223/s3"},"text":"Apr. 30, 1956, ch. 223, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/121"},"text":"70 Stat. 121","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb42815e1-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb42815e2-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb42815e3-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For “the effective date of this section”, referred to in text, see section 7 of act ","children":[{"tag":"date","attrib":{"date":"1956-04-30"},"text":"Apr. 30, 1956","children":[],"tail":", which provided in part that this section shall become effective the first day of the month following the day of enactment, "},{"tag":"date","attrib":{"date":"1956-04-30"},"text":"Apr. 30, 1956","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb42815e4-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idb42815e5-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Secretary of Health and Human Services” substituted for “Secretary of Health, Education, and Welfare” pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/88/s509/b"},"text":"section 509(b) of Pub. L. 96–88","children":[],"tail":", which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s3508/b"},"text":"section 3508(b) of Title 20","children":[],"tail":", Education."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idb42815e6-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"idb42815e7-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Functions of Public Health Service, Surgeon General of Public Health Service, and all other officers and employees of Public Health Service, and functions of all agencies of or in Public Health Service transferred to Secretary of Health, Education, and Welfare by Reorg. Plan No. 3 of 1966, eff. ","children":[{"tag":"date","attrib":{"date":"1966-06-25"},"text":"June 25, 1966","children":[],"tail":", 31 F.R. 8855, "},{"tag":"ref","attrib":{"href":"/us/stat/80/1610"},"text":"80 Stat. 1610","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s202"},"text":"section 202 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
