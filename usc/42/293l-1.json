{"tag":"section","attrib":{"id":"idb5dca3b6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s293l–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"293l–1"},"text":"§ 293l–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Teaching health centers development grants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5dca3b7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s293l–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program authorized","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may award grants under this section to teaching health centers for the purpose of establishing new accredited or expanded primary care residency programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5dca3b8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s293l–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount and duration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Grants awarded under this section shall be for a term of not more than 3 years and the maximum award may not be more than $500,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5dca3b9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s293l–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Amounts provided under a grant under this section shall be used to cover the costs of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5dca3ba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s293l–1/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" establishing or expanding a primary care residency training program described in subsection (a), including costs associated with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5dca3bb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s293l–1/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" curriculum development;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5dca3bc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s293l–1/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recruitment, training and retention of residents and faculty: ","children":[{"tag":"ref","attrib":{"idref":"fn002267"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002267"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The colon probably should be a semicolon."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5dca3bd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s293l–1/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accreditation by the Accreditation Council for Graduate Medical Education (ACGME), the American Dental Association (ADA), or the American Osteopathic Association (AOA); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5dca3be-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s293l–1/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" faculty salaries during the development phase; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5dca3bf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s293l–1/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" technical assistance provided by an eligible entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5dca3c0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s293l–1/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A teaching health center seeking a grant under this section shall submit an application to the Secretary at such time, in such manner, and containing such information as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5dca3c1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s293l–1/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preference for certain applications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In selecting recipients for grants under this section, the Secretary shall give preference to any such application that documents an existing affiliation agreement with an area health education center program as defined in sections 294a and 295p of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5dca3c2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s293l–1/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5dca3c3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s293l–1/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “eligible entity” means an organization capable of providing technical assistance including an area health education center program as defined in sections 294a and 295p of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5dca3c4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s293l–1/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Primary care residency program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “primary care residency program” means an approved graduate medical residency training program (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s256h"},"text":"section 256h of this title","children":[],"tail":") in family medicine, internal medicine, pediatrics, internal medicine-pediatrics, obstetrics and gynecology, psychiatry, general dentistry, pediatric dentistry, and geriatrics."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5dca3c5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s293l–1/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Teaching health center","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5dca3c6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s293l–1/f/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “teaching health center” means an entity that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb5dca3c7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s293l–1/f/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a community based, ambulatory patient care center; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5dca3c8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s293l–1/f/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operates a primary care residency program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5dca3c9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s293l–1/f/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusion of certain entities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Such term includes the following:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb5dca3ca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s293l–1/f/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A Federally qualified health center (as defined in section 1396d(","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(2)(B) of this title)."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5dca3cb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s293l–1/f/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A community mental health center (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395x/ff/3/B"},"text":"section 1395x(ff)(3)(B) of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5dca3cc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s293l–1/f/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A rural health clinic, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395x/aa"},"text":"section 1395x(aa) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5dca3cd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s293l–1/f/3/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A health center operated by the Indian Health Service, an Indian tribe or tribal organization, or an urban Indian organization (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1603"},"text":"section 1603 of title 25","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5dca3ce-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s293l–1/f/3/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An entity receiving funds under subchapter VIII.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5dca3cf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s293l–1/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated, $25,000,000 for fiscal year 2010, $50,000,000 for fiscal year 2011, $50,000,000 for fiscal year 2012, and such sums as may be necessary for each fiscal year thereafter to carry out this section. Not to exceed $5,000,000 annually may be used for technical assistance program grants.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5dca3d0-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title VII, § 749A, as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tV/s5508/a"},"text":"Pub. L. 111–148, title V, § 5508(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/668"},"text":"124 Stat. 668","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
