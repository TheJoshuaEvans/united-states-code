{"tag":"section","attrib":{"id":"idb5d57851-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s292x"},"text":null,"children":[{"tag":"num","attrib":{"value":"292x"},"text":"§ 292x.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distribution of assets from loan funds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5d57852-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s292x/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distribution after termination of fund","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a school terminates a loan fund established under an agreement pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s292q/b"},"text":"section 292q(b) of this title","children":[],"tail":", or if the Secretary for good cause terminates the agreement with the school, there shall be a capital distribution as follows:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5d57853-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s292x/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall first be paid an amount which bears the same ratio to such balance in such fund on the date of termination of the fund as the total amount of the Federal capital contributions to such fund by the Secretary pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s292q/b/2/A"},"text":"section 292q(b)(2)(A) of this title","children":[],"tail":" bears to the total amount in such fund derived from such Federal capital contributions and from funds deposited therein pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s292q/b/2/B"},"text":"section 292q(b)(2)(B) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5d57854-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s292x/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The remainder of such balance shall be paid to the school.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5d57855-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s292x/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment of proportionate share to Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a capital distribution is made under subsection (a), the school involved shall, after the capital distribution, pay to the Secretary, not less often than quarterly, the same proportionate share of amounts received by the school in payment of principal or interest on loans made from the loan fund established pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s292q/b"},"text":"section 292q(b) of this title","children":[],"tail":" as was determined by the Secretary under subsection (a)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5d57856-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title VII, § 728, as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/408/tI/s102"},"text":"Pub. L. 102–408, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-13"},"text":"Oct. 13, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2021"},"text":"106 Stat. 2021","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb5d57857-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb5d57858-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb5d57859-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 728 of act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s294a"},"text":"section 294a of this title","children":[],"tail":" prior to the general revision of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/102/408"},"text":"Pub. L. 102–408","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 728 of act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s293h"},"text":"section 293h of this title","children":[],"tail":" prior to renumbering by "},{"tag":"ref","attrib":{"href":"/us/pl/94/484"},"text":"Pub. L. 94–484","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
