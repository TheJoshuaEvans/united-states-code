{"tag":"section","attrib":{"id":"idb59058ea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s289g–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"289g–2"},"text":"§ 289g–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibitions regarding human fetal tissue","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb59058eb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s289g–2/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purchase of tissue","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It shall be unlawful for any person to knowingly acquire, receive, or otherwise transfer any human fetal tissue for valuable consideration if the transfer affects interstate commerce.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb59058ec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s289g–2/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Solicitation or acceptance of tissue as directed donation for use in transplantation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It shall be unlawful for any person to solicit or knowingly acquire, receive, or accept a donation of human fetal tissue for the purpose of transplantation of such tissue into another person if the donation affects interstate commerce, the tissue will be or is obtained pursuant to an induced abortion, and—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb59058ed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s289g–2/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the donation will be or is made pursuant to a promise to the donating individual that the donated tissue will be transplanted into a recipient specified by such individual;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb59058ee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s289g–2/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the donated tissue will be transplanted into a relative of the donating individual; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb59058ef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s289g–2/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the person who solicits or knowingly acquires, receives, or accepts the donation has provided valuable consideration for the costs associated with such abortion.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb59058f0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s289g–2/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Solicitation or acceptance of tissue from fetuses gestated for research purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It shall be unlawful for any person or entity involved or engaged in interstate commerce to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5908001-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s289g–2/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" solicit or knowingly acquire, receive, or accept a donation of human fetal tissue knowing that a human pregnancy was deliberately initiated to provide such tissue; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5908002-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s289g–2/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" knowingly acquire, receive, or accept tissue or cells obtained from a human embryo or fetus that was gestated in the uterus of a nonhuman animal.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5908003-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s289g–2/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criminal penalties for violations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5908004-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s289g–2/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person who violates subsection (a), (b), or (c) shall be fined in accordance with title 18, subject to paragraph (2), or imprisoned for not more than 10 years, or both.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5908005-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s289g–2/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalties applicable to persons receiving consideration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to the imposition of a fine under paragraph (1), if the person involved violates subsection (a) or (b)(3), a fine shall be imposed in an amount not less than twice the amount of the valuable consideration received.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5908006-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s289g–2/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5908007-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s289g–2/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “human fetal tissue” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s289g–1/g"},"text":"section 289g–1(g) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5908008-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s289g–2/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “interstate commerce” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s321/b"},"text":"section 321(b) of title 21","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5908009-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s289g–2/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “valuable consideration” does not include reasonable payments associated with the transportation, implantation, processing, preservation, quality control, or storage of human fetal tissue.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb590800a-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title IV, § 498B, as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/43/tI/s112"},"text":"Pub. L. 103–43, title I, § 112","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-06-10"},"text":"June 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/131"},"text":"107 Stat. 131","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/242/s2"},"text":"Pub. L. 109–242, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-07-19"},"text":"July 19, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/570"},"text":"120 Stat. 570","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb590800b-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb590800c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb590800d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/242/s2/2"},"text":"Pub. L. 109–242, § 2(2)","children":[],"tail":", added subsec. (c). Former subsec. (c) redesignated (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/242/s2/1"},"text":"Pub. L. 109–242, § 2(1)","children":[],"tail":", (3), redesignated subsec. (c) as (d) and substituted “(a), (b), or (c)” for “(a) or (b)” in par. (1). Former subsec. (d) redesignated (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/242/s2/1"},"text":"Pub. L. 109–242, § 2(1)","children":[],"tail":", (4), redesignated subsec. (d) as (e) and substituted “section 289g–1(g)” for “section 289g–1(f)” in par. (1)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
