{"tag":"section","attrib":{"id":"idb5ce4c89-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s292"},"text":null,"children":[{"tag":"num","attrib":{"value":"292"},"text":"§ 292.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statement of purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The purpose of this subpart is to enable the Secretary to provide a Federal program of student loan insurance for students in (and certain former students of) eligible institutions (as defined in section 292","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":" of this title)."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb5ce4c8a-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title VII, § 701, as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/408/tI/s102"},"text":"Pub. L. 102–408, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-13"},"text":"Oct. 13, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1994"},"text":"106 Stat. 1994","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb5ce4c8b-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb5ce4c8c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb5ce4c8d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 292, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373/tVII/s700"},"text":"act July 1, 1944, ch. 373, title VII, § 700","children":[],"tail":", as added "},{"tag":"date","attrib":{"date":"1976-10-12"},"text":"Oct. 12, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/94/484/tII/s201/b"},"text":"Pub. L. 94–484, title II, § 201(b)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2246"},"text":"90 Stat. 2246","children":[],"tail":", set forth limitations on use of appropriations, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tXXVII/s2715"},"text":"Pub. L. 97–35, title XXVII, § 2715","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/913"},"text":"95 Stat. 913","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 292, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373/tVII/s701"},"text":"act July 1, 1944, ch. 373, title VII, § 701","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/act/1956-07-30/ch779/s2"},"text":"July 30, 1956, ch. 779, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/717"},"text":"70 Stat. 717","children":[],"tail":"; amended "},{"tag":"date","attrib":{"date":"1963-09-24"},"text":"Sept. 24, 1963","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/88/129/s2/a"},"text":"Pub. L. 88–129, § 2(a)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/77/164"},"text":"77 Stat. 164","children":[],"tail":", stated Congressional findings and declaration of policy respecting grants for construction of health research facilities, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/94/484/tII/s201/a"},"text":"Pub. L. 94–484, title II, § 201(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-12"},"text":"Oct. 12, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2246"},"text":"90 Stat. 2246","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior section 701 of act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s292a"},"text":"section 292a of this title","children":[],"tail":" prior to the general revision of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/102/408"},"text":"Pub. L. 102–408","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb5ce4c8e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb5ce4c8f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/408/tI/s103"},"text":"Pub. L. 102–408, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-13"},"text":"Oct. 13, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2069"},"text":"106 Stat. 2069","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/408/tI/s103"},"text":"“The amendment made by section 102 [enacting this subchapter] takes effect on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1992-10-13"},"text":"Oct. 13, 1992","children":[],"tail":"], except that section 708 of the Public Health Service Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s292g"},"text":"42 U.S.C. 292g","children":[],"tail":"], as added by section 102 of this Act, takes effect "},{"tag":"date","attrib":{"date":"1993-01-01"},"text":"January 1, 1993","children":[],"tail":". Until such date, section 732(c) of the Public Health Service Act [former "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s294e/c"},"text":"42 U.S.C. 294e(c)","children":[],"tail":"], as in effect on the day before the date of the enactment of this Act, continues in effect in lieu of such section 708.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb5ce4c90-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Transfer of Health Education Assistance Loan Program","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/76/dH/tV/s525"},"text":"Pub. L. 113–76, div. H, title V, § 525","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-01-17"},"text":"Jan. 17, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/413"},"text":"128 Stat. 413","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/113/76/dH/tV/s525"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Health Education Assistance Loan (‘HEAL’) program under title VII, part A, subpart I of the PHS [Public Health Service] Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s292"},"text":"42 U.S.C. 292","children":[],"tail":" et seq.], and the authority to administer such program, including servicing, collecting, and enforcing any loans that were made under such program that remain outstanding, shall be permanently transferred from the Secretary of Health and Human Services to the Secretary of Education no later than the end of the first fiscal quarter that begins after the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"2014-01-17"},"text":"Jan. 17, 2014","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transfer of Functions, Assets, and Liabilities","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The functions, assets, and liabilities of the Secretary of Health and Human Services relating to such program shall be transferred to the Secretary of Education.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Interdepartmental Coordination of Transfer","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Health and Human Services and the Secretary of Education shall carry out the transfer of the HEAL program described in subsection (a), including the transfer of the functions, assets, and liabilities specified in subsection (b), in the manner that they determine is most appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of Authorities Under HEA of ","children":[],"tail":"1965.—"}],"tail":null},{"tag":"content","attrib":{},"text":"In servicing, collecting, and enforcing the loans described in subsection (a), the Secretary of Education shall have available any and all authorities available to such Secretary in servicing, collecting, or enforcing a loan made, insured, or guaranteed under part B of title IV of the HEA [Higher Education Act] of 1965 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1071"},"text":"20 U.S.C. 1071","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"“(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Conforming Amendments","children":[],"tail":".—"}],"tail":null},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb5ce4c91-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"p","attrib":{},"text":"[Amended section 292","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":" of this title.]”"}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb5ce4c92-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Study on Effectiveness of Health Professions Programs","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/408/tIII/s309"},"text":"Pub. L. 102–408, title III, § 309","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-13"},"text":"Oct. 13, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2089"},"text":"106 Stat. 2089","children":[],"tail":", directed the Comptroller General to conduct a study of the programs carried out under this subchapter and subchapter VI of this chapter for the purpose of determining the effectiveness of such programs in increasing the number of primary care providers (physicians, physician assistants, nurse midwives, nurse practitioners and general dentists), nurses and allied health personnel, improving the geographic distribution of health professionals in medically underserved and rural areas, and recruiting and retaining as students in health professions schools individuals who are members of a minority group, and report to the Congress not later than "},{"tag":"date","attrib":{"date":"1994-01-01"},"text":"Jan. 1, 1994","children":[],"tail":", on findings and recommendations made as a result of the study relevant to the reauthorization of such programs."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
