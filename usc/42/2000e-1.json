{"tag":"section","attrib":{"id":"idbbbd00f7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000e–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"2000e–1"},"text":"§ 2000e–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbbbd00f8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000e–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inapplicability of subchapter to certain aliens and employees of religious entities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This subchapter shall not apply to an employer with respect to the employment of aliens outside any State, or to a religious corporation, association, educational institution, or society with respect to the employment of individuals of a particular religion to perform work connected with the carrying on by such corporation, association, educational institution, or society of its activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbbbd00f9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000e–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compliance with statute as violative of foreign law","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It shall not be unlawful under section 2000e–2 or 2000e–3 of this title for an employer (or a corporation controlled by an employer), labor organization, employment agency, or joint labor-management committee controlling apprenticeship or other training or retraining (including on-the-job training programs) to take any action otherwise prohibited by such section, with respect to an employee in a workplace in a foreign country if compliance with such section would cause such employer (or such corporation), such organization, such agency, or such committee to violate the law of the foreign country in which such workplace is located.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbbbd00fa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000e–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Control of corporation incorporated in foreign country","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbbbd00fb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000e–1/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If an employer controls a corporation whose place of incorporation is a foreign country, any practice prohibited by section 2000e–2 or 2000e–3 of this title engaged in by such corporation shall be presumed to be engaged in by such employer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbbd00fc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000e–1/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Sections 2000e–2 and 2000e–3 of this title shall not apply with respect to the foreign operations of an employer that is a foreign person not controlled by an American employer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbbd00fd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000e–1/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of this subsection, the determination of whether an employer controls a corporation shall be based on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbbbd00fe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000e–1/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the interrelation of operations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbbbd00ff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000e–1/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the common management;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbbbd0100-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000e–1/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the centralized control of labor relations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbbbd0101-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000e–1/c/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the common ownership or financial control,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"of the employer and the corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbbbd0102-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/352/tVII/s702"},"text":"Pub. L. 88–352, title VII, § 702","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-07-02"},"text":"July 2, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/255"},"text":"78 Stat. 255","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/92/261/s3"},"text":"Pub. L. 92–261, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-03-24"},"text":"Mar. 24, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/103"},"text":"86 Stat. 103","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/166/tI/s109/b/1"},"text":"Pub. L. 102–166, title I, § 109(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-11-21"},"text":"Nov. 21, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1077"},"text":"105 Stat. 1077","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbbbd0103-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbbbd0104-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbbbd0105-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/166"},"text":"Pub. L. 102–166","children":[],"tail":" designated existing provisions as subsec. (a) and added subsecs. (b) and (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1972—","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/261"},"text":"Pub. L. 92–261","children":[],"tail":" reenacted section catchline without change and amended text generally. Prior to amendment, text read as follows: “This subchapter shall not apply to an employer with respect to the employment of aliens outside any State, or to a religious corporation, association, or society with respect to the employment of individuals of a particular religion to perform work connected with the carrying on by such corporation, association, or society of its religious activities or to an educational institution with respect to the employment of individuals to perform work connected with the educational activities of such institution.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbbbd0106-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbbbd0107-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1991 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/166"},"text":"Pub. L. 102–166","children":[],"tail":" inapplicable to conduct occurring before "},{"tag":"date","attrib":{"date":"1991-11-21"},"text":"Nov. 21, 1991","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/102/166/s109/c"},"text":"section 109(c) of Pub. L. 102–166","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2000e"},"text":"section 2000e of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
