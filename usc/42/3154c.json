{"tag":"section","attrib":{"id":"idbc7701cc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154c"},"text":null,"children":[{"tag":"num","attrib":{"value":"3154c"},"text":"§ 3154c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Direct expenditure or redistribution by recipient","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbc7701cd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subsection (b), a recipient of a grant under section 3141, 3143, or 3147 of this title may directly expend the grant funds or may redistribute the funds in the form of a subgrant to other eligible recipients to fund required components of the scope of work approved for the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc7701ce-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A recipient may not redistribute grant funds received under section 3141 or 3143 of this title to a for-profit entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc7701cf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Economic adjustment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subsection (d), a recipient of a grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3149"},"text":"section 3149 of this title","children":[],"tail":" may directly expend the grant funds or may redistribute the funds to public and private entities in the form of a grant, loan, loan guarantee, payment to reduce interest on a loan guarantee, or other appropriate assistance."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc7701d0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154c/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Under subsection (c), a recipient may not provide any grant to a private for-profit entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc7701d1-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/136/tII/s217"},"text":"Pub. L. 89–136, title II, § 217","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/373/tII/s212/a"},"text":"Pub. L. 108–373, title II, § 212(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-27"},"text":"Oct. 27, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1766"},"text":"118 Stat. 1766","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
