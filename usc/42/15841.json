{"tag":"section","attrib":{"id":"idbfe48b80-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15841"},"text":null,"children":[{"tag":"num","attrib":{"value":"15841"},"text":"§ 15841.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Energy-efficient appliances","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In purchasing appliances, a public housing agency shall purchase energy-efficient appliances that are Energy Star products or FEMP-designated products, as such terms are defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s8259b"},"text":"section 8259b of this title","children":[],"tail":", unless the purchase of energy-efficient appliances is not cost-effective to the agency."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbfe48b81-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tI/s152"},"text":"Pub. L. 109–58, title I, § 152","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/649"},"text":"119 Stat. 649","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
