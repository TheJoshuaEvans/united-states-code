{"tag":"section","attrib":{"id":"idc056fc11-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18361"},"text":null,"children":[{"tag":"num","attrib":{"value":"18361"},"text":"§ 18361.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sense of Congress on the Space Shuttle program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc056fc12-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18361/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Congress makes the following findings:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc056fc13-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18361/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Space Shuttle program represents a national asset consisting of critical skills and capabilities, including the ability to lift large payloads into space and return them to Earth.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc056fc14-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18361/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Space Shuttle has carried more than 355 people from 16 nations into space.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc056fc15-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18361/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Space Shuttle has projected the best of American values around the world, and Space Shuttle crews have sparked the imagination and dreams of the world’s youth and young at heart.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc056fc16-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18361/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sense of Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is the sense of Congress that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc056fc17-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18361/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" it is essential that the retirement of the Space Shuttle and the transition to new human space flight capabilities be done in a manner that builds upon the legacy of this national asset; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc056fc18-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18361/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" it is imperative for the United States to retain the skills and the industrial capability to provide a follow-on Space Launch System that is primarily designed for missions beyond near-Earth space, while offering some potential for supplanting shuttle delivery capabilities to low-Earth orbit, particularly in support of ISS requirements, if necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc056fc19-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/267/tVI/s601"},"text":"Pub. L. 111–267, title VI, § 601","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-11"},"text":"Oct. 11, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2828"},"text":"124 Stat. 2828","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
