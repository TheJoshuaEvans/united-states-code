{"tag":"section","attrib":{"id":"idbfc0d72f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13435"},"text":null,"children":[{"tag":"num","attrib":{"value":"13435"},"text":"§ 13435.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Electric motor vehicles and associated equipment research and development","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfc0d730-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13435/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall conduct, pursuant to the Federal Nonnuclear Energy Research and Development Act of 1974 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5901–592"},"text":"42 U.S.C. 5901–592","children":[],"tail":"0), a research and development program on electric motor vehicles and associated equipment. Such program shall be conducted in cooperation with the electric utility industry, and automobile industry, battery manufacturers, and such other persons as the Secretary considers appropriate."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfc0d731-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13435/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Comprehensive plan","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfc0d732-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13435/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall prepare a comprehensive 5-year program plan for carrying out the purposes of this section. Such comprehensive plan shall be updated biennially for a period of not less than 10 years after ","children":[{"tag":"date","attrib":{"date":"1992-10-24"},"text":"October 24, 1992","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc0d733-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13435/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The comprehensive plan under paragraph (1) shall be prepared in consultation with the Administrator of the Environmental Protection Agency, the Secretary of Transportation, the Secretary of Commerce, the heads of other appropriate Federal agencies, representatives of the electric utility industry, electric motor vehicle manufacturers, the United States automobile industry, and such other persons as the Secretary considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc32024-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13435/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The comprehensive plan shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfc32025-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13435/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a prioritization of research areas critical to the commercialization of electric motor vehicles, including advanced battery technology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfc32026-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13435/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the program elements, management structure, and activities, including program responsibilities, of Federal agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfc32027-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13435/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the program strategies, including technical milestones to be achieved toward specific goals during each fiscal year of the comprehensive plan for all major activities and projects;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfc32028-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13435/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the estimated costs of individual program elements, including estimated costs for each of the fiscal years of the comprehensive plan for each of the participating Federal agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfc32029-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13435/b/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the methods of technology transfer;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfc3202a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13435/b/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a proposal for participation by non-Federal entities in the implementation of the comprehensive plan; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfc3202b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13435/b/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other information as the Secretary considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc3202c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13435/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"1992-10-24"},"text":"October 24, 1992","children":[],"tail":", the Secretary shall transmit the comprehensive plan to the Congress. Biennial updates shall be submitted to the Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfc3202d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13435/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperative agreements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, consistent with the comprehensive plan under subsection (b), may enter into cooperative agreements to conduct research and development projects with industry in such areas of technology development as—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfc3202e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13435/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" high efficiency electric power trains, including advanced motors, motor controllers, and hybrid power trains for electric motor vehicle range improvement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc3202f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13435/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" light-weight structures for electric motor vehicle weight reduction;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc32030-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13435/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advanced batteries with high energy density and power density, and improved range or recharging cycles for a given unit weight, for electric motor vehicle application;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc32031-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13435/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hybrid power trains incorporating an electric motor and recyclable battery charged by an onboard liquid fuel engine, designed to significantly improve fuel economies while maintaining acceleration characteristics comparable to a conventionally fueled vehicle;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc32032-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13435/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" batteries and fuel cells for electric-hybrid vehicle application;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc32033-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13435/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fuel cells and fuel cell systems for primary electric motor vehicle power sources; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc32034-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13435/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" photovoltaics for use with electric motor vehicles.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfc32035-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13435/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Solicitation of proposals","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfc32036-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13435/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Within one year after ","children":[{"tag":"date","attrib":{"date":"1992-10-24"},"text":"October 24, 1992","children":[],"tail":", the Secretary shall solicit proposals for cooperative agreements for research and development under subsection (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc32037-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13435/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Thereafter, the Secretary may solicit additional proposals for cooperative agreements under subsection (c) if, in the judgment of the Secretary, such cooperative agreements could contribute to the development of electric motor vehicles and associated equipment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfc32038-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13435/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost-sharing","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfc32039-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13435/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall require at least 50 percent of the costs directly and specifically related to any cooperative agreement under this section, other than a cooperative agreement under subsection (j), to be from non-Federal sources. Such share may be in the form of cash, personnel, services, equipment, and other resources.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc3203a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13435/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary may reduce the amount of costs required to be provided by non-Federal sources under paragraph (1), if the Secretary determines that the reduction is necessary and appropriate—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfc3203b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13435/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" considering the technological risks involved in the project; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfc3203c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13435/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in order to meet the objectives of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfc3203d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13435/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deployment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfc3203e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13435/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall conduct a program designed to accelerate deployment of advanced battery technologies for use with electric motor vehicles.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc3203f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13435/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In carrying out the program authorized by this subsection, the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfc32040-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13435/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" undertake an inventory and assessment of advanced battery technologies and electric motor vehicle technologies and the commercial capability of such technologies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfc32041-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13435/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop a Federal industry information exchange program to improve the deployment or use of such technologies, which may consist of workshops, publications, conferences, and a data base for use by the public and private sectors.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfc32042-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13435/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Domestic parts manufacturers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out this section, the Secretary, in consultation with the Secretary of Commerce, shall issue regulations to ensure that the procurement practices of participating electric motor vehicle and associated equipment manufacturers do not discriminate against the United States manufacturers of vehicle parts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfc32043-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13435/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hold harmless","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed to alter, affect, modify, or change any activities or agreements initiated prior to ","children":[{"tag":"date","attrib":{"date":"1992-10-24"},"text":"October 24, 1992","children":[],"tail":", with domestic motor vehicle manufacturers through joint venture or consortium agreements regarding batteries for electric motor vehicles."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfc32044-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13435/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall consult with the Administrator of the Environmental Protection Agency and the Secretary of Transportation in carrying out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfc32045-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13435/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fuel cells for transportation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfc32046-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13435/j/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall develop and implement a comprehensive program of research, development, and demonstration of fuel cells and related systems for transportation applications through the establishment of one or more cooperative programs among industry, government, and research institutions to develop and demonstrate the use of fuel cells as the primary power source for private and mass transit vehicles and other mobile applications.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc32047-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13435/j/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Research, development, and demonstration activities under this subsection shall be designed to incorporate one or more of the following priorities:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfc32048-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13435/j/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The potential for near-term to mid-term commercialization.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfc32049-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13435/j/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The ability of the systems to use a variety of renewable and nonfossil fuels.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfc3204a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13435/j/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Emission reduction and energy conservation potential.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfc3204b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13435/j/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The potential to utilize fuel cells and fuel cell systems developed under Department of Defense and National Aeronautics and Space Administration programs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfc3204c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13435/j/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The potential to take maximum practical advantage of advances made in electric motor vehicle research, stationary source fuel cell research, and other research activities authorized by this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc3204d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13435/j/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfc3204e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13435/j/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Research, development, and demonstration projects selected by the Secretary under this subsection shall apply to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbfc3204f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13435/j/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" passenger vehicles;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbfc32050-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13435/j/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" vans and utility vehicles;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbfc32051-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13435/j/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" light rail systems and locomotives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbfc32052-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13435/j/3/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" trucks, including long-haul trucks, dump trucks, and garbage trucks;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbfc32053-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13435/j/3/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" passenger buses;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbfc32054-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13435/j/3/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" non-chlorofluorocarbon mobile refrigeration systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbfc32055-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13435/j/3/A/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" marine vessels, including recreational marine engines; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbfc32056-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13435/j/3/A/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" mobile engines and power generation, including recreational generators, and industrial and construction equipment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfc32057-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13435/j/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall establish programs to undertake research, development, and demonstration activities for the applications listed in clauses (i) through (viii) of subparagraph (A) in each of fiscal years 1993, 1994, 1995, and 1996, based on the priorities established in paragraph (2), so that by the end of the period, research, development, and demonstration activities are under way for the applications under each such clause. The initiatives authorized and implemented pursuant to this subsection shall be in addition to any other fuel cell programs authorized in existing law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfc32058-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13435/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfc32059-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13435/k/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “advanced battery technology” means electrochemical storage devices and systems, including fuel cells, and associated technology necessary to charge, discharge, recharge, or regenerate such devices, for use as a source of power for an electric motor vehicle and any other associated equipment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc3205a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13435/k/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “associated equipment” means equipment necessary for the regeneration, refueling, or recharging of batteries or other forms of electric energy used to power an electric motor vehicle and, in the case of electric-hybrid vehicles, such term includes nonpetroleum-related equipment necessary for, and solely related to, the demonstration of such vehicles;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc3205b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13435/k/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “electric motor vehicle” means a motor vehicle primarily powered by an electric motor that draws current from rechargeable storage batteries, fuel cells, photovoltaic arrays, or other sources of electric current and may include an electric-hybrid vehicle; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc3205c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13435/k/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “electric-hybrid vehicle” means vehicle primarily powered by an electric motor that draws current from rechargeable storage batteries, fuel cells, or other sources of electric current and also relies on a nonelectric source of power that also operates on or is capable of operating on a nonelectrical source of power.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfc3205d-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/tXX/s2025"},"text":"Pub. L. 102–486, title XX, § 2025","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3063"},"text":"106 Stat. 3063","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/362/tIV/s402/a"},"text":"Pub. L. 105–362, title IV, § 402(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-10"},"text":"Nov. 10, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3283"},"text":"112 Stat. 3283","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbfc3205e-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbfc3205f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbfc32060-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Nonnuclear Energy Research and Development Act of 1974, referred to in subsec. (a), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/577"},"text":"Pub. L. 93–577","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-12-31"},"text":"Dec. 31, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1878"},"text":"88 Stat. 1878","children":[],"tail":", which is classified generally to chapter 74 (§ 5901 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5901"},"text":"section 5901 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbfc32061-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/362/s402/a/1"},"text":"Pub. L. 105–362, § 402(a)(1)","children":[],"tail":", substituted “biennially” for “annually” in second sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/362/s402/a/2"},"text":"Pub. L. 105–362, § 402(a)(2)","children":[],"tail":", substituted “Biennial updates” for “Annual updates” in second sentence."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
