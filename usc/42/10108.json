{"tag":"section","attrib":{"id":"idbf0e0165-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10108"},"text":null,"children":[{"tag":"num","attrib":{"value":"10108"},"text":"§ 10108.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability to transportation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter shall be construed to affect Federal, State, or local laws pertaining to the transportation of spent nuclear fuel or high-level radioactive waste.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbf0e0166-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/425/s9"},"text":"Pub. L. 97–425, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-07"},"text":"Jan. 7, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2206"},"text":"96 Stat. 2206","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
