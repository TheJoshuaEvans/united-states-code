{"tag":"section","attrib":{"id":"idbc12e8e2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2276"},"text":null,"children":[{"tag":"num","attrib":{"value":"2276"},"text":"§ 2276.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tampering with Restricted Data","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever, with intent to injure the United States or with intent to secure an advantage to any foreign nation, removes, conceals, tampers with, alters, mutilates, or destroys any document, writing, sketch, photograph, plan, model, instrument, appliance, or note involving or incorporating Restricted Data and used by any individual or person in connection with the production of special nuclear material, or research or development relating to atomic energy, conducted by the United States, or financed in whole or in part by Federal funds, or conducted with the aid of special nuclear material, shall be punished by imprisonment for life, or by imprisonment for any term of years or a fine of not more than $20,000 or both.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbc12e8e3-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-08-01/ch724"},"text":"Aug. 1, 1946, ch. 724","children":[],"tail":", title I, § 226, as added "},{"tag":"ref","attrib":{"href":"/us/act/1954-08-30/ch1073/s1"},"text":"Aug. 30, 1954, ch. 1073, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/959"},"text":"68 Stat. 959","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/91/161/s3/b"},"text":"Pub. L. 91–161, § 3(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-12-24"},"text":"Dec. 24, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/444"},"text":"83 Stat. 444","children":[],"tail":"; renumbered title I, "},{"tag":"ref","attrib":{"href":"/us/pl/102/486/tIX/s902/a/8"},"text":"Pub. L. 102–486, title IX, § 902(a)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2944"},"text":"106 Stat. 2944","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc12e8e4-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc12e8e5-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbc12e8e6-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1969—","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/161"},"text":"Pub. L. 91–161","children":[],"tail":" made death penalty inapplicable for willful violation, or attempted violation of this section with intent to injure the United States, or secure an advantage for any foreign nation."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbc12e8e7-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbc12e8e8-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1969 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/161"},"text":"Pub. L. 91–161","children":[],"tail":" applicable to offenses committed on or after "},{"tag":"date","attrib":{"date":"1969-12-24"},"text":"Dec. 24, 1969","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/91/161/s7"},"text":"section 7 of Pub. L. 91–161","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2272"},"text":"section 2272 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
