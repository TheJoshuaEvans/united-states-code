{"tag":"section","attrib":{"id":"idbf281870-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10401"},"text":null,"children":[{"tag":"num","attrib":{"value":"10401"},"text":"§ 10401.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Short title; purpose","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf281871-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10401/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Short title","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This chapter may be cited as the “Family Violence Prevention and Services Act”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf281872-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10401/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is the purpose of this chapter to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf281873-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10401/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist States and Indian tribes in efforts to increase public awareness about, and primary and secondary prevention of, family violence, domestic violence, and dating violence;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf281874-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10401/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist States and Indian tribes in efforts to provide immediate shelter and supportive services for victims of family violence, domestic violence, or dating violence, and their dependents;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf281875-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10401/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for a national domestic violence hotline;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf281876-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10401/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for technical assistance and training relating to family violence, domestic violence, and dating violence programs to States and Indian tribes, local public agencies (including law enforcement agencies, courts, and legal, social service, and health care professionals in public agencies), nonprofit private organizations (including faith-based and charitable organizations, community-based organizations, and voluntary associations), tribal organizations, and other persons seeking such assistance and training.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf281877-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/457/tIII/s301"},"text":"Pub. L. 98–457, title III, § 301","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/320/tII/s201"},"text":"Pub. L. 111–320, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-20"},"text":"Dec. 20, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3484"},"text":"124 Stat. 3484","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf281878-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf281879-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbf28187a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 10401, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/457/tIII/s302"},"text":"Pub. L. 98–457, title III, § 302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-09"},"text":"Oct. 9, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1757"},"text":"98 Stat. 1757","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/295/tIII/s302"},"text":"Pub. L. 102–295, title III, § 302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-05-28"},"text":"May 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/201"},"text":"106 Stat. 201","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/36/tIV/s415/1"},"text":"Pub. L. 108–36, title IV, § 415(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-06-25"},"text":"June 25, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/830"},"text":"117 Stat. 830","children":[],"tail":", related to declaration of purpose, prior to the general amendment of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/111/320"},"text":"Pub. L. 111–320","children":[],"tail":". See subsec. (b) of this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/457/s301"},"text":"section 301 of Pub. L. 98–457","children":[],"tail":", title III, "},{"tag":"date","attrib":{"date":"1984-10-09"},"text":"Oct. 9, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1757"},"text":"98 Stat. 1757","children":[],"tail":", provided a short title for title III of "},{"tag":"ref","attrib":{"href":"/us/pl/98/457"},"text":"Pub. L. 98–457","children":[],"tail":" and was set out as a note under former "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s10401"},"text":"section 10401 of this title","children":[],"tail":", prior to the general amendment of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/111/320"},"text":"Pub. L. 111–320","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbf28187b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbf28187c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Programs for Survivors of Sexual Assault and Domestic Violence","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/2/tII/s2204/b"},"text":"Pub. L. 117–2, title II, § 2204(b)","children":[],"tail":"–(d), "},{"tag":"date","attrib":{"date":"2021-03-11"},"text":"Mar. 11, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/34"},"text":"135 Stat. 34","children":[],"tail":", 35, provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/2/tII/s2204/b"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"COVID–19 Public Health Emergency Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section [amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s10403"},"text":"section 10403 of this title","children":[],"tail":"], the term ‘COVID–19 public health emergency’ means the public health emergency declared by the Secretary of Health and Human Services under section 319 of the Public Health Service Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s247d"},"text":"42 U.S.C. 247d","children":[],"tail":") on "},{"tag":"date","attrib":{"date":"2020-01-31"},"text":"January 31, 2020","children":[],"tail":", with respect to COVID–19, including any renewal of the declaration."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Grants to Support Culturally Specific Populations.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In addition to amounts otherwise made available, there is appropriated, out of any amounts in the Treasury not otherwise appropriated, to the Secretary of Health and Human Services (in this section referred to as the ‘Secretary’), $49,500,000 for fiscal year 2021, to be available until expended, to carry out this subsection (excluding Federal administrative costs, for which funds are appropriated under subsection (e)).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of funds","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"From amounts appropriated under paragraph (1), the Secretary acting through the Director of the Family Violence Prevention and Services Program, shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support culturally specific community-based organizations to provide culturally specific activities for survivors of sexual assault and domestic violence, to address emergent needs resulting from the COVID–19 public health emergency and other public health concerns; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support culturally specific community-based organizations that provide culturally specific activities to promote strategic partnership development and collaboration in responding to the impact of COVID–19 and other public health concerns on survivors of sexual assault and domestic violence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Grants to Support Survivors of Sexual Assault.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In addition to amounts otherwise made available, there is appropriated, out of any amounts in the Treasury not otherwise appropriated, to the Secretary, $198,000,000 for fiscal year 2021, to be available until expended, to carry out this subsection (excluding Federal administrative costs, for which funds are appropriated under subsection (e)).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of funds","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"From amounts appropriated under paragraph (1), the Secretary acting through the Director of the Family Violence Prevention and Services Program, shall assist rape crisis centers in transitioning to virtual services and meeting the emergency needs of survivors.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbf28187d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Study of Training Needs of Health Professionals","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/392/tIV/s407/b"},"text":"Pub. L. 105–392, title IV, § 407(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3589"},"text":"112 Stat. 3589","children":[],"tail":", related to study by the Institute of Medicine concerning the training needs of health professionals with respect to the detection and referral of victims of family or acquaintance violence and required the Institute to submit a report to Congress concerning such study not later than 2 years after "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
