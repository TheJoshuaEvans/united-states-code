{"tag":"section","attrib":{"id":"idb64f146c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–27"},"text":null,"children":[{"tag":"num","attrib":{"value":"300j–27"},"text":"§ 300j–27.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Registry for lead exposure and Advisory Committee","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb64f146d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–27/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb64f146e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–27/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" City","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “City” means a city exposed to lead contamination in the local drinking water system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb64f146f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–27/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Committee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Committee” means the Advisory Committee established under subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb64f1470-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–27/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of Health and Human Services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb64f1471-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–27/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lead exposure registry","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish within the Agency for Toxic Substances and Disease Registry or the Centers for Disease Control and Prevention at the discretion of the Secretary, or establish through a grant award or contract, a lead exposure registry to collect data on the lead exposure of residents of a City on a voluntary basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb64f1472-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–27/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisory Committee","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb64f1473-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–27/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb64f1474-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–27/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall establish, within the Agency for Toxic Substances and Disease Registry an Advisory Committee in coordination with the Director of the Centers for Disease Control and Prevention and other relevant agencies as determined by the Secretary consisting of Federal members and non-Federal members, and which shall include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb64f1475-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–27/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an epidemiologist;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb64f1476-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–27/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a toxicologist;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb64f1477-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–27/c/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a mental health professional;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb64f1478-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–27/c/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a pediatrician;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb64f1479-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–27/c/1/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an early childhood education expert;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb64f147a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–27/c/1/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a special education expert;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb64f147b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–27/c/1/A/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a dietician; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb64f147c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–27/c/1/A/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an environmental health expert.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb64f147d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–27/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Membership in the Committee shall not exceed 15 members and not less than ½ of the members shall be Federal members.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb64f147e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–27/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chair","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall designate a chair from among the Federal members appointed to the Committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb64f147f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–27/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Members of the Committee shall serve for a term of not more than 3 years and the Secretary may reappoint members for consecutive terms.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb64f1480-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–27/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of FACA","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Committee shall be subject to the Federal Advisory Committee Act (5 U.S.C. App.).","children":[{"tag":"ref","attrib":{"idref":"fn002355"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002355"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb64f1481-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–27/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibilities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Committee shall, at a minimum—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb64f1482-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–27/c/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review the Federal programs and services available to individuals and communities exposed to lead;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb64f1483-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–27/c/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review current research on lead poisoning to identify additional research needs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb64f1484-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–27/c/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review and identify best practices, or the need for best practices, regarding lead screening and the prevention of lead poisoning;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb64f1485-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–27/c/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify effective services, including services relating to healthcare, education, and nutrition for individuals and communities affected by lead exposure and lead poisoning, including in consultation with, as appropriate, the lead exposure registry as established in subsection (b); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb64f1486-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–27/c/5/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" undertake any other review or activities that the Secretary determines to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb64f1487-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–27/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Annually for 5 years and thereafter as determined necessary by the Secretary or as required by Congress, the Committee shall submit to the Secretary, the Committees on Finance, Health, Education, Labor, and Pensions, and Agriculture, Nutrition, and Forestry of the Senate and the Committees on Education and the Workforce, Energy and Commerce, and Agriculture of the House of Representatives a report that includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb64f1488-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–27/c/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an evaluation of the effectiveness of the Federal programs and services available to individuals and communities exposed to lead;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb64f1489-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–27/c/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an evaluation of additional lead poisoning research needs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb64f148a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–27/c/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of any effective screening methods or best practices used or developed to prevent or screen for lead poisoning;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb64f148b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–27/c/6/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" input and recommendations for improved access to effective services relating to health care, education, or nutrition for individuals and communities impacted by lead exposure; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb64f148c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–27/c/6/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other recommendations for communities affected by lead exposure, as appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb64f148d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–27/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated for the period of fiscal years 2017 through 2021—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb64f148e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–27/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $17,500,000 to carry out subsection (b); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb64f148f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–27/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $2,500,000 to carry out subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb64f1490-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/322/tII/s2203"},"text":"Pub. L. 114–322, title II, § 2203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1734"},"text":"130 Stat. 1734","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb64f1491-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb64f1492-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb64f1493-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Advisory Committee Act, referred to in subsec. (c)(4), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/463"},"text":"Pub. L. 92–463","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-06"},"text":"Oct. 6, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/770"},"text":"86 Stat. 770","children":[],"tail":", which was set out in the Appendix to Title 5, Government Organization and Employees, and was substantially repealed and restated in chapter 10 (§ 1001 et seq.) of Title 5 by "},{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":", §§ 3(a), 7, "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4197"},"text":"136 Stat. 4197","children":[],"tail":", 4361. For disposition of sections of the Act into chapter 10 of Title 5, see Disposition Table preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s101"},"text":"section 101 of Title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb64f1494-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Water and Waste Act of 2016, and also as part of the Water Infrastructure Improvements for the Nation Act, also known as the WIIN Act, and not as part of the Public Health Service Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
