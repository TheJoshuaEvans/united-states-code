{"tag":"section","attrib":{"id":"idbd9c4802-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6346"},"text":null,"children":[{"tag":"num","attrib":{"value":"6346"},"text":"§ 6346.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sustainable manufacturing initiative","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd9c4803-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6346/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As part of the Office of Energy Efficiency and Renewable Energy of the Department of Energy, the Secretary, on the request of a manufacturer, shall carry out onsite technical assessments to identify opportunities for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd9c4804-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6346/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maximizing the energy efficiency of industrial processes and cross-cutting systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd9c4805-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6346/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preventing pollution and minimizing waste;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd9c4806-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6346/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improving efficient use of water in manufacturing processes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd9c4807-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6346/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conserving natural resources; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd9c4808-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6346/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" achieving such other goals as the Secretary determines to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd9c4809-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6346/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To implement any recommendations resulting from an onsite technical assessment carried out under subsection (a) and to accelerate the adoption of new and existing technologies and processes that improve energy efficiency, the Secretary shall coordinate with—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd9c480a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6346/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Advanced Manufacturing Office of the Department of Energy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd9c480b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6346/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Building Technologies Office of the Department of Energy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd9c480c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6346/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Energy Management Program of the Department of Energy; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd9c480d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6346/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the private sector and other appropriate agencies, including the National Institute of Standards and Technology.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd9c480e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6346/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research and development program for sustainable manufacturing and industrial technologies and processes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As part of the industrial efficiency programs of the Department of Energy, the Secretary shall carry out a joint industry-government partnership program to research, develop, and demonstrate new sustainable manufacturing and industrial technologies and processes that maximize the energy efficiency of industrial plants, reduce pollution, and conserve natural resources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd9c480f-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/163/tIII/s376"},"text":"Pub. L. 94–163, title III, § 376","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/dD/tV/s40522/a"},"text":"Pub. L. 117–58, div. D, title V, § 40522(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1067"},"text":"135 Stat. 1067","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd9c4810-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd9c4811-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbd9c4812-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 6346, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/163/tIII/s376"},"text":"Pub. L. 94–163, title III, § 376","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-12-22"},"text":"Dec. 22, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/938"},"text":"89 Stat. 938","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/619/tIV/s461/d/1"},"text":"Pub. L. 95–619, title IV, § 461(d)(1)","children":[],"tail":", title VI, § 691(b)(2), "},{"tag":"date","attrib":{"date":"1978-11-09"},"text":"Nov. 9, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3275"},"text":"92 Stat. 3275","children":[],"tail":", 3288, set forth general provisions relating to compliance with former part C reporting requirements, use of information, and absence of liability for failure to meet energy efficiency improvement targets, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/99/509/tIII/s3101/b"},"text":"Pub. L. 99–509, title III, § 3101(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-21"},"text":"Oct. 21, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1888"},"text":"100 Stat. 1888","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbd9c4813-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbd9c4814-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Wage Rate Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions relating to rates of wages to be paid to laborers and mechanics on projects for construction, alteration, or repair work funded under div. D or an amendment by div. D of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":", including authority of Secretary of Labor, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s18851"},"text":"section 18851 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
