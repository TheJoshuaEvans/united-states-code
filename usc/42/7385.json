{"tag":"section","attrib":{"id":"idbe0c6ff7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385"},"text":null,"children":[{"tag":"num","attrib":{"value":"7385"},"text":"§ 7385.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Offset for certain payments","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"A payment of compensation to an individual, or to a survivor of that individual, under this subchapter shall be offset by the amount of any payment made pursuant to a final award or settlement on a claim (other than a claim for worker’s compensation), against any person, that is based on injuries incurred by that individual on account of the exposure for which compensation is payable under this subchapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbe0c6ff8-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dC/tXXXVI/s3641"},"text":"Pub. L. 106–398, § 1 [div. C, title XXXVI, § 3641]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–509; "},{"tag":"ref","attrib":{"href":"/us/pl/108/375/dC/tXXXI/s3162/a"},"text":"Pub. L. 108–375, div. C, title XXXI, § 3162(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-28"},"text":"Oct. 28, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2186"},"text":"118 Stat. 2186","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbe0c6ff9-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbe0c6ffa-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbe0c6ffb-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375"},"text":"Pub. L. 108–375","children":[],"tail":" substituted “this subchapter” for “part B” and “on account of the exposure for which compensation is payable under this subchapter” for “on account of the exposure of a covered beryllium employee, covered employee with cancer, covered employee with chronic silicosis (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s7384r"},"text":"section 7384r of this title","children":[],"tail":"), or covered uranium employee (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s7384u"},"text":"section 7384u of this title","children":[],"tail":"), while so employed, to beryllium, radiation, silica, or radiation, respectively”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
