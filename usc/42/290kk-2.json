{"tag":"section","attrib":{"id":"idb5c720c9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290kk–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"290kk–2"},"text":"§ 290kk–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on use of funds for certain purposes","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No funds provided under a designated program shall be expended for sectarian worship, instruction, or proselytization.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb5c720ca-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title V, § 596B, formerly § 583, as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/7/tI/s144"},"text":"Pub. L. 106–554, § 1(a)(7) [title I, § 144]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–622; renumbered § 596B, "},{"tag":"ref","attrib":{"href":"/us/pl/119/44/tI/s107/a/2"},"text":"Pub. L. 119–44, title I, § 107(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-01"},"text":"Dec. 1, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/674"},"text":"139 Stat. 674","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
