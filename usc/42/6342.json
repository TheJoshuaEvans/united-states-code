{"tag":"section","attrib":{"id":"idbd99fe42-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6342"},"text":null,"children":[{"tag":"num","attrib":{"value":"6342"},"text":"§ 6342.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Survey and Registry","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd99fe43-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6342/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recoverable waste energy inventory program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd99fe44-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6342/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator, in cooperation with the Secretary and State energy offices, shall establish a recoverable waste energy inventory program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd99fe45-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6342/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Survey","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The program shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd99fe46-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6342/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an ongoing survey of all major industrial and large commercial combustion sources in the United States (as defined by the Administrator) and the sites at which the sources are located; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd99fe47-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6342/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a review of each source for the quantity and quality of waste energy produced at the source.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd99fe48-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6342/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd99fe49-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6342/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 270 days after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"December 19, 2007","children":[],"tail":", the Administrator shall publish a rule for establishing criteria for including sites in the Registry."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd99fe4a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6342/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The criteria shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd99fe4b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6342/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a requirement that, to be included in the Registry, a project at the site shall be determined to be economically feasible by virtue of offering a payback of invested costs not later than 5 years after the date of first full project operation (including incentives offered under this part);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd99fe4c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6342/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" standards to ensure that projects proposed for inclusion in the Registry are not developed or used for the primary purpose of making sales of excess electric power under the regulatory provisions of this part; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd99fe4d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6342/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" procedures for contesting the listing of any source or site on the Registry by any State, utility, or other interested person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd99fe4e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6342/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical support","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"On the request of the owner or operator of a source or site included in the Registry, the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd99fe4f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6342/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide to owners or operators of combustion sources technical support; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd99fe50-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6342/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" offer partial funding (in an amount equal to not more than one-half of total costs) for feasibility studies to confirm whether or not investment in recovery of waste energy or combined heat and power at a source would offer a payback period of 5 years or less.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd99fe51-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6342/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Registry","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd99fe52-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6342/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd99fe53-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6342/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"December 19, 2007","children":[],"tail":", the Administrator shall establish a Registry of Recoverable Waste Energy Sources, and sites on which the sources are located, that meet the criteria established under subsection (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd99fe54-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6342/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Updates; availability","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbd99fe55-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6342/d/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" update the Registry on a regular basis; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd99fe56-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6342/d/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make the Registry available to the public on the website of the Environmental Protection Agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd99fe57-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6342/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contesting listing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any State, electric utility, or other interested person may contest the listing of any source or site by submitting a petition to the Administrator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd99fe58-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6342/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd99fe59-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6342/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall register and include on the Registry all sites meeting the criteria established under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd99fe5a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6342/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quantity of recoverable waste energy","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbd99fe5b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6342/d/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" calculate the total quantities of potentially recoverable waste energy from sources at the sites, nationally and by State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd99fe5c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6342/d/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" make public—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbd99fe5d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6342/d/2/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total quantities described in clause (i); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbd99fe5e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6342/d/2/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information on the criteria pollutant and greenhouse gas emissions savings that might be achieved with recovery of the waste energy from all sources and sites listed on the Registry.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd99fe5f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6342/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of information","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd99fe60-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6342/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall notify owners or operators of recoverable waste energy sources and sites listed on the Registry prior to publishing the listing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd99fe61-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6342/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Detailed quantitative information","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbd99fe62-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6342/d/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in clause (ii), the owner or operator of a source at a site may elect to have detailed quantitative information concerning the site not made public by notifying the Administrator of the election.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd99fe63-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6342/d/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limited availability","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The information shall be made available to—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbd99fe64-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6342/d/3/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the applicable State energy office; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbd99fe65-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6342/d/3/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any utility requested to support recovery of waste energy from the source pursuant to the incentives provided under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6344"},"text":"section 6344 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd99fe66-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6342/d/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State totals","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Information concerning the site shall be included in the total quantity of recoverable waste energy for a State unless there are fewer than 3 sites in the State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd99fe67-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6342/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Removal of projects from registry","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd99fe68-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6342/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subparagraph (B), as a project achieves successful recovery of waste energy, the Administrator shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbd99fe69-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6342/d/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" remove the related sites or sources from the Registry; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd99fe6a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6342/d/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designate the removed projects as eligible for incentives under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6344"},"text":"section 6344 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd99fe6b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6342/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No project shall be removed from the Registry without the consent of the owner or operator of the project if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbd99fe6c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6342/d/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the owner or operator has submitted a petition under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6344"},"text":"section 6344 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd99fe6d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6342/d/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the petition has not been acted on or denied.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd99fe6e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6342/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ineligibility of certain sources","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall not list any source constructed after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"December 19, 2007","children":[],"tail":", on the Registry if the Administrator determines that the source—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd99fe6f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6342/d/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was developed for the primary purpose of making sales of excess electric power under the regulatory provisions of this part; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd99fe70-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6342/d/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not capture at least 60 percent of the total energy value of the fuels used (on a higher-heating-value basis) in the form of useful thermal energy, electricity, mechanical energy, chemical output, or any combination thereof.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd99fe71-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6342/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Self-certification","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd99fe72-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6342/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to any procedures that are established by the Administrator, an owner, operator, or third-party developer of a recoverable waste energy project that qualifies under standards established by the Administrator may self-certify the sites or sources of the owner, operator, or developer to the Administrator for inclusion in the Registry.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd99fe73-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6342/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review and approval","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To prevent a fraudulent listing, a site or source shall be included on the Registry only if the Administrator reviews and approves the self-certification.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd99fe74-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6342/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" New facilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As a new energy-consuming industrial facility is developed after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"December 19, 2007","children":[],"tail":", to the extent the facility may constitute a site with recoverable waste energy that may qualify for inclusion on the Registry, the Administrator may elect to include the facility on the Registry, at the request of the owner, operator, or developer of the facility, on a conditional basis with the site to be removed from the Registry if the development ceases or the site fails to qualify for listing under this part."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd99fe75-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6342/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Optimum means of recovery","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For each site listed in the Registry, at the request of the owner or operator of the site, the Administrator shall offer, in cooperation with Clean Energy Application Centers operated by the Secretary of Energy, suggestions for optimum means of recovery of value from waste energy stream in the form of electricity, useful thermal energy, or other energy-related products.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd99fe76-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6342/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Revision","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each annual report of a State under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s8258/a"},"text":"section 8258(a) of title 42","children":[],"tail":" shall include the results of the survey for the State under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd99fe77-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6342/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd99fe78-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6342/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Administrator to create and maintain the Registry and services authorized by this section, $1,000,000 for each of fiscal years 2008 through 2012; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd99fe79-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6342/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Secretary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd99fe7a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6342/i/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assist site or source owners and operators in determining the feasibility of projects authorized by this section, $2,000,000 for each of fiscal years 2008 through 2012; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd99fe7b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6342/i/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide funding for State energy office functions under this section, $5,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd99fe7c-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/163/tIII/s372"},"text":"Pub. L. 94–163, title III, § 372","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/tIV/s451/a"},"text":"Pub. L. 110–140, title IV, § 451(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1624"},"text":"121 Stat. 1624","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd99fe7d-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd99fe7e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbd99fe7f-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Clean Energy Application Centers, referred to in subsec. (g), were redesignated as the CHP Technical Assistance Partnership Program. See ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6345"},"text":"section 6345 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbd99fe80-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 6342, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/163/tIII/s372"},"text":"Pub. L. 94–163, title III, § 372","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-12-22"},"text":"Dec. 22, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/936"},"text":"89 Stat. 936","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/91/tIII/s301/a"},"text":"Pub. L. 95–91, title III, § 301(a)","children":[],"tail":", title VII, §§ 703, 707, "},{"tag":"date","attrib":{"date":"1977-08-04"},"text":"Aug. 4, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/577"},"text":"91 Stat. 577","children":[],"tail":", 606, 607; "},{"tag":"ref","attrib":{"href":"/us/pl/95/619/tVI/s691/b/2"},"text":"Pub. L. 95–619, title VI, § 691(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-09"},"text":"Nov. 9, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3288"},"text":"92 Stat. 3288","children":[],"tail":", related to e