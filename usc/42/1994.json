{"tag":"section","attrib":{"id":"idbbb11a54-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1994"},"text":null,"children":[{"tag":"num","attrib":{"value":"1994"},"text":"§ 1994.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Peonage abolished","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The holding of any person to service or labor under the system known as peonage is abolished and forever prohibited in any Territory or State of the United States; and all acts, laws, resolutions, orders, regulations, or usages of any Territory or State, which have heretofore established, maintained, or enforced, or by virtue of which any attempt shall hereafter be made to establish, maintain, or enforce, directly or indirectly, the voluntary or involuntary service or labor of any persons as peons, in liquidation of any debt or obligation, or otherwise, are declared null and void.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbbb11a55-3a70-11f1-ae07-e4213316b5fa"},"text":"(R.S. § 1990.)","children":[],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbbb11a56-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbbb11a57-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbbb11a58-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 1990 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1867-03-02/ch187/s1"},"text":"act Mar. 2, 1867, ch. 187, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/14/546"},"text":"14 Stat. 546","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s56"},"text":"section 56 of Title 8","children":[],"tail":", Aliens and Nationality."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
