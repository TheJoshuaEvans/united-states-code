{"tag":"section","attrib":{"id":"idbfc3210b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13472"},"text":null,"children":[{"tag":"num","attrib":{"value":"13472"},"text":"§ 13472.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" High efficiency heat engines","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfc3210c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13472/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program direction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall conduct a 5-year program, in accordance with sections 13541 and 13542 of this title, to improve the efficiency of heat engines. Such program shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfc3210d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13472/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include field demonstrations of sufficient scale and number so as to demonstrate technical and economic feasibility;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc3210e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13472/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" incorporate materials that increase engine efficiency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc3210f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13472/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" cover advanced engine designs for electric and industrial power generation for a range of small-, mid-, and large-scale applications, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfc32110-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13472/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" mechanically recuperated gas turbines;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfc32111-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13472/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" intercooled gas turbines with steam injection or recuperation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfc32112-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13472/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" gas turbines utilizing reformed fuels or hydrogen; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfc32113-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13472/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" high efficiency, simple cycle gas turbines.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfc32114-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13472/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program goal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The goal of the program established under subsection (a) shall be to develop heat engines that can achieve over 50 percent efficiency in the mid-term.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfc32115-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13472/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Within 180 days after ","children":[{"tag":"date","attrib":{"date":"1992-10-24"},"text":"October 24, 1992","children":[],"tail":", the Secretary shall prepare and submit to the Congress a 5-year program plan, to be included in the plan required under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s13451/c"},"text":"section 13451(c) of this title","children":[],"tail":", to guide the activities under this section. In preparing the program plan, the Secretary shall consult with appropriate representatives of industry, institutions of higher education, Federal agencies, including the Environmental Protection Agency and national laboratories, and professional and technical societies."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfc32116-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13472/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Proposals","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Within 1 year after ","children":[{"tag":"date","attrib":{"date":"1992-10-24"},"text":"October 24, 1992","children":[],"tail":", the Secretary shall solicit proposals for conducting activities under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfc32117-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13472/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to the Secretary for carrying out this section such sums as may be necessary to be derived from sums authorized under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s13451/e"},"text":"section 13451(e) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfc32118-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/tXXI/s2112"},"text":"Pub. L. 102–486, title XXI, § 2112","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3072"},"text":"106 Stat. 3072","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
