{"tag":"section","attrib":{"id":"idbf25cf12-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10368"},"text":null,"children":[{"tag":"num","attrib":{"value":"10368"},"text":"§ 10368.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National water availability and use assessment program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf25cf13-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10368/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, in coordination with the Advisory Committee and State and local water resource agencies, shall establish a national assessment program to be known as the “national water availability and use assessment program”—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf25cf14-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10368/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide a more accurate assessment of the status of the water resources of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf25cf15-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10368/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assist in the determination of the quantity of water that is available for beneficial uses;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf25cf16-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10368/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assist in the determination of the quality of the water resources of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf25cf17-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10368/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to identify long-term trends in water availability;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf25cf18-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10368/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to use each long-term trend described in paragraph (4) to provide a more accurate assessment of the change in the availability of water in the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf25cf19-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10368/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop the basis for an improved ability to forecast the availability of water for future economic, energy production, and environmental uses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf25cf1a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10368/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program elements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf25cf1b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10368/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Water use","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the assessment program, the Secretary shall conduct any appropriate activity to carry out an ongoing assessment of water use in hydrologic accounting units and major aquifer systems located in the United States, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf25cf1c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10368/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the maintenance of a comprehensive national water use inventory to enhance the level of understanding with respect to the effects of spatial and temporal patterns of water use on the availability and sustainable use of water resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf25cf1d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10368/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the incorporation of water use science principles, with an emphasis on applied research and statistical estimation techniques in the assessment of water use;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf25cf1e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10368/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the integration of any dataset maintained by any other Federal or State agency into the dataset maintained by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf25cf1f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10368/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a focus on the scientific integration of any data relating to water use, water flow, or water quality to generate relevant information relating to the impact of human activity on water and ecological resources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf25cf20-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10368/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Water availability","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the assessment program, the Secretary shall conduct an ongoing assessment of water availability by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf25cf21-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10368/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" developing and evaluating nationally consistent indicators that reflect each status and trend relating to the availability of water resources in the United States, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbf25cf22-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10368/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" surface water indicators, such as streamflow and surface water storage measures (including lakes, reservoirs, perennial snowfields, and glaciers);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf25cf23-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10368/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" groundwater indicators, including groundwater level measurements and changes in groundwater levels due to—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbf25cf24-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10368/b/2/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" natural recharge;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbf25cf25-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10368/b/2/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" withdrawals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbf25cf26-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10368/b/2/A/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" saltwater intrusion;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbf25cf27-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10368/b/2/A/ii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" mine dewatering;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbf25cf28-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10368/b/2/A/ii/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" land drainage;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbf25cf29-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10368/b/2/A/ii/VI"},"text":null,"children":[{"tag":"num","attrib":{"value":"VI"},"text":"(VI)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" artificial recharge; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbf25cf2a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10368/b/2/A/ii/VII"},"text":null,"children":[{"tag":"num","attrib":{"value":"VII"},"text":"(VII)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other relevant factors, as determined by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf25cf2b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10368/b/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" impaired surface water and groundwater supplies that are known, accessible, and used to meet ongoing water demands;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf25cf2c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10368/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" maintaining a national database of water availability data that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbf25cf2d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10368/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is comprised of maps, reports, and other forms of interpreted data;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf25cf2e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10368/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides electronic access to the archived data of the national database; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf25cf2f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10368/b/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides for real-time data collection; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf25cf30-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10368/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing and applying predictive modeling tools that integrate groundwater, surface water, and ecological systems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf25cf31-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10368/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf25cf32-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10368/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of Secretary","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may provide grants to State water resource agencies to assist State water resource agencies in—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf25cf33-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10368/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing water use and availability datasets that are integrated with each appropriate dataset developed or maintained by the Secretary; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf25cf34-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10368/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" integrating any water use or water availability dataset of the State water resource agency into each appropriate dataset developed or maintained by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf25cf35-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10368/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to receive a grant under paragraph (1), a State water resource agency shall demonstrate to the Secretary that the water use and availability dataset proposed to be established or integrated by the State water resource agency—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf25cf36-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10368/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is in compliance with each quality and conformity standard established by the Secretary to ensure that the data will be capable of integration with any national dataset; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf25cf37-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10368/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will enhance the ability of the officials of the State or the State water resource agency to carry out each water management and regulatory responsibility of the officials of the State in accordance with each applicable law of the State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf25cf38-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10368/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of a grant provided to a State water resource agency under paragraph (1) shall be an amount not more than $250,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf25cf39-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10368/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2012-12-31"},"text":"December 31, 2012","children":[],"tail":", and every 5 years thereafter, the Secretary shall submit to the appropriate committees of Congress a report that provides a detailed assessment of—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf25cf3a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10368/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the current availability of water resources in the United States, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf25cf3b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10368/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" historic trends and annual updates of river basin inflows and outflows;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf25cf3c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10368/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" surface water storage;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf25cf3d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10368/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" groundwater reserves; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf25cf3e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10368/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" estimates of undeveloped potential resources (including saline and brackish water and wastewater);","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf25cf3f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10368/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" significant trends affecting water availability, including each documented or projected impact to the availability of water as a result of global climate change;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf25cf40-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10368/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the withdrawal and use of surface water and groundwater by various sectors, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf25cf41-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10368/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the agricultural sector;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf25cf42-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10368/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" municipalities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf25cf43-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10368/d/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the industrial sector;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf25cf44-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10368/d/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" thermoelectric power generators; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf25cf45-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10368/d/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hydroelectric power generators;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf25cf46-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10368/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" significant trends relating to each water use sector, including significant changes in water use due to the development of new energy supplies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf25cf47-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10368/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" significant water use conflicts or shortages that have occurred or are occurring; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf25cf48-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10368/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each factor that has caused, or is causing, a conflict or shortage described in paragraph (5).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf25cf49-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10368/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf25cf4a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10368/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out subsections (a), (b), and (d) $20,000,000 for each of fiscal years 2009 through 2023, to remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf25cf4b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10368/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out subsection (c) $12,500,000 for the period of fiscal years 2009 through 2013, to remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf25cf4c-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11/tIX/s9508"},"text":"Pub. L. 111–11, title IX, § 9508","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-03-30"},"text":"Mar. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1343"},"text":"123 Stat. 1343","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
