{"tag":"section","attrib":{"id":"idbdf23052-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7137"},"text":null,"children":[{"tag":"num","attrib":{"value":"7137"},"text":"§ 7137.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions of Comptroller General","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The functions of the Comptroller General of the United States under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s771"},"text":"section 771 of title 15","children":[],"tail":" shall apply with respect to the monitoring and evaluation of all functions and activities of the Department under this chapter or any other Act administered by the Department."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbdf23053-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/91/tII/s207"},"text":"Pub. L. 95–91, title II, § 207","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-08-04"},"text":"Aug. 4, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/574"},"text":"91 Stat. 574","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbdf23054-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbdf23055-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbdf23056-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/91"},"text":"Pub. L. 95–91","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-08-04"},"text":"Aug. 4, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/565"},"text":"91 Stat. 565","children":[],"tail":", known as the Department of Energy Organization Act, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s7101"},"text":"section 7101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
