{"tag":"section","attrib":{"id":"idbb96dbcc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862s–7"},"text":null,"children":[{"tag":"num","attrib":{"value":"1862s–7"},"text":"§ 1862s–7.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Computer science education research","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbb96dbcd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862s–7/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Congress finds that as the lead Federal agency for building the research knowledge base for computer science education, the Foundation is well positioned to make investments that will accelerate ongoing efforts to enable rigorous and engaging computer science throughout the Nation as an integral part of STEM education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb96dbce-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862s–7/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb96dbcf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862s–7/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the Foundation shall award grants to eligible entities to research computer science and cybersecurity education and computational thinking.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb96dbd0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862s–7/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The research described in paragraph (1) may include the development or adaptation, piloting or full implementation, and testing of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbb96dbd1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862s–7/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" models of preservice preparation for teachers who will teach computer science and computational thinking;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb96dbd2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862s–7/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" scalable and sustainable models of professional development and ongoing support for the teachers described in subparagraph (A);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb96dbd3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862s–7/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" tools and models for teaching and learning aimed at supporting student success and inclusion in computing within and across diverse populations, particularly poor, rural, and tribal populations and other populations that have been historically underrepresented in computer science and STEM fields;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb96dbd4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862s–7/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" high-quality learning opportunities for teaching computer science and, especially in poor, rural, or tribal schools at the elementary school and middle school levels, for integrating computational thinking into STEM teaching and learning; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb96dbd5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862s–7/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" tools and models for the integration of cybersecurity and other interdisciplinary efforts into computer science education and computational thinking at secondary and postsecondary levels of education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb96dbd6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862s–7/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uses of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The tools and models described in paragraph (2)(C) may include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbb96dbd7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862s–7/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" offering training and professional development programs, including summer or academic year institutes or workshops, designed to strengthen the capabilities of prekindergarten and elementary school teachers and to familiarize such teachers with the role of bias against female students in the classroom;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb96dbd8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862s–7/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" offering innovative pre-service and in-service programs that instruct teachers on female-inclusive practices for teaching computing concepts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb96dbd9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862s–7/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing distance learning programs for teachers or students, including developing curricular materials, play-based computing activities, and other resources for the in-service professional development of teachers that are made available to teachers through the Internet;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb96dbda-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862s–7/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing or adapting prekindergarten and elementary school computer science curricular materials that incorporate contemporary research on the science of learning, particularly with respect to female inclusion;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb96dbdb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862s–7/b/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing and offering female-inclusive computer science enrichment programs for students, including after-school and summer programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb96dbdc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862s–7/b/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing mentors for female students in prekindergarten through elementary school to support such students in participating in computer science activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb96dbdd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862s–7/b/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" engaging female students in prekindergarten through elementary school, and their guardians (if such communication takes place on school premises during otherwise-scheduled conferences or formal conversations between teachers and guardians) about—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbb96dbde-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862s–7/b/3/G/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the difficulties faced by female students with regard to maintaining an interest in participating in computer science activities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbb96dbdf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862s–7/b/3/G/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the potential positive career benefits of engaging in such activities;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb96dbe0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862s–7/b/3/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acquainting female students in prekindergarten through elementary school with careers in computer science and encouraging such students to consider careers in the computer science field; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb96dbe1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862s–7/b/3/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing tools to evaluate activities conducted under this subsection, including reports for evaluating the effectiveness of activities under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb96dbe2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862s–7/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collaborations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out the grants established in subsection (b), eligible entities may collaborate and partner with local or remote schools to support the integration of computing, cybersecurity, and computational thinking within pre-kindergarten through grade 12 STEM curricula and instruction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb96dbe3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862s–7/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Metrics","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the Foundation shall develop metrics to measure the success of the grant program funded under this section in achieving program goals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb96dbe4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862s–7/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the Foundation shall report, in the annual budget submission to Congress, on the success of the program as measured by the metrics in subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb96dbe5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862s–7/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of eligible entity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “eligible entity” means an institution of higher education or a nonprofit research organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbb96dbe6-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/329/tIII/s310"},"text":"Pub. L. 114–329, title III, § 310","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-01-06"},"text":"Jan. 6, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/3012"},"text":"130 Stat. 3012","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/102/s5"},"text":"Pub. L. 116–102, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-24"},"text":"Dec. 24, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/3264"},"text":"133 Stat. 3264","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dH/tXCIV/s9405/a"},"text":"Pub. L. 116–283, div. H, title XCIV, § 9405(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4812"},"text":"134 Stat. 4812","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbb96dbe7-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbb96dbe8-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbb96dbe9-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the American Innovation and Competitiveness Act, and not as part of the National Science Foundation Act of 1950 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbb96dbea-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s9405/a/1/A"},"text":"Pub. L. 116–283, § 9405(a)(1)(A)","children":[],"tail":", inserted “and cybersecurity” after “computer science”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s9405/a/1/B"},"text":"Pub. L. 116–283, § 9405(a)(1)(B)","children":[],"tail":", added subpar. (E)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s9405/a/2"},"text":"Pub. L. 116–283, § 9405(a)(2)","children":[],"tail":", inserted “, cybersecurity,” after “computing”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2019—Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/102"},"text":"Pub. L. 116–102","children":[],"tail":" added par. (3)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbb96dbeb-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idbb96dbec-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definitions of terms used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/329/s2"},"text":"section 2 of Pub. L. 114–329","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1862s"},"text":"section 1862s of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
