{"tag":"section","attrib":{"id":"idb6078555-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299c–6"},"text":null,"children":[{"tag":"num","attrib":{"value":"299c–6"},"text":"§ 299c–6.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb6078556-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299c–6/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Intent","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To ensure that the United States investment in biomedical research is rapidly translated into improvements in the quality of patient care, there must be a corresponding investment in research on the most effective clinical and organizational strategies for use of these findings in daily practice. The authorization levels in subsections (b) and (c) provide for a proportionate increase in health care research as the United States investment in biomedical research increases.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6078557-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299c–6/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of carrying out this subchapter, there are authorized to be appropriated $250,000,000 for fiscal year 2000, and such sums as may be necessary for each of the fiscal years 2001 through 2005.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6078558-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299c–6/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to amounts available pursuant to subsection (b) for carrying out this subchapter, there shall be made available for such purpose, from the amounts made available pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s238j"},"text":"section 238j of this title","children":[],"tail":" (relating to evaluations), an amount equal to 40 percent of the maximum amount authorized in such "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s238j"},"text":"section 238j of this title","children":[],"tail":" to be made available for a fiscal year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6078559-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299c–6/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Health disparities research","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of carrying out the activities under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s299a–1"},"text":"section 299a–1 of this title","children":[],"tail":", there are authorized to be appropriated $50,000,000 for fiscal year 2001, and such sums as may be necessary for each of the fiscal years 2002 through 2005."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb607855a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299c–6/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Patient safety and quality improvement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of carrying out part C, there are authorized to be appropriated such sums as may be necessary for each of the fiscal years 2006 through 2010.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb607855b-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title IX, § 947, formerly § 927, as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/129/s2/a"},"text":"Pub. L. 106–129, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-12-06"},"text":"Dec. 6, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1670"},"text":"113 Stat. 1670","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/525/tII/s201/b"},"text":"Pub. L. 106–525, title II, § 201(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-22"},"text":"Nov. 22, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2507"},"text":"114 Stat. 2507","children":[],"tail":"; renumbered § 937 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/41/s2/a/3"},"text":"Pub. L. 109–41, § 2(a)(3)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2005-07-29"},"text":"July 29, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/424"},"text":"119 Stat. 424","children":[],"tail":", 434; renumbered § 947, "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tIII/s3013/a/2"},"text":"Pub. L. 111–148, title III, § 3013(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/381"},"text":"124 Stat. 381","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb607855c-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"cross