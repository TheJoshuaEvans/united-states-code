{"tag":"section","attrib":{"id":"idbf38e1d0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11101"},"text":null,"children":[{"tag":"num","attrib":{"value":"11101"},"text":"§ 11101.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Congress finds the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf38e1d1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11101/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The increasing occurrence of medical malpractice and the need to improve the quality of medical care have become nationwide problems that warrant greater efforts than those that can be undertaken by any individual State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf38e1d2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11101/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is a national need to restrict the ability of incompetent physicians to move from State to State without disclosure or discovery of the physician’s previous damaging or incompetent performance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf38e1d3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11101/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This nationwide problem can be remedied through effective professional peer review.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf38e1d4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11101/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The threat of private money damage liability under Federal laws, including treble damage liability under Federal antitrust law, unreasonably discourages physicians from participating in effective professional peer review.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf38e1d5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11101/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is an overriding national need to provide incentive and protection for physicians engaging in effective professional peer review.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf38e1d6-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/660/tIV/s402"},"text":"Pub. L. 99–660, title IV, § 402","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3784"},"text":"100 Stat. 3784","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf38e1d7-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbf38e1d8-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"idbf38e1d9-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/660/tIV/s401"},"text":"Pub. L. 99–660, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3784"},"text":"100 Stat. 3784","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/660/tIV/s401"},"text":"“This title [enacting this chapter and provisions set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11111"},"text":"section 11111 of this title","children":[],"tail":"] may be cited as the ‘Health Care Quality Improvement Act of 1986’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
