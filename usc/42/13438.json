{"tag":"section","attrib":{"id":"idbfc3206d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13438"},"text":null,"children":[{"tag":"num","attrib":{"value":"13438"},"text":"§ 13438.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Telecommuting study","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfc3206e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13438/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, in consultation with the Secretary of Transportation, shall conduct a study of the potential costs and benefits to the energy and transportation sectors of telecommuting. The study shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfc3206f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13438/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an estimation of the amount and type of reduction of commuting by form of transportation type and numbers of commuters;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc32070-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13438/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an estimation of the potential number of lives saved;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc32071-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13438/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an estimation of the reduction in environmental pollution, in consultation with the Environmental Protection Agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc32072-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13438/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an estimation of the amount and type of reduction of energy use and savings by form of transportation type; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc32073-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13438/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an estimation of the social impact of widespread use of telecommuting.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfc32074-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13438/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This study shall be completed no more than one hundred and eighty days after ","children":[{"tag":"date","attrib":{"date":"1992-10-24"},"text":"October 24, 1992","children":[],"tail":". A report, summarizing the results of the study, shall be transmitted to the United States House of Representatives and the Committee on Energy and Natural Resources of the United States Senate no more than sixty days after completion of this study."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfc32075-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/tXX/s2028"},"text":"Pub. L. 102–486, title XX, § 2028","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3067"},"text":"106 Stat. 3067","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
