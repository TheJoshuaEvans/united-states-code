{"tag":"section","attrib":{"id":"idb5b8c7bf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290cc–22"},"text":null,"children":[{"tag":"num","attrib":{"value":"290cc–22"},"text":"§ 290cc–22.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose of grants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5b8c7c0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290cc–22/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may not make payments under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s290cc–21"},"text":"section 290cc–21 of this title","children":[],"tail":" unless the State involved agrees that the payments will be expended solely for making grants to political subdivisions of the State, and to nonprofit private entities (including community-based veterans organizations and other community organizations), for the purpose of providing the services specified in subsection (b) to individuals who—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5b8c7c1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290cc–22/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5b8c7c2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290cc–22/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are suffering from serious mental illness; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5b8c7c3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290cc–22/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are suffering from serious mental illness and from a substance use disorder; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5b8c7c4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290cc–22/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are homeless or at imminent risk of becoming homeless.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5b8c7c5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290cc–22/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specification of services","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The services referred to in subsection (a) are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5b8c7c6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290cc–22/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" outreach services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5b8c7c7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290cc–22/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" screening and diagnostic treatment services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5b8c7c8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290cc–22/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" habilitation and rehabilitation services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5b8c7c9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290cc–22/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" community mental health services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5b8c7ca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290cc–22/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" alcohol or drug treatment services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5b8c7cb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290cc–22/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" staff training, including the training of individuals who work in shelters, mental health clinics, substance use disorder programs, and other sites where homeless individuals require services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5b8c7cc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290cc–22/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" case management services, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5b8c7cd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290cc–22/b/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preparing a plan for the provision of community mental health services to the eligible homeless individual involved, and reviewing such plan not less than once every 3 months;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5b8c7ce-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290cc–22/b/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing assistance in obtaining and coordinating social and maintenance services for the eligible homeless individuals, including services relating to daily living activities, personal financial planning, transportation services, and habilitation and rehabilitation services, prevocational and vocational services, and housing services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5b8c7cf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290cc–22/b/7/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing assistance to the eligible homeless individual in obtaining income support services, including housing assistance, supplemental nutrition assistance program benefits, and supplemental security income benefits;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5b8c7d0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290cc–22/b/7/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" referring the eligible homeless individual for such other services as may be appropriate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5b8c7d1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290cc–22/b/7/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing representative payee services in accordance with section 1631(a)(2) of the Social Security Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1383/a/2"},"text":"42 U.S.C. 1383(a)(2)","children":[],"tail":"] if the eligible homeless individual is receiving aid under title XVI of such act ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1381"},"text":"42 U.S.C. 1381","children":[],"tail":" et seq.] and if the applicant is designated by the Secretary to provide such services;"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5b8c7d2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290cc–22/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supportive and supervisory services in residential settings;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5b8c7d3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290cc–22/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" referrals for primary health services, job training, educational services, and relevant housing services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5b8c7d4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290cc–22/b/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" subject to subsection (h)(1)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5b8c7d5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290cc–22/b/10/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" minor renovation, expansion, and repair of housing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5b8c7d6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290cc–22/b/10/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" planning of housing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5b8c7d7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290cc–22/b/10/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" technical assistance in applying for housing assistance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5b8c7d8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290cc–22/b/10/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improving the coordination of housing services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5b8c7d9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290cc–22/b/10/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" security deposits;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5b8c7da-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290cc–22/b/10/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the costs associated with matching eligible homeless individuals with appropriate housing situations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5b8c7db-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290cc–22/b/10/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1-time rental payments to prevent eviction; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5b8c7dc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290cc–22/b/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other appropriate services, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5b8c7dd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290cc–22/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may not make payments under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s290cc–21"},"text":"section 290cc–21 of this title","children":[],"tail":" unless the State involved agrees to make grants pursuant to subsection (a) only to entities that have the capacity to provide, directly or through arrangements, the services specified in subsection (b), including coordinating the provision of services in order to meet the needs of eligible homeless individuals who are both mentally ill and suffering from a substance use disorder."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5b8c7de-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290cc–22/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special consideration regarding veterans","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may not make payments under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s290cc–21"},"text":"section 290cc–21 of this title","children":[],"tail":" unless the State involved agrees that, in making grants to entities pursuant to subsection (a), the State will give special consideration to entities with a demonstrated effectiveness in serving homeless veterans."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5b8c7df-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290cc–22/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may not make payments under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s290cc–21"},"text":"section 290cc–21 of this title","children":[],"tail":" unless the State involved agrees that grants pursuant to subsection (a) will not be made to any entity that—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5b8c7e0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290cc–22/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a policy of excluding individuals from mental health services due to the existence or suspicion of a substance use disorder; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5b8c7e1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290cc–22/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a policy of excluding individuals from substance use disorder services due to the existence or suspicion of mental illness.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5b8c7e2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290cc–22/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may not make payments under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s290cc–21"},"text":"section 290cc–21 of this title","children":[],"tail":" unless the State involved agrees that not more than 4 percent of the payments will be expended for administrative expenses regarding the payments."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5b8c7e3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290cc–22/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restrictions on use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may not make payments under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s290cc–21"},"text":"section 290cc–21 of this title","children":[],"tail":" unless the State involved agrees that—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5b8c7e4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290cc–22/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not more than 20 percent of the payments will be expended for housing services under subsection (b)(10); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5b8c7e5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290cc–22/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the payments will not be expended—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5b8c7e6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290cc–22/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to support emergency shelters or construction of housing facilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5b8c7e7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290cc–22/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for inpatient psychiatric treatment costs or inpatient substance use disorder treatment costs; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5b8c7e8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290cc–22/g/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to make cash payments to intended recipients of mental health or substance use disorder services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5b8c7e9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290cc–22/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver for territories","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to the United States Virgin Islands, Guam, American Samoa, Palau, the Marshall Islands, and the Commonwealth of the Northern Mariana Islands, the Secretary may waive the provisions of this part that the Secretary determines to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5b8c7ea-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title V, § 522, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/77/tVI/s611/3"},"text":"Pub. L. 100–77, title VI, § 611(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-07-22"},"text":"July 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/516"},"text":"101 Stat. 516","children":[],"