{"tag":"section","attrib":{"id":"idb52c1922-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280c–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"280c–1"},"text":"§ 280c–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on duration of grant and requirement of matching funds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb52c1923-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280c–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on duration of grant","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The period during which payments are made to a State from a grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s280c/a"},"text":"section 280c(a) of this title","children":[],"tail":" may not exceed 3 years. Such payments shall be subject to annual evaluation by the Secretary."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb52c1924-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280c–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement of matching funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb52c1925-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280c–1/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb52c1926-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280c–1/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the first year of payments to a State from a grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s280c/a"},"text":"section 280c(a) of this title","children":[],"tail":", the Secretary may not make such payments in an amount exceeding 75 percent of the costs of services to be provided by the State pursuant to such section."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb52c1927-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280c–1/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the second year of such payments to a State, the Secretary may not make such payments in an amount exceeding 65 percent of the costs of such services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb52c1928-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280c–1/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the third year of such payments to a State, the Secretary may not make such payments in an amount exceeding 55 percent of the costs of such services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb52c1929-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280c–1/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary may not make a grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s280c/a"},"text":"section 280c(a) of this title","children":[],"tail":" to a State unless the State agrees to make available, directly or through donations from public or private entities, non-Federal contributions toward the costs of services to be provided pursuant to such section in an amount equal to—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb52c192a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280c–1/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the first year of payments to the State from the grant, not less than $25 (in cash or in kind under subsection (c)) for each $75 of Federal funds provided in the grant;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb52c192b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280c–1/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the second year of such payments to the State, not less than $35 (in cash or in kind under subsection (c)) for each $65 of such Federal funds; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb52c192c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280c–1/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the third year of such payments to the State, not less than $45 (in cash or in kind under subsection (c)) for each $55 of such Federal funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb52c192d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280c–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of amount of non-Federal contribution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Non-Federal contributions required in subsection (b) may be in cash or in kind, fairly evaluated, including plant, equipment, or services. Amounts provided by the Federal Government, or services assisted or subsidized to any significant extent by the Federal Government, may not be included in determining the amount of such non-Federal contributions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb52c192e-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title III, § 396, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/175/tVI/s602"},"text":"Pub. L. 100–175, title VI, § 602","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-11-29"},"text":"Nov. 29, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/979"},"text":"101 Stat. 979","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb52c192f-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb52c1930-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb52c1931-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 396 of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373/tIII"},"text":"act July 1, 1944, ch. 373, title III","children":[],"tail":", formerly § 398, as added "},{"tag":"date","attrib":{"date":"1965-10-22"},"text":"Oct. 22, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/89/291/s2"},"text":"Pub. L. 89–291, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/1065"},"text":"79 Stat. 1065","children":[],"tail":"; renumbered § 397 and amended "},{"tag":"date","attrib":{"date":"1970-03-13"},"text":"Mar. 13, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/91/212"},"text":"Pub. L. 91–212","children":[],"ta