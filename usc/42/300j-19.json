{"tag":"section","attrib":{"id":"idb647e97e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19"},"text":null,"children":[{"tag":"num","attrib":{"value":"300j–19"},"text":"§ 300j–19.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Algal toxin risk assessment and management","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb647e97f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Strategic plan","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb647e980-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Development","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"2015-08-07"},"text":"August 7, 2015","children":[],"tail":", the Administrator shall develop and submit to Congress a strategic plan for assessing and managing risks associated with algal toxins in drinking water provided by public water systems. The strategic plan shall include steps and timelines to—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb647e981-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluate the risk to human health from drinking water provided by public water systems contaminated with algal toxins;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb647e982-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish, publish, and update a comprehensive list of algal toxins which the Administrator determines may have an adverse effect on human health when present in drinking water provided by public water systems, taking into account likely exposure levels;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb647e983-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" summarize—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb647e984-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19/a/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the known adverse human health effects of algal toxins included on the list published under subparagraph (B) when present in drinking water provided by public water systems; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb647e985-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19/a/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" factors that cause toxin-producing cyanobacteria and algae to proliferate and express toxins;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb647e986-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" with respect to algal toxins included on the list published under subparagraph (B), determine whether to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb647e987-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19/a/1/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" publish health advisories pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300g–1/b/1/F"},"text":"section 300g–1(b)(1)(F) of this title","children":[],"tail":" for such algal toxins in drinking water provided by public water systems;"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb647e988-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19/a/1/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish guidance regarding feasible analytical methods to quantify the presence of algal toxins; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb647e989-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19/a/1/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish guidance regarding the frequency of monitoring necessary to determine if such algal toxins are present in drinking water provided by public water systems;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb647e98a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommend feasible treatment options, including procedures, equipment, and source water protection practices, to mitigate any adverse public health effects of algal toxins included on the list published under subparagraph (B); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb647e98b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19/a/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enter into cooperative agreements with, and provide technical assistance to, affected States and public water systems, as identified by the Administrator, for the purpose of managing risks associated with algal toxins included on the list published under subparagraph (B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb647e98c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Updates","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall, as appropriate, update and submit to Congress the strategic plan developed under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb647e98d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information coordination","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out this section the Administrator shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb647e98e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" identify gaps in the Agency’s understanding of algal toxins, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb647e98f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the human health effects of algal toxins included on the list published under subsection (a)(1)(B); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb647e990-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" methods and means of testing and monitoring for the presence of harmful algal toxins in source water of, or drinking water provided by, public water systems;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb647e991-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" as appropriate, consult with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb647e992-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" other Federal agencies that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb647e993-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" examine or analyze cyanobacteria or algal toxins; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb647e994-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" address public health concerns related to harmful algal blooms;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb647e995-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb647e996-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operators of public water systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb647e997-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" multinational agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb647e998-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" foreign governments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb647e999-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" research and academic institutions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb647e99a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19/b/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" companies that provide relevant drinking water treatment options; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb647e99b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" assemble and publish information from each Federal agency that has—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb647e99c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" examined or analyzed cyanobacteria or algal toxins; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb647e99d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" addressed public health concerns related to harmful algal blooms.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb647e99e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of science","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall carry out this section in accordance with the requirements described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300g–1/b/3/A"},"text":"section 300g–1(b)(3)(A) of this title","children":[],"tail":", as applicable."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb647e99f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Feasible","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “feasible” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300g–1/b/4/D"},"text":"section 300g–1(b)(4)(D) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb647e9a0-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XIV, § 1459, as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/45/s2/a"},"text":"Pub. L. 114–45, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-08-07"},"text":"Aug. 7, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/473"},"text":"129 Stat. 473","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
