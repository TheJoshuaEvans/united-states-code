{"tag":"section","attrib":{"id":"idbf400d98-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11320"},"text":null,"children":[{"tag":"num","attrib":{"value":"11320"},"text":"§ 11320.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Encouragement of State involvement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf400d99-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11320/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State contact persons","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each State shall designate an individual to serve as a State contact person for the purpose of receiving and disseminating information and communications received from the Council, including the bimonthly bulletin described in section 11313(a)(7) ","children":[{"tag":"ref","attrib":{"idref":"fn003998"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003998"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf400d9a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11320/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State interagency councils and lead agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each State is encouraged to establish a State interagency council on the homeless or designate a lead agency for the State for the purpose of assuming primary responsibility for coordinating and interacting with the Council and State and local agencies as necessary.","children":[],"tail":"\n"}],"ta