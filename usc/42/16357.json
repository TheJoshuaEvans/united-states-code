{"tag":"section","attrib":{"id":"idc00f6b3e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16357"},"text":null,"children":[{"tag":"num","attrib":{"value":"16357"},"text":"§ 16357.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Strategy for facilities and infrastructure","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc00f6b3f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16357/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Facility and infrastructure policy","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc00f6b40-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16357/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall develop and implement a strategy for facilities and infrastructure supported primarily from the Office of Science, the Office of Energy Efficiency and Renewable Energy, the Office of Fossil Energy, or the Office of Nuclear Energy, Science and Technology Programs at all National Laboratories and single-purpose research facilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00f6b41-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16357/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Strategy","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The strategy shall provide cost-effective means for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc00f6b42-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16357/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintaining existing facilities and infrastructure;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00f6b43-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16357/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" closing unneeded facilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00f6b44-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16357/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" making facility modifications; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00f6b45-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16357/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" building new facilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc00f6b46-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16357/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc00f6b47-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16357/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall prepare and submit, along with the budget request of the President submitted to Congress for fiscal year 2018, a report describing the strategy developed under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00f6b48-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16357/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For each National Laboratory and single-purpose research facility that is primarily used for science and energy research, the report shall contain—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc00f6b49-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16357/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the current priority list of proposed facilities and infrastructure projects, including cost and schedule requirements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00f6b4a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16357/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a current 10-year plan that demonstrates the reconfiguration of its facilities and infrastructure to meet its missions and to address its long-term operational costs and return on investment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00f6b4b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16357/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total current budget for all facilities and infrastructure funding; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00f6b4c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16357/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the current status of each facility and infrastructure project compared to the original baseline cost, schedule, and scope.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc00f6b4d-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tIX/s993"},"text":"Pub. L. 109–58, title IX, § 993","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/913"},"text":"119 Stat. 913","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/246/tII/s205/a"},"text":"Pub. L. 115–246, title II, § 205(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-09-28"},"text":"Sept. 28, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3137"},"text":"132 Stat. 3137","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc00f6b4e-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc00f6b4f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc00f6b50-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/246/s205/a/1"},"text":"Pub. L. 115–246, § 205(a)(1)","children":[],"tail":", substituted “Strategy for facilities and infrastructure” for “Strategy and plan for science and energy facilities and infrastructure” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/246/s205/a/2"},"text":"Pub. L. 115–246, § 205(a)(2)","children":[],"tail":", substituted “2018” for “2008”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
