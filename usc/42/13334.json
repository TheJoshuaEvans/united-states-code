{"tag":"section","attrib":{"id":"idbfbbf465-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13334"},"text":null,"children":[{"tag":"num","attrib":{"value":"13334"},"text":"§ 13334.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonfuel use of coal","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfbbf466-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13334/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall prepare a plan for and carry out a program of research, development, demonstration, and commercial application with respect to technologies for the nonfuel use of coal, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfbbf467-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13334/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" production of coke and other carbon products derived from coal;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfbbf468-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13334/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" production of coal-derived, carbon-based chemical intermediates that are precursors of value-added chemicals and polymers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfbbf469-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13334/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" production of chemicals from coal-derived synthesis gas;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfbbf46a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13334/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coal treatment processes, including methodologies such as solvent-extraction techniques that produce low ash, low sulfur, coal-based chemical feedstocks; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfbbf46b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13334/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" waste utilization, including recovery, processing, and marketing of products derived from sulfur, carbon dioxide, nitrogen, and ash from coal.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfbbf46c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13334/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plan contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The plan described in subsection (a) shall address and evaluate—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfbbf46d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13334/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the known and potential processes for using coal in the creation of products in the chemical, utility, fuel, and carbon-based materials industries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfbbf46e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13334/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the costs, benefits, and economic feasibility of using coal products in the chemical and materials industries, including value-added chemicals, carbon-based products, coke, and waste derived from coal;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfbbf46f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13334/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the economics of coproduction of products from coal in conjunction with the production of electric power, thermal energy, and fuel;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfbbf470-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13334/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the economics of the refining of coal and coal byproducts to produce nonfuel products;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfbbf471-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13334/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the economics of coal utilization in comparison with other feedstocks that might be used for the same purposes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfbbf472-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13334/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the steps that can be taken by the public and private sectors to bring about commercialization of technologies developed under the program recommended; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfbbf473-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13334/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the past development, current status, and future potential of coal products and processes associated with nonfuel uses of coal.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfbbf474-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/tXIII/s1304"},"text":"Pub. L. 102–486, title XIII, § 1304","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2973"},"text":"106 Stat. 2973","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
