{"tag":"section","attrib":{"id":"idbff79e99-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16191"},"text":null,"children":[{"tag":"num","attrib":{"value":"16191"},"text":"§ 16191.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Energy efficiency","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbff79e9a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16191/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbff79e9b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16191/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Objectives","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall conduct programs of energy efficiency research, development, demonstration, and commercial application, including activities described in this part. Such programs shall take into consideration the following objectives:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbff79e9c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16191/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Increasing the energy efficiency of vehicles, buildings, and industrial processes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff79e9d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16191/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Reducing the demand of the United States for energy, especially energy from foreign sources.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff79e9e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16191/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Reducing the cost of energy and making the economy more efficient and competitive.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff79e9f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16191/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Improving the energy security of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff79ea0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16191/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Reducing the environmental impact of energy-related activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff79ea1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16191/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Programs","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Programs under this part shall include research, development, demonstration, and commercial application of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbff79ea2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16191/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" advanced, cost-effective technologies to improve the energy efficiency and environmental performance of vehicles, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbff79ea3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16191/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hybrid and electric propulsion systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbff79ea4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16191/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" plug-in hybrid systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbff79ea5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16191/a/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advanced combustion engines;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbff79ea6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16191/a/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" weight and drag reduction technologies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbff79ea7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16191/a/2/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whole-vehicle design optimization; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbff79ea8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16191/a/2/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advanced drive trains;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff79ea9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16191/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cost-effective technologies, for new construction and retrofit, to improve the energy efficiency and environmental performance of buildings, using a whole-buildings approach, including onsite renewable energy generation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff79eaa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16191/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advanced technologies to improve the energy efficiency, environmental performance, and process efficiency of energy-intensive and waste-intensive industries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff79eab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16191/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advanced control devices to improve the energy efficiency of electric motors, including those used in industrial processes, heating, ventilation, and cooling; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff79eac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16191/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" technologies to improve the energy efficiency of appliances and mechanical systems for buildings in cold climates, including combined heat and power units and increased use of renewable resources, including fuel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff79ead-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16191/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated to the Secretary to carry out energy efficiency and conservation research, development, demonstration, and commercial application activities, including activities authorized under this part—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbff79eae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16191/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $783,000,000 for fiscal year 2007;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff79eaf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16191/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $865,000,000 for fiscal year 2008; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff79eb0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16191/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $952,000,000 for fiscal year 2009.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff79eb1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16191/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"From amounts authorized under subsection (b), the following sums are authorized:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbff79eb2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16191/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For activities under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16192"},"text":"section 16192 of this title","children":[],"tail":", $50,000,000 for each of fiscal years 2007 through 2009."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff79eb3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16191/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For activities under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16195"},"text":"section 16195 of this title","children":[],"tail":", $7,000,000 for each of fiscal years 2007 through 2009."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff79eb4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16191/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For activities under subsection (a)(2)(A)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbff79eb5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16191/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $200,000,000 for fiscal year 2007;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff79eb6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16191/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $270,000,000 for fiscal year 2008; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff79eb7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16191/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $310,000,000 for fiscal year 2009.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff79eb8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16191/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For activities under subsection (a)(2)(D), $2,000,000 for each of fiscal years 2007 and 2008.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff79eb9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16191/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extended authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to the Secretary to carry out ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16192"},"text":"section 16192 of this title","children":[],"tail":" $50,000,000 for each of fiscal years 2010 through 2013."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff79eba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16191/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"None of the funds authorized to be appropriated under this section may be used for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbff79ebb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16191/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":