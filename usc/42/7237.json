{"tag":"section","attrib":{"id":"idbdfba66a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7237"},"text":null,"children":[{"tag":"num","attrib":{"value":"7237"},"text":"§ 7237.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority placement, job placement, retraining, and counseling programs for United States Department of Energy employees affected by reduction in force","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbdfba66b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7237/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbdfba66c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7237/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purposes of this section, the term “agency” means the United States Department of Energy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdfba66d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7237/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For the purposes of this section, the term “eligible employee” means any employee of the agency who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbdfba66e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7237/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is scheduled to be separated from service due to a reduction in force under—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbdfba66f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7237/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" regulations prescribed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3502"},"text":"section 3502 of title 5","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbdfba670-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7237/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" procedures established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3595"},"text":"section 3595 of title 5","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbdfba671-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7237/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is separated from service due to such a reduction in force, but does not include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbdfba672-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7237/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an employee separated from service for cause on charges of misconduct or delinquency; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbdfba673-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7237/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an employee who, at the time of separation, meets the age and service requirements for an immediate annuity under subchapter III of chapter 83 or chapter 84 of title 5.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdfba674-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7237/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority placement and retraining program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 30 days after ","children":[{"tag":"date","attrib":{"date":"1996-09-30"},"text":"September 30, 1996","children":[],"tail":", the United States Department of Energy shall establish an agency-wide priority placement and retraining program for eligible employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdfba675-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7237/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Filling vacancy from outside agency","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The priority placement program established under subsection (b) shall include provisions under which a vacant position shall not be filled by the appointment or transfer of any individual from outside of the agency if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbdfba676-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7237/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is then available any eligible employee who applies for the position within 30 days of the agency issuing a job announcement and is qualified (or can be trained or retrained to become qualified within 90 days of assuming the position) for the position; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdfba677-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7237/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the position is within the same commuting area as the eligible employee’s last-held position or residence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdfba678-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7237/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Job placement and counseling services","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The head of the agency may establish a program to provide job placement and counseling services to eligible employees. A program established under subsection (d) may include, but is not limited to, such services as—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbdfba679-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7237/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" career and personal counseling;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdfba67a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7237/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" training and job search skills; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdfba67b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7237/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" job placement assistance, including assistance provided through cooperative arrangements with State and local employment services offices.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbdfba67c-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/206/tIII/s301"},"text":"Pub. L. 104–206, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2999"},"text":"110 Stat. 2999","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbdfba67d-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbdfba67e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbdfba67f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Energy and Water Development Appropriations Act, 1997, and not as part of the Department of Energy Organization Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
