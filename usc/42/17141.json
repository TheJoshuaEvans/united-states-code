{"tag":"section","attrib":{"id":"idc029aa97-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17141"},"text":null,"children":[{"tag":"num","attrib":{"value":"17141"},"text":"§ 17141.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on incandescent lamps by Coast Guard","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc029aa98-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17141/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided by subsection (b), on and after ","children":[{"tag":"date","attrib":{"date":"2009-01-01"},"text":"January 1, 2009","children":[],"tail":", a general service incandescent lamp shall not be purchased or installed in a Coast Guard facility by or on behalf of the Coast Guard."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc029aa99-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17141/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A general service incandescent lamp may be purchased, installed, and used in a Coast Guard facility whenever the application of a general service incandescent lamp is—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc029aa9a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17141/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" necessary due to purpose or design, including medical, security, and industrial applications;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc029aa9b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17141/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reasonable due to the architectural or historical value of a light fixture installed before ","children":[{"tag":"date","attrib":{"date":"2009-01-01"},"text":"January 1, 2009","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc029aa9c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17141/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Commandant of the Coast Guard determines that operational requirements necessitate the use of a general service incandescent lamp.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc029aa9d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17141/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “facility” does not include a vessel or aircraft of the Coast Guard.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc029aa9e-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/tV/s522"},"text":"Pub. L. 110–140, title V, § 522","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1662"},"text":"121 Stat. 1662","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc029aa9f-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc029aaa0-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc029aaa1-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the date that is 1 day after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/s1601"},"text":"section 1601 of Pub. L. 110–140","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1824"},"text":"section 1824 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
