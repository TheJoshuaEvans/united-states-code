{"tag":"section","attrib":{"id":"idc06554bc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18742"},"text":null,"children":[{"tag":"num","attrib":{"value":"18742"},"text":"§ 18742.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advanced energy manufacturing and recycling grant program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc06554bd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18742/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc06554be-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18742/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advanced energy property","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “advanced energy property” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc06554bf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18742/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" property designed to be used to produce energy from the sun, water, wind, geothermal or hydrothermal (as those terms are defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s17191"},"text":"section 17191 of this title","children":[],"tail":") resources, enhanced geothermal systems (as defined in that section), or other renewable resources;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06554c0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18742/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fuel cells, microturbines, or energy storage systems and components;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06554c1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18742/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" electric grid modernization equipment or components;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06554c2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18742/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" property designed to capture, remove, use, or sequester carbon oxide emissions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06554c3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18742/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" equipment designed to refine, electrolyze, or blend any fuel, chemical, or product that is—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc06554c4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18742/a/1/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" renewable; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc06554c5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18742/a/1/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" low-carbon and low-emission;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06554c6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18742/a/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" property designed to produce energy conservation technologies (including for residential, commercial, and industrial applications);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06554c7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18742/a/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc06554c8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18742/a/1/G/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" light-, medium-, or heavy-duty electric or fuel cell vehicles, electric or fuel cell locomotives, electric or fuel cell maritime vessels, or electric or fuel cell planes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc06554c9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18742/a/1/G/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" technologies, components, and materials of those vehicles, locomotives, maritime vessels, or planes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc06554ca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18742/a/1/G/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" charging or refueling infrastructure associated with those vehicles, locomotives, maritime vessels, or planes;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06554cb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18742/a/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc06554cc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18742/a/1/H/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hybrid vehicles with a gross vehicle weight rating of not less than 14,000 pounds; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc06554cd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18742/a/1/H/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" technologies, components, and materials for those vehicles; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06554ce-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18742/a/1/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other advanced energy property designed to reduce greenhouse gas emissions, as may be determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06554cf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18742/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered census tract","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “covered census tract” means a census tract—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc06554d0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18742/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in which, after ","children":[{"tag":"date","attrib":{"date":"1999-12-31"},"text":"December 31, 1999","children":[],"tail":", a coal mine had closed;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06554d1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18742/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in which, after ","children":[{"tag":"date","attrib":{"date":"2009-12-31"},"text":"December 31, 2009","children":[],"tail":", a coal-fired electricity generating unit had been retired; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06554d2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18742/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is immediately adjacent to a census tract described in subparagraph (A) or (B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06554d3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18742/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible entity” means a manufacturing firm—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc06554d4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18742/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the gross annual sales of which are less than $100,000,000;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06554d5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18742/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that has fewer than 500 employees at the plant site of the manufacturing firm; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06554d6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18742/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the annual energy bills of which total more than $100,000 but less than $2,500,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06554d7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18742/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minority-owned","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “minority-owned”, with respect to an eligible entity, means an eligible entity not less than 51 percent of which is owned by 1 or more individuals who are—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc06554d8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18742/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" citizens of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06554d9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18742/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Asian American, Native Hawaiian, Pacific Islander, African American, Hispanic, Puerto Rican, Native American, or Alaska Native.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06554da-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18742/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Program” means the grant program established under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06554db-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18742/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifying advanced energy project","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “qualifying advanced energy project” means a project that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc06554dc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18742/a/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc06554dd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18742/a/6/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" re-equips, expands, or establishes a manufacturing or recycling facility for the production or recycling, as applicable, of advanced energy property; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc06554de-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18742/a/6/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" re-equips an industrial or manufacturing facility with equipment designed to reduce the greenhouse gas emissions of that facility substantially below the greenhouse gas emissions under current best practices, as determined by the Secretary, through the installation of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idc06554df-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18742/a/6/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" low- or zero-carbon process heat systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc06554e0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18742/a/6/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carbon capture, transport, utilization, and storage systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc06554e1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18742/a/6/A/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" technology relating to energy efficiency and reduction in waste from industrial processes; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc06554e2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18742/a/6/A/ii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other industrial technology that significantly reduces greenhouse gas emissions, as determined by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06554e3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18742/a/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a reasonable expectation of commercial viability, as determined by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06554e4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18742/a/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is located in a covered census tract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc06554e5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18742/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2021-11-15"},"text":"November 15, 2021","children":[],"tail":", the Secretary shall establish a program to award grants to eligible entities to carry out qualifying advanced energy projects."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc06554e6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18742/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc06554e7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18742/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each eligible entity seeking a grant under the Program shall submit to the Secretary an application at such time, in such manner, and containing such information as the Secretary may require, including a description of the proposed qualifying advanced energy project to be carried out using the grant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06554e8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18742/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection criteria","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc06554e9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18742/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Projects","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In selecting eligible entities to receive grants under the Program, the Secretary shall, with respect to the qualifying advanced energy projects proposed by the eligible entities, give higher priority to projects that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc06554ea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18742/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will provide higher net impact in avoiding or reducing anthropogenic emissions of greenhouse gases;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc06554eb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18742/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will result in a higher level of domestic job creation (both direct and indirect) during the lifetime of the project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc06554ec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18742/c/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" will result in a higher level of job creation in the vicinity of the project, particularly with respect to—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idc06554ed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18742/c/2/A/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" low-income communities (as described in section 45D(e) of the Internal Revenue Code of 1986); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc06554ee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18742/c/2/A/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" dislocated workers who were previously employed in manufacturing, coal power plants, or coal mining;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc06554ef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18742/c/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have higher potential for technological innovation and commercial deployment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc06554f0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18742/c/2/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" have a lower levelized cost of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idc06554f1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18742/c/2/A/v/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" generated or stored energy; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc06554f2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18742/c/2/A/v/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" measured reduction in energy consumption or greenhouse gas emission (based on costs of the full supply chain); and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc06554f3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18742/c/2/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have a shorter project time.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06554f4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18742/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In selecting eligible entities to receive grants under the Program, the Secretary shall give priority to eligible entities that are minority-owned.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc06554f5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18742/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Project completion and location; return of unobligated funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc06554f6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18742/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Completion; return of unobligated funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An eligible entity that receives a grant under the Program shall be required—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc06554f7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18742/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to complete the qualifying advanced energy project funded by the grant not later than 3 years after the date of receipt of the grant funds; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06554f8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18742/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to return to the Secretary any grant funds that remain unobligated at the end of that 3-year period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06554f9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18742/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Location","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary determines that an eligible entity awarded a grant under the Program has carried out the applicable qualifying advanced energy project at a location that is materially different from the location specified in the application for the grant, the eligible entity shall be required to return the grant funds to the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc06554fa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18742/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc06554fb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18742/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2021-11-15"},"text":"November 15, 2021","children":[],"tail":", the Secretary shall provide technical assistance on a selective basis to eligible entities that are seeking a grant under the Program to enhance the impact of the qualifying advanced energy project to be carried out using the grant with respect to the selection criteria described in subsection (c)(2)(A)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06554fc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18742/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An eligible entity desiring technical assistance under paragraph (1) shall submit to the Secretary an application at such time, in such manner, and containing such information as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06554fd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18742/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Factors for consideration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In selecting eligible entities for technical assistance under paragraph (1), the Secretary shall give higher priority to eligible entities that propose a qualifying advanced energy project that has greater potential for enhancement of the impact of the project with respect to the selection criteria described in subsection (c)(2)(A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc06554fe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18742/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication of grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall make publicly available the identity of each eligible entity awarded a grant under the Program and the amount of the grant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc06554ff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18742/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 4 years after ","children":[{"tag":"date","attrib":{"date":"2021-11-15"},"text":"November 15, 2021","children":[],"tail":", the Secretary shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0655500-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18742/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review the grants awarded under the Program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0655501-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18742/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit to the Committee on Energy and Natural Resources of the Senate and the Committee on Energy and Commerce of the House of Representatives a report describing those grants.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0655502-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18742/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to the Secretary to carry out the Program $750,000,000 for the period of fiscal years 2022 through 2026.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc0655503-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dD/tII/s40209"},"text":"Pub. L. 117–58, div. D, title II, § 40209","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/975"},"text":"135 Stat. 975","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc0655504-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc0655505-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc0655506-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Wage Rate Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions relating to rates of wages to be paid to laborers and mechanics on projects for construction, alteration, or repair work funded under div. D or an amendment by div. D of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":", including authority of Secretary of Labor, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s18851"},"text":"section 18851 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
