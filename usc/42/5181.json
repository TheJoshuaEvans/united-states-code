{"tag":"section","attrib":{"id":"idbd1b8022-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5181"},"text":null,"children":[{"tag":"num","attrib":{"value":"5181"},"text":"§ 5181.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relocation assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, no person otherwise eligible for any kind of replacement housing payment under the Uniform Relocation Assistance and Real Property Acquisition Policies Act of 1970 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/646"},"text":"P.L. 91–646","children":[],"tail":") ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4601"},"text":"42 U.S.C. 4601","children":[],"tail":" et seq.] shall be denied such eligibility as a result of his being unable, because of a major disaster as determined by the President, to meet the occupancy requirements set by such Act."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbd1b8023-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/288/tIV/s414"},"text":"Pub. L. 93–288, title IV, § 414","children":[],"tail":", formerly § 411, "},{"tag":"date","attrib":{"date":"1974-05-22"},"text":"May 22, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/157"},"text":"88 Stat. 157","children":[],"tail":"; renumbered § 414, "},{"tag":"ref","attrib":{"href":"/us/pl/100/707/tI/s106/h"},"text":"Pub. L. 100–707, title I, § 106(h)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-23"},"text":"Nov. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4705"},"text":"102 Stat. 4705","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd1b8024-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd1b8025-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbd1b8026-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Uniform Relocation Assistance and Real Property Acquisition Policies Act of 1970, referred to in text, is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/646"},"text":"Pub. L. 91–646","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-01-02"},"text":"Jan. 2, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1894"},"text":"84 Stat. 1894","children":[],"tail":", which is classified principally to chapter 61 (§ 4601 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4601"},"text":"section 4601 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbd1b8027-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 414(a), (b) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/288"},"text":"Pub. L. 93–288","children":[],"tail":" was renumbered section 417(a), (b) by "},{"tag":"ref","attrib":{"href":"/us/pl/100/707"},"text":"Pub. L. 100–707","children":[],"tail":" and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5184"},"text":"section 5184 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
