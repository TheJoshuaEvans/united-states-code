{"tag":"section","attrib":{"id":"idbfdfcfe1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15095"},"text":null,"children":[{"tag":"num","attrib":{"value":"15095"},"text":"§ 15095.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation of the lead entity","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfdfcfe2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15095/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Chief Executive Officer of a State that desires to receive a grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s15093"},"text":"section 15093 of this title","children":[],"tail":", shall designate the office or entity (referred to in this subchapter as the “lead entity”) responsible for—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfdfcfe3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15095/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submitting the application described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s15094"},"text":"section 15094 of this title","children":[],"tail":" on behalf of the State;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfdfcfe4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15095/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" administering and supervising the use of the amounts made available under the grant;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfdfcfe5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15095/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinating efforts related to and supervising the preparation of the application;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfdfcfe6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15095/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinating the planning, development, implementation (or expansion and enhancement), and evaluation of a statewide system of family support services for families of children with disabilities among public agencies and between public agencies and private agencies, including coordinating efforts related to entering into interagency agreements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfdfcfe7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15095/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinating efforts related to the participation by families of children with disabilities in activities carried out under a grant made under this subchapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfdfcfe8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15095/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submitting the report described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s15097"},"text":"section 15097 of this title","children":[],"tail":" on behalf of the State."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfdfcfe9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15095/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifications","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In designating the lead entity, the Chief Executive Officer may designate—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfdfcfea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15095/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an office of the Chief Executive Officer;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfdfcfeb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15095/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a commission appointed by the Chief Executive Officer;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfdfcfec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15095/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a public agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfdfcfed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15095/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a council established under Federal or State law; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfdfcfee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15095/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" another appropriate office, agency, or entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfdfcfef-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/402/tII/s206"},"text":"Pub. L. 106–402, title II, § 206","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1731"},"text":"114 Stat. 1731","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
