{"tag":"section","attrib":{"id":"idbfcf06b2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14305"},"text":null,"children":[{"tag":"num","attrib":{"value":"14305"},"text":"§ 14305.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information gathering and access","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfcf06b3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14305/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Records and reports","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A person who is required to carry out the objectives of this chapter, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfcf06b4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14305/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a regulated battery manufacturer;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfcf06b5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14305/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a rechargeable consumer product manufacturer;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfcf06b6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14305/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a mercury-containing battery manufacturer; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfcf06b7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14305/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an authorized agent of a person described in paragraph (1), (2), or (3),","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall establish and maintain such records and report such information as the Administrator may by regulation reasonably require to carry out the objectives of this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfcf06b8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14305/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Access and copying","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator or the Administrator’s authorized representative, on presentation of credentials of the Administrator, may at reasonable times have access to and copy any records required to be maintained under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfcf06b9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14305/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Confidentiality","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall maintain the confidentiality of documents and records that contain proprietary information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfcf06ba-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/142/s6"},"text":"Pub. L. 104–142, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-05-13"},"text":"May 13, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1332"},"text":"110 Stat. 1332","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
