{"tag":"section","attrib":{"id":"idb4806fb7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s238b"},"text":null,"children":[{"tag":"num","attrib":{"value":"238b"},"text":"§ 238b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposition of money collected for care of patients","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Money collected as provided by law for expenses incurred in the care and treatment of foreign seamen, and money received for the care and treatment of pay patients, including any amounts received from any executive department on account of care and treatment of pay patients, shall be covered into the appropriation from which the expenses of such care and treatment were paid.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb4806fb8-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title II, § 233, formerly title V, § 503, "},{"tag":"ref","attrib":{"href":"/us/stat/58/710"},"text":"58 Stat. 710","children":[],"tail":", renumbered title XXI, § 2103, "},{"tag":"ref","attrib":{"href":"/us/pl/98/24/s2/a/1"},"text":"Pub. L. 98–24, § 2(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-04-26"},"text":"Apr. 26, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/176"},"text":"97 Stat. 176","children":[],"tail":"; renumbered title XXIII, § 2303, "},{"tag":"ref","attrib":{"href":"/us/pl/99/660/tIII/s311/a"},"text":"Pub. L. 99–660, title III, § 311(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3755"},"text":"100 Stat. 3755","children":[],"tail":"; renumbered title XXV, § 2503, "},{"tag":"ref","attrib":{"href":"/us/pl/100/607/tII/s201/1"},"text":"Pub. L. 100–