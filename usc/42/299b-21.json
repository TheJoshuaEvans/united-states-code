{"tag":"section","attrib":{"id":"idb602c92c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–21"},"text":null,"children":[{"tag":"num","attrib":{"value":"299b–21"},"text":"§ 299b–21.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this part:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb602c92d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–21/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" HIPAA confidentiality regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “HIPAA confidentiality regulations” means regulations promulgated under section 264(c) of the Health Insurance Portability and Accountability Act of 1996 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/191"},"text":"Public Law 104–191","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/110/2033"},"text":"110 Stat. 2033","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb602c92e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–21/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Identifiable patient safety work product","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “identifiable patient safety work product” means patient safety work product that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb602c92f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–21/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is presented in a form and manner that allows the identification of any provider that is a subject of the work product, or any providers that participate in activities that are a subject of the work product;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb602c930-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–21/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" constitutes individually identifiable health information as that term is defined in the HIPAA confidentiality regulations; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb602c931-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–21/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is presented in a form and manner that allows the identification of an individual who reported information in the manner specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s299b–22/e"},"text":"section 299b–22(e) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb602c932-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–21/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonidentifiable patient safety work product","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “nonidentifiable patient safety work product” means patient safety work product that is not identifiable patient safety work product (as defined in paragraph (2)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb602c933-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–21/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Patient safety organization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “patient safety organization” means a private or public entity or component thereof that is listed by the Secretary pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s299b–24/d"},"text":"section 299b–24(d) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb602c934-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–21/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Patient safety activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “patient safety activities” means the following activities:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb602c935-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–21/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Efforts to improve patient safety and the quality of health care delivery.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb602c936-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–21/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The collection and analysis of patient safety work product.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb602c937-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–21/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The development and dissemination of information with respect to improving patient safety, such as recommendations, protocols, or information regarding best practices.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb602c938-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–21/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The utilization of patient safety work product for the purposes of encouraging a culture of safety and of providing feedback and assistance to effectively minimize patient risk.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb602c939-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–21/5/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The maintenance of procedures to preserve confidentiality with respect to patient safety work product.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb602c93a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–21/5/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The provision of appropriate security measures with respect to patient safety work product.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb602c93b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–21/5/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The utilization of qualified staff.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb602c93c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–21/5/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Activities related to the operation of a patient safety evaluation system and to the provision of feedback to participants in a patient safety evaluation system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb602c93d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–21/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Patient safety evaluation system","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “patient safety evaluation system” means the collection, management, or analysis of information for reporting to or by a patient safety organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb602c93e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–21/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Patient safety work product","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb602c93f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–21/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subparagraph (B), the term “patient safety work product” means any data, reports, records, memoranda, analyses (such as root cause analyses), or written or oral statements—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb602c940-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–21/7/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" which—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb602c941-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–21/7/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are assembled or developed by a provider for reporting to a patient safety organization and are reported to a patient safety organization; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb602c942-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–21/7/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are developed by a patient safety organization for the conduct of patient safety activities;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":" and which could result in improved patient safety, health care quality, or health care outcomes; or","children":[],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb602c943-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–21/7/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which identify or constitute the deliberations or analysis of, or identify the fact of reporting pursuant to, a patient safety evaluation system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb602c944-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–21/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Clarification","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb602c945-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–21/7/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Information described in subparagraph (A) does not include a patient’s medical record, billing and discharge information, or any other original patient or provider record.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb602c946-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–21/7/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Information described in subparagraph (A) does not include information that is collected, maintained, or developed separately, or exists separately, from a patient safety evaluation system. Such separate information or a copy thereof reported to a patient safety organization shall not by reason of its reporting be considered patient safety work product.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb602c947-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–21/7/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Nothing in this part shall be construed to limit—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb602c948-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–21/7/B/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the discovery of or admissibility of information described in this subparagraph in a criminal, civil, or administrative proceeding;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb602c949-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–21/7/B/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reporting of information described in this subparagraph to a Federal, State, or local governmental agency for public health surveillance, investigation, or other public health purposes or health oversight purposes; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb602c94a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–21/7/B/iii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a provider’s recordkeeping obligation with respect to information described in this subparagraph under Federal, State, or local law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb602c94b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–21/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provider","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “provider” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb602c94c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–21/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an individual or entity licensed or otherwise authorized under State law to provide health care services, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb602c94d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–21/8/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a hospital, nursing facility, comprehensive outpatient rehabilitation facility, home health agency, hospice program, renal dialysis facility, ambulatory surgical center, pharmacy, physician or health care practitioner’s office, long term care facility, behavior health residential treatment facility, clinical laboratory, or health center; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb602c94e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–21/8/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a physician, physician assistant, nurse practitioner, clinical nurse specialist, certified registered nurse anesthetist, certified nurse midwife, psychologist, certified social worker, registered dietitian or nutrition professional, physical or occupational therapist, pharmacist, or other individual health care practitioner; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb602c94f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–21/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other individual or entity specified in regulations promulgated by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb602c950-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title IX, § 921, as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/41/s2/a/5"},"text":"Pub. L. 109–41, § 2(a)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-07-29"},"text":"July 29, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/424"},"text":"119 Stat. 424","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb602c951-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb602c952-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb602c953-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 264(c) of the Health Insurance Portability and Accountability Act of 1996, referred to in par. (1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/191/s264/c"},"text":"section 264(c) of Pub. L. 104–191","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320d–2"},"text":"section 1320d–2 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb602c954-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 921 of act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", was renumbered section 941 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s299c"},"text":"section 299c of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 921 of act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s299c"},"text":"section 299c of this title","children":[],"tail":" prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/106/129"},"text":"Pub. L. 106–129","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
