{"tag":"section","attrib":{"id":"idb5f20129-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s296j"},"text":null,"children":[{"tag":"num","attrib":{"value":"296j"},"text":"§ 296j.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advanced education nursing grants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5f2012a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s296j/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may award grants to and enter into contracts with eligible entities to meet the costs of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5f2012b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s296j/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" projects that support the enhancement of advanced nursing education and practice; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5f2012c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s296j/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" traineeships for individuals in advanced nursing education programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5f2012d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s296j/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of advanced education nurses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “advanced education nurses” means individuals trained in advanced degree programs including individuals in combined R.N./graduate degree programs, post-nursing master’s certificate programs, or, in the case of nurse midwives, in certificate programs in existence on the date that is one day prior to ","children":[{"tag":"date","attrib":{"date":"1998-11-13"},"text":"November 13, 1998","children":[],"tail":", to serve as nurse practitioners, clinical nurse specialists, nurse midwives, nurse anesthetists, nurse educators, nurse administrators, clinical nurse leaders, or public health nurses, or in other nurse specialties determined by the Secretary to require advanced education."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5f2012e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s296j/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorized nurse practitioner","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nurse practitioner programs eligible for support under this section are educational programs for registered nurses (irrespective of the type of school of nursing in which the nurses received their training) that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5f2012f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s296j/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meet guidelines prescribed by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5f20130-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s296j/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have as their objective the education of nurses who will upon completion of their studies in such programs, be qualified to effectively provide primary health care, including primary health care in homes and in ambulatory care facilities, long-term care facilities, acute care, and other health care settings.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5f20131-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s296j/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorized nurse-midwifery programs","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Midwifery programs that are eligible for support under this section are educational programs that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5f20132-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s296j/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have as their objective the education of midwives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5f20133-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s296j/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are accredited by the American College of Nurse-Midwives Accreditation Commission for Midwifery Education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5f20134-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s296j/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorized nurse anesthesia programs","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nurse anesthesia programs eligible for support under this section are education programs that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5f20135-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s296j/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide registered nurses with full-time anesthetist education; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5f20136-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s296j/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are accredited by the Council on Accreditation of Nurse Anesthesia Educational Programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5f20137-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s296j/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorized clinical nurse specialist programs","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Clinical nurse specialist programs eligible for support under this section are education programs that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5f20138-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s296j/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide registered nurses with full-time clinical nurse specialist education; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5f20139-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s296j/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have as their objective the education of clinical nurse specialists who will, upon completion of such a program, be qualified to effectively provide care through the wellness and illness continuum to inpatients and outpatients experiencing acute and chronic illness.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5f2013a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s296j/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other authorized educational programs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall prescribe guidelines as appropriate for other advanced nurse education programs eligible for support under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5f2013b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s296j/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Traineeships","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5f2013c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s296j/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may not award a grant to an applicant under subsection (a) unless the applicant involved agrees that traineeships provided with the grant will only pay all or part of the costs of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5f2013d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s296j/h/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the tuition, books, and fees of the program of advanced nurse education with respect to which the traineeship is provided; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5f2013e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s296j/h/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reasonable living expenses of the individual during the period for which the traineeship is provided.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5f2013f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s296j/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special consideration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In making awards of grants and contracts under subsection (a)(2), the Secretary shall give special consideration to an eligible entity that agrees to expend the award to train advanced education nurses who will practice in health professional shortage areas designated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s254e"},"text":"section 254e of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5f20140-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title VIII, § 811, as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/392/tI/s123/4"},"text":"Pub. L. 105–392, title I, § 123(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3566"},"text":"112 Stat. 3566","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tV/s5308"},"text":"Pub. L. 111–148, title V, § 5308","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/629"},"text":"124 Stat. 629","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/136/dA/tIII/s3404/a/5"},"text":"Pub. L. 116–136, div. A, title III, § 3404(a)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-03-27"},"text":"Mar. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/393"},"text":"134 Stat. 393","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb5f20141-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb5f20142-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb5f20143-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 296j, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373/tVIII/s815"},"text":"act July 1, 1944, ch. 373, title VIII, § 815","children":[],"tail":", as added "},{"tag":"date","attrib":{"date":"1975-07-29"},"text":"July 29, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/94/63/tIX/s921"},"text":"Pub. L. 94–63, title IX, § 921","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/358"},"text":"89 Stat. 358","children":[],"tail":"; amended "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tXXVII/s2752"},"text":"Pub. L. 97–35, title XXVII, § 2752","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/929"},"text":"95 Stat. 929","children":[],"tail":", set forth provisions relating to authorization, terms and conditions, etc., respecting grants for operational costs or meeting accreditation requirements, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/99/92"},"text":"Pub. L. 99–92","children":[],"tail":", §§ 9(a)(1), 10(a), "},{"tag":"date","attrib":{"date":"1985-08-16"},"text":"Aug. 16, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/400"},"text":"99 Stat. 400","children":[],"tail":", 402, effective "},{"tag":"date","attrib":{"date":"1985-10-01"},"text":"Oct. 1, 1985","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb5f20144-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/136/s3404/a/5/A"},"text":"Pub. L. 116–136, § 3404(a)(5)(A)","children":[],"tail":", substituted “R.N./graduate” for “R.N./Master’s” and inserted “clinical nurse leaders,” after “nurse administrators,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (f) to (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/136/s3404/a/5/B"},"text":"Pub. L. 116–136, § 3404(a)(5)(B)","children":[],"tail":", (C), added subsec. (f) and redesignated former subsecs. (f) and (g) as (g) and (h), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/s5308/1"},"text":"Pub. L. 111–148, § 5308(1)","children":[],"tail":", struck out “and nurse midwifery programs” after “practitioner” in heading and “and nurse midwifery” after “practitioner” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (d), (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/s5308/3"},"text":"Pub. L. 111–148, § 5308(3)","children":[],"tail":", (4), added subsec. (d) and redesignated former subsec. (d) as (e). Former subsec. (e) redesignated (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/s5308/3"},"text":"Pub. L. 111–148, § 5308(3)","children":[],"tail":", redesignated subsec. (e) as (f). Former subsec. (f) redesignated (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(2), (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/s5308/2"},"text":"Pub. L. 111–148, § 5308(2)","children":[],"tail":", redesignated par. (3) as (2) and struck out former par. (2). Prior to amendment, text of par. (2) read as follows: “The Secretary may not obligate more than 10 percent of the traineeships under subsection (a) of this section for individuals in doctorate degree programs.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/s5308/3"},"text":"Pub. L. 111–148, § 5308(3)","children":[],"tail":", redesignated subsec. (f) as (g)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
