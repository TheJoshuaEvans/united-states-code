{"tag":"section","attrib":{"id":"idbf177698-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10166"},"text":null,"children":[{"tag":"num","attrib":{"value":"10166"},"text":"§ 10166.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice of disapproval","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf177699-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10166/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The selection of a site under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s10165"},"text":"section 10165 of this title","children":[],"tail":" shall be effective at the end of the period of 60 calendar days beginning on the date of notification under such subsection,"},{"tag":"ref","attrib":{"idref":"fn003945"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003945"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “section,”."}],"tail":" unless the governing body of the Indian tribe on whose reservation such site is located, or, if the site is not on a reservation, the Governor and the legislature of the State in which the site is located, has submitted to Congress a notice of disapproval with respect to such site. If any such notice of disapproval has been submitted under this subsection, the selection of the site under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s10165"},"text":"section 10165 of this title","children":[],"tail":" shall not be effective except as provided under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s10135/c"},"text":"section 10135(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf17769a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10166/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" References","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of carrying out the provisions of this subsection,","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" references in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s10135/c"},"text":"section 10135(c) of this title","children":[],"tail":" to a repository shall be considered to refer to a monitored retrievable storage facility and references to a notice of disapproval of a repository site designation under section 10136(b) or 10138(a) of this title shall be considered to refer to a notice of disapproval under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf17769b-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/425/tI/s146"},"text":"Pub. L. 97–425, title I, § 146","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/202/s101/d/tIII/s300"},"text":"Pub. L. 100–202, § 101(d) [title III, § 300]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1329-104"},"text":"101 Stat. 1329–104","children":[],"tail":", 1329–121; "},{"tag":"ref","attrib":{"href":"/us/pl/100/203/tV/s5021"},"text":"Pub. L. 100–203, title V, § 5021","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1330-235"},"text":"101 Stat. 1330–235","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf17769c-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"