{"tag":"section","attrib":{"id":"idb60784ff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299c–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"299c–1"},"text":"§ 299c–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Peer review with respect to grants and contracts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb6078500-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299c–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement of review","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6078501-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299c–1/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Appropriate technical and scientific peer review shall be conducted with respect to each application for a grant, cooperative agreement, or contract under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6078502-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299c–1/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports to Director","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each peer review group to which an application is submitted pursuant to paragraph (1) shall report its finding and recommendations respecting the application to the Director in such form and in such manner as the Director shall require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6078503-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299c–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval as precondition of awards","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director may not approve an application described in subsection (a)(1) unless the application is recommended for approval by a peer review group established under subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6078504-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299c–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of peer review groups","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6078505-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299c–1/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall establish such technical and scientific peer review groups as may be necessary to carry out this section. Such groups shall be established without regard to the provisions of title 5 that govern appointments in the competitive service, and without regard to the provisions of chapter 51, and subchapter III of chapter 53, of such title that relate to classification and pay rates under the General Schedule.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6078506-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299c–1/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The members of any peer review group established under this section shall be appointed from among individuals who by virtue of their training or experience are eminently qualified to carry out the duties of such peer review group. Officers and employees of the United States may not constitute more than 25 percent of the membership of any such group. Such officers and employees may not receive compensation for service on such groups in addition to the compensation otherwise received for these duties carried out as such officers and employees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6078507-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299c–1/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s1013/a"},"text":"section 1013(a) of title 5","children":[],"tail":", peer review groups established under this section may continue in existence until otherwise provided by law."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6078508-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299c–1/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifications","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Members of any peer review group shall, at a minimum, meet the following requirements:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6078509-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299c–1/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such members shall agree in writing to treat information received, pursuant to their work for the group, as confidential information, except that this subparagraph shall not apply to public records and public information.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb607850a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299c–1/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such members shall agree in writing to recuse themselves from participation in the peer review of specific applications which present a potential personal conflict of interest or appearance of such conflict, including employment in a directly affected organization, stock ownership, or any financial or other arrangement that might introduce bias in the process of peer review.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb607850b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299c–1/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority for procedural adjustments in certain cases","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of applications for financial assistance whose direct costs will not exceed $100,000, the Director may make appropriate adjustments in the procedures otherwise established by the Director for the conduct of peer review under this section. Such adjustments may be made for the purpose of encouraging the entry of individuals into the field of research, for the purpose of encouraging clinical practice-oriented or provider-based research, and for such other purposes as the Director may determine to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb607850c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299c–1/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall issue regulations for the conduct of peer review under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb607850d-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title IX, § 942, formerly § 922, as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/129/s2/a"},"text":"Pub. L. 106–129, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-12-06"},"text":"Dec. 6, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1665"},"text":"113 Stat. 1665","children":[],"tail":"; renumbered § 932, "},{"tag":"ref","attrib":{"href":"/us/pl/109/41/s2/a/3"},"text":"Pub. L. 109–41, § 2(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-07-29"},"text":"July 29, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/424"},"text":"119 Stat. 424","children":[],"tail":"; renumbered § 942, "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tIII/s3013/a/2"},"text":"Pub. L. 111–148, title III, § 3013(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/381"},"text":"124 Stat. 381","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/243"},"text":"Pub. L. 117–286, § 4(a)(243)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4332"},"text":"136 Stat. 4332","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb607850e-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb607850f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb6078510-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The provisions of title 5 that govern appointments in the competitive service, referred to in subsec. (c)(1), are classified generally to section 3301 et seq. of Title 5, Government Organization and Employees.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb6078511-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 299c–1, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373/tIX/s922"},"text":"act July 1, 1944, ch. 373, title IX, § 922","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/239/tVI/s6103/c"},"text":"Pub. L. 101–239, title VI, § 6103(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2201"},"text":"103 Stat. 2201","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/tIV/s4118/f/2/F"},"text":"Pub. L. 101–508, title IV, § 4118(f)(2)(F)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-70"},"text":"104 Stat. 1388–70","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/410/s5/d"},"text":"Pub. L. 102–410, § 5(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-13"},"text":"Oct. 13, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2098"},"text":"106 Stat. 2098","children":[],"tail":", related to peer review with respect to grants and contracts, prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/106/129"},"text":"Pub. L. 106–129","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb6078512-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":", which directed amendment of “Section 941(c)(3) of the Public Health Service Act” by substituting “"},{"tag":"ref","attrib":{"href":"/us/usc/t5/s1013/a"},"text":"section 1013(a) of title 5","children":[],"tail":",” for “section 14(a) of the Federal Advisory Committee Act,”, was executed to this section, which is section 942 of the Public Health Service Act, to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
