{"tag":"section","attrib":{"id":"idbdc99a38-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6917"},"text":null,"children":[{"tag":"num","attrib":{"value":"6917"},"text":"§ 6917.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of Ombudsman","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbdc99a39-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6917/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment; functions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall establish an Office of Ombudsman, to be directed by an Ombudsman. It shall be the function of the Office of Ombudsman to receive individual complaints, grievances, requests for information submitted by any person with respect to any program or requirement under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdc99a3a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6917/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to render assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Ombudsman shall render assistance with respect to the complaints, grievances, and requests submitted to the Office of Ombudsman, and shall make appropriate recommendations to the Administrator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdc99a3b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6917/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect on procedures for grievances, appeals, or administrative matters","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The establishment of the Office of Ombudsman shall not affect any procedures for grievances, appeals, or administrative matters in any other provision of this chapter, any other provision of law, or any Federal regulation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdc99a3c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6917/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Office of the Ombudsman shall cease to exist 4 years after ","children":[{"tag":"date","attrib":{"date":"1984-11-08"},"text":"November 8, 1984","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbdc99a3d-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/272/tII/s2008"},"text":"Pub. L. 89–272, title II, § 2008","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/98/616/tI/s103/a"},"text":"Pub. L. 98–616, title I, § 103(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-11-08"},"text":"Nov. 8, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3225"},"text":"98 Stat. 3225","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
