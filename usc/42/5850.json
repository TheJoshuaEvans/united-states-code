{"tag":"section","attrib":{"id":"idbd630fbd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5850"},"text":null,"children":[{"tag":"num","attrib":{"value":"5850"},"text":"§ 5850.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unresolved safety issues plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Commission shall develop a plan providing for the specification and analysis of unresolved safety issues relating to nuclear reactors and shall take such action as may be necessary to implement corrective measures with respect to such issues. Such plan shall be submitted to the Congress on or before ","children":[{"tag":"date","attrib":{"date":"1978-01-01"},"text":"January 1, 1978","children":[],"tail":" and progress reports shall be included in the annual report of the Commission thereafter."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbd630fbe-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/438/tII/s210"},"text":"Pub. L. 93–438, title II, § 210","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/95/209/s3"},"text":"Pub. L. 95–209, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-12-13"},"text":"Dec. 13, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1482"},"text":"91 Stat. 1482","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd630fbf-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd630fc0-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbd630fc1-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Another ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/438/s210"},"text":"section 210 of Pub. L. 93–438","children":[],"tail":" was renumbered section 211 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5851"},"text":"section 5851 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idbd630fc2-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"idbd630fc3-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of certain functions from Nuclear Regulatory Commission to Chairman thereof, see Reorg. Plan No. 1 of 1980, 45 F.R. 40561, ","children":[{"tag":"ref","attrib":{"href":"/us/stat/94/3585"},"text":"94 Stat. 3585","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5841"},"text":"section 5841 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
