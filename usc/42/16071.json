{"tag":"section","attrib":{"id":"idbff071b9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16071"},"text":null,"children":[{"tag":"num","attrib":{"value":"16071"},"text":"§ 16071.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pilot program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbff071ba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16071/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in consultation with the Secretary of Transportation, shall establish a competitive grant pilot program (referred to in this subpart as the “pilot program”), to be administered through the Clean Cities Program of the Department, to provide not more than 30 geographically dispersed project grants to State governments, local governments, or metropolitan transportation authorities to carry out a project or projects for the purposes described in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff071bb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16071/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A grant under this section may be used for the following purposes:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbff071bc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16071/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The acquisition of alternative fueled vehicles or fuel cell vehicles, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbff071bd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16071/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" passenger vehicles (including neighborhood electric vehicles); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff071be-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16071/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" motorized 2-wheel bicycles or other vehicles for use by law enforcement personnel or other State or local government or metropolitan transportation authority employees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff071bf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16071/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The acquisition of alternative fueled vehicles, hybrid vehicles, or fuel cell vehicles, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbff071c0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16071/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" buses used for public transportation or transportation to and from schools;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff071c1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16071/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" delivery vehicles for goods or services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff071c2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16071/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ground support vehicles at public airports (including vehicles to carry baggage or push or pull airplanes toward or away from terminal gates).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff071c3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16071/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The acquisition of ultra-low sulfur diesel vehicles.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff071c4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16071/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Installation or acquisition of infrastructure necessary to directly support an alternative fueled vehicle, fuel cell vehicle, or hybrid vehicle project funded by the grant, including fueling and other support equipment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff071c5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16071/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Operation and maintenance of vehicles, infrastructure, and equipment acquired as part of a project funded by the grant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff071c6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16071/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbff071c7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16071/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbff071c8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16071/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall issue requirements for applying for grants under the pilot program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff071c9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16071/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"At a minimum, the Secretary shall require that an application for a grant—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbff071ca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16071/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be submitted by the head of a State or local government or a metropolitan transportation authority, or any combination thereof, and a registered participant in the Clean Cities Program of the Department; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbff071cb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16071/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" include—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbff071cc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16071/c/1/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the project proposed in the application, including how the project meets the requirements of this subpart;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbff071cd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16071/c/1/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an estimate of the ridership or degree of use of the project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbff071ce-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16071/c/1/B/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an estimate of the air pollution emissions reduced and fossil fuel displaced as a result of the project, and a plan to collect and disseminate environmental data, related to the project to be funded under the grant, over the life of the project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbff071cf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16071/c/1/B/ii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of how the project will be sustainable without Federal assistance after the completion of the term of the grant;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbff071d0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16071/c/1/B/ii/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a complete description of the costs of the project, including acquisition, construction, operation, and maintenance costs over the expected life of the project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbff071d1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16071/c/1/B/ii/VI"},"text":null,"children":[{"tag":"num","attrib":{"value":"VI"},"text":"(VI)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of which costs of the project will be supported by Federal assistance under this subpart; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbff071d2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16071/c/1/B/ii/VII"},"text":null,"children":[{"tag":"num","attrib":{"value":"VII"},"text":"(VII)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" documentation to the satisfaction of the Secretary that diesel fuel containing sulfur at not more than 15 parts per million is available for carrying out the project, and a commitment by the applicant to use such fuel in carrying out the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff071d3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16071/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Partners","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An applicant under paragraph (1) may carry out a project under the pilot program in partnership with public and private entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff071d4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16071/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In evaluating applications under the pilot program, the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbff071d5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16071/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consider each applicant’s previous experience with similar projects; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff071d6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16071/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" give priority consideration to applications that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbff071d7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16071/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are most likely to maximize protection of the environment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff071d8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16071/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrate the greatest commitment on the part of the applicant to ensure funding for the proposed project and the greatest likelihood that the project will be maintained or expanded after Federal assistance under this subpart is completed; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff071d9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16071/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exceed the minimum requirements of subsection (c)(1)(B)(ii).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff071da-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16071/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pilot project requirements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbff071db-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16071/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall not provide more than $15,000,000 in Federal assistance under the pilot program to any applicant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff071dc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16071/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost sharing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall not provide more than 50 percent of the cost, incurred during the period of the grant, of any project under the pilot program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff071dd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16071/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum period of grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall not fund any applicant under the pilot program for more than 5 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff071de-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16071/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deployment and distribution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall seek to the maximum extent practicable to ensure a broad geographic distribution of project sites.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff071df-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16071/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of information and knowledge","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish mechanisms to ensure that the information and knowledge gained by participants in the pilot program are transferred among the pilot program participants and to other interested parties, including other applicants that submitted applications.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff071e0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16071/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Schedule","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbff071e1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16071/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":", the Secretary shall publish in the Federal Register, Commerce Business Daily, and elsewhere as appropriate, a request for applications to undertake projects under the pilot program. Applications shall be due not later than 180 days after the date of publication of the notice."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff071e2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16071/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after the date by which applications for grants are due, the Secretary shall select by competitive, peer reviewed proposal, all applications for projects to be awarded a grant under the pilot program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff071e3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16071/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of carrying out the pilot program, the Secretary shall issue regulations defining any term, as the Secretary determines to be necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbff071e4-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tVII/s721"},"text":"Pub. L. 109–58, title VII, § 721","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/818"},"text":"119 Stat. 818","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
