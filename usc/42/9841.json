{"tag":"section","attrib":{"id":"idbef1511a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9841"},"text":null,"children":[{"tag":"num","attrib":{"value":"9841"},"text":"§ 9841.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appeals, notice, hearing, and mediation; alternative agency for Indian tribe","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbef1511b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9841/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice requirements; suspension or termination of assistance stayed pending hearing; mediation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall prescribe—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbef1511c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9841/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" procedures to assure that special notice of and an opportunity for a timely and expeditious appeal to the Secretary will be provided for an agency or organization which desires to serve as a delegate agency under this subchapter and whose application to the Head Start agency has been wholly or substantially rejected or has not been acted upon within a period of time deemed reasonable by the Secretary, in accordance with regulations which the Secretary shall prescribe;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbef1511d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9841/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" procedures to assure that financial assistance under this subchapter shall not be suspended, except in emergency situations, unless the recipient agency has been given reasonable notice and opportunity to show cause why such action should not be taken;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbef1511e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9841/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" procedures to assure that financial assistance under this subchapter may be terminated or reduced, and an application for refunding may be denied, after the recipient has been afforded reasonable notice and opportunity for a full and fair hearing, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbef1511f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9841/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a right to file a notice of appeal of a decision not later than 30 days after notice of the decision from the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbef15120-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9841/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" access to a full and fair hearing of the appeal, not later than 120 days after receipt by the Secretary of the notice of appeal;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbef15121-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9841/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" procedures (including mediation procedures) are developed and published, to be used in order to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbef15122-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9841/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" resolve in a timely manner conflicts potentially leading to an adverse action between—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbef15123-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9841/a/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recipients of financial assistance under this subchapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbef15124-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9841/a/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" delegate agencies, or policy councils of Head Start agencies;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbef15125-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9841/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" avoid the need for an administrative hearing on an adverse action; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbef15126-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9841/a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prohibit a Head Start agency from expending financial assistance awarded under this subchapter for the purpose of paying legal fees, or other costs incurred, pursuant to an appeal under paragraph (3);","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbef15127-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9841/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" procedures to assure that the Secretary may suspend financial assistance to a recipient under this subchapter—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbef15128-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9841/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except as provided in subparagraph (B), for not more than 30 days; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbef15129-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9841/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a recipient under this subchapter that has multiple and recurring deficiencies for 180 days or more and has not made substantial and significant progress toward meeting the goals of the grantee’s quality improvement plan or eliminating all deficiencies identified by the Secretary, during the hearing of an appeal described in paragraph (3), for any amount of time; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbef1512a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9841/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" procedures to assure that in cases where a Head Start agency prevails in a decision under paragraph (4), the Secretary may determine and provide a reimbursement to the Head Start agency for fees deemed reasonable and customary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbef1512b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9841/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification of conflict by Head Start agency to regional office","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In prescribing procedures for the mediation described in subsection (a)(4), the Secretary shall specify—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbef1512c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9841/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date by which a Head Start agency engaged in a conflict described in subsection (a)(4) will notify the appropriate regional office of the Department of the conflict; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbef1512d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9841/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a reasonable period for the mediation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbef1512e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9841/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timeline for administrative hearing","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall also specify—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbef1512f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9841/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a timeline for an administrative hearing, if necessary, on an adverse action; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbef15130-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9841/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a timeline by which the person conducting the administrative hearing shall issue a decision based on the hearing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbef15131-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9841/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of designation not stayed upon appeal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In any case in which a termination, reduction, or suspension of financial assistance under this subchapter is upheld in an administrative hearing under this section, such termination, reduction, or suspension shall not be stayed pending any judicial appeal of such administrative decision.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbef15132-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9841/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of alternative agency by Indian tribe","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbef15133-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9841/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall by regulation specify a process by which an Indian tribe may identify and establish an alternative agency, and request that the alternative agency be designated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s9836"},"text":"section 9836 of this title","children":[],"tail":" as the Head Start agency providing services to the tribe, if—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbef15134-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9841/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary terminates financial assistance under this section to the only agency that was receiving financial assistance to provide Head Start services to the Indian tribe; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbef15135-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9841/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the tribe would otherwise be precluded from providing such services to the members of the tribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbef15136-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9841/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The regulation required by this subsection shall prohibit such designation of an alternative agency that includes an employee who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbef15137-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9841/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" served on the administrative staff or program staff of the agency described in paragraph (1)(A); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbef15138-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9841/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" was responsible for a deficiency that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbef15139-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9841/e/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" relates to the performance standards or financial management standards described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s9836a/a/1"},"text":"section 9836a(a)(1) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbef1513a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9841/e/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was the basis for the termination of financial assistance described in paragraph (1)(A);","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"as determined by the Secretary after providing the notice and opportunity described in subsection (a)(3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbef1513b-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35/tVI/s646"},"text":"Pub. L. 97–35, title VI, § 646","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/504"},"text":"95 Stat. 504","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/501/tI/s115"},"text":"Pub. L. 101–501, title I, § 115","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-03"},"text":"Nov. 3, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1232"},"text":"104 Stat. 1232","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/252/tI/s113"},"text":"Pub. L. 103–252, title I, § 113","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-05-18"},"text":"May 18, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/641"},"text":"108 Stat. 641","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/134/s16"},"text":"Pub. L. 110–134, § 16","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-12"},"text":"Dec. 12, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1421"},"text":"121 Stat. 1421","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbef1513c-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbef1513d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbef1513e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2007—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/134/s16/1"},"text":"Pub. L. 110–134, § 16(1)","children":[],"tail":", struck out “procedures to assure that” after “prescribe” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1), (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/134/s16/2"},"text":"Pub. L. 110–134, § 16(2)","children":[],"tail":", inserted “procedures to assure that” after the par. designation."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3) to (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/134/s16/3"},"text":"Pub. L. 110–134, § 16(3)","children":[],"tail":", added pars. (3) to (6) and struck out former pars. (3) and (4) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) financial assistance under this subchapter shall not be terminated or reduced, an application for refunding shall not be denied, and a suspension of financial assistance shall not be continued for longer than 30 days, unless the recipient has been afforded reasonable notice and opportunity for a full and fair hearing; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(4) the Secretary shall develop and publish procedures (including mediation procedures) to be used in order to—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) resolve in a timely manner conflicts potentially leading to adverse action between—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(i) recipients of financial assistance under this subchapter; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(ii) delegate agencies or Head Start Parent Policy Councils; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) avoid the need for an administrative hearing on an adverse action.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/252/s113/a"},"text":"Pub. L. 103–252, § 113(a)","children":[],"tail":", added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b) to (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/252/s113/b"},"text":"Pub. L. 103–252, § 113(b)","children":[],"tail":", added subsecs. (b) to (e) and struck out former subsec. (b) which read as follows: “The Secretary may not prescribe any procedure that would modify the operation of section 1303.21 or 1303.33, or any of subdivisions (a) through (f) of section 1303.35, of title 45 of the Code of Federal Regulations as in effect on "},{"tag":"date","attrib":{"date":"1990-04-01"},"text":"April 1, 1990","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/501/s115/1"},"text":"Pub. L. 101–501, § 115(1)","children":[],"tail":", (2), designated existing provisions as subsec. (a) and inserted “or reduced” after “terminated” in par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/501/s115/3"},"text":"Pub. L. 101–501, § 115(3)","children":[],"tail":", added subsec. (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbef1513f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbef15140-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/252"},"text":"Pub. L. 103–252","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1994-05-18"},"text":"May 18, 1994","children":[],"tail":", but not applicable to Head Start agencies and other recipients of financial assistance under the Head Start Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s9831"},"text":"42 U.S.C. 9831","children":[],"tail":" et seq.) until "},{"tag":"date","attrib":{"date":"1994-10-01"},"text":"Oct. 1, 1994","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/252/s127"},"text":"section 127 of Pub. L. 103–252","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s9832"},"text":"section 9832 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbef15141-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1990 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by section 115(1), (2) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/501"},"text":"Pub. L. 101–501","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1990-10-01"},"text":"Oct. 1, 1990","children":[],"tail":", and amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/101/501/s115/3"},"text":"section 115(3) of Pub. L. 101–501","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1990-04-01"},"text":"Apr. 1, 1990","children":[],"tail":", see section 1001(a), (b)(2) of "},{"tag":"ref","attrib":{"href":"/us/pl/101/501"},"text":"Pub. L. 101–501","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s8621"},"text":"section 8621 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
