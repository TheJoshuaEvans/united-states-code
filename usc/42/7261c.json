{"tag":"section","attrib":{"id":"idbdfe1761-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7261c"},"text":null,"children":[{"tag":"num","attrib":{"value":"7261c"},"text":"§ 7261c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technology partnerships ombudsman","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbdfe1762-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7261c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment of ombudsman","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Energy shall direct the director of each national laboratory of the Department of Energy, and may direct the director of each facility under the jurisdiction of the Department of Energy, to appoint a technology partnership ombudsman to hear and help resolve complaints from outside organizations regarding the policies and actions of each such laboratory or facility with respect to technology partnerships (including cooperative research and development agreements), patents, and technology licensing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdfe1763-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7261c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An ombudsman appointed under subsection (a) shall be a senior official of the national laboratory or facility who is not involved in day-to-day technology partnerships, patents, or technology licensing, or, if appointed from outside the laboratory or facility, function as such a senior official.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdfe1764-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7261c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each ombudsman appointed under subsection (a) shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbdfe1765-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7261c/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serve as the focal point for assisting the public and industry in resolving complaints and disputes with the national laboratory or facility regarding technology partnerships, patents, and technology licensing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdfe1766-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7261c/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote the use of collaborative alternative dispute resolution techniques such as mediation to facilitate the speedy and low-cost resolution of complaints and disputes, when appropriate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdfe1767-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7261c/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" report quarterly on the number and nature of complaints and disputes raised, along with the ombudsman’s assessment of their resolution, consistent with the protection of confidential and sensitive information, to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbdfe1768-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7261c/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbdfe1769-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7261c/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Administrator for Nuclear Security;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbdfe176a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7261c/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Director of the Office of Dispute Resolution of the Department of Energy; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbdfe176b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7261c/c/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the employees of the Department responsible for the administration of the contract for the operation of each national laboratory or facility that is a subject of the report, for consideration in the administration and review of that contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbdfe176c-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/404/s11"},"text":"Pub. L. 106–404, § 11","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-01"},"text":"Nov. 1, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1749"},"text":"114 Stat. 1749","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbdfe176d-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbdfe176e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbdfe176f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Technology Transfer Commercialization Act of 2000, and not as part of the Department of Energy Organization Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
