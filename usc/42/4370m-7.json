{"tag":"section","attrib":{"id":"idbcd1a598-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370m–7"},"text":null,"children":[{"tag":"num","attrib":{"value":"4370m–7"},"text":"§ 4370m–7.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbcd1a599-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370m–7/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports to Congress","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbcd1a59a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370m–7/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Executive Director annual report","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbcd1a59b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370m–7/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than April 15 of each year for 10 years beginning on ","children":[{"tag":"date","attrib":{"date":"2021-11-15"},"text":"November 15, 2021","children":[],"tail":", the Executive Director shall submit to Congress a report detailing the progress accomplished under this subchapter during the previous fiscal year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcd1a59c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370m–7/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Opportunity to include comments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each councilmember, with input from the respective agency CERPO, shall have the opportunity to include comments concerning the performance of the agency in the report described in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcd1a59d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370m–7/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quarterly agency performance report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Executive Director shall submit to Congress a quarterly report evaluating agency compliance with the provisions of this subchapter, which shall include a description of the implementation and adherence of each agency to the coordinated project plan and permitting timetable requirements under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4370m–2/c"},"text":"section 4370m–2(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcd1a59e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370m–7/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agency best practices report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than April 15 of each year, each participating agency and lead agency shall submit to Congress and the Director of the Office of Management and Budget a report assessing the performance of the agency in implementing the best practices described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4370m–1/c/2/B"},"text":"section 4370m–1(c)(2)(B) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcd1a59f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370m–7/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Comptroller general report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 3 years after ","children":[{"tag":"date","attrib":{"date":"2015-12-04"},"text":"December 4, 2015","children":[],"tail":", the Comptroller General of the United States shall submit to Congress a report that describes—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbcd1a5a0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370m–7/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" agency progress in making improvements consistent with the best practices issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4370m–1/c/2/B"},"text":"section 4370m–1(c)(2)(B) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcd1a5a1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370m–7/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" agency compliance with the performance schedules established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4370m–1/c/1/C"},"text":"section 4370m–1(c)(1)(C) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbcd1a5a2-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/dD/tXLI/s41008"},"text":"Pub. L. 114–94, div. D, title XLI, § 41008","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1760"},"text":"129 Stat. 1760","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/dG/tVIII/s70801/f"},"text":"Pub. L. 117–58, div. G, title VIII, § 70801(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1293"},"text":"135 Stat. 1293","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbcd1a5a3-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbcd1a5a4-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbcd1a5a5-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Fixing America’s Surface Transportation Act, also known as the FAST Act, and not as part of the National Environmental Policy Act of 1969 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbcd1a5a6-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":" added subsec. (a) and struck out former subsec. (a) which required, for a period of 10 years beginning on "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":", Executive Director to submit annual reports to Congress on progress accomplished under this subchapter during previous fiscal year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
