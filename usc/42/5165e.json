{"tag":"section","attrib":{"id":"idbd120ac9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5165e"},"text":null,"children":[{"tag":"num","attrib":{"value":"5165e"},"text":"§ 5165e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Integrated plan for administrative cost reduction","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd120aca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5165e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 365 days after ","children":[{"tag":"date","attrib":{"date":"2016-02-29"},"text":"February 29, 2016","children":[],"tail":", the Administrator shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd120acb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5165e/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" develop and implement an integrated plan to control and reduce administrative costs for major disasters, which shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd120acc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5165e/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" steps the Agency will take to reduce administrative costs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd120acd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5165e/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" milestones needed for accomplishing the reduction of administrative costs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd120ace-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5165e/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" strategic goals for the average annual percentage of administrative costs of major disasters for each fiscal year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd120acf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5165e/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the assignment of clear roles and responsibilities, including the designation of officials responsible for monitoring and measuring performance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd120ad0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5165e/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a timetable for implementation;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd120ad1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5165e/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compare the costs and benefits of tracking the administrative cost data for major disasters by the public assistance, individual assistance, hazard mitigation, and mission assignment programs, and if feasible, track this information; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd120ad2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5165e/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" clarify Agency guidance and minimum documentation requirements for a direct administrative cost claimed by a grantee or subgrantee of a public assistance grant program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd120ad3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5165e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional update","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"2016-02-29"},"text":"February 29, 2016","children":[],"tail":", the Administrator shall brief the Committee on Homeland Security and Governmental Affairs of the Senate and the Committee on Transportation and Infrastructure of the House of Representatives on the plan required to be developed under subsection (a)(1)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd147ad4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5165e/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Updates","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Administrator modifies the plan or the timetable under subsection (a), the Administrator shall submit to the Committee on Homeland Security and Governmental Affairs of the Senate and the Committee on Transportation and Infrastructure of the House of Representatives a report notifying Congress of the modification, which shall include the details of the modification.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd147ad5-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/132/s3"},"text":"Pub. L. 114–132, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-29"},"text":"Feb. 29, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/294"},"text":"130 Stat. 294","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd147ad6-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd147ad7-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbd147ad8-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Directing Dollars to Disaster Relief Act of 2015, and not as part of the Robert T. Stafford Disaster Relief and Emergency Assistance Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbd147ad9-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbd147ada-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Reporting Requirement","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/132/s4"},"text":"Pub. L. 114–132, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-29"},"text":"Feb. 29, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/294"},"text":"130 Stat. 294","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/132/s4"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than November 30 of each year for 7 years beginning on the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2016-02-29"},"text":"Feb. 29, 2016","children":[],"tail":"], the Administrator shall submit to Committee on Homeland Security and Governmental Affairs of the Senate and the Committee on Transportation and Infrastructure of the House of Representatives a report on the development and implementation of the integrated plan required under section 3 ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5165e"},"text":"42 U.S.C. 5165e","children":[],"tail":"] for the previous fiscal year."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report Updates.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Three year update","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 3 years after the date on which the Administrator submits a report under subsection (a), the Administrator shall submit an updated report for the previous 3-fiscal-year period.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Five year update","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 5 years after the date on which the Administrator submits a report under subsection (a), the Administrator shall submit an updated report for the previous 5-fiscal-year period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contents of Reports","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each report required under subsections (a) and (b) shall contain, at a minimum—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total amount spent on administrative costs for the fiscal year period for which the report is being submitted;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the average annual percentage of administrative costs for the fiscal year period for which the report is being submitted;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of the effectiveness of the plan developed under section 3(a)(1) [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5165e/a/1"},"text":"42 U.S.C. 5165e(a)(1)","children":[],"tail":"];"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an analysis of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether the Agency is achieving the strategic goals established under section 3(a)(1)(C) [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5165e/a/1/C"},"text":"42 U.S.C. 5165e(a)(1)(C)","children":[],"tail":"]; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of the Agency not achieving such strategic goals, what is preventing the Agency from doing so;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any actions the Agency has identified as useful in improving upon and reaching the goals for administrative costs established under section 3(a)(1)(C); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"“(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any data described in section 3(a)(2) [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5165e/a/2"},"text":"42 U.S.C. 5165e(a)(2)","children":[],"tail":"], if the Agency determines it is feasible to track such data."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Public Availability","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 30 days after the date on which the Administrator submits a report to Congress under this section, the Administrator shall make the report publicly available on the website of the Agency.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idbd147adb-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/132/s2"},"text":"Pub. L. 114–132, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-29"},"text":"Feb. 29, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/293"},"text":"130 Stat. 293","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/132/s2"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“In this Act [see Short Title of 2016 Amendment note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5121"},"text":"section 5121 of this title","children":[],"tail":"]—"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term ‘administrative cost’—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means a cost incurred by the Agency in support of the delivery of disaster assistance for a major disaster; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not include a cost incurred by a grantee or subgrantee;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term ‘Administrator’ means the Administrator of the Agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term ‘Agency’ means the Federal Emergency Management Agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term ‘direct administrative cost’ means a cost incurred by a grantee or subgrantee of a program authorized by the Robert T. Stafford Disaster Relief and Emergency Assistance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5121"},"text":"42 U.S.C. 5121","children":[],"tail":" et seq.) that can be identified separately and assigned to a specific project;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term ‘hazard mitigation program’ means the hazard mitigation grant program authorized under section 404 of the Robert T. Stafford Disaster Relief and Emergency Assistance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5170c"},"text":"42 U.S.C. 5170c","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"“(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term ‘individual assistance program’ means the individual assistance grant program authorized under sections 408, 410, 415, 416, 426, and 502(a) of the Robert T. Stafford Disaster Relief and Emergency Assistance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5174"},"text":"42 U.S.C. 5174","children":[],"tail":", 5177, 5182, 5183, 5189d, and 5192(a));"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"“(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term ‘major disaster’ means a major disaster declared by the President under section 401 of the Robert T. Stafford Disaster Relief and Emergency Assistance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5170"},"text":"42 U.S.C. 5170","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"“(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term ‘mission assignment’ has the meaning given the term in section 641 of the Post-Katrina Emergency Management Reform Act of 2006 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s741"},"text":"6 U.S.C. 741","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"“(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term ‘public assistance program’ means the public assistance grant program authorized under sections 403(a)(3), 406, 418, 419, 428, and 502(a) of the Robert T. Stafford Disaster Relief and Emergency Assistance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5170b/a/3"},"text":"42 U.S.C. 5170b(a)(3)","children":[],"tail":", 5172, 5185, 5186, 5189f, and 5192(a)).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
