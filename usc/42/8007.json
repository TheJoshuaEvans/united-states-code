{"tag":"section","attrib":{"id":"idbe77b414-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8007"},"text":null,"children":[{"tag":"num","attrib":{"value":"8007"},"text":"§ 8007.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation of applications and programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbe77b415-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8007/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application evaluations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In evaluating applications for assistance under this chapter, the Secretary shall consider—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe77b416-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8007/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the types and priorities of the basic services proposed to be provided, and the relationship of such proposal to the needs and characteristics of the eligible residents of the projects where the services are to be provided;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe77b417-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8007/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how quickly services will be established following approval of the application;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe77b418-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8007/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the degree to which local social services are adequate for the purpose of assisting eligible project residents to maintain independent living and avoid unnecessary institutionalization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe77b419-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8007/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the professional qualifications of the members of the professional assessment committee; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe77b41a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8007/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reasonableness of fee schedules established for each congregate service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe77b41b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8007/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program evaluations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In evaluating programs receiving assistance under this chapter, the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe77b41c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8007/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish procedures for the review and evaluation of the performance of nonprofit corporations and public housing agencies receiving assistance under this chapter, including provisions for the submission of an annual report, by each such nonprofit corporation and public housing agency, which evaluates the impact and effectiveness of its congregate services program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe77b41d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8007/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" publish annually and submit to the Congress, a report on and evaluation of the impact and effectiveness of congregate services programs assisted under this chapter. Such report and evaluation shall be based, in part, on the evaluations required to be submitted pursuant to paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe77b41e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8007/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe77b41f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8007/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall contract with a university or qualified research institution to produce a report—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbe77b420-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8007/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" documenting the number of elderly living in federally assisted housing at risk of institutionalization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe77b421-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8007/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" studying and comparing alternative delivery systems in the States, including the congregate housing services program, to provide services to older persons in assisted congregate housing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe77b422-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8007/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assessing existing and potential financial resources at the Federal, State, and local levels for the support of congregate housing services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe77b423-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8007/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" making legislative recommendations as to the feasibility of permitting State housing agencies and other appropriate State agencies to participate and operate the program on a matching grant basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe77b424-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8007/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall submit the report to the Congress not later than ","children":[{"tag":"date","attrib":{"date":"1988-09-30"},"text":"September 30, 1988","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbe77b425-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/557/tIV/s408"},"text":"Pub. L. 95–557, title IV, § 408","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-31"},"text":"Oct. 31, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2108"},"text":"92 Stat. 2108","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/181/tI"},"text":"Pub. L. 98–181, title I","children":[],"tail":" [title II, § 224(a)], "},{"tag":"date","attrib":{"date":"1983-11-30"},"text":"Nov. 30, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/1191"},"text":"97 Stat. 1191","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/242/tI/s163/b"},"text":"Pub. L. 100–242, title I, § 163(b)","children":[],"tail":", (c), "},{"tag":"date","attrib":{"date":"1988-02-05"},"text":"Feb. 5, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1860"},"text":"101 Stat. 1860","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbe77b426-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbe77b427-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbe77b428-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/242"},"text":"Pub. L. 100–242","children":[],"tail":" added subsec. (c) and struck out former subsec. (c) which required Secretary to prepare and submit a report to Congress evaluating the congregate housing services program, not later than "},{"tag":"date","attrib":{"date":"1984-03-15"},"text":"March 15, 1984","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/181"},"text":"Pub. L. 98–181","children":[],"tail":" added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbe77b429-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbe77b42a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Reporting Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For termination, effective ","children":[{"tag":"date","attrib":{"date":"2000-05-15"},"text":"May 15, 2000","children":[],"tail":", of provisions in subsec. (b)(2) of this section relating to submitting the annually published report to Congress, see "},{"tag":"ref","attrib":{"href":"/us/pl/104/66/s3003"},"text":"section 3003 of Pub. L. 104–66","children":[],"tail":", as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1113"},"text":"section 1113 of Title 31","children":[],"tail":", Money and Finance, and the 8th item on page 106 of House Document No. 103–7."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
