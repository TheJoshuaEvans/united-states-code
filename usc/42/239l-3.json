{"tag":"section","attrib":{"id":"idb489e529-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s239l–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"239l–3"},"text":"§ 239l–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Beginning with fiscal year 2010, the Secretary shall transfer from the Public Health and Social Services Emergency Fund such sums as may be necessary to carry out this part.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb489e52a-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title II, § 274, as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tV/s5315"},"text":"Pub. L. 111–148, title V, § 5315","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/642"},"text":"124 Stat. 642","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb489e52b-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb489e52c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb489e52d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Transfer of Appropriated Funds","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/10/dB/tVIII/s1828"},"text":"Pub. L. 112–10, div. B, title VIII, § 1828","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-04-15"},"text":"Apr. 15, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/162"},"text":"125 Stat. 162","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/10/dB/tVIII/s1828"},"text":"“Hereafter, no funds appropriated by this division or by any previous or subsequent Act shall be available for transfer under section 274 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s239"},"text":"42 U.S.C. 239","children":[],"tail":null},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"–3] of the PHS Act [Public Health Service Act].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
