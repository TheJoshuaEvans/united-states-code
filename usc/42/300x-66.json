{"tag":"section","attrib":{"id":"idb6705864-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–66"},"text":null,"children":[{"tag":"num","attrib":{"value":"300x–66"},"text":"§ 300x–66.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Services for individuals with co-occurring disorders","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"States may use funds available for treatment under sections 300x and 300x–21 of this title to treat persons with co-occurring substance use disorders and mental disorders as long as funds available under such sections are used for the purposes for which they were authorized by law and can be tracked for accounting purposes.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb6705865-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XIX, § 1956, as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/310/dB/tXXXIV/s3407"},"text":"Pub. L. 106–310, div. B, title XXXIV, § 3407","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-17"},"text":"Oct. 17, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1222"},"text":"114 Stat. 1222","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dFF/tI/s1241/a/13"},"text":"Pub. L. 117–328, div. FF, title I, § 1241(a)(13)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5678"},"text":"136 Stat. 5678","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb6705866-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb6705867-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb6705868-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328"},"text":"Pub. L. 117–328","children":[],"tail":" substituted “substance use disorders” for “substance abuse”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
