{"tag":"section","attrib":{"id":"idbbb38b91-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1997"},"text":null,"children":[{"tag":"num","attrib":{"value":"1997"},"text":"§ 1997.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbbb38b92-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1997/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “institution” means any facility or institution—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbbb38b93-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1997/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which is owned, operated, or managed by, or provides services on behalf of any State or political subdivision of a State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbbb38b94-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1997/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" which is—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbbb38b95-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1997/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for persons who are mentally ill, disabled, or retarded, or chronically ill or handicapped;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbbb38b96-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1997/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a jail, prison, or other correctional facility;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbbb38b97-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1997/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a pretrial detention facility;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbbb38b98-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1997/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for juveniles—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbbb38b99-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1997/1/B/iv/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" held awaiting trial;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbbb38b9a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1997/1/B/iv/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" residing in such facility or institution for purposes of receiving care or treatment; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbbb38b9b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1997/1/B/iv/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" residing for any State purpose in such facility or institution (other than a residential facility providing only elementary or secondary education that is not an institution in which reside juveniles who are adjudicated delinquent, in need of supervision, neglected, placed in State custody, mentally ill or disabled, mentally retarded, or chronically ill or handicapped); or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbbb38b9c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1997/1/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing skilled nursing, intermediate or long-term care, or custodial or residential care.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbb38b9d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1997/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Privately owned and operated facilities shall not be deemed “institutions” under this subchapter if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbbb38b9e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1997/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the licensing of such facility by the State constitutes the sole nexus between such facility and such State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbbb38b9f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1997/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the receipt by such facility, on behalf of persons residing in such facility, of payments under title XVI, XVIII [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1381"},"text":"42 U.S.C. 1381","children":[],"tail":" et seq., 1395 et seq.], or under a State plan approved under title XIX ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1396"},"text":"42 U.S.C. 1396","children":[],"tail":" et seq.], of the Social Security Act, constitutes the sole nexus between such facility and such State; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbbb38ba0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1997/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the licensing of such facility by the State, and the receipt by such facility, on behalf of persons residing in such facility, of payments under title XVI, XVIII [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1381"},"text":"42 U.S.C. 1381","children":[],"tail":" et seq., 1395 et seq.], or under a State plan approved under title XIX ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1396"},"text":"42 U.S.C. 1396","children":[],"tail":" et seq.], of the Social Security Act, constitutes the sole nexus between such facility and such State;"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbb38ba1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1997/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “person” means an individual, a trust or estate, a partnership, an association, or a corporation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbb38ba2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1997/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “State” means any of the several States, the District of Columbia, the Commonwealth of Puerto Rico, or any of the territories and possessions of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbb38ba3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1997/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “legislative days” means any calendar day on which either House of Congress is in session.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbbb38ba4-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/247/s2"},"text":"Pub. L. 96–247, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-05-23"},"text":"May 23, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/349"},"text":"94 Stat. 349","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbbb38ba5-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbbb38ba6-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbbb38ba7-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Social Security Act, referred to in par. (2)(B), (C), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"act Aug. 14, 1935, ch. 531","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/620"},"text":"49 Stat. 620","children":[],"tail":". Titles XVI, XVIII, and XIX of the Social Security Act are classified generally to subchapters XVI (§ 1381 et seq.), XVIII (§ 1395 et seq.), and XIX (§ 1396 et seq.) of chapter 7 of this title, respectively. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1305"},"text":"section 1305 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbbb38ba8-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"idbbb38ba9-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/96/247/s1"},"text":"Pub. L. 96–247, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-05-23"},"text":"May 23, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/349"},"text":"94 Stat. 349","children":[],"tail":", provided: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/96/247/s1"},"text":"“That this Act [enacting this subchapter] may be cited as the ‘Civil Rights of Institutionalized Persons Act’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
