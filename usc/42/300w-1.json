{"tag":"section","attrib":{"id":"idb66227a0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300w–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"300w–1"},"text":"§ 300w–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allotments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb66227a1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300w–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability based upon prior year distributions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb66227a2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300w–1/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" From the amounts appropriated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300w"},"text":"section 300w of this title","children":[],"tail":" for any fiscal year and available for allotment under this subsection, the Secretary shall allot to each State an amount which bears the same ratio to the available amounts for that fiscal year as the amounts provided by the Secretary under the provisions of law listed in paragraph (2) to the State and entities in the State for fiscal year 1981 bore to the total amount appropriated for such provisions of law for fiscal year 1981."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb66227a3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300w–1/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The provisions of law referred to in paragraph (1) are the following provisions of law as in effect on ","children":[{"tag":"date","attrib":{"date":"1981-09-30"},"text":"September 30, 1981","children":[],"tail":":"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb66227a4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300w–1/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The authority for grants under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s247b"},"text":"section 247b of this title","children":[],"tail":" for preventive health service programs for the control of rodents."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb66227a5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300w–1/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The authority for grants under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s247b"},"text":"section 247b of this title","children":[],"tail":" for establishing and maintaining community and school-based fluoridation programs."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb66227a6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300w–1/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The authority for grants under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s247b"},"text":"section 247b of this title","children":[],"tail":" for preventive health service programs for hypertension."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb66227a7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300w–1/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Sections 247b–1 ","children":[{"tag":"ref","attrib":{"idref":"fn002383"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002383"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" and 247b–2 of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb66227a8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300w–1/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 246(d) ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb66227a9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300w–1/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 255(a) ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb66227aa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300w–1/a/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Sections 300d–1,","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" 300d–2,"},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" and 300d–3 "},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb66227ab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300w–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Population","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"From the amount required to be made available under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300w/b"},"text":"section 300w(b) of this title","children":[],"tail":" for allotments under this subsection for any fiscal year, the Secretary shall make allotments to each State on the basis of the population of the State."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb66227ac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300w–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distribution of appropriated funds not allotted","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To the extent that all the funds appropriated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300w"},"text":"section 300w of this title","children":[],"tail":" for a fiscal year and available for allotment in such fiscal year are not otherwise allotted to States because—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb66227ad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300w–1/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one or more States have not submitted an application or description of activities in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300w–4"},"text":"section 300w–4 of this title","children":[],"tail":" for the fiscal year;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb66227ae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300w–1/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one or more States have notified the Secretary that they do not intend to use the full amount of their allotment; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb66227af-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300w–1/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" some State allotments are offset or repaid under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300w–5/b/3"},"text":"section 300w–5(b)(3) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"such excess shall be allotted among each of the remaining States in proportion to the amount otherwise allotted to such States for the fiscal year without regard to this subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb66227b0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300w–1/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distributions to Indian tribes","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb66227b1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300w–1/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If the Secretary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb66227b2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300w–1/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" receives a request from the governing body of an Indian tribe or tribal organization within any State that funds under this part be provided directly by the Secretary to such tribe or organization, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb66227b3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300w–1/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determines that the members of such tribe or tribal organization would be better served by means of grants made directly by the Secretary under this part,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the Secretary shall reserve from amounts which would otherwise be allotted to such State under subsection (a) for the fiscal year the amount determined under paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb66227b4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300w–1/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall reserve for the purpose of paragraph (1) from amounts that would otherwise be allotted to such State under subsection (a) an amount equal to the amount which bears the same ratio to the State’s allotment for the fiscal year involved as the total amount provided or allotted for fiscal year 1981 by the Secretary to such tribe or tribal organization under the provisions of law referred to in subsection (a) bore to the total amount provided or allotted for such fiscal year by the Secretary to the State and entities (including Indian tribes and tribal organizations) in the State under such provisions of law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb66227b5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300w–1/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amount reserved by the Secretary on the basis of a determination under this subsection shall be granted to the Indian tribe or tribal organization serving the individuals for whom such a determination has been made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb66227b6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300w–1/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In order for an Indian tribe or tribal organization to be eligible for a grant for a fiscal year under this subsection, it shall submit to the Secretary a plan for such fiscal year which meets such criteria as the Secretary may prescribe.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb66227b7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300w–1/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The terms “Indian tribe” and “tribal organization” have the same meaning given such terms in section 5304(b) and (c) ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of title 25."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb66227b8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300w–1/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report on equitable distribution of available funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall conduct a study for the purpose of devising a formula for the equitable distribution of funds available for allotment to the States under this section. In conducting the study, the Secretary shall take into account—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb66227b9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300w–1/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the financial resources of the various States,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb66227ba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300w–1/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the populations of the States, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb66227bb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300w–1/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other factor which the Secretary may consider appropriate.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Before ","children":[{"tag":"date","attrib":{"date":"1982-06-30"},"text":"June 30, 1982","children":[],"tail":", the Secretary shall submit a report to the Congress respecting the development of a formula and make such recommendations as the Secretary may deem appropriate in order to ensure the most equitable distribution of funds under allotments under this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb66227bc-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XIX, § 1902, as added "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tIX/s901"},"text":"Pub. L. 97–35, title IX, § 901","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/535"},"text":"95 Stat. 535","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb66227bd-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb66227be-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attri