{"tag":"section","attrib":{"id":"idb4dd5cb3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254"},"text":null,"children":[{"tag":"num","attrib":{"value":"254"},"text":"§ 254.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interdepartmental work","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing contained in this part shall affect the authority of the Service to furnish any materials, supplies, or equipment, or perform any work of services, requested in accordance with sections 1535 and 1536 of title 31, or the authority of any other executive department to furnish any materials, supplies, or equipment, or perform any work or services, requested by the Department of Health and Human Services for the Service in accordance with that section.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb4dd5cb4-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title III, § 327, "},{"tag":"ref","attrib":{"href":"/us/stat/58/697"},"text":"58 Stat. 697","children":[],"tail":"; 1953 Reorg. Plan No. 1, §§ 5, 8, eff. "},{"tag":"date","attrib":{"date":"1953-04-11"},"text":"Apr. 11, 1953","children":[],"tail":", 18 F.R. 2053, "},{"tag":"ref","attrib":{"href":"/us/stat/67/631"},"text":"67 Stat. 631","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/88/tV/s509/b"},"text":"Pub. L. 96–88, title V, § 509(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-10-17"},"text":"Oct. 17, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/695"},"text":"93 Stat. 695","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb4dd5cb5-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb4dd5cb6-3