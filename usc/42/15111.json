{"tag":"section","attrib":{"id":"idbfdfd013-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15111"},"text":null,"children":[{"tag":"num","attrib":{"value":"15111"},"text":"§ 15111.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfdfd014-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15111/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" direct support workers, especially young adults, have played essential roles in providing the support needed by individuals with developmental disabilities and expanding community options for those individuals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfdfd015-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15111/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" 4 factors have contributed to a decrease in the available pool of direct support workers, specifically—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfdfd016-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15111/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the small population of individuals who are age 18 through 25, an age group that has been attracted to direct support work in the past;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfdfd017-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15111/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the rapid expansion of the service sector, which attracts individuals who previously would have elected to pursue employment as direct support workers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfdfd018-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15111/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the failure of wages in the human services sector to keep pace with wages in other service sectors; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfdfd019-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15111/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the lack of quality training and career advancement opportunities available to direct support workers; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfdfd01a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15111/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" individuals with developmental disabilities benefit from assistance from direct support workers who are well trained, and benefit from receiving services from professionals who have spent time as direct support workers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfdfd01b-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/402/tIII/s301"},"text":"Pub. L. 106–402, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1734"},"text":"114 Stat. 1734","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
