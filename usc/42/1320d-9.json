{"tag":"section","attrib":{"id":"idb860422f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–9"},"text":null,"children":[{"tag":"num","attrib":{"value":"1320d–9"},"text":"§ 1320d–9.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of HIPAA regulations to genetic information","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8604230-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–9/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall revise the HIPAA privacy regulation (as defined in subsection (b)) so it is consistent with the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8604231-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–9/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Genetic information shall be treated as health information described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320d/4/B"},"text":"section 1320d(4)(B) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8604232-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–9/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The use or disclosure by a covered entity that is a group health plan, health insurance issuer that issues health insurance coverage, or issuer of a medicare supplemental policy of protected health information that is genetic information about an individual for underwriting purposes under the group health plan, health insurance coverage, or medicare supplemental policy shall not be a permitted use or disclosure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8604233-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–9/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8604234-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–9/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Genetic information; genetic test; family member","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “genetic information”, “genetic test”, and “family member” have the meanings given such terms in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300gg–91"},"text":"section 300gg–91 of this title","children":[],"tail":", as amended by the Genetic Information Nondiscrimination Act of 2007."},{"tag":"ref","attrib":{"idref":"fn002731"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002731"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8604235-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–9/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Group health plan; health insurance coverage; medicare supplemental policy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “group health plan” and “health insurance coverage” have the meanings given such terms under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300gg–91"},"text":"section 300gg–91 of this title","children":[],"tail":", and the term “medicare supplemental policy” has the meaning given such term in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395ss/g"},"text":"section 1395ss(g) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8604236-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–9/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" HIPAA privacy regulation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “HIPAA privacy regulation” means the regulations promulgated by the Secretary under this part and section 264 of the Health Insurance Portability and Accountability Act of 1996 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320d–2"},"text":"42 U.S.C. 1320d–2","children":[],"tail":" note)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8604237-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–9/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Underwriting purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “underwriting purposes” means, with respect to a group health plan, health insurance coverage, or a medicare supplemental policy—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8604238-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–9/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rules for, or determination of, eligibility (including enrollment and continued eligibility) for, or determination of, benefits under the plan, coverage, or policy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8604239-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–9/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the computation of premium or contribution amounts under the plan, coverage, or policy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb860423a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–9/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the application of any pre-existing condition exclusion under the plan, coverage, or policy; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb860423b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–9/b/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other activities related to the creation, renewal, or replacement of a contract of health insurance or health benefits.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb860423c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–9/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedure","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The revisions under subsection (a) shall be made by notice in the Federal Register published not later than 60 days after ","children":[{"tag":"date","attrib":{"date":"2008-05-21"},"text":"May 21, 2008","children":[],"tail":", and shall be effective upon publication, without opportunity for any prior public comment, but may be revised, consistent with this section, after opportunity for public comment."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb860423d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–9/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to any other sanctions or remedies that may be available under law, a covered entity that is a group health plan, health insurance issuer, or issuer of a medicare supplemental policy and that violates the HIPAA privacy regulation (as revised under subsection (a) or otherwise) with respect to the use or disclosure of genetic information shall be subject to the penalties described in sections 1320d–5 and 1320d–6 of this title in the same manner and to the same extent that such penalties apply to violations of this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb860423e-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title XI, § 1180, as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/233/tI/s105/a"},"text":"Pub. L. 110–233, title I, § 105(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-21"},"text":"May 21, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/903"},"text":"122 Stat. 903","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb860423f-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8604240-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb8604241-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Genetic Information Nondiscrimination Act of 2007, referred to in subsec. (b)(1), probably means the Genetic Information Nondiscrimination Act of 2008, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/233"},"text":"Pub. L. 110–233","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-21"},"text":"May 21, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/881"},"text":"122 Stat. 881","children":[],"tail":". For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2000ff"},"text":"section 2000ff of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 264 of the Health Insurance Portability and Accountability Act of 1996, referred to in subsec. (b)(3), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/191/s264"},"text":"section 264 of Pub. L. 104–191","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320d–2"},"text":"section 1320d–2 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8604242-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb8604243-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/233/tI/s105/b/2"},"text":"Pub. L. 110–233, title I, § 105(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-21"},"text":"May 21, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/905"},"text":"122 Stat. 905","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/233/tI/s105/b/2"},"text":"“The amendment made by subsection (a) [enacting this section] shall take effect on the date that is 1 year after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2008-05-21"},"text":"May 21, 2008","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb8604244-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/233/tI/s105/b/1"},"text":"Pub. L. 110–233, title I, § 105(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-21"},"text":"May 21, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/905"},"text":"122 Stat. 905","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/233/tI/s105/b/1"},"text":"“Not later than 12 months after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2008-05-21"},"text":"May 21, 2008","children":[],"tail":"], the Secretary of Health and Human Services shall issue final regulations to carry out the revision required by section 1180(a) of the Social Security Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320d–9/a"},"text":"42 U.S.C. 1320d–9(a)","children":[],"tail":"], as added by subsection (a). The Secretary has the sole authority to promulgate such regulations, but shall promulgate such regulations in consultation with the Secretaries of Labor and the Treasury.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
