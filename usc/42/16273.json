{"tag":"section","attrib":{"id":"idc0013a8b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16273"},"text":null,"children":[{"tag":"num","attrib":{"value":"16273"},"text":"§ 16273.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fuel cycle research, development, demonstration, and commercial application","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc0013a8c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16273/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Used nuclear fuel research, development, demonstration, and commercial application","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0013a8d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16273/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall conduct an advanced fuel cycle research, development, demonstration, and commercial application program to improve fuel cycle performance, minimize environmental and public health and safety impacts, and support a variety of options for used nuclear fuel storage, use, and disposal, including advanced nuclear reactor and non-reactor concepts (such as radioisotope power systems), which may include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0013a8e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16273/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" dry cask storage;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0013a8f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16273/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consolidated interim storage;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0013a90-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16273/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deep geological storage and disposal, including mined repository, and other technologies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0013a91-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16273/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" used nuclear fuel transportation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0013a92-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16273/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" integrated waste management systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0013a93-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16273/a/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" vitrification;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0013a94-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16273/a/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fuel recycling and transmutation technologies, including advanced reprocessing technologies such as electrochemical and molten salt technologies, and advanced redox extraction technologies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0013a95-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16273/a/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advanced materials to be used in subparagraphs (A) through (G); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0013a96-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16273/a/1/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other areas as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0013a97-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16273/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the program under this subsection, the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0013a98-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16273/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure all activities and designs incorporate state of the art safeguards technologies and techniques to reduce risk of proliferation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0013a99-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16273/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consult with the Administrator of the National Nuclear Security Administration to integrate safeguards and security by design;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0013a9a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16273/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consider the potential benefits and other impacts of those activities for civilian nuclear applications, environmental health and safety, and national security, including consideration of public consent; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0013a9b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16273/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consider the economic viability of all activities and designs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0013a9c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16273/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to the Secretary to carry out the program under this subsection $60,000,000 for each of fiscal years 2021 through 2025.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0013a9d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16273/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advanced fuels","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0013a9e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16273/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall conduct an advanced fuels research, development, demonstration, and commercial application program on next-generation light water reactor and advanced reactor fuels that demonstrate the potential for improved—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0013a9f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16273/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" performance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0013aa0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16273/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accident tolerance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0013aa1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16273/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" proliferation resistance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0013aa2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16273/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use of resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0013aa3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16273/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" environmental impact; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0013aa4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16273/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" economics.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0013aa5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16273/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out the program under this subsection, the Secretary shall focus on the development of advanced technology fuels, including fabrication techniques, that offer improved accident-tolerance and economic performance with the goal of initial commercial application by ","children":[{"tag":"date","attrib":{"date":"2025-12-31"},"text":"December 31, 2025","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0013aa6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16273/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days ","children":[{"tag":"date","attrib":{"date":"2020-12-27"},"text":"December 27, 2020","children":[],"tail":", the Secretary shall submit to the Committee on Science, Space, and Technology of the House of Representatives and the Committee on Energy and Natural Resources of the Senate a report that describes how the technologies and concepts studied under this program would impact reactor economics, the fuel cycle, operations, safety, proliferation, and the environment."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0013aa7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16273/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to the Secretary to carry out the program under this subsection $125,000,000 for each of fiscal years 2021 through 2025.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc0013aa8-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tIX/s953"},"text":"Pub. L. 109–58, title IX, § 953","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/886"},"text":"119 Stat. 886","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/248/s2/c"},"text":"Pub. L. 115–248, § 2(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-09-28"},"text":"Sept. 28, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3155"},"text":"132 Stat. 3155","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dZ/tII/s2003/b"},"text":"Pub. L. 116–260, div. Z, title II, § 2003(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2462"},"text":"134 Stat. 2462","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc0013aa9-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc0013aaa-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc0013aab-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Pub. L. 116–260","children":[],"tail":" amended section generally. Prior to amendment, section related to advanced fuel cycle initiative."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/248"},"text":"Pub. L. 115–248","children":[],"tail":" struck out “, acting through the Director of the Office of Nuclear Energy, Science and Technology,” after “The Secretary”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
