{"tag":"section","attrib":{"id":"idb5c26569-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ff"},"text":null,"children":[{"tag":"num","attrib":{"value":"290ff"},"text":"§ 290ff.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Comprehensive community mental health services for children with serious emotional disturbances","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5c2656a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ff/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants to certain public entities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5c2656b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ff/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Director of the Center for Mental Health Services, shall make grants to public entities for the purpose of providing comprehensive community mental health services to children with a serious emotional disturbance, which may include efforts to identify and serve children at risk.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5c2656c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ff/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Public entity” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this part, the term “public entity” means any State, any political subdivision of a State, and any Indian tribe or tribal organization (as defined in section 5304(b) and section 5304(c) ","children":[{"tag":"ref","attrib":{"idref":"fn002245"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002245"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of title 25)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5c2656d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ff/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Considerations in making grants","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5c2656e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ff/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement of status as grantee under part B of subchapter XVII","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may make a grant under subsection (a) to a public entity only if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5c2656f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ff/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a public entity that is a State, the State is a grantee under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x"},"text":"section 300x of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5c26570-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ff/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a public entity that is a political subdivision of a State, the State in which the political subdivision is located is such a grantee; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5c26571-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ff/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a public entity that is an Indian tribe or tribal organization, the State in which the tribe or tribal organization is located is such a grantee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5c26572-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ff/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement of status as medicaid provider","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5c26573-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ff/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subject to subparagraph (B), the Secretary may make a grant under subsection (a) only if, in the case of any service under such subsection that is covered in the State plan approved under title XIX of the Social Security Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1396"},"text":"42 U.S.C. 1396","children":[],"tail":" et seq.] for the State involved—"}],"tail":null},{"tag":"clause","attrib":{"id":"idb5c26574-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ff/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the public entity involved will provide the service directly, and the entity has entered into a participation agreement under the State plan and is qualified to receive payments under such plan; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5c26575-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ff/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the public entity will enter into an agreement with an organization under which the organization will provide the service, and the organization has entered into such a participation agreement and is qualified to receive such payments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5c26576-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ff/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb5c26577-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ff/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of an organization making an agreement under subparagraph (A)(ii) regarding the provision of services under subsection (a), the requirement established in such subparagraph regarding a participation agreement shall be waived by the Secretary if the organization does not, in providing health or mental health services, impose a charge or accept reimbursement available from any third-party payor, including reimbursement under any insurance policy or under any Federal or State health benefits program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5c26578-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ff/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A determination by the Secretary of whether an organization referred to in clause (i) meets the criteria for a waiver under such clause shall be made without regard to whether the organization accepts voluntary donations regarding the provision of services to the public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5c26579-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ff/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain considerations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In making grants under subsection (a), the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5c2657a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ff/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" equitably allocate such assistance among the principal geographic regions of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5c2657b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ff/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consider the extent to which the public entity involved has a need for the grant; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5c2657c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ff/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of any public entity that is a political subdivision of a State or that is an Indian tribe or tribal organization—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb5c2657d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ff/b/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall consider any comments regarding the application of the entity for such a grant that are received by the Secretary from the State in which the entity is located; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5c2657e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ff/b/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall give special consideration to the entity if the State agrees to provide a portion of the non-Federal contributions required in subsection (c) regarding such a grant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5c2657f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ff/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matching funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5c26580-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ff/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A funding agreement for a grant under subsection (a) is that the public entity involved will, with respect to the costs to be incurred by the entity in carrying out the purpose described in such subsection, make available (directly or through donations from public or private entities) non-Federal contributions toward such costs in an amount that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5c4ae71-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ff/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the first fiscal year for which the entity receives payments from a grant under such subsection, is not less than $1 for each $3 of Federal funds provided in the grant;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5c4ae72-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ff/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for any second or third such fiscal year, is not less than $1 for each $3 of Federal funds provided in the grant;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5c4ae73-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ff/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for any fourth such fiscal year, is not less than $1 for each $1 of Federal funds provided in the grant; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5c4ae74-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ff/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for any fifth and sixth such fiscal year,","children":[{"tag":"ref","attrib":{"idref":"fn002246"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002246"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be “years,”."}],"tail":" is not less than $2 for each $1 of Federal funds provided in the grant."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5c4ae75-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ff/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of amount contributed","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5c4ae76-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ff/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Non-Federal contributions required in paragraph (1) may be in cash or in kind, fairly evaluated, including plant, equipment, or services. Amounts provided by the Federal Government, or services assisted or subsidized to any significant extent by the Federal Government, may not be included in determining the amount of such non-Federal contributions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5c4ae77-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ff/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In making a determination of the amount of non-Federal contributions for purposes of subparagraph (A), the Secretary may include only non-Federal contributions in excess of the average amount of non-Federal contributions made by the public entity involved toward the purpose described in subsection (a) for the 2-year period preceding the first fiscal year for which the entity receives a grant under such section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5c4ae78-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title V, § 561, as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/321/tI/s119"},"text":"Pub. L. 102–321, title I, § 119","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-10"},"text":"July 10, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/349"},"text":"106 Stat. 349","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/43/tXX/s2017/1"},"text":"Pub. L. 103–43, title XX, § 2017(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-06-10"},"text":"June 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/218"},"text":"107 Stat. 218","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/310/dB/tXXXI/s3105/a"},"text":"Pub. L. 106–310, div. B, title XXXI, § 3105(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-17"},"text":"Oct. 17, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1175"},"text":"114 Stat. 1175","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/255/dB/tX/s10001/a"},"text":"Pub. L. 114–255, div. B, title X, § 10001(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-13"},"text":"Dec. 13, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1262"},"text":"130 Stat. 1262","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb5c4ae79-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb5c4ae7a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb5c4ae7b-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Subsections (b) and (c) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304"},"text":"section 5304 of title 25","children":[],"tail":", referred to in subsec. (a)(2), do not contain definitions of the terms “Indian tribe” and “tribal organization”. However, such terms are defined elsewhere in that section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Social Security Act, referred to in subsec. (b)(2)(A), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"act Aug. 14, 1935, ch. 531","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/620"},"text":"49 Stat. 620","children":[],"tail":". Title XIX of the Act is classified generally to subchapter XIX (§ 1396 et seq.) of chapter 7 of this title. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1305"},"text":"section 1305 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb5c4ae7c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 290ff, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373/tV/s561"},"text":"act July 1, 1944, ch. 373, title V, § 561","children":[],"tail":", as added "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tII/s2081/a"},"text":"Pub. L. 100–690, title II, § 2081(a)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4216"},"text":"102 Stat. 4216","children":[],"tail":", which related to action by National Institute on Drug Abuse and States concerning military facilities, was renumbered section 513 of act "},{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", by "},{"tag":"ref","attrib":{"href":"/us/pl/102/321"},"text":"Pub. L. 102–321","children":[],"tail":" and transferred to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s290bb–6"},"text":"section 290bb–6 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb5c4ae7d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255"},"text":"Pub. L. 114–255","children":[],"tail":" inserted “, which may include efforts to identify and serve children at risk” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (c)(1)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/310"},"text":"Pub. L. 106–310","children":[],"tail":" substituted “fifth and sixth such fiscal year” for “fifth such fiscal year”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/43/s2017/1/A"},"text":"Pub. L. 103–43, § 2017(1)(A)","children":[],"tail":", substituted “this part” for “this subpart”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(B), (C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/43/s2017/1/B"},"text":"Pub. L. 103–43, § 2017(1)(B)","children":[],"tail":", substituted “is such a grantee” for “is receiving such payments”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb5c4ae7e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb5c4ae7f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1992-10-01"},"text":"Oct. 1, 1992","children":[],"tail":", with provision for programs providing financial assistance, see section 801(c), (d) of "},{"tag":"ref","attrib":{"href":"/us/pl/102/321"},"text":"Pub. L. 102–321","children":[],"tail":", set out as an Effective Date of 1992 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s236"},"text":"section 236 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb5c4ae80-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Current Grantees","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/310/dB/tXXXI/s3105/e"},"text":"Pub. L. 106–310, div. B, title XXXI, § 3105(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-17"},"text":"Oct. 17, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1175"},"text":"114 Stat. 1175","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/310/dB/tXXXI/s3105/e"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Entities with active grants under section 561 of the Public Health Service Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s290ff"},"text":"42 U.S.C. 290ff","children":[],"tail":") on the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2000-10-17"},"text":"Oct. 17, 2000","children":[],"tail":"] shall be eligible to receive a sixth year of funding under the grant in an amount not to exceed the amount that such grantee received in the fifth year of funding under such grant. Such sixth year may be funded without requiring peer and Advisory Council review as required under section 504 of such Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s290aa–3"},"text":"42 U.S.C. 290aa–3","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Paragraph (1) shall apply with respect to a grantee only if the grantee agrees to comply with the provisions of section 561 as amended by subsection (a).”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
