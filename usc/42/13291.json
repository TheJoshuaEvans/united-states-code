{"tag":"section","attrib":{"id":"idbfb9aa94-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13291"},"text":null,"children":[{"tag":"num","attrib":{"value":"13291"},"text":"§ 13291.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General authority","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfb9aa95-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13291/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall undertake a program with one or more non-Federal persons, including fleet operators, for cost-shared research, development, demonstration, or commercial application of an infrastructure and support systems program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfb9aa96-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13291/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A non-Federal person shall be eligible to receive financial assistance under this part only if such person demonstrates, to the satisfaction of the Secretary, that the person will conduct a substantial portion of activities under the project in the United States using domestic labor and materials.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfb9aa97-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13291/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Activities under this part shall be coordinated with activities under part A.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfb9aa98-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/tVI/s621"},"text":"Pub. L. 102–486, title VI, § 621","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2904"},"text":"106 Stat. 2904","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
