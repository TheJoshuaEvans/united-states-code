{"tag":"section","attrib":{"id":"idbc82ea18-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3513a"},"text":null,"children":[{"tag":"num","attrib":{"value":"3513a"},"text":"§ 3513a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Working capital fund; availability for centralized personnel data collection and reporting and common regional administrative support services","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Working Capital Fund of the Department of Health and Human Services shall on and after ","children":[{"tag":"date","attrib":{"date":"1971-01-11"},"text":"January 11, 1971","children":[],"tail":", be available for expenses necessary for centralized personnel data collection and reporting and common regional administrative support services."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbc82ea19-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/667/tII"},"text":"Pub. L. 91–667, title II","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-01-11"},"text":"Jan. 11, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/2015"},"text":"84 Stat. 2015","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/88/tV/s509/b"},"text":"Pub. L. 96–88, title V, § 509(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-10-17"},"text":"Oct. 17, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/695"},"text":"93 Stat. 695","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc82ea1a-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc82ea1b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbc82ea1c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/667"},"text":"Pub. L. 91–667","children":[],"tail":", popularly known as the Department of Health, Education, and Welfare Appropriation Act, 1971."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3510"},"text":"section 3510 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbc82ea1d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idbc82ea1e-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Department of Health and Human Services” substituted in text for “Department of Health, Education, and Welfare” pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/88/s509/b"},"text":"section 509(b) of Pub. L. 96–88","children":[],"tail":", which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s3508/b"},"text":"section 3508(b) of Title 20","children":[],"tail":", Education."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
