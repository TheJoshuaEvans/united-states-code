{"tag":"section","attrib":{"id":"idbfc320b5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13456"},"text":null,"children":[{"tag":"num","attrib":{"value":"13456"},"text":"§ 13456.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Improving efficiency in energy-intensive industries","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfc320b6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13456/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretarial action","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, in accordance with sections 13541 and 13542 of this title, shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfc320b7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13456/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pursue a research, development, demonstration and commercial application program intended to improve energy efficiency and productivity in energy-intensive industries and industrial processes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc320b8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13456/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" undertake joint ventures to encourage the commercialization of technologies developed under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfc320b9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13456/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Joint ventures","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfc320ba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13456/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfc320bb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13456/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct a competitive solicitation for proposals from private firms and investors for such joint ventures under subsection (a)(2); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfc320bc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13456/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide financial assistance to at least five such joint ventures.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc320bd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13456/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The purpose of the joint ventures shall be to design, test, and demonstrate changes to industrial processes that will result in improved energy efficiency and productivity. The joint ventures may also demonstrate other improvements of benefit to such industries so long as demonstration of energy efficiency improvements is the principal objective of the joint venture.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc320be-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13456/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In evaluating proposals for financial assistance and joint ventures under this section, the Secretary shall consider—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfc320bf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13456/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether the activities conducted under this section improve the quality and energy efficiency of industries or industrial processes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfc320c0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13456/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the regional distribution of the energy-intensive industries and industrial processes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfc320c1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13456/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether the proposed joint venture project would be located in the region which has the energy-intensive industry and industrial processes that would benefit from the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfc320c2-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/tXXI/s2107"},"text":"Pub. L. 102–486, title XXI, § 2107","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3070"},"text":"106 Stat. 3070","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
