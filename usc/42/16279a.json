{"tag":"section","attrib":{"id":"idc0038491-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16279a"},"text":null,"children":[{"tag":"num","attrib":{"value":"16279a"},"text":"§ 16279a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advanced reactor demonstration program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc0038492-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16279a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Demonstration project defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purposes of this section, the term “demonstration project” means an advanced nuclear reactor operated in any manner, including as part of the power generation facilities of an electric utility system, for the purpose of demonstrating the suitability for commercial application of the advanced nuclear reactor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0038493-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16279a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall establish a program to advance the research, development, demonstration, and commercial application of domestic advanced, affordable, nuclear energy technologies by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0038494-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16279a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" demonstrating a variety of advanced nuclear reactor technologies, including those that could be used to produce—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0038495-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16279a/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" safer, emissions-free power at a competitive cost of electricity compared to other new energy generation technologies on ","children":[{"tag":"date","attrib":{"date":"2020-12-27"},"text":"December 27, 2020","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0038496-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16279a/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" heat for community heating, industrial purposes, heat storage, or synthetic fuel production;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0038497-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16279a/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" remote or off-grid energy supply; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0038498-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16279a/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" backup or mission-critical power supplies;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0038499-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16279a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying research areas that the private sector is unable or unwilling to undertake due to the cost of, or risks associated with, the research; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc003849a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16279a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" facilitating the access of the private sector—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc003849b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16279a/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to Federal research facilities and personnel; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc003849c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16279a/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the results of research relating to civil nuclear technology funded by the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc003849d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16279a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Demonstration projects","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out demonstration projects under the program established in subsection (b), the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc003849e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16279a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" include, as an evaluation criterion, diversity in designs for the advanced nuclear reactors demonstrated under this section, including designs using various—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc003849f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16279a/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" primary coolants;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00384a0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16279a/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fuel types and compositions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00384a1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16279a/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" neutron spectra;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00384a2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16279a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" consider, as evaluation criterions—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc00384a3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16279a/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the likelihood that the operating cost for future commercial units for each design implemented through a demonstration project under this subsection is cost-competitive in the applicable market, including those designs configured as integrated energy systems as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16272/c"},"text":"section 16272(c) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00384a4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16279a/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the technology readiness level of a proposed advanced nuclear reactor technology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00384a5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16279a/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the technical abilities and qualifications of teams desiring to demonstrate a proposed advanced nuclear reactor technology; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00384a6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16279a/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the capacity to meet cost-share requirements of the Department;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00384a7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16279a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" ensure that each evaluation of candidate technologies for the demonstration projects is completed through an external review of proposed designs, which review shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc00384a8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16279a/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" be conducted by a panel that includes not fewer than 1 representative that does not have a conflict of interest of each within the applicable market of the design of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc00384a9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16279a/c/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an electric utility;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc00384aa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16279a/c/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an entity that uses high-temperature process heat for manufacturing or industrial processing, such as a petrochemical or synthetic fuel company, a manufacturer of metals or chemicals, or a manufacturer of concrete;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc00384ab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16279a/c/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an expert from the investment community;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc00384ac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16279a/c/3/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a project management practitioner; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc00384ad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16279a/c/3/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an environmental health and safety expert; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00384ae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16279a/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include a review of each demonstration project under this subsection which shall include consideration of cost-competitiveness and other value streams, together with the technology readiness level, the technical abilities and qualifications of teams desiring to demonstrate a proposed advanced nuclear reactor technology, the capacity to meet cost-share requirements of the Department, if Federal funding is provided, and environmental impacts;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00384af-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16279a/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for federally funded demonstration projects, enter into cost-sharing agreements with private sector partners in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16352"},"text":"section 16352 of this title","children":[],"tail":" for the conduct of activities relating to the research, development, and demonstration of advanced nuclear reactor designs under the program;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00384b0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16279a/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" consult with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc00384b1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16279a/c/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" National Laboratories;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00384b2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16279a/c/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" institutions of higher education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00384b3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16279a/c/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" traditional end users (such as electric utilities);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00384b4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16279a/c/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" potential end users of new technologies (such as users of high-temperature process heat for manufacturing processing, including petrochemical or synthetic fuel companies, manufacturers of metals or chemicals, or manufacturers of concrete);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00384b5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16279a/c/5/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developers of advanced nuclear reactor technology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00384b6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16279a/c/5/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" environmental and public health and safety experts; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00384b7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16279a/c/5/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" non-proliferation experts;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00384b8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16279a/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" seek to ensure that the demonstration projects carried out under this section do not cause any delay in the progress of an advanced reactor project by private industry and the Department of Energy that is underway as of ","children":[{"tag":"date","attrib":{"date":"2020-12-27"},"text":"December 27, 2020","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00384b9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16279a/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish a streamlined approval process for expedited contracting between awardees and the Department;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00384ba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16279a/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify technical challenges to candidate technologies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00384bb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16279a/c/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" support near-term research and development to address the highest risk technical challenges to the successful demonstration of a selected advanced reactor technology, in accordance with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc00384bc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16279a/c/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" paragraph (8);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00384bd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16279a/c/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the research and development activities under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16272/b"},"text":"section 16272(b) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00384be-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16279a/c/9/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the research and development activities under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16278"},"text":"section 16278 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00384bf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16279a/c/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" establish such technology advisory working groups as the Secretary determines to be appropriate to advise the Secretary regarding the technical challenges identified under paragraph (8) and the scope of research and development programs to address the challenges, in accordance with paragraph (9), to be comprised of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc00384c0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16279a/c/10/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" private sector advanced nuclear reactor technology developers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00384c1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16279a/c/10/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" technical experts with respect to the relevant technologies at institutions of higher education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00384c2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16279a/c/10/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" technical experts at the National Laboratories;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00384c3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16279a/c/10/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" environmental and public health and safety experts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00384c4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16279a/c/10/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" non-proliferation experts; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00384c5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16279a/c/10/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other entities the Secretary determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc00384c6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16279a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Milestone-based demonstration projects","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may carry out demonstration projects under subsection (c) as a milestone-based demonstration project under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7256c"},"text":"section 7256c of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc00384c7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16279a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonduplication","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Entities may not receive funds under this program if receiving funds from another reactor demonstration program at the Department in the same fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc00384c8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16279a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated to the Secretary to carry out the program under this subsecti