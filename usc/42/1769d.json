{"tag":"section","attrib":{"id":"idbb6989e4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769d"},"text":null,"children":[{"tag":"num","attrib":{"value":"1769d"},"text":"§ 1769d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Childhood hunger research","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbb6989e5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research on causes and consequences of childhood hunger","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb6989e6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769d/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall conduct research on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbb6989e7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769d/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the causes of childhood hunger and food insecurity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb6989e8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769d/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the characteristics of households with childhood hunger and food insecurity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb6989e9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769d/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the consequences of childhood hunger and food insecurity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb6989ea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769d/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out research under paragraph (1), the Secretary may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbb6989eb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769d/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enter into competitively awarded contracts or cooperative agreements; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb6989ec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769d/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide grants to States or public or private agencies or organizations, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb6989ed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769d/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be eligible to enter into a contract or cooperative agreement or receive a grant under this subsection, a State or public or private agency or organization shall submit to the Secretary an application at such time, in such manner, and containing such information as the Secretary shall require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb6989ee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769d/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Areas of inquiry","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall design the research program to advance knowledge and understanding of information on the issues described in paragraph (1), such as—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbb6989ef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769d/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" economic, health, social, cultural, demographic, and other factors that contribute to childhood hunger or food insecurity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb6989f0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769d/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the geographic distribution of childhood hunger and food insecurity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb6989f1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769d/a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the extent to which—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbb6989f2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769d/a/4/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" existing Federal assistance programs, including title 26, reduce childhood hunger and food insecurity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbb6989f3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769d/a/4/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" childhood hunger and food insecurity persist due to—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbb6989f4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769d/a/4/C/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" gaps in program coverage;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbb6989f5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769d/a/4/C/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the inability of potential participants to access programs; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbb6989f6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769d/a/4/C/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the insufficiency of program benefits or services;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb6989f7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769d/a/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the public health and medical costs of childhood hunger and food insecurity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb6989f8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769d/a/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an estimate of the degree to which the Census Bureau measure of food insecurity underestimates childhood hunger and food insecurity because the Census Bureau excludes certain households, such as homeless, or other factors;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb6989f9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769d/a/4/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effects of childhood hunger on child development, well-being, and educational attainment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb6989fa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769d/a/4/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other critical outcomes as are determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb6989fb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769d/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbb6989fc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769d/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On ","children":[{"tag":"date","attrib":{"date":"2012-10-01"},"text":"October 1, 2012","children":[],"tail":", out of any funds in the Treasury not otherwise appropriated, the Secretary of the Treasury shall transfer to the Secretary to carry out this subsection $10,000,000, to remain available until expended."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb6989fd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769d/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Receipt and acceptance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall be entitled to receive, shall accept, and shall use to carry out this subsection the funds transferred under subparagraph (A), without further appropriation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb6989fe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Demonstration projects to end childhood hunger","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb6989ff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769d/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbb698a00-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769d/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Child","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “child” means a person under the age of 18.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb698a01-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769d/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supplemental nutrition assistance program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “supplemental nutrition assistance program” means the supplemental nutrition assistance program established under the Food and Nutrition Act of 2008 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2011"},"text":"7 U.S.C. 2011","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb698a02-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769d/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Under such terms and conditions as are established by the Secretary, the Secretary shall carry out demonstration projects that test innovative strategies to end childhood hunger, including alternative models for service delivery and benefit levels that promote the reduction or elimination of childhood hunger and food insecurity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb698a03-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769d/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Projects","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Demonstration projects carried out under this subsection may include projects that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbb698a04-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769d/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhance benefits provided under the supplemental nutrition assistance program for eligible households with children;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb698a05-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769d/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhance benefits or provide for innovative program delivery models in the school meals, afterschool snack, and child and adult care food programs under this chapter and the Child Nutrition Act of 1966 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1771"},"text":"42 U.S.C. 1771","children":[],"tail":" et seq.); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb698a06-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769d/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" target Federal, State, or local assistance, including emergency housing or family preservation services, at households with children who are experiencing hunger or food insecurity, to the extent permitted by the legal authority establishing those assistance programs and services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb698a07-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769d/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbb698a08-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769d/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Demonstration projects","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbb698a09-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769d/b/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out this subsection, the Secretary may enter into competitively awarded contracts or cooperative agreements with, or provide grants to, public or private organizations or agencies (as determined by the Secretary), for use in accordance with demonstration projects that meet the purposes of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbb698a0a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769d/b/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"At least 1 demonstration project funded under this subsection shall be carried out on an Indian reservation in a rural area with a service population with a prevalence of diabetes that exceeds 15 percent, as determined by the Director of the Indian Health Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb698a0b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769d/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be eligible to receive a contract, cooperative agreement, or grant under this subsection, an organization or agency shall submit to the Secretary an application at such time, in such manner, and containing such information as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb698a0c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769d/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Demonstration projects shall be selected based on publicly disseminated criteria that may include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbb698a0d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769d/b/4/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an identification of a low-income target group that reflects individuals experiencing hunger or food insecurity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbb698a0e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769d/b/4/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a commitment to a demonstration project that allows for a rigorous outcome evaluation as described in paragraph (6);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbb698a0f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769d/b/4/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a focus on innovative strategies to reduce the risk of childhood hunger or provide a significant improvement to the food security status of households with children; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbb698a10-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769d/b/4/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other criteria as are determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb698a11-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769d/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In determining the range of projects and defining selection criteria under this subsection, the Secretary shall consult with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbb698a12-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769d/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Health and Human Services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb698a13-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769d/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Labor; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb698a14-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769d/b/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Housing and Urban Development.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb698a15-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769d/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation and reporting","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbb698a16-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769d/b/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Independent evaluation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall provide for an independent evaluation of each demonstration project carried out under this subsection that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbb698a17-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769d/b/6/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" measures the impact of each demonstration project on appropriate participation, food security, nutrition, and associated behavioral outcomes among participating households; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbb698a18-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769d/b/6/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" uses rigorous experimental designs and methodologies, particularly random assignment or other methods that are capable of producing scientifically valid information regarding which activities are effective in reducing the prevalence or preventing the incidence of food insecurity and hunger in the community, especially among children.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb698a19-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769d/b/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2013-12-31"},"text":"December 31, 2013","children":[],"tail":" and each December 31 thereafter until the date on which the last evaluation under subparagraph (A) is completed, the Secretary shall—"}],"tail":null},{"tag":"clause","attrib":{"id":"idbb698a1a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769d/b/6/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" submit to the Committee on Agriculture and the Committee on Education and Labor of the House of Representatives and the Committee on Agriculture, Nutrition, and Forestry of the Senate a report that includes a description of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbb698a1b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769d/b/6/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the status of each demonstration project; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbb698a1c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769d/b/6/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the results of any evaluations of the demonstration projects completed during the previous fiscal year; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbb698a1d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769d/b/6/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that the evaluation results are shared broadly to inform policy makers, service providers, other partners, and the public in order to promote the wide use of successful strategies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb698a1e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769d/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbb698a1f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769d/b/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On ","children":[{"tag":"date","attrib":{"date":"2012-10-01"},"text":"October 1, 2012","children":[],"tail":", out of any funds in the Treasury not otherwise appropriated, the Secretary of the Treasury shall transfer to the Secretary to carry out this subsection $40,000,000, to remain available until "},{"tag":"date","attrib":{"date":"2017-09-30"},"text":"September 30, 2017","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb698a20-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769d/b/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Receipt and acceptance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall be entitled to receive, shall accept, and shall use to carry out this subsection the funds transferred under subparagraph (A), without further appropriation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb698a21-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769d/b/7/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbb698a22-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769d/b/7/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds made available under subparagraph (A) may be used to carry out this subsection, including to pay Federal costs associated with developing, soliciting, awarding, monitoring, evaluating, and disseminating the results of each demonstration project under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbb698a23-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769d/b/7/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian reservations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of amounts made available under subparagraph (A), the Secretary shall use a portion of the amounts to carry out research relating to hunger, obesity and type 2 diabetes on Indian reservations, including research to determine the manner in which Federal nutrition programs can help to overcome those problems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbb698a24-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769d/b/7/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2010-12-13"},"text":"December 13, 2010","children":[],"tail":", the Secretary shall submit to the Committee on Agriculture of the House of Representatives and the Committee on Agriculture, Nutrition, and Forestry of the Senate a report that—"}],"tail":null},{"tag":"subclause","attrib":{"id":"idbb698a25-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769d/b/7/C/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describes the manner in which Federal nutrition programs can help to overcome child hunger nutrition problems on Indian reservations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbb698a26-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769d/b/7/C/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contains proposed administrative and legislative recommendations to strengthen and streamline all relevant Department of Agriculture nutrition programs to reduce childhood hunger, obesity, and type 2 diabetes on Indian reservations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb698a27-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769d/b/7/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbb698a28-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769d/b/7/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No project may be funded under this subsection for more than 5 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbb698a29-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769d/b/7/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Project requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No project that makes use of, alters, or coordinates with the supplemental nutrition assistance program may be funded under this subsection unless the project is fully consistent with the project requirements described in section 17(b)(1)(B) of the Food and Nutrition Act of 2008 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2026/b/1/B"},"text":"7 U.S.C. 2026(b)(1)(B)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbb698a2a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769d/b/7/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hunger-free communities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No project may be funded under this subsection that receives funding under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7517"},"text":"section 7517 of title 7","children":[],"tail":"."},{"tag":"ref","attrib":{"idref":"fn003200"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003200"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbb698a2b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769d/b/7/D/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other benefits","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Funds made available under this subsection may not be used for any project in a manner that is inconsistent with—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbb698a2c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769d/b/7/D/iv/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbb698a2d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769d/b/7/D/iv/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Child Nutrition Act of 1966 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1771"},"text":"42 U.S.C. 1771","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbb698a2e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769d/b/7/D/iv/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Food and Nutrition Act of 2008 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2011"},"text":"7 U.S.C. 2011","children":[],"tail":" et seq.); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbb698a2f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769d/b/7/D/iv/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Emergency Food Assistance Act of 1983 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7501"},"text":"7 U.S.C. 7501","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbb698a30-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-06-04/ch281/s23"},"text":"June 4, 1946, ch. 281, § 23","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/296/tI/s141"},"text":"Pub. L. 111–296, title I, § 141","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-13"},"text":"Dec. 13, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3206"},"text":"124 Stat. 3206","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbb698a31-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbb698a32-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbb698a33-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7517"},"text":"Section 7517 of title 7","children":[],"tail":", referred to in subsec. (b)(7)(D)(iii), was amended generally by "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tIV/s4208"},"text":"Pub. L. 113–79, title IV, § 4208","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/826"},"text":"128 Stat. 826","children":[],"tail":", and now relates to the Gus Schumacher nutrition incentive program."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Food and Nutrition Act of 2008, referred to in subsec. (b)(1)(B), (7)(D)(iv)(III), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/525"},"text":"Pub. L. 88–525","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-08-31"},"text":"Aug. 31, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/703"},"text":"78 Stat. 703","children":[],"tail":", which is classified generally to chapter 51 (§ 2011 et seq.) of Title 7, Agriculture. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2011"},"text":"section 2011 of Title 7","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Child Nutrition Act of 1966, referred to in subsec. (b)(3)(B), (7)(D)(iv)(II), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/642"},"text":"Pub. L. 89–642","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-10-11"},"text":"Oct. 11, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/885"},"text":"80 Stat. 885","children":[],"tail":", which is classified generally to chapter 13A (§ 1771 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1771"},"text":"section 1771 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Emergency Food Assistance Act of 1983, referred to in subsec. (b)(7)(D)(iv)(IV), is title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/8"},"text":"Pub. L. 98–8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-03-24"},"text":"Mar. 24, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/35"},"text":"97 Stat. 35","children":[],"tail":", which is classified principally to chapter 102 (§ 7501 et seq.) of Title 7, Agriculture. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s7501"},"text":"section 7501 of Title 7","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbb698a34-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1769d, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-06-04/ch281/s23"},"text":"act June 4, 1946, ch. 281, § 23","children":[],"tail":", as added "},{"tag":"date","attrib":{"date":"1989-11-10"},"text":"Nov. 10, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/101/147/tI/s111"},"text":"Pub. L. 101–147, title I, § 111","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/890"},"text":"103 Stat. 890","children":[],"tail":", directed Secretary to provide each appropriate State agency with information on income eligibility for free or reduced price meals under each program established under this chapter and the Child Nutrition Act of 1966, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/104/193/tVII/s711"},"text":"Pub. L. 104–193, title VII, § 711","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-22"},"text":"Aug. 22, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2301"},"text":"110 Stat. 2301","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbb698a35-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idbb698a36-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Education and Labor of House of Representatives changed to Committee on Education and the Workforce of House of Representatives by House Resolution No. 5, One Hundred Eighteenth Congress, ","children":[{"tag":"date","attrib":{"date":"2023-01-09"},"text":"Jan. 9, 2023","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbb698a37-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2010-10-01"},"text":"Oct. 1, 2010","children":[],"tail":", except as otherwise specifically provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/296/s445"},"text":"section 445 of Pub. L. 111–296","children":[],"tail":", set out as an Effective Date of 2010 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1751"},"text":"section 1751 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
