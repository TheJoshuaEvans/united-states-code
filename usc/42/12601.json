{"tag":"section","attrib":{"id":"idbf7e007e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12601"},"text":null,"children":[{"tag":"num","attrib":{"value":"12601"},"text":"§ 12601.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of the National Service Trust","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf7e007f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12601/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is established in the Treasury of the United States an account to be known as the National Service Trust. The Trust shall consist of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf7e0080-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12601/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" from the amounts appropriated to the Corporation and made available to carry out this division, such amounts as the Corporation may designate to be available for the payment of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf7e0081-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12601/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" national service educational awards, summer of service educational awards, and silver scholar educational awards; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf7e0082-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12601/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" interest expenses pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12604/e"},"text":"section 12604(e) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf7e0083-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12601/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any amounts received by the Corporation as gifts, bequests, devises, or otherwise pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12651g/a/2"},"text":"section 12651g(a)(2) of this title","children":[],"tail":", if the terms of such donations direct that the donated amounts be deposited in the National Service Trust;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf7e0084-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12601/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any amounts recovered by the Corporation pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12602a"},"text":"section 12602a of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf7e0085-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12601/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the interest on, and proceeds from the sale or redemption of, any obligations held by the Trust.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf7e0086-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12601/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investment of Trust","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It shall be the duty of the Secretary of the Treasury to invest in full the amounts appropriated to the Trust. Except as otherwise expressly provided in instruments concerning a gift, bequest, devise, or other donation and agreed to by the Corporation, such investments may be made only in interest-bearing obligations of the United States or in obligations guaranteed as to both principal and interest by the United States. For such purpose, such obligations may be acquired on original issue at the issue price or by purchase of outstanding obligations at the market price. Any obligation acquired by the Trust may be sold by the Secretary at the market price.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf7e0087-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12601/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expenditures from Trust","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Amounts in the Trust shall be available, to the extent provided for in advance by appropriation, for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf7e0088-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12601/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" payments of national service educational awards, summer of service educational awards, and silver scholar educational awards in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12604"},"text":"section 12604 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf7e0089-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12601/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" payments of interest in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12604/e"},"text":"section 12604(e) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf7e008a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12601/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports to the authorizing committees on receipts and expenditures","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than March 1 of each year, the Corporation shall submit a report to the authorizing committees on the financial status of the Trust during the preceding fiscal year. Such report shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf7e008b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12601/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specify the amount deposited to the Trust from the most recent appropriation to the Corporation, the amount received by the Corporation as gifts, bequests, devises, or otherwise pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12651g/a/2"},"text":"section 12651g(a)(2) of this title","children":[],"tail":" during the period covered by the report, and any amounts obtained by the Trust pursuant to subsection (a)(3);"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf7e008c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12601/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify the number of individuals who are currently performing service to qualify, or have qualified, for national service educational awards, summer of service educational awards, or silver scholar awards;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf7e008d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12601/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" identify the number of individuals whose expectation to receive national service educational awards, summer of service educational awards, or silver scholar awards during the period covered by the report—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf7e008e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12601/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has been reduced pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12603/c"},"text":"section 12603(c) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf7e008f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12601/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has lapsed pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12602/d"},"text":"section 12602(d) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf7e0090-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12601/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" estimate the number of additional approved national service positions, additional approved summer of service positions, and additional approved silver scholar positions that the Corporation will be able to make available on the basis of any accumulated surplus in the Trust above the amount required to provide national service educational awards, summer of service educational awards, or silver scholar awards to individuals identified under paragraph (2), including any amounts available as a result of the circumstances referred to in paragraph (3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf7e0091-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/610/tI/s145"},"text":"Pub. L. 101–610, title I, § 145","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/tI/s102/a"},"text":"Pub. L. 103–82, title I, § 102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-09-21"},"text":"Sept. 21, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/816"},"text":"107 Stat. 816","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/13/tI/s1401/b"},"text":"Pub. L. 111–13, title I, § 1401(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-04-21"},"text":"Apr. 21, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1512"},"text":"123 Stat. 1512","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf7e0092-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf7e0093-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbf7e0094-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 12601, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/610/tI/s156"},"text":"Pub. L. 101–610, title I, § 156","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3156"},"text":"104 Stat. 3156","children":[],"tail":", related to authority of Commission on National and Community Service to make grants to States or Indian tribes for creation of innovative volunteer and community service programs, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/s104/a"},"text":"Pub. L. 103–82, § 104(a)","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/610/s145"},"text":"section 145 of Pub. L. 101–610","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12575"},"text":"section 12575 of this title","children":[],"tail":" prior to the general amendment of subtitle D of title I of "},{"tag":"ref","attrib":{"href":"/us/pl/101/610"},"text":"Pub. L. 101–610","children":[],"tail":" [former part D of this subchapter] by "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/s102/a"},"text":"Pub. L. 103–82, § 102(a)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbf7e0095-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2009—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1401/b/1/A/i"},"text":"Pub. L. 111–13, § 1401(b)(1)(A)(i)","children":[],"tail":", struck out “pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12681/a/2"},"text":"section 12681(a)(2) of this title","children":[],"tail":"” after “carry out this division” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1401/b/1/A/ii"},"text":"Pub. L. 111–13, § 1401(b)(1)(A)(ii)","children":[],"tail":", inserted “, summer of service educational awards, and silver scholar educational awards” after “national service educational awards”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1401/b/1/B/i"},"text":"Pub. L. 111–13, § 1401(b)(1)(B)(i)","children":[],"tail":", substituted “pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12651g/a/2"},"text":"section 12651g(a)(2) of this title","children":[],"tail":", if the terms of such donations direct that the donated amounts be deposited in the National Service Trust” for “pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12651g/a/2"},"text":"section 12651g(a)(2) of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3), (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1401/b/1/B/ii"},"text":"Pub. L. 111–13, § 1401(b)(1)(B)(ii)","children":[],"tail":"–(D), added par. (3) and redesignated former par. (3) as (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1401/b/2"},"text":"Pub. L. 111–13, § 1401(b)(2)","children":[],"tail":", substituted “for—” for “for payments of national service educational awards in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12604"},"text":"section 12604 of this title","children":[],"tail":".” and added pars. (1) and (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1401/b/3/A"},"text":"Pub. L. 111–13, § 1401(b)(3)(A)","children":[],"tail":", (B), substituted “the authorizing committees” for “Congress” in heading and “the authorizing committees” for “the Congress” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2), (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1401/b/3/C"},"text":"Pub. L. 111–13, § 1401(b)(3)(C)","children":[],"tail":", inserted “, summer of service educational awards, or silver scholar awards” after “national service educational awards”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1401/b/3/C"},"text":"Pub. L. 111–13, § 1401(b)(3)(C)","children":[],"tail":", (D), inserted “, additional approved summer of service positions, and additional approved silver scholar positions” after “additional approved national service positions”, struck out “under division C of this subchapter” after “make available”, and inserted “, summer of service educational awards, or silver scholar awards” after “national service educational awards”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbf7e0096-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbf7e0097-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2009 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13"},"text":"Pub. L. 111–13","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2009-10-01"},"text":"Oct. 1, 2009","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/111/13/s6101/a"},"text":"section 6101(a) of Pub. L. 111–13","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4950"},"text":"section 4950 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbf7e0098-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1993-10-01"},"text":"Oct. 1, 1993","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/s123"},"text":"section 123 of Pub. L. 103–82","children":[],"tail":", set out as an Effective Date of 1993 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1701"},"text":"section 1701 of Title 16","children":[],"tail":", Conservation."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbf7e0099-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Segal AmeriCorps Education Award","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/234/tVII/s7014"},"text":"Pub. L. 109–234, title VII, § 7014","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-06-15"},"text":"June 15, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/484"},"text":"120 Stat. 484","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/234/tVII/s7014"},"text":"“Any national service educational award described in subtitle D of title I of the National and Community Service Act of 1990 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12601"},"text":"42 U.S.C. 12601","children":[],"tail":" et seq.), made with funds appropriated to, funds transferred to, or interest accumulated in the National Service Trust, shall hereafter be known as a ‘Segal AmeriCorps Education Award’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
