{"tag":"section","attrib":{"id":"idbc534e28-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3029"},"text":null,"children":[{"tag":"num","attrib":{"value":"3029"},"text":"§ 3029.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments of grants or contracts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbc534e29-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3029/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advances or reimbursement; installments; assistance in development of State plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Payments of grants or contracts under this subchapter may be made (after necessary adjustments resulting from previously made overpayments or underpayments) in advance or by way of reimbursement, and in such installments, as the Assistant Secretary may determine. From a State’s allotment for a fiscal year which is available under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3028"},"text":"section 3028 of this title","children":[],"tail":" the Assistant Secretary may pay to a State which does not have a State plan approved under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3027"},"text":"section 3027 of this title","children":[],"tail":" such amounts as the Assistant Secretary deems appropriate for the purpose of assisting such State in developing a State plan."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc534e2a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3029/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matching funds; percentage limitation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc534e2b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3029/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For each fiscal year, not less than 25 percent of the non-Federal share of the total expenditures under the State plan which is required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3024/d"},"text":"section 3024(d) of this title","children":[],"tail":" shall be met from funds from State or local public sources."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc534e2c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3029/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Funds required to meet the non-Federal share required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3024/d/1/D"},"text":"section 3024(d)(1)(D) of this title","children":[],"tail":", in amounts exceeding 10 percent of the cost of the services specified in such "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3024/d/1/D"},"text":"section 3024(d)(1)(D) of this title","children":[],"tail":", shall be met from State sources."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc534e2d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3029/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reduction of State allotment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State’s allotment under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3024"},"text":"section 3024 of this title","children":[],"tail":" for a fiscal year shall be reduced by the percentage (if any) by which its expenditures for such year from State sources under its State plan approved under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3027"},"text":"section 3027 of this title","children":[],"tail":" are less than its average annual expenditures from such sources for the period of 3 fiscal years preceding such year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc534e2e-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/73/tIII/s309"},"text":"Pub. L. 89–73, title III, § 309","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/95/478/tI/s103/b"},"text":"Pub. L. 95–478, title I, § 103(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-18"},"text":"Oct. 18, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1532"},"text":"92 Stat. 1532","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/98/459/tIII/s309"},"text":"Pub. L. 98–459, title III, § 309","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-09"},"text":"Oct. 9, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1779"},"text":"98 Stat. 1779","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/175/tI/s139"},"text":"Pub. L. 100–175, title I, § 139","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-11-29"},"text":"Nov. 29, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/944"},"text":"101 Stat. 944","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/171/s3/a/13"},"text":"Pub. L. 103–171, § 3(a)(13)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-02"},"text":"Dec. 2, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1990"},"text":"107 Stat. 1990","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/365/tIII/s308"},"text":"Pub. L. 109–365, title III, § 308","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2545"},"text":"120 Stat. 2545","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc534e2f-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc534e30-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbc534e31-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 3029, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/73/tIII/s309"},"text":"Pub. L. 89–73, title III, § 309","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/93/351/s3"},"text":"Pub. L. 93–351, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-07-12"},"text":"July 12, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/357"},"text":"88 Stat. 357","children":[],"tail":", related to transportation projects, prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/95/478"},"text":"Pub. L. 95–478","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3026"},"text":"section 3026 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions similar to those comprising this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/73/tIII/s307"},"text":"Pub. L. 89–73, title III, § 307","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/93/29/tIII/s301"},"text":"Pub. L. 93–29, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-05-03"},"text":"May 3, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href"