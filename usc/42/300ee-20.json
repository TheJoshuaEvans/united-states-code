{"tag":"section","attrib":{"id":"idb68a977d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–20"},"text":null,"children":[{"tag":"num","attrib":{"value":"300ee–20"},"text":"§ 300ee–20.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance and provision by Secretary of supplies and services in lieu of grant funds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb68a977e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–20/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may provide training and technical assistance to States with respect to the planning, development, and operation of any program or service carried out pursuant to this part. The Secretary may provide such technical assistance directly or through grants or contracts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb68a977f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–20/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provision by Secretary of supplies and services in lieu of grant funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb68a9780-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–20/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Upon the request of a State receiving payments under this part, the Secretary may, subject to paragraph (2), provide supplies, equipment, and services for the purpose of aiding the State in carrying out such part and, for such purpose, may detail to the State any officer or employee of the Department of Health and Human Services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb68a9781-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–20/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" With respect to a request described in paragraph (1), the Secretary shall reduce the amount of payments under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ee–11/a"},"text":"section 300ee–11(a) of this title","children":[],"tail":" to the State by an amount equal to the costs of detailing personnel and the fair market value of any supplies, equipment, or services provided by the Secretary. The Secretary shall, for the payment of expenses incurred in complying with such request, expend the amounts withheld."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb68a9782-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XXV, formerly title XV, § 2510, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/607/tII/s221"},"text":"Pub. L. 100–607, title II, § 221","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-04"},"text":"Nov. 4, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3101"},"text":"102 Stat. 3101","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tII/s2619/g"},"text":"Pub. L. 100–690, title II, § 2619(g) [(h)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4243"},"text":"102 Stat. 4243","children":[],"tail":"; renumbered title XXV, "},{"tag":"ref","attrib":{"href":"/us/pl/101/93/s5/e/1"},"text":"Pub. L. 101–93, § 5(e)(1)","children":[],"tail":", "},{"tag":"dat