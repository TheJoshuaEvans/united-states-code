{"tag":"section","attrib":{"id":"idbc74b8b1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154"},"text":null,"children":[{"tag":"num","attrib":{"value":"3154"},"text":"§ 3154.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special impact areas","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbc74b8b2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On the application of an eligible recipient that is determined by the Secretary to be unable to comply with the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3162"},"text":"section 3162 of this title","children":[],"tail":", the Secretary may waive, in whole or in part, the requirements of "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3162"},"text":"section 3162 of this title","children":[],"tail":" and designate the area represented by the recipient as a special impact area."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc74b8b3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conditions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may make a designation under subsection (a) only after determining that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc74b8b4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the project will fulfill a pressing need of the area; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc74b8b5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the project will—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc74b8b6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be useful in alleviating or preventing conditions of excessive unemployment or underemployment; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc74b8b7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist in providing useful employment opportunities for the unemployed or underemployed residents in the area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc74b8b8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"At the time of the designation under subsection (a), the Secretary shall submit to the Committee on Environment and Public Works of the Senate and the Committee on Transportation and Infrastructure of the House of Representatives a written notice of the designation, including a justification for the designation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc74b8b9-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/136/tII/s214"},"text":"Pub. L. 89–136, title II, § 214","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/373/tII/s209/a"},"text":"Pub. L. 108–373, title II, § 209(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-27"},"text":"Oct. 27, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1763"},"text":"118 Stat. 1763","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
