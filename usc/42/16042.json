{"tag":"section","attrib":{"id":"idbff07186-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16042"},"text":null,"children":[{"tag":"num","attrib":{"value":"16042"},"text":"§ 16042.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Department of Homeland Security consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Before issuing a license for a utilization facility, the Nuclear Regulatory Commission shall consult with the Department of Homeland Security concerning the potential vulnerabilities of the location of the proposed facility to terrorist attack.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbff07187-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tVI/s657"},"text":"Pub. L. 109–58, title VI, § 657","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/814"},"text":"119 Stat. 814","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
