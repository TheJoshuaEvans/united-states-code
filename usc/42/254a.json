{"tag":"section","attrib":{"id":"idb4dd5cbc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254a"},"text":null,"children":[{"tag":"num","attrib":{"value":"254a"},"text":"§ 254a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sharing of medical care facilities and resources","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb4dd5cbd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4dd5cbe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “specialized health resources” means health care resources (whether equipment, space, or personnel) which, because of cost, limited availability, or unusual nature, are either unique in the health care community or are subject to maximum utilization only through mutual use;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4dfccbf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “hospital”, unless otherwise specified, includes (in addition to other hospitals) any Federal hospital.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4dfccc0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statement of purpose; agreements or arrangements; reciprocity; reimbursement; credits","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purpose of maintaining or improving the quality of care in Public Health Service facilities and to provide a professional environment therein which will help to attract and retain highly qualified and talented health personnel, to encourage mutually beneficial relationships between Public Health Service facilities and hospitals and other health facilities in the health care community, and to promote the full utilization of hospitals and other health facilities and resources, the Secretary may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4dfccc1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enter into agreements or arrangements with schools of medicine, schools of osteopathic medicine, and with other health professions schools, agencies, or institutions, for such interchange or cooperative use of facilities and services on a reciprocal or reimbursable basis, as will be of benefit to the training or research programs of the participating agencies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4dfccc2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enter into agreements or arrangements with hospitals and other health care facilities for the mutual use or the exchange of use of specialized health resources, and providing for reciprocal reimbursement.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Any reimbursement pursuant to any such agreement or arrangement shall be based on charges covering the reasonable cost of such utilization, including normal depreciation and amortization costs of equipment. Any proceeds to the Government under this subsection shall be credited to the applicable appropriation of the Public Health Service for the year in which such proceeds are received.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb4dfccc3-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title III, § 327A, formerly § 328, as added "},{"tag":"ref","attrib":{"href":"/us/pl/90/174/s7"},"text":"Pub. L. 90–174, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-12-05"},"text":"Dec. 5, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/539"},"text":"81 Stat. 539","children":[],"tail":"; renumbered § 327A, "},{"tag":"ref","attrib":{"href":"/us/pl/95/626/tI/s113/a/2"},"text":"Pub. L. 95–626, title I, § 113(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-10"},"text":"Nov. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3562"},"text":"92 Stat. 3562","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/607/tVI/s629/a/1"},"text":"Pub. L. 100–607, title VI, § 629(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-04"},"text":"Nov. 4, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3146"},"text":"102 Stat. 3146","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb4dfccc4-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb4dfccc5-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb4dfccc6-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/607"},"text":"Pub. L. 100–607","children":[],"tail":" inserted “schools of osteopathic medicine,” after “schools of medicine,” and “professions” after “health”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb4dfccc7-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb4dfccc8-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Availability of Appropriations for Expenses of Sharing Medical Care Facilities and Resources","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/394/tII/s204"},"text":"Pub. L. 102–394, title II, § 204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-06"},"text":"Oct. 6, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1811"},"text":"106 Stat. 1811","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/394/tII/s204"},"text":"“Funds advanced to the National Institutes of Health Management Fund from appropriations in this Act or subsequent Departments of Labor, Health and Human Services, and Education, and Related Agencies Appropriations Acts shall be available for the expenses of sharing medical care facilities and resources pursuant to section 327A of the Public Health Service Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s254a"},"text":"42 U.S.C. 254a","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Similar provisions were contained in the following prior appropriation acts:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/170/tII/s204"},"text":"Pub. L. 102–170, title II, § 204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-11-26"},"text":"Nov. 26, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1126"},"text":"105 Stat. 1126","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/517/tII/s204"},"text":"Pub. L. 101–517, title II, § 204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2208"},"text":"104 Stat. 2208","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/166/tII/s205"},"text":"Pub. L. 101–166, title II, § 205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-21"},"text":"Nov. 21, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1177"},"text":"103 Stat. 1177","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/202/s101/h/tII/s205"},"text":"Pub. L. 100–202, § 101(h) [title II, § 205]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1329-256"},"text":"101 Stat. 1329–256","children":[],"tail":", 1329–274."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/500/s101/i/tII/s205"},"text":"Pub. L. 99–500, § 101(i) [H.R. 5233, title II, § 205]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-18"},"text":"Oct. 18, 1986","children":[],"ta