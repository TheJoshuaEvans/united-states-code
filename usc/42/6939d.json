{"tag":"section","attrib":{"id":"idbdd7f1e7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6939d"},"text":null,"children":[{"tag":"num","attrib":{"value":"6939d"},"text":"§ 6939d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public vessels","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbdd7f1e8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6939d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waste generated on public vessels","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any hazardous waste generated on a public vessel shall not be subject to the storage, manifest, inspection, or recordkeeping requirements of this chapter until such waste is transferred to a shore facility, unless—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbdd7f1e9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6939d/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the waste is stored on the public vessel for more than 90 days after the public vessel is placed in reserve or is otherwise no longer in service; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdd7f1ea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6939d/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the waste is transferred to another public vessel within the territorial waters of the United States and is stored on such vessel or another public vessel for more than 90 days after the date of transfer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdd7f1eb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6939d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Computation of storage period","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subsection (a), the 90-day period begins on the earlier of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbdd7f1ec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6939d/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which the public vessel on which the waste was generated is placed in reserve or is otherwise no longer in service; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdd7f1ed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6939d/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which the waste is transferred from the public vessel on which the waste was generated to another public vessel within the territorial waters of the United States;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"and continues, without interruption, as long as the waste is stored on the original public vessel (if in reserve or not in service) or another public vessel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdd7f1ee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6939d/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbdd7f1ef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6939d/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “public vessel” means a vessel owned or bareboat chartered and operated by the United States, or by a foreign nation, except when the vessel is engaged in commerce.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdd7f1f0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6939d/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The terms “in reserve” and “in service” have the meanings applicable to those terms under section 8663 and sections 8674 through 8678 of title 10 and regulations prescribed under those sections.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdd7f1f1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6939d/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relationship to other law","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed as altering or otherwise affecting the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s8681"},"text":"section 8681 of title 10","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbdd7f1f2-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/272/tII/s3022"},"text":"Pub. L. 89–272, title II, § 3022","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/386/tI/s106/a"},"text":"Pub. L. 102–386, title I, § 106(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-06"},"text":"Oct. 6, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1513"},"text":"106 Stat. 1513","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s809/n/2"},"text":"Pub. L. 115–232, div. A, title VIII, § 809(n)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1844"},"text":"132 Stat. 1844","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbdd7f1f3-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbdd7f1f4-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbdd7f1f5-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s809/n/2/A"},"text":"Pub. L. 115–232, § 809(n)(2)(A)","children":[],"tail":", substituted “section 8663 and sections 8674 through 8678 of title 10” for “section 7293 and sections 7304 through 7308 of title 10”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s809/n/2/B"},"text":"Pub. L. 115–232, § 809(n)(2)(B)","children":[],"tail":", substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t10/s8681"},"text":"section 8681 of title 10","children":[],"tail":"” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t10/s7311"},"text":"section 7311 of title 10","children":[],"tail":"”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbdd7f1f6-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbdd7f1f7-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-02-01"},"text":"Feb. 1, 2019","children":[],"tail":", with provision for the coordination of amendments and special rule for certain redesignations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s800"},"text":"section 800 of Pub. L. 115–232","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of Title 10","children":[],"tail":", Armed Forces."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
