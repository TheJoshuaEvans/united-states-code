{"tag":"section","attrib":{"id":"idbc428507-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3013a"},"text":null,"children":[{"tag":"num","attrib":{"value":"3013a"},"text":"§ 3013a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation with State agencies, area agencies on aging, and Native American grant recipients","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Assistant Secretary shall consult and coordinate with State agencies, area agencies on aging, and recipients of grants under subchapter X in the development of Federal goals, regulations, program instructions, and policies under this chapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbc428508-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/73/tII/s203A"},"text":"Pub. L. 89–73, title II, § 203A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/375/tII/s204"},"text":"Pub. L. 102–375, title II, § 204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-09-30"},"text":"Sept. 30, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1211"},"text":"106 Stat. 1211","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/171/s3/a/13"},"text":"Pub. L. 103–171, § 3(a)(13)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-02"},"text":"Dec. 2, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1990"},"text":"107 Stat. 1990","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc428509-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc42850a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbc42850b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1993—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/171"},"text":"Pub. L. 103–171","children":[],"tail":" substituted “Assistant Secretary” for “Commissioner”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
