{"tag":"section","attrib":{"id":"idbf2a89f3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10414"},"text":null,"children":[{"tag":"num","attrib":{"value":"10414"},"text":"§ 10414.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Domestic Violence Prevention Enhancement and Leadership Through Alliances (DELTA)","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf2a89f4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10414/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall enter into cooperative agreements with State Domestic Violence Coalitions for the purposes of establishing, operating, and maintaining local community projects to prevent family violence, domestic violence, and dating violence, including violence committed by and against youth, using a coordinated community response model and through prevention and education programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf2a89f5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10414/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall enter into a cooperative agreement under this section for a period of not more than 5 fiscal years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf2a89f6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10414/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conditions on payment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The provision of payments under a cooperative agreement under this section shall be subject to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf2cf9f7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10414/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" annual approval by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf2cf9f8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10414/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the availability of appropriations for each fiscal year to make the payments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf2cf9f9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10414/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to enter into a cooperative agreement under this section, an organization shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf2cf9fa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10414/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be a State Domestic Violence Coalition; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf2cf9fb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10414/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" include representatives of pertinent sectors of the local community, which may include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf2cf9fc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10414/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" health care providers and State or local health departments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf2cf9fd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10414/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the education community;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf2cf9fe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10414/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the faith-based community;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf2cf9ff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10414/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the criminal justice system;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf2cfa00-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10414/d/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" family violence, domestic violence, and dating violence service program advocates;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf2cfa01-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10414/d/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" human service entities such as State child services divisions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf2cfa02-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10414/d/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" business and civic leaders; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf2cfa03-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10414/d/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other pertinent sectors.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf2cfa04-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10414/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An organization that desires to enter into a cooperative agreement under this section shall submit to the Secretary an application, in such form and in such manner as the Secretary shall require, that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf2cfa05-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10414/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrates the capacity of the applicant, who may enter into a partnership with a local family violence, domestic violence, or dating violence service provider or community-based organization, to undertake the project involved;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf2cfa06-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10414/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrates that the project will include a coordinated community response to improve and expand prevention strategies through increased communication and coordination among all affected sectors of the local community;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf2cfa07-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10414/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" includes a complete description of the applicant’s plan for the establishment and implementation of the coordinated community response, including a description of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf2cfa08-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10414/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the method to be used for identification and selection of an administrative committee made up of persons knowledgeable about comprehensive family violence, domestic violence, and dating violence prevention planning to oversee the project, hire staff, assure compliance with the project outline, and secure annual evaluation of the project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf2cfa09-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10414/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the method to be used for identification and selection of project staff and a project evaluator;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf2cfa0a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10414/e/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the method to be used for identification and selection of a project council consisting of representatives of the community sectors listed in subsection (d)(2); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf2cfa0b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10414/e/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the method to be used for identification and selection of a steering committee consisting of representatives of the various community sectors who will chair subcommittees of the project council, each of which will focus on 1 of the sectors;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf2cfa0c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10414/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrates that the applicant has experience in providing, or the capacity to provide, prevention-focused training and technical assistance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf2cfa0d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10414/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrates that the applicant has the capacity to carry out collaborative community initiatives to prevent family violence, domestic violence, and dating violence; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf2cfa0e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10414/e/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contains such other information, agreements, and assurances as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf2cfa0f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10414/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Geographical dispersion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall enter into cooperative agreements under this section with organizations in States geographically dispersed throughout the Nation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf2cfa10-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10414/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf2cfa11-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10414/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An organization that enters into a cooperative agreement under subsection (a) shall use the funds made available through the agreement to establish, operate, and maintain comprehensive family violence, domestic violence, and dating violence prevention programming.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf2cfa12-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10414/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance, evaluation and monitoring","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may use a portion of the funds provided under this section to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf2cfa13-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10414/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide technical assistance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf2cfa14-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10414/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" monitor the performance of organizations carrying out activities under the cooperative agreements; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf2cfa15-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10414/g/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct an independent evaluation of the program carried out under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf2cfa16-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10414/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In establishing and operating a project under this section, an eligible organization shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf2cfa17-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10414/g/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish protocols to improve and expand family violence, domestic violence, and dating violence prevention and intervention strategies within affected community sectors described in subsection (d)(2);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf2cfa18-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10414/g/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop comprehensive prevention plans to coordinate prevention efforts with other community sectors;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf2cfa19-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10414/g/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for periodic evaluation of the project, and analysis to assist in replication of the prevention strategies used in the project in other communities, and submit a report under subsection (h) that contains the evaluation and analysis;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf2cfa1a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10414/g/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" develop, replicate, or conduct comprehensive, evidence-informed primary prevention programs that reduce risk factors and promote protective factors that reduce the likelihood of family violence, domestic violence, and dating violence, which may include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbf2cfa1b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10414/g/3/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" educational workshops and seminars;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf2cfa1c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10414/g/3/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" training programs for professionals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf2cfa1d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10414/g/3/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the preparation of informational material;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf2cfa1e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10414/g/3/D/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developmentally appropriate education programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf2cfa1f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10414/g/3/D/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other efforts to increase awareness of the facts about, or to help prevent, family violence, domestic violence, and dating violence; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf2cfa20-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10414/g/3/D/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the dissemination of information about the results of programs conducted under this subparagraph;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf2cfa21-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10414/g/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" utilize evidence-informed prevention program planning; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf2cfa22-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10414/g/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recognize, in applicable cases, the needs of underserved populations, racial and linguistic populations, and individuals with disabilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf2cfa23-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10414/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports and evaluation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each organization entering into a cooperative agreement under this section shall submit a performance report to the Secretary at such time as shall be reasonably required by the Secretary. Such performance report shall describe activities that have been carried out with the funds made available through the agreement, contain an evaluation of the effectiveness of such activities, and provide such additional information as the Secretary may reasonably require. The Secretary shall make the evaluations received under this subsection publicly available on the Department of Health and Human Services website. The reports shall also be submitted to the Committee on Education and Labor of the House of Representatives and the Committee on Health, Education, Labor, and Pensions of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf2cfa24-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/457/tIII/s314"},"text":"Pub. L. 98–457, title III, § 314","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/320/tII/s201"},"text":"Pub. L. 111–320, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-20"},"text":"Dec. 20, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3507"},"text":"124 Stat. 3507","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf2cfa25-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf2cfa26-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbf2cfa27-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 10414, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/457/tIII/s314"},"text":"Pub. L. 98–457, title III, § 314","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/295/tIII/s320"},"text":"Pub. L. 102–295, title III, § 320","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-05-28"},"text":"May 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/209"},"text":"106 Stat. 209","children":[],"tail":", related to grants for public information campaigns, prior to the general amendment of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/111/320"},"text":"Pub. L. 111–320","children":[],"tail":