{"tag":"section","attrib":{"id":"idbf6aeefa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12371"},"text":null,"children":[{"tag":"num","attrib":{"value":"12371"},"text":"§ 12371.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf6aeefb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12371/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf6aeefc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12371/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" children and youth are inherently our most valuable resource and their welfare, protection, healthy development, and positive role in society are essential to the Nation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf6aeefd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12371/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" children and youth deserve love, respect, and guidance, as well as good health, shelter, food, education, productive work, and preparation for responsible participation in community life;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf6aeefe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12371/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an increasing opportunity for children and youth to participate in the decisions that affect their lives is essential;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf6aeeff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12371/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the family is the primary caregiver and the source of social learning which must be supported and strengthened, but when families are unable to ensure the satisfaction of the needs of children and youth, it is society’s responsibility to assist them;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf6aef00-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12371/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" at a minimum, all children and youth need and deserve access to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf6aef01-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12371/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the best possible physical and mental health;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf6aef02-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12371/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adequate and safe physical shelter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf6aef03-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12371/a/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the highest quality of educational opportunity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf6aef04-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12371/a/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" effective training, apprenticeships, opportunities for community service, and productive employment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf6aef05-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12371/a/5/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the widest range of civic, cultural, and recreational activities which recognize young Americans as resources and promote self-esteem and a stake in their communities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf6aef06-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12371/a/5/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" comprehensive community services which are efficient, coordinated, and readily available; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf6aef07-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12371/a/5/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" genuine participation in decisions concerning the planning and managing of their lives; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf6aef08-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12371/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is a great need for a comprehensive national policy with respect to young individuals, designed to engage Federal, State, and local government agencies, youth organizations, and other voluntary organizations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf6aef09-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12371/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statement of policy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It is the policy of the Congress that the Federal Government should work jointly with the States and their citizens to develop recommendations and plans for action to meet the challenge and needs of young individuals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf6aef0a-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/501/tIX/s982"},"text":"Pub. L. 101–501, title IX, § 982","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-03"},"text":"Nov. 3, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1280"},"text":"104 Stat. 1280","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf6aef0b-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbf6aef0c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbf6aef0d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1990-10-01"},"text":"Oct. 1, 1990","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/101/501/s1001/a"},"text":"section 1001(a) of Pub. L. 101–501","children":[],"tail":", set out as an Effective Date of 1990 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s8621"},"text":"section 8621 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
