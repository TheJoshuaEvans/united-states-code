{"tag":"section","attrib":{"id":"idbb70b5ee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1780"},"text":null,"children":[{"tag":"num","attrib":{"value":"1780"},"text":"§ 1780.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibitions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbb70b5ef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1780/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interference with school personnel, curriculum, or instruction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out the provisions of sections 1772 and 1773 of this title, the Secretary shall not impose any requirements with respect to teaching personnel, curriculum, instruction, methods of instruction, and materials of instruction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb70b5f0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1780/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusion of assistance in determining income or resources","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The value of assistance to children under this chapter shall not be considered to be income or resources for any purpose under any Federal or State laws including, but not limited to, laws relating to taxation, welfare, and public assistance programs. Expenditures of funds from State and local sources for the maintenance of food programs for children shall not be diminished as a result of funds received under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb70b5f1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1780/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal law not applicable","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Section 1693","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":"–2 of title 15 shall not apply to electronic benefit transfer systems established under this chapter or the Richard B. Russell National School Lunch Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1751"},"text":"42 U.S.C. 1751","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbb70b5f2-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/642/s11"},"text":"Pub. L. 89–642, § 11","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-10-11"},"text":"Oct. 11, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/889"},"text":"80 Stat. 889","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tVIII/s819/f"},"text":"Pub. L. 97–35, title VIII, § 819(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/533"},"text":"95 Stat. 533","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/193/tVII/s726"},"text":"Pub. L. 104–193, title VII, § 726","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-22"},"text":"Aug. 22, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2302"},"text":"110 Stat. 2302","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tX/s1075/d"},"text":"Pub. L. 111–203, title X, § 1075(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href"