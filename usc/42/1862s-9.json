{"tag":"section","attrib":{"id":"idbb96dc13-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862s–9"},"text":null,"children":[{"tag":"num","attrib":{"value":"1862s–9"},"text":"§ 1862s–9.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Translational research grants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbb96dc14-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862s–9/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sense of Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is the sense of Congress that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb96dc15-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862s–9/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" commercialization of federally funded research may benefit society and the economy; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb96dc16-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862s–9/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not-for-profit organizations support the commercialization of federally funded research by providing useful business and technical expertise to researchers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb96dc17-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862s–9/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commercialization promotion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the Foundation shall continue to award grants on a competitive, merit-reviewed basis to eligible entities to promote the commercialization of federally funded research results.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb96dc18-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862s–9/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Activities supported by grants under this section may include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb96dc19-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862s–9/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying Foundation-sponsored research and technologies that have the potential for accelerated commercialization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb96dc1a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862s–9/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supporting prior or current Foundation-sponsored investigators, institutions of higher education, and non-profit organizations that partner with an institution of higher education in undertaking proof-of-concept work, including development of prototypes of technologies that are derived from Foundation-sponsored research and have potential market value;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb96dc1b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862s–9/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promoting sustainable partnerships between Foundation-funded institutions, industry, and other organizations within academia and the private sector with the purpose of accelerating the transfer of technology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb96dc1c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862s–9/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing multi-disciplinary innovation ecosystems which involve and are responsive to specific needs of academia and industry; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb96dc1d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862s–9/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing professional development, mentoring, and advice in entrepreneurship, project management, and technology and business development to innovators.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb96dc1e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862s–9/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb96dc1f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862s–9/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The following organizations may be eligible for grants under this section:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbb96dc20-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862s–9/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Institutions of higher education.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb96dc21-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862s–9/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Public or nonprofit technology transfer organizations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb96dc22-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862s–9/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A nonprofit organization that partners with an institution of higher education.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb96dc23-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862s–9/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A consortia of 2 or more of the organizations described under subparagraphs (A) through (C).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb96dc24-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862s–9/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lead organizations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any eligible organization under paragraph (1) may apply as a lead organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb96dc25-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862s–9/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An eligible entity seeking a grant under this section shall submit an application to the Director at such time, in such manner, and containing such information as the Director may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbb96dc26-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/329/tVI/s602"},"text":"Pub. L. 114–329, title VI, § 602","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-01-06"},"text":"Jan. 6, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/3035"},"text":"130 Stat. 3035","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbb96dc27-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbb96dc28-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbb96dc29-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the American Innovation and Competitiveness Act, and not as part of the National Science Foundation Act of 1950 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbb96dc2a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idbb96dc2b-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definitions of terms used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/329/s2"},"text":"section 2 of Pub. L. 114–329","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1862s"},"text":"section 1862s of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
