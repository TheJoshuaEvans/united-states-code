{"tag":"section","attrib":{"id":"idb9216ea4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–6"},"text":null,"children":[{"tag":"num","attrib":{"value":"1395w–6"},"text":"§ 1395w–6.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Empowering beneficiary choices through continued access to information on physicians’ services","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb9216ea5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–6/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On an annual basis (beginning with 2015), the Secretary shall make publicly available, in an easily understandable format, information with respect to physicians and, as appropriate, other eligible professionals on items and services furnished to Medicare beneficiaries under title XVIII of the Social Security Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395"},"text":"42 U.S.C. 1395","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9216ea6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–6/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Type and manner of information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The information made available under this section shall be similar to the type of information in the Medicare Provider Utilization and Payment Data: Physician and Other Supplier Public Use File released by the Secretary with respect to 2012 and shall be made available in a manner similar to the manner in which the information in such file is made available.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9216ea7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–6/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The information made available under this section shall include, at a minimum, the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9216ea8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–6/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Information on the number of services furnished by the physician or other eligible professional under part B of title XVIII of the Social Security Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395j"},"text":"42 U.S.C. 1395j","children":[],"tail":" et seq.), which may include information on the most frequent services furnished or groupings of services."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9216ea9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–6/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Information on submitted charges and payments for services under such part.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9216eaa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–6/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A unique identifier for the physician or other eligible professional that is available to the public, such as a national provider identifier.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9216eab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–6/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Searchability","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The information made available under this section shall be searchable by at least the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9216eac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–6/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The specialty or type of the physician or other eligible professional.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9216ead-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–6/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Characteristics of the services furnished, such as volume or groupings of services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9216eae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–6/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The location of the physician or other eligible professional.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9216eaf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–6/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Integration on physician compare","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Beginning with 2016, the Secretary shall integrate the information made available under this section on Physician Compare.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9216eb0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–6/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9216eb1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–6/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible professional; physician; Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “eligible professional”, “physician”, and “Secretary” have the meaning given such terms in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395w–5/i"},"text":"section 1395w–5(i) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9216eb2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–6/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Physician compare","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Physician Compare” means the Physician Compare Internet website of the Centers for Medicare & Medicaid Services (or a successor website).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb9216eb3-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/10/tI/s104"},"text":"Pub. L. 114–10, title I, § 104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-04-16"},"text":"Apr. 16, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/132"},"text":"129 Stat. 132","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9216eb4-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb9216eb5-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb9216eb6-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Social Security Act, referred to in subsecs. (a) and (c)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"act Aug. 14, 1935, ch. 531","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/620"},"text":"49 Stat. 620","children":[],"tail":". Title XVIII of the Act is classified generally to this subchapter. Part B of title XVIII of the Act is classified generally to this part. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1305"},"text":"section 1305 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb9216eb7-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Medicare Access and CHIP Reauthorization Act of 2015, and not as part of the Social Security Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
