{"tag":"section","attrib":{"id":"idbe07b4d9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381r"},"text":null,"children":[{"tag":"num","attrib":{"value":"7381r"},"text":"§ 7381r.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mentoring program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbe07b4da-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381r/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As part of the programs established under subparts 3 and 4, the Director shall establish a program to recruit and provide mentors for women and underrepresented minorities who are interested in careers in science, engineering, and mathematics.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe07b4db-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381r/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pairing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The program shall pair mentors with women and minorities who are in programs of study at specialty schools for science and mathematics, Centers of Excellence, and summer institutes established under subparts 3 and 4, respectively.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe07b4dc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381r/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program evaluation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall annually—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe07b4dd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381r/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use metrics to evaluate the success of the programs established under subsection (a); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe07b4de-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381r/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit to Congress a report that describes the results of each evaluation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbe07b4df-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510/dC/tXXXI/s3195"},"text":"Pub. L. 101–510, div. C, title XXXI, § 3195","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/69/tV/s5003/d/3"},"text":"Pub. L. 110–69, title V, § 5003(d)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-08-09"},"text":"Aug. 9, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/611"},"text":"121 Stat. 611","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/358/tIX/s901/c/2"},"text":"Pub. L. 111–358, title IX, § 901(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4044"},"text":"124 Stat. 4044","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbe07b4e0-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbe07b4e1-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbe07b4e2-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Subparts 3 and 4, referred to in subsec. (b), relate to Centers of Excellence and summer institutes, respectively. Prior to amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/358"},"text":"Pub. L. 111–358","children":[],"tail":", subsec. (b) also contained reference to subpart 1, which related to specialty schools for science and mathematics and was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/111/358/tIX/s901/c/1"},"text":"Pub. L. 111–358, title IX, § 901(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4044"},"text":"124 Stat. 4044","children":[],"tail":". See 2011 Amendment note below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbe07b4e3-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2011—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/358"},"text":"Pub. L. 111–358","children":[],"tail":" substituted “subparts 3 and 4” for “subparts 1, 3, and 4” in subsecs. (a) and (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
