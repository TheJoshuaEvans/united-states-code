{"tag":"section","attrib":{"id":"idbea9c0b7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9008"},"text":null,"children":[{"tag":"num","attrib":{"value":"9008"},"text":"§ 9008.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this chapter, the term—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbea9c0b8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9008/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “ocean thermal energy conversion” means a method of converting part of the heat from the Sun which is stored in the surface layers of a body of water into electrical energy or energy product equivalent;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbea9c0b9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9008/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “energy product equivalent” means an energy carrier including, but not limited to, ammonia, hydrogen, or molten salts or an energy-intensive commodity, including, but not limited to, electrometals, fresh water, or nutrients for aquaculture; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbea9c0ba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9008/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Secretary” means the Secretary of Energy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbea9c0bb-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/310/s9"},"text":"Pub. L. 96–310, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-07-17"},"text":"July 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/946"},"text":"94 Stat. 946","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
