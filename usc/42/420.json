{"tag":"section","attrib":{"id":"idb75ed6b3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s420"},"text":null,"children":[{"tag":"num","attrib":{"value":"420"},"text":"§ 420.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disability provisions inapplicable if benefit rights impaired","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"None of the provisions of this subchapter relating to periods of disability shall apply in any case in which their application would result in the denial of monthly benefits or a lump-sum death payment which would otherwise be payable under this subchapter; nor shall they apply in the case of any monthly benefit or lump-sum death payment under this subchapter if such benefit or payment would be greater without their application.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb75ed6b4-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title II, § 220, as added "},{"tag":"ref","attrib":{"href":"/us/act/1954-09-01/ch1206"},"text":"Sept. 1, 1954, ch. 1206","children":[],"tail":", title I, § 106(g), "},{"tag":"ref","attrib":{"href":"/us/stat/68/1081"},"text":"68 Stat. 1081","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb75ed6b5-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb75ed6b6-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb75ed6b7-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 420, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531/tII/s220"},"text":"act Aug. 14, 1935, ch. 531, title II, § 220","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/act/1952-07-18/ch945/s3/e"},"text":"July 18, 1952, ch. 945, § 3(e)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/66/772"},"text":"66 Stat. 772","children":[],"tail":", relating to inapplicability of disability provisions if benefits were reduced, ceased to be in effect at the close of "},{"tag":"date","attrib":{"date":"1953-06-30"},"text":"June 30, 1953","children":[],"tail":". See Effective and Termination Date of 1952 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s413"},"text":"section 413 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
