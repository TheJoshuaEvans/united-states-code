{"tag":"section","attrib":{"id":"idbff2e438-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16134"},"text":null,"children":[{"tag":"num","attrib":{"value":"16134"},"text":"§ 16134.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation and report","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbff2e439-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16134/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after the date on which funds are made available under this part, and biennially thereafter, the Administrator shall submit to Congress a report evaluating the implementation of the programs under this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff2e43a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16134/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The report shall include a description of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbff52c2b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16134/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total number of grant applications received;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff52c2c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16134/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each grant, rebate, or loan made under this part, including the amount of the grant, rebate, or loan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff52c2d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16134/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each project for which a grant, rebate, or loan is provided under this part, including the criteria used to select the grant, rebate, or loan recipients;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff52c2e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16134/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the actual and estimated air quality and diesel fuel conservation benefits, cost-effectiveness, and cost-benefits of the grant, rebate, and loan programs under this part;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff52c2f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16134/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the problems encountered by projects for which a grant, rebate, or loan is provided under this part;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff52c30-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16134/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other information the Administrator considers to be appropriate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff52c31-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16134/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the last report sent to Congress before ","children":[{"tag":"date","attrib":{"date":"2016-01-01"},"text":"January 1, 2016","children":[],"tail":", an analysis of the need to continue the program, including an assessment of the size of the vehicle and engine fleet that could provide benefits from being retrofit under this program and a description of the number and types of applications that were not granted in the preceding year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbff52c32-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tVII/s794"},"text":"Pub. L. 109–58, title VII, § 794","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/843"},"text":"119 Stat. 843","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/364/s2/d"},"text":"Pub. L. 111–364, § 2(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4060"},"text":"124 Stat. 4060","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbff52c33-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbff52c34-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbff52c35-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2011—Subsec. (b)(2) to (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/364/s2/d/1"},"text":"Pub. L. 111–364, § 2(d)(1)","children":[],"tail":", inserted “, rebate,” after “grant” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/364/s2/d/2"},"text":"Pub. L. 111–364, § 2(d)(2)","children":[],"tail":"–(4), added par. (7)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbff52c36-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbff52c37-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2011 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/364"},"text":"Pub. L. 111–364","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2011-10-01"},"text":"Oct. 1, 2011","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/364/s4"},"text":"section 4 of Pub. L. 111–364","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s16131"},"text":"section 16131 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
