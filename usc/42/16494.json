{"tag":"section","attrib":{"id":"idc0169737-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16494"},"text":null,"children":[{"tag":"num","attrib":{"value":"16494"},"text":"§ 16494.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Oxygen-fuel","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc0169738-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16494/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a program on oxygen-fuel systems. If feasible, the program shall include renovation of at least one existing large unit and one existing small unit, and construction of one new large unit and one new small unit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0169739-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16494/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated to the Secretary for carrying out this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc016973a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16494/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $100,000,000 for fiscal year 2006;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc016973b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16494/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $100,000,000 for fiscal year 2007; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc016973c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16494/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $100,000,000 for fiscal year 2008.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc016973d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16494/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc016973e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16494/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “large unit” means a unit with a generating capacity of 100 megawatts or more;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc016973f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16494/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “oxygen-fuel systems” means systems that utilize fuel efficiency benefits of oil, gas, coal, and biomass combustion using substantially pure oxygen, with high flame temperatures and the exclusion of air from the boiler, in industrial or electric utility steam generating units; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0169740-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16494/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “small unit” means a unit with a generating capacity in the 10–50 megawatt range.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc0169741-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tXIV/s1407"},"text":"Pub. L. 109–58, title XIV, § 1407","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1064"},"text":"119 Stat. 1064","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
