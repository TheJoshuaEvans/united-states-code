{"tag":"section","attrib":{"id":"idbc214189-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2374"},"text":null,"children":[{"tag":"num","attrib":{"value":"2374"},"text":"§ 2374.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Utilities transferable","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"All utilities are authorized to be transferred under this subchapter, but shall not include property which the Commission determines to be needed for its own use.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbc21418a-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1955-08-04/ch543"},"text":"Aug. 4, 1955, ch. 543","children":[],"tail":", ch. 7, § 74, "},{"tag":"ref","attrib":{"href":"/us/stat/69/480"},"text":"69 Stat. 480","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc21418b-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbc21418c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"idbc21418d-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Atomic Energy Commission abolished and functions transferred by sections 5814 and 5841 of this title. See also Transfer of Functions notes set out under those sections.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
