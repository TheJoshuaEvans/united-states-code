{"tag":"section","attrib":{"id":"idbdc99a08-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6914b"},"text":null,"children":[{"tag":"num","attrib":{"value":"6914b"},"text":"§ 6914b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Degradable plastic ring carriers; definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this title—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbdc99a09-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6914b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “regulated item” means any plastic ring carrier device that contains at least one hole greater than 1¾ inches in diameter which is made, used, or designed for the purpose of packaging, transporting, or carrying multipackaged cans or bottles, and which is of a size, shape, design, or type capable, when discarded, of becoming entangled with fish or wildlife; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdc99a0a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6914b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “naturally degradable material” means a material which, when discarded, will be reduced to environmentally benign subunits under the action of normal environmental forces, such as, among others, biological decomposition, photodegradation, or hydrolysis.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbdc99a0b-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/556/tI/s102"},"text":"Pub. L. 100–556, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-28"},"text":"Oct. 28, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2779"},"text":"102 Stat. 2779","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbdc99a0c-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbdc99a0d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbdc99a0e-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This title, referred to in text, is title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/556"},"text":"Pub. L. 100–556","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-28"},"text":"Oct. 28, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2779"},"text":"102 Stat. 2779","children":[],"tail":", which enacted sections 6914b and 6914b–1 of this title, and provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s6914b"},"text":"section 6914b of this title","children":[],"tail":". For complete classification of this title to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbdc99a0f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of the Solid Waste Disposal Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbdc99a10-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbdc99a11-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Congressional Findings","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/556/tI/s101"},"text":"Pub. L. 100–556, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-28"},"text":"Oct. 28, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2779"},"text":"102 Stat. 2779","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/556/tI/s101"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The Congress finds that—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" plastic ring carrier devices have been found in large quantities in the marine environment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fish and wildlife have been known to have become entangled in plastic ring carriers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nondegradable plastic ring carrier devices can remain intact in the marine environment for decades, posing a threat to fish and wildlife; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 16 States have enacted laws requiring that plastic ring carrier devices be made from degradable material in order to reduce litter and to protect fish and wildlife.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
