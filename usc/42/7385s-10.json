{"tag":"section","attrib":{"id":"idbe0eb9b6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385s–10"},"text":null,"children":[{"tag":"num","attrib":{"value":"7385s–10"},"text":"§ 7385s–10.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative matters","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbe0eb9b7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385s–10/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall administer this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe0eb9b8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385s–10/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contract authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may enter into contracts with appropriate persons and entities to administer this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe0eb9b9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385s–10/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Records","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe0eb9ba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385s–10/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbe0eb9bb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385s–10/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Energy shall provide to the Secretary all records, files, and other data, whether paper, electronic, imaged, or otherwise, developed by the Secretary of Energy that are applicable to the administration of this part, including records, files, and data on facility industrial hygiene, employment of individuals or groups, exposure and medical records, and claims applications.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe0eb9bc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385s–10/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In providing records, files, and other data under this paragraph, the Secretary of Energy shall preserve the current organization of such records, files, and other data, and shall provide such description and indexing of such records, files, and other data as the Secretary considers appropriate to facilitate their use by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe0eb9bd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385s–10/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Energy and the Secretary shall jointly undertake such actions as are appropriate to retrieve records applicable to the claims of Department of Energy contractor employees for contractor employee compensation under this part, including employment records, records of exposure to beryllium, radiation, silica, or other toxic substances, and records regarding medical treatment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe0eb9be-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385s–10/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"At the request of the Secretary, the Secretary of Energy and any contractor who employed a Department of Energy contractor employee shall, within time periods specified by the Secretary, provide to the Secretary and to the employee information or documents in response to the request.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe0eb9bf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385s–10/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall prescribe regulations necessary for the administration of this part. The initial regulations shall be prescribed not later than 210 days after ","children":[{"tag":"date","attrib":{"date":"2004-10-28"},"text":"October 28, 2004","children":[],"tail":". The Secretary may prescribe interim final regulations necessary to meet the deadlines specified in this part."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe0eb9c0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385s–10/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transition provisions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe0eb9c1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385s–10/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall commence the administration of the provisions of this part not later than 210 days after ","children":[{"tag":"date","attrib":{"date":"2004-10-28"},"text":"October 28, 2004","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe0eb9c2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385s–10/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Until the commencement of the administration of this part, the Department of Energy Physicians Panels appointed pursuant to part D shall continue to consider and issue determinations concerning any cases pending before such Panels immediately before ","children":[{"tag":"date","attrib":{"date":"2004-10-28"},"text":"October 28, 2004","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe0eb9c3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385s–10/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall take such actions as are appropriate to identify other activities under part D that will continue until the commencement of the administration of this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe0eb9c4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385s–10/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Previous applications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon the commencement of the administration of this part, any application previously filed with the Secretary of Energy pursuant to part D shall be considered to have been filed with the Secretary as a claim for benefits pursuant to this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbe0eb9c5-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dC/tXXXVI/s3681"},"text":"Pub. L. 106–398, § 1 [div. C, title XXXVI, § 3681]","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/375/dC/tXXXI/s3161"},"text":"Pub. L. 108–375, div. C, title XXXI, § 3161","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-28"},"text":"Oct. 28, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2183"},"text":"118 Stat. 2183","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbe0eb9c6-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbe0eb9c7-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbe0eb9c8-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Part D, referred to in subsecs. (f)(2), (3) and (g), was repealed by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375/dC/tXXXI/s3162/i"},"text":"Pub. L. 108–375, div. C, title XXXI, § 3162(i)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-28"},"text":"Oct. 28, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2186"},"text":"118 Stat. 2186","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
