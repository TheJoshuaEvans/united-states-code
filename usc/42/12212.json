{"tag":"section","attrib":{"id":"idbf687c79-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12212"},"text":null,"children":[{"tag":"num","attrib":{"value":"12212"},"text":"§ 12212.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Alternative means of dispute resolution","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Where appropriate and to the extent authorized by law, the use of alternative means of dispute resolution, including settlement negotiations, conciliation, facilitation, mediation, factfinding, minitrials, and arbitration, is encouraged to resolve disputes arising under this chapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbf687c7a-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/336/tV/s514"},"text":"Pub. L. 101–336, title V, § 514","children":[],"tail":", formerly § 513, "},{"tag":"date","attrib":{"date":"1990-07-26"},"text":"July 26, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/377"},"text":"104 Stat. 377","children":[],"tail":"; renumbered § 514, "},{"tag":"ref","attrib":{"href":"/us/pl/110/325/s6/a/2"},"text":"Pub. L. 110–325, § 6(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-09-25"},"text":"Sept. 25, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3558"},"text":"122 Stat. 3558","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf687c7b-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf687c7c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbf687c7d-3a