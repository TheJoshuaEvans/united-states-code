{"tag":"section","attrib":{"id":"idbfc801f3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13553"},"text":null,"children":[{"tag":"num","attrib":{"value":"13553"},"text":"§ 13553.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Energy subsidy study","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfc801f4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13553/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall contract with the National Academy of Sciences to conduct a study of energy subsidies that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfc801f5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13553/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are in effect on ","children":[{"tag":"date","attrib":{"date":"1992-10-24"},"text":"October 24, 1992","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc801f6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13553/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have been in effect prior to ","children":[{"tag":"date","attrib":{"date":"1992-10-24"},"text":"October 24, 1992","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfc801f7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13553/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No