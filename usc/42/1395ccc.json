{"tag":"section","attrib":{"id":"idba03e034-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395ccc"},"text":null,"children":[{"tag":"num","attrib":{"value":"1395ccc"},"text":"§ 1395ccc.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Offset of payments to individuals to collect past-due obligations arising from breach of scholarship and loan contract","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idba03e035-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395ccc/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idba03e036-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395ccc/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idba03e037-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395ccc/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to subparagraph (B), the Secretary shall enter into an agreement under this section with any individual who, by reason of a breach of a contract entered into by such individual pursuant to the National Health Service Corps Scholarship Program, the Physician Shortage Area Scholarship Program, or the Health Education Assistance Loan Program, owes a past-due obligation to the United States (as defined in subsection (b)).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idba03e038-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395ccc/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall not enter into an agreement with an individual under this section to the extent—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idba03e039-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395ccc/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idba03e03a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395ccc/a/1/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the individual has entered into a contract with the Secretary pursuant to section 204(a)(1) of the Public Health Service Amendments of 1987, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idba03e03b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395ccc/a/1/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the individual has fulfilled or (as determined by the Secretary) is fulfilling the terms of such contract; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idba03e03c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395ccc/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the liability of the individual under such section 204(a)(1) has otherwise been relieved under such section; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idba03e03d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395ccc/a/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the individual is performing such physician’s ","children":[{"tag":"ref","attrib":{"idref":"fn002967"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002967"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “individual’s”."}],"tail":" service obligation under a forbearance agreement entered into with the Secretary under subpart II of part D of title III of the Public Health Service Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s254d"},"text":"42 U.S.C. 254d","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idba03e03e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395ccc/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The agreement under this section shall provide that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idba03e03f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395ccc/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deductions shall be made from the amounts otherwise payable to the individual under this subchapter, in accordance with a formula and schedule agreed to by the Secretary and the individual, until such past-due obligation (and accrued interest) have been repaid;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idba03e040-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395ccc/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" payment under this subchapter for services provided by such individual shall be made only on an assignment-related basis;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idba03e041-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395ccc/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" if the individual does not provide services, for which payment would otherwise be made under this subchapter, of a sufficient quantity to maintain the offset collection according to the agreed upon formula and schedule—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idba03e042-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395ccc/a/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary shall immediately inform the Attorney General, and the Attorney General shall immediately commence an action to recover the full amount of the past-due obligation, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idba03e043-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395ccc/a/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to paragraph (4), the Secretary shall immediately exclude the individual from the program under this subchapter, until such time as the entire past-due obligation has been repaid.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idba03e044-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395ccc/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If the individual refuses to enter into an agreement or breaches any provision of the agreement—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idba065045-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395ccc/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary shall immediately inform the Attorney General, and the Attorney General shall immediately commence an action to recover the full amount of the past-due obligation, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idba065046-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395ccc/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to paragraph (4), the Secretary shall immediately exclude the individual from the program under this subchapter, until such time as the entire past-due obligation has been repaid.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idba065047-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395ccc/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall not exclude an individual pursuant to paragraph (2)(C)(ii) or paragraph (3)(B) if such individual is a sole community practitioner or sole source of essential specialized services in a community if a State requests that the individual not be excluded.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idba065048-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395ccc/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Past-due obligation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, a past-due obligation is any amount—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idba065049-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395ccc/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" owed by an individual to the United States by reason of a breach of a scholarship contract under section 338E of the Public Health Service Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s254"},"text":"42 U.S.C. 254","children":[],"tail":null},{"tag":"i","attrib":{},"text":"o","children":[],"tail":"] or under subpart III of part F of title VII of such Act (as in effect before "},{"tag":"date","attrib":{"date":"1976-10-01"},"text":"October 1, 1976","children":[],"tail":") and which has not been paid by the deadline established by the Secretary pursuant to such respective section, and has not been canceled, waived, or suspended by the Secretary pursuant to such section; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idba06504a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395ccc/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" owed by an individual to the United States by reason of a loan covered by Federal loan insurance under subpart I ","children":[{"tag":"ref","attrib":{"idref":"fn002968"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002968"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" See References in Text note below."}],"tail":" of part C of title VII of the Public Health Service Act and payment for which has not been cancelled, waived, or suspended by the Secretary under such subpart."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idba06504b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395ccc/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collection under this section shall not be exclusive","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall not preclude the United States from applying other provisions of law otherwise applicable to the collection of obligations owed to the United States, including (but not limited to) the use of tax refund offsets pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3720A"},"text":"section 3720A of title 31","children":[],"tail":" and the application of other procedures provided under chapter 37 of title 31."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idba06504c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395ccc/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collection from providers and health maintenance organizations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idba06504d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395ccc/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of an individual who owes a past-due obligation, and who is an employee of, or affiliated by a medical services agreement with, a provider having an agreement under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395cc"},"text":"section 1395cc of this title","children":[],"tail":" or a health maintenance organization or competitive medical plan having a contract under section 1395"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":" of this title or "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395mm"},"text":"section 1395mm of this title","children":[],"tail":", the Secretary shall deduct the amounts of such past-due obligation from amounts otherwise payable under this subchapter to such provider, organization, or plan."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idba06504e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395ccc/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Deductions shall be in accordance with a formula and schedule agreed to by the Secretary, the individual and the provider, organization, or plan. The deductions shall be made from the amounts otherwise payable to the individual under this subchapter as long as the individual continues to be employed or affiliated by a medical services agreement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idba06504f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395ccc/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such deduction shall not be made until 6 months after the Secretary notifies the provider, organization, or plan of the amount to be deducted and the particular physicians ","children":[{"tag":"ref","attrib":{"idref":"fn002969"},"text":"3","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002969"},"text":null,"children":[{"tag":"num","attrib":{},"text":"3","children":[],"tail":" So in original. Probably should be “individuals”."}],"tail":" to whom the deductions are attributable."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idba065050-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395ccc/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A deduction made under this subsection shall relieve the individual of the obligation (to the extent of the amount collected) to the United States, but the provider, organization, or plan shall have a right of action to collect from such individual the amount deducted pursuant to this subsection (including accumulated interest).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idba065051-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395ccc/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No deduction shall be made under this subsection if, within the 6-month period after notice is given to the provider, organization, or plan, the individual pays the past-due obligation, or ceases to be employed by the provider, organization, or plan.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idba065052-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395ccc/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall also apply the provisions of this subsection in the case of an individual who is a member of a group practice, if such group practice submits bills under this program as a group, rather than by individual physicians.","children":[{"tag":"sup","attrib":{},"text":"3","children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idba065053-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395ccc/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer from trust funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts equal to the amounts deducted pursuant to this section shall be transferred from the Trust Fund from which the payment to the individual, provider, or other entity would otherwise have been made, to the general fund in the Treasury, and shall be credited as payment of the past-due obligation of the individual from whom (or with respect to whom) the deduction was made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idba065054-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title XVIII, § 1892, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/203/tIV/s4052/a"},"text":"Pub. L. 100–203, title IV, § 4052(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1330-95"},"text":"101 Stat. 1330–95","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/360/tIV/s411/f/10/A"},"text":"Pub. L. 100–360, title IV, § 411(f)(10)(A)","children":[],"tail":", (C)(i), "},{"tag":"date","attrib":{"date":"1988-07-01"},"text":"July 1, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/780"},"text":"102 Stat. 780","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/485/tVI/s608/d/21/E"},"text":"Pub. L. 100–485, title VI, § 608(d)(21)(E)","children":[],"tail":"–(H), "},{"tag":"date","attrib":{"date":"1988-10-13"},"text":"Oct. 13, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2420"},"text":"102 Stat. 2420","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idba065055-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idba065056-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idba065057-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 204(a)(1) of the Public Health Service Amendments of 1987, referred to in subsec. (a)(1)(B), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/177/s204/a/1"},"text":"section 204(a)(1) of Pub. L. 100–177","children":[],"tail":", title II, "},{"tag":"date","attrib":{"date":"1987-12-01"},"text":"Dec. 1, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1000"},"text":"101 Stat. 1000","children":[],"tail":", which is set out as a note under section 254"},{"tag":"i","attrib":{},"text":"o","children":[],"tail":" of this title."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Public Health Service Act, referred to in subsecs. (a)(1)(B)(iii) and (b), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"act July 1, 1944, ch. 373","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/58/682"},"text":"58 Stat. 682","children":[],"tail":". Subpart II of part D of title III of the Act is classified generally to subpart II (§ 254d et seq.) of part D of subchapter II of chapter 6A of this title. Subpart I of part C of title VII of the Act was classified generally to subpart I (§ 294 et seq.) of part C of subchapter V of chapter 6A of this title and was omitted in the general revision of subchapter V by "},{"tag":"ref","attrib":{"href":"/us/pl/102/408/tI/s102"},"text":"Pub. L. 102–408, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-13"},"text":"Oct. 13, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1994"},"text":"106 Stat. 1994","children":[],"tail":". See subpart I (§ 292 et seq.) of part A of subchapter V of chapter 6A of this title. Subpart III of part F of title VII of the Public Health Service Act (as in effect before "},{"tag":"date","attrib":{"date":"1976-10-01"},"text":"October 1, 1976","children":[],"tail":") was classified to subpart III (§ 295g–21 et seq.) of part F of subchapter V of chapter 6A of this title, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/94/484/tIV/s409/a"},"text":"Pub. L. 94–484, title IV, § 409(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-12"},"text":"Oct. 12, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2290"},"text":"90 Stat. 2290","children":[],"tail":". For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s201"},"text":"section 201 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idba065058-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/360/s411/f/10/C/i/I"},"text":"Pub. L. 100–360, § 411(f)(10)(C)(i)(I)","children":[],"tail":", substituted “individuals” for “physicians” and inserted “and loan” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/360/s411/f/10/C/i/IV"},"text":"Pub. L. 100–360, § 411(f)(10)(C)(i)(IV)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/100/485/s608/d/21/H"},"text":"Pub. L. 100–485, § 608(d)(21)(H)","children":[],"tail":", inserted “, the Physician Shortage Area Scholarship Program, or the Health Education Assistance Loan Program”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/360/s411/f/10/C/i/II"},"text":"Pub. L. 100–360, § 411(f)(10)(C)(i)(II)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/100/485/s608/d/21/G"},"text":"Pub. L. 100–485, § 608(d)(21)(G)","children":[],"tail":", substituted “individual” for “physician” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/360/s411/f/10/C/i/II"},"text":"Pub. L. 100–360, § 411(f)(10)(C)(i)(II)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/100/485/s608/d/