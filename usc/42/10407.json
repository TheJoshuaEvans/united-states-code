{"tag":"section","attrib":{"id":"idbf281912-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10407"},"text":null,"children":[{"tag":"num","attrib":{"value":"10407"},"text":"§ 10407.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State application","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf281913-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10407/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf281914-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10407/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The chief executive officer of a State seeking funds under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s10406/a"},"text":"section 10406(a) of this title","children":[],"tail":" or a tribally designated official seeking funds under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s10409/a"},"text":"section 10409(a) of this title","children":[],"tail":" shall submit an application to the Secretary at such time and in such manner as the Secretary may reasonably require."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf281915-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10407/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each such application shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf281916-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10407/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide a description of the procedures that have been developed to ensure compliance with the provisions of sections 10406(c) and 10408(d) of this title;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf281917-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10407/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide, with respect to funds described in paragraph (1), assurances that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbf281918-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10407/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not more than 5 percent of such funds will be used for administrative costs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf281919-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10407/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the remaining funds will be distributed to eligible entities as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s10408/a"},"text":"section 10408(a) of this title","children":[],"tail":" for approved activities as described in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s10408/b"},"text":"section 10408(b) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf28191a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10407/a/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the distribution of funds by a State under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s10408/a"},"text":"section 10408(a) of this title","children":[],"tail":", the State will give special emphasis to the support of community-based projects of demonstrated effectiveness, that are carried out by nonprofit private organizations and that—"}],"tail":null},{"tag":"subclause","attrib":{"id":"idbf28191b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10407/a/2/B/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have as their primary purpose the operation of shelters for victims of family violence, domestic violence, and dating violence, and their dependents; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbf28191c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10407/a/2/B/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide counseling, advocacy, and self-help services to victims of family violence, domestic violence, and dating violence, and their dependents;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf28191d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10407/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an application submitted by a State, provide an assurance that there will be an equitable distribution of grants and grant funds within the State and between urban and rural areas within such State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf28191e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10407/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an application submitted by a State, provide an assurance that the State will consult with and provide for the participation of the State Domestic Violence Coalition in the planning and monitoring of the distribution of grants to eligible entities as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s10408/a"},"text":"section 10408(a) of this title","children":[],"tail":" and the administration of the grant programs and projects;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf28191f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10407/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describe how the State or Indian tribe will involve community-based organizations, whose primary purpose is to provide culturally appropriate services to underserved populations, including how such community-based organizations can assist the State or Indian tribe in addressing the unmet needs of such populations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf281920-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10407/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describe how activities and services provided by the State or Indian tribe are designed to reduce family violence, domestic violence, and dating violence, including how funds will be used to provide shelter, supportive services, and prevention services in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s10408/b"},"text":"section 10408(b) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf281921-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10407/a/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specify the State agency or tribally designated official to be designated as responsible for the administration of programs and activities relating to family violence, domestic violence, and dating violence, that are carried out by the State or Indian tribe under this chapter, and for coordination of related programs within the jurisdiction of the State or Indian tribe;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf2a8922-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10407/a/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide an assurance that the State or Indian tribe has a law or procedure to bar an abuser from a shared household or a household of the abused person, which may include eviction laws or procedures, where appropriate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf2a8923-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10407/a/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meet such requirements as the Secretary reasonably determines are necessary to carry out the objectives and provisions of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf2a8924-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10407/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval of application","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf2a8925-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10407/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall approve any application that meets the requirements of subsection (a) and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s10406"},"text":"section 10406 of this title","children":[],"tail":". The Secretary shall not disapprove any application under this subsection unless the Secretary gives the applicant reasonable notice of the Secretary’s intention to disapprove and a 6-month period providing an opportunity for correction of any deficiencies."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf2a8926-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10407/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Correction of deficiencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall give such notice, within 45 days after the date of submission of the application, if any of the provisions of subsection (a) or ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s10406"},"text":"section 10406 of this title","children":[],"tail":" have not been satisfied in such application. If the State or Indian tribe does not correct the deficiencies in such application within the 6-month period following the receipt of the Secretary’s notice, the Secretary shall withhold payment of any grant funds under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s10406"},"text":"section 10406 of this title","children":[],"tail":" to such State or under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s10409"},"text":"section 10409 of this title","children":[],"tail":" to such Indian tribe until such date as the State or Indian tribe provides documentation that the deficiencies have been corrected."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf2a8927-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10407/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State or tribal Domestic Violence Coalition participation in determinations of compliance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"State Domestic Violence Coalitions, or comparable coalitions for Indian tribes, shall be permitted to participate in determining whether grantees for corresponding States or Indian tribes are in compliance with subsection (a) and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s10406/c"},"text":"section 10406(c) of this title","children":[],"tail":", except that no funds made available under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s10411"},"text":"section 10411 of this title","children":[],"tail":" shall be used to challenge a determination about whether a grantee is in compliance with, or to seek the enforcement of, the requirements of this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf2a8928-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10407/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to report; nonconforming expenditures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall suspend funding for an approved application if the applicant fails to submit an annual performance report under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s10406/d"},"text":"section 10406(d) of this title","children":[],"tail":", or if funds are expended for purposes other than those set forth in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s10406/b"},"text":"section 10406(b) of this title","children":[],"tail":", after following the procedures set forth in paragraphs (1), (2), and (3)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf2a8929-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/457/tIII/s307"},"text":"Pub. L. 98–457, title III, § 307","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/320/tII/s201"},"text":"Pub. L. 111–320, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-20"},"text":"Dec. 20, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3493"},"text":"124 Stat. 3493","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf2a892a-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf2a892b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbf2a892c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 10407, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/457/tIII/s308"},"text":"Pub. L. 98–457, title III, § 308","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-09"},"text":"Oct. 9, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1761"},"text":"98 Stat. 1761","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/295/tIII/s315"},"text":"Pub. L. 102–295, title III, § 315","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-05-28"},"text":"May 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/204"},"text":"106 Stat. 204","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tIV/s40272/b"},"text":"Pub. L. 103–322, title IV, § 40272(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1937"},"text":"108 Stat. 1937","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/36/tIV/s404"},"text":"Pub. L. 108–36, title IV, § 404","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-06-25"},"text":"June 25, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/826"},"text":"117 Stat. 826","children":[],"tail":", related to information and technical assistance centers, prior to the general amendment of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/111/320"},"text":"Pub. L. 111–320","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s10410"},"text":"section 10410 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/457/s307"},"text":"section 307 of Pub. L. 98–457","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s10406"},"text":"section 10406 of this title","children":[],"tail":" prior to the general amendment of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/111/320"},"text":"Pub. L. 111–320","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
