{"tag":"section","attrib":{"id":"idc0084029-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16294"},"text":null,"children":[{"tag":"num","attrib":{"value":"16294"},"text":"§ 16294.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research and development for coal mining technologies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc008402a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16294/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall carry out a program for research and development on coal mining technologies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc008402b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16294/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out the program, the Secretary shall cooperate with appropriate Federal agencies, coal producers, trade associations, equipment manufacturers, institutions of higher education with mining engineering departments, and other relevant entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc008402c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16294/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The research and development activities carried out under this section shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc008402d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16294/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be guided by the mining research and development priorities identified by the Mining Industry of the Future Program and in the recommendations from relevant reports of the National Academy of Sciences on mining technologies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc008402e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16294/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include activities exploring minimization of contaminants in mined coal that contribute to environmental concerns including development and demonstration of electromagnetic wave imaging ahead of mining operations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc008402f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16294/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" develop and demonstrate coal bed electromagnetic wave imaging, spectroscopic reservoir analysis technology, and techniques for horizontal drilling in order to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0084030-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16294/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify areas of high coal gas content;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0084031-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16294/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase methane recovery efficiency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0084032-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16294/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prevent spoilage of domestic coal reserves; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0084033-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16294/c/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" minimize water disposal associated with methane extraction; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0084034-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16294/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expand mining research capabilities at institutions of higher education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc0084035-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tIX/s964"},"text":"Pub. L. 109–58, title IX, § 964","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/892"},"text":"119 Stat. 892","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
