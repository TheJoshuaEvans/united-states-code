{"tag":"section","attrib":{"id":"idb5fb9d73-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s297o"},"text":null,"children":[{"tag":"num","attrib":{"value":"297o"},"text":"§ 297o.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible individual student loan repayment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5fb9d74-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s297o/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Administrator of the Health Resources and Services Administration, may enter into an agreement with eligible individuals for the repayment of education loans, in accordance with this section, to increase the number of qualified nursing faculty.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5fb9d75-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s297o/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each agreement entered into under this subsection shall require that the eligible individual shall serve as a full-time member of the faculty of an accredited school of nursing, for a total period, in the aggregate, of at least 4 years during the 6-year period beginning on the later of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5fb9d76-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s297o/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which the individual receives a master’s or doctorate nursing degree from an accredited school of nursing; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5fb9d77-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s297o/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which the individual enters into an agreement under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5fb9d78-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s297o/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreement provisions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Agreements entered into pursuant to subsection (b) shall be entered into on such terms and conditions as the Secretary may determine, except that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5fb9d79-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s297o/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not more than 10 months after the date on which the 6-year period described under subsection (b) begins, but in no case before the individual starts as a full-time member of the faculty of an accredited school of nursing ","children":[{"tag":"ref","attrib":{"idref":"fn002306"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002306"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be followed by a comma."}],"tail":" the Secretary shall begin making payments, for and on behalf of that individual, on the outstanding principal of, and interest on, any loan of that individual obtained to pay for such degree;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5fb9d7a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s297o/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for an individual who has completed a master’s in nursing or equivalent degree in nursing—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5fb9d7b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s297o/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" payments may not exceed $10,000 per calendar year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5fb9d7c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s297o/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" total payments may not exceed $40,000 during the 2010 and 2011 fiscal years (after fiscal year 2011, such amounts shall be adjusted to provide for a cost-of-attendance increase for the yearly loan rate and the aggregate loan); and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5fb9d7d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s297o/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for an individual who has completed a doctorate or equivalent degree in nursing—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5fb9d7e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s297o/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" payments may not exceed $20,000 per calendar year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5fb9d7f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s297o/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" total payments may not exceed $80,000 during the 2010 and 2011 fiscal years (adjusted for subsequent fiscal years as provided for in the same manner as in paragraph (2)(B)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5fb9d80-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s297o/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Breach of agreement","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5fb9d81-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s297o/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of any agreement made under subsection (b), the individual is liable to the Federal Government for the total amount paid by the Secretary under such agreement, and for interest on such amount at the maximum legal prevailing rate, if the individual fails to meet the agreement terms required under such subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5fb9d82-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s297o/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver or suspension of liability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of an individual making an agreement for purposes of paragraph (1), the Secretary shall provide for the waiver or suspension of liability under such paragraph if compliance by the individual with the agreement involved is impossible or would involve extreme hardship to the individual or if enforcement of the agreement with respect to the individual would be unconscionable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5fb9d83-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s297o/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Date certain for recovery","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (2), any amount that the Federal Government is entitled to recover under paragraph (1) shall be paid to the United States not later than the expiration of the 3-year period beginning on the date the United States becomes so entitled.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5fb9d84-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s297o/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts recovered under paragraph (1) shall be available to the Secretary for making loan repayments under this section and shall remain available for such purpose until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5fb9d85-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s297o/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible individual defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “eligible individual” means an individual who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5fb9d86-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s297o/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a United States citizen, national, or lawful permanent resident;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5fb9d87-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s297o/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" holds an unencumbered license as a registered nurse; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5fb9d88-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s297o/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has either already completed a master’s or doctorate nursing program at an accredited school of nursing or is currently enrolled on a full-time or part-time basis in such a program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5fb9d89-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s297o/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purposes of this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s297n–1"},"text":"section 297n–1 of this title","children":[],"tail":", funding priority will be awarded to School of Nursing Student Loans "},{"tag":"ref","attrib":{"idref":"fn002307"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002307"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should not be capitalized."}],"tail":" that support doctoral nursing students or Individual Student Loan Repayment "},{"tag":"ref","attrib":{"idref":"fn002308"},"text":"3","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002308"},"text":null,"children":[{"tag":"num","attrib":{},"text":"3","children":[],"tail":" So in original. Probably should be “individual student loan repayments”."}],"tail":" that support doctoral nursing students."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5fb9d8a-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title VIII, § 847, as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tV/s5311/b"},"text":"Pub. L. 111–148, title V, § 5311(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/632"},"text":"124 Stat. 632","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/136/dA/tIII/s3404/a/10"},"text":"Pub. L. 116–136, div. A, title III, § 3404(a)(10)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-03-27"},"text":"Mar. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/394"},"text":"134 Stat. 394","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb5fb9d8b-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb5fb9d8c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb5fb9d8d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 847 of act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s297n"},"text":"section 297n of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/102/408"},"text":"Pub. L. 102–408","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior section 297q, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373/tVIII/s841"},"text":"act July 1, 1944, ch. 373, title VIII, § 841","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/392/tI/s123/5"},"text":"Pub. L. 105–392, title I, § 123(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3569"},"text":"112 Stat. 3569","children":[],"tail":", was renumbered section 871 of act "},{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", and amended by "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tV"},"text":"Pub. L. 111–148, title V","children":[],"tail":", §§ 5310(b)(7), 5312, "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/631"},"text":"124 Stat. 631","children":[],"tail":", 633, and transferred to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s298d"},"text":"section 298d of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb5fb9d8e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/136"},"text":"Pub. L. 116–136","children":[],"tail":" struck out subsec. (g). Text read as follows: “There are authorized to be appropriated to carry out this section such sums as may be necessary for each of fiscal years 2010 through 2014.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
