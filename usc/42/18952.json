{"tag":"section","attrib":{"id":"idc0713b63-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18952"},"text":null,"children":[{"tag":"num","attrib":{"value":"18952"},"text":"§ 18952.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standards development organization grants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc0713b64-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18952/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nongovernmental standards development organization defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “nongovernmental standards development organization” means a nongovernmental standards development organization (as defined in section 2(e) of the Office of Management and Budget Circular A–119 (relating to Federal participation in the development and use of voluntary consensus standards in conformity assessment activities), or any successor document) that adheres to the American National Standards Institute (ANSI) Essential Requirements for Due Process for American National Standards.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0713b65-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18952/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Commerce, acting through the Director, shall establish a competitive program of grants for nongovernmental standards development organizations for the purposes described in subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0713b66-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18952/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A grant awarded under subsection (b) shall be used to develop, approve, disseminate, maintain, and review forensic science voluntary consensus standards and best practices that shall be available to the public free of charge.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0713b67-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18952/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director may promulgate such requirements, guidelines, and procedures as may be necessary to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0713b68-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18952/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this section $2,000,000 for each of fiscal years 2022 through 2026.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc0713b69-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/tII/s10248"},"text":"Pub. L. 117–167, div. B, title II, § 10248","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1495"},"text":"136 Stat. 1495","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
