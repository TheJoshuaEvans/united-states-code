{"tag":"section","attrib":{"id":"idbc12e93f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2282c"},"text":null,"children":[{"tag":"num","attrib":{"value":"2282c"},"text":"§ 2282c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Worker health and safety rules for Department of Energy nuclear facilities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbc12e940-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2282c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations required","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc12e941-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2282c/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall promulgate regulations for industrial and construction health and safety at Department of Energy facilities that are operated by contractors covered by agreements of indemnification under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2210/d"},"text":"section 2210(d) of this title","children":[],"tail":", after public notice and opportunity for comment under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s553"},"text":"section 553 of title 5","children":[],"tail":" (commonly known as the “Administrative Procedure Act”). Such regulations shall, subject to paragraph (3), provide a level of protection for workers at such facilities that is substantially equivalent to the level of protection currently provided to such workers at such facilities."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc12e942-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2282c/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The regulations promulgated under paragraph (1) shall not apply to any facility that is a component of, or any activity conducted under, the Naval Nuclear Propulsion Program provided for under Executive Order No. 12344, dated ","children":[{"tag":"date","attrib":{"date":"1982-02-01"},"text":"February 1, 1982","children":[],"tail":" (as in force pursuant to section 1634 of the Department of Defense Authorization Act, 1985 ("},{"tag":"ref","attrib":{"href":"/us/pl/98/525"},"text":"Public Law 98–525","children":[],"tail":"))."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc12e943-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2282c/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Flexibility","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In promulgating the regulations under paragraph (1), the Secretary shall include flexibility—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc12e944-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2282c/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to tailor implementation of such regulations to reflect activities and hazards associated with a particular work environment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc12e945-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2282c/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to take into account special circumstances at a facility that is, or is expected to be, permanently closed and that is expected to be demolished, or title to which is expected to be transferred to another entity for reuse; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc12e946-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2282c/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to achieve national security missions of the Department of Energy in an efficient and timely manner.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc12e947-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2282c/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No effect on health and safety enforcement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This subsection does not diminish or otherwise affect the enforcement or the application of any other law, regulation, order, or contractual obligation relating to worker health and safety.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc12e948-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2282c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil penalties","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc12e949-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2282c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A person (or any subcontractor or supplier of the person) who has entered into an agreement of indemnification under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2210/d"},"text":"section 2210(d) of this title","children":[],"tail":" (or any subcontractor or supplier of the person) that violates (or is the employer of a person that violates) any regulation promulgated under subsection (a) shall be subject to a civil penalty of not more than $70,000 for each such violation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc12e94a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2282c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continuing violations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If any violation under this subsection is a continuing violation, each day of the violation shall constitute a separate violation for the purpose of computing the civil penalty under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc12e94b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2282c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contract penalties","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc12e94c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2282c/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall include in each contract with a contractor of the Department who has entered into an agreement of indemnification under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2210/d"},"text":"section 2210(d) of this title","children":[],"tail":" provisions that provide an appropriate reduction in the fees or amounts paid to the contractor under the contract in the event of a violation by the contractor or contractor employee of any regulation promulgated under subsection (a)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc12e94d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2282c/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provisions shall specify various degrees of violations and the amount of the reduction attributable to each degree of violation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc12e94e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2282c/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination of penalties","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc12e94f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2282c/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Choice of penalties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For any violation by a person of a regulation promulgated under subsection (a), the Secretary shall pursue either civil penalties under subsection (b) or contract penalties under subsection (c), but not both.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc12e950-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2282c/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of an entity described in subsection (d) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2282a"},"text":"section 2282a of this title","children":[],"tail":", the total amount of civil penalties under subsection (b) and contract penalties under subsection (c) in a fiscal year may not exceed the total amount of fees paid by the Department of Energy to that entity in that fiscal year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc12e951-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2282c/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2282a"},"text":"section 2282a of this title","children":[],"tail":null}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall ensure that a contractor of the Department is not penalized both under this section and under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2282a"},"text":"section 2282a of this title","children":[],"tail":" for the same violation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc12e952-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-08-01/ch724"},"text":"Aug. 1, 1946, ch. 724","children":[],"tail":", title I, § 234C, as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/314/dC/tXXXI/s3173/a"},"text":"Pub. L. 107–314, div. C, title XXXI, § 3173(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-02"},"text":"Dec. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2743"},"text":"116 Stat. 2743","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc12e953-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc12e954-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbc12e955-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Executive Order No. 12344, referred to in subsec. (a)(2), is set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s6102"},"text":"section 6102 of Title 10","children":[],"tail":", Armed Forces."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 1634 of the Department of Defense Authorization Act, 1985 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/525"},"text":"Public Law 98–525","children":[],"tail":"), referred to in subsec. (a)(2), was formerly set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s7158"},"text":"section 7158 of this title","children":[],"tail":", was renumbered "},{"tag":"ref","attrib":{"href":"/us/pl/107/314/s4101"},"text":"section 4101 of Pub. L. 107–314","children":[],"tail":" by Pub. L 108–136, div. C, title XXXI, § 3141(d)(2), "},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1757"},"text":"117 Stat. 1757","children":[],"tail":", and classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s2511"},"text":"section 2511 of Title 50","children":[],"tail":", War and National Defense, and was repealed and restated as "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s6102"},"text":"section 6102 of Title 10","children":[],"tail":", Armed Forces, by "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dC/tXXXI/s3111/a"},"text":"Pub. L. 119–60, div. C, title XXXI, § 3111(a)","children":[],"tail":", (b)(1), "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1340"},"text":"139 Stat. 1340","children":[],"tail":", 1458."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbc12e956-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbc12e957-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Promulgation of Initial Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/314/dC/tXXXI/s3173/b"},"text":"Pub. L. 107–314, div. C, title XXXI, § 3173(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-02"},"text":"Dec. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2745"},"text":"116 Stat. 2745","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/314/dC/tXXXI/s3173/b"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Deadline for promulgating regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Energy shall promulgate the regulations required by subsection a. of section 234C of the Atomic Energy Act of 1954 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2282c/a"},"text":"42 U.S.C. 2282c(a)","children":[],"tail":"] (as added by subsection (a)) not later than one year after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2002-12-02"},"text":"Dec. 2, 2002","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effective date","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The regulations promulgated under paragraph (1) shall take effect on the date that is one year after the promulgation date of the regulations.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbc12e958-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prohibition","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/314/dC/tXXXI/s3173/c"},"text":"Pub. L. 107–314, div. C, title XXXI, § 3173(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-02"},"text":"Dec. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2745"},"text":"116 Stat. 2745","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/314/dC/tXXXI/s3173/c"},"text":"“The Secretary of Energy shall not participate in or otherwise support any study or other project relating to a modification in the scope of the regulations enforceable by civil penalties under section 234A or 234C of the Atomic Energy Act of 1954 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2282a"},"text":"42 U.S.C. 2282a","children":[],"tail":", 2282c], or the responsibility of the Secretary to implement and enforce such regulations, until after the date on which the regulations for such purposes under such section 234C take effect in accordance with subsection (b) [set out as a note above].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
