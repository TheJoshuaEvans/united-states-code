{"tag":"section","attrib":{"id":"idbcc83021-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4364"},"text":null,"children":[{"tag":"num","attrib":{"value":"4364"},"text":"§ 4364.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expenditure of funds for research and development related to regulatory program activities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbcc83022-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4364/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination, etc., with research needs and priorities of program offices and Environmental Protection Agency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator of the Environmental Protection Agency shall assure that the expenditure of any funds appropriated pursuant to this Act or any other provision of law for environmental research and development related to regulatory program activities shall be coordinated with and reflect the research needs and priorities of the program offices, as well as the overall research needs and priorities of the Agency, including those defined in the five-year research plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcc83023-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4364/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program offices subject to coverage","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subsection (a), the appropriate program offices are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbcc83024-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4364/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Office of Air and Waste Management, for air quality activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcc83025-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4364/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Office of Water and Hazardous Materials, for water quality activities and water supply activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcc83026-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4364/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Office of Pesticides, for environmental effects of pesticides;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcc83027-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4364/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Office of Solid Waste, for solid waste activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcc83028-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4364/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Office of Toxic Substances, for toxic substance activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcc83029-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4364/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Office of Radiation Programs, for radiation activities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcc8302a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4364/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Office of Noise Abatement and Control, for noise activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcc8302b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4364/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress; contents","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall submit to the President and the Congress a report concerning the most appropriate means of assuring, on a continuing basis, that the research efforts of the Agency reflect the needs and priorities of the regulatory program offices, while maintaining a high level of scientific quality. Such report shall be submitted on or before ","children":[{"tag":"date","attrib":{"date":"1978-03-31"},"text":"March 31, 1978","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbcc8302c-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/155/s7"},"text":"Pub. L. 95–155, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-11-08"},"text":"Nov. 8, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1259"},"text":"91 Stat. 1259","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbcc8302d-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbcc8302e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbcc8302f-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in subsec. (a), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/155"},"text":"Pub. L. 95–155","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-11-08"},"text":"Nov. 8, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1257"},"text":"91 Stat. 1257","children":[],"tail":", known as the Environmental Research, Development, and Demonstration Authorization Act of 1978, which to the extent classified to the Code enacted sections 300j–3a, 4361a, 4361b, and 4363 to 4367 of this title. For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbcc83030-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Environmental Research, Development, and Demonstration Authorization Act of 1978, and not as part of the National Environmental Policy Act of 1969 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
