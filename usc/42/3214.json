{"tag":"section","attrib":{"id":"idbc79738b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3214"},"text":null,"children":[{"tag":"num","attrib":{"value":"3214"},"text":"§ 3214.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Delegation of functions and transfer of funds among Federal agencies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbc79738c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3214/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Delegation of functions to other Federal agencies","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc79738d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3214/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" delegate to the heads of other Federal agencies such functions, powers, and duties of the Secretary under this chapter as the Secretary determines to be appropriate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc79738e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3214/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" authorize the redelegation of the functions, powers, and duties by the heads of the agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc79738f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3214/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of funds to other Federal agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds authorized to be appropriated to carry out this chapter may be transferred between Federal agencies, if the funds are used for the purposes for which the funds are specifically authorized and appropriated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc797390-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3214/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of funds from other Federal agencies","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc797391-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3214/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (2), for the purposes of this chapter, the Secretary may accept transfers of funds from other Federal agencies if the funds are used for the purposes for which (and in accordance with the terms under which) the funds are specifically authorized and appropriated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc797392-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3214/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The transferred funds—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc797393-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3214/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall remain available until expended; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc797394-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3214/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may, to the extent necessary to carry out this chapter, be transferred to and merged by the Secretary with the appropriations for salaries and expenses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc797395-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/136/tVI/s604"},"text":"Pub. L. 89–136, title VI, § 604","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/393/tI/s102/a"},"text":"Pub. L. 105–393, title I, § 102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3614"},"text":"112 Stat. 3614","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc797396-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc797397-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbc797398-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 3214, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/136/tVII/s704"},"text":"Pub. L. 89–136, title VII, § 704","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-08-26"},"text":"Aug. 26, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/572"},"text":"79 Stat. 572","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/487/tI/s120"},"text":"Pub. L. 94–487, title I, § 120","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-12"},"text":"Oct. 12, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2336"},"text":"90 Stat. 2336","children":[],"tail":", related to transfer of functions of Area Redevelopment Administration, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/105/393/s102/b/3"},"text":"Pub. L. 105–393, § 102(b)(3)","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/136/s604"},"text":"section 604 of Pub. L. 89–136","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3204"},"text":"section 3204 of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/105/393/s102/a"},"text":"Pub. L. 105–393, § 102(a)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbc797399-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbc79739a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1999-02-11"},"text":"Feb. 11, 1999","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/393/s105"},"text":"section 105 of Pub. L. 105–393","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3121"},"te