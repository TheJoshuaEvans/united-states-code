{"tag":"section","attrib":{"id":"idc073abbf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18981"},"text":null,"children":[{"tag":"num","attrib":{"value":"18981"},"text":"§ 18981.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this subchapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc073abc0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18981/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Board","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Board” means the National Science Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc073abc1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18981/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Director” means the Director of the National Science Foundation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc073abc2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18981/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" NSF INCLUDES","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “NSF INCLUDES” means the initiative carried out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s19012"},"text":"section 19012 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc073abc3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18981/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" STEM ecosystem","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “STEM ecosystem” means a local, regional, or statewide network, consortium, or multi-sector partnership, which may be led or co-led by a nonprofit organizational entity, that is operating in the United States with the goal of supporting participation in STEM study, activities, and career pathways as defined in the CoSTEM Annual Progress Report of 2020 with a broad range of non-Federal partners.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc073abc4-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/tIII/s10302"},"text":"Pub. L. 117–167, div. B, title III, § 10302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1506"},"text":"136 Stat. 1506","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
