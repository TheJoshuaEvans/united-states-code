{"tag":"section","attrib":{"id":"idbd762250-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6247b"},"text":null,"children":[{"tag":"num","attrib":{"value":"6247b"},"text":"§ 6247b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purchase of oil from marginal wells","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd762251-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6247b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"From amounts authorized under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6246"},"text":"section 6246 of this title","children":[],"tail":", in any case in which the price of oil decreases to an amount less than $15.00 per barrel (an amount equal to the annual average well head price per barrel for all domestic crude oil), adjusted for inflation, the Secretary may purchase oil from a marginal well at $15.00 per barrel, adjusted for inflation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd762252-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6247b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of marginal well","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “marginal well” has the same meaning as the definition of “stripper well property” in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s613A/c/6/E"},"text":"section 613A(c)(6)(E) of title 26","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd762253-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/163/tI/s169"},"text":"Pub. L. 94–163, title I, § 169","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/469/tIII/s301/a"},"text":"Pub. L. 106–469, title III, § 301(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-09"},"text":"Nov. 9, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2037"},"text":"114 Stat. 2037","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
