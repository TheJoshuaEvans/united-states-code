{"tag":"section","attrib":{"id":"idbcc82f64-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336d"},"text":null,"children":[{"tag":"num","attrib":{"value":"4336d"},"text":"§ 4336d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" E-NEPA","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbcc82f65-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Permitting portal study","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Council on Environmental Quality shall conduct a study and submit a report to Congress within 1 year of the enactment of this Act ","children":[{"tag":"ref","attrib":{"idref":"fn003354"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003354"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" on the potential for online and digital technologies to address delays in reviews and improve public accessibility and transparency under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4332/2/C"},"text":"section 4332(2)(C) of this title","children":[],"tail":" including, but not limited to, a unified permitting portal that would—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbcc82f66-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336d/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" allow applicants to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbcc82f67-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336d/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit required documents or materials for their project in one unified portal;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcc82f68-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336d/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" upload and collaborate with the applicable agencies to edit documents in real-time, as required;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcc82f69-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336d/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" upload and display visual features such as video, animation, geographic information system displays, and three-dimensional renderings; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcc82f6a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336d/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" track the progress of individual applications;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcc82f6b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336d/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" include a cloud based, digital tool for more complex reviews that would enhance interagency coordination in consultation by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbcc82f6c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336d/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" centralizing, across all necessary agencies, the data, visuals, and documents, including but not limited to geographic information system displays, other visual renderings, and completed reports and analyses necessary for reviews;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcc82f6d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336d/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" streamlining communications between all necessary agencies and the applicant;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcc82f6e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336d/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allowing for comments and responses by and to all necessary agencies in one unified portal;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcc82f6f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336d/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" generating analytical reports to aid in organizing and cataloguing public comments; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcc82f70-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336d/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be ","children":[{"tag":"ref","attrib":{"idref":"fn003355"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003355"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be “being”."}],"tail":" accessible on mobile devices;"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcc82f71-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336d/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" boost transparency in agency processes and present information suitable for a lay audience, including but not limited to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbcc82f72-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336d/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" scientific data and analysis; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcc82f73-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336d/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" anticipated agency process and timeline; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcc82f74-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336d/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include examples describing how at least five permits would be reviewed and processed through this portal.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcc82f75-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated $500,000 for the Council on Environmental Quality to carry out the study directed by this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbcc82f76-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/190/tI/s110"},"text":"Pub. L. 91–190, title I, § 110","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/118/5/dC/tIII/s321/b"},"text":"Pub. L. 118–5, div. C, title III, § 321(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-06-03"},"text":"June 3, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/44"},"text":"137 Stat. 44","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbcc82f77-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbcc82f78-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbcc82f79-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The enactment of this Act, referred to in subsec. (a), probably means the enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/5"},"text":"Pub. L. 118–5","children":[],"tail":", which added this section to title I of "},{"tag":"ref","attrib":{"href":"/us/pl/91/190"},"text":"Pub. L. 91–190","children":[],"tail":" and was approved "},{"tag":"date","attrib":{"date":"2023-06-03"},"text":"June 3, 2023","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
