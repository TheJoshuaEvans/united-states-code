{"tag":"section","attrib":{"id":"idba7b31fd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396r–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1396r–1"},"text":"§ 1396r–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Presumptive eligibility for pregnant women","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idba7b31fe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396r–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ambulatory prenatal care","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State plan approved under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1396a"},"text":"section 1396a of this title","children":[],"tail":" may provide for making ambulatory prenatal care available to a pregnant woman during a presumptive eligibility period."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idba7b31ff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396r–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idba7b3200-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396r–1/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “presumptive eligibility period” means, with respect to a pregnant woman, the period that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idba7b3201-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396r–1/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" begins with the date on which a qualified provider determines, on the basis of preliminary information, that the family income of the woman does not exceed the applicable income level of eligibility under the State plan, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idba7b3202-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396r–1/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" ends with (and includes) the earlier of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idba7b3203-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396r–1/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the day on which a determination is made with respect to the eligibility of the woman for medical assistance under the State plan, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idba7b3204-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396r–1/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a woman who does not file an application by the last day of the month following the month during which the provider makes the determination referred to in subparagraph (A), such last day; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idba7b3205-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396r–1/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “qualified provider” means any provider that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idba7b3206-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396r–1/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is eligible for payments under a State plan approved under this subchapter,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idba7b3207-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396r–1/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides services of the type described in subparagraph (A) or (B) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1396d/a/2"},"text":"section 1396d(a)(2) of this title","children":[],"tail":" or in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1396d/a/9"},"text":"section 1396d(a)(9) of this title","children":[],"tail":","}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idba7b3208-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396r–1/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is determined by the State agency to be capable of making determinations of the type described in paragraph (1)(A), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idba7b3209-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396r–1/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idba7b320a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396r–1/b/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" receives funds under—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idba7b320b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396r–1/b/2/D/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 254b or 254c of this title,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idba7b320c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396r–1/b/2/D/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subchapter V of this chapter, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idba7b320d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396r–1/b/2/D/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" title V of the Indian Health Care Improvement Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1651"},"text":"25 U.S.C. 1651","children":[],"tail":" et seq.];"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idba7b320e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396r–1/b/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" participates in a program established under—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idba7b320f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396r–1/b/2/D/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1786"},"text":"section 1786 of this title","children":[],"tail":", or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idba7b3210-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396r–1/b/2/D/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 4(a) of the Agriculture and Consumer Protection Act of 1973;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idba7b3211-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396r–1/b/2/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" participates in a State perinatal program; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idba7b3212-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396r–1/b/2/D/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is the Indian Health Service or is a health program or facility operated by a tribe or tribal organization under the Indian Self-Determination Act (","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/638"},"text":"Public Law 93–638","children":[],"tail":") ["},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5321"},"text":"25 U.S.C. 5321","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The term “qualified provider” also includes a qualified entity, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1396r–1a/b/3"},"text":"section 1396r–1a(b)(3) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idba7b3213-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396r–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties of State agency, qualified providers, and presumptively eligible pregnant women","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idba7b3214-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396r–1/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The State agency shall provide qualified providers with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idba7b3215-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396r–1/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such forms as are necessary for a pregnant woman to make application for medical assistance under the State plan, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idba7b3216-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396r–1/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information on how to assist such women in completing and filing such forms.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idba7b3217-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396r–1/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A qualified provider that determines under subsection (b)(1)(A) that a pregnant woman is presumptively eligible for medical assistance under a State plan shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idba7b3218-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396r–1/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notify the State agency of the determination within 5 working days after the date on which determination is made, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idba7b3219-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396r–1/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inform the woman at the time the determination is made that she is required to make application for medical assistance under the State plan by not later than the last day of the month following the month during which the determination is made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idba7b321a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396r–1/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A pregnant woman who is determined by a qualified provider to be presumptively eligible for medical assistance under a State plan shall make application for medical assistance under such plan by not later than the last day of the month following the month during which the determination is made, which application may be the application used for the receipt of medical assistance by individuals described in section 1396a(","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(1)(A) of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idba7b321b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396r–1/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ambulatory prenatal care as medical assistance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of this subchapter, ambulatory prenatal care that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idba7b321c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396r–1/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is furnished to a pregnant woman—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idba7b321d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396r–1/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" during a presumptive eligibility period,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idba7b321e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396r–1/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by a provider that is eligible for payments under the State plan; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idba7b321f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396r–1/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is included in the care and services covered by a State plan;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be treated as medical assistance provided by such plan for purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1396b"},"text":"section 1396b of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idba7b3220-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396r–1/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Option to provide presumptive eligibility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the State has elected the option to provide a presumptive eligibility period under this section or ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1396r–1a"},"text":"section 1396r–1a of this title","children":[],"tail":", the State may elect to provide a presumptive eligibility period (as defined in subsection (b)(1)) for individuals who are eligible for medical assistance under clause (i)(VIII), clause (i)(IX), or clause (ii)(XX) of subsection (a)(10)(A) "},{"tag":"ref","attrib":{"idref":"fn003041"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003041"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably means subsection (a)(10)(A) of "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1396a"},"text":"section 1396a of this title","children":[],"tail":"."}],"tail":" or "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1396u–1"},"text":"section 1396u–1 of this title","children":[],"tail":" in the same manner as the State provides for such a period under this section or "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1396r–1a"},"text":"section 1396r–1a of this title","children":[],"tail":", subject to such guidance as the Secretary shall establish."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idba7b3221-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title XIX, § 1920, as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/509/tIX/s9407/b"},"text":"Pub. L. 99–509, title IX, § 9407(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-21"},"text":"Oct. 21, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2058"},"text":"100 Stat. 2058","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/360/tIV/s411/k/16/A"},"text":"Pub. L. 100–360, title IV, § 411(k)(16)(A)","children":[],"tail":", (B), "},{"tag":"date","attrib":{"date":"1988-07-01"},"text":"July 1, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/799"},"text":"102 Stat. 799","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/485/tVI/s608/d/26/L"},"text":"Pub. L. 100–485, title VI, § 608(d)(26)(L)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-13"},"text":"Oct. 13, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2422"},"text":"102 Stat. 2422","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/tIV/s4605/a"},"text":"Pub. L. 101–508, title IV, § 4605(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-169"},"text":"104 Stat. 1388–169","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/113/dB/s1000/a/6/tVI/s608/q"},"text":"Pub. L. 106–113, div. B, § 1000(a)(6) [title VI, § 608(q)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-29"},"text":"Nov. 29, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1536"},"text":"113 Stat. 1536","children":[],"tail":", 1501A–397; "},{"tag":"ref","attrib":{"href":"/us/pl/111/3/tI/s113/b/2"},"text":"Pub. L. 111–3, title I, § 113(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-02-04"},"text":"Feb. 4, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/34"},"text":"123 Stat. 34","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tII"},"text":"Pub. L. 111–148, title II","children":[],"tail":", §§ 2001(a)(4)(B), (e)(2)(C), 2004(b), "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/274"},"text":"124 Stat. 274","children":[],"tail":", 279, 283.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idba7b3222-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idba7b3223-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idba7b3224-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Indian Health Care Improvement Act, referred to in subsec. (b)(2)(D)(i)(III), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437"},"text":"Pub. L. 94–437","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-09-30"},"text":"Sept. 30, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1400"},"text":"90 Stat. 1400","children":[],"tail":". Title V of the Indian Health Care Improvement Act is classified generally to subchapter IV (§ 1651 et seq.) of chapter 18 of Title 25, Indians. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s1601"},"text":"section 1601 of Title 25","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 4(a) of the Agriculture and Consumer Protection Act of 1973, referred to in subsec. (b)(2)(D)(ii)(II), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/86/s4/a"},"text":"section 4(a) of Pub. L. 93–86","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-08-10"},"text":"Aug. 10, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/249"},"text":"87 Stat. 249","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s612c"},"text":"section 612c of Title 7","children":[],"tail":", Agriculture."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Indian Self-Determination Act (","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/638"},"text":"Public Law 93–638","children":[],"tail":"), referred to in subsec. (b)(2)(D)(iv), is title I of "},{"tag":"ref","attrib":{"href":"/us/pl/93/638"},"text":"Pub. L. 93–638","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-04"},"text":"Jan. 4, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2206"},"text":"88 Stat. 2206","children":[],"tail":", which is classified principally to subchapter I (§ 5321 et seq.) of chapter 46 of Title 25, Indians. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5301"},"text":"section 5301 of Title 25","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idba7b3225-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1920 of act ","children":[{"tag":"date","attrib":{"date":"1935-08-14"},"text":"Aug. 14, 1935","children":[],"tail":", was renumbered section 1939 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1396v"},"text":"section 1396v of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idba7b3226-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/s2004/b"},"text":"Pub. L. 111–148, § 2004(b)","children":[],"tail":", inserted “, clause (i)(IX),” after “clause (i)(VIII)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/s2001/e/2/C"},"text":"Pub. L. 111–148, § 2001(e)(2)(C)","children":[],"tail":", inserted “or clause (ii)(XX)” after “clause (i)(VIII)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/s2001/a/4/B"},"text":"Pub. L. 111–148, § 2001(a)(4)(B)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2009—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/3"},"text":"Pub. L. 111–3","children":[],"tail":" inserted concluding provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Subsec. (b)(2)(D)(i)(I). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/113"},"text":"Pub. L. 106–113","children":[],"tail":" substituted “section 254b or 254c of this title,” for “section 254b, 254c, or 256 of this title,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (b)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508/s4605/a/1"},"text":"Pub. L. 101–508, § 4605(a)(1)","children":[],"tail":", inserted “or” at end of cl. (i), redesignated cl. (iii) as (ii) and amended it generally, and struck out former cl. (ii). Prior to amendment, cls. (ii) and (iii) read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(ii) the day that is 45 days after the date on which the provider makes the determination referred to in subparagraph (A), or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(iii) in the case of a woman who does not file an application for medical assistance within 14 calendar days after the date on which the provider makes the determination referred to in subparagraph (A), the fourteenth calendar day after such determination is made; and”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508/s4605/a/2"},"text":"Pub. L. 101–508, § 4605(a)(2)","children":[],"tail":", substituted “by not later than the last day of the month following the month during which” for “within 14 calendar days after the date on which”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508/s4605/b"},"text":"Pub. L. 101–508, § 4605(b)","children":[],"tail":", inserted before period at end “, which application may be the application used for the receipt of medical assistance by individuals described in section 1396a("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(1)(A) of this title”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508/s4605/a/2"},"text":"Pub. L. 101–508, § 4605(a)(2)","children":[],"tail":", substituted “by not later than the last day of the month following the month during which” for “within 14 calendar days after the date on which”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (b)(2)(D)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/360/s411/k/16/B/i"},"text":"Pub. L. 100–360, § 411(k)(16)(B)(i)","children":[],"tail":", substituted “section 254b, 254c, or 256 of this title,” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t42/s254b"},"text":"section 254b of this title","children":[],"tail":" or "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s254c"},"text":"section 254c of this title","children":[],"tail":", or” in subcl. (I), substituted “chapter, or” for “chapter;” in subcl. (II), and added subcl. (III)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(D)(ii)(II). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/360/s411/k/16/B/ii"},"text":"Pub. L. 100–360, § 411(k)(16)(B)(ii)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/100/485/s608/d/26/L/i"},"text":"Pub. L. 100–485, § 608(d)(26)(L)(i)","children":[],"tail":", struck out “or” after “1973;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(D)(iii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/360/s411/k/16/B/iii"},"text":"Pub. L. 100–360, § 411(k)(16)(B)(iii)","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/100/485/s608/d/26/L/iii"},"text":"Pub. L. 100–485, § 608(d)(26)(L)(iii)","children":[],"tail":", substituted “program; or” for “program.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(D)(iv). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/360/s411/k/16/B/iv"},"text":"Pub. L. 100–360, § 411(k)(16)(B)(iv)","children":[],"tail":", formerly § 411(k)(16)(B)(iii), as redesignated by "},{"tag":"ref","attrib":{"href":"/us/pl/100/485/s608/d/26/L/ii"},"text":"Pub. L. 100–485, § 608(d)(26)(L)(ii)","children":[],"tail":", added cl. (iv)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/360/s411/k/16/A"},"text":"Pub. L. 100–360, § 411(k)(16)(A)","children":[],"tail":", substituted “by a provider that is eligible for payments under the State plan” for “by a qualified provider”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idba7b3227-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idba7b3228-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/s2004/b"},"text":"section 2004(b) of Pub. L. 111–148","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2014-01-01"},"text":"Jan. 1, 2014","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/s2004/d"},"text":"section 2004(d) of Pub. L. 111–148","children":[],"tail":", set out as an Effective and Termination Dates of 2010 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1396a"},"text":"s