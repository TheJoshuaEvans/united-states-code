12-19"},"text":"Dec. 19, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2814"},"text":"120 Stat. 2814","children":[],"tail":", 2820; "},{"tag":"ref","attrib":{"href":"/us/pl/111/87/s2/a/1"},"text":"Pub. L. 111–87, § 2(a)(1)","children":[],"tail":", (3)(A), "},{"tag":"date","attrib":{"date":"2009-10-30"},"text":"Oct. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2885"},"text":"123 Stat. 2885","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb6a28c76-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb6a28c77-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb6a28c78-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 264(c) of the Health Insurance Portability and Accountability Act of 1996, referred to in subsec. (b), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/191/s264/c"},"text":"section 264(c) of Pub. L. 104–191","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320d–2"},"text":"section 1320d–2 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb6a28c79-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 300ff–85, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373/tXXVI/s2685"},"text":"act July 1, 1944, ch. 373, title XXVI, § 2685","children":[],"tail