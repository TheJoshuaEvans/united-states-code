{"tag":"section","attrib":{"id":"idc067c4a4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18751"},"text":null,"children":[{"tag":"num","attrib":{"value":"18751"},"text":"§ 18751.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Infrastructure planning for micro and small modular nuclear reactors","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc067c4a5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18751/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc067c4a6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18751/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advanced nuclear reactor","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":" The term “advanced nuclear reactor” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16271/b"},"text":"section 16271(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc067c4a7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18751/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Isolated community","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “isolated community” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s17392/a"},"text":"section 17392(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc067c4a8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18751/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Micro-reactor","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “micro-reactor” means an advanced nuclear reactor that has an electric power production capacity that is not greater than 50 megawatts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc067c4a9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18751/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Laboratory","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “National Laboratory” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s15801"},"text":"section 15801 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc067c4aa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18751/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Small modular reactor","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “small modular reactor” means an advanced nuclear reactor—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc067c4ab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18751/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with a rated capacity of less than 300 electrical megawatts; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc067c4ac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18751/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that can be constructed and operated in combination with similar reactors at a single site.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc067c4ad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18751/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2021-11-15"},"text":"November 15, 2021","children":[],"tail":", the Secretary shall submit to the Committee on Energy and Natural Resources of the Senate and the Committees on Energy and Commerce and Science, Space, and Technology of the House of Representatives a report that describes how the Department could enhance energy resilience and reduce carbon emissions with the use of micro-reactors and small modular reactors."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc067c4ae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18751/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Elements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The report required by subsection (b) shall address the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc067c4af-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18751/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An evaluation by the Department of current resilience and carbon reduction requirements for energy for facilities of the Department to determine whether changes are needed to address—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc067c4b0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18751/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the need to provide uninterrupted power to facilities of the Department for at least 3 days during power grid failures;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc067c4b1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18751/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the need for protection against cyber threats and electromagnetic pulses; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc067c4b2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18751/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" resilience to extreme natural events, including earthquakes, volcanic activity, tornados, hurricanes, floods, tsunamis, lahars, landslides, seiches, a large quantity of snowfall, and very low or high temperatures.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc067c4b3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18751/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A strategy of the Department for using nuclear energy to meet resilience and carbon reduction goals of facilities of the Department.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc067c4b4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18751/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A strategy to partner with private industry to develop and deploy micro-reactors and small modular reactors to remote communities in order to replace diesel generation and other fossil fuels.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc067c4b5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18751/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An assessment by the Department of the value associated with enhancing the resilience of a facility of the Department by transitioning to power from micro-reactors and small modular reactors and to co-located nuclear facilities with the capability to provide dedicated power to the facility of the Department during a grid outage or failure.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc067c4b6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18751/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The plans of the Department—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc067c4b7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18751/c/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for deploying a micro-reactor and a small modular reactor to produce energy for use by a facility of the Department in the United States by 2026;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc067c4b8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18751/c/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for deploying a small modular reactor to produce energy for use by a facility of the Department in the United States by 2029; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc067c4b9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18751/c/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to include micro-reactors and small modular reactors in the planning for meeting future facility energy needs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc067c4ba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18751/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial and technical assistance for siting micro-reactors, small modular reactors, and advanced nuclear reactors","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc067c4bb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18751/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall offer financial and technical assistance to entities to conduct feasibility studies for the purpose of identifying suitable locations for the deployment of micro-reactors, small modular reactors, and advanced nuclear reactors in isolated communities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc067c4bc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18751/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Prior to providing financial and technical assistance under paragraph (1), the Secretary shall conduct robust community engagement and outreach for the purpose of identifying levels of interest in isolated communities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc067c4bd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18751/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall not disburse more than 50 percent of the amounts available for financial assistance under this subsection to the National Laboratories.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc067c4be-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dD/tIII/s40321"},"text":"Pub. L. 117–58, div. D, title III, § 40321","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1016"},"text":"135 Stat. 1016","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc067c4bf-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc067c4c0-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc067c4c1-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Wage Rate Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions relating to rates of wages to be paid to laborers and mechanics on projects for construction, alteration, or repair work funded under div. D or an amendment by div. D of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":", including authority of Secretary of Labor, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s18851"},"text":"section 18851 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
