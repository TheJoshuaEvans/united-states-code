{"tag":"section","attrib":{"id":"idbb817ed3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1856a–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1856a–1"},"text":"§ 1856a–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to enter into contracts with State and local governmental entities","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, in fiscal year 1992 and thereafter, the Secretary of the Interior, the Secretary of Agriculture, the Secretary of Energy, the Secretary of the Army, and the Secretary of the Smithsonian Institution are authorized to enter into contracts with State and local governmental entities, including local fire districts, for procurement of services in the presuppression, detection, and suppression of fires on any units within their jurisdiction.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbb817ed4-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/154/tIII/s309"},"text":"Pub. L. 102–154, title III, § 309","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-11-13"},"text":"Nov. 13, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1034"},"text":"105 Stat. 1034","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/114/tII/s2012"},"text":"Pub. L. 110–114, title II, § 2012","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-11-08"},"text":"Nov. 8, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1075"},"text":"121 Stat. 1075","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbb817ed5-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbb817ed6-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbb817ed7-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Department of the Interior and Related Agencies Appropriations Act, 1992, and not as part of act ","children":[{"tag":"date","attrib":{"date":"1955-05-27"},"text":"May 27, 1955","children":[],"tail":", which comprises this subchapter."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbb817ed8-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in the following prior appropriation act: ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/512/tIII/s310"},"text":"Pub. L. 101–512, title III, § 310","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1959"},"text":"104 Stat. 1959","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbb817ed9-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2007—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/114"},"text":"Pub. L. 110–114","children":[],"tail":" inserted “the Secretary of the Army,” after “the Secretary of Energy,”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
