{"tag":"section","attrib":{"id":"idbf879e68-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12645b"},"text":null,"children":[{"tag":"num","attrib":{"value":"12645b"},"text":"§ 12645b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Generation of volunteers","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In making decisions on applications for assistance or approved national service positions under the national service laws, the Corporation shall take into consideration the extent to which the applicant’s proposal will increase the involvement of volunteers in meeting community needs. In reviewing the application for this purpose, the Corporation may take into account the mission of the applicant.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbf879e69-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/610/tI/s188"},"text":"Pub. L. 101–610, title I, § 188","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/13/tI/s1612"},"text":"Pub. L. 111–13, title I, § 1612","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-04-21"},"text":"Apr. 21, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1538"},"text":"123 Stat. 1538","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf879e6a-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbf879e6b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbf879e6c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"