{"tag":"section","attrib":{"id":"idc052402c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18084"},"text":null,"children":[{"tag":"num","attrib":{"value":"18084"},"text":"§ 18084.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Premium tax credit and cost-sharing reduction payments disregarded for Federal and federally-assisted programs","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of determining the eligibility of any individual for benefits or assistance, or the amount or extent of benefits or assistance, under any Federal program or under any State or local program financed in whole or in part with Federal funds—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc052402d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18084/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any credit or refund allowed or made to any individual by reason of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s36B"},"text":"section 36B of title 26","children":[],"tail":" (as added by section 1401) "},{"tag":"ref","attrib":{"idref":"fn004341"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004341"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" shall not be taken into account as income and shall not be taken into account as resources for the month of receipt and the following 2 months; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc052402e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18084/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any cost-sharing reduction payment or advance payment of the credit allowed under such section 36B that is made under section 18071 or 18082 of this title shall be treated as made to the qualified health plan in which an individual is enrolled and not to that individual.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc052402f-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/tI/s1415"},"text":"Pub. L. 111–148, title I, § 1415","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/237"},"text":"124 Stat. 237","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc0524030-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc0524031-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc0524032-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 1401, referred to in par. (1), means ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/s1401"},"text":"section 1401 of Pub. L. 111–148","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
