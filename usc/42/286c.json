{"tag":"section","attrib":{"id":"idb581d9ae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s286c"},"text":null,"children":[{"tag":"num","attrib":{"value":"286c"},"text":"§ 286c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose, establishment, functions, and funding of National Center for Biotechnology Information","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb581d9af-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s286c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to focus and expand the collection, storage, retrieval, and dissemination of the results of biotechnology research by information systems, and to support and enhance the development of new information technologies to aid in the understanding of the molecular processes that control health and disease, there is established the National Center for Biotechnology Information (hereinafter in this section referred to as the “Center”) in the National Library of Medicine.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb581d9b0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s286c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, through the Center and subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s286/d"},"text":"section 286(d) of this title","children":[],"tail":", shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb581d9b1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s286c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" design, develop, implement, and manage automated systems for the collection, storage, retrieval, analysis, and dissemination of knowledge concerning human molecular biology, biochemistry, and genetics;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb581d9b2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s286c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" perform research into advanced methods of computer-based information processing capable of representing and analyzing the vast number of biologically important molecules and compounds;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb581d9b3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s286c/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enable persons engaged in biotechnology research and medical care to use systems developed under paragraph (1) and methods described in paragraph (2); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb581d9b4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s286c/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate, as much as is practicable, efforts to gather biotechnology information on an international basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb581d9b5-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title IV, § 478, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/607/tI/s105"},"text":"Pub. L. 100–607, title I, § 105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-04"},"text":"Nov. 4, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3052"},"text":"102 Stat. 3052","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/43/tXIV/s1402/b"},"text":"Pub. L. 103–43, title XIV, § 1402(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-06-10"},"text":"June 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/171"},"text":"107 Stat. 171","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb581d9b6-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb581d9b7-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb581d9b8-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1993—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/43"},"text":"Pub. L. 103–43","children":[],"tail":" struck out subsec. (c) which read as follows: “For the purpose of performing the duties specified in subsection (b) of this section, there are authorized to be appropriated $8,000,000 for fiscal year 1989 and such sums as may be necessary for fiscal year 1990. Funds appropriated under this subsection shall remain available until expended.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
