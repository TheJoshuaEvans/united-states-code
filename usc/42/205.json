of this title","children":[],"tail":". Office of Surgeon General reestablished within the Office of the Assistant Secretary for Health, see Notice of Department of Health and Human Services, Office of the Assistant Secretary for Health, "},{"tag":"date","attrib":{"date":"1987-03-30"},"text":"Mar. 30, 1987","children":[],"tail":", 52 F.R. 11754."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
