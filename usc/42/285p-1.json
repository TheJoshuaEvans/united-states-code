{"tag":"section","attrib":{"id":"idb57d1f2e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285p–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"285p–1"},"text":"§ 285p–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Associate Director for Prevention","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb57d1f2f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285p–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There shall be in the Institute an Associate Director for Prevention who shall be responsible for the full-time coordination and promotion of the programs in the Institute concerning the prevention of mental disorder. The Associate Director shall be appointed by the Director of the Institute from individuals who because of their professional training or expertise are experts in mental disorder and the prevention of such.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb57d1f30-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285p–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Associate Director for Prevention shall prepare for inclusion in the biennial report made under section 284b ","children":[{"tag":"ref","attrib":{"idref":"fn002203"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002203"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title a description of the prevention activities of the Institute, including a description of the staff and resources allocated to those activities."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb57d1f31-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title IV, § 464S, as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/321/tI/s124/b"},"text":"Pub. L. 102–321, title I, § 124(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-10"},"text":"July 10, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/365"},"text":"106 Stat. 365","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb57d1f32-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb57d1f33-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb57d1f34-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s284b"},"text":"Section 284b of this title","children":[],"tail":", referred to in subsec. (b), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/109/482/tI/s104/b/1/C"},"text":"Pub. L. 109–482, title I, § 104(b)(1)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-01-15"},"text":"Jan. 15, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3693"},"text":"120 Stat. 3693","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb57d1f35