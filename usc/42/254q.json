ttrib":{"topic":"amendments","id":"idb4fc55eb-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148"},"text":"Pub. L. 111–148","children":[],"tail":" amended subsec. (a) generally. Prior to amendment, subsec. (a) related to authorization of appropriations for the purposes of carrying out this subpart as follows: for fiscal year 2008, $131,500,000; for fiscal year 2009, $143,335,000; for fiscal year 2010, $156,235,150; for fiscal year 2011, $170,296,310; and for fiscal year 2012, $185,622,980."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/355"},"text":"Pub. L. 110–355","children":[],"tail":" substituted “appropriated—” for “appropriated $146,250,000 for fiscal year 2002, and such sums as may be necessary for each of fiscal years 2003 through 2006.” and added pars. (1) to (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/251"},"text":"Pub. L. 107–251","children":[],"tail":" amended section generally. Prior to amendment, section related to annual report to Congress, authorization of appropriations for fiscal years 1991 through 2000, and reservation of percentage of appropriated amounts for scholarships for new participants and for first-year study in certain fields."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/597/s205/a"},"text":"Pub. L. 101–597, § 205(a)","children":[],"tail":", substituted “March 1” for “January 20” and “5 fiscal years” for “3 fiscal years” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/597/s205/b"},"text":"Pub. L. 101–597, § 205(b)","children":[],"tail":", amended subsec. (b) generally. Prior to amendment, subsec. (b) read as follows: “There are authorized to be appropriated such sums as may be necessary for scholarships and loan repayments under this subpart.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
