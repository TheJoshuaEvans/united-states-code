{"tag":"section","attrib":{"id":"idb4fc55d8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254q"},"text":null,"children":[{"tag":"num","attrib":{"value":"254q"},"text":"§ 254q.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb4fc55d9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254q/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purpose of carrying out this section,","children":[{"tag":"ref","attrib":{"idref":"fn002093"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002093"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “subpart,”."}],"tail":" there is authorized to be appropriated, out of any funds in the Treasury not otherwise appropriated, the following:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4fc55da-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254q/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For fiscal year 2010, $320,461,632.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4fc55db-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254q/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For fiscal year 2011, $414,095,394.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4fc55dc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254q/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For fiscal year 2012, $535,087,442.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4fc55dd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254q/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For fiscal year 2013, $691,431,432.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4fc55de-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254q/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For fiscal year 2014, $893,456,433.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4fc55df-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254q/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For fiscal year 2015, $1,154,510,336.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4fc55e0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254q/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For fiscal year 2016, and each subsequent fiscal year, the amount appropriated for the preceding fiscal year adjusted by the product of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4fc55e1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254q/a/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one plus the average percentage increase in the costs of health professions education during the prior fiscal year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4fc55e2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254q/a/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one plus the average percentage change in the number of individuals residing in health professions shortage areas designated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s254f"},"text":"section 254f of this title","children":[],"tail":" during the prior fiscal year, relative to the number of individuals residing in such areas during the previous fiscal year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4fc55e3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254q/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scholarships for new participants","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Of the amounts appropriated under subsection (a) for a fiscal year, the Secretary shall obligate not less than 10 percent for the purpose of providing contracts for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4fc55e4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254q/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" scholarships under this subpart to individuals who have not previously received such scholarships; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4fc55e5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254q/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" scholarships or loan repayments under the Loan Repayment Program under section 254","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":"–1 of this title to individuals from disadvantaged backgrounds."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4fc55e6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254q/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scholarships and loan repayments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to certification as a nurse practitioner, nurse midwife, or physician assistant, the Secretary shall, from amounts appropriated under subsection (a) for a fiscal year, obligate not less than a total of 10 percent for contracts for both scholarships under the Scholarship Program under section 254","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":" of this title and loan repayments under the Loan Repayment Program under section 254"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"–1 of this title to individuals who are entering the first year of a course of study or program described in section 254"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"(b)(1)(B) of this title that leads to such a certification or individuals who are eligible for the loan repayment program as specified in section 254"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"–1(b) of this title for a loan related to such certification."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb4fc55e7-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title III, § 338H, formerly § 338G, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/177/tII/s203"},"text":"Pub. L. 100–177, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-01"},"text":"Dec. 1, 1987","children":[],"tail":", "},{"tag":"ref","attrib":