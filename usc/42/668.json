{"tag":"section","attrib":{"id":"idb7c7ab34-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s668"},"text":null,"children":[{"tag":"num","attrib":{"value":"668"},"text":"§ 668.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Encouragement of States to adopt civil procedure for establishing paternity in contested cases","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In the administration of the child support enforcement program under this part, each State is encouraged to establish and implement a civil procedure for establishing paternity in contested cases.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb7c7ab35-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title IV, § 468, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/485/tI/s111/d"},"text":"Pub. L. 100–485, title I, § 111(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-13"},"text":"Oct. 13, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2350"},"text":"102 Stat. 2350","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/193/tIII/s331/c"},"text":"Pub. L. 104–193, title III, § 331(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-22"},"text":"Aug. 22, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2230"},"text":"110 Stat. 2230","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb7c7ab36-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb7c7ab37-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}