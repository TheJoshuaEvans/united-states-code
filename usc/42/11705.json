{"tag":"section","attrib":{"id":"idbf556a30-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11705"},"text":null,"children":[{"tag":"num","attrib":{"value":"11705"},"text":"§ 11705.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Native Hawaiian health care systems","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf556a31-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11705/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Comprehensive health promotion, disease prevention, and primary health services","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf556a32-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11705/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf556a33-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11705/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary, in consultation with Papa Ola Lokahi, may make grants to, or enter into contracts with, any qualified entity for the purpose of providing comprehensive health promotion and disease prevention services as well as primary health services to Native Hawaiians.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf556a34-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11705/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In making grants and entering into contracts under this paragraph, the Secretary shall give preference to Native Hawaiian health care systems and Native Hawaiian organizations and, to the extent feasible, health promotion and disease prevention services shall be performed through Native Hawaiian health care systems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf556a35-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11705/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In addition to paragraph (1), the Secretary may make a grant to, or enter into a contract with, Papa Ola Lokahi for the purpose of planning Native Hawaiian health care systems to serve the health needs of Native Hawaiian communities on each of the islands of O’ahu, Moloka’i, Maui, Hawai’i, Lana’i, Kaua’i, and Ni’ihau in the State of Hawaii.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf556a36-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11705/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified entity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An entity is a qualified entity for purposes of subsection (a)(1) if the entity is a Native Hawaiian health care system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf556a37-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11705/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Services to be provided","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf556a38-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11705/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Each recipient of funds under subsection (a)(1) shall provide the following services:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf556a39-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11705/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" outreach services to inform Native Hawaiians of the availability of health services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf556a3a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11705/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" education in health promotion and disease prevention of the Native Hawaiian population by, wherever possible, Native Hawaiian health care practitioners, community outreach workers, counselors, and cultural educators;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf556a3b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11705/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" services of physicians, physicians’ assistants, nurse practitioners or other health professionals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf556a3c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11705/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" immunizations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf556a3d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11705/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prevention and control of diabetes, high blood pressure, and otitis media;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf556a3e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11705/c/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pregnancy and infant care; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf556a3f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11705/c/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improvement of nutrition.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf556a40-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11705/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In addition to the mandatory services under paragraph (1), the following services may be provided pursuant to subsection (a)(1):","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf556a41-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11705/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identification, treatment, control, and reduction of the incidence of preventable illnesses and conditions endemic to Native Hawaiians;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf556a42-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11705/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collection of data related to the prevention of diseases and illnesses among Native Hawaiians; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf556a43-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11705/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" services within the meaning of the terms “health promotion”, “disease prevention”, and “primary health services”, as such terms are defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11711"},"text":"section 11711 of this title","children":[],"tail":", which are not specifically referred to in paragraph (1) of this subsection."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf556a44-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11705/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The health care services referred to in paragraphs (1) and (2) which are provided under grants or contracts under subsection (a)(1) may be provided by traditional Native Hawaiian healers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf556a45-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11705/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Health and education","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In order to enable privately funded organizations to continue to supplement public efforts to provide educational programs designed to improve the health, capability, and well-being of Native Hawaiians and to continue to provide health services to Native Hawaiians, notwithstanding any other provision of Federal or State law, it shall be lawful for the private educational organization identified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7512/16"},"text":"section 7512(16) of title 20","children":[],"tail":" (as such section was in effect on the day before "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"December 10, 2015","children":[],"tail":") to continue to offer its educational programs and services to Native Hawaiians (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s7517"},"text":"section 7517 of title 20","children":[],"tail":") first and to others only after the need for such programs and services by Native Hawaiians has been met."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf556a46-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11705/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation of number of entities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"During a fiscal year, the Secretary under this chapter may make a grant to, or hold a contract with, not more than 5 Native Hawaiian health care systems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf556a47-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11705/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matching funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf556a48-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11705/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary may not make a grant or provide funds pursuant to a contract under subsection (a)(1) to a Native Hawaiian health care system—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf556a49-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11705/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in an amount exceeding 83.3 percent of the costs of providing health services under the grant or contract; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf556a4a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11705/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" unless the Native Hawaiian health care system agrees that the Native Hawaiian health care system or the State of Hawaii will make available, directly or through donations to the Native Hawaiian health care system, non-Federal contributions toward such costs in an amount equal to not less than $1 (in cash or in kind under paragraph (2)) for each $5 of Federal funds provided in such grant or contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf556a4b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11705/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Non-Federal contributions required in paragraph (1) may be in cash or in kind, fairly evaluated, including plant, equipment, or services. Amounts provided by the Federal Government or services assisted or subsidized to any significant extent by the Federal Government may not be included in determining the amount of such non-Federal contributions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf556a4c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11705/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary may waive the requirement established in paragraph (1) if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf556a4d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11705/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Native Hawaiian health care system involved is a nonprofit private entity described in subsection (b); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf556a4e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11705/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary, in consultation with Papa Ola Lokahi, determines that it is not feasible for the Native Hawaiian health care system to comply with such requirement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf556a4f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11705/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restriction on use of grant and contract funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may not make a grant to, or enter into a contract with, any entity under subsection (a)(1) unless the entity agrees that, amounts received pursuant to such subsection will not, directly or through contract, be expended—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf556a50-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11705/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for any purpose other than the purposes described in subsection (c);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf556a51-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11705/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide inpatient services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf556a52-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11705/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to make cash payments to intended recipients of health services; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf556a53-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11705/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to purchase or improve real property (other than minor remodeling of existing improvements to real property) or to purchase major medical equipment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf556a54-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11705/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on charges for services","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may not make a grant, or enter into a contract with, any entity under subsection (a)(1) unless the entity agrees that, whether health services are provided directly or through contract—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf556a55-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11705/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" health services under the grant or contract will be provided without regard to ability to pay for the health services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf556a56-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11705/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the entity will impose a charge for the delivery of health services, and such charge—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf556a57-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11705/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will be made according to a schedule of charges that is made available to the public, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf556a58-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11705/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will be adjusted to reflect the income of the individual involved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf556a59-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11705/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf556a5a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11705/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There are authorized to be appropriated such sums as may be necessary for fiscal years 1993 through 2019 to carry out subsection (a)(1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf556a5b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11705/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There are authorized to be appropriated such sums as may be necessary to carry out subsection (a)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf556a5c-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/579/s6"},"text":"Pub. L. 100–579, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-31"},"text":"Oct. 31, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2919"},"text":"102 Stat. 2919","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tII/s2306"},"text":"Pub. L. 100–690, title II, § 2306","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4226"},"text":"102 Stat. 4226","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/396/tIX/s9168"},"text":"Pub. L. 102–396, title IX, § 9168","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-06"},"text":"Oct. 6, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1948"},"text":"106 Stat. 1948","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tX/s10221/a"},"text":"Pub. L. 111–148, title X, § 10221(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/935"},"text":"124 Stat. 935","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tIX/s9215/jjj"},"text":"Pub. L. 114–95, title IX, § 9215(jjj)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2187"},"text":"129 Stat. 2187","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf556a5d-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf556a5e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbf556a5f-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7512/16"},"text":"Section 7512(16) of title 20","children":[],"tail":" (as such section was in effect on the day before "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"December 10, 2015","children":[],"tail":"), referred to in subsec. (c)(4), means "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s7512/16"},"text":"section 7512(16) of title 20","children":[],"tail":" prior to amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tVI"},"text":"Pub. L. 114–95, title VI","children":[],"tail":", §§ 6001(a), (b)(1), 6003(a), "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2046"},"text":"129 Stat. 2046","children":[],"tail":", 2063."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbf556a60-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendments by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148"},"text":"Pub. L. 111–148","children":[],"tail":" are based on section 202(a), (b)(1), of title II of S. 1790, One Hundred Eleventh Congress, as reported by the Committee on Indian Affairs of the Senate in Dec. 2009, which was enacted into law by "},{"tag":"ref","attrib":{"href":"/us/p