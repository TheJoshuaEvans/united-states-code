{"tag":"section","attrib":{"id":"idbf19e7e0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10204"},"text":null,"children":[{"tag":"num","attrib":{"value":"10204"},"text":"§ 10204.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subseabed disposal","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf19e7e1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10204/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repealed. ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/66/tI/s1051/d"},"text":"Pub. L. 104–66, title I, § 1051(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-21"},"text":"Dec. 21, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/716"},"text":"109 Stat. 716","children":[],"tail":null}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf19e7e2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10204/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of Subseabed Disposal Research","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf19e7e3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10204/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is hereby established an Office of Subseabed Disposal Research within the Office of Science of the Department of Energy. The Office shall be headed by the Director, who shall be a member of the Senior Executive Service appointed by the Director of the Office of Science, and compensated at a rate determined by applicable law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf19e7e4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10204/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of the Office of Subseabed Disposal Research shall be responsible for carrying out research, development, and demonstration activities on all aspects of subseabed disposal of high-level radioactive waste and spent nuclear fuel, subject to the general supervision of the Secretary. The Director of the Office shall be directly responsible to the Director of the Office of Science, and the first such Director shall be appointed within 30 days of ","children":[{"tag":"date","attrib":{"date":"1987-12-22"},"text":"December 22, 1987","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf19e7e5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10204/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In carrying out his responsibilities under this chapter, the Secretary may make grants to, or enter into contracts with, the Subseabed Consortium described in subsection (d) of this section, and other persons.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf19e7e6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10204/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf19e7e7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10204/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Within 60 days of ","children":[{"tag":"date","attrib":{"date":"1987-12-22"},"text":"December 22, 1987","children":[],"tail":", the Secretary shall establish a university-based Subseabed Consortium involving leading oceanographic universities and institutions, national laboratories, and other organizations to investigate the technical and institutional feasibility of subseabed disposal."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf19e7e8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10204/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Subseabed Consortium shall develop a research plan and budget to achieve the following objectives by 1995:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbf19e7e9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10204/b/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrate the capacity to identify and characterize potential subseabed disposal sites;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf19e7ea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10204/b/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop conceptual designs for a subseabed disposal system, including estimated costs and institutional requirements; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf19e7eb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10204/b/4/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify and assess the potential impacts of subseabed disposal on the human and marine environment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf19e7ec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10204/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In 1990, and again in 1995, the Subseabed Consortium shall report to Congress on the progress being made in achieving the objectives of paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf19e7ed-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/425/tII/s224"},"text":"Pub. L. 97–425, title II, § 224","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/202/s101/d/tIII"},"text":"Pub. L. 100–202, § 101(d) [title III]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1329-104"},"text":"101 Stat. 1329–104","children":[],"tail":", 1329–121; "},{"tag":"ref","attrib":{"href":"/us/pl/100/203/tV/s5063"},"text":"Pub. L. 100–203, title V, § 5063","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1330-253"},"text":"101 Stat. 1330–253","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/66/tI/s1051/d"},"text":"Pub. L. 104–66, title I, § 1051(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-21"},"text":"Dec. 21, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/716"},"text":"109 Stat. 716","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/245/tIII/s309/b/2/E"},"text":"Pub. L. 105–245, title III, § 309(b)(2)(E)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1853"},"text":"112 Stat. 1853","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf19e7ee-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf19e7ef-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbf19e7f0-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/202"},"text":"Pub. L. 100–202","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/100/203"},"text":"Pub. L. 100–203","children":[],"tail":" added identical sections."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbf19e7f1-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/245"},"text":"Pub. L. 105–245","children":[],"tail":" which directed the substitution of “Science” for “Energy Research”, was executed by making the substitution in two places to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/245"},"text":"Pub. L. 105–245","children":[],"tail":" substituted “Office of Science” for “Office of Energy Research”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1995—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/66"},"text":"Pub. L. 104–66","children":[],"tail":" struck out subsec. (a) which required Secretary of Energy to report to Congress on subseabed disposal of spent nuclear fuel and high-level radioactive waste."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/66"},"text":"Pub. L. 104–66","children":[],"tail":" struck out par. (5) which read as follows: “The Director of the Office of Subseabed Disposal Research shall annually prepare and submit a report to the Congress on the activities and expenditures of the Office.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
