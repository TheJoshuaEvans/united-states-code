{"tag":"section","attrib":{"id":"idbfee2868-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15972"},"text":null,"children":[{"tag":"num","attrib":{"value":"15972"},"text":"§ 15972.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loan to place Alaska clean coal technology facility in service","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfee2869-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15972/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfee286a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15972/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Borrower","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “borrower” means the owner of the clean coal technology plant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfee286b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15972/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Clean coal technology plant","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “clean coal technology plant” means the plant located near Healy, Alaska, constructed under Department cooperative agreement number DE–FC–22–91PC90544.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfee286c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15972/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost of a direct loan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “cost of a direct loan” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s661a/5/B"},"text":"section 661a(5)(B) of title 2","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfee286d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15972/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subsection (c), the Secretary shall use amounts made available under subsection (e) to provide the cost of a direct loan to the borrower for purposes of placing the clean coal technology plant into reliable operation for the generation of electricity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfee286e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15972/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfee286f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15972/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum loan amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of the direct loan provided under subsection (b) shall not exceed $80,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfee2870-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15972/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determinations by Secretary","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Before providing the direct loan to the borrower under subsection (b), the Secretary shall determine that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfee2871-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15972/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the plan of the borrower for placing the clean coal technology plant in reliable operation has a reasonable prospect of success;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfee2872-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15972/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of the loan (when combined with amounts available to the borrower from other sources) will be sufficient to carry out the project; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfee2873-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15972/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is a reasonable prospect that the borrower will repay the principal and interest on the loan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfee2874-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15972/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interest; term","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The direct loan provided under subsection (b) shall bear interest at a rate and for a term that the Secretary determines appropriate, after consultation with the Secretary of the Treasury, taking into account the needs and capacities of the borrower and the prevailing rate of interest for similar loans made by public and private lenders.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfee2875-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15972/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional terms and conditions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may require any other terms and conditions that the Secretary determines to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfee2876-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15972/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of payments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall retain any payments of principal and interest on the direct loan provided under subsection (b) to support energy research and development activities, to remain available until expended, subject to any other conditions in an applicable appropriations Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfee2877-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15972/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums as are necessary to provide the cost of a direct loan under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfee2878-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tIV/s412"},"text":"Pub. L. 109–58, title IV, § 412","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/754"},"text":"119 Stat. 754","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
