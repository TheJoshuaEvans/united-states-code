{"tag":"section","attrib":{"id":"idb5596a7d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s283f"},"text":null,"children":[{"tag":"num","attrib":{"value":"283f"},"text":"§ 283f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements regarding surveys of sexual behavior","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"With respect to any survey of human sexual behavior proposed to be conducted or supported through the National Institutes of Health, the survey may not be carried out unless—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5596a7e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s283f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the proposal has undergone review in accordance with any applicable requirements of sections 289 and 289a of this title; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5596a7f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s283f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Secretary, in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s289a–1"},"text":"section 289a–1 of this title","children":[],"tail":", makes a determination that the information expected to be obtained through the survey will assist—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5596a80-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s283f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in reducing the incidence of sexually transmitted diseases, the incidence of infection with the human immunodeficiency virus, or the incidence of any other infectious disease; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5596a81-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s283f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in improving reproductive health or other conditions of health.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5596a82-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title IV, § 404D, as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/43/tII/s207"},"text":"Pub. L. 103–43, title II, § 207","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-06-10"},"text":"June 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/148"},"text":"107 Stat. 148","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb5596a83-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb5596a84-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb5596a85-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prohibition Against SHARP Adult Sex Survey and American Teenage Sex Survey","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/43/tXX/s2015"},"text":"Pub. L. 103–43, title XX, § 2015","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-06-10"},"text":"June 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/217"},"text":"107 Stat. 217","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/43/tXX/s2015"},"text":"“The Secretary of Health and Human Services may not during fiscal year 1993 or any subsequent fiscal year conduct or support the SHARP survey of adult sexual behavior or the American Teenage Study of adolescent sexual behavior. This section becomes effective on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1993-06-10"},"text":"June 10, 1993","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
