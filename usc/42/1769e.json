{"tag":"section","attrib":{"id":"idbb698a38-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769e"},"text":null,"children":[{"tag":"num","attrib":{"value":"1769e"},"text":"§ 1769e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State childhood hunger challenge grants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbb698a39-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb698a3a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769e/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Child","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “child” means a person under the age of 18.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb698a3b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769e/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supplemental nutrition assistance program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “supplemental nutrition assistance program” means the supplemental nutrition assistance program established under the Food and Nutrition Act of 2008 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2011"},"text":"7 U.S.C. 2011","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb698a3c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Under such terms and conditions as are established by the Secretary, funds made available under this section may be used to competitively award grants to or enter into cooperative agreements with Governors to carry out comprehensive and innovative strategies to end childhood hunger, including alternative models for service delivery and benefit levels that promote the reduction or elimination of childhood hunger by 2015.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb698a3d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769e/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Projects","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"State demonstration projects carried out under this section may include projects that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb698a3e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769e/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhance benefits provided under the supplemental nutrition assistance program for eligible households with children;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb698a3f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769e/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhance benefits or provide for innovative program delivery models in the school meals, afterschool snack, and child and adult care food programs under this chapter and the Child Nutrition Act of 1966 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1771"},"text":"42 U.S.C. 1771","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb698a40-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769e/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" target Federal, State, or local assistance, including emergency housing, family preservation services, child care, or temporary assistance at households with children who are experiencing hunger or food insecurity, to the extent permitted by the legal authority establishing those assistance programs and services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb698a41-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769e/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhance outreach to increase access and participation in Federal nutrition assistance programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb698a42-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769e/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve the coordination of Federal, State, and community resources and services aimed at preventing food insecurity and hunger, including through the establishment and expansion of State food policy councils.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb698a43-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769e/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb698a44-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769e/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out this section, the Secretary may competitively award grants or enter into competitively awarded cooperative agreements with Governors for use in accordance with demonstration projects that meet the purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb698a45-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769e/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be eligible to receive a grant or cooperative agreement under this section, a Governor shall submit to the Secretary an application at such time, in such manner, and containing such information as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb698a46-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769e/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall evaluate proposals based on publicly disseminated criteria that may include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbb698a47-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769e/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an identification of a low-income target group that reflects individuals experiencing hunger or food insecurity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb698a48-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769e/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a commitment to approaches that allow for a rigorous outcome evaluation as described in subsection (f);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb698a49-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769e/d/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a comprehensive and innovative strategy to reduce the risk of childhood hunger or provide a significant improvement to the food security status of households with children; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb6bfa4a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769e/d/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other criteria as are determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb6bfa4b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769e/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any project funded under this section shall provide for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbb6bfa4c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769e/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a baseline assessment, and subsequent annual assessments, of the prevalence and severity of very low food security among children in the State, based on a methodology prescribed by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb6bfa4d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769e/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a collaborative planning process including key stakeholders in the State that results in a comprehensive agenda to eliminate childhood hunger that is—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbb6bfa4e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769e/d/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" described in a detailed project plan; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbb6bfa4f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769e/d/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provided to the Secretary for approval;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb6bfa50-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769e/d/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an annual budget;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb6bfa51-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769e/d/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specific performance goals, including the goal to sharply reduce or eliminate food insecurity among children in the State by 2015, as determined through a methodology prescribed by the Secretary and carried out by the Governor; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb6bfa52-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769e/d/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an independent outcome evaluation of not less than 1 major strategy of the project that measures—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbb6bfa53-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769e/d/4/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the specific impact of the strategy on food insecurity among children in the State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbb6bfa54-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769e/d/4/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if applicable, the nutrition assistance participation rate among children in the State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb6bfa55-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769e/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In determining the range of projects and defining selection criteria under this section, the Secretary shall consult with—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb6bfa56-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769e/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Health and Human Services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb6bfa57-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769e/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Labor;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb6bfa58-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769e/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Education; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb6bfa59-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769e/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Housing and Urban Development.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb6bfa5a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769e/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation and reporting","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb6bfa5b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769e/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General performance assessment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each project authorized under this section shall require an independent assessment that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbb6bfa5c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769e/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" measures the impact of any activities carried out under the project on the level of food insecurity in the State that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbb6bfa5d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769e/f/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" focuses particularly on the level of food insecurity among children in the State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbb6bfa5e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769e/f/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes a preimplementation baseline and annual measurements taken during the project of the level of food insecurity in the State; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb6bfa5f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769e/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is carried out using a methodology prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb6bfa60-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769e/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Independent evaluation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each project authorized under this section shall provide for an independent evaluation of not less than 1 major strategy that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbb6bfa61-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769e/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" measures the impact of the strategy on appropriate participation, food security, nutrition, and associated behavioral outcomes among participating households; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb6bfa62-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769e/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" uses rigorous experimental designs and methodologies, particularly random assignment or other methods that are capable of producing scientifically valid information regarding which activities are effective in reducing the prevalence or preventing the incidence of food insecurity and hunger in the community, especially among children.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb6bfa63-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769e/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2011-12-31"},"text":"December 31, 2011","children":[],"tail":" and each December 31 thereafter until the date on which the last evaluation under paragraph (1) is completed, the Secretary shall—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbb6bfa64-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769e/f/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" submit to the Committee on Agriculture and the Committee on Education and Labor of the House of Representatives and the Committee on Agriculture, Nutrition, and Forestry of the Senate a report that includes a description of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbb6bfa65-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769e/f/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the status of each State demonstration project; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbb6bfa66-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769e/f/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the results of any evaluations of the demonstration projects completed during the previous fiscal year; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb6bfa67-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769e/f/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that the evaluation results are shared broadly to inform policy makers, service providers, other partners, and the public in order to promote the wide use of successful strategies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb6bfa68-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769e/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb6bfa69-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769e/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this section such sums as are necessary for each of fiscal years 2011 through 2014, to remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb6bfa6a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769e/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds made available under paragraph (1) may be used to carry out this section, including to pay Federal costs associated with developing, soliciting, awarding, monitoring, evaluating, and disseminating the results of each demonstration project under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb6bfa6b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769e/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbb6bfa6c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769e/g/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No project may be funded under this section for more than 5 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb6bfa6d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769e/g/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Performance basis","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds provided under this section shall be made available to each Governor on an annual basis, with the amount of funds provided for each year contingent on the satisfactory implementation of the project plan and progress towards the performance goals defined in the project year plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb6bfa6e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769e/g/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Altering nutrition assistance program requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No project that makes use of, alters, or coordinates with the supplemental nutrition assistance program may be funded under this section unless the project is fully consistent with the project requirements described in section 17(b)(1)(B) of the Food and Nutrition Act of 2008 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2026/b/1/B"},"text":"7 U.S.C. 2026(b)(1)(B)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb6bfa6f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769e/g/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other benefits","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Funds made available under this section may not be used for any project in a manner that is inconsistent with—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbb6bfa70-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769e/g/3/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbb6bfa71-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769e/g/3/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Child Nutrition Act of 1966 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1771"},"text":"42 U.S.C. 1771","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbb6bfa72-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769e/g/3/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Food and Nutrition Act of 2008 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2011"},"text":"7 U.S.C. 2011","children":[],"tail":" et seq.); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbb6bfa73-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769e/g/3/D/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Emergency Food Assistance Act of 1983 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7501"},"text":"7 U.S.C. 7501","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbb6bfa74-3a70-11f1-ae07-e4213316b5fa"