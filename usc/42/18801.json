{"tag":"section","attrib":{"id":"idc06c7f6e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18801"},"text":null,"children":[{"tag":"num","attrib":{"value":"18801"},"text":"§ 18801.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Building, training, and assessment centers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc06c7f6f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18801/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall provide grants to institutions of higher education (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of title 20","children":[],"tail":") and Tribal Colleges or Universities (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1059c/b"},"text":"section 1059c(b) of title 20","children":[],"tail":") to establish building training and assessment centers—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc06c7f70-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18801/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to identify opportunities for optimizing energy efficiency and environmental performance in buildings;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06c7f71-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18801/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to promote the application of emerging concepts and technologies in commercial and institutional buildings;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06c7f72-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18801/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to train engineers, architects, building scientists, building energy permitting and enforcement officials, and building technicians in energy-efficient design and operation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06c7f73-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18801/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assist institutions of higher education and Tribal Colleges or Universities in training building technicians;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06c7f74-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18801/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to promote research and development for the use of alternative energy sources and distributed generation to supply heat and power for buildings, particularly energy-intensive buildings; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06c7f75-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18801/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to coordinate with and assist State-accredited technical training centers, community colleges, Tribal Colleges or Universities, and local offices of the National Institute of Food and Agriculture and ensure appropriate services are provided under this section to each region of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc06c7f76-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18801/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination and nonduplication","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc06c7f77-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18801/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall coordinate the program with the industrial research and assessment centers program under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s17116"},"text":"section 17116 of this title","children":[],"tail":" and with other Federal programs to avoid duplication of effort."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06c7f78-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18801/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collocation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the maximum extent practicable, building, training, and assessment centers established under this section shall be collocated with industrial research and assessment centers (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s18811"},"text":"section 18811 of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc06c7f79-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18801/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to the Secretary to carry out this section $10,000,000 for fiscal year 2022, to remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc06c7f7a-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dD/tV/s40512"},"text":"Pub. L. 117–58, div. D, title V, § 40512","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1059"},"text":"135 Stat. 1059","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc06c7f7b-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc06c7f7c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc06c7f7d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Wage Rate Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions relating to rates of wages to be paid to laborers and mechanics on projects for construction, alteration, or repair work funded under div. D or an amendment by div. D of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":", including authority of Secretary of Labor, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s18851"},"text":"section 18851 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
