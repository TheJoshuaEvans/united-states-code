{"tag":"section","attrib":{"id":"idbefaed76-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858b"},"text":null,"children":[{"tag":"num","attrib":{"value":"9858b"},"text":"§ 9858b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lead agency","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbefaed77-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Governor of a State desiring to receive a grant under this subchapter shall designate an agency (which may be an appropriate collaborative agency), or establish a joint interagency office, that complies with the requirements of subsection (b) to serve as the lead agency for the State under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbefaed78-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbefaed79-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The lead agency shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbefaed7a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858b/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" administer, directly or through other governmental or nongovernmental agencies, the financial assistance received under this subchapter by the State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbefaed7b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858b/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop the State plan to be submitted to the Secretary under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s9858c/a"},"text":"section 9858c(a) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbefaed7c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858b/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in conjunction with the development of the State plan as required under subparagraph (B), hold at least one hearing in the State with sufficient time and Statewide distribution of the notice of such hearing, to provide to the public an opportunity to comment on the provision of child care services under the State plan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbefaed7d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858b/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate the provision of services under this subchapter with other Federal, State and local child care and early childhood development programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbefaed7e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858b/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at the option of an Indian tribe or tribal organization in the State, collaborate and coordinate with such Indian tribe or tribal organization in the development of the State plan in a timely manner.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbefaed7f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Development of plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the development of the State plan described in paragraph (1)(B), the lead agency shall consult with appropriate representatives of units of general purpose local government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbefaed80-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35/tVI/s658D"},"text":"Pub. L. 97–35, title VI, § 658D","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/tV/s5082/2"},"text":"Pub. L. 101–508, title V, § 5082(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-236"},"text":"104 Stat. 1388–236","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/401/s3/a"},"text":"Pub. L. 102–401, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-07"},"text":"Oct. 7, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1959"},"text":"106 Stat. 1959","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/586/s8/c/1"},"text":"Pub. L. 102–586, § 8(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-11-04"},"text":"Nov. 4, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/5036"},"text":"106 Stat. 5036","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/193/tVI/s604"},"text":"Pub. L. 104–193, title VI, § 604","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-22"},"text":"Aug. 22, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2281"},"text":"110 Stat. 2281","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/186/s4"},"text":"Pub. L. 113–186, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-11-19"},"text":"Nov. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1972"},"text":"128 Stat. 1972","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbefaed81-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbefaed82-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbefaed83-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/186/s4/a"},"text":"Pub. L. 113–186, § 4(a)","children":[],"tail":", substituted “Governor” for “chief executive officer” and “designate an agency (which may be an appropriate collaborative agency), or establish a joint interagency office, that complies with the requirements of subsection (b) to serve as the lead agency for the State under this subchapter” for “designate, in an application submitted to the Secretary under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s9858c"},"text":"section 9858c of this title","children":[],"tail":", an appropriate State agency that complies with the requirements of subsection (b) of this section to act as the lead agency”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/186/s4/b"},"text":"Pub. L. 113–186, § 4(b)","children":[],"tail":", added subpar. (E)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (b)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/193/s604/1/A"},"text":"Pub. L. 104–193, § 604(1)(A)","children":[],"tail":", substituted “governmental or nongovernmental agencies” for “State agencies”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/193/s604/1/B"},"text":"Pub. L. 104–193, § 604(1)(B)","children":[],"tail":", inserted “with sufficient time and Statewide distribution of the notice of such hearing,” after “hearing in the State”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/193/s604/2"},"text":"Pub. L. 104–193, § 604(2)","children":[],"tail":", struck out at end “Such consultations may include consideration of local child care needs and resources, the effectiveness of existing child care and early childhood development services, and the methods by which funds made available under this subchapter can be used to effectively address local shortages.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/401"},"text":"Pub. L. 102–401","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/102/586"},"text":"Pub. L. 102–586","children":[],"tail":" made identical technical corrections to directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/s5082/2"},"text":"Pub. L. 101–508, § 5082(2)","children":[],"tail":", which added this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbefaed84-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbefaed85-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/193"},"text":"Pub. L. 104–193","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1996-10-01"},"text":"Oct. 1, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/193/s615"},"text":"section 615 of Pub. L. 104–193","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s9858"},"text":"section 9858 of this title","children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
