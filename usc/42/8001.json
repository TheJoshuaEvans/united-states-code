{"tag":"section","attrib":{"id":"idbe77b3da-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8001"},"text":null,"children":[{"tag":"num","attrib":{"value":"8001"},"text":"§ 8001.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional findings","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe77b3db-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8001/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" congregate housing, coordinated with the delivery of supportive services, offers an innovative, proven, and cost-effective means of enabling temporarily disabled or handicapped individuals to maintain their dignity and independence and to avoid costly and unnecessary institutionalization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe77b3dc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8001/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a large and growing number of elderly and handicapped residents of public housing projects and of nonprofit projects for the elderly and handicapped face premature and unnecessary institutionalization because of the absence of or deficiencies in the availability, adequacy, coordination, or delivery of the supportive services required for the successful development of adequate numbers of congregate housing projects; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe77b3dd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8001/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supplemental supportive services, available on a secure and continuing basis, are essential to a successful congregate housing program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbe77b3de-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/557/tIV/s402"},"text":"Pub. L. 95–557, title IV, § 402","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-31"},"text":"Oct. 31, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2104"},"text":"92 Stat. 2104","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbe77b3df-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbe77b3e0-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idbe77b3e1-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2011 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/374/s1/a"},"text":"Pub. L. 111–374, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4089"},"text":"124 Stat. 4089","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/374/s1/a"},"text":"“This Act [amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s8013"},"text":"section 8013 of this title","children":[],"tail":" and enacting provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s8013"},"text":"section 8013 of this title","children":[],"tail":"] may be cited as the ‘Frank Melville Supportive Housing Investment Act of 2010’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"idbe77b3e2-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/557/tIV/s401"},"text":"Pub. L. 95–557, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-31"},"text":"Oct. 31, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2104"},"text":"92 Stat. 2104","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/95/557/tIV/s401"},"text":"“This title [enacting this chapter and amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1437e"},"text":"section 1437e of this title","children":[],"tail":"] may be cited as the ‘Congregate Housing Services Act of 1978’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
