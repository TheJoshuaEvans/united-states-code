{"tag":"section","attrib":{"id":"idbf721976-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12521"},"text":null,"children":[{"tag":"num","attrib":{"value":"12521"},"text":"§ 12521.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purpose of this part is to promote service-learning as a strategy to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf721977-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12521/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support high-quality service-learning projects that engage students in meeting community needs with demonstrable results, while enhancing students’ academic and civic learning; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf721978-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12521/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support efforts to build institutional capacity, including the training of educators, and to strengthen the service infrastructure to expand service opportunities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf721979-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/610/tI/s111"},"text":"Pub. L. 101–610, title I, § 111","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/13/tI/s1201"},"text":"Pub. L. 111–13, title I, § 1201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-04-21"},"text":"Apr. 21, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1467"},"text":"123 Stat. 1467","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf72197a-3a70-11f1-ae