{"tag":"section","attrib":{"id":"idbc5f347b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032i"},"text":null,"children":[{"tag":"num","attrib":{"value":"3032i"},"text":"§ 3032i.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Demonstration and support projects for legal assistance for older individuals","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbc5f347c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032i/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program authorized","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Assistant Secretary shall make grants and enter into contracts, in order to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc5f347d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032i/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide a national legal assistance support system (operated by one or more grantees or contractors) of activities to State and area agencies on aging for providing, developing, or supporting legal assistance for older individuals, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc5f347e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032i/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" case consultations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc5f347f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032i/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" training;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc5f3480-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032i/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provision of substantive legal advice and assistance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc5f3481-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032i/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assistance in the design, implementation, and administration of legal assistance delivery systems to local providers of legal assistance for older individuals; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc5f3482-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032i/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support demonstration projects to expand or improve the delivery of legal assistance to older individuals with social or economic needs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc5f3483-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032i/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assurances","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any grants or contracts made under subsection (a)(2) shall contain assurances that the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3027/a/11"},"text":"section 3027(a)(11) of this title","children":[],"tail":" are met."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc5f3484-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032i/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To carry out subsection (a)(1), the Assistant Secretary shall make grants to or enter into contracts with nonprofit organizations experienced in providing support and technical assistance on a nationwide basis to States, area agencies on aging, legal assistance providers, ombudsmen, elder abuse prevention programs, and other organizations interested in the legal rights of older individuals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc5f3485-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/73/tIV/s420"},"text":"Pub. L. 89–73, title IV, § 420","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/501/tIV/s401"},"text":"Pub. L. 106–501, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-13"},"text":"Nov. 13, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2265"},"text":"114 Stat. 2265","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/144/s5/c"},"text":"Pub. L. 114–144, § 5(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-04-19"},"text":"Apr. 19, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/342"},"text":"130 Stat. 342","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc5f3486-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc5f3487-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbc5f3488-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/73/s420"},"text":"section 420 of Pub. L. 89–73","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3034"},"text":"section 3034 of this title","children":[],"tail":", prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/106/501"},"text":"Pub. L. 106–501","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbc5f3489-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/144"},"text":"Pub. L. 114–144","children":[],"tail":" struck out “national” before “nonprofit organizations”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
