{"tag":"section","attrib":{"id":"idc00d20da-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16313"},"text":null,"children":[{"tag":"num","attrib":{"value":"16313"},"text":"§ 16313.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Solar Fuels Research Initiative","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc00d20db-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16313/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initiative","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc00d20dc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16313/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall carry out a research initiative, to be known as the “Solar Fuels Research Initiative” (referred to in this section as the “Initiative”) to expand theoretical and fundamental knowledge of photochemistry, electrochemistry, biochemistry, and materials science useful for the practical development of experimental systems to convert solar energy to chemical energy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00d20dd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16313/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Leveraging","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out programs and activities under the Initiative, the Secretary shall leverage expertise and resources from—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc00d20de-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16313/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Basic Energy Sciences Program and the Biological and Environmental Research Program of the Office of Science; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00d20df-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16313/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Office of Energy Efficiency and Renewable Energy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00d20e0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16313/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Teams","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc00d20e1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16313/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out the Initiative, the Secretary shall organize activities among multidisciplinary teams to leverage, to the maximum extent practicable, expertise from the National Laboratories, institutions of higher education, and the private sector.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00d20e2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16313/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Goals","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The multidisciplinary teams described in subparagraph (A) shall pursue aggressive, milestone-driven, basic research goals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00d20e3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16313/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Resources","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide sufficient resources to the multidisciplinary teams described in subparagraph (A) to achieve the goals described in subparagraph (B) over a period of time to be determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00d20e4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16313/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may organize additional activities under this subsection through Energy Frontier Research Centers, Energy Innovation Hubs, or other organizational structures.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc00d20e5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16313/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Artificial photosynthesis","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc00d20e6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16313/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall carry out under the Initiative a program to support research needed to bridge scientific barriers to, and discover knowledge relevant to, artificial photosynthetic systems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00d20e7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16313/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As part of the program described in paragraph (1)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc00d20e8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16313/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Director of the Office of Basic Energy Sciences shall support basic research to pursue distinct lines of scientific inquiry, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc00d20e9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16313/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" photoinduced production of hydrogen and oxygen from water; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc00d20ea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16313/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the sustainable photoinduced reduction of carbon dioxide to fuel products including hydrocarbons, alcohols, carbon monoxide, and natural gas; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00d20eb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16313/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Assistant Secretary for Energy Efficiency and Renewable Energy shall support translational research, development, and validation of physical concepts developed under the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00d20ec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16313/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standard of review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall review activities carried out under the program described in paragraph (1) to determine the achievement of technical milestones.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00d20ed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16313/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the funds authorized to be appropriated for basic energy sciences in a fiscal year, there is authorized to be appropriated to the Secretary to carry out activities under this subsection $50,000,000 for each of fiscal years 2023 through 2027.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc00d20ee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16313/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Biochemistry, replication of natural photosynthesis, and related processes","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc00d20ef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16313/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall carry out under the Initiative a program to support research needed to replicate natural photosynthetic processes by use of artificial photosynthetic components and materials.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00d20f0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16313/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As part of the program described in paragraph (1)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc00d20f1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16313/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Director of the Office of Basic Energy Sciences shall support basic research to expand fundamental knowledge to replicate natural synthesis processes, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc00d20f2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16313/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the photoinduced reduction of dinitrogen to ammonia;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc00d20f3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16313/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the absorption of carbon dioxide from ambient air;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc00d20f4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16313/c/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" molecular-based charge separation and storage;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc00d20f5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16313/c/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" photoinitiated electron transfer; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc00d20f6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16313/c/2/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" catalysis in biological or biomimetic systems;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00d20f7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16313/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Associate Director of Biological and Environmental Research shall support systems biology and genomics approaches to understand genetic and physiological pathways connected to photosynthetic mechanisms; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00d20f8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16313/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Assistant Secretary for Energy Efficiency and Renewable Energy shall support translational research, development, and validation of physical concepts developed under the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00d20f9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16313/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standard of review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall review activities carried out under the program described in paragraph (1) to determine the achievement of technical milestones.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00d20fa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16313/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the funds authorized to be appropriated for basic energy sciences in a fiscal year, there is authorized to be appropriated to the Secretary to carry out activities under this subsection $50,000,000 for each of fiscal years 2023 through 2027.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc00d20fb-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tIX/s973"},"text":"Pub. L. 109–58, title IX, § 973","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/902"},"text":"119 Stat. 902","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/246/tIII/s303/f/1"},"text":"Pub. L. 115–246, title III, § 303(f)(1)","children":[],"tail":", formerly § 303(d)(1), "},{"tag":"date","attrib":{"date":"2018-09-28"},"text":"Sept. 28, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3141"},"text":"132 Stat. 3141","children":[],"tail":", renumbered § 303(f)(1), "},{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/tI/s10102/a/1"},"text":"Pub. L. 117–167, div. B, title I, § 10102(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1409"},"text":"136 Stat. 1409","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/tI/s10102/b"},"text":"Pub. L. 117–167, div. B, title I, § 10102(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1414"},"text":"136 Stat. 1414","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc00d20fc-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc00d20fd-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc00d20fe-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/s10102/b/1"},"text":"Pub. L. 117–167, § 10102(b)(1)","children":[],"tail":", added par. (4) and struck out former par. (4). Prior to amendment, text read as follows: “No funds allocated to the program described in paragraph (1) may be obligated or expended for commercial application of energy technology.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/s10102/b/2"},"text":"Pub. L. 117–167, § 10102(b)(2)","children":[],"tail":", added par. (4) and struck out former par. (4). Prior to amendment, text read as follows: “No funds allocated to the program described in paragraph (1) may be obligated or expended for commercial application of energy technology.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/246"},"text":"Pub. L. 115–246","children":[],"tail":" amended section generally. Prior to amendment, section related to catalysis research program."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
