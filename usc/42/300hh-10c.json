{"tag":"section","attrib":{"id":"idb6cd6c1f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–10c"},"text":null,"children":[{"tag":"num","attrib":{"value":"300hh–10c"},"text":"§ 300hh–10c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Advisory Committee on Seniors and Disasters","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb6cd6c20-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–10c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in consultation with the Secretary of Homeland Security and the Secretary of Veterans Affairs, shall establish an advisory committee to be known as the National Advisory Committee on Seniors and Disasters (referred to in this section as the “Advisory Committee”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6cd6c21-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–10c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Advisory Committee shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6cd6c22-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–10c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide advice and consultation with respect to the activities carried out pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300hh–16"},"text":"section 300hh–16 of this title","children":[],"tail":", as applicable and appropriate;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6cd6c23-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–10c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluate and provide input with respect to the medical and public health needs of seniors related to preparation for, response to, and recovery from all-hazards emergencies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6cd6c24-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–10c/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide advice and consultation with respect to State emergency preparedness and response activities relating to seniors, including related drills and exercises pursuant to the preparedness goals under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300hh–1/b"},"text":"section 300hh–1(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6cd6c25-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–10c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional duties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Advisory Committee may provide advice and recommendations to the Secretary with respect to seniors and the medical and public health grants and cooperative agreements as applicable to preparedness and response activities under this subchapter and subchapter III.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6cd6c26-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–10c/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6cd6c27-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–10c/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in consultation with such other heads of agencies as appropriate, shall appoint not more than 17 members to the Advisory Committee. In appointing such members, the Secretary shall ensure that the total membership of the Advisory Committee is an odd number.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6cd6c28-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–10c/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required members","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Advisory Committee shall include Federal members or their designees (who may be nonvoting members, as determined by the Secretary) and non-Federal members, as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6cd6c29-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–10c/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Assistant Secretary for Preparedness and Response.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6cd6c2a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–10c/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of the Biomedical Advanced Research and Development Authority.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6cd6c2b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–10c/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of the Centers for Disease Control and Prevention.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6cd6c2c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–10c/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Commissioner of Food and Drugs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6cd6c2d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–10c/d/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of the National Institutes of Health.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6cd6c2e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–10c/d/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Administrator of the Centers for Medicare & Medicaid Services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6cd6c2f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–10c/d/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Administrator of the Administration for Community Living.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6cd6c30-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–10c/d/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Administrator of the Federal Emergency Management Agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6cd6c31-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–10c/d/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Under Secretary for Health of the Department of Veterans Affairs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6cd6c32-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–10c/d/2/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" At least 2 non-Federal health care professionals with expertise in geriatric medical disaster planning, preparedness, response, or recovery.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6cd6c33-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–10c/d/2/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" At least 2 representatives of State, local, Tribal, or territorial agencies with expertise in geriatric disaster planning, preparedness, response, or recovery.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6cd6c34-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–10c/d/2/L"},"text":null,"children":[{"tag":"num","attrib":{"value":"L"},"text":"(L)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Representatives of such other Federal agencies (such as the Department of Energy and the Department of Homeland Security) as the Secretary determines necessary to fulfill the duties of the Advisory Committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6cd6c35-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–10c/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Advisory Committee shall meet not less frequently than biannually. At least one meeting per year shall be an in-person meeting.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6cd6c36-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–10c/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall coordinate duties and activities authorized under this section in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300hh–10e"},"text":"section 300hh–10e of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6cd6c37-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–10c/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sunset","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6cd6c38-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–10c/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Advisory Committee shall terminate on ","children":[{"tag":"date","attrib":{"date":"2026-12-31"},"text":"December 31, 2026","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6cd6c39-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–10c/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extension of Committee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2022-10-01"},"text":"October 1, 2022","children":[],"tail":", the Secretary shall submit to Congress a recommendation on whether the Advisory Committee should be extended."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb6cd6c3a-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XXVIII, § 2811B, as added "},{"tag":"ref","attrib":{"href":"/us/pl/116/22/tIII/s305/b"},"text":"Pub. L. 116–22, title III, § 305(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-06-24"},"text":"June 24, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/938"},"text":"133 Stat. 938","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/118/15/dB/tIII/s2333/b"},"text":"Pub. L. 118–15, div. B, title III, § 2333(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-09-30"},"text":"Sept. 30, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/96"},"text":"137 Stat. 96","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/22/dB/tII/s203/d/2"},"text":"Pub. L. 118–22, div. B, title II, § 203(d)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-11-17"},"text":"Nov. 17, 2023","children":[],"tail":", "},{"