{"tag":"section","attrib":{"id":"idbd60c65c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5843"},"text":null,"children":[{"tag":"num","attrib":{"value":"5843"},"text":"§ 5843.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of Nuclear Reactor Regulation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd60c65d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5843/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment; appointment of Director","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is hereby established in the Commission an Office of Nuclear Reactor Regulation under the direction of a Director of Nuclear Reactor Regulation, who shall be appointed by the Commission, who may report directly to the Commission, as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5849"},"text":"section 5849 of this title","children":[],"tail":", and who shall serve at the pleasure of and be removable by the Commission."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd60c65e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5843/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions of Director","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to the provisions of this chapter, the Director of Nuclear Reactor Regulation shall perform such functions as the Commission shall delegate, including the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd60c65f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5843/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Principal licensing and regulation involving all facilities, and materials licensed under the Atomic Energy Act of 1954, as amended [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2011"},"text":"42 U.S.C. 2011","children":[],"tail":" et seq.], associated with the construction and operation of nuclear reactors licensed under the Atomic Energy Act of 1954, as amended;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd60c660-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5843/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Review the safety and safeguards of all such facilities, materials, and activities, and such review functions shall include, but not be limited to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd60c661-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5843/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" monitoring, testing and recommending upgrading of systems designed to prevent substantial health or safety hazards; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd60c662-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5843/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluating methods of transporting special nuclear and other nuclear materials and of transporting and storing high-level radioactive wastes to prevent radiation hazards to employees and the general public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd60c663-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5843/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Recommend research necessary to fulfill the licensing and regulatory oversight functions of the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd60c664-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5843/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Licensing process","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the principal licensing and regulation functions under subsection (b)(1), the Director of Nuclear Reactor Regulation shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd60c665-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5843/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish techniques and guidance for evaluating applications for licenses for nuclear reactors to support efficient, timely, and predictable reviews of applications for those licenses to enable the safe and secure use of nuclear reactors;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd60c666-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5843/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain the techniques and guidance established under paragraph (1) by periodically assessing and, if necessary, modifying those techniques and guidance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd60c667-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5843/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" obtain approval from the Commission if establishment or modification of the techniques and guidance under paragraph (1) or (2) involves policy formulation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd60c668-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5843/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibility for safe operation of facilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed to limit in any way the functions of the Administration relating to the safe operation of all facilities resulting from all activities within the jurisdiction of the Administration pursuant to this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd60c669-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/438/tII/s203"},"text":"Pub. L. 93–438, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-10-11"},"text":"Oct. 11, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1244"},"text":"88 Stat. 1244","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/67/dB/tV/s505/a"},"text":"Pub. L. 118–67, div. B, title V, § 505(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-07-09"},"text":"July 9, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1477"},"text":"138 Stat. 1477","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd60c66a-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd60c66b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbd60c66c-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsecs. (b) and (d), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/438"},"text":"Pub. L. 93–438","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-10-11"},"text":"Oct. 11, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1233"},"text":"88 Stat. 1233","children":[],"tail":", known as the Energy Reorganization Act of 1974, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5801"},"text":"section 5801 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Atomic Energy Act of 1954, referred to in subsec. (b)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-08-01/ch724"},"text":"act Aug. 1, 1946, ch. 724","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/act/1954-08-30/ch1073/s1"},"text":"act Aug. 30, 1954, ch. 1073, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/919"},"text":"68 Stat. 919","children":[],"tail":", which is classified principally to chapter 23 (§ 2011 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2011"},"text":"section 2011 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd60c66d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/67/s505/a/1"},"text":"Pub. L. 118–67, § 505(a)(1)","children":[],"tail":", inserted heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/67/s505/a/2/A"},"text":"Pub. L. 118–67, § 505(a)(2)(A)","children":[],"tail":", inserted heading and substituted “delegate, including the following:” for “delegate including:” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/67/s505/a/2/B"},"text":"Pub. L. 118–67, § 505(a)(2)(B)","children":[],"tail":", substituted “to fulfill the licensing and regulatory oversight” for “for the discharge of the”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/67/s505/a/3"},"text":"Pub. L. 118–67, § 505(a)(3)","children":[],"tail":", (4), added subsec. (c), redesignated former subsec. (c) as (d), and inserted heading in subsec. (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idbd60c66e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"idbd60c66f-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of certain functions from Nuclear Regulatory Commission to Chairman thereof, see Reorg. Plan No. 1 of 1980, 45 F.R. 40561, ","children":[{"tag":"ref","attrib":{"href":"/us/stat/94/3585"},"text":"94 Stat. 3585","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5841"},"text":"section 5841 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
