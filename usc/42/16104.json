{"tag":"section","attrib":{"id":"idbff2e2fe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16104"},"text":null,"children":[{"tag":"num","attrib":{"value":"16104"},"text":"§ 16104.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reduction of engine idling","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbff2e2ff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16104/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbff2e300-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16104/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrator","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Administrator” means the Administrator of the Environmental Protection Agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff2e301-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16104/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advanced truck stop electrification system","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “advanced truck stop electrification system” means a stationary system that delivers heat, air conditioning, electricity, or communications, and is capable of providing verifiable and auditable evidence of use of those services, to a heavy-duty vehicle and any occupants of the heavy-duty vehicle with or without relying on components mounted onboard the heavy-duty vehicle for delivery of those services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff2e302-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16104/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Auxiliary power unit","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “auxiliary power unit” means an integrated system that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbff2e303-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16104/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides heat, air conditioning, engine warming, or electricity to components on a heavy-duty vehicle; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff2e304-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16104/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is certified by the Administrator under part 89 of title 40, Code of Federal Regulations (or any successor regulation), as meeting applicable emission standards.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff2e305-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16104/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Heavy-duty vehicle","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “heavy-duty vehicle” means a vehicle that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbff2e306-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16104/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a gross vehicle weight rating greater than 8,500 pounds; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff2e307-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16104/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is powered by a diesel engine.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff2e308-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16104/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Idle reduction technology","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “idle reduction technology” means an advanced truck stop electrification system, auxiliary power unit, or other technology that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbff2e309-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16104/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is used to reduce long-duration idling; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff2e30a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16104/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allows for the main drive engine or auxiliary refrigeration engine to be shut down.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff2e30b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16104/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Energy conservation technology","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"the ","children":[{"tag":"ref","attrib":{"idref":"fn004207"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004207"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be capitalized."}],"tail":" term “energy conservation technology” means any device, system of devices, or equipment that improves the fuel economy."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff2e30c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16104/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Long-duration idling","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbff2e30d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16104/a/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “long-duration idling” means the operation of a main drive engine or auxiliary refrigeration engine, for a period greater than 15 consecutive minutes, at a time at which the main drive engine is not engaged in gear.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff2e30e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16104/a/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “long-duration idling” does not include the operation of a main drive engine or auxiliary refrigeration engine during a routine stoppage associated with traffic movement or congestion.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff2e30f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16104/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Idle reduction technology benefits, programs, and studies","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbff2e310-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16104/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":", the Administrator shall—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbff2e311-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16104/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbff2e312-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16104/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" commence a review of the mobile source air emission models of the Environmental Protection Agency used under the Clean Air Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7401"},"text":"42 U.S.C. 7401","children":[],"tail":" et seq.) to determine whether the models accurately reflect the emissions resulting from long-duration idling of heavy-duty vehicles and other vehicles and engines; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbff2e313-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16104/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" update those models as the Administrator determines to be appropriate; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff2e314-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16104/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbff2e315-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16104/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" commence a review of the emission reductions achieved by the use of idle reduction technology; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbff2e316-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16104/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" complete such revisions of the regulations and guidance of the Environmental Protection Agency as the Administrator determines to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff2e317-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16104/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deadline for completion","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":", the Administrator shall—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbff2e318-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16104/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" complete the reviews under subparagraphs (A)(i) and (B)(i) of paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff2e319-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16104/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prepare and make publicly available one or more reports on the results of the reviews.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff2e31a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16104/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Discretionary inclusions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The reviews under subparagraphs (A)(i) and (B)(i) of paragraph (1) and the reports under paragraph (2)(B) may address the potential fuel savings resulting from use of idle reduction technology.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff2e31b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16104/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Idle reduction and energy conservation deployment program","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbff2e31c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16104/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbff2e31d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16104/b/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":", the Administrator, in consultation with the Secretary of Transportation shall, through the Environmental Protection Agency’s SmartWay Transport Partnership, establish a program to support deployment of idle reduction and energy conservation technologies."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbff2e31e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16104/b/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall give priority to the deployment of idle reduction and energy conservation technologies based on the costs and beneficial effects on air quality and ability to lessen the emission of criteria air pollutants.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff2e31f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16104/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbff2e320-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16104/b/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to the Administrator to carry out subparagraph (A) for the purpose of reducing extended idling from heavy-duty vehicles $19,500,000 for fiscal year 2006, $30,000,000 for fiscal year 2007, and $45,000,000 for fiscal year 2008.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbff2e321-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16104/b/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Locomotives","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to the administrator to carry out subparagraph (A) for the purpose of reducing extended idling from locomotives $10,000,000 for fiscal year 2006, $15,000,000 for fiscal year 2007, and $20,000,000 for fiscal year 2008.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbff2e322-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16104/b/4/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost sharing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to clause (iv), the Administrator shall require at least 50 percent of the costs directly and specifically related to any project under this section to be provided from non-Federal sources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbff2e323-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16104/b/4/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Necessary and appropriate reductions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator may reduce the non-Federal requirement under clause (iii) if the Administrator determines that the reduction is necessary and appropriate to meet the objectives of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff2e324-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16104/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Idling location study","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbff2e325-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16104/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":", the Administrator, in consultation with the Secretary of Transportation, shall commence a study to analyze all locations at which heavy-duty vehicles stop for long-duration idling, including—"}],"tail":null},{"tag":"clause","attrib":{"id":"idbff2e326-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16104/b/5/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" truck stops;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbff2e327-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16104/b/5/A/ii"},"text":null,"children":[{"tag"