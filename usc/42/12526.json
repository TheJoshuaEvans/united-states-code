{"tag":"section","attrib":{"id":"idbf7219e8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12526"},"text":null,"children":[{"tag":"num","attrib":{"value":"12526"},"text":"§ 12526.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consideration of applications","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf7219e9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12526/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria for local applications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In providing assistance under this part, a State educational agency, territory, or Indian tribe (or the Corporation if ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12524/c"},"text":"section 12524(c) of this title","children":[],"tail":" applies) shall consider criteria with respect to sustainability, replicability, innovation, and quality of programs."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf7219ea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12526/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority for local applications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In providing assistance under this part, a State educational agency, territory, or Indian tribe (or the Corporation if ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12524/c"},"text":"section 12524(c) of this title","children":[],"tail":" applies) shall give priority to entities that submit applications under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12525"},"text":"section 12525 of this title","children":[],"tail":" with respect to service-learning programs described in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12521"},"text":"section 12521 of this title","children":[],"tail":" that are in the greatest need of assistance, such as programs targeting low-income areas or serving economically disadvantaged youth."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf7219eb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12526/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rejection of applications to Corporation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Corporation rejects an application submitted by a State, territory, or Indian tribe under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12525"},"text":"section 12525 of this title","children":[],"tail":" for an allotment, the Corporation shall promptly notify the State, territory, or Indian tribe of the reasons for the rejection of the application. The Corporation shall provide the State, territory, or Indian tribe with a reasonable opportunity to revise and resubmit the application and shall provide technical assistance, if needed, to the State, territory, or Indian tribe as part of the resubmission process. The Corporation shall promptly reconsider such resubmitted application."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf7219ec-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/610/tI/s114"},"text":"Pub. L. 101–610, title I, § 114","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/13/tI/s1201"},"text":"Pub. L. 111–13, title I, § 1201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-04-21"},"text":"Apr. 21, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1472"},"text":"123 Stat. 1472","children":[],"t