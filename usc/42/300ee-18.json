{"tag":"section","attrib":{"id":"idb68a975c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–18"},"text":null,"children":[{"tag":"num","attrib":{"value":"300ee–18"},"text":"§ 300ee–18.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to comply with agreements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb68a975d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–18/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repayment of payments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb68a975e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–18/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may, subject to subsection (c), require a State to repay any payments received by the State under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ee–11/a"},"text":"section 300ee–11(a) of this title","children":[],"tail":" that the Secretary determines were not expended by the State in accordance with the agreements required to be contained in the application submitted by the State pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ee–13"},"text":"section 300ee–13 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb68a975f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–18/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If a State fails to make a repayment required in paragraph (1), the Secretary may offset the amount of the repayment against the amount of any payment due to be paid to the State under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ee–11/a"},"text":"section 300ee–11(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb68a9760-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–18/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Withholding of payments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb68a9761-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–18/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may, subject to subsection (c), withhold payments due under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ee–11/a"},"text":"section 300ee–11(a) of this title","children":[],"tail":" if the Secretary determines that the State involved is not expending amounts received under such section in accordance with the agreements required to be contained in the application submitted by the State pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ee–13"},"text":"section 300ee–13 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb68a9762-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–18/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall cease withholding payments from a State under paragraph (1) if the Secretary determines that there are reasonable assurances that the State will expend amounts received under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ee–11/a"},"text":"section 300ee–11(a) of this title","children":[],"tail":" in accordance with the agreements referred to in such paragraph."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb68a9763-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–18/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may not withhold funds under paragraph (1) from a State for a minor failure to comply with the agreements referred to in such paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb68a9764-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–18/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Opportunity for hearing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Before requiring repayment of payments under subsection (a)(1), or withholding payments under subsection (b)(1), the Secretary shall provide to the State an opportunity for a hearing conducted within the State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb68a9765-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–18/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prompt response to serious allegations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall promptly respond to any complaint of a substantial or serious nature that a State has failed to expend amounts received under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ee–11/a"},"text":"section 300ee–11(a) of this title","children":[],"tail":" in accordance with the agreements required to be contained in the application submitted by the State pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ee–13"},"text":"section 300ee–13 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb68a9766-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–18/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investigations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb68a9767-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–18/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall conduct in several States in each fiscal year investigations of the expenditure of payments received by the States under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ee–11/a"},"text":"section 300ee–11(a) of this title","children":[],"tail":" in order to evaluate compliance with the agreements required to be contained in the applications submitted to the Secretary pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ee–13"},"text":"section 300ee–13 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb68a9768-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–18/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Comptroller General of the United States may conduct investigations of the expenditure of funds received under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ee–11/a"},"text":"section 300ee–11(a) of this title","children":[],"tail":" by a State in order to ensure compliance with the agreements referred to in paragraph (1)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb68a9769-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–18/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each State, and each entity receiving funds from payments made to a State under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ee–11/a"},"text":"section 300ee–11(a) of this title","children":[],"tail":", shall make appropriate books, documents, papers, and records available to the Secretary and the Comptroller General of the United States, or any of their duly authorized representatives, for examination, copying, or mechanical reproduction on or off the premises of the appropriate entity upon a reasonable request therefor."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb68a976a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–18/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb68a976b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–18/e/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In conducting any investigation in a State, the Secretary and the Comptroller General of the United States may not make a request for any information not readily available to the State, or to an entity receiving funds from payments made to the State under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ee–11/a"},"text":"section 300ee–11(a) of this title","children":[],"tail":", or make an unreasonable request for information to be compiled, collected, or transmitted in any form not readily available."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb68a976c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–18/e/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subparagraph (A) shall not apply to the collection, compilation, or transmittal of data in the course of a judicial proceeding.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb68a976d-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XXV, formerly title XV, § 2508, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/607/tII/s221"},"text":"Pub. L. 100–607, title II, § 221","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-04"},"text":"Nov. 4, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3099"},"text":"102 Stat. 3099","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tII/s2619/f"},"text":"Pub. L. 100–690, title II, § 2619(f) [(g)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4243"},"text":"102 Stat. 4243","children":[],"tail":"; renumbered title XXV, "},{"tag":"ref","attrib":{"href":"/us/pl/101/93/s5/e/1"},"text":"Pub. L. 101–93, § 5(e)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-08-16"},"text":"Aug. 16, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/612"},"text":"103 Stat. 612","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb68a976e-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb68a976f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb68a9770-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2508 of act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", was successively renumbered by subsequent acts, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s238g"},"text":"section 238g of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb68a9771-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690/s2619/f/1/s1"},"text":"Pub. L. 100–690, § 2619(f)(1) [(g)(1)]","children":[],"tail":", substituted “300ee–13 of this title” for “300ee–17 of this title”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690/s2619/f/2/s2"},"text":"Pub. L. 100–690, § 2619(f)(2) [(g)(2)]","children":[],"tail":", inserted “of payments” after “Withholding” in heading and substituted “300ee–13 of this title” for “300ee–17 of this title” in par. (1)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (d), (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690/s2619/f/3"},"text":"Pub. L. 100–690, § 2619(f)(3)","children":[],"tail":", (4) [(g)(3), (4)], substituted “300ee–13 of this title” for “300ee–17 of this title”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb68a9772-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb68a9773-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690"},"text":"Pub. L. 100–690","children":[],"tail":" effective immediately after enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/100/607"},"text":"Pub. L. 100–607","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"1988-11-04"},"text":"Nov. 4, 1988","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/s2600"},"text":"section 2600 of Pub. L. 100–690","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s242m"},"text":"section 242m of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
