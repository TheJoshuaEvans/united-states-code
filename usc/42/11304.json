{"tag":"section","attrib":{"id":"idbf400d03-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11304"},"text":null,"children":[{"tag":"num","attrib":{"value":"11304"},"text":"§ 11304.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation by Comptroller General","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Comptroller General of the United States may evaluate the disbursement and use of the amounts made available by appropriation Acts under the authorizations in subchapters III and IV.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbf400d04-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/77/tI/s105"},"text":"Pub. L. 100–77, title I, § 105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-07-22"},"text":"July 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/486"},"text":"101 Stat. 486","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/628/tI/s102/a"},"text":"Pub. L. 100–628, title I, § 102(a)","children":[],"tail":", (b)(1), "},{"tag":"date","attrib":{"date":"1988-11-07"},"text":"Nov. 7, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3227"},"text":"102 Stat. 3227","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/316/tI/s122/t"},"text":"Pub. L. 104–316, title I, § 122(t)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-19"},"text":"Oct. 19, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3838"},"text":"110 Stat. 3838","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf400d05-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf400d06-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attri