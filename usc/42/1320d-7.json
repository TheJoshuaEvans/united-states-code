{"tag":"section","attrib":{"id":"idb860420f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–7"},"text":null,"children":[{"tag":"num","attrib":{"value":"1320d–7"},"text":"§ 1320d–7.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect on State law","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8604210-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–7/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General effect","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8604211-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–7/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), a provision or requirement under this part, or a standard or implementation specification adopted or established under sections 1320d–1 through 1320d–3 of this title, shall supersede any contrary provision of State law, including a provision of State law that requires medical or health plan records (including billing information) to be maintained or transmitted in written rather than electronic form.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8604212-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–7/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A provision or requirement under this part, or a standard or implementation specification adopted or established under sections 1320d–1 through 1320d–3 of this title, shall not supersede a contrary provision of State law, if the provision of State law—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8604213-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–7/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is a provision the Secretary determines—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb8604214-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–7/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is necessary—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb8604215-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–7/a/2/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to prevent fraud and abuse;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb8604216-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–7/a/2/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to ensure appropriate State regulation of insurance and health plans;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb8604217-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–7/a/2/A/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for State reporting on health care delivery or costs; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb8604218-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–7/a/2/A/i/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for other purposes; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8604219-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–7/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" addresses controlled substances; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb860421a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–7/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to section 264(c)(2) of the Health Insurance Portability and Accountability Act of 1996, relates to the privacy of individually identifiable health information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb860421b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–7/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public health","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this part shall be construed to invalidate or limit the authority, power, or procedures established under any law providing for the reporting of disease or injury, child abuse, birth, or death, public health surveillance, or public health investigation or intervention.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb860421c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–7/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State regulatory reporting","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this part shall limit the ability of a State to require a health plan to report, or to provide access to, information for management audits, financial audits, program monitoring and evaluation, facility licensure or certification, or individual licensure or certification.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb860421d-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title XI, § 1178, as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/191/tII/s262/a"},"text":"Pub. L. 104–191, title II, § 262(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-21"},"text":"Aug. 21, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2029"},"text":"110 Stat. 2029","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb860421e-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb860421f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb8604220-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 264(c)(2) of the Health Insurance Portability and Accountability Act of 1996, referred to in subsec. (a)(2)(B), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/191/s264/c/2"},"text":"section 264(c)(2) of Pub. L. 104–191","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320d–2"},"text":"section 1320d–2 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
