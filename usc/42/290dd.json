{"tag":"section","attrib":{"id":"idb5bb398f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290dd"},"text":null,"children":[{"tag":"num","attrib":{"value":"290dd"},"text":"§ 290dd.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Substance abuse among government and other employees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5bb3990-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290dd/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Programs and services","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5bb3991-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290dd/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Development","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Assistant Secretary for Mental Health and Substance Use, shall be responsible for fostering substance abuse prevention and treatment programs and services in State and local governments and in private industry.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5bb3992-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290dd/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Model programs","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5bb3993-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290dd/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Consistent with the responsibilities described in paragraph (1), the Secretary, acting through the Assistant Secretary for Mental Health and Substance Use, shall develop a variety of model programs suitable for replication on a cost-effective basis in different types of business concerns and State and local governmental entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5bb3994-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290dd/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dissemination of information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Assistant Secretary for Mental Health and Substance Use, shall disseminate information and materials relative to such model programs to the State agencies responsible for the administration of substance abuse prevention, treatment, and rehabilitation activities and shall, to the extent feasible provide technical assistance to such agencies as requested.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5bb3995-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290dd/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deprivation of employment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5bb3996-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290dd/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No person may be denied or deprived of Federal civilian employment or a Federal professional or other license or right solely on the grounds of prior substance abuse.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5bb3997-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290dd/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"This subsection shall not apply to employment in—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5bb3998-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290dd/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Central Intelligence Agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5bb3999-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290dd/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Bureau of Investigation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5bb399a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290dd/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Security Agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5bb399b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290dd/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other department or agency of the Federal Government designated for purposes of national security by the President; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5bb399c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290dd/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in any position in any department or agency of the Federal Government, not referred to in subparagraphs (A) through (D), which position is determined pursuant to regulations prescribed by the head of such agency or department to be a sensitive position.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5bb399d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290dd/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rehabilitation Act","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The inapplicability of the prohibition described in paragraph (1) to the employment described in paragraph (2) shall not be construed to reflect on the applicability of the Rehabilitation Act of 1973 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s701"},"text":"29 U.S.C. 701","children":[],"tail":" et seq.] or other anti-discrimination laws to such employment."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5bb399e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290dd/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall not be construed to prohibit the dismissal from employment of a Federal civilian employee who cannot properly function in his employment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5bb399f-3