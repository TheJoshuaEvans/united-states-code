out under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s701"},"text":"section 701 of Title 29","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb5bb39a3-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4571"},"text":"section 4571 of this title","children":[],"tail":" prior to renumbering by "},{"tag":"ref","attrib":{"href":"/us/pl/98/24"},"text":"Pub. L. 98–24","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb5bb39a4-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255"},"text":"Pub. L. 114–255","children":[],"tail":" substituted “Assistant Secretary for Mental Health and Substance Use” for “Administrator of the Substance Abuse and Mental Health Services Administration” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/321"},"text":"Pub. L. 102–321","children":[],"tail":" amended section generally, substituting provisions relating to substance abuse among government and other employees for provisions relating to technical assistance to States relative to alcohol abuse and alcoholism programs."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/93"},"text":"Pub. L. 101–93","children":[],"tail":" directed that subsec. (a)(4) of this section as similarly amended by title VIII of "},{"tag":"ref","attrib":{"href":"/us/pl/100/607"},"text":"Pub. L. 100–607","children":[],"tail":" and title VI of "},{"tag":"ref","attrib":{"href":"/us/pl/100/628"},"text":"Pub. L. 100–628","children":[],"tail":" be amended to read as if the amendments made by title VI of "},{"tag":"ref","attrib":{"href":"/us/pl/100/628"},"text":"Pub. L. 100–628","children":[],"tail":" had not been enacted. See 1988 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/607"},"text":"Pub. L. 100–607","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/100/628"},"text":"Pub. L. 100–628","children":[],"tail":" made identical technical amendments to reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s290dd–2"},"text":"section 290dd–2 of this title","children":[],"tail":" to reflect renumbering of corresponding section of original act."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/509"},"text":"Pub. L. 98–509","children":[],"tail":" amended directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/98/24/s2/b/13"},"text":"Pub. L. 98–24, § 2(b)(13)","children":[],"tail":". See 1983 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/24/s2/b/13"},"text":"Pub. L. 98–24, § 2(b)(13)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/98/509"},"text":"Pub. L. 98–509","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4571"},"text":"section 4571 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/24/s2/b/13/A/i"},"text":"Pub. L. 98–24, § 2(b)(13)(A)(i)","children":[],"tail":", substituted “the National Institute on Alcohol Abuse and Alcoholism” for “the Institute”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/24/s2/b/13/A/i