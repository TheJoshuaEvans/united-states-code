{"tag":"section","attrib":{"id":"idbcd1a609-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4375"},"text":null,"children":[{"tag":"num","attrib":{"value":"4375"},"text":"§ 4375.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of Environmental Quality Management Fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbcd1a60a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4375/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment; financing of study contracts and Federal interagency environmental projects","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is established an Office of Environmental Quality Management Fund (hereinafter referred to as the “Fund”) to receive advance payments from other agencies or accounts that may be used solely to finance—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbcd1a60b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4375/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" study contracts that are jointly sponsored by the Office and one or more other Federal agencies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcd1a60c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4375/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal interagency environmental projects (including task forces) in which the Office participates.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcd1a60d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4375/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study contract or project initiative","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any study contract or project that is to be financed under subsection (a) may be initiated only with the approval of the Director.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcd1a60e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4375/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall promulgate regulations setting forth policies and procedures for operation of the Fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbcd1a60f-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/224/tII/s206"},"text":"Pub. L. 91–224, title II, § 206","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/98/581/s2"},"text":"Pub. L. 98–581, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3093"},"text":"98 Stat. 3093","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
