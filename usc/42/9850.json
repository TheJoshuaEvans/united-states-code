{"tag":"section","attrib":{"id":"idbef87cf1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9850"},"text":null,"children":[{"tag":"num","attrib":{"value":"9850"},"text":"§ 9850.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation with respect to certain unlawful activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No individual employed or assigned by or in any Head Start agency or other agency assisted under this subchapter shall, pursuant to or during the performance of services rendered in connection with any program or activity conducted or assisted under this subchapter by such Head Start agency or such other agency, plan, initiate, participate in, or otherwise aid or assist in the conduct of any unlawful demonstration, rioting, or civil disturbance.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbef87cf2-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35/tVI/s655"},"text":"Pub. L. 97–35, title VI, § 655","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/507"},"text":"95 Stat. 507","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/134/s23"},"text":"Pub. L. 110–134, § 23","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-12"},"text":"Dec. 12, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1443"},"text":"121 Stat. 1443","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbef87cf3-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbef87cf4-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbef87cf5-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2007—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/134"},"text":"Pub. L. 110–134","children":[],"tail":" inserted “or in” after “assigned by”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
