{"tag":"section","attrib":{"id":"idb6a28cb3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–88"},"text":null,"children":[{"tag":"num","attrib":{"value":"300ff–88"},"text":"§ 300ff–88.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this subchapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6a28cb4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–88/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" AIDS","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “AIDS” means acquired immune deficiency syndrome.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6a28cb5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–88/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Co-occurring conditions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “co-occurring conditions” means one or more adverse health conditions in an individual with HIV/AIDS, without regard to whether the individual has AIDS and without regard to whether the conditions arise from HIV.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6a28cb6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–88/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Counseling","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “counseling” means such counseling provided by an individual trained to provide such counseling.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6a28cb7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–88/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Family-centered care","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “family-centered care” means the system of services described in this subchapter that is targeted specifically to the special needs of infants, children, women and families. Family-centered care shall be based on a partnership between parents, professionals, and the community designed to ensure an integrated, coordinated, culturally sensitive, and community-based continuum of care for children, women, and families with HIV/AIDS.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6a28cb8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–88/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Families with HIV/AIDS","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “families with HIV/AIDS” means families in which one or more members have HIV/AIDS.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6a28cb9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–88/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" HIV","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “HIV” means infection with the human immunodeficiency virus.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6a28cba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–88/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" HIV/AIDS","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6a28cbb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–88/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “HIV/AIDS” means HIV, and includes AIDS and any condition arising from AIDS.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6a28cbc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–88/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Counting of cases","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “living cases of HIV/AIDS”, with respect to the counting of cases in a geographic area during a period of time, means the sum of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb6a28cbd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–88/7/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of living non-AIDS cases of HIV in the area; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6a28cbe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–88/7/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of living cases of AIDS in the area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6a28cbf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–88/7/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-AIDS cases","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “non-AIDS”, with respect to a case of HIV, means that the individual involved has HIV but does not have AIDS.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6a28cc0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–88/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Human immunodeficiency virus","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “human immunodeficiency virus” means the etiologic agent for AIDS.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6a28cc1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–88/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Official poverty line","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “official poverty line” means the poverty line established by the Director of the Office of Management and Budget and revised by the Secretary in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s9902/2"},"text":"section 9902(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6a28cc2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–88/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Person","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “person” includes one or more individuals, governments (including the Federal Government and the governments of the States), governmental agencies, political subdivisions, labor unions, partnerships, associations, corporations, legal representatives, mutual companies, joint-stock companies, trusts, unincorporated organizations, receivers, trustees, and trustees in cases under title 11.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6a28cc3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–88/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6a28cc4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–88/11/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State” means each of the 50 States, the District of Columbia, and each of the territories.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6a28cc5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–88/11/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Territories","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “territory” means each of American Samoa, Guam, the Commonwealth of Puerto Rico, the Commonwealth of the Northern Mariana Islands, the Virgin Islands, the Republic of the Marshall Islands, the Federated States of Micronesia, and Palau.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6a28cc6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–88/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Youth with HIV","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “youth with HIV” means individuals who are 13 through 24 years old and who have HIV/AIDS.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb6a28cc7-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XXVI, § 2689, formerly § 2688, as added and amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/415/tV/s501"},"text":"Pub. L. 109–415, title V, § 501","children":[],"tail":", title VII, § 703, "},{"tag":"date","attrib":{"date":"2006-12-19"},"text":"Dec. 19, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2815"},"text":"120 Stat. 2815","children":[],"tail":", 2820; renumbered § 2689 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/87"},"text":"Pub. L. 111–87","children":[],"tail":", §§ 2(a)(1), (3)(A), 12(1), "},{"tag":"date","attrib":{"date":"2009-10-30"},"text":"Oct. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2885"},"text":"123 Stat. 2885","children":[],"tail":", 2896.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb6a28cc8-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb6a28cc9-3a70-11f1-ae07-e4213316b5fa"},"tex