ons of former subpart II of this part."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 300ff–90, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373/tXXVI/s2690"},"text":"act July 1, 1944, ch. 373, title XXVI, § 2690","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/381/tIV/s411/a"},"text":"Pub. L. 101–381, title IV, § 411(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-08-18"},"text":"Aug. 18, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/628"},"text":"104 Stat. 628","children":[],"tail":", related to applicability of former subpart II of this part."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb6a28ccb-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2009—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/87/s2/a/1"},"text":"Pub. L. 111–87, § 2(a)(1)","children":[],"tail":", (3)(A), repealed "},{"tag":"ref","attrib":{"href":"/us/pl/109/415/s703"},"text":"Pub. L. 109–415, § 703","children":[],"tail":", and revived the provisions of this section as in effect on "},{"tag":"date","attrib":{"date":"2009-09-30"},"text":"Sept. 30, 2009","children":[],"tail":". See 2006 Amendment note and Effective Date of 2009 Amendment; Revival of Section note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/415/s703"},"text":"Pub. L. 109–415, § 703","children":[],"tail":", which directed repeal of this section effective "},{"tag":"date","attrib":{"date":"2009-10-01"},"text":"Oct. 1, 2009","children":[],"tail":", was itself repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/111/87/s2/a/1"},"text":"Pub. L. 111–87, § 2(a)(1)","children":[],"tail":", effective "},{"tag":"date","attrib":{"date":"2009-09-30"},"text":"Sept. 30, 2009","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb6a28ccc-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb6a28ccd-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2009 Amendment; Revival of Section","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions that repeal by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/87/s2/a/1"},"text":"section 2(a)(1) of Pub. L. 111–87","children":[],"tail":" of "},{"tag":"ref","attrib":{"href":"/us/pl/109/415/s703"},"text":"section 703 of Pub. L. 109–415","children":[],"tail":" be effective "},{"tag":"date","attrib":{"date":"2009-09-30"},"text":"Sept. 30, 2009","children":[],"tail":", and that the provisions of this section as in effect on "},{"tag":"date","attrib":{"date":"2009-09-30"},"text":"Sept. 30, 2009","children":[],"tail":", be revived, see section 2(a)(2), (3)(A) of "},{"tag":"ref","attrib":{"href":"/us/pl/111/87"},"text":"Pub. L. 111–87","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–11"},"text":"section 300ff–11 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
