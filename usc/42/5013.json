{"tag":"section","attrib":{"id":"idbcee55e6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5013"},"text":null,"children":[{"tag":"num","attrib":{"value":"5013"},"text":"§ 5013.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants and contracts for volunteer service projects","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbcee55e7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5013/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Costs of project development and operation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director is authorized to make grants to or contracts with public and nonprofit private agencies and organizations to pay part or all of the cost of development and operation of projects (including direct payments to individuals serving under this part in the same manner as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5011/a"},"text":"section 5011(a) of this title","children":[],"tail":") designed for the purpose of providing opportunities for low-income persons age 55 or older to serve as “senior companions” to persons with exceptional needs. Senior companions may provide services designed to help older persons requiring long-term care, including services to persons receiving home health care, nursing care, home-delivered meals or other nutrition services; services designed to help persons deinstitutionalized from mental hospitals, nursing homes, and other institutions; and services designed to assist persons having developmental disabilities and other special needs for companionship."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcf09ed8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5013/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of other laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsections (d), (e), and (f) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5011"},"text":"section 5011 of this title","children":[],"tail":", and such other provisions of part B as the Director determines to be necessary, shall apply to this part, except that for purposes of this part any reference in such subsections and such provisions to part B shall be deemed to be a reference to this part."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcf09ed9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5013/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Senior companion projects to assist homebound elderly","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbcf09eda-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5013/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director is authorized to make grants or contracts after ","children":[{"tag":"ref","attrib":{"idref":"fn003384"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003384"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “under”."}],"tail":" subsection (a) for senior companion projects to assist homebound elderly individuals to remain in their own homes and to enable institutionalized elderly individuals to return to home care settings."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcf09edb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5013/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbcf09edc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5013/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director is authorized to recruit, subject to subparagraph (B), senior companion volunteer trainers who on the basis of experience (such as, doctors, nurses, home economists, social workers) will be used to train senior companion volunteers to participate in and monitor initial and continuing needs assessments and appropriate in-home services for senior companion volunteer recipients. The needs assessments and in-home services shall be coordinated with and supplement existing community based home health and long-term care systems. The Director may also use senior companion volunteer leaders, who on the basis of experience as volunteers, special skills, and demonstrated leadership abilities may spend time in the program (in addition to their regular assignment) to assist newer senior companion volunteers in performing their assignments and in coordinating activities of such volunteers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcf09edd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5013/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Senior companion volunteer trainers recruited under subparagraph (A) of this paragraph shall not be paid stipends.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbcf09ede-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/113/tII/s213"},"text":"Pub. L. 93–113, title II, § 213","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tVI/s608/c/2"},"text":"Pub. L. 97–35, title VI, § 608(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/487"},"text":"95 Stat. 487","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/98/288/s15"},"text":"Pub. L. 98–288, § 15","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-05-21"},"text":"May 21, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/193"},"text":"98 Stat. 193","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/551"},"text":"Pub. L. 99–551","children":[],"tail":", §§ 7(b), 10(c)(1), "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3075"},"text":"100 Stat. 3075","children":[],"tail":", 3077; "},{"tag":"ref","attrib":{"href":"/us/pl/101/204/tIX/s902/5"},"text":"Pub. L. 101–204, title IX, § 902(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-07"},"text":"Dec. 7, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1826"},"text":"103 Stat. 1826","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/tIII/s347"},"text":"Pub. L. 103–82, title III, § 347","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-09-21"},"text":"Sept. 21, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/905"},"text":"107 Stat. 905","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/13/tII/s2145"},"text":"Pub. L. 111–13, title II, § 2145","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-04-21"},"text":"Apr. 21, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1589"},"text":"123 Stat. 1589","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbcf09edf-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbcf09ee0-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbcf09ee1-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2009—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13"},"text":"Pub. L. 111–13","children":[],"tail":" substituted “age 55 or older” for “aged 60 or over”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/82"},"text":"Pub. L. 103–82","children":[],"tail":" struck out par. (3) which required an evaluation of, and report on, impact of senior companion projects to assist homebound elderly."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/204"},"text":"Pub. L. 101–204","children":[],"tail":" inserted “after subsection (a)” after “grants or contracts”, and “individuals” after “elderly” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/551"},"text":"Pub. L. 99–551","children":[],"tail":" inserted “for volunteer service projects” in section catchline and amended subsec. (b) generally. Prior to amendment, subsec. (b) read as follows: “The provisions of "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5011/d"},"text":"section 5011(d) of this title","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5011/e"},"text":"section 5011(e) of this title","children":[],"tail":" and such other provisions of part B as the Director determines to be necessary shall apply to the provisions of this part.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/288"},"text":"Pub. L. 98–288","children":[],"tail":" added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbcf09ee2-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbcf09ee3-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2009 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13"},"text":"Pub. L. 111–13","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2009-10-01"},"text":"Oct. 1, 2009","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/111/13/s6101/a"},"text":"section 6101(a) of Pub. L. 111–13","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4950"},"text":"section 4950 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbcf09ee4-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1993 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/82"},"text":"Pub. L. 103–82","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1993-10-01"},"text":"Oct. 1, 1993","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/s392"},"text":"section 392 of Pub. L. 103–82","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4951"},"text":"section 4951 of this title","ch