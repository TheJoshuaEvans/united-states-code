{"tag":"section","attrib":{"id":"idbfc80206-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13554"},"text":null,"children":[{"tag":"num","attrib":{"value":"13554"},"text":"§ 13554.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tar sands","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfc80207-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13554/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Policy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It is the policy of the United States to promote the development and production, by all means consistent with sound engineering, economic, and environmental practices, of deposits of tar sands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfc80208-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13554/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Tar sands” defined","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfc80209-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13554/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of this section, the term “tar sands” means any consolidated or unconsolidated rock (other than coal, oil shale, or gilsonite) that either—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfc8020a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13554/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contains a hydrocarbonaceous material with a gas-free viscosity, at original reservoir temperature, greater than 10,000 centipoise; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfc8020b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13554/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contains a hydrocarbonaceous material and is produced by mining or quarrying.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc8020c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13554/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nothing in this section is intended or shall be construed to affect in any way the definition of the term tar sands under any other provision of Federal law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfc8020d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13554/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in consultation with the Secretary of the Interior, shall submit a study to the House of Representatives and the Committee on Energy and Natural Resources of the Senate within one year after ","children":[{"tag":"date","attrib":{"date":"1992-10-24"},"text":"October 24, 1992","children":[],"tail":". Such study shall identify and evaluate the development potential of sources of tar sands in the United States. The study shall also identify and evaluate processes for extracting oil from the identified tar sand sources, including existing tar sands waste tailings, and evaluate the environmental benefits of, and the potential for co-production of minerals and metals from, such processes."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfc8020e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13554/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums as may be necessary for each of the fiscal years 1993 and 1994 to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfc8020f-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/tXXX/s3016"},"text":"Pub. L. 102–486, title XXX, § 3016","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3129"},"text":"106 Stat. 3129","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
