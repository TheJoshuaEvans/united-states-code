{"tag":"section","attrib":{"id":"idbff79ee7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16193"},"text":null,"children":[{"tag":"num","attrib":{"value":"16193"},"text":"§ 16193.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Building Performance Initiative","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbff79ee8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16193/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interagency group","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbff79ee9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16193/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":", the Director of the Office of Science and Technology Policy shall establish an interagency group to develop, in coordination with the advisory committee established under subsection (e), a National Building Performance Initiative (referred to in this section as the “Initiative”)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff79eea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16193/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cochairs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The interagency group shall be co-chaired by appropriate officials of the Department and the Department of Commerce, who shall jointly arrange for the provision of necessary administrative support to the group.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff79eeb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16193/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Integration of efforts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Initiative shall integrate Federal, State, and voluntary private sector efforts to reduce the costs of construction, operation, maintenance, and renovation of commercial, industrial, institutional, and residential buildings.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff79eec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16193/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plan","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbff79eed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16193/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":", the interagency group shall submit to Congress a plan for carrying out the appropriate Federal role in the Initiative."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff79eee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16193/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The plan shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbff79eef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16193/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" research, development, demonstration, and commercial application of energy technology systems and materials for new construction and retrofit relating to the building envelope and building system components;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff79ef0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16193/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" research, development, demonstration, and commercial application of energy technology and infrastructure enabling the energy efficient, automated operation of buildings and building equipment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff79ef1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16193/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the collection, analysis, and dissemination of research results and other pertinent information on enhancing building performance to industry, government entities, and the public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff79ef2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16193/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Department of Energy role","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Within the Federal portion of the Initiative, the Department shall be the lead agency for all aspects of building performance related to use and conservation of energy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff79ef3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16193/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisory committee","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director of the Office of Science and Technology Policy shall establish an advisory committee to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbff79ef4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16193/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" analyze and provide recommendations on potential private sector roles and participation in the Initiative; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff79ef5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16193/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review and provide recommendations on the plan described in subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff79ef6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16193/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section provides any Federal agency with new authority to regulate building performance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbff79ef7-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tIX/s913"},"text":"Pub. L. 109–58, title IX, § 913","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/860"},"text":"119 Stat. 860","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
