{"tag":"section","attrib":{"id":"idbf9f6c45-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12781"},"text":null,"children":[{"tag":"num","attrib":{"value":"12781"},"text":"§ 12781.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary shall, insofar as is feasible through contract with eligible organizations, develop the capacity of participating jurisdictions, State and local housing finance agencies, nonprofit organizations and for-profit corporations, working in partnership, to identify and meet needs for an increased supply of decent, affordable housing.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbf9f6c46-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/625/tII/s241"},"text":"Pub. L. 101–625, title II, § 241","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4117"},"text":"104 Stat. 4117","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
