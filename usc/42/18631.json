{"tag":"section","attrib":{"id":"idc0596d39-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18631"},"text":null,"children":[{"tag":"num","attrib":{"value":"18631"},"text":"§ 18631.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Crosscutting research and development","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc0596d3a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18631/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall use the capabilities of the Department to identify strategic opportunities for collaborative research, development, demonstration, and commercial application of innovative science and technologies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0596d3b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18631/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Existing programs; coordination of activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To the maximum extent practicable, the Secretary shall seek—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0596d3c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18631/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to leverage existing programs of the Department; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0596d3d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18631/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to consolidate and coordinate activities throughout the Department to promote collaboration and crosscutting approaches within programs of the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0596d3e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18631/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional actions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0596d3f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18631/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prioritize activities that use all affordable domestic resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0596d40-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18631/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" develop a planning, evaluation, and technical assessment framework for setting objective long-term strategic goals and evaluating progress that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0596d41-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18631/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensures integrity and independence; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0596d42-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18631/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides the flexibility to adapt to market dynamics;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0596d43-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18631/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that activities shall be undertaken in a manner that does not duplicate other activities within the Department or other Federal Government activities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0596d44-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18631/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify programs that may be more effectively left to the States, industry, nongovernmental organizations, institutions of higher education, or other stakeholders.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc0596d45-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/246/tII/s203"},"text":"Pub. L. 115–246, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-09-28"},"text":"Sept. 28, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3135"},"text":"132 Stat. 3135","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
