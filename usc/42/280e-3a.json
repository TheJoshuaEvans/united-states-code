{"tag":"section","attrib":{"id":"idb530d366-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280e–3a"},"text":null,"children":[{"tag":"num","attrib":{"value":"280e–3a"},"text":"§ 280e–3a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National childhood cancer registry","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb530d367-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280e–3a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Director of the Centers for Disease Control and Prevention, may make awards to State cancer registries to enhance and expand infrastructure to collect information to better understand the epidemiology of cancer in children, adolescents, and young adults. Such registries may be updated to include each occurrence of such cancers within a period of time designated by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb530d368-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280e–3a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The grants described in subsection (a) may be used for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb530d369-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280e–3a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying, recruiting, and training potential sources for reporting childhood, adolescent, and young adult cancer cases;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb530d36a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280e–3a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing practices to ensure early inclusion of childhood, adolescent, and young adult cancer cases in State cancer registries through the use of electronic reporting;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb530d36b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280e–3a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collecting and submitting deidentified data to the Centers for Disease Control and Prevention for inclusion in a national database that includes information on childhood, adolescent, and young adult cancers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb530d36c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280e–3a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improving State cancer registries and the database described in paragraph (3), as appropriate, including to support the early inclusion of childhood, adolescent, and young adult cancer cases.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb530d36d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280e–3a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To encourage the greatest possible efficiency and effectiveness of federally supported efforts with respect to the activities described in this section, the Secretary shall ensure the appropriate coordination of programs supported under this section with other federally supported cancer registry programs and the activities under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s285a–11/a"},"text":"section 285a–11(a) of this title","children":[],"tail":", as appropriate."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb530d36e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280e–3a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Informed consent and privacy requirements and coordination with existing programs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The activities described in this section shall be subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552a"},"text":"section 552a of title 5","children":[],"tail":", the regulations promulgated under section 264(c) of the Health Insurance Portability and Accountability Act of 1996, applicable Federal and State informed consent regulations, any other applicable Federal and State laws relating to the privacy of patient information, and "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s280e/d/4"},"text":"section 280e(d)(4) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb530d36f-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title III, § 399E–1, as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/285/s4/b/1"},"text":"Pub. L. 110–285, § 4(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-07-29"},"text":"July 29, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2630"},"text":"122 Stat. 2630","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/180/tI/s102/a"},"text":"Pub. L. 115–180, title I, § 102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-06-05"},"text":"June 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1385"},"text":"132 Stat. 1385","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb530d370-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb530d371-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb530d372-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 264(c) of the Health Insurance Portability and Accountability Act of 1996, referred to in subsec. (d), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/191/s264/c"},"text":"section 264(c) of Pub. L. 104–191","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320d–2"},"text":"section 1320d–2 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb530d373-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/180/s102/a/1"},"text":"Pub. L. 115–180, § 102(a)(1)","children":[],"tail":", substituted “may make awards to State cancer registries” for “shall award a grant”, “collect information to better understand the epidemiology of cancer in children, adolescents, and young adults” for “track the epidemiology of pediatric cancer into a comprehensive nationwide registry of actual occurrences of pediatric cancer”, and “Such registries may be updated to include each occurrence of such cancers within a period of time designated by the Secretary.” for “Such registry shall be updated to include an actual occurrence within weeks of the date of such occurrence.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/180/s102/a/3"},"text":"Pub. L. 115–180, § 102(a)(3)","children":[],"tail":", added subsecs. (b) and (c). Former subsec. (b) redesignated (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/180/s102/a/2"},"text":"Pub. L. 115–180, § 102(a)(2)","children":[],"tail":", (4), redesignated subsec. (b) as (d) and substituted “activities described in this section” for “registry established pursuant to subsection (a)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb530d374-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb530d375-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Findings and Purposes","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/285"},"text":"Pub. L. 110–285","children":[],"tail":", §§ 2, 3, "},{"tag":"date","attrib":{"date":"2008-07-29"},"text":"July 29, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2628"},"text":"122 Stat. 2628","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/285"},"text":"\n","children":[{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“SEC. 2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" FINDINGS","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"“Congress makes the following findings:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Cancer kills more children than any other disease.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each year cancer kills more children between 1 and 20 years of age than asthma, diabetes, cystic fibrosis, and AIDS, combined.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Every year, over 12,500 young people are diagnosed with cancer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each year about 2,300 children and teenagers die from cancer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One in every 330 Americans develops cancer before age 20.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"“(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Some forms of childhood cancer have proven to be so resistant that even in spite of the great research strides made, most of those children die. Up to 75 percent of the children with cancer can now be cured.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"“(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The causes of most childhood cancers are not yet known.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"“(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Childhood cancers are mostly those of the white blood cells (leukemias), brain, bone, the lymphatic system, and tumors of the muscles, kidneys, and nervous system. Each of these behaves differently, but all are characterized by an uncontrolled proliferation of abnormal cells.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"“(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Eighty percent of the children who are diagnosed with cancer have disease which has already spread to distant sites in the body.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"“(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Ninety percent of children with a form of pediatric cancer are treated at one of the more than 200 Children’s Oncology Group member institutions throughout the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“SEC. 3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" PURPOSES","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"“It is the purpose of this Act [see Short Title of 2008 Amendment note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s201"},"text":"section 201 of this title","children":[],"tail":"] to authorize appropriations to—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage the support for pediatric cancer research and other activities related to pediatric cancer;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish a comprehensive national childhood cancer registry; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide informational services to patients and families affected by childhood cancer.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
