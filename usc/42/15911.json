{"tag":"section","attrib":{"id":"idbfe9467a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15911"},"text":null,"children":[{"tag":"num","attrib":{"value":"15911"},"text":"§ 15911.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Denali Commission","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfe9467b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15911/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of Commission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “Commission” means the Denali Commission established by the Denali Commission Act of 1998 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3121"},"text":"42 U.S.C. 3121","children":[],"tail":" note; "},{"tag":"ref","attrib":{"href":"/us/pl/105/277"},"text":"Public Law 105–277","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfe9467c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15911/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Energy programs","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commission shall use amounts made available under subsection (d) to carry out energy programs, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfe9467d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15911/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" energy generation and development, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfe9467e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15911/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fuel cells, hydroelectric, solar, wind, wave, and tidal energy; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfe9467f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15911/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" alternative energy sources;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe94680-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15911/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the construction of energy transmission, including interties;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe94681-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15911/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the replacement and cleanup of fuel tanks;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe94682-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15911/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the construction of fuel transportation networks and related facilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe94683-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15911/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" power cost equalization programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe94684-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15911/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" projects using coal as a fuel, including coal gasification projects.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfe94685-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15911/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Open meetings","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfe94686-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15911/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in paragraph (2), a meeting of the Commission shall be open to the public if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfe94687-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15911/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Commission members take action on behalf of the Commission; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfe94688-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15911/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the deliberations of the Commission determine, or result in the joint conduct or disposition of, official Commission business.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe94689-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15911/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraph (1) shall not apply to any portion of a Commission meeting for which the Commission, in public session, votes to close the meeting for the reasons described in paragraph (2), (4), (5), or (6) of subsection (c) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552b"},"text":"section 552b of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe9468a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15911/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public notice","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfe9468b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15911/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"At least 1 week before a meeting of the Commission, the Commission shall make a public announcement of the meeting that describes—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbfe9468c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15911/c/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the time, place, and subject matter of the meeting;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbfe9468d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15911/c/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether the meeting is to be open or closed to the public; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbfe9468e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15911/c/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name and telephone number of an appropriate person to respond to requests for information about the meeting.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfe9468f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15911/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional notice","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall make a public announcement of any change to the information made available under subparagraph (A) at the earliest practicable time.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe94690-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15911/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minutes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall keep, and make available to the public, a transcript, electronic recording, or minutes from each Commission meeting, except for portions of the meeting closed under paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfe94691-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15911/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to the Commission not more than $55,000,000 for each of fiscal years 2006 through 2015 to carry out subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfe94692-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tIII/s356"},"text":"Pub. L. 109–58, title III, § 356","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/719"},"text":"119 Stat. 719","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbfe94693-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbfe94694-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbfe94695-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Denali Commission Act of 1998, referred to in subsec. (a), is title III of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/dC"},"text":"Pub. L. 105–277, div. C","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-637"},"text":"112 Stat. 2681–637","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3121"},"text":"section 3121 of this title","children":[],"tail":". For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
