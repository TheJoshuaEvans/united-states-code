{"tag":"section","attrib":{"id":"idbbf63958-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2160c"},"text":null,"children":[{"tag":"num","attrib":{"value":"2160c"},"text":"§ 2160c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation with Department of Defense concerning certain exports and subsequent arrangements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbbf63959-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2160c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In addition to other applicable requirements—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbbf6395a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2160c/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a license may be issued by the Nuclear Regulatory Commission under this chapter for the export of special nuclear material described in subsection (b); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbf6395b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2160c/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" approval may be granted by the Secretary of Energy under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2160"},"text":"section 2160 of this title","children":[],"tail":" for the transfer of special nuclear material described in subsection (b);"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"only after the Secretary of Defense has been consulted on whether the physical protection of that material during the export or transfer will be adequate to deter theft, sabotage, and other acts of international terrorism which would result in the diversion of that material. If, in the view of the Secretary of Defense based on all available intelligence information, the export or transfer might be subject to a genuine terrorist threat, the Secretary shall provide to the Nuclear Regulatory Commission or the Secretary of Energy, as appropriate, his written assessment of the risk and a description of the actions the Secretary of Defense considers necessary to upgrade physical protection measures.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbbf6395c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2160c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subsection (a) applies to the export or transfer of more than 2 kilograms of plutonium or more than 5 kilograms of uranium enriched to more than 20 percent in the isotope 233 or the isotope 235.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbbf6395d-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-08-01/ch724"},"text":"Aug. 1, 1946, ch. 724","children":[],"tail":", title I, § 133, as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/399/tVI/s603"},"text":"Pub. L. 99–399, title VI, § 603","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-08-27"},"text":"Aug. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/875"},"text":"100 Stat. 875","children":[],"tail":"; renumbered title I, "},{"tag":"ref","attrib":{"href":"/us/pl/102/486/tIX/s902/a/8"},"text":"Pub. L. 102–486, title IX, § 902(a)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2944"},"text":"106 Stat. 2944","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/236/tVIII/s829"},"text":"Pub. L. 103–236, title VIII, § 829","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-04-30"},"text":"Apr. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/521"},"text":"108 Stat. 521","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbbf6395e-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbbf6395f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbbf63960-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (a)(1), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-08-01/ch724"},"text":"act Aug. 1, 1946, ch. 724","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/act/1954-08-30/ch1073/s1"},"text":"act Aug. 30, 1954, ch. 1073, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/919"},"text":"68 Stat. 919","children":[],"tail":", known as the Atomic Energy Act of 1954, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2011"},"text":"section 2011 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbbf63961-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/236"},"text":"Pub. L. 103–236","children":[],"tail":" substituted “5 kilograms” for “20 kilograms”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbbf63962-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbbf63963-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/236"},"text":"Pub. L. 103–236","children":[],"tail":" effective 60 days after "},{"tag":"date","attrib":{"date":"1994-04-30"},"text":"Apr. 30, 1994","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/236/s831"},"text":"section 831 of Pub. L. 103–236","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s6301"},"text":"section 6301 of Title 22","children":[],"tail":", Foreign Relations and Intercourse."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
