{"tag":"section","attrib":{"id":"idc01696d9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16460"},"text":null,"children":[{"tag":"num","attrib":{"value":"16460"},"text":"§ 16460.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Not later than 4 months after ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":", the Commission shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc01696da-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16460/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issue such regulations as may be necessary or appropriate to implement this part (other than ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16453"},"text":"section 16453 of this title","children":[],"tail":", relating to State access to books and records); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc01696db-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16460/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit to Congress detailed recommendations on technical and conforming amendments to Federal law necessary to carry out this part and the amendments made by this part.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc01696dc-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tXII/s1272"},"text":"Pub. L. 109–58, title XII, § 1272","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/977"},"text":"119 Stat. 977","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc01696dd-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc01696de-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc01696df-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This part, referred to in text, was in the original “this subtitle”, meaning subtitle F (§§ 1261–1277) of title XII of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58"},"text":"Pub. L. 109–58","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/972"},"text":"119 Stat. 972","children":[],"tail":", which enacted this part, amended sections 824 and 824m of Title 16, Conservation, repealed chapter 2C (§ 79 et seq.) of Title 15, Commerce and Trade, and "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s825q"},"text":"section 825q of Title 16","children":[],"tail":", and enacted provisions set out as notes under sections 15801 and 16451 of this title. For complete classification of subtitle F to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s15801"},"text":"section 15801 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
