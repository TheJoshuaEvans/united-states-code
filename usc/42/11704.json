{"tag":"section","attrib":{"id":"idbf556a1b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11704"},"text":null,"children":[{"tag":"num","attrib":{"value":"11704"},"text":"§ 11704.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions of Papa Ola Lokahi","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf556a1c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11704/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibility","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Papa Ola Lokahi shall be responsible for the—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf556a1d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11704/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordination, implementation, and updating, as appropriate, of the comprehensive health care master plan developed pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11703"},"text":"section 11703 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf556a1e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11704/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" training for the persons described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11705/c/1/B"},"text":"section 11705(c)(1)(B) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf556a1f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11704/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identification of and research into the diseases that are most prevalent among Native Hawaiians, including behavioral, biomedical, epidemiological, and health services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf556a20-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11704/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development of an action plan outlining the contributions that each member organization of Papa Ola Lokahi will make in carrying out the policy of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf556a21-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11704/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special project funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Papa Ola Lokahi is authorized to receive special project funds that may be appropriated for the purpose of research on the health status of Native Hawaiians or for the purpose of addressing the health care needs of Native Hawaiians.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf556a22-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11704/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Clearinghouse","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Papa Ola Lokahi shall serve as a clearinghouse for:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf556a23-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11704/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the collection and maintenance of data associated with the health status of Native Hawaiians;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf556a24-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11704/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the identification and research into diseases affecting Native Hawaiians;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf556a25-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11704/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the availability of Native Hawaiian project funds, research projects and publications;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf556a26-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11704/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the collaboration of research in the area of Native Hawaiian health; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf556a27-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11704/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the timely dissemination of information pertinent to the Native Hawaiian health care systems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf556a28-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11704/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination of programs and services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Papa Ola Lokahi shall, to the maximum extent possible, coordinate and assist the health care programs and services provided to Native Hawaiians.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf556a29-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11704/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical support","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Papa Ola Lokahi shall act as a statewide infrastructure to provide technical support and coordination of training and technical assistance to the Native Hawaiian health care systems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf556a2a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11704/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relationships with other agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Papa Ola Lokahi is authorized to enter into agreements or memoranda of understanding with relevant agencies or organizations that are capable of providing resources or services to the Native Hawaiian health care systems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf556a2b-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/579/s5"},"text":"Pub. L. 100–579, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-31"},"text":"Oct. 31, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2919"},"text":"102 Stat. 2919","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tII/s2305"},"text":"Pub. L. 100–690, title II, § 2305","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4225"},"text":"102 Stat. 4225","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/396/tIX/s9168"},"text":"Pub. L. 102–396, title IX, § 9168","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-06"},"text":"Oct. 6, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1948"},"text":"106 Stat. 1948","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf556a2c-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf556a2d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbf556a2e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The 1992 amendment is based on section 1 of S. 2681, One Hundred Second Congress, as passed by the Senate on ","children":[{"tag":"date","attrib":{"date":"1992-08-07"},"text":"Aug. 7, 1992","children":[],"tail":", and enacted into law by "},{"tag":"ref","attrib":{"href":"/us/pl/102/396/s9168"},"text":"section 9168 of Pub. L. 102–396","children":[],"tail":". Section 9168, which referred to S. 2681, as passed by the Senate on “"},{"tag":"date","attrib":{"date":"1992-09-12"},"text":"September 12, 1992","children":[],"tail":"”, has been treated as referring to S. 2681, as passed by the Senate on "},{"tag":"date","attrib":{"date":"1992-08-07"},"text":"Aug. 7, 1992","children":[],"tail":", to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/579"},"text":"Pub. L. 100–579","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/100/690"},"text":"Pub. L. 100–690","children":[],"tail":" enacted substantially identical sections. The text of this section is based on "},{"tag":"ref","attrib":{"href":"/us/pl/100/579/s5"},"text":"section 5 of Pub. L. 100–579","children":[],"tail":", as subsequently amended."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbf556a2f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/396"},"text":"Pub. L. 102–396","children":[],"tail":" amended section generally. Prior to amendment, section related to administrative grant for Papa Ola Lokahi."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
