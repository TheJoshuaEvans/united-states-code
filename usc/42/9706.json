{"tag":"section","attrib":{"id":"idbed9842c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9706"},"text":null,"children":[{"tag":"num","attrib":{"value":"9706"},"text":"§ 9706.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dissemination of information","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary shall assure that full and complete safety-related information resulting from any project or other activity conducted under this chapter is made available in a timely manner to appropriate committees of Congress, Federal, State, and local authorities, relevant segments of private industry, the scientific community, and the public.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbed9842d-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/567/s7"},"text":"Pub. L. 96–567, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-22"},"text":"Dec. 22, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3332"},"text":"94 Stat. 3332","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
