{"tag":"section","attrib":{"id":"idb5844a88-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s287b"},"text":null,"children":[{"tag":"num","attrib":{"value":"287b"},"text":"§ 287b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General purpose","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The general purpose of the John E. Fogarty International Center for Advanced Study in the Health Sciences is to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5844a89-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s287b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitate the assembly of scientists and others in the biomedical, behavioral, and related fields for discussion, study, and research relating to the development of health science internationally;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb585f83a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s287b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide research programs, conferences, and seminars to further international cooperation and collaboration in the life sciences;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb585f83b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s287b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide postdoctorate fellowships for research training in the United States and abroad and promote exchanges of senior scientists between the United States and other countries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb585f83c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s287b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate the activities of the National Institutes of Health concerned with the health sciences internationally; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb585f83d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s287b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" receive foreign visitors to the National Institutes of Health.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb585f83e-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title IV, § 482, as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/158/s2"},"text":"Pub. L. 99–158, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-11-20"},"text":"Nov. 20, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/866"},"text":"99 Stat. 866","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
