{"tag":"section","attrib":{"id":"idbfe21a98-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15704"},"text":null,"children":[{"tag":"num","attrib":{"value":"15704"},"text":"§ 15704.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Advisory Committee on Windstorm Impact Reduction","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfe21a99-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15704/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director of the National Institute of Standards and Technology shall establish an Advisory Committee on Windstorm Impact Reduction, which shall be composed of at least 7 and not more than 15 members who are qualified to provide advice on windstorm impact reduction and represent related scientific, architectural, and engineering disciplines, none of whom may be employees of the Federal Government, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfe21a9a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15704/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" representatives of research and academic institutions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe21a9b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15704/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" industry standards development organizations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe21a9c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15704/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" emergency management agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe21a9d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15704/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State and local government; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe21a9e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15704/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" business communities, including the insurance industry.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfe21a9f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15704/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessments","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Advisory Committee on Windstorm Impact Reduction shall offer assessments and recommendations on—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfe21aa0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15704/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" trends and developments in the natural, engineering, and social sciences and practices of windstorm impact mitigation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe21aa1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15704/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the priorities of the Program’s Strategic Plan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe21aa2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15704/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the coordination of the Program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe21aa3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15704/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effectiveness of the Program in meeting its purposes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe21aa4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15704/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any revisions to the Program which may be necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfe21aa5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15704/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The members of the Advisory Committee established under this section shall serve without compensation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfe21aa6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15704/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"At least every 2 years, the Advisory Committee shall report to the Director on the assessments carried out under subsection (b) and its recommendations for ways to improve the Program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfe21aa7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15704/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Charter","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s1013/b/2"},"text":"section 1013(b)(2) of title 5","children":[],"tail":", the Advisory Committee shall not be required to file a charter subsequent to its initial charter, filed under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s1008/c"},"text":"section 1008(c) of title 5","children":[],"tail":", before the termination date specified in subsection (f) of this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfe21aa8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15704/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Advisory Committee shall terminate on ","children":[{"tag":"date","attrib":{"date":"2017-09-30"},"text":"September 30, 2017","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfe21aa9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15704/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conflict of interest","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An Advisory Committee member shall recuse himself from any Advisory Committee activity in which he has an actual pecuniary interest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfe21aaa-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/360/tII/s205"},"text":"Pub. L. 108–360, title II, § 205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-25"},"text":"Oct. 25, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1678"},"text":"118 Stat. 1678","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/52/s4"},"text":"Pub. L. 114–52, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-09-30"},"text":"Sept. 30, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/499"},"text":"129 Stat. 499","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/277"},"text":"Pub. L. 117–286, § 4(a)(277)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4336"},"text":"136 Stat. 4336","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbfe21aab-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbfe21aac-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbfe21aad-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":" substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t5/s1013/b/2"},"text":"section 1013(b)(2) of title 5","children":[],"tail":", the Advisory Committee shall not be required to file a charter subsequent to its initial charter, filed under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s1008/c"},"text":"section 1008(c) of title 5","children":[],"tail":",” for “section 14(b)(2) of the Federal Advisory Committee Act (5 U.S.C. App.), the Advisory Committee shall not be required to file a charter subsequent to its initial charter, filed under section 9(c) of such Act,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2015—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/52"},"text":"Pub. L. 114–52","children":[],"tail":" amended section generally. Prior to amendment, section established a National Advisory Committee on Windstorm Impact Reduction."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
