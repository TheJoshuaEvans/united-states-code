{"tag":"section","attrib":{"id":"idbfb4c8bf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13220"},"text":null,"children":[{"tag":"num","attrib":{"value":"13220"},"text":"§ 13220.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Biodiesel fuel use credits","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfb4c8c0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13220/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation of credits","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfb4c8c1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13220/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall allocate one credit under this section to a fleet or covered person for each qualifying volume of the biodiesel component of fuel containing at least 20 percent biodiesel by volume purchased after the date of the enactment of this section, for use by the fleet or covered person in vehicles owned or operated by the fleet or covered person that weigh more than 8,500 pounds gross vehicle weight rating.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfb4c8c2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13220/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No credits shall be allocated under paragraph (1) for a purchase of biodiesel—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfb4c8c3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13220/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for use in alternative fueled vehicles; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfb4c8c4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13220/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is required by Federal or State law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfb4c8c5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13220/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to modify percentage","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may, by rule, lower the 20 percent biodiesel volume requirement in paragraph (1) for reasons related to cold start, safety, or vehicle function considerations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfb4c8c6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13220/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Documentation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A fleet or covered person seeking a credit under this section shall provide written documentation to the Secretary supporting the allocation of a credit to such fleet or covered person under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfb4c8c7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13220/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of credits","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfb4c8c8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13220/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"At the request of a fleet or covered person allocated a credit under subsection (a), the Secretary shall, for the year in which the purchase of a qualifying volume is made, treat that purchase as the acquisition of one alternative fueled vehicle the fleet or covered person is required to acquire under this subchapter, subchapter II, or subchapter III.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfb4c8c9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13220/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Credits allocated under subsection (a) may not be used to satisfy more than 50 percent of the alternative fueled vehicle requirements of a fleet or covered person under this subchapter, subchapter II, and subchapter III. This paragraph shall not apply to a fleet or covered person that is a biodiesel alternative fuel provider described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s13251/a/2/A"},"text":"section 13251(a)(2)(A) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfb4c8ca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13220/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Credit not a section 13258 credit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A credit under this section shall not be considered a credit under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s13258"},"text":"section 13258 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfb4c8cb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13220/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Issuance of rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall, before ","children":[{"tag":"date","attrib":{"date":"1999-01-01"},"text":"January 1, 1999","children":[],"tail":", issue a rule establishing procedures for the implementation of this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfb4c8cc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13220/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collection of data","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall collect such data as are required to make a determination described in subsection (f)(2)(B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfb4c8cd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13220/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfb4c8ce-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13220/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “biodiesel”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfb4c8cf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13220/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means a diesel fuel substitute produced from nonpetroleum renewable resources that meets the registration requirements for fuels and fuel additives established by the Environmental Protection Agency under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7545"},"text":"section 7545 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfb4c8d0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13220/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" includes biodiesel derived from—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbfb4c8d1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13220/f/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" animal wastes, including poultry fats and poultry wastes, and other waste materials; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbfb4c8d2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13220/f/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" municipal solid waste and sludges and oils derived from wastewater and the treatment of wastewater; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfb4c8d3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13220/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “qualifying volume” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfb4c8d4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13220/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 450 gallons; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfb4c8d5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13220/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the Secretary determines by rule that the average annual alternative fuel use in light duty vehicles by fleets and covered persons exceeds 450 gallons or gallon equivalents, the amount of such average annual alternative fuel use.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfb4c8d6-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/tIII/s312"},"text":"Pub. L. 102–486, title III, § 312","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dA/s101/a/tXII/s1201/a"},"text":"Pub. L. 105–277, div. A, § 101(a) [title XII, § 1201(a)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681"},"text":"112 Stat. 2681","children":[],"tail":", 2681–48; "},{"tag":"ref","attrib":{"href":"/us/pl/105/388/s7/a"},"text":"Pub. L. 105–388, § 7(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3480"},"text":"112 Stat. 3480","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/58/tXV/s1515"},"text":"Pub. L. 109–58, title XV, § 1515","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1091"},"text":"119 Stat. 1091","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbfb4c8d7-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbfb4c8d8-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbfb4c8d9-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of this section, referred to in subsec. (a)(1), probably means ","children":[{"tag":"date","attrib":{"date":"1998-10-21"},"text":"October 21, 1998","children":[],"tail":", the date of the enactment of this section by "},{"tag":"ref","attrib":{"href":"/us/pl/105/277"},"text":"Pub. L. 105–277","children":[],"tail":", rather than "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", the date of the enactment of this section by "},{"tag":"ref","attrib":{"href":"/us/pl/105/388"},"text":"Pub. L. 105–388","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This subchapter, referred to in subsec. (b), was in the original “this title”, meaning title III of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486"},"text":"Pub. L. 102–486","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2866"},"text":"106 Stat. 2866","children":[],"tail":", which enacted this subchapter, amended "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s6374"},"text":"section 6374 of this title","children":[],"tail":", and repealed provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s6374"},"text":"section 6374 of this title","children":[],"tail":". For complete classification of title III to the Code, see Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subchapter II, referred to in subsec. (b), was in the original “title IV”, meaning title IV of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486"},"text":"Pub. L. 102–486","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2875"},"text":"106 Stat. 2875","children":[],"tail":", which enacted subchapter II (§ 13231 et seq.) of this chapter, amended sections 6374a and 6374b and former "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s6374c"},"text":"section 6374c of this title","children":[],"tail":" and sections 717, 717a, 2001, 2002, 2006, and 2013 of Title 15, Commerce and Trade, enacted provisions set out as notes under former section 79b and "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s717"},"text":"section 717 of Title 15","children":[],"tail":", and repealed provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s717c"},"text":"section 717c of Title 15","children":[],"tail":". For complete classification of title IV to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbfb4c8da-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277"},"text":"Pub. L. 105–277","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/105/388"},"text":"Pub. L. 105–388","children":[],"tail":" enacted identical sections."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbfb4c8db-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2005—Subsec. (f)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58"},"text":"Pub. L. 109–58","children":[],"tail":" inserted dash after “ ‘biodiesel’ ”, designated remainder of existing provisions as subpar. (A), and added subpar. (B)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
