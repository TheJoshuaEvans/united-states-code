{"tag":"section","attrib":{"id":"idb6e2f0e0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–32"},"text":null,"children":[{"tag":"num","attrib":{"value":"300mm–32"},"text":"§ 300mm–32.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Followup monitoring and treatment of certified-eligible WTC survivors for WTC-related health conditions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb6e2f0e1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–32/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subsection (b), the provisions of sections 300mm–21 and 300mm–22 of this title shall apply to followup monitoring and treatment of WTC-related health conditions for certified-eligible WTC survivors in the same manner as such provisions apply to the monitoring and treatment of WTC-related health conditions for enrolled WTC responders.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6e2f0e2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–32/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" List of WTC-related health conditions for survivors","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The list of health conditions for screening-eligible WTC survivors and certified-eligible WTC survivors consists of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6e2f0e3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–32/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Aerodigestive disorders","children":[],