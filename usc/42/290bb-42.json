{"tag":"section","attrib":{"id":"idb5b67e3a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–42"},"text":null,"children":[{"tag":"num","attrib":{"value":"290bb–42"},"text":"§ 290bb–42.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Improving uptake and patient access to integrated care services","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5b67e3b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–42/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5b67e3c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–42/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible entity” means a State, or an appropriate State agency, in collaboration with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5b67e3d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–42/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 or more qualified community programs as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x–2/b/1"},"text":"section 300x–2(b)(1) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5b67e3e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–42/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 or more health centers (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s254b/a"},"text":"section 254b(a) of this title","children":[],"tail":"), rural health clinics (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395x/aa"},"text":"section 1395x(aa) of this title","children":[],"tail":"), or Federally qualified health centers (as defined in such section), or primary care practices serving adult or pediatric patients or both."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5b67e3f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–42/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Integrated care; bidirectional integrated care","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5b67e40-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–42/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “integrated care” means collaborative models, including the psychiatric collaborative care model and other evidence-based or evidence-informed models, or practices for coordinating and jointly delivering behavioral and physical health services, which may include practices that share the same space in the same facility.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5b67e41-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–42/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “bidirectional integrated care” means the integration of behavioral health care and specialty physical health care, and the integration of primary and physical health care within specialty behavioral health settings, including within primary health care settings.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5b67e42-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–42/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Psychiatric collaborative care model","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “psychiatric collaborative care model” means the evidence-based, integrated behavioral health service delivery method that includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5b67e43-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–42/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" care directed by the primary care team;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5b67e44-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–42/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" structured care management;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5b67e45-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–42/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" regular assessments of clinical status using developmentally appropriate, validated tools; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5b67e46-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–42/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" modification of treatment as appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5b67e47-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–42/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special population","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “special population” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5b67e48-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–42/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adults with a serious mental illness or adults who have co-occurring mental illness and physical health conditions or chronic disease;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5b67e49-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–42/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" children and adolescents with a serious emotional disturbance who have a co-occurring physical health condition or chronic disease;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5b67e4a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–42/a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" individuals with a substance use disorder; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5b67e4b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–42/a/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" individuals with a mental illness who have a co-occurring substance use disorder.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5b67e4c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–42/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants and cooperative agreements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5b67e4d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–42/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may award grants and cooperative agreements to eligible entities to support the improvement of integrated care for physical and behavioral health care in accordance with paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5b67e4e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–42/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A grant or cooperative agreement awarded under this section shall be used—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5b67e4f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–42/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to promote full integration and collaboration in clinical practices between physical and behavioral health care, including for special populations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5b67e50-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–42/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to support the improvement of integrated care models for physical and behavioral health care to improve overall wellness and physical health status, including for special populations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5b67e51-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–42/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to promote the implementation and improvement of bidirectional integrated care services provided at entities described in subsection (a)(1), including evidence-based or evidence-informed screening, assessment, diagnosis, prevention, treatment, and recovery services for mental and substance use disorders, and co-occurring physical health conditions and chronic diseases; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5b67e52-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–42/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of an eligible entity that is collaborating with a primary care practice, to support the implementation of evidence-based or evidence-informed integrated care models, including the psychiatric collaborative care model, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb5b67e53-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–42/b/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by hiring staff;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5b67e54-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–42/b/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by identifying and formalizing contractual relationships with other health care providers or other relevant entities offering care management and behavioral health consultation to facilitate the adoption of integrated care, including, as applicable, providers who will function as psychiatric consultants and behavioral health care managers in providing behavioral health integration services through the collaborative care model;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5b67e55-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–42/b/2/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by purchasing or upgrading software and other resources, as applicable, needed to appropriately provide behavioral health integration, including resources needed to establish a patient registry and implement measurement-based care; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5b67e56-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–42/b/2/D/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for such other purposes as the Secretary determines to be applicable and appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5b67e57-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–42/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5b67e58-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–42/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An eligible entity that is seeking a grant or cooperative agreement under this section shall submit an application to the Secretary at such time, in such manner, and accompanied by such information as the Secretary may require, including the contents described in paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5b67e59-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–42/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents for awards","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any such application of an eligible entity seeking a grant or cooperative agreement under this section shall include, as applicable—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5b67e5a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–42/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of a plan to achieve fully collaborative agreements to provide bidirectional integrated care to special populations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5b67e5b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–42/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a summary of the policies, if any, that are barriers to the provision of integrated care, and the specific steps, if applicable, that will be taken to address such barriers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5b67e5c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–42/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of partnerships or other arrangements with local health care providers to provide services to special populations and, as applicable, in areas with demonstrated need, such as Tribal, rural, or other medically underserved communities, such as those with a workforce shortage of mental health and substance use disorder, pediatric mental health, or other related professionals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5b67e5d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–42/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an agreement and plan to report to the Secretary performance measures necessary to evaluate patient outcomes and facilitate evaluations across participating projects; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5b67e5e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–42/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the plan or progress in implementing the psychiatric collaborative care model, as applicable and appropriate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5b67e5f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–42/c/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the plan or progress of evidence-based or evidence-informed integrated care models other than the psychiatric collaborative care model implemented by primary care practices, as applicable and appropriate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5b67e60-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–42/c/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a plan for sustainability beyond the grant or cooperative agreement period under subsection (e).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5b67e61-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–42/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant and cooperative agreement amounts","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5b67e62-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–42/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Target amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The target amount that an eligible entity may receive for a year through a grant or cooperative agreement under this section shall be no more than $2,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5b67e63-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–42/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustment permitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, taking into consideration the quality of an eligible entity’s application and the number of eligible entities that received grants under this section prior to ","children":[{"tag":"date","attrib":{"date":"2022-12-29"},"text":"December 29, 2022","children":[],"tail":", may adjust the target amount that an eligible entity may receive for a year through a grant or cooperative agreement under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5b67e64-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–42/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An eligible entity that is receiving funding under subsection (b)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5b67e65-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–42/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not allocate more than 10 percent of the funds awarded to such eligible entity under this section to administrative functions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5b67e66-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–42/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall allocate the remainder of such funding to health facilities that provide integrated care.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5b67e67-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–42/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A grant or cooperative agreement under this section shall be for a period not to exceed 5 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5b67e68-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–42/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report on program outcomes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An eligible entity receiving a grant or cooperative agreement under this section shall submit an annual report to the Secretary. Such annual report shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5b67e69-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–42/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the progress made to reduce barriers to integrated care as described in the entity’s application under subsection (c);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5b67e6a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–42/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of outcomes with respect to each special population listed in subsection (a)(4), including outcomes related to education, employment, and housing, or, as applicable and appropriate, outcomes for such populations receiving behavioral health care through the psychiatric collaborative care model in primary care practices; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5b67e6b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–42/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" progress in meeting performance metrics and other relevant benchmarks; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5b67e6c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–42/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other information that the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5b67e6d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–42/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance for primary-behavioral health care integration","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5b67e6e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–42/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain recipients","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may provide appropriate information, training, and technical assistance to eligible entities that receive a grant or cooperative agreement under subsection (b)(2), in order to help such entities meet the requirements of this section, including assistance with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5b67e6f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–42/g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" development and selection of integrated care models;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5b67e70-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–42/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" dissemination of evidence-based interventions in integrated care;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5b67e71-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–42/g/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishment of organizational practices to support operational and administrative success; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5b67e72-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–42/g/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as appropriate, appropriate information, training, and technical assistance in implementing the psychiatric collaborative care model when an eligible entity is collaborating with 1 or more primary care practices for the purposes of implementing the psychiatric collaborative care model.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5b67e73-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–42/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional dissemination of technical information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to providing the assistance described in paragraph (1) to recipients of a grant or cooperative agreement under this section, the Secretary may also provide such assistance to other States and political subdivisions of States, Indian Tribes and Tribal organizations, as those terms are defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304"},"text":"section 5304 of title 25","children":[],"tail":", outpatient mental health and addiction treatment centers, community mental health centers that meet the criteria under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x–2/c"},"text":"section 300x–2(c) of this title","children":[],"tail":", certified community behavioral health clinics described in section 223 of the Protecting Access to Medicare Act of 2014, primary care organizations such as Federally qualified health centers or rural health clinics as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395x/aa"},"text":"section 1395x(aa) of this title","children":[],"tail":", primary health care practices, the community-based organizations, and other entities engaging in integrated care activities, as the Secretary determines appropriate."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5b67e74-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–42/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 18 months after ","children":[{"tag":"date","attrib":{"date":"2022-12-29"},"text":"December 29, 2022","children":[],"tail":", and annually thereafter, the Secretary shall submit a report to the Committee on Health, Education, Labor, and Pensions of the Senate and the Committee on Energy and Commerce of the House of Representatives summarizing the information submitted in reports to the Secretary under subsection (f), including progress made in meeting performance metrics and the uptake of integrated care models, any adjustments made to target amounts pursuant to subsection (d)(2), and any other relevant information."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5b67e75-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–42/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5b67e76-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–42/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To carry out this section, there is authorized to be appropriated $60,000,000 for each of fiscal years 2023 through 2027.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5b67e77-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–42/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Increasing uptake of the psychiatric collaborative care model by primary care practices","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not less than 10 percent of funds appropriated to carry out this section shall be for the purposes of implementing the psychiatric collaborative care model implemented by primary care practices under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5b67e78-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–42/i/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding contingency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraph (2) shall not apply to a fiscal year unless the amount made available to carry out this section for such fiscal year exceeds the amount appropriated to carry out this section (as in effect before ","children":[{"tag":"date","attrib":{"date":"2022-12-29"},"text":"December 29, 2022","children":[],"tail":") for fiscal year 2022."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5b67e79-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", ch.373, title V, § 520K, as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tV/s5604"},"text":"Pub. L. 111–148, title V, § 5604","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/679"},"text":"124 Stat. 679","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/255/dB/tIX/s9003"},"text":"Pub. L. 114–255, div. B, title IX, § 9003","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-13"},"text":"Dec. 13, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1235"},"text":"130 Stat. 1235","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dFF/tI/s1301"},"text":"Pub. L. 117–328, div. FF, title I, § 1301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5692"},"text":"136 Stat. 5692","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb5b67e7a-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb5b67e7b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb5b67e7c-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 223 of the Protecting Access to Medicare Act of 2014, referred to in subsec. (g)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/93/s223"},"text":"section 223 of Pub. L. 113–93","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1396a"},"text":"section 1396a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb5b67e7d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328"},"text":"Pub. L. 117–328","children":[],"tail":" amended section generally. Prior to amendment, section authorized Secretary to award grants and cooperative agreements to eligible entities to support improvement of integrated care for primary care and behavioral health care."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255"},"text":"Pub. L. 114–255","children":[],"tail":" amended section generally. Prior to amendment, section related to awards for co-locating primary and specialty care in community-based mental health settings."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
