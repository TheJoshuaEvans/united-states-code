{"tag":"section","attrib":{"id":"idbc7973b8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3217"},"text":null,"children":[{"tag":"num","attrib":{"value":"3217"},"text":"§ 3217.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maintenance and public inspection of list of approved applications for financial assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbc7973b9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3217/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc7973ba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3217/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain as a permanent part of the records of the Department a list of applications approved for financial assistance under this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc7973bb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3217/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make the list available for public inspection during the regular business hours of the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc7973bc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3217/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additions to list","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The following information shall be added to the list maintained under subsection (a) as soon as an application described in subsection (a)(1) is approved:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc7973bd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3217/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The name of the applicant and, in the case of a corporate application, the name of each officer and director of the corporation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc7973be-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3217/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amount and duration of the financial assistance for which application is made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc7973bf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3217/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The purposes for which the proceeds of the financial assistance are to be used.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc7973c0-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/136/tVI/s607"},"text":"Pub. L. 89–136, title VI, § 607","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/393/tI/s102/a"},"text":"Pub. L. 105–393, title I, § 102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3615"},"text":"112 Stat. 3615","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc7973c1-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc7973c2-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbc7973c3-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 3217, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/136/tVII/s707"},"text":"Pub. L. 89–136, title VII, § 707","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-08-26"},"text":"Aug. 26, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/573"},"text":"79 Stat. 573","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/273/s26"},"text":"Pub. L. 94–273, § 26","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-04-21"},"text":"Apr. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/380"},"text":"90 Stat. 380","children":[],"tail":", required annual report to Congress on operations under this chapter, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/105/393/s102/b/3"},"text":"Pub. L. 105–393, § 102(b)(3)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbc7973c4-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbc7973c5-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date