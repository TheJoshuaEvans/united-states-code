{"tag":"section","attrib":{"id":"idb6515f06-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300n–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"300n–1"},"text":"§ 300n–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Description of intended uses of grant","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary may not make a grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300k"},"text":"section 300k of this title","children":[],"tail":" unless—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6515f07-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300n–1/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State involved submits to the Secretary a description of the purposes for which the State intends to expend the grant;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6515f08-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300n–1/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the description identifies the populations, areas, and localities in the State with a need for the services or activities described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300k/a"},"text":"section 300k(a) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6515f09-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300n–1/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the description provides information relating to the services and activities to be provided, including a description of the manner in which the services and activities will be coordinated with any similar services or activities of public and private entities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6515f0a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300n–1/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the description provides assurances that the grant funds will be used in the most cost-effective manner.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb6515f0b-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XV, § 1505, as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/354/s2"},"text":"Pub. L. 101–354, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-08-10"},"text":"Aug. 10, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/414"},"text":"104 Stat. 414","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/43/tXX/s2008/c/2"},"text":"Pub. L. 103–43, title XX, § 2008(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-06-10"},"text":"June 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/211"},"text":"107 Stat. 211","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/183/tI/s101/g/2"},"text":"Pub. L. 103–183, title I, § 101(g)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-14"},"text":"Dec. 14, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2229"},"text":"107 Stat. 2229","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/392/tIV/s401/b/6"},"text":"Pub. L. 105–392, title IV, § 401(b)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3587"},"text":"112 Stat. 3587","children