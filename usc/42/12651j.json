{"tag":"section","attrib":{"id":"idbf8ea2f5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651j"},"text":null,"children":[{"tag":"num","attrib":{"value":"12651j"},"text":"§ 12651j.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assignment to State Commissions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf8ea2f6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651j/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assignment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12651d/c/1"},"text":"section 12651d(c)(1) of this title","children":[],"tail":", the Chief Executive Officer may assign to State Commissions specific programmatic functions upon a determination that such an assignment will increase efficiency in the operation or oversight of a program under the national service laws. In carrying out this section, and before executing any assignment of authority, the Corporation shall seek input from and consult Corporation employees, State Commissions, State educational agencies, and other interested stakeholders."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf8ea2f7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651j/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 2 years after the effective date of the Serve America Act, the Corporation shall submit a report to the authorizing committees describing the consultation process described in subsection (a), including the stakeholders consulted, the recommendation of stakeholders, and any actions taken by the Corporation under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf8ea2f8-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/610/tI/s196B"},"text":"Pub. L. 101–610, title I, § 196B","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/13/tI/s1708"},"text":"Pub. L. 111–13, title I, § 1708","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-04-21"},"text":"Apr. 21, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1548"},"text":"123 Stat. 1548","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf8ea2f9-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf8ea2fa-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbf8ea2fb-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For the effective date of the Serve America Act, referred to in subsec. (b), as ","children":[{"tag":"date","attrib":{"date":"2009-10-01"},"text":"Oct. 1, 2009","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/111/13/s6101/a"},"text":"section 6101(a) of Pub. L. 111–13","children":[],"tail":", set out as an Effective Date of 2009 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4950"},"text":"section 4950 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbf8ea2fc-3a70-11f1-ae07-e4213316b5fa"},"text":nu