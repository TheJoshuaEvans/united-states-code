{"tag":"section","attrib":{"id":"idbc666134-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3057e"},"text":null,"children":[{"tag":"num","attrib":{"value":"3057e"},"text":"§ 3057e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbc666135-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3057e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval criteria; provisions and assurances","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No grant may be made under this part unless the eligible tribal organization submits an application to the Assistant Secretary which meets such criteria as the Assistant Secretary may by regulation prescribe. Each such application shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc666136-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3057e/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide that the eligible tribal organization will evaluate the need for supportive and nutrition services among older individuals who are Indians to be represented by the tribal organization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc666137-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3057e/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for the use of such methods of administration as are necessary for the proper and efficient administration of the program to be assisted;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc666138-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3057e/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide that the tribal organization will make such reports in such form and containing such information, as the Assistant Secretary may reasonably require, and comply with such requirements as the Assistant Secretary may impose to assure the correctness of such reports;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc666139-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3057e/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for periodic evaluation of activities and projects carried out under the application;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc66613a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3057e/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish objectives consistent with the purposes of this part toward which activities under the application will be directed, identify obstacles to the attainment of such objectives, and indicate the manner in which the tribal organization proposes to overcome such obstacles;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc66613b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3057e/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for establishing and maintaining information and assistance services to assure that older individuals who are Indians to be served by the assistance made available under this part will have reasonably convenient access to such services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc66613c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3057e/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide a preference for older individuals who are Indians for full or part-time staff positions wherever feasible;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc66613d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3057e/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide assurances that either directly or by way of grant or contract with appropriate entities nutrition services will be delivered to older individuals who are Indians represented by the tribal organization substantially in compliance with the provisions of part C of subchapter III, except that in any case in which the need for nutritional services for older individuals who are Indians represented by the tribal organization is already met from other sources, the tribal organization may use the funds otherwise required to be expended under this paragraph for supportive services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc66613e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3057e/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide that any legal or ombudsman services made available to older individuals who are Indians represented by the tribal organization will be substantially in compliance with the provisions of subchapter III relating to the furnishing of similar services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc66613f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3057e/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide satisfactory assurance that fiscal control and fund accounting procedures will be adopted as may be necessary to assure proper disbursement of, and accounting for, Federal funds paid under this part to the tribal organization, including any funds paid by the tribal organization to a recipient of a grant or contract; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc666140-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3057e/a/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contain assurances that the tribal organization will coordinate services provided under this part with services provided under subchapter III in the same geographical area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc666141-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3057e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Population statistics development","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of any application submitted under this part, the tribal organization may develop its own population statistics, with approval from the Bureau of Indian Affairs, in order to establish eligibility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc666142-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3057e/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval by Assistant Secretary","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc666143-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3057e/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Assistant Secretary shall approve any application which complies with the provisions of subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc666144-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3057e/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Assistant Secretary shall provide waivers and exemptions of the reporting requirements of subsection (a)(3) for applicants that serve Indian populations in geographically isolated areas, or applicants that serve small Indian populations, where the small scale of the project, the nature of the applicant, or other factors make the reporting requirements unreasonable under the circumstances. The Assistant Secretary shall consult with such applicants in establishing appropriate waivers and exemptions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc666145-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3057e/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Assistant Secretary shall approve any application that complies with the provisions of subsection (a), except that in determining whether an application complies with the requirements of subsection (a)(8), the Assistant Secretary shall provide maximum flexibility to an applicant that seeks to take into account subsistence needs, local customs, and other characteristics that are appropriate to the unique cultural, regional, and geographic needs of the Indian populations to be served.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc666146-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3057e/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In determining whether an application complies with the requirements of subsection (a)(11), the Assistant Secretary shall require only that an applicant provide an appropriate narrative description of the geographic area to be served and an assurance that procedures will be adopted to ensure against duplicate services being provided to the same recipients.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc666147-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3057e/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disapproval by Assistant Secretary","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Whenever the Assistant Secretary determines not to approve an application submitted under subsection (a) the Assistant Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc666148-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3057e/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" state objections in writing to the tribal organization within 60 days after such decision;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc666149-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3057e/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide to the extent practicable technical assistance to the tribal organization to overcome such stated objections; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc66614a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3057e/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide the tribal organization with a hearing, under such rules and regulations as the Assistant Secretary may prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc66614b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3057e/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funds per year","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Whenever the Assistant Secretary approves an application of a tribal organization under this part, funds shall be awarded for not less than 12 months.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc66614c-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/73/tVI/s614"},"text":"Pub. L. 89–73, title VI, § 614","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/175/tI/s171"},"text":"Pub. L. 100–175, title I, § 171","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-11-29"},"text":"Nov. 29, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/960"},"text":"101 Stat. 960","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/375/tI/s102/b/4"},"text":"Pub. L. 102–375, title I, § 102(b)(4)","children":[],"tail":", title VI, § 601, title IX, § 904(a)(23), "},{"tag":"date","attrib":{"date":"1992-09-30"},"text":"Sept. 30, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1201"},"text":"106 Stat. 1201","children":[],"tail":", 1269, 1309; "},{"tag":"ref","attrib":{"href":"/us/pl/103/171"},"text":"Pub. L. 103–171","children":[],"tail":", §§ 2(21), 3(a)(13), "},{"tag":"date","attrib":{"date":"1993-12-02"},"text":"Dec. 2, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1989"},"text":"107 Stat. 1989","children":[],"tail":", 1990; "},{"tag":"ref","attrib":{"href":"/us/pl/106/501/tVI/s602"},"text":"Pub. L. 106–501, title VI, § 602","children":[],"tail":", title VIII, § 801(d), "},{"tag":"date","attrib":{"date":"2000-11-13"},"text":"Nov. 13, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2287"},"text":"114 Stat. 2287","children":[],"tail":", 2292; "},{"tag":"ref","attrib":{"href":"/us/pl/116/131/tVII/s701/11"},"text":"Pub. L. 116–131, title VII, § 701(11)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-03-25"},"text":"Mar. 25, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/271"},"text":"134 Stat. 271","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc66614d-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc66614e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbc66614f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 3057e, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/73/tVI/s606"},"text":"Pub. L. 89–73, title VI, § 606","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/95/478/tI/s106"},"text":"Pub. L. 95–478, title I, § 106","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-18"},"text":"Oct. 18, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1551"},"text":"92 Stat. 1551","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/97/115/s3/d"},"text":"Pub. L. 97–115, § 3(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-12-29"},"text":"Dec. 29, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1597"},"text":"95 Stat. 1597","children":[],"tail":", related to surplus educational facilities, prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/100/175"},"text":"Pub. L. 100–175","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3057f"},"text":"section 3057f of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbc666150-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—Subsec. (c)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/131"},"text":"Pub. L. 116–131","children":[],"tail":" substituted “(a)(11)” for “(a)(12)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (a)(9) to (12). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/501/s801/d"},"text":"Pub. L. 106–501, § 801(d)","children":[],"tail":", redesignated pars. (10) to (12) as (9) to (11), respectively, and struck out former par. (9) which read as follows: “contain assurances that the provisions of sections 3027(a)(14)(A)(i) and (iii), 3027(a)(14)(B), and 3027(a)(14)(C) of this title will be complied with whenever the application contains provisions for the acquisition, alteration, or renovation of facilities to serve as multipurpose senior centers;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/501/s602/1"},"text":"Pub. L. 106–501, § 602(1)","children":[],"tail":", substituted “approval” for “certification”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/501/s602/2"},"text":"Pub. L. 106–501, § 602(2)","children":[],"tail":", designated existing provisions as par. (1) and added pars. (2) to (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/171/s3/a/13"},"text":"Pub. L. 103–171, § 3(a)(13)","children":[],"tail":", substituted “Assistant Secretary” for “Commissioner” wherever appearing in introductory provisions and in par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/171/s2/21"},"text":"Pub. L. 103–171, § 2(21)","children":[],"tail":", substituted “Assistant Secretary” for “Commission”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/171"},"text":"Pub. L. 103–171","children":[],"tail":", §§ 2(21), 3(a)(13), in introductory provisions, substituted “Assistant Secretary determines” for “Commissioner determines” and “Assistant Secretary shall” for “Commission shall” and, in par. (3), substituted “Assistant Secretary” for “Commissioner”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/171/s3/a/13"},"text":"Pub. L. 103–171, § 3(a)(13)","children":[],"tail":", substituted “Assistant Secretary” for “Commissioner”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/375/s904/a/23/C"},"text":"Pub. L. 102–375, § 904(a)(23)(C)","children":[],"tail":", inserted “individuals who are” after “older”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/375"},"text":"Pub. L. 102–375","children":[],"tail":", §§ 102(b)(4), 904(a)(23)(C), substituted “information and assistance” for “information and referral” and inserted “individuals who are” after “older”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/375/s904/a/23/A"},"text":"Pub. L. 102–375, § 904(a)(23)(A)","children":[],"tail":", substituted “older individuals who are Indians” for “Indians aged 60 and older”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/375/s904/a/23/B"},"text":"Pub. L. 102–375, § 904(a)(23)(B)","children":[],"tail":", (C), inserted “individuals who are” after “older” in two places and substituted “paragraph” for “clause”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(10). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/375/s904/a/23/C"},"text":"Pub. L. 102–375, § 904(a)(23)(C)","children":[],"tail":", inserted “individuals who are” after “older”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(12). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/375/s601"},"text":"Pub. L. 102–375, § 601","children":[],"tail":", added par. (12)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbc666151-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbc666152-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1992 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/375/s601"},"text":"section 601 of Pub. L. 102–375","children":[],"tail":" inapplicable to fiscal year 1992, see "},{"tag":"ref","attrib":{"href":"/us/pl/102/375/s905/b/5"},"text":"section 905(b)(5) of Pub. L. 102–375","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbc666153-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1987-10-01"},"text":"Oct. 1, 1987","children":[],"tail":", except not applicable with respect to any area plan submitted under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3026/a"},"text":"section 3026(a) of this title","children":[],"tail":" or any State plan submitted under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3027/a"},"text":"section 3027(a) of this title","children":[],"tail":" and approved for any fiscal year beginning before "},{"tag":"date","attrib":{"date":"1987-11-29"},"text":"Nov. 29, 1987","children":[],"tail":", see section 701(a), (b) of "},{"tag":"ref","attrib":{"href":"/us/pl/100/175"},"text":"Pub. L. 100–175","children":[],"tail":", set out as an Effective Date of 1987 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
