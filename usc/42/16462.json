{"tag":"section","attrib":{"id":"idc01696e5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16462"},"text":null,"children":[{"tag":"num","attrib":{"value":"16462"},"text":"§ 16462.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Service allocation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc01696e6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16462/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of public utility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “public utility” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s824/e"},"text":"section 824(e) of title 16","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc01696e7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16462/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" FERC review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of non-power goods or administrative or management services provided by an associate company organized specifically for the purpose of providing such goods or services to any public utility in the same holding company system, at the election of the system or a State commission having jurisdiction over the public utility, the Commission, after the effective date of this part, shall review and authorize the allocation of the costs for such goods or services to the extent relevant to that associate company.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc01696e8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16462/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect on Federal and State law","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall affect the authority of the Commission or a State commission under other applicable law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc01696e9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16462/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 4 months after ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":", the Commission shall issue rules (which rules shall be effective no earlier than the effective date of this part) to exempt from the requirements of this section any company in a holding company system whose public utility operations are confined substantially to a single State and any other class of transactions that the Commission finds is not relevant to the jurisdictional rates of a public utility."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc01696ea-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tXII/s1275"},"text":"Pub. L. 109–58, title XII, § 1275","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/977"},"text":"119 Stat. 977","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc01696eb-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc01696ec-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc01696ed-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For the effective date of this part, referred to in subsecs. (b) and (d), see Effective Date note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16451"},"text":"section 16451 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
