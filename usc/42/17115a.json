{"tag":"section","attrib":{"id":"idc027618c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17115a"},"text":null,"children":[{"tag":"num","attrib":{"value":"17115a"},"text":"§ 17115a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Development of national smart manufacturing plan","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc027618d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17115a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 3 years after ","children":[{"tag":"date","attrib":{"date":"2020-12-27"},"text":"December 27, 2020","children":[],"tail":", the Secretary of Energy (in this section referred to as the “Secretary”), in consultation with the National Academies, shall develop and complete a national plan for smart manufacturing technology development and deployment to improve the productivity and energy efficiency of the manufacturing sector of the United States."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc029a97e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17115a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Content","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc029a97f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17115a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The plan developed under subsection (a) shall identify areas in which agency actions by the Secretary and other heads of relevant Federal agencies would—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc029a980-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17115a/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitate quicker development, deployment, and adoption of smart manufacturing technologies and processes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc029a981-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17115a/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" result in greater energy efficiency and lower environmental impacts for all American manufacturers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc029a982-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17115a/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhance competitiveness and strengthen the manufacturing sectors of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc029a983-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17115a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Agency actions identified under paragraph (1) shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc029a984-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17115a/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of previous and current actions of the Department relating to smart manufacturing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc029a985-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17115a/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the establishment of voluntary interconnection protocols and performance standards;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc029a986-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17115a/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use of smart manufacturing to improve energy efficiency and reduce emissions in supply chains across multiple companies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc029a987-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17115a/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" actions to increase cybersecurity in smart manufacturing infrastructure;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc029a988-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17115a/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deployment of existing research results;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc029a989-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17115a/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the leveraging of existing high-performance computing infrastructure; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc029a98a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17115a/b/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consideration of the impact of smart manufacturing on existing manufacturing jobs and future manufacturing jobs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc029a98b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17115a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Biennial revisions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 2 years after the date on which the Secretary completes the plan under subsection (a), and not less frequently than once every 2 years thereafter, the Secretary shall revise the plan to account for advancements in information and communication technology and manufacturing needs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc029a98c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17115a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Annually until the completion of the plan under subsection (a), the Secretary shall submit to Congress a report on the progress made in developing the plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc029a98d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17115a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “smart manufacturing” means advanced technologies in information, automation, monitoring, computation, sensing, modeling, artificial intelligence, analytics, and networking that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc029a98e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17115a/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" digitally—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc029a98f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17115a/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" simulate manufacturing production lines;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc029a990-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17115a/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operate computer-controlled manufacturing equipment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc029a991-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17115a/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" monitor and communicate production line status; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc029a992-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17115a/e/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" manage and optimize energy productivity and cost throughout production;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc029a993-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17115a/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" model, simulate, and optimize the energy efficiency of a factory building;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc029a994-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17115a/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" monitor and optimize building energy performance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc029a995-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17115a/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" model, simulate, and optimize the design of energy efficient and sustainable products, including the use of digital prototyping and additive manufacturing to enhance product design;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc029a996-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17115a/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" connect manufactured products in networks to monitor and optimize the performance of the networks, including automated network operations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc029a997-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17115a/e/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" digitally connect the supply chain network.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc029a998-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dZ/tVI/s6006"},"text":"Pub. L. 116–260, div. Z, title VI, § 6006","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2560"},"text":"134 Stat. 2560","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc029a999-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc029a99a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idc029a99b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Energy Act of 2020, and not as part of the Energy Independence and Security Act of 2007 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
