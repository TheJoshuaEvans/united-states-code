{"tag":"section","attrib":{"id":"idb573a868-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285e–8"},"text":null,"children":[{"tag":"num","attrib":{"value":"285e–8"},"text":"§ 285e–8.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dissemination project","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb573a869-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285e–8/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant or contract for establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the Institute shall make a grant to, or enter into a contract with, a national organization representing individuals with Alzheimer’s disease and related dementias for the conduct of the activities described in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb573a86a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285e–8/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Project activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The organization receiving a grant or contract under this section shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb573a86b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285e–8/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" establish a central computerized information system to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb573a86c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285e–8/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compile and disseminate information concerning initiatives by State and local governments and private entities to provide programs and services for individuals with Alzheimer’s disease and related dementias; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb573a86d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285e–8/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" translate scientific and technical information concerning such initiatives into information readily understandable by the general public, and make such information available upon request; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb573a86e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285e–8/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish a national toll-free telephone line to make available the information described in paragraph (1), and information concerning Federal programs, services, and benefits for individuals with Alzheimer’s disease and related dementias and their families.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb573a86f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285e–8/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fees for information; exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The organization receiving a grant or contract under this section may charge appropriate fees for information provided through the toll-free telephone line established under subsection (b)(2), and may make exceptions to such fees for individuals and organizations who are not financially able to pay such fees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb573a870-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285e–8/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application for grant or contract; contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In order to receive a grant or contract under this section, an organization shall submit an application to the Director of the Institute. Such application shall contain—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb573a871-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285e–8/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information demonstrating that such organization has a network of contacts which will enable such organization to receive information necessary to the operation of the central computerized information system described in subsection (b)(1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb573a872-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285e–8/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information demonstrating that, by the end of fiscal year 1991, such organization will be financially able to, and will, carry out the activities described in subsection (b) without a grant or contract from the Federal Government; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb573a873-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285e–8/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other information as the Director may prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb573a874-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title IV, § 445F, formerly "},{"tag":"ref","attrib":{"href":"/us/pl/99/660/tIX/s952"},"text":"Pub. L. 99–660, title IX, § 952","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3813"},"text":"100 Stat. 3813","children":[],"tail":"; renumbered § 445F of act "},{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", and amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/607/tI/s142/a"},"text":"Pub. L. 100–607, title I, § 142(a)","children":[],"tail":", (d)(5), "},{"tag":"date","attrib":{"date":"1988-11-04"},"text":"Nov. 4, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3057"},"text":"102 Stat. 3057","children":[],"tail":", 3058.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb573a875-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb573a876-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb573a877-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11282"},"text":"section 11282 of this title","children":[],"tail":" prior to renumbering by "},{"tag":"ref","attrib":{"href":"/us/pl/100/607"},"text":"Pub. L. 100–607","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb573a878-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/607/s142/a"},"text":"Pub. L. 100–607, § 142(a)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s11282"},"text":"section 11282 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (a), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/607/s142/d/5"},"text":"Pub. L. 100–607, § 142(d)(5)","children":[],"tail":", substituted “the Institute” for “the National Institute on Aging”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
