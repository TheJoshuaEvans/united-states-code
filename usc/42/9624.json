{"tag":"section","attrib":{"id":"idbed257cd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9624"},"text":null,"children":[{"tag":"num","attrib":{"value":"9624"},"text":"§ 9624.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Methane recovery","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbed257ce-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9624/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a facility at which equipment for the recovery or processing (including recirculation of condensate) of methane has been installed, for purposes of this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbed257cf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9624/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The owner or operator of such equipment shall not be considered an “owner or operator”, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s9601/20"},"text":"section 9601(20) of this title","children":[],"tail":", with respect to such facility."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbed257d0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9624/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The owner or operator of such equipment shall not be considered to have arranged for disposal or treatment of any hazardous substance at such facility pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s9607"},"text":"section 9607 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbed257d1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9624/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The owner or operator of such equipment shall not be subject to any action under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s9606"},"text":"section 9606 of this title","children":[],"tail":" with respect to such facility."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbed257d2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9624/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsection (a) does not apply with respect to a release or threatened release of a hazardous substance from a facility described in subsection (a) if either of the following circumstances exist:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbed257d3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9624/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The release or threatened release was primarily caused by activities of the owner or operator of the equipment described in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbed257d4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9624/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The owner or operator of such equipment would be covered by paragraph (1), (2), (3), or (4) of subsection (a) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s9607"},"text":"section 9607 of this title","children":[],"tail":" with respect to such release or threatened release if he were not the owner or operator of such equipment."}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"In the case of any release or threatened release referred to in paragraph (1), the owner or operator of the equipment described in subsection (a) shall be liable under this chapter only for costs or damages primarily caused by the activities of such owner or operator.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbed257d5-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/510/tI/s124"},"text":"Pub. L. 96–510, title I, § 124","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/499/tI/s124/a"},"text":"Pub. L. 99–499, title I, § 124(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-17"},"text":"Oct. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1688"},"text":"100 Stat. 1688","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbed257d6-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbed257d7-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbed257d8-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/510"},"text":"Pub. L. 96–510","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-11"},"text":"Dec. 11, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2767"},"text":"94 Stat. 2767","children":[],"tail":", known as the Comprehensive Environmental Response, Compensation, and Liability Act of 1980, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s9601"},"text":"section 9601 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
