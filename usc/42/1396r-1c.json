{"tag":"section","attrib":{"id":"idba7d7c5e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396r–1c"},"text":null,"children":[{"tag":"num","attrib":{"value":"1396r–1c"},"text":"§ 1396r–1c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Presumptive eligibility for family planning services","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idba7d7c5f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396r–1c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State option","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"State ","children":[{"tag":"ref","attrib":{"idref":"fn003045"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003045"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be preceded by “A”."}],"tail":" plan approved under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1396a"},"text":"section 1396a of this title","children":[],"tail":" may provide for making medical assistance available to an individual described in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1396a/ii"},"text":"section 1396a(ii) of this title","children":[],"tail":" (relating to individuals who meet certain income eligibility standard) during a presumptive eligibility period. In the case of an individual described in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1396a/ii"},"text":"section 1396a(ii) of this title","children":[],"tail":", such medical assistance shall be limited to family planning services and supplies described in 1396d(a)(4)(C) "},{"tag":"ref","attrib":{"idref":"fn003046"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003046"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be preceded by “section”."}],"tail":" of this title and, at the State’s option, medical diagnosis and treatment services that are provided in conjunction with a family planning service in a family planning setting."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idba7d7c60-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396r–1c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idba7d7c61-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396r–1c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Presumptive eligibility period","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “presumptive eligibility period” means, with respect to an individual described in subsection (a), the period that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idba7d7c62-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396r–1c/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" begins with the date on which a qualified entity determines, on the basis of preliminary information, that the individual is described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1396a/ii"},"text":"section 1396a(ii) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idba7d7c63-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396r–1c/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" ends with (and includes) the earlier of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idba7d7c64-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396r–1c/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the day on which a determination is made with respect to the eligibility of such individual for services under the State plan; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idba7d7c65-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396r–1c/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of such an individual who does not file an application by the last day of the month following the month during which the entity makes the determination referred to in subparagraph (A), such last day.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idba7d7c66-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396r–1c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified entity","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idba7d7c67-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396r–1c/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subparagraph (B), the term “qualified entity” means any entity that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idba7d7c68-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396r–1c/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is eligible for payments under a State plan approved under this subchapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idba7d7c69-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396r–1c/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is determined by the State agency to be capable of making determinations of the type described in paragraph (1)(A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idba7d7c6a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396r–1c/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this paragraph shall be construed as preventing a State from limiting the classes of entities that may become qualified entities in order to prevent fraud and abuse.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idba7d7c6b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396r–1c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idba7d7c6c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396r–1c/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The State agency shall provide qualified entities with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idba7d7c6d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396r–1c/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such forms as are necessary for an application to be made by an individual described in subsection (a) for medical assistance under the State plan; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idba7d7c6e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396r–1c/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information on how to assist such individuals in completing and filing such forms.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idba7d7c6f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396r–1c/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A qualified entity that determines under subsection (b)(1)(A) that an individual described in subsection (a) is presumptively eligible for medical assistance under a State plan shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idba7d7c70-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396r–1c/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notify the State agency of the determination within 5 working days after the date on which determination is made; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idba7d7c71-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396r–1c/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inform such individual at the time the determination is made that an application for medical assistance is required to be made by not later than the last day of the month following the month during which the determination is made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idba7d7c72-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396r–1c/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application for medical assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of an individual described in subsection (a) who is determined by a qualified entity to be presumptively eligible for medical assistance under a State plan, the individual shall apply for medical assistance by not later than the last day of the month following the month during which the determination is made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idba7d7c73-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396r–1c/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of law, medical assistance that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idba7d7c74-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396r–1c/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is furnished to an individual described in subsection (a)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idba7d7c75-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396r–1c/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" during a presumptive eligibility period; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idba7d7c76-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396r–1c/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by a ","children":[{"tag":"ref","attrib":{"idref":"fn003047"},"text":"3","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003047"},"text":null,"children":[{"tag":"num","attrib":{},"text":"3","children":[],"tail":" So in original. Probably should be “an”."}],"tail":" entity that is eligible for payments under the State plan; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idba7d7c77-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396r–1c/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is included in the care and services covered by the State plan,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be treated as medical assistance provided by such plan for purposes of clause (4) of the first sentence of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1396d/b"},"text":"section 1396d(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idba7d7c78-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title XIX, § 1920C, as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tII/s2303/b/1"},"text":"Pub. L. 111–148, title II, § 2303(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/294"},"text":"124 Stat. 294","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idba7d7c79-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idba7d7c7a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idba7d7c7b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", and applicable to items and services furnished on or after such date, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/s2303/d"},"text":"section 2303(d) of Pub. L. 111–148","children":[],"tail":", set out as an Effective and Termination Dates of 2010 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1396a"},"text":"section 1396a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
