{"tag":"section","attrib":{"id":"idbce97391-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4952"},"text":null,"children":[{"tag":"num","attrib":{"value":"4952"},"text":"§ 4952.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to operate VISTA program","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"This part shall be administered by one of the Assistant Directors appointed pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12651e/d/1/A"},"text":"section 12651e(d)(1)(A) of this title","children":[],"tail":". Such Director may recruit, select, and train persons to serve in full-time volunteer programs consistent with the provisions and to carry out the purpose of this part."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbce97392-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/113/tI/s102"},"text":"Pub. L. 93–113, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-10-01"},"text":"Oct. 1, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/396"},"text":"87 Stat. 396","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/288/s3"},"text":"Pub. L. 98–288, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-05-21"},"text":"May 21, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/189"},"text":"98 Stat. 189","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/204/tI/s101/d/1"},"text":"Pub. L. 101–204, title I, § 101(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-07"},"text":"Dec. 7, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1811"},"text":"103 Stat. 1811","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/tIII/s322/a"},"text":"Pub. L. 103–82, title III, § 322(a)","children":[],"tail":",