":"ref","attrib":{"href":"/us/pl/100/607"},"text":"Pub. L. 100–607","children":[],"tail":" had not been enacted."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb575f388-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb575f389-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For effective date of amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690"},"text":"Pub. L. 100–690","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/s2613/b/1"},"text":"section 2613(b)(1) of Pub. L. 100–690","children":[],"tail":", set out as an Effect of Enactment of Similar Provisions note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s285m"},"text":"section 285m of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
