{"tag":"section","attrib":{"id":"idb575f383-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285j"},"text":null,"children":[{"tag":"num","attrib":{"value":"285j"},"text":"§ 285j.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose of Institute","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The general purpose of the National Institute of Neurological Disorders and Stroke (hereafter in this subpart referred to as the “Institute”) is the conduct and support of research, training, health information dissemination, and other programs with respect to neurological disease and disorder and stroke.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb575f384-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title IV, § 457, as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/158/s2"},"text":"Pub. L. 99–158, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-11-20"},"text":"Nov. 20, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/857"},"text":"99 Stat. 857","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/553/s2/3"},"text":"Pub. L. 100–553, § 2(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-28"},"text":"Oct. 28, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2769"},"text":"102 Stat. 2769","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/607/tI/s101/3"},"text":"Pub. L. 100–607, title I, § 101(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-04"},"text":"Nov. 4, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3049"},"text":"102 Stat. 3049","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tII/s2613/b/2"},"text":"Pub. L. 10