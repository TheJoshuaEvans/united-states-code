{"tag":"section","attrib":{"id":"idbfdfd083-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15203"},"text":null,"children":[{"tag":"num","attrib":{"value":"15203"},"text":"§ 15203.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Board personnel matters","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfdfd084-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15203/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation of members","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfdfd085-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15203/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in paragraph (2), each member of the Board shall be compensated at a rate equal to the daily equivalent of the annual rate of basic pay prescribed for level IV of the Executive Schedule under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5315"},"text":"section 5315 of title 5","children":[],"tail":" for each day (including travel time) during which such member is engaged in the performance of the duties of the Board."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfdfd086-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15203/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" All members of the Board who serve as officers or employees of the United States, a State, or a local government, shall serve without compensation in addition to that received for those services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfdfd087-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15203/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Travel expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The members of the Board shall be allowed travel expenses, including per diem in lieu of subsistence, at rates authorized for employees of agencies under subchapter I of chapter 57 of title 5, while away from their homes or regular places of business in the performance of service for the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfdfd088-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/12/s4"},"text":"Pub. L. 107–12, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-05-30"},"text":"May 30, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/21"},"text":"115 Stat. 21","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
