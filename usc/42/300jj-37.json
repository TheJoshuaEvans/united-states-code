{"tag":"section","attrib":{"id":"idb6dbc471-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–37"},"text":null,"children":[{"tag":"num","attrib":{"value":"300jj–37"},"text":"§ 300jj–37.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General grant and loan provisions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb6dbc472-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–37/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may require that an entity receiving assistance under this part shall submit to the Secretary, not later than the date that is 1 year after the date of receipt of such assistance, a report that includes—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6dbc473-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–37/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an analysis of the effectiveness of the activities for which the entity receives such assistance, as compared to the goals for such activities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6dbc474-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–37/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an analysis of the impact of the project on health care quality and safety.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6dbc475-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–37/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement to improve quality of care and decrease in costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The National Coordinator shall annually evaluate the activities conducted under this part and shall, in awarding grants, implement the lessons learned from such evaluation in a manner so that awards made subsequent to each such evaluation are made in a manner that, in the determination of the National Coordinator, will result in the greatest improvement in the quality and efficiency of health care.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb6dbc476-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XXX, § 3017, as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/5/dA/tXIII/s13301"},"text":"Pub. L. 111–5, div. A, title XIII, § 13301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-02-17"},"text":"Feb. 17, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/257"},"text":"123 Stat. 257","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
