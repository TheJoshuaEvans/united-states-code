{"tag":"section","attrib":{"id":"idb575f3aa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285l–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"285l–1"},"text":"§ 285l–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applied Toxicological Research and Testing Program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb575f3ab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285l–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is established within the Institute a program for conducting applied research and testing regarding toxicology, which program shall be known as the Applied Toxicological Research and Testing Program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb575f3ac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285l–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In carrying out the program established under subsection (a), the Director of the Institute shall, with respect to toxicology, carry out activities—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb575f3ad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285l–1/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to expand knowledge of the health effects of environmental agents;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb575f3ae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285l–1/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to broaden the spectrum of toxicology information that is obtained on selected chemicals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb575f3af-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285l–1/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop and validate assays and protocols, including alternative methods that can reduce or eliminate the use of animals in acute or chronic safety testing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb575f3b0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285l–1/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to establish criteria for the validation and regulatory acceptance of alternative testing and to recommend a process through which scientifically validated alternative methods can be accepted for regulatory use;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb575f3b1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285l–1/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to communicate the results of research to government agencies, to medical, scientific, and regulatory communities, and to the public; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb575f3b2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285l–1/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to integrate related activities of the Department of Health and Human Services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb575f3b3-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title IV, § 463A, as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/43/tXIII/s1301/a"},"text":"Pub. L. 103–43, title XIII, § 1301(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-06-10"},"text":"June 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/169"},"text":"107 Stat. 169","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
