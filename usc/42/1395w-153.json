{"tag":"section","attrib":{"id":"idb961ac19-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–153"},"text":null,"children":[{"tag":"num","attrib":{"value":"1395w–153"},"text":"§ 1395w–153.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Condition for coverage of drugs under this part","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb961ac1a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–153/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In order for coverage to be available under this part for covered part D drugs (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395w–102/e"},"text":"section 1395w–102(e) of this title","children":[],"tail":") of a manufacturer, the manufacturer must—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb961ac1b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–153/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" participate in—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb961ac1c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–153/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for 2011 through 2024, the Medicare coverage gap discount program under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395w–114a"},"text":"section 1395w–114a of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb961ac1d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–153/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for 2025 and each subsequent year, the manufacturer discount program under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395w–114c"},"text":"section 1395w–114c of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb961ac1e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–153/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" have entered into and have in effect—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb961ac1f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–153/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for 2011 through 2024, an agreement described in subsection (b) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395w–114a"},"text":"section 1395w–114a of this title","children":[],"tail":" with the Secretary; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb961ac20-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–153/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for 2025 and each subsequent year, an agreement described in subsection (b) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395w–114c"},"text":"section 1395w–114c of this title","children":[],"tail":" with the Secretary; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb961ac21-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–153/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have entered into and have in effect, under terms and conditions specified by the Secretary, a contract with a third party that the Secretary has entered into a contract with under subsection (d)(3) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395w–114a"},"text":"section 1395w–114a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb961ac22-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–153/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraphs (1)(A), (2)(A), and (3) of subsection (a) shall apply to covered part D drugs dispensed under this part on or after ","children":[{"tag":"date","attrib":{"date":"2011-01-01"},"text":"January 1, 2011","children":[],"tail":", and before "},{"tag":"date","attrib":{"date":"2025-01-01"},"text":"January 1, 2025","children":[],"tail":", and paragraphs (1)(B) and (2)(B) of such subsection shall apply to covered part D drugs dispensed under this part on or after "},{"tag":"date","attrib":{"date":"2025-01-01"},"text":"January 1, 2025","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb961ac23-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–153/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorizing coverage for drugs not covered under agreements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb961ac24-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–153/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to paragraph (2), subsection (a) shall not apply to the dispensing of a covered part D drug if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb961ac25-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–153/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary has made a determination that the availability of the drug is essential to the health of beneficiaries under this part; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb961ac26-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–153/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary determines that in the period beginning on ","children":[{"tag":"date","attrib":{"date":"2011-01-01"},"text":"January 1, 2011","children":[],"tail":", and "},{"tag":"ref","attrib":{"idref":"fn002887"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002887"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be followed by “ending on”."}],"tail":" "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"December 31, 2011","children":[],"tail":", there were extenuating circumstances."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb961ac27-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–153/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraph (1)(A) shall not apply to a covered part D drug of a manufacturer for any period described in section 5000D(c)(1) of the Internal Revenue Code of 1986 wit