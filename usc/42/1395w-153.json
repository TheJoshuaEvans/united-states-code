3","children":[],"tail":", 1892.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb961ac2a-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb961ac2b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb961ac2c-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 5000D(c)(1) of the Internal Revenue Code of 1986, referred to in subsec. (c)(2), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s5000D/c/1"},"text":"section 5000D(c)(1) of Title 26","children":[],"tail":", Internal Revenue Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb961ac2d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/169/s11201/e/7/A/i"},"text":"Pub. L. 117–169, § 11201(e)(7)(A)(i)","children":[],"tail":", added par. (1) and struck out former par. (1) which read as follows: “participate in the Medicare coverage gap discount program under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395w–114a"},"text":"section 1395w–114a of this title","children":[],"tail":";”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/169/s11201/e/7/A/ii"},"text":"Pub. L. 117–169, § 11201(e)(7)(A)(ii)","children":[],"tail":", added par. (2) and struck out former par. (2) which read as follows: “have entered into and have in effect an agreement described in subsection (b) of such section with the Secretary; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/169/s11201/e/7/A/iii"},"text":"Pub. L. 117–169, § 11201(e)(7)(A)(iii)","children":[],"tail":", substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395w–114a"},"text":"section 1395w–114a of this title","children":[],"tail":"” for “such section”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/169/s11201/e/7/B"},"text":"Pub. L. 117–169, § 11201(e)(7)(B)","children":[],"tail":", added subsec. (b) and struck out former subsec. (b). Prior to amendment, text read as follows: “Subsection (a) shall apply to covered part D drugs dispensed under this part on or after "},{"tag":"date","attrib":{"date":"2011-01-01"},"text":"January 1, 2011","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/169/s11001/b/1/G/i"},"text":"Pub. L. 117–169, § 11001(b)(1)(G)(i)","children":[],"tail":", designated existing provisions as par. (1) and inserted heading, substituted “Subject to paragraph (2), subsection” for “Subsection” in introductory provisions, redesignated former pars. (1) and (2) as subpars. (A) and (B), respectively, of par. (1), and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/152/s1101/b/1/A"},"text":"Pub. L. 111–152, § 1101(b)(1)(A)","children":[],"tail":", substituted “"},{"tag":"date","attrib":{"date":"2011-01-01"},"text":"January 1, 2011","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2010-07-01"},"text":"July 1, 2010","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/152/s1101/b/1/B"},"text":"Pub. L. 111–152, § 1101(b)(1)(B)","children":[],"tail":",