{"tag":"section","attrib":{"id":"idb47b8d3f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s235"},"text":null,"children":[{"tag":"num","attrib":{"value":"235"},"text":"§ 235.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration of grants in multigrant proj­ects; promulgation of regulations","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For the purpose of facilitating the administration of, and expediting the carrying out of the purposes of, the programs established by subchapters V, VI, and VII,","children":[{"tag":"ref","attrib":{"idref":"fn002013"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002013"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" and sections 242b, 246(a), 246(b), 246(c), 246(d),"},{"tag":"ref","attrib":{"idref":"fn002013"},"text":"1","children":[],"tail":" and 246(e) "},{"tag":"ref","attrib":{"idref":"fn002013"},"text":"1","children":[],"tail":" of this title in situations in which grants are sought or made under two or more of such programs with respect to a single project, the Secretary is authorized to promulgate regulations—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb47b8d40-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s235/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under which the administrative functions under such programs with respect to such project will be performed by a single administrative unit which is the administrative unit charged with the administration of any of such programs or is the administrative unit charged with the supervision of two or more of such programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb47b8d41-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s235/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designed to reduce the number of applications, reports, and other materials required under such programs to be submitted with respect to such project, and otherwise to simplify, consolidate, and make uniform (to the extent feasible), the data and information required to be contained in such applications, reports, and other materials; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb47b8d42-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s235/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under which inconsistent or duplicative requirements imposed by such programs will be revised and made uniform with respect to such project;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"except that nothing in this section shall be construed to authorize the Secretary to waive or suspend, with respect to any such project, any requirement with respect to any of such programs if such requirement is imposed by law or by any regulation required by law.","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb47b8d43-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title II, § 226, formerly title III, § 310A, as added "},{"tag":"ref","attrib":{"href":"/us/pl/91/515/tII/s270"},"text":"Pub. L. 91–515, title II, § 270","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-10-30"},"text":"Oct. 30, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1306"},"text":"84 Stat. 1306","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/92/157/tII/s201"},"text":"Pub. L. 92–157, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-11-18"},"text":"Nov. 18, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/461"},"text":"85 Stat. 461","children":[],"tail":"; renumbered § 226, "},{"tag":"ref","attrib":{"href":"/us/pl/93/353/tI/s102/e"},"text":"Pub. L. 93–353, title I, § 102(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-07-23"},"text":"July 23, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/362"},"text":"88 Stat. 362","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb47b8d44-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb47b8d45-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb47b8d46-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Subchapters V and VI, referred to in text, are classified to sections 292 et seq. and 296 et seq., respectively, of this title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subchapter VII, referred to in text, which was classified to section 299 et seq. of this title, was repealed by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/117/s12/d"},"text":"Pub. L. 99–117, § 12(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-10-07"},"text":"Oct. 7, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/495"},"text":"99 Stat. 495","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s246/d"},"text":"Section 246(d) of this title","children":[],"tail":", referred to in text, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tIX/s902/b"},"text":"Pub. L. 97–35, title IX, § 902(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/559"},"text":"95 Stat. 559","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s246/e"},"text":"Section 246(e) of this title","children":[],"tail":", referred to in text, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/94/63/tV/s501/b"},"text":"Pub. L. 94–63, title V, § 501(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-07-29"},"text":"July 29, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/346"},"text":"89 Stat. 346","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb47b8d47-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s242i"},"text":"section 242i of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb47b8d48-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1971—","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/157"},"text":"Pub. L. 92–157","children":[],"tail":" provided for administration of programs established under subchapters V and VI of this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
