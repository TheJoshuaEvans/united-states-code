{"tag":"section","attrib":{"id":"idbb0c9d31-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437aaa"},"text":null,"children":[{"tag":"num","attrib":{"value":"1437aaa"},"text":"§ 1437aaa.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program authority","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbb0c9d32-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437aaa/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary is authorized to make—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb0c9d33-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437aaa/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" planning grants to help applicants to develop homeownership programs in accordance with this subchapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb0c9d34-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437aaa/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" implementation grants to carry out homeownership programs in accordance with this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb0c9d35-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437aaa/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to reserve housing assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In connection with a grant under this subchapter, the Secretary may reserve authority to provide assistance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1437f"},"text":"section 1437f of this title","children":[],"tail":" to the extent necessary to provide replacement housing and rental assistance for a nonpurchasing tenant who resides in the project on the date the Secretary approves the application for an implementation grant, for use by the tenant in another project."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbb0c9d36-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1937-09-01/ch896"},"text":"Sept. 1, 1937, ch. 896","children":[],"tail":", title III, § 301, as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/625/tIV/s411"},"text":"Pub. L. 101–625, title IV, § 411","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4148"},"text":"104 Stat. 4148","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/550/tI/s181/a/2/A"},"text":"Pub. L. 102–550, title I, § 181(a)(2)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3735"},"text":"106 Stat. 3735","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbb0c9d37-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbb0c9d38-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbb0c9d39-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550"},"text":"Pub. L. 102–550","children":[],"tail":" struck out subsec. (c) which read as follows: “There are authorized to be appropriated for grants under this subchapter $68,000,000 for fiscal year 1991 and $380,000,000 for fiscal year 1992. Any amount appropriated pursuant to this subsection shall remain available until expended.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbb0c9d3a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"idbb0c9d3b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/625/tIV/s401"},"text":"Pub. L. 101–625, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4148"},"text":"104 Stat. 4148","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/625/tIV/s401"},"text":"“This title [enacting this subchapter and subchapter IV (§ 12871 et seq.) of chapter 130 of this title, amending sections 1437c, 1437f, 1437","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":", 1437p, 1437r, and 1437s of this title and "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1709"},"text":"section 1709 of Title 12","children":[],"tail":", Banks and Banking, and enacting provisions set out as notes under this section and sections 1437c and 1437aa of this title] may be cited as the ‘Homeownership and Opportunity Through HOPE Act’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbb0c9d3c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Establishment and Implementation of Requirements by Secretary","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/625/tIV/s418"},"text":"Pub. L. 101–625, title IV, § 418","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4161"},"text":"104 Stat. 4161","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/625/tIV/s418"},"text":"“Not later than the expiration of the 180-day period beginning on the date that funds authorized under title III of the United States Housing Act of 1937 [this subchapter] first become available for obligation, the Secretary shall by notice establish such requirements as may be necessary to carry out the provisions of this subtitle [subtitle A (§§ 411–419) of title IV of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/625"},"text":"Pub. L. 101–625","children":[],"tail":", enacting this subchapter, amending sections 1437c, 1437f, 1437"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":", 1437p, 1437r, and 1437s of this title, and enacting provisions set out as notes under sections 1437c and 1437aa of this title]. Such requirements shall be subject to "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s553"},"text":"section 553 of title 5","children":[],"tail":", United States Code. The Secretary shall issue regulations based on the initial notice before the expiration of the 8-month period beginning on the date of the notice.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
