{"tag":"section","attrib":{"id":"idbf4256d4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11343"},"text":null,"children":[{"tag":"num","attrib":{"value":"11343"},"text":"§ 11343.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes of grants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf4256d5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11343/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Grants to the National Board may be used—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf4256d6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11343/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to supplement and expand ongoing efforts to provide shelter, food, and supportive services for homeless individuals with sensitivity to the transition from temporary shelter to permanent homes, and attention to the special needs of homeless individuals with mental and physical disabilities and illnesses, and to facilitate access for homeless individuals to other sources of services and benefits;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf4256d7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11343/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to strengthen efforts to create more effective and innovative local programs by providing funding for them; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf4256d8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11343/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to conduct minimum rehabilitation of existing mass shelter or mass feeding facilities, but only to the extent necessary to make facilities safe, sanitary, and bring them into compliance with local building codes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf4256d9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11343/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on activities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf4256da-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11343/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The National Board may only provide funding provided under this part for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf4256db-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11343/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" programs undertaken by private nonprofit organizations and local governments; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf4256dc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11343/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" programs that are consistent with the purposes of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf4256dd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11343/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The National Board may not carry out programs directly.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf4256de-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/77/tIII/s313"},"text":"Pub. L. 100–77, title III, § 313","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-07-22"},"text":"July 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/492"},"text":"101 Stat. 492","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
