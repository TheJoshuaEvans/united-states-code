{"tag":"section","attrib":{"id":"idbd086d31-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5116e"},"text":null,"children":[{"tag":"num","attrib":{"value":"5116e"},"text":"§ 5116e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Local program requirements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd086d32-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5116e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Grants made under this subchapter shall be used to develop, implement, operate, expand, and enhance community-based, and prevention-focused programs and activities designed to strengthen and support families to prevent child abuse and neglect that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd086d33-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5116e/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assess community assets and needs through a planning process that involves parents, local public agencies, local nonprofit organizations, and private sector representatives in meaningful roles;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd086d34-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5116e/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop a comprehensive strategy to provide a continuum of preventive, family-centered services to children and families, especially to young parents, to parents with young children, and to parents who are adult former victims of domestic violence or child abuse or neglect, through public-private partnerships;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd086d35-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5116e/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd086d36-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5116e/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide for core child abuse and neglect prevention services, which may be provided directly by the local recipient of the grant funds or through grants or agreements with other local agencies, such as—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbd086d37-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5116e/a/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" parent education, mutual support and self help, and parent leadership services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd086d38-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5116e/a/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" respite care services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd086d39-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5116e/a/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" outreach and followup services, which may include voluntary home visiting services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd086d3a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5116e/a/3/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" community and social service referrals; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd086d3b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5116e/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide access to optional services, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbd086d3c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5116e/a/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" referral to and counseling for adoption services for individuals interested in adopting a child or relinquishing their child for adoption;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd086d3d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5116e/a/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" child care, early childhood education and care, and intervention services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd086d3e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5116e/a/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" referral to services and supports to meet the additional needs of families with children with disabilities and parents who are individuals with disabilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd086d3f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5116e/a/3/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" referral to job readiness services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd086d40-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5116e/a/3/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" referral to educational services, such as academic tutoring, literacy training, and General Educational Degree services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd086d41-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5116e/a/3/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" self-sufficiency and life management skills training;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd086d42-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5116e/a/3/B/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" community referral services, including early developmental screening of children;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd086d43-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5116e/a/3/B/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" peer counseling; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd086d44-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5116e/a/3/B/ix"},"text":null,"children":[{"tag":"num","attrib":{"value":"ix"},"text":"(ix)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" domestic violence service programs that provide services and treatment to children and their non-abusing caregivers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd086d45-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5116e/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop leadership roles for the meaningful involvement of parents in the development, operation, evaluation, and oversight of the programs and services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd086d46-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5116e/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide leadership in mobilizing local public and private resources to support the provision of needed child abuse and neglect prevention program services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd086d47-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5116e/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" participate with other community-based and prevention-focused programs and activities designed to strengthen and support families to prevent child abuse and neglect in the development, operation, and expansion of networks where appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd086d48-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5116e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In awarding local grants under this subchapter, a lead entity shall give priority to effective community-based programs serving low-income communities and those serving young parents or parents with young children, including community-based child abuse and neglect prevention programs..","children":[{"tag":"ref","attrib":{"idref":"fn003400"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003400"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd086d49-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/247/tII/s205"},"text":"Pub. L. 93–247, title II, § 205","children":[],"tail":", formerly § 206, as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/235/tI/s121"},"text":"Pub. L. 104–235, title I, § 121","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-03"},"text":"Oct. 3, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3085"},"text":"110 Stat. 3085","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/36/tI/s126"},"text":"Pub. L. 108–36, title I, § 126","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-06-25"},"text":"June 25, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/816"},"text":"117 Stat. 816","children":[],"tail":"; renumbered § 205 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/320/tI"},"text":"Pub. L. 111–320, title I","children":[],"tail":", §§ 136, 141, "},{"tag":"date","attrib":{"date":"2010-12-20"},"text":"Dec. 20, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3480"},"text":"124 Stat. 3480","children":[],"tail":", 3482.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd086d4a-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd086d4b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbd086d4c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 5116e, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/247/tII/s206"},"text":"Pub. L. 93–247, title II, § 206","children":[],"tail":", formerly "},{"tag":"ref","attrib":{"href":"/us/pl/98/473/tIV/s407"},"text":"Pub. L. 98–473, title IV, § 407","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2199"},"text":"98 Stat. 2199","children":[],"tail":"; renumbered "},{"tag":"ref","attrib":{"href":"/us/pl/93/247/s206"},"text":"§ 206 of Pub. L. 93–247","children":[],"tail":", and amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/126"},"text":"Pub. L. 101–126","children":[],"tail":", §§ 2(a), 3(a)(3), (c)(1), 4(f), "},{"tag":"date","attrib":{"date":"1989-10-25"},"text":"Oct. 25, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/764"},"text":"103 Stat. 764","children":[],"tail":", 766, 768, related to withholding of grant payments upon failure to comply with provisions of this subchapter, prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/103/252/s401/a"},"text":"Pub. L. 103–252, § 401(a)","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/247/s205"},"text":"section 205 of Pub. L. 93–247","children":[],"tail":" was renumbered section 204 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5116d"},"text":"section 5116d of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/247/s205"},"text":"section 205 of Pub. L. 93–247","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5116d"},"text":"section 5116d of this title","children":[],"tail":" prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/103/252/s401/a"},"text":"Pub. L. 103–252, § 401(a)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd086d4d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/320/s136/a/1"},"text":"Pub. L. 111–320, § 136(a)(1)","children":[],"tail":", inserted a comma after “expand” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/320/s136/a/2"},"text":"Pub. L. 111–320, § 136(a)(2)","children":[],"tail":", substituted “parents,” for “parents and” and inserted “in meaningful roles” before semicolon at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/320/s136/a/3"},"text":"Pub. L. 111–320, § 136(a)(3)","children":[],"tail":", substituted “a comprehensive strategy to provide” for “a strategy to provide, over time,”, “family-centered” for “family centered”, and “, to parents with young children, and to parents who are adult former victims of domestic violence or child abuse or neglect,” for “and parents with young children,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/320/s136/a/4/A"},"text":"Pub. L. 111–320, § 136(a)(4)(A)","children":[],"tail":", struck out introductory provisions which read as follows: “provide—”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/320/s136/a/4/A"},"text":"Pub. L. 111–320, § 136(a)(4)(A)","children":[],"tail":", added subpar. (A) and struck out former subpar. (A) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) core family resource and support services such as—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(i) parent education, mutual support and self help, and leadership services;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(ii) outreach services;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(iii) community and social service referrals; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(iv) follow-up services;”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/320/s136/a/4/A"},"text":"Pub. L. 111–320, § 136(a)(4)(A)","children":[],"tail":", (B)(i), redesignated subpar. (C) as (B), inserted “provide” before “access”, and struck out former subpar. (B) which read as follows: “other core services, which must be provided or arranged for through contracts or agreements with other local agencies, including voluntary home visiting and all forms of respite care services to the extent practicable; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3)(B)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/320/s136/a/4/B/ii"},"text":"Pub. L. 111–320, § 136(a)(4)(B)(ii)","children":[],"tail":", added cl. (ii) and struck out former cl. (ii) which read as follows: “child care, early childhood development and intervention services;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3)(B)(iii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/320/s136/a/4/B/iii"},"text":"Pub. L. 111–320, § 136(a)(4)(B)(iii)","children":[],"tail":", inserted “and parents who are individuals with disabilities” before semicolon at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3)(B)(v). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/320/s136/a/4/B/iv"},"text":"Pub. L. 111–320, § 136(a)(4)(B)(iv)","children":[],"tail":", (viii), amended cl. (v) identically, substituting “academic tutoring” for “scholastic tutoring”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3)(B)(ix). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/320/s136/a/4/B/v"},"text":"Pub. L. 111–320, § 136(a)(4)(B)(v)","children":[],"tail":"–(vii), added cl. (ix)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/320/s136/a/4/B/i"},"text":"Pub. L. 111–320, § 136(a)(4)(B)(i)","children":[],"tail":", redesignated subpar. (C) as (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/320/s136/a/5"},"text":"Pub. L. 111–320, § 136(a)(5)","children":[],"tail":", substituted “child abuse and neglect prevention program” for “family resource and support program”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/320/s136/a/6"},"text":"Pub. L. 111–320, § 136(a)(6)","children":[],"tail":", inserted a comma after “operation”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/320/s136/b"},"text":"Pub. L. 111–320, § 136(b)","children":[],"tail":", substituted “low-income” for “low income” and “child abuse and neglect prevention programs.” for “family resource and support programs”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/36/s126/1"},"text":"Pub. L. 108–36, § 126(1)","children":[],"tail":", substituted “and prevention-focused programs and activities designed to strengthen and support families to prevent child abuse and neglect” for “prevention-focused, family resource and support programs” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/36/s126/2"},"text":"Pub. L. 108–36, § 126(2)","children":[],"tail":", inserted “voluntary home visiting and” after “including”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/36/s126/3"},"text":"Pub. L. 108–36, § 126(3)","children":[],"tail":", added par. (6) and struck out former par. (6) which read as follows: “participate with other community-based, prevention-focused, family resource and support program grantees in the development, operation and expansion of the Statewide network.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
