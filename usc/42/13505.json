{"tag":"section","attrib":{"id":"idbfc59275-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13505"},"text":null,"children":[{"tag":"num","attrib":{"value":"13505"},"text":"§ 13505.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Integration of research and development","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Within 180 days after ","children":[{"tag":"date","attrib":{"date":"1992-10-24"},"text":"October 24, 1992","children":[],"tail":", the Secretary, in consultation with appropriate representatives of industry, institutions of higher education, Department of Energy national laboratories, and professional and technical societies, shall prepare and submit to Congress a 5-year program plan for improving the integration of basic energy research programs with other energy programs within the Department of Energy. Such program plan shall include—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfc59276-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13505/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an evaluation of current procedures and mechanisms used to achieve such integration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc59277-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13505/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of the role that the Department of Energy national laboratories play in such integration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc59278-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13505/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an identification and evaluation of models that could enhance such integration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc59279-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13505/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an identification and evaluation of new programs, mechanisms, and related policy options that could improve the integrating process, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfc5927a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13505/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" set aside funding for matching or leveraging basic and applied programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfc5927b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13505/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" more formal linkages; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfc5927c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13505/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" program coordination;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc5927d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13505/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommendations for expanded research and development and new technology areas; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc5927e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13505/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" budget estimates for activities under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfc5927f-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/tXXII/s2205"},"text":"Pub. L. 102–486, title XXII, § 2205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3091"},"text":"106 Stat. 3091","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
