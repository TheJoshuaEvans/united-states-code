{"tag":"section","attrib":{"id":"idb685dc03-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–16"},"text":null,"children":[{"tag":"num","attrib":{"value":"300cc–16"},"text":"§ 300cc–16.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research centers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb685dc04-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–16/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb685dc05-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–16/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary, acting through the Director of the National Institute of Allergy and Infectious Diseases, may make grants to, and enter into contracts with, public and nonprofit private entities to assist such entities in planning, establishing, or strengthening, and providing basic operating support for, centers for basic and clinical research into, and training in, advanced diagnostic, prevention, and treatment methods for acquired immune deficiency syndrome.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb685dc06-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–16/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A grant or contract under paragraph (1) shall be provided in accordance with policies established by the Secretary, acting through the Director of the National Institutes of Health, and after consultation with the advisory council for the National Institute of Allergy and Infectious Diseases.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb685dc07-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–16/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall ensure that, as appropriate, clinical research programs carried out under paragraph (1) include as research subjects women, children, hemophiliacs, and minorities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb685dc08-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–16/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of financial assistance","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb685dc09-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–16/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Financial assistance under subsection (a) may be expended for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb685dc0a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–16/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the renovation or leasing of space;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb685dc0b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–16/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" staffing and other basic operating costs, including such patient care costs as are required for clinical research;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb685dc0c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–16/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" clinical training with respect to acquired immune deficiency syndrome (including such training for allied health professionals); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb685dc0d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–16/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstration purposes, including projects in the long-term monitoring and outpatient treatment of individuals infected with the etiologic agent for such syndrome.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb685dc0e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–16/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Financial assistance under subsection (a) may not be expended to provide research training for which Ruth L. Kirschstein National Research Service Awards may be provided under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s288"},"text":"section 288 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb685dc0f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–16/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration of support","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Support of a center under subsection (a) may be for not more than five years. Such period may be extended by the Director for additional periods of not more than five years each if the operations of such center have been reviewed by an appropriate technical and scientific peer review group established by the Director and if such group has recommended to the Director that such period should be extended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb685dc10-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–16/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of carrying out this section, there are authorized to be appropriated such sums as may be necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb685dc11-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XXIII, § 2316, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/607/tII/s201/4"},"text":"Pub. L. 100–607, title II, § 201(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-04"},"text":"Nov. 4, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3071"},"text":"102 Stat. 3071","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/206/tI/s804/c"},"text":"Pub. L. 107–206, title I, § 804(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-02"},"text":"Aug. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/874"},"text":"116 Stat. 874","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb685dc12-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb685dc13-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb685dc14-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/206"},"text":"Pub. L. 107–206","children":[],"tail":" substituted “Ruth L. Kirschstein National Research Service Awards” for “National Research Service Awards”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
