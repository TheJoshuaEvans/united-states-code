{"tag":"section","attrib":{"id":"idbff52d08-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16157"},"text":null,"children":[{"tag":"num","attrib":{"value":"16157"},"text":"§ 16157.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Demonstration","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbff52d09-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16157/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the programs under this section, the Secretary shall fund a limited number of demonstration projects, consistent with this subchapter and a determination of the maturity, cost-effectiveness, and environmental impacts of technologies supporting each project. In selecting projects under this subsection, the Secretary shall, to the extent practicable and in the public interest, select projects that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbff52d0a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16157/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" involve using hydrogen and related products at existing facilities or installations, such as existing office buildings, military bases, vehicle fleet centers, transit bus authorities, or units of the National Park System;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff52d0b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16157/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" depend on reliable power from hydrogen to carry out essential activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff52d0c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16157/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" lead to the replication of hydrogen technologies and draw such technologies into the marketplace;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff52d0d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16157/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include vehicle, portable, and stationary demonstrations of fuel cell and hydrogen-based energy technologies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff52d0e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16157/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" address the interdependency of demand for hydrogen fuel cell applications and hydrogen fuel infrastructure;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff52d0f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16157/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" raise awareness of hydrogen technology among the public;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff52d10-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16157/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitate identification of an optimum technology among competing alternatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff52d11-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16157/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" address distributed generation using renewable sources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff52d12-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16157/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry out demonstrations of evolving hydrogen and fuel cell technologies in national parks, remote island areas, and on Indian tribal land, as selected by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff52d13-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16157/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" carry out a program to demonstrate developmental hydrogen and fuel cell systems for mobile, portable, and stationary uses, using improved versions of the learning demonstrations program concept of the Department including demonstrations involving—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbff52d14-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16157/a/10/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" light-duty vehicles;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff52d15-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16157/a/10/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" heavy-duty vehicles;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff52d16-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16157/a/10/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fleet vehicles;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff52d17-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16157/a/10/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specialty industrial and farm vehicles; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff52d18-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16157/a/10/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" commercial and residential portable, continuous, and backup electric power generation;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff52d19-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16157/a/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in accordance with any code or standards developed in a region, fund prototype, pilot fleet, and infrastructure regional hydrogen supply corridors along the interstate highway system in varied climates across the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff52d1a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16157/a/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fund demonstration programs that explore the use of hydrogen blends, hybrid hydrogen, and hydrogen reformed from renewable agricultural fuels, including the use of hydrogen in hybrid electric, heavier duty, and advanced internal combustion-powered vehicles.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The Secretary shall give preference to projects which address multiple elements contained in paragraphs (1) through (12).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff52d1b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16157/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" System demonstrations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbff52d1c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16157/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"idref":"fn004210"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004210"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. No par. (2) has been enacted."}],"tail":" In general"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"As a component of the demonstration program under this section, the Secretary shall provide grants, on a cost share basis as appropriate, to eligible entities (as determined by the Secretary) for use in—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbff52d1d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16157/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" devising system design concepts that provide for the use of advanced composite vehicles in programs under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16122"},"text":"section 16122 of this title","children":[],"tail":" that—"}],"tail":null},{"tag":"clause","attrib":{"id":"idbff52d1e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16157/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have as a primary goal the reduction of drive energy requirements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbff52d1f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16157/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after 2010, add another research and development phase, as defined in subsection (c), including the vehicle and infrastructure partnerships developed under the learning demonstrations program concept of the Department; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbff52d20-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16157/b/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are managed through an enhanced FreedomCAR program within the Department that encourages involvement in cost-shared projects by manufacturers and governments; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff52d21-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16157/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" designing a local distributed energy system that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbff52d22-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16157/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" incorporates renewable hydrogen production, off-grid electricity production, and fleet applications in industrial or commercial service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbff52d23-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16157/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" integrates energy or applications described in clause (i), such as stationary, portable, micro, and mobile fuel cells, into a high-density commercial or residential building complex or agricultural community; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbff52d24-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16157/b/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is managed in cooperation with industry, State, tribal, and local governments, agricultural organizations, and nonprofit generators and distributors of electricity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff52d25-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16157/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Identification of new program requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the demonstrations under subsection (a), the Secretary, in consultation with the Task Force and the Technical Advisory Committee, shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbff52d26-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16157/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after 2008 for stationary and portable applications, and after 2010 for vehicles, identify new requirements that refine technological concepts, planning, and applications; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff52d27-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16157/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" during the second phase of the learning demonstrations under subsection (b)(1)(A)(ii), redesign subsequent program work to incorporate those requirements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff52d28-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16157/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated to carry out this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbff52d29-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16157/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $185,000,000 for fiscal year 2006;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff52d2a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16157/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $200,000,000 for fiscal year 2007;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff52d2b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16157/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $250,000,000 for fiscal year 2008;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff52d2c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16157/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $300,000,000 for fiscal year 2009;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff52d2d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16157/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $375,000,000 for fiscal year 2010; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff52d2e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16157/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such sums as are necessary for each of fiscal years 2011 through 2020.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbff52d2f-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tVIII/s808"},"text":"Pub. L. 109–58, title VIII, § 808","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/850"},"text":"119 Stat. 850","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
