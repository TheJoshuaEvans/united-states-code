{"tag":"section","attrib":{"id":"idbcb4f67b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4104–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"4104–1"},"text":"§ 4104–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scientific Resolution Panel","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbcb4f67c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4104–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbcb4f67d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4104–1/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Pursuant to the authority provided under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4104/e"},"text":"section 4104(e) of this title","children":[],"tail":", the Administrator shall make available an independent review panel, to be known as the Scientific Resolution Panel, to any community—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbcb4f67e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4104–1/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" that has—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbcb4f67f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4104–1/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" filed a timely map appeal in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4104"},"text":"section 4104 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbcb4f680-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4104–1/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" completed 60 days of consultation with the Federal Emergency Management Agency on the appeal; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbcb4f681-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4104–1/a/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not allowed more than 120 days, or such longer period as may be provided by the Administrator by waiver, to pass since the end of the appeal period; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcb4f682-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4104–1/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that has received an unsatisfactory ruling under the map revision process established pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4101/f"},"text":"section 4101(f) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcb4f683-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4104–1/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appeals by owners and lessees","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a community and an owner or lessee of real property within the community appeal a proposed determination of a flood elevation under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4104/b"},"text":"section 4104(b) of this title","children":[],"tail":", upon the request of the community—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbcb4f684-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4104–1/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the owner or lessee shall submit scientific and technical data relating to the appeals to the Scientific Resolution Panel; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcb4f685-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4104–1/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Scientific Resolution Panel shall make a determination with respect to the appeals in accordance with subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcb4f686-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4104–1/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of paragraph (1)(B), an “unsatisfactory ruling” means that a community—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbcb4f687-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4104–1/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" received a revised Flood Insurance Rate Map from the Federal Emergency Management Agency, via a Letter of Final Determination, after ","children":[{"tag":"date","attrib":{"date":"2008-09-30"},"text":"September 30, 2008","children":[],"tail":", and prior to "},{"tag":"date","attrib":{"date":"2012-07-06"},"text":"July 6, 2012","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcb4f688-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4104–1/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has subsequently applied for a Letter of Map Revision or Physical Map Revision with the Federal Emergency Management Agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcb4f689-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4104–1/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has received an unfavorable ruling on their request for a map revision.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcb4f68a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4104–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Scientific Resolution Panel made available under subsection (a) shall consist of 5 members with expertise that relates to the creation and study of flood hazard maps and flood insurance. The Scientific Resolution Panel may include representatives from Federal agencies not involved in the mapping study in question and from other impartial experts. Employees of the Federal Emergency Management Agency may not serve on the Scientific Resolution Panel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcb4f68b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4104–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbcb4f68c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4104–1/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Following deliberations, and not later than 90 days after its formation, the Scientific Resolution Panel shall issue a determination of resolution of the dispute. Such determination shall set forth recommendations for the base flood elevation determination or the designation of an area having special flood hazards that shall be reflected in the Flood Insurance Rate Maps.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcb7668d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4104–1/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Basis","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The determination of the Scientific Resolution Panel shall be based on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbcb7668e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4104–1/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" data previously provided to the Administrator by the community, and, in the case of a dispute submitted under subsection (a)(2), an owner or lessee of real property in the community; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcb7668f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4104–1/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" data provided by the Administrator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcb76690-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4104–1/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No alternative determinations permissible","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Scientific Resolution Panel—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbcb76691-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4104–1/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall provide a determination of resolution of a dispute that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbcb76692-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4104–1/c/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is either in favor of the Administrator or in favor of the community on each distinct element of the dispute; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbcb76693-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4104–1/c/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a dispute submitted under subsection (a)(2), is in favor of the Administrator, in favor of the community, or in favor of the owner or lessee of real property in the community on each distinct element of the dispute; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcb76694-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4104–1/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not offer as a resolution any other alternative determination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcb76695-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4104–1/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of determination","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbcb76696-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4104–1/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Binding","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The recommendations of the Scientific Resolution Panel shall be binding on all appellants and not subject to further judicial review unless the Administrator determines that implementing the determination of the panel would—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbcb76697-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4104–1/c/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pose a significant threat due to failure to identify a substantial risk of special flood hazards; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbcb76698-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4104–1/c/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" violate applicable law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcb76699-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4104–1/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Written justification not to enforce","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Administrator elects not to implement the determination of the Scientific Resolution Panel pursuant to subparagraph (A), then not later than 60 days after the issuance of the determination, the Administrator shall issue a written justification explaining such election.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcb7669a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4104–1/c/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appeal of determination not to enforce","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Administrator elects not to implement the determination of the Scientific Resolution Panel pursuant to subparagraph (A), the community may appeal the determination of the Administrator as provided for under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4104/g"},"text":"section 4104(g) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcb7669b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4104–1/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maps used for insurance and mandatory purchase requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to any community that has a dispute that is being considered by the Scientific Resolution Panel formed pursuant to this subsection, the Federal Emergency Management Agency shall ensure that for each such community that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbcb7669c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4104–1/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Flood Insurance Rate Map described in the most recently issued Letter of Final Determination shall be in force and effect with respect to such community; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcb7669d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4104–1/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" flood insurance shall continue to be made available to the property owners and residents of the participating community.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbcb7669e-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/448/tXIII/s1363A"},"text":"Pub. L. 90–448, title XIII, § 1363A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/112/141/dF/tII/s100218/a"},"text":"Pub. L. 112–141, div. F, title II, § 100218(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-06"},"text":"July 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/930"},"text":"126 Stat. 930","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
