{"tag":"section","attrib":{"id":"idbda12a02-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6371k"},"text":null,"children":[{"tag":"num","attrib":{"value":"6371k"},"text":"§ 6371k.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination of energy retrofitting assistance for schools","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbda12a03-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6371k/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of school","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “school” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbda12a04-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6371k/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an elementary school or secondary school (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7801"},"text":"section 7801 of title 20","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbda12a05-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6371k/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an institution of higher education (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001/a"},"text":"section 1001(a) of title 20","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbda12a06-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6371k/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a postsecondary vocational institution (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1002/c"},"text":"section 1002(c) of title 20","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbda12a07-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6371k/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a school of the defense dependents’ education system under the Defense Dependents’ Education Act of 1978 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s921"},"text":"20 U.S.C. 921","children":[],"tail":" et seq.) or established under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2164"},"text":"section 2164 of title 10","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbda12a08-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6371k/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a school operated by the Bureau of Indian Education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbda12a09-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6371k/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a tribally controlled school (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s2511"},"text":"section 2511 of title 25","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbda12a0a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6371k/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Tribal College or University (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1059c/b"},"text":"section 1059c(b) of title 20","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbda12a0b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6371k/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation of lead agency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Energy (in this section referred to as the “Secretary”), acting through the Office of Energy Efficiency and Renewable Energy, shall act as the lead Federal agency for coordinating and disseminating information on existing Federal programs and assistance that may be used to help initiate, develop, and finance energy efficiency, renewable energy, and energy retrofitting projects for schools.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbda12a0c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6371k/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out coordination and outreach under subsection (b), the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbda12a0d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6371k/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in consultation and coordination with the appropriate Federal agencies, carry out a review of existing programs and financing mechanisms (including revolving loan funds and loan guarantees) available in or from the Department of Agriculture, the Department of Energy, the Department of Education, the Department of the Treasury, the Internal Revenue Service, the Environmental Protection Agency, and other appropriate Federal agencies with jurisdiction over energy financing and facilitation that are currently used or may be used to help initiate, develop, and finance energy efficiency, renewable energy, and energy retrofitting projects for schools;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbda12a0e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6371k/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" establish a Federal cross-departmental collaborative coordination, education, and outreach effort to streamline communication and promote available Federal opportunities and assistance described in paragraph (1), for energy efficiency, renewable energy, and energy retrofitting projects that enables States, local educational agencies, and schools—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbda12a0f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6371k/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to use existing Federal opportunities more effectively; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbda12a10-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6371k/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to form partnerships with Governors, State energy programs, local educational, financial, and energy officials, State and local government officials, nonprofit organizations, and other appropriate entities, to support the initiation of the projects;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbda12a11-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6371k/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide technical assistance for States, local educational agencies, and schools to help develop and finance energy efficiency, renewable energy, and energy retrofitting projects—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbda12a12-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6371k/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to increase the energy efficiency of buildings or facilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbda12a13-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6371k/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to install systems that individually generate energy from renewable energy resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbda12a14-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6371k/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to establish partnerships to leverage economies of scale and additional financing mechanisms available to larger clean energy initiatives; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbda12a15-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6371k/c/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to promote—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbda12a16-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6371k/c/3/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the maintenance of health, environmental quality, and safety in schools, including the ambient air quality, through energy efficiency, renewable energy, and energy retrofit projects; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbda12a17-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6371k/c/3/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the achievement of expected energy savings and renewable energy production through proper operations and maintenance practices;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbda12a18-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6371k/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop and maintain a single online resource website with contact information for relevant technical assistance and support staff in the Office of Energy Efficiency and Renewable Energy for States, local educational agencies, and schools to effectively access and use Federal opportunities and assistance described in paragraph (1) to develop energy efficiency, renewable energy, and energy retrofitting projects; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbda12a19-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6371k/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" establish a process for recognition of schools that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbda12a1a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6371k/c/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have successfully implemented energy efficiency, renewable energy, and energy retrofitting projects; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbda12a1b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6371k/c/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are willing to serve as resources for other local educational agencies and schools to assist initiation of similar efforts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbda12a1c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6371k/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2020-12-27"},"text":"December 27, 2020","children":[],"tail":", the Secretary shall submit to Congress a report describing the implementation of this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbda12a1d-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dZ/tI/s1001"},"text":"Pub. L. 116–260, div. Z, title I, § 1001","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2420"},"text":"134 Stat. 2420","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbda12a1e-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbda12a1f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbda12a20-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Defense Dependents’ Education Act of 1978, referred to in subsec. (a)(4), is title XIV of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/561"},"text":"Pub. L. 95–561","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-01"},"text":"Nov. 1, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2365"},"text":"92 Stat. 2365","children":[],"tail":", which is classified principally to chapter 25A (§ 921 et seq.) of Title 20, Education. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s921"},"text":"section 921 of Title 20","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbda12a21-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Energy Act of 2020, and not as part of the Energy Policy and Conservation Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
