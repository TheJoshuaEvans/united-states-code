{"tag":"section","attrib":{"id":"idbcd1a5d2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4371"},"text":null,"children":[{"tag":"num","attrib":{"value":"4371"},"text":"§ 4371.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional findings, declarations, and purposes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbcd1a5d3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4371/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Congress finds—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbcd1a5d4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4371/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that man has caused changes in the environment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcd1a5d5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4371/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that many of these changes may affect the relationship between man and his environment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcd1a5d6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4371/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that population increases and urban concentration contribute directly to pollution and the degradation of our environment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcd1a5d7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4371/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbcd1a5d8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4371/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Congress declares that there is a national policy for the environment which provides for the enhancement of environmental quality. This policy is evidenced by statutes heretofore enacted relating to the prevention, abatement, and control of environmental pollution, water and land resources, transportation, and economic and regional development.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcd1a5d9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4371/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The primary responsibility for implementing this policy rests with State and local government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcd1a5da-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4371/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Federal Government encourages and supports implementation of this policy through appropriate regional organizations established under existing law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcd1a5db-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4371/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The purposes of this chapter are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbcd1a5dc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4371/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assure that each Federal department and agency conducting or supporting public works activities which affect the environment shall implement the policies established under existing law; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcd1a5dd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4371/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to authorize an Office of Environmental Quality, which, notwithstanding any other provision of law, shall provide the professional and administrative staff for the Council on Environmental Quality established by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/190"},"text":"Public Law 91–190","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbcd1a5de-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/224/tII/s202"},"text":"Pub. L. 91–224, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-04-03"},"text":"Apr. 3, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/114"},"text":"84 Stat. 114","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbcd1a5df-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbcd1a5e0-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbcd1a5e1-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/91/190"},"text":"Public Law 91–190","children":[],"tail":", referred to in subsec. (c)(2), is "},{"tag":"ref","attrib":{"href":"/us/pl/91/190"},"text":"Pub. L. 91–190","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-01-01"},"text":"Jan. 1, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/852"},"text":"83 Stat. 852","children":[],"tail":", known as the National Environmental Policy Act of 1969, which is classified generally to chapter 55 (§ 4321 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"section 4321 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbcd1a5e2-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"idbcd1a5e3-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/91/224/tII/s201"},"text":"Pub. L. 91–224, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-04-03"},"text":"Apr. 3, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/114"},"text":"84 Stat. 114","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/91/224/tII/s201"},"text":"“This title [enacting this chapter] may be cited as the ‘Environmental Quality Improvement Act of 1970’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
