{"tag":"section","attrib":{"id":"idb86041cb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–5"},"text":null,"children":[{"tag":"num","attrib":{"value":"1320d–5"},"text":"§ 1320d–5.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General penalty for failure to comply with requirements and standards","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb86041cc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–5/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General penalty","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb86041cd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–5/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subsection (b), the Secretary shall impose on any person who violates a provision of this part—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb86041ce-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–5/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a violation of such provision in which it is established that the person did not know (and by exercising reasonable diligence would not have known) that such person violated such provision, a penalty for each such violation of an amount that is at least the amount described in paragraph (3)(A) but not to exceed the amount described in paragraph (3)(D);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb86041cf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–5/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a violation of such provision in which it is established that the violation was due to reasonable cause and not to willful neglect, a penalty for each such violation of an amount that is at least the amount described in paragraph (3)(B) but not to exceed the amount described in paragraph (3)(D); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb86041d0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–5/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of a violation of such provision in which it is established that the violation was due to willful neglect—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb86041d1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–5/a/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the violation is corrected as described in subsection (b)(3)(A),","children":[{"tag":"ref","attrib":{"idref":"fn002727"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002727"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “(b)(2)(A),”."}],"tail":" a penalty in an amount that is at least the amount described in paragraph (3)(C) but not to exceed the amount described in paragraph (3)(D); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb86041d2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–5/a/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the violation is not corrected as described in such subsection, a penalty in an amount that is at least the amount described in paragraph (3)(D).","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"In determining the amount of a penalty under this section for a violation, the Secretary shall base such determination on the nature and extent of the violation and the nature and extent of the harm resulting from such violation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb86041d3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–5/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320a–7a"},"text":"section 1320a–7a of this title","children":[],"tail":" (other than subsections (a) and (b) and the second sentence of subsection (f)) shall apply to the imposition of a civil money penalty under this subsection in the same manner as such provisions apply to the imposition of a penalty under such "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320a–7a"},"text":"section 1320a–7a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb86041d4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–5/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tiers of penalties described","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of paragraph (1), with respect to a violation by a person of a provision of this part—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb86041d5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–5/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount described in this subparagraph is $100 for each such violation, except that the total amount imposed on the person for all such violations of an identical requirement or prohibition during a calendar year may not exceed $25,000;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb86041d6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–5/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount described in this subparagraph is $1,000 for each such violation, except that the total amount imposed on the person for all such violations of an identical requirement or prohibition during a calendar year may not exceed $100,000;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb86041d7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–5/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount described in this subparagraph is $10,000 for each such violation, except that the total amount imposed on the person for all such violations of an identical requirement or prohibition during a calendar year may not exceed $250,000; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb86041d8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–5/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount described in this subparagraph is $50,000 for each such violation, except that the total amount imposed on the person for all such violations of an identical requirement or prohibition during a calendar year may not exceed $1,500,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb86041d9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–5/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb86041da-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–5/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Offenses otherwise punishable","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No penalty may be imposed under subsection (a) and no damages obtained under subsection (d) with respect to an act if a penalty has been imposed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320d–6"},"text":"section 1320d–6 of this title","children":[],"tail":" with respect to such act."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb86041db-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–5/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failures due to reasonable cause","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb86041dc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–5/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subparagraph (B) or subsection (a)(1)(C), no penalty may be imposed under subsection (a) and no damages obtained under subsection (d) if the failure to comply is corrected during the 30-day period beginning on the first date the person liable for the penalty or damages knew, or by exercising reasonable diligence would have known, that the failure to comply occurred.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb86041dd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–5/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extension of period","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb86041de-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–5/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No penalty","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to the imposition of a penalty by the Secretary under subsection (a), the period referred to in subparagraph (A) may be extended as determined appropriate by the Secretary based on the nature and extent of the failure to comply.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb86041df-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–5/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary determines that a person failed to comply because the person was unable to comply, the Secretary may provide technical assistance to the person during the period described in subparagraph (A). Such assistance shall be provided in any manner determined appropriate by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb86041e0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–5/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reduction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a failure to comply which is due to reasonable cause and not to willful neglect, any penalty under subsection (a) and any damages under subsection (d) that is ","children":[{"tag":"ref","attrib":{"idref":"fn002728"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002728"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be “are”."}],"tail":" not entirely waived under paragraph (3) "},{"tag":"ref","attrib":{"idref":"fn002729"},"text":"3","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002729"},"text":null,"children":[{"tag":"num","attrib":{},"text":"3","children":[],"tail":" So in original. Probably should be “(2)”."}],"tail":" may be waived to the extent that the payment of such penalty "},{"tag":"ref","attrib":{"idref":"fn002730"},"text":"4","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002730"},"text":null,"children":[{"tag":"num","attrib":{},"text":"4","children":[],"tail":" So in original. The words “or damages” probably should appear after “penalty”."}],"tail":" would be excessive relative to the compliance failure involved."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb86041e1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–5/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Noncompliance due to willful neglect","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb86041e2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–5/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A violation of a provision of this part due to willful neglect is a violation for which the Secretary is required to impose a penalty under subsection (a)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb86041e3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–5/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required investigation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of paragraph (1), the Secretary shall formally investigate any complaint of a violation of a provision of this part if a preliminary investigation of the facts of the complaint indicate such a possible violation due to willful neglect.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb86041e4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–5/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement by State attorneys general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb86041e5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–5/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil action","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subsection (b), in any case in which the attorney general of a State has reason to believe that an interest of one or more of the residents of that State has been or is threatened or adversely affected by any person who violates a provision of this part, the attorney general of the State, as parens patriae, may bring a civil action on behalf of such residents of the State in a district court of the United States of appropriate jurisdiction—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb86041e6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–5/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to enjoin further such violation by the defendant; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb86041e7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–5/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to obtain damages on behalf of such residents of the State, in an amount equal to the amount determined under paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb86041e8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–5/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statutory damages","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb86041e9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–5/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of paragraph (1)(B), the amount determined under this paragraph is the amount calculated by multiplying the number of violations by up to $100. For purposes of the preceding sentence, in the case of a continuing violation, the number of violations shall be determined consistent with the HIPAA privacy regulations (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320d–9/b/3"},"text":"section 1320d–9(b)(3) of this title","children":[],"tail":") for violations of subsection (a)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb86041ea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–5/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The total amount of damages imposed on the person for all violations of an identical requirement or prohibition during a calendar year may not exceed $25,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb86041eb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–5/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reduction of damages","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In assessing damages under subparagraph (A), the court may consider the factors the Secretary may consider in determining the amount of a civil money penalty under subsection (a) under the HIPAA privacy regulations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb86041ec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–5/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Attorney fees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of any successful action under paragraph (1), the court, in its discretion, may award the costs of the action and reasonable attorney fees to the State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb86041ed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–5/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice to Secretary","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The State shall serve prior written notice of any action under paragraph (1) upon the Secretary and provide the Secretary with a copy of its complaint, except in any case in which such prior notice is not feasible, in which case the State shall serve such notice immediately upon instituting such action. The Secretary shall have the right—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb86041ee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–5/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to intervene in the action;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb86041ef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–5/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" upon so intervening, to be heard on all matters arising therein; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb86041f0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–5/d/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to file petitions for appeal.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb86041f1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–5/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of bringing any civil action under paragraph (1), nothing in this section shall be construed to prevent an attorney general of a State from exercising the powers conferred on the attorney general by the laws of that State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb86041f2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–5/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Venue; service of process","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb86041f3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–5/d/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Venue","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any action brought under paragraph (1) may be brought in the district court of the United States that meets applicable requirements relating to venue under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s1391"},"text":"section 1391 of title 28","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb86041f4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–5/d/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Service of process","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In an action brought under paragraph (1), process may be served in any district in which the defendant—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb86041f5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–5/d/6/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is an inhabitant; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb86041f6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–5/d/6/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintains a physical place of business.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb86041f7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–5/d/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on State action while Federal action is pending","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary has instituted an action against a person under subsection (a) with respect to a specific violation of this part, no State attorney general may bring an action under this subsection against the person with respect to such violation during the pendency of that action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb86041f8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–5/d/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of CMP statute of limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A civil action may not be instituted with respect to a violation of this part unless an action to impose a civil money penalty may be instituted under subsection (a) with respect to such violation consistent with the second sentence of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320a–7a/c/1"},"text":"section 1320a–7a(c)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb86041f9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–5/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allowing continued use of corrective action","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed as preventing the Office for Civil Rights of the Department of Health and Human Services from continuing, in its discretion, to use corrective action without a penalty in cases where the person did not know (and by exercising reasonable diligence would not have known) of the violation involved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb86041fa-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title XI, § 1176, as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/191/tII/s262/a"},"text":"Pub. L. 104–191, title II, § 262(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-21"},"text":"Aug. 21, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2028"},"text":"110 Stat. 2028","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/5/dA/tXIII/s13410/a/1"},"text":"Pub. L. 111–5, div. A, title XIII, § 13410(a)(1)","children":[],"tail":", (d)(1)–(3), (e)(1), (2), (f), "},{"tag":"date","attrib":{"date":"2009-02-17"},"text":"Feb. 17, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/271-276"},"text":"123 Stat. 271–276","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb86041fb-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb86041fc-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb86041fd-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2009—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/5/s13410/d/1"},"text":"Pub. L. 111–5, § 13410(d)(1)","children":[],"tail":", substituted “who violates a provision of this part—” for “who violates a provision of this part a penalty of not more than $100 for each such violation, except that the total amount imposed on the person for all violations of an identical requirement or prohibition during a calendar year may not exceed $25,000.”, added subpars. (A) to (C), and inserted concluding provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/5/s13410/d/2"},"text":"Pub. L. 111–5, § 13410(d)(2)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/5/s13410/e/2/A"},"text":"Pub. L. 111–5, § 13410(e)(2)(A)","children":[],"tail":", substituted “No penalty may be imposed under subsection (a) and no damages obtained under subsection (d)” for “A penalty may not be imposed under subsection (a)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/5/s13410/a/1/A"},"text":"Pub. L. 111–5, § 13410(a)(1)(A)","children":[],"tail":", substituted “a penalty has been imposed under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320d–6"},"text":"section 1320d–6 of this title","children":[],"tail":" with respect to such act” for “the act constitutes an offense punishable under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320d–6"},"text":"section 1320d–6 of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/5/s13410/d/3/A"},"text":"Pub. L. 111–5, § 13410(d)(3)(A)","children":[],"tail":", redesignated par. (3) as (2) and struck out former par. (2). Prior to amendment, text of par. (2) read as follows: “A penalty may not be imposed under subsection (a) of this section with respect to a provision of this part if it is established to the satisfaction of the Secretary that the person liable for the penalty did not know, and by exercising reasonable diligence would not have known, that such person violated the provision.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/5/s13410/e/2/B/ii"},"text":"Pub. L. 111–5, § 13410(e)(2)(B)(ii)","children":[],"tail":", which directed amendment of cl. (ii) of subpar. (A) by inserting “or damages” after “the penalty”, was executed by making the insertion in subpar. (A) to reflect the probable intent of Congress and the intervening amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/111/5/s13410/d/3/B/i"},"text":"Pub. L. 111–5, § 13410(d)(3)(B)(i)","children":[],"tail":", which struck out the cl. (ii) designation. See below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/5/s13410/e/2/B/i"},"text":"Pub. L. 111–5, § 13410(e)(2)(B)(i)","children":[],"tail":", substituted “no penalty may be imposed under subsection (a) and no damages obtained under subsection (d)” for “a penalty may not be imposed under subsection (a)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/5/s13410/d/3/B/i"},"text":"Pub. L. 111–5, § 13410(d)(3)(B)(i)","children":[],"tail":", substituted “in subparagraph (B) or subsection (a)(1)(C), a penalty may not be imposed under subsection (a) if the failure to comply is corrected” for “in subparagraph (B), a penalty may not be imposed under subsection (a) of this section if—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(i) the failure to comply was due to reasonable cause and not to willful neglect; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(ii) the failure to comply is corrected”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/5/s13410/d/3/B/ii"},"text":"Pub. L. 111–5, § 13410(d)(3)(B)(ii)","children":[],"tail":", substituted “(A)” for “(A)(ii)” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(B)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/5/s13410/e/2/C"},"text":"Pub. L. 111–5, § 13410(e)(2)(C)","children":[],"tail":", substituted “With respect to the imposition of a penalty by the Secretary under subsection (a), the period” for “The period”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/5/s13410/e/2/D"},"text":"Pub. L. 111–5, § 13410(e)(2)(D)","children":[],"tail":", inserted “and any damages under subsection (d)” after “any penalty under subsection (a)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/5/s13410/d/3/A"},"text":"Pub. L. 111–5, § 13410(d)(3)(A)","children":[],"tail":", redesignated par. (4) as (3). Former par. (3) redesignated (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/5/s13410/d/3/A"},"text":"Pub. L. 111–5, § 13410(d)(3)(A)","children":[],"tail":", redesignated par. (4) as (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/5/s13410/a/1/B"},"text":"Pub. L. 111–5, § 13410(a)(1)(B)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/5/s13410/e/1"},"text":"Pub. L. 111–5, § 13410(e)(1)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/5/s13410/f"},"text":"Pub. L. 111–5, § 13410(f)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb86041fe-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb86041ff-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2009 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/5"},"text":"Pub. L. 111–5","children":[],"tail":" effective 12 months after "},{"tag":"date","attrib":{"date":"2009-02-17"},"text":"Feb. 17, 2009","children":[],"tail":", except as otherwise specifically provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/5/s13423"},"text":"section 13423 of Pub. L. 111–5","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s17931"},"text":"section 17931 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/5/s13410/a/1"},"text":"section 13410(a)(1) of Pub. L. 111–5","children":[],"tail":" applicable to penalties imposed on or after the date that is 24 months after "},{"tag":"date","attrib":{"date":"2009-02-17"},"text":"Feb. 17, 2009","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s17939/b/1"},"text":"section 17939(b)(1) of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by section 13410(d)(1)–(3) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/5"},"text":"Pub. L. 111–5","children":[],"tail":" applicable to violations occurring after "},{"tag":"date","attrib":{"date":"2009-02-17"},"text":"Feb. 17, 2009","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s17939/d/4"},"text":"section 17939(d)(4) of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by section 13410(e)(1), (2) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/5"},"text":"Pub. L. 111–5","children":[],"tail":" applicable to violations occurring after "},{"tag":"date","attrib":{"date":"2009-02-17"},"text":"Feb. 17, 2009","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s17939/e/3"},"text":"section 17939(e)(3) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
