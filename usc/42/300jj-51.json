{"tag":"section","attrib":{"id":"idb6dbc47a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–51"},"text":null,"children":[{"tag":"num","attrib":{"value":"300jj–51"},"text":"§ 300jj–51.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Health information technology enrollment standards and protocols","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb6dbc47b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–51/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6dbc47c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–51/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standards and protocols","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2010-03-23"},"text":"March 23, 2010","children":[],"tail":","},{"tag":"ref","attrib":{"idref":"fn002533"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002533"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" the Secretary, in consultation with the HIT Advisory Committee, shall develop interoperable and secure standards and protocols that facilitate enrollment of individuals in Federal and State health and human services programs, as determined by the Secretary."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6dbc47d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–51/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Methods","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall facilitate enrollment in such programs through methods determined appropriate by the Secretary, which shall include providing individuals and third parties authorized by such individuals and their designees notification of eligibility and verification of eligibility required under such programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6dbc47e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–51/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Content","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The standards and protocols for electronic enrollment in the Federal and State programs described in subsection (a) shall allow for the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6dbc47f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–51/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Electronic matching against existing Federal and State data, including vital records, employment history, enrollment systems, tax records, and other data determined appropriate by the Secretary to serve as evidence of eligibility and in lieu of paper-based documentation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6dbc480-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–51/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Simplification and submission of electronic documentation, digitization of documents, and systems verification of eligibility.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6dbc481-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–51/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Reuse of stored eligibility information (including documentation) to assist with retention of eligible individuals.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6dbc482-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–51/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Capability for individuals to apply, recertify and manage their eligibility information online, including at home, at points of service, and other community-based locations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6dbc483-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–51/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Ability to expand the enrollment system to integrate new programs, rules, and functionalities, to operate at increased volume, and to apply streamlined verification and eligibility processes to other Federal and State programs, as appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6dbc484-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–51/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notification of eligibility, recertification, and other needed communication regarding eligibility, which may include communication via email and cellular phones.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6dbc485-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–51/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Other functionalities necessary to provide eligibles with streamlined enrollment process.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6dbc486-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–51/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval and notification","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to any standard or protocol developed under subsection (a) that has been approved by the HIT Advisory Committee, the Secretary—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6dbc487-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–51/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall notify States of such standards or protocols; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6dbc488-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–51/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may require, as a condition of receiving Federal funds for the health information technology investments, that States or other entities incorporate such standards and protocols into such investments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6dbc489-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–51/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants for implementation of appropriate enrollment HIT","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6dbc48a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–51/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall award grant ","children":[{"tag":"ref","attrib":{"idref":"fn002534"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002534"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be “grants”."}],"tail":" to eligible entities to develop new, and adapt existing, technology systems to implement the HIT enrollment standards and protocols developed under subsection (a) (referred to in this subsection as “appropriate HIT technology”)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6dbc48b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–51/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible for a grant under this subsection, an entity shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6dbc48c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–51/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be a State, political subdivision of a State, or a local governmental entity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6dbc48d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–51/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" submit to the Secretary an application at such time, in such manner, and containing—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb6dbc48e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–51/d/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a plan to adopt and implement appropriate enrollment technology that includes—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb6dbc48f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–51/d/2/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" proposed reduction in maintenance costs of technology systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb6dbc490-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–51/d/2/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" elimination or updating of legacy systems; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb6dbc491-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–51/d/2/B/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrated collaboration with other entities that may receive a grant under this section that are located in the same State, political subdivision, or locality;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6dbc492-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–51/d/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assurance that the entity will share such appropriate enrollment technology in accordance with paragraph (4); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6dbc493-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–51/d/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other information as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6dbc494-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–51/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sharing","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6dbc495-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–51/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall ensure that appropriate enrollment HIT adopted under grants under this subsection is made available to other qualified State, qualified political subdivisions of a State, or other appropriate qualified entities (as described in subparagraph (B)) at no cost.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6dbc496-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–51/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified entities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall determine what entities are qualified to receive enrollment HIT under subparagraph (A), taking into consideration the recommendations of the HIT Advisory Committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb6dbc497-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XXX, § 3021, as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tI/s1561"},"text":"Pub. L. 111–148, title I, § 1561","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/262"},"text":"124 Stat. 262","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/255/dA/tIV/s4003/e/2/A/ii"},"text":"Pub. L. 114–255, div. A, title IV, § 4003(e)(2)(A)(ii)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-13"},"text":"Dec. 13, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1174"},"text":"130 Stat. 1174","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb6dbc498-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb6dbc499-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb6dbc49a-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"date","attrib":{"date":"2010-03-23"},"text":"March 23, 2010","children":[],"tail":", referred to in subsec. (a)(1), was in the original “the date of enactment of this title”, which was translated as meaning the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/111/148"},"text":"Pub. L. 111–148","children":[],"tail":", which enacted this part, to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb6dbc49b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Subsecs. (a)(1), (c), (d)(3)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255"},"text":"Pub. L. 114–255","children":[],"tail":" substituted “HIT Advisory Committee” for “HIT Policy Committee and the HIT Standards Committee”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
