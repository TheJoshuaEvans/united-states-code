{"tag":"section","attrib":{"id":"idbfbbf495-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13339"},"text":null,"children":[{"tag":"num","attrib":{"value":"13339"},"text":"§ 13339.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Underground coal gasification","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfbbf496-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13339/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall conduct a research, development, demonstration, and commercial application program for underground coal gasification technology for in-situ conversion of coal to a cleaner burning, easily transportable gaseous fuel. The goal and objective of this program shall be to accelerate the development and commercialization of underground coal gasification. In carrying out this program, the Secretary shall give equal consideration to all ranks of coal.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfbbf497-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13339/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Demonstration projects","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As part of the program authorized in subsection (a), the Secretary may solicit proposals for underground coal gasification technology projects to fulfill the goal and objective of subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfbbf498-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/tXIII/s1309"},"text":"Pub. L. 102–486, title XIII, § 1309","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2975"},"text":"106 Stat. 2975","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
