{"tag":"section","attrib":{"id":"idbbc69e4b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000g–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"2000g–3"},"text":"§ 2000g–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Subject to the provisions of sections 2000a–4 and 2000g–2(b) of this title, the Director shall, on or before January 31 of each year, submit to the Congress a report of the activities of the Service during the preceding fiscal year.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbbc69e4c-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/352/tX/s1004"},"text":"Pub. L. 88–352, title X, § 1004","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-07-02"},"text":"July 2, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/267"},"text":"78 Stat. 267","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
