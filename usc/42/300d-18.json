{"tag":"section","attrib":{"id":"idb615dc84-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–18"},"text":null,"children":[{"tag":"num","attrib":{"value":"300d–18"},"text":"§ 300d–18.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of amount of allotment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb615dc85-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–18/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum allotment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to the extent of amounts made available in appropriations Acts, the amount of an allotment under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300d–11/a"},"text":"section 300d–11(a) of this title","children":[],"tail":" for a State for a fiscal year shall be the greater of—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb615dc86-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–18/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount determined under subsection (b)(1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb615dc87-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–18/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $250,000 in the case of each of the several States, the District of Columbia, and the Commonwealth of Puerto Rico, and $50,000 in the case of each of the Virgin Islands, Guam, American Samoa, and the Commonwealth of the Northern Mariana Islands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb615dc88-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–18/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination under formula","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb615dc89-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–18/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount referred to in subsection (a)(1) for a State for a fiscal year is the sum of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb615dc8a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–18/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an amount determined under paragraph (2); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb615dc8b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–18/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an amount determined under paragraph (3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb615dc8c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–18/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount relating to population","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount referred to in subparagraph (A) of paragraph (1) for a State for a fiscal year is the product of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb615dc8d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–18/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an amount equal to 80 percent of the amounts appropriated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300d–32/a"},"text":"section 300d–32(a) of this title","children":[],"tail":" for the fiscal year and available for allotment under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300d–11/a"},"text":"section 300d–11(a) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb615dc8e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–18/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a percentage equal to the quotient of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb615dc8f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–18/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an amount equal to the population of the State; divided by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb615dc90-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–18/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an amount equal to the population of all States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb615dc91-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–18/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount relating to square mileage","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount referred to in subparagraph (B) of paragraph (1) for a State for a fiscal year is the product of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb615dc92-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–18/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an amount equal to 20 percent of the amounts appropriated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300d–32/a"},"text":"section 300d–32(a) of this title","children":[],"tail":" for the fiscal year and available for allotment under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300d–11/a"},"text":"section 300d–11(a) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb615dc93-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–18/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a percentage equal to the quotient of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb615dc94-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–18/b/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an amount equal to the lesser of 266,807 and the amount of the square mileage of the State; divided by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb615dc95-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–18/b/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an amount equal to the sum of the respective amounts determined for the States under clause (i).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb615dc96-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–18/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposition of certain funds appropriated for allotments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb615dc97-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–18/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts described in paragraph (2) shall, in accordance with paragraph (3), be allotted by the Secretary to States receiving payments under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300d–11/a"},"text":"section 300d–11(a) of this title","children":[],"tail":" for the fiscal year (other than any State referred to in paragraph (2)(C))."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb615dc98-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–18/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Type of amounts","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amounts referred to in paragraph (1) are any amounts made available pursuant to 300d–32(b)(3) of this title that are not paid under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300d–11/a"},"text":"section 300d–11(a) of this title","children":[],"tail":" to a State as a result of—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb615dc99-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–18/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the failure of the State to submit an application under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300d–17"},"text":"section 300d–17 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb615dc9a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–18/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the failure, in the determination of the Secretary, of the State to prepare within a reasonable period of time such application in compliance with such section; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb615dc9b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–18/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State informing the Secretary that the State does not intend to expend the full amount of the allotment made for the State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb615dc9c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–18/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount of an allotment under paragraph (1) for a State for a fiscal year shall be an amount equal to the product of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb615dc9d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–18/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an amount equal to the amount described in paragraph (2) for the fiscal year involved; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb615dc9e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–18/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the percentage determined under subsection (b)(2) for the State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb615dc9f-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XII, § 1218, as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/590/s3"},"text":"Pub. L. 101–590, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2924"},"text":"104 Stat. 2924","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
