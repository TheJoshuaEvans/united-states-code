{"tag":"section","attrib":{"id":"idbffa0e03-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16195"},"text":null,"children":[{"tag":"num","attrib":{"value":"16195"},"text":"§ 16195.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secondary electric vehicle battery use program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbffa0e04-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16195/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbffa0e05-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16195/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Battery","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “battery” means an energy storage device that previously has been used to provide motive power in a vehicle powered in whole or in part by electricity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbffa0e06-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16195/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Associated equipment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “associated equipment” means equipment located where the batteries will be used that is necessary to enable the use of the energy stored in the batteries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbffa0e07-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16195/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbffa0e08-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16195/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish and conduct a program of research, development, demonstration, and commercial application of energy technology for the secondary use of batteries, if the Secretary finds that there are sufficient numbers of batteries to support the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbffa0e09-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16195/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The program shall be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbffa0e0a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16195/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designed to demonstrate the use of batteries in secondary applications, including utility and commercial power storage and power quality;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbffa0e0b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16195/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" structured to evaluate the performance, including useful service life and costs, of such batteries in field operations, and the necessary supporting infrastructure, including reuse and disposal of batteries; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbffa0e0c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16195/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinated with ongoing secondary battery use programs at the National Laboratories and in industry.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbffa0e0d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16195/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Solicitation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbffa0e0e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16195/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":", the Secretary shall solicit proposals to demonstrate the secondary use of batteries and associated equipment and supporting infrastructure in geographic locations throughout the United States."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbffa0e0f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16195/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional solicitations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may make additional solicitations for proposals if the Secretary determines that the solicitations are necessary to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbffa0e10-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16195/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection of proposals","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbffa0e11-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16195/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 90 days after the closing date established by the Secretary for receipt of proposals under subsection (c), the Secretary shall select up to five proposals that may receive financial assistance under this section once the Department receives appropriated funds to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbffa0e12-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16195/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Factors","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In selecting proposals, the Secretary shall consider—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbffa0e13-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16195/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the diversity of battery type;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbffa0e14-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16195/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" geographic and climatic diversity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbffa0e15-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16195/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" life-cycle environmental effects of the approaches.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbffa0e16-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16195/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No one project selected under this section shall receive more than 25 percent of the funds made available to carry out the program under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbffa0e17-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16195/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-Federal involvement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In selecting proposals, the Secretary shall consider the extent of involvement of State or local government and other persons in each demonstration project to optimize use of Federal resources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbffa0e18-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16195/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other criteria","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In selecting proposals, the Secretary may consider such other criteria as the Secretary considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbffa0e19-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16195/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conditions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out this section, the Secretary shall require that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbffa0e1a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16195/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" relevant information be provided to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbffa0e1b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16195/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbffa0e1c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16195/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the users of the batteries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbffa0e1d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16195/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the proposers of a project under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbffa0e1e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16195/e/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the battery manufacturers; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbffa0e1f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16195/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the costs of carrying out projects and activities under this section are shared in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16352"},"text":"section 16352 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbffa0e20-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tIX/s915"},"text":"Pub. L. 109–58, title IX, § 915","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/861"},"text":"119 Stat. 861","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
