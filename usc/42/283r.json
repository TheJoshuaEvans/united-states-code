{"tag":"section","attrib":{"id":"idb55e2585-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s283r"},"text":null,"children":[{"tag":"num","attrib":{"value":"283r"},"text":"§ 283r.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Science Advisory Board for Biosecurity","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb55e2586-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s283r/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Director of NIH, shall establish an advisory committee, to be known as the “National Science Advisory Board for Biosecurity” (referred to in this section as the “Board”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb55e2587-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s283r/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb55e2588-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s283r/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"idref":"fn002170"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002170"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. No par. (2) has been enacted."}],"tail":" In general"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The National Science Advisory Board for Biosecurity referred to in section 205 of the Pandemic and All-Hazards Preparedness Act (","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/417"},"text":"Public Law 109–417","children":[],"tail":") (referred to in this section as the “Board”) shall provide technical advice, guidance, or recommendations, to relevant Federal departments and agencies related to biosafety and biosecurity oversight of biomedical research, including—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb55e2589-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s283r/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" oversight of federally-conducted or federally-supported dual use biomedical research, such as the review of policies or frameworks used to assess and appropriately manage safety and security risks associated with such research, taking into consideration national security concerns, the potential benefits of such research, considerations related to the research community, transparency, and public availability of information, and international research collaboration; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb55e258a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s283r/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" continuing to carry out the activities required under section 205 of the Pandemic and All-Hazards Preparedness Act (","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/417"},"text":"Public Law 109–417","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb55e258b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s283r/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Considerations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the duties under subsection (b), the Board may consider strategies to improve the safety and security of biomedical research, including through—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb55e258c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s283r/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" leveraging or using new technologies and scientific advancements to reduce safety and security risks associated with such research and improve containment of pathogens; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55e258d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s283r/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" outreach to, and education and training of, researchers, laboratory personnel, and other appropriate individuals with respect to safety and security risks associated with such research and mitigation of such risks.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb55e258e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s283r/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Board shall be composed of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb55e258f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s283r/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Non-voting, ex officio members, including the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb55e2590-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s283r/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" At least one representative of each of the following:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb55e2591-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s283r/d/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of Health and Human Services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb55e2592-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s283r/d/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb55e2593-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s283r/d/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb55e2594-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s283r/d/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of Homeland Security.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb55e2595-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s283r/d/1/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of Energy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb55e2596-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s283r/d/1/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb55e2597-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s283r/d/1/A/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office of Science and Technology Policy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb55e2598-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s283r/d/1/A/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office of the Director of National Intelligence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb55e2599-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s283r/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Representatives of such other Federal departments or agencies as the Secretary determines appropriate to carry out the requirements of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55e259a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s283r/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Individuals, appointed by the Secretary, with expertise in biology, infectious diseases, public health, ethics, national security, and other fields, as the Secretary determines appropriate, who shall serve as voting members.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb55e259b-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title IV, § 404O, as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dFF/tII/s2313/a"},"text":"Pub. L. 117–328, div. FF, title II, § 2313(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5761"},"text":"136 Stat. 5761","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb55e259c-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb55e259d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb55e259e-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 205 of the Pandemic and All-Hazards Preparedness Act, referred to in subsec. (b)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/417/s205"},"text":"section 205 of Pub. L. 109–417","children":[],"tail":", which is set out as a note below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb55e259f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb55e25a0-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Orderly Transition","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/dFF/tII/s2313/b"},"text":"Pub. L. 117–328, div. FF, title II, § 2313(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5762"},"text":"136 Stat. 5762","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/328/dFF/tII/s2313/b"},"text":"“The Secretary of Health and Human Services shall take such steps as are necessary to provide for the orderly transition to the authority of the National Science Advisory Board for Biosecurity established under section 404O of the Public Health Service Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s283r"},"text":"42 U.S.C. 283r","children":[],"tail":"], as added by subsection (a), from any authority of the Board described in section 205 of the Pandemic and All-Hazards Preparedness Act ("},{"tag":"ref","attrib":{"href":"/us/pl/109/417"},"text":"Public Law 109–417","children":[],"tail":") [set out below], as in effect on the day before the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb55e25a1-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Application","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/dFF/tII/s2313/c"},"text":"Pub. L. 117–328, div. FF, title II, § 2313(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5763"},"text":"136 Stat. 5763","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/328/dFF/tII/s2313/c"},"text":"“The requirements under section 404O of the Public Health Service Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s283r"},"text":"42 U.S.C. 283r","children":[],"tail":"], as added by subsection (a), related to the mission, activities, or functions of the National Science Advisory Board for Biosecurity shall not apply until the completion of any work undertaken by such Board before the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb55e25a2-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"National Science Advisory Board for Biosecurity: Provision of Advice, Guidance, or Recommendations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/417/tII/s205"},"text":"Pub. L. 109–417, title II, § 205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-19"},"text":"Dec. 19, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2851"},"text":"120 Stat. 2851","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/417/tII/s205"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The National Science Advisory Board for Biosecurity shall, when requested by the Secretary of Health and Human Services, provide to relevant Federal departments and agencies, advice, guidance, or recommendations concerning—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a core curriculum and training requirements for workers in maximum containment biological laboratories; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" periodic evaluations of maximum containment biological laboratory capacity nationwide and assessments of the future need for increased laboratory capacity.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
