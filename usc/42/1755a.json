{"tag":"section","attrib":{"id":"idbb481f44-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1755a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1755a"},"text":"§ 1755a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Whole grain products","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbb481f45-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1755a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The purpose of this section is to encourage greater awareness and interest in the number and variety of whole grain products available to schoolchildren, as recommended by the 2005 Dietary Guidelines for Americans.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb481f46-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1755a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of eligible whole grains and whole grain products","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the terms “whole grains” and “whole grain products” have the meaning given the terms by the Food and Nutrition Service in the HealthierUS School Challenge.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb481f47-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1755a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purchase of whole grains and whole grain products","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In addition to the commodities delivered under section 6 of the Richard B. Russell National School Lunch Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1755"},"text":"42 U.S.C. 1755","children":[],"tail":"), the Secretary shall purchase whole grains and whole grain products for use in—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb481f48-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1755a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the school lunch program established under the Richard B. Russell National School Lunch Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1751"},"text":"42 U.S.C. 1751","children":[],"tail":" et seq.); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb481f49-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1755a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the school breakfast program established by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1773"},"text":"section 1773 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb481f4a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1755a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2011-09-30"},"text":"September 30, 2011","children":[],"tail":", the Secretary shall conduct an evaluation of the activities conducted under subsection (c) that includes—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb481f4b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1755a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an evaluation of whether children participating in the school lunch and breakfast programs increased their consumption of whole grains;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb481f4c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1755a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an evaluation of which whole grains and whole grain products are most acceptable for use in the school lunch and breakfast programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb481f4d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1755a/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any recommendations of the Secretary regarding the integration of whole grain products in the school lunch and breakfast programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb481f4e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1755a/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an evaluation of any other outcomes determined to be appropriate by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb481f4f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1755a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As soon as practicable after the completion of the evaluation under subsection (d), the Secretary shall submit to the Committee on Agriculture, Nutrition, and Forestry of the Senate and the Committee on Education and Labor of the House of Representative ","children":[{"tag":"ref","attrib":{"idref":"fn003186"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003186"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “Representatives”."}],"tail":" a report describing the results of the evaluation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbb481f50-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234/tIV/s4305"},"text":"Pub. L. 110–234, title IV, § 4305","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1131"},"text":"122 Stat. 1131","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title IV, § 4305, "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 1892.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbb481f51-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbb481f52-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbb481f53-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Richard B. Russell National School Lunch Act, refe