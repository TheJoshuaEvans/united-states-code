{"tag":"section","attrib":{"id":"idc029aab7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17144"},"text":null,"children":[{"tag":"num","attrib":{"value":"17144"},"text":"§ 17144.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" OMB Government efficiency reports and scorecards","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc029aab8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17144/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than April 1 of each year, the Director of the Office of Management and Budget shall submit an annual Government efficiency report to the Committee on Oversight and Government Reform of the House of Representatives and the Committee on Governmental Affairs of the Senate, which shall contain—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc029aab9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17144/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a summary of the information reported by agencies under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s17143"},"text":"section 17143 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc029aaba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17144/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an evaluation of the overall progress of the Federal Government toward achieving the goals of this title ","children":[{"tag":"ref","attrib":{"idref":"fn004260"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004260"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" and the amendments made by this title; "},{"tag":"ref","attrib":{"idref":"fn004260"},"text":"1","children":[],"tail":" and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc029aabb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17144/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommendations for additional actions necessary to meet the goals of this title ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" and the amendments made by this title."},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc029aabc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17144/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scorecards","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the Office of Management and Budget shall include in any annual energy scorecard the Director is otherwise required to submit a description of the compliance of each agency with the requirements of this title ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" and the amendments made by this title."},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc029aabd-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/tV/s528"},"text":"Pub. L. 110–140, title V, § 528","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1664"},"text":"121 Stat. 1664","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc029aabe-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc029aabf-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc029aac0-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This title, referred to in text, is title V of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140"},"text":"Pub. L. 110–140","children":[],"tail":", which enacted this subchapter, part D (§ 8279) of subchapter III of chapter 91 of this title, and sections 1824, 2162a, and 2169 of Title 2, The Congress, amended sections 6325, 6834, 8256, 8258, 8259b, 8287, and 8287c of this title, "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s2162"},"text":"section 2162 of Title 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2913"},"text":"section 2913 of Title 10","children":[],"tail":", Armed Forces, "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s3203"},"text":"section 3203 of Title 15","children":[],"tail":", Commerce and Trade, and "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s2621"},"text":"section 2621 of Title 16","children":[],"tail":", Conservation, and enacted provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s8259b"},"text":"section 8259b of this title","children":[],"tail":". For complete classification of title V to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc029aac1-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idc029aac2-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Oversight and Government Reform of House of Representatives changed to Committee on Oversight and Reform of House of Representatives by House Resolution No. 6, One Hundred Sixteenth Congress, ","children":[{"tag":"date","attrib":{"date":"2019-01-09"},"text":"Jan. 9, 2019","children":[],"tail":". Committee on Oversight and Reform of House of Representatives changed to Committee on Oversight and Accountability of House of Representatives by House Resolution No. 5, One Hundred Eighteenth Congress, "},{"tag":"date","attrib":{"date":"2023-01-09"},"text":"Jan. 9, 2023","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc029aac3-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the date that is 1 day after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/s1601"},"text":"section 1601 of Pub. L. 110–140","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1824"},"text":"section 1824 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
