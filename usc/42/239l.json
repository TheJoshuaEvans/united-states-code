{"tag":"section","attrib":{"id":"idb4879af6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s239l"},"text":null,"children":[{"tag":"num","attrib":{"value":"239l"},"text":"§ 239l.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb4879af7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s239l/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States Public Health Services Track","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4879af8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s239l/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is hereby authorized to be established a United States Public Health Sciences Track (referred to in this part as the “Track”), at sites to be selected by the Secretary, with authority to grant appropriate advanced degrees in a manner that uniquely emphasizes team-based service, public health, epidemiology, and emergency preparedness and response. It shall be so organized as to graduate not less than—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4879af9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s239l/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 150 medical students annually, 10 of whom shall be awarded studentships to the Uniformed Services University of Health Sciences;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4879afa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s239l/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 100 dental students annually;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4879afb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s239l/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 250 nursing students annually;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4879afc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s239l/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 100 public health students annually;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4879afd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s239l/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 100 behavioral and mental health professional students annually;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4879afe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s239l/a/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 100 physician assistant or nurse practitioner students annually; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4879aff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s239l/a/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 50 pharmacy students annually.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4879b00-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s239l/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Locations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Track shall be located at existing and accredited, affiliated health professions education training programs at academic health centers located in regions of the United States determined appropriate by the Surgeon General, in consultation with the National Health Care Workforce Commission established in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s294q"},"text":"section 294q of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4879b01-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s239l/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Number of graduates","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subsection (a), the number of persons to be graduated from the Track shall be prescribed by the Secretary. In so prescribing the number of persons to be graduated from the Track, the Secretary shall institute actions necessary to ensure the maximum number of first-year enrollments in the Track consistent with the academic capacity of the affiliated sites and the needs of the United States for medical, dental, and nursing personnel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4879b02-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s239l/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Development","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The development of the Track may be by such phases as the Secretary may prescribe subject to the requirements of subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4879b03-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s239l/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Integrated longitudinal plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Surgeon General shall develop an integrated longitudinal plan for health professions continuing education throughout the continuum of health-related education, training, and practice. Training under such plan shall emphasize patient-centered, interdisciplinary, and care coordination skills. Experience with deployment of emergency response teams shall be included during the clinical experiences.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4879b04-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s239l/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Faculty development","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Surgeon General shall develop faculty development programs and curricula in decentralized venues of health care, to balance urban, tertiary, and inpatient venues.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb4879b05-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title II, § 271, as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tV/s5315"},"text":"Pub. L. 111–148, title V, § 5315","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/637"},"text":"124 Stat. 637","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
