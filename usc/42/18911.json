{"tag":"section","attrib":{"id":"idc06ec917-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18911"},"text":null,"children":[{"tag":"num","attrib":{"value":"18911"},"text":"§ 18911.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Basic energy sciences program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc06ec918-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18911/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" to (c) Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc06ec919-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18911/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foundational nuclear science","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc06ec91a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18911/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the Office of Science shall support a program of research and development to bridge scientific barriers to, and expand theoretical and fundamental knowledge relevant to, understanding nuclear materials and matter for the benefit of commerce, medicine, and national security.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06ec91b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18911/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As part of the program described in paragraph (1)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc06ec91c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18911/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Director of the Office of Science shall support basic research to pursue distinct lines of scientific inquiry, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc06ec91d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18911/d/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" research in nuclear materials science, including the application of advanced computing practices to foundational and emerging research areas in nuclear materials science and discovery, such as—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idc06ec91e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18911/d/2/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the advanced characterization of materials;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc06ec91f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18911/d/2/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" materials synthesis;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc06ec920-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18911/d/2/A/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" processing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc06ec921-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18911/d/2/A/i/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the innovative use of experimental and theoretical data; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc06ec922-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18911/d/2/A/i/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" mechanical behavior in unique environments, including the effects of radiation;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc06ec923-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18911/d/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" electrochemistry research and associated techniques for processing nuclear materials;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc06ec924-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18911/d/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development of advanced instrumentation and nuclear data collection to inform the activities described in clauses (i) and (ii); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc06ec925-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18911/d/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other area of research, as determined by the Director of the Office of Science; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06ec926-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18911/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Assistant Secretary for Nuclear Energy shall consult with the Director of the Office of Science to support the direction of translational research, development, and validation of physical concepts developed under the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06ec927-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18911/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the funds authorized to be appropriated for basic energy sciences in a fiscal year, there is authorized to be appropriated to the Secretary of Energy to carry out activities under this subsection $50,000,000 for each of fiscal years 2023 through 2027.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc06ec928-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18911/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Carbon Materials Science Initiative","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc06ec929-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18911/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initiative","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc06ec92a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18911/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the Office of Science (referred to in this subsection as the “Director”) shall establish a research initiative, to be known as the “Carbon Materials Science Initiative” (referred to in this subsection as the “Initiative”), to expand the fundamental knowledge of coal, coal-wastes, and carbon ore chemistry useful for understanding the conversion of carbon to material products.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06ec92b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18911/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out programs and activities under the Initiative, the Director shall leverage expertise and resources from the Office of Fossil Energy and Carbon Management and the United States Geological Survey.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06ec92c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18911/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Teams","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc06ec92d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18911/e/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out the Initiative, the Director shall establish and organize activities among multidisciplinary teams to leverage, to the maximum extent practicable, expertise from the National Laboratories, institutions of higher education, and the private sector.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc06ec92e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18911/e/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Goals","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The multidisciplinary teams described in clause (i) shall pursue expedient, milestone-driven research goals established by the Director.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06ec92f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18911/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research program","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc06ec930-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18911/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall carry out under the Initiative a program to support, and discover fundamental knowledge relevant to, carbon materials and carbon ore processing research.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06ec931-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18911/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As part of the program described in subparagraph (A), the Director shall, in coordination with the Assistant Secretary of Energy for Fossil Energy and Carbon Management, as appropriate, support research to pursue distinct lines of scientific inquiry, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc06ec932-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18911/e/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" methods of extraction, processing, recycling, and utilization of the materials and valuable minerals contained in raw coal and coal-waste;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc06ec933-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18911/e/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" methods of improving performance, cost, and availability of materials for use in carbon capture systems; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc06ec934-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18911/e/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" unconventional pathways and materials for conversion of carbon dioxide molecules, minerals, and materials.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06ec935-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18911/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall periodically review activities carried out under the program described in subparagraph (A) to evaluate the achievement of scientific objectives and research milestones.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06ec936-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18911/e/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with existing programs and centers","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the program described in subparagraph (A), the Director shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc06ec937-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18911/e/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" ensure coordination and knowledge sharing with—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idc06ec938-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18911/e/2/D/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States Geological Survey; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc06ec939-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18911/e/2/D/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the programs and the Carbon Utilization Research Center established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16298a"},"text":"section 16298a of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc06ec93a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18911/e/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" avoid duplication of efforts to the maximum extent practicable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06ec93b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18911/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Carbon Materials Research Centers","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc06ec93c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18911/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the activities authorized under paragraph (2), the Director shall establish 1 center in each of the 2 major coal-producing regions of the United States, each of which shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc06ec93d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18911/e/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be known as a “Carbon Materials Research Center” (referred to in this paragraph as a “Center”); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc06ec93e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18911/e/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" focus on early stage research and development activities, including—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idc06ec93f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18911/e/3/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing and advancing methods of extracting, processing, or recycling carbon or other valuable materials or minerals from raw coal, coal-waste, or other solid carbon materials, for the development of new carbon-based materials;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc06ec940-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18911/e/3/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" methods of improving the structural, physical, and chemical properties of carbon-based materials or other valuable materials from raw coal, coal-waste, or other solid carbon materials and their recyclability;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc06ec941-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18911/e/3/A/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" overcoming the challenges and maximizing the benefits of commercially extracting, producing, or improving coal-derived carbon and resulting products; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc06ec942-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18911/e/3/A/ii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying novel pathways and materials for carbon storage and conversion into useful products.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06ec943-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18911/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc06ec944-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18911/e/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" select Centers under subparagraph (A) on a competitive, merit-reviewed basis; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc06ec945-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18911/e/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consider applications from the National Laboratories, institutions of higher education, multi-institutional collaborations, and other appropriate entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06ec946-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18911/e/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A Center shall receive support for a period of not more than 5 years beginning on the date of establishment of that Center, subject to the availability of appropriations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06ec947-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18911/e/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Renewal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On the expiration of any period of support of a Center, the Director may renew support for that Center, on a merit-reviewed basis, for a period of not more than 5 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06ec948-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18911/e/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Existing facilities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc06ec949-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18911/e/3/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that the research activities carried out by the Centers are not duplicative of existing efforts; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc06ec94a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18911/e/3/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if practicable, leverage existing user facilities and other capabilities of the Department of Energy to carry out the research objectives of the Centers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc06ec94b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18911/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Carbon Sequestration Research and Geologic Computational Science Initiative","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc06ec94c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18911/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initiative","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc06ec94d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18911/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Energy (referred to in this subsection as the “Secretary”) shall establish a research initiative, to be known as the “Carbon Sequestration Research and Geologic Computational Science Initiative” (referred to in this subsection as the “Initiative”), to expand the fundamental knowledge, data collection, data analysis, and modeling of subsurface geology for the purpose of advancing carbon sequestration in geologic formations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06ec94e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18911/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Leveraging","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out programs and activities under the Initiative, the Secretary shall leverage expertise and resources from the Office of Fossil Energy and Carbon Management and the United States Geological Survey.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06ec94f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18911/f/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Teams","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc06ec950-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18911/f/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out the Initiative, the Secretary shall establish and organize activities among multidisciplinary teams to leverage, to the maximum extent practicable, expertise from the National Laboratories, institutions of higher education, and the private sector.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc06ec951-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18911/f/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Goals","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The multidisciplinary teams described in clause (i) shall pursue aggressive, milestone-driven research goals established by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06ec952-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18911/f/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may organize additional activities under this subsection through other organizational structures.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06ec953-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18911/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research program","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc06ec954-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18911/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall carry out under the Initiative a program to support research needed for, and discover knowledge relevant to, the sequestration of carbon in geologic formations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06ec955-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18911/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As part of the program described in subparagraph (A), the Director of the Office of Science shall support fundamental research to pursue distinct lines of scientific inquiry, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc06ec956-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18911/f/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" gathering geologic data for pore space characterization, including improvements to geologic seismic imaging;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc06ec957-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18911/f/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluating pore space quality, including evaluation of geologic samples, to determine appropriate sequestration zones for carbon;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc06ec958-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18911/f/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" testing carbon sequestration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc06ec959-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18911/f/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" monitoring carbon migration in geologic formations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc06ec95a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18911/f/2/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advancements in data analytics, including the analysis of seismic data, and computational science to improve the advanced computing, visualization, and imaging of geologic formations for the sequestration of carbon; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc06ec95b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18911/f/2/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" predictive understanding of coupled processes in complex subsurface geologic systems for secure carbon storage.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06ec95c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18911/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall periodically review activities carried out under the program described in subparagraph (A) to evaluate achievement of scientific objectives and research milestones.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06ec95d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18911/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Carbon storage research and geologic computational science centers","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc06ec95e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18911/f/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out the activities authorized under paragraph (2), the Secretary shall select and establish not more than 2 carbon storage research and geologic computational science centers (referred to in this paragraph as a “Center”) to develop and advance improvements to data collection, analysis, and modeling of subsurface geology for the purpose of advancing carbon sequestration in geologic formations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06ec95f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18911/f/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc06ec960-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18911/f/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idc06ec961-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18911/f/3/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" select Centers under subparagraph (A) on a competitive, merit-reviewed basis; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc06ec962-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18911/f/3/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the maximum extent practicable, locate each Center in a geographically diverse region with established and ongoing geologic carbon sequestration research and demonstration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc06ec963-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18911/f/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In selecting Centers under subparagraph (A), the Secretary shall consider applications from institutions of higher education, multi-institutional collaborations, and other appropriate entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06ec964-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18911/f/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc06ec965-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18911/f/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" New Centers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A Center established after ","children":[{"tag":"date","attrib":{"date":"2022-08-09"},"text":"August 9, 2022","children":[],"tail":", shall receive support for a period of not more than 5 years beginning on the date of establishment of that Center, subject to the availability of appropriations."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc06ec966-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18911/f/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Existing Centers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A Center already in existence on ","children":[{"tag":"date","attrib":{"date":"2022-08-09"},"text":"August 9, 2022","children":[],"tail":", may continue to receive support for a period of not more than 5 years beginning on "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"August 9, 2022","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc06ec967-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18911/f/3/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Renewal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On expiration of a period of support described in clause (i) or (ii), the Secretary may renew support for the Center, on a merit-reviewed basis, for a period of not more than 5 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06ec968-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18911/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with existing programs and Centers","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out this subsection, the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc06ec969-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18911/f/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" ensure coordination with—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc06ec96a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18911/f/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States Geological Survey; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc06ec96b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18911/f/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the programs established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16293"},"text":"section 16293 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06ec96c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18911/f/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" avoid duplication of efforts to the maximum extent practicable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc06ec96d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18911/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding for Carbon Initiatives","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the funds authorized to be appropriated for basic energy sciences in a fiscal year, there is authorized to be appropriated to the Secretary to carry out activities under subsections (e) and (f) $50,000,000 for each of fiscal years 2023 through 2027.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc06ec96e-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/tI/s10102"},"text":"Pub. L. 117–167, div. B, title I, § 10102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1409"},"text":"136 Stat. 1409","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc06ec96f-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc06ec970-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idc06ec971-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/s10102"},"text":"section 10102 of div. B of Pub. L. 117–167","children":[],"tail":". Subsecs. (a), (b), and (c) of "},{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/s10102"},"text":"section 10102 of div. B of Pub. L. 117–167","children":[],"tail":" amended sections 18641, 16313, and 16315 of this title, respectively."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
