{"tag":"section","attrib":{"id":"idbd716847-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6217"},"text":null,"children":[{"tag":"num","attrib":{"value":"6217"},"text":"§ 6217.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scientific inventory of oil and gas reserves","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd716848-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6217/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Interior, in consultation with the Secretaries of Agriculture and Energy, shall conduct an inventory of all onshore Federal lands. The inventory shall identify—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd716849-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6217/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States Geological Survey estimates of the oil and gas resources underlying these lands;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd71684a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6217/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the extent and nature of any restrictions or impediments to the development of the resources, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd71684b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6217/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" impediments to the timely granting of leases;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd71684c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6217/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" post-lease restrictions, impediments, or delays on development for conditions of approval, applications for permits to drill, or processing of environmental permits; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd71684d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6217/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" permits or restrictions associated with transporting the resources for entry into commerce; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd71684e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6217/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the quantity of resources not produced or introduced into commerce because of the restrictions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd71684f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6217/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regular update","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Once completed, the USGS resource estimates and the surface availability data as provided in subsection (a)(2) shall be regularly updated and made publicly available.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd716850-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6217/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inventory","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The inventory shall be provided to the Committee on Resources of the House of Representatives and to the Committee on Energy and Natural Resources of the Senate within 2 years after ","children":[{"tag":"date","attrib":{"date":"2000-11-09"},"text":"November 9, 2000","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd716851-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6217/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Using the inventory, the Secretary of Energy shall make periodic assessments of economically recoverable resources accounting for a range of parameters such as current costs, commodity prices, technology, and regulations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd716852-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/469/tVI/s604"},"text":"Pub. L. 106–469, title VI, § 604","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-09"},"text":"Nov. 9, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2041"},"text":"114 Stat. 2041","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/58/tIII/s364/a"},"text":"Pub. L. 109–58, title III, § 364(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/723"},"text":"119 Stat. 723","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd716853-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd716854-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbd716855-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Energy Act of 2000, and not as part of the Energy Policy and Conservation Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd716856-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2005—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/s364/a/1/A"},"text":"Pub. L. 109–58, § 364(a)(1)(A)","children":[],"tail":", struck out “reserve” before “estimates” and “and” after the semicolon."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2), (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/s364/a/1/B"},"text":"Pub. L. 109–58, § 364(a)(1)(B)","children":[],"tail":", added pars. (2) and (3) and struck out former par. (2) which read as follows: “the extent and nature of any restrictions or impediments to the development of such resources.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/s364/a/2"},"text":"Pub. L. 109–58, § 364(a)(2)","children":[],"tail":", substituted “resource” for “reserve” and “publicly” for “publically”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/s364/a/3"},"text":"Pub. L. 109–58, § 364(a)(3)","children":[],"tail":", added subsec. (d) and struck out heading and text of former subsec. (d). Text read as follows: “There are authorized to be appropriated such sums as may be necessary to implement this section.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbd716857-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idbd716858-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Resources of House of Representatives changed to Committee on Natural Resources of House of Representatives by House Resolution No. 6, One Hundred Tenth Congress, ","children":[{"tag":"date","attrib":{"date":"2007-01-05"},"text":"Jan. 5, 2007","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
