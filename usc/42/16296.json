{"tag":"section","attrib":{"id":"idc008404b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16296"},"text":null,"children":[{"tag":"num","attrib":{"value":"16296"},"text":"§ 16296.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Low-volume oil and gas reservoir research program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc008404c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16296/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of GIS","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “GIS” means geographic information systems technology that facilitates the organization and management of data with a geographic component.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc008404d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16296/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a program of research, development, demonstration, and commercial application to maximize the productive capacity of marginal wells and reservoirs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc008404e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16296/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data collection","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Under the program, the Secretary shall collect data on—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc00ab04f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16296/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the status and location of marginal wells and oil and gas reservoirs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00ab050-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16296/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the production capacity of marginal wells and oil and gas reservoirs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00ab051-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16296/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the location of low-pressure gathering facilities and pipelines; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00ab052-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16296/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the quantity of natural gas vented or flared in association with crude oil production.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc00ab053-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16296/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Analysis","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Under the program, the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc00ab054-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16296/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" estimate the remaining producible reserves based on variable pipeline pressures; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00ab055-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16296/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommend measures that will enable the continued production of those resources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc00ab056-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16296/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc00ab057-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16296/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may award a grant to an organization of States that contain significant numbers of marginal oil and natural gas wells to conduct an annual study of low-volume natural gas reservoirs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00ab058-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16296/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Organization with no GIS capabilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If an organization receiving a grant under paragraph (1) does not have GIS capabilities, the organization shall contract with an institution of higher education with GIS capabilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00ab059-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16296/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State geologists","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The organization receiving a grant under paragraph (1) shall collaborate with the State geologist of each State being studied.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc00ab05a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16296/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may use the data collected and analyzed under this section to produce maps and literature to disseminate to States to promote conservation of natural gas reserves.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc00ab05b-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tIX/s966"},"text":"Pub. L. 109–58, title IX, § 966","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/893"},"text":"119 Stat. 893","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
