{"tag":"section","attrib":{"id":"idb67eb034-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300bb–7"},"text":null,"children":[{"tag":"num","attrib":{"value":"300bb–7"},"text":"§ 300bb–7.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any individual who is aggrieved by the failure of a State, political subdivision, or agency or instrumentality thereof, to comply with the requirements of this subchapter may bring an action for appropriate equitable relief.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb67eb035-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XXII, § 2207, as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/272/tX/s10003/a"},"text":"Pub. L. 99–272, title X, § 10003(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-04-07"},"text":"Apr. 7, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/236"},"text":"100 Stat. 236","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb67eb036-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb67eb037-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb67eb038-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Continued Coverage of Costs of Pediatric Vaccine Under Certain Group Health Plans","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/66/tXIII/s13631/d"},"text":"Pub. L. 103–66, title XIII, § 13631(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-10"},"text":"Aug. 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/643"},"text":"107 Stat. 643","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/66/tXIII/s13631/d"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The requirement of this paragraph, with respect to a group health plan for plan years beginning after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1993-08-10"},"text":"Aug. 10, 1993","children":[],"tail":"], is that the group health plan not reduce its coverage of the costs of pediatric vaccines (as defined under section 1928(h)(6) of the Social Security Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1396s/h/6"},"text":"42 U.S.C. 1396s(h)(6)","children":[],"tail":"]) below the coverage it provided as of "},{"tag":"date","attrib":{"date":"1993-05-01"},"text":"May 1, 1993","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Enforcement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of section 2207 of the Public Health Service Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300bb–7"},"text":"42 U.S.C. 300bb–7","children":[],"tail":"], the requirement of paragraph (1) is deemed a requirement of title XXII of such Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300bb–1"},"text":"42 U.S.C. 300bb–1","children":[],"tail":" et seq.].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
