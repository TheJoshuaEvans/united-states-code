{"tag":"section","attrib":{"id":"idbe302452-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7438"},"text":null,"children":[{"tag":"num","attrib":{"value":"7438"},"text":"§ 7438.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Environmental and climate justice block grants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbe302453-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7438/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In addition to amounts otherwise available, there is appropriated to the Administrator for fiscal year 2022, out of any money in the Treasury not otherwise appropriated—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe302454-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7438/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $2,800,000,000 to remain available until ","children":[{"tag":"date","attrib":{"date":"2026-09-30"},"text":"September 30, 2026","children":[],"tail":", to award grants for the activities described in subsection (b); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe302455-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7438/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $200,000,000 to remain available until ","children":[{"tag":"date","attrib":{"date":"2026-09-30"},"text":"September 30, 2026","children":[],"tail":", to provide technical assistance to eligible entities related to grants awarded under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe302456-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7438/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe302457-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7438/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall use amounts made available under subsection (a)(1) to award grants for periods of up to 3 years to eligible entities to carry out activities described in paragraph (2) that benefit disadvantaged communities, as defined by the Administrator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe302458-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7438/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An eligible entity may use a grant awarded under this subsection for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbe302459-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7438/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" community-led air and other pollution monitoring, prevention, and remediation, and investments in low- and zero-emission and resilient technologies and related infrastructure and workforce development that help reduce greenhouse gas emissions and other air pollutants;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe30245a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7438/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" mitigating climate and health risks from urban heat islands, extreme heat, wood heater emissions, and wildfire events;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe30245b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7438/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" climate resiliency and adaptation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe30245c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7438/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reducing indoor toxics and indoor air pollution; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe30245d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7438/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitating engagement of disadvantaged communities in State and Federal advisory groups, workshops, rulemakings, and other public processes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe30245e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7438/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection, the term “eligible entity” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbe30245f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7438/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a partnership between—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbe302460-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7438/b/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an Indian tribe, a local government, or an institution of higher education; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbe302461-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7438/b/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a community-based nonprofit organization;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe302462-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7438/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a community-based nonprofit organization; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe302463-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7438/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a partnership of community-based nonprofit organizations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe302464-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7438/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall reserve 7 percent of the amounts made available under subsection (a) for administrative costs to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe302465-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7438/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of greenhouse gas","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “greenhouse gas” means the air pollutants carbon dioxide, hydrofluorocarbons, methane, nitrous oxide, perfluorocarbons, and sulfur hexafluoride.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbe302466-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1955-07-14/ch360"},"text":"July 14, 1955, ch. 360","children":[],"tail":", title I, § 138, as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/169/tVI/s60201"},"text":"Pub. L. 117–169, title VI, § 60201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-16"},"text":"Aug. 16, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2078"},"text":"136 Stat. 2078","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
