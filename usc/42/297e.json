en":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb5f92d00-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148"},"text":"Pub. L. 111–148","children":[],"tail":" made technical amendment to section and subsec. (a) designations resulting in no change in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/392/s133/e/1/A"},"text":"Pub. L. 105–392, § 133(e)(1)(A)","children":[],"tail":", added introductory provisions and struck out former introductory provisions which read as follows: “After "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"September 30, 1996","children":[],"tail":", and not later than "},{"tag":"date","attrib":{"date":"1999-12-31"},"text":"December 31, 1999","children":[],"tail":", there shall be a capital distribution of the balance of the loan fund established under an agreement pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s297a"},"text":"section 297a of this title","children":[],"tail":" by each school as follows:”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/392/s133/e/1/B"},"text":"Pub. L. 105–392, § 133(e)(1)(B)","children":[],"tail":", substituted “on the date of termination of the fund” for “at the close of "},{"tag":"date","attrib":{"date":"1999-09-30"},"text":"September 30, 1999","children":[],"tail":",”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/392/s133/e/2"},"text":"Pub. L. 105–392, § 133(e)(2)","children":[],"tail":", amended subsec. (b) generally. Prior to amendment, subsec. (b) read as follows: “After "},{"tag":"date","attrib":{"date":"1999-12-31"},"text":"December 31, 1999","children":[],"tail":", each school with which the Secretary has made an agreement under this subpart shall pay to the Secretary, not less often than quarterly, the same proportionate share of amounts received by the school after "},{"tag":"date","attrib":{"date":"1999-09-30"},"text":"September 30, 1999","children":[],"tail":", in payment of principal or interest on loans made from the loan fund established pursuant to such agreement as was determined for the Secretary under subsection (a) of this section.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/408/s208/b/2"},"text":"Pub. L. 102–408, § 208(b)(2)","children":[],"tail":", substituted “1999” for “1994” in introductory provisions and in par. (1)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/408/s208/b/1"},"text":"Pub. L. 102–408, § 208(b)(1)","children":[],"tail":", substituted “1996” for “1991” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/408/s208/b/2"},"text":"Pub. L. 102–408, § 208(b)(2)","children":[],"tail":", substituted “1999” for “1994” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/607/s713/i/1/A"},"text":"Pub. L. 100–607, § 713(i)(1)(A)","children":[],"tail":", which directed substitution of “1994” for “1991” in text preceding par. (1), was executed by making the substitution for “1991” the second time appearing to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/607/s713/i/1/B"},"text":"Pub. L. 100–607, § 713(i)(1)(B)","children":[],"tail":", substituted “1994” for “1991”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/607/s713/i/2"},"text":"Pub. L. 100–607, § 713(i)(2)","children":[],"tail":", substituted “1994” for “1991” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1985—Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/92/s8/f/1"},"text":"Pub. L. 99–92, § 8(f)(1)","children":[],"tail":", substituted “1991” for “1987” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/92/s8/f/2"},"text":"Pub. L. 99–92, § 8(f)(2)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35"},"text":"Pub. L. 97–35","children":[],"tail":" substituted “1987” for “1983” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1979—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/76/s109/c/1"},"text":"Pub. L. 96–76, § 109(c)(1)","children":[],"tail":", substituted “"},{"tag":"date","attrib":{"date":"1983-09-30"},"text":"September 30, 1983","children":[],"tail":", and not later than "},{"tag":"date","attrib":{"date":"1983-12-31"},"text":"December 31, 1983","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"1980-09-30"},"text":"September 30, 1980","children":[],"tail":", and not later than "},{"tag":"date","attrib":{"date":"1981-12-31"},"text":"December 31, 1981","children":[],"tail":"”. Prior to amendment, subsec. (a) referred to “"},{"tag":"date","attrib":{"date":"1980-12-31"},"text":"December 31, 1980","children":[],"tail":"” rather than to “"},{"tag":"date","attrib":{"date":"1981-12-31"},"text":"December 31, 1981","children":[],"tail":"” as cited in directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/96/76"},"text":"Pub. L. 96–76","children":[],"tail":". See below for explanation of amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/96/32"},"text":"Pub. L. 96–32","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":