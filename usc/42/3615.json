{"tag":"section","attrib":{"id":"idbc95fc26-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3615"},"text":null,"children":[{"tag":"num","attrib":{"value":"3615"},"text":"§ 3615.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect on State laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing in this subchapter shall be construed to invalidate or limit any law of a State or political subdivision of a State, or of any other jurisdiction in which this subchapter shall be effective, that grants, guarantees, or protects the same rights as are granted by this subchapter; but any law of a State, a political subdivision, or other such jurisdiction that purports to require or permit any action that would be a discriminatory housing practice under this subchapter shall to that extent be invalid.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbc95fc27-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/284/tVIII/s816"},"text":"Pub. L. 90–284, title VIII, § 816","children":[],"tail":", formerly § 815, "},{"tag":"date","attrib":{"date":"1968-04-11"},"text":"Apr. 11, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/89"},"text":"82 Stat. 89","children":[],"tail":"; renumbered § 816, "},{"tag":"ref","attrib":{"href":"/us/pl/100/430/s8/1"},"text":"Pub. L. 100–430, § 8(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-09-13"},"text":"Sept. 13, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1625"},"text":"102 Stat. 1625","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc95fc28-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc95fc29-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbc95fc2a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/284/s816"},"text":"section 816 of Pub. L. 90–284","children":[],"tail":" was renumbered section 817 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3616"},"text":"section 3616 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
