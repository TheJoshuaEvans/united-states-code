{"tag":"section","attrib":{"id":"idb6cfddb1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–14"},"text":null,"children":[{"tag":"num","attrib":{"value":"300hh–14"},"text":"§ 300hh–14.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protection of health and safety during disasters","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb6cfddb2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–14/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6cfddb3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–14/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certified monitoring program","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “certified monitoring program” means a medical monitoring program—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6cfddb4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–14/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in which a participating responder is a participant as a condition of the employment of such participating responder; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6cfddb5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–14/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that the Secretary of Health and Human Services certifies includes an adequate baseline medical screening.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6cfddb6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–14/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disaster area","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “disaster area” means an area in which the President has declared a major disaster (as that term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5122"},"text":"section 5122 of this title","children":[],"tail":"), during the period of such declaration."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6cfddb7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–14/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" High exposure level","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “high exposure level” means a level of exposure to a substance of concern that is for such a duration, or of such a magnitude, that adverse effects on human health can be reasonably expected to occur, as determined by the President, acting through the Secretary of Health and Human Services, in accordance with human monitoring or environmental or other appropriate indicators.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6cfddb8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–14/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Individual","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “individual” includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6cfddb9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–14/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a worker or volunteer who responds to a disaster, either natural or manmade, involving any mode of transportation in the United States or disrupting the transportation system of the United States, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb6cfddba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–14/a/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a police officer;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6cfddbb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–14/a/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a firefighter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6cfddbc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–14/a/4/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an emergency medical technician;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6cfddbd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–14/a/4/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any participating member of an urban search and rescue team; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6cfddbe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–14/a/4/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other relief or rescue worker or volunteer that the President, acting through the Secretary of Health and Human Services, determines to be appropriate;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6cfddbf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–14/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a worker who responds to a disaster, either natural or manmade, involving any mode of transportation in the United States or disrupting the transportation system of the United States, by assisting in the cleanup or restoration of critical infrastructure in and around a disaster area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6cfddc0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–14/a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a person whose place of residence is in a disaster area, caused by either a natural or manmade disaster involving any mode of transportation in the United States or disrupting the transportation system of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6cfddc1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–14/a/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a person who is employed in or attends school, child care, or adult day care in a building located in a disaster area, caused by either a natural or manmade disaster involving any mode of transportation in the United States or disrupting the transportation system of the United States, of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6cfddc2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–14/a/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other person that the President, acting through the Secretary of Health and Human Services, determines to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6cfddc3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–14/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Participating responder","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “participating responder” means an individual described in paragraph (4)(A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6cfddc4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–14/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “program” means a program described in subsection (b) that is carried out for a disaster area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6cfddc5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–14/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Substance of concern","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “substance of concern” means a chemical or other substance that is associated with potential acute or chronic human health effects, the risk of exposure to which could potentially be increased as the result of a disaster, as determined by the President, acting through the Secretary of Health and Human Services, and in coordination with the Agency for Toxic Substances and Disease Registry, the Environmental Protection Agency, the Centers for Disease Control and Prevention, the National Institutes of Health, the Federal Emergency Management Agency, the Occupational Health and Safety Administration, and other agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6cfddc6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–14/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6cfddc7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–14/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the President, acting through the Secretary of Health and Human Services, determines that 1 or more substances of concern are being, or have been, released in an area declared to be a disaster area and disrupts the transportation system of the United States, the President, acting through the Secretary of Health and Human Services, may carry out a program for the coordination, protection, assessment, monitoring, and study of the health and safety of individuals with high exposure levels to ensure that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6cfddc8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–14/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the individuals are adequately informed about and protected against potential health impacts of any substance of concern in a timely manner;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6cfddc9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–14/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the individuals are monitored and studied over time, including through baseline and followup clinical health examinations, for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb6cfddca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–14/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any short- and long-term health impacts of any substance of concern; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6cfddcb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–14/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any mental health impacts;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6cfddcc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–14/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the individuals receive health care referrals as needed and appropriate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6cfddcd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–14/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information from any such monitoring and studies is used to prevent or protect against similar health impacts from future disasters.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6cfddce-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–14/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A program under paragraph (1) may include such activities as—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6cfddcf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–14/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collecting and analyzing environmental exposure data;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6cfddd0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–14/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing and disseminating information and educational materials;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6cfddd1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–14/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" performing baseline and followup clinical health and mental health examinations and taking biological samples;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6cfddd2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–14/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing and maintaining an exposure registry;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6cfddd3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–14/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" studying the short- and long-term human health impacts of any exposures through epidemiological and other health studies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6cfddd4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–14/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing assistance to individuals in determining eligibility for health coverage and identifying appropriate health services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6cfddd5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–14/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the maximum extent practicable, activities under any program carried out under paragraph (1) (including baseline health examinations) shall be commenced in a timely manner that will ensure the highest level of public health protection and effective monitoring.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6cfddd6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–14/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Participation in registries and studies","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6cfddd7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–14/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Participation in any registry or study that is part of a program carried out under paragraph (1) shall be voluntary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6cfddd8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–14/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protection of privacy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President, acting through the Secretary of Health and Human Services, shall take appropriate measures to protect the privacy of any participant in a registry or study described in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6cfddd9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–14/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb6cfddda-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–14/b/4/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in clause (ii), the President, acting through the Secretary of Health and Human Services, shall give priority in any registry or study described in subparagraph (A) to the protection, monitoring and study of the health and safety of individuals with the highest level of exposure to a substance of concern.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6cfdddb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–14/b/4/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Modifications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding clause (i), the President, acting through the Secretary of Health and Human Services, may modify the priority of a registry or study described in subparagraph (A), if the President, acting through the Secretary of Health and Human Services, determines such modification to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6cfdddc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–14/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperative agreements","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6cfdddd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–14/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President, acting through the Secretary of Health and Human Services, may carry out a program under paragraph (1) through a cooperative agreement with a medical institution, including a local health department, or a consortium of medical institutions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6cfddde-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–14/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To the maximum extent practicable, the President, acting through the Secretary of Health and Human Services, shall select, to carry out a program under paragraph (1), a medical institution or a consortium of medical institutions that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb6cfdddf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–14/b/5/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is located near—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb6cfdde0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–14/b/5/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the disaster area with respect to which the program is carried out; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb6cfdde1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–14/b/5/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other area in which there reside groups of individuals that worked or volunteered in response to the disaster; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6cfdde2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–14/b/5/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" has appropriate experience in the areas of environmental or occupational health, toxicology, and safety, including experience in—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb6cfdde3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–14/b/5/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing clinical protocols and conducting clinical health examinations, including mental health assessments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb6cfdde4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–14/b/5/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conducting long-term health monitoring and epidemiological studies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb6cfdde5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–14/b/5/B/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conducting long-term mental health studies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb6cfdde6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–14/b/5/B/ii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing and maintaining medical surveillance programs and environmental exposure or disease registries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6cfdde7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–14/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Involvement","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6cfdde8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–14/b/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out a program under paragraph (1), the President, acting through the Secretary of Health and Human Services, shall involve interested and affected parties, as appropriate, including representatives of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb6cfdde9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–14/b/6/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal, State, and local government agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6cfddea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–14/b/6/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" groups of individuals that worked or volunteered in response to the disaster in the disaster area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6cfddeb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–14/b/6/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" local residents, businesses, and schools (including parents and teachers);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6cfddec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–14/b/6/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" health care providers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6cfdded-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–14/b/6/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" faith based organizations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6cfddee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–14/b/6/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other organizations and persons.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6cfddef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–14/b/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Committees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Involvement under subparagraph (A) may be provided through the establishment of an advisory or oversight committee or board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6cfddf0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–14/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Privacy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President, acting through the Secretary of Health and Human Services, shall carry out each program under paragraph (1) in accordance with regulations relating to privacy promulgated under section 264(c) of the Health Insurance Portability and Accountability Act of 1996 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320d–2"},"text":"42 U.S.C. 1320d–2","children":[],"tail":" note; "},{"tag":"ref","attrib":{"href":"/us/pl/104/191"},"text":"Public Law 104–191","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6cfddf1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–14/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Existing programs","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out a program under paragraph (1), the President, acting through the Secretary of Health and Human Services, may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6cfddf2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–14/b/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include the baseline clinical health examination of a participating responder under a certified monitoring programs; ","children":[{"tag":"ref","attrib":{"idref":"fn002509"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002509"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “program;”."}],"tail":" and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6cfddf3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–14/b/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" substitute the baseline clinical health examination of a participating responder under a certified monitoring program for a baseline clinical health examination under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6cfddf4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–14/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after the establishment of a program under subsection (b)(1), and every 5 years thereafter, the President, acting through the Secretary of Health and Human Services, or the medical institution or consortium of such institutions having entered into a cooperative agreement under subsection (b)(5), may submit a report to the Secretary of Homeland Security, the Secretary of Labor, the Administrator of the Environmental Protection Agency, and appropriate committees of Congress describing the programs and studies carried out under the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6cfddf5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–14/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Academy of Sciences report on disaster area health and environmental protection and monitoring","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6cfddf6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–14/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Health and Human Services, the Secretary of Homeland Security, and the Administrator of the Environmental Protection Agency shall jointly enter into a contract with the National Academy of Sciences to conduct a study and prepare a report on disaster area health and environmental protection and monitoring.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6cfddf7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–14/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Participation of experts","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The report under paragraph (1) shall be prepared with the participation of individuals who have expertise in—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6cfddf8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–14/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" environmental health, safety, and medicine;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6cfddf9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–14/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" occupational health, safety, and medicine;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6cfddfa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–14/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" clinical medicine, including pediatrics;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6cfddfb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–14/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" environmental toxicology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6cfddfc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–14/d/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" epidemiology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6cfddfd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–14/d/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" mental health;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6cfddfe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–14/d/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" medical monitoring and surveillance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6cfddff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–14/d/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" environmental monitoring and surveillance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6cfde00-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–14/d/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" environmental and industrial hygiene;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6cfde01-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–14/d/2/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" emergency planning and preparedness;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6cfde02-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–14/d/2/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" public outreach and education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6cfde03-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–14/d/2/L"},"text":null,"children":[{"tag":"num","attrib":{"value":"L"},"text":"(L)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State and local health departments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6cfde04-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–14/d/2/M"},"text":null,"children":[{"tag":"num","attrib":{"value":"M"},"text":"(M)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State and local environmental protection departments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6cfde05-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–14/d/2/N"},"text":null,"children":[{"tag":"num","attrib":{"value":"N"},"text":"(N)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" functions of workers that respond to disasters, including first responders;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6cfde06-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–14/d/2/O"},"text":null,"children":[{"tag":"num","attrib":{"value":"O"},"text":"(O)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" public health; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6cfde07-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–14/d/2/P"},"text":null,"children":[{"tag":"num","attrib":{"value":"P"},"text":"(P)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" family services, such as counseling and other disaster-related services provided to families.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6cfde08-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–14/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The report under paragraph (1) shall provide advice and recommendations regarding protecting and monitoring the health and safety of individuals potentially exposed to any chemical or other substance associated with potential acute or chronic human health effects as the result of a disaster, including advice and recommendations regarding—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6cfde09-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–14/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the establishment of protocols for monitoring and responding to chemical or substance releases in a disaster area to protect public health and safety, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb6cfde0a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–14/d/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" chemicals or other substances for which samples should be collected in the event of a disaster, including a terrorist attack;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6cfde0b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–14/d/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" chemical- or substance-specific methods of sample collection, including sampling methodologies and locations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6cfde0c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–14/d/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" chemical- or substance-specific methods of sample analysis;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6cfde0d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–14/d/3/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" health-based threshold levels to be used and response actions to be taken in the event that thresholds are exceeded for individual chemicals or other substances;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6cfde0e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–14/d/3/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" procedures for providing monitoring results to—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb6cfde0f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–14/d/3/A/v/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appropriate Federal, State, and local government agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb6cfde10-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–14/d/3/A/v/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appropriate response personnel; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb6cfde11-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–14/d/3/A/v/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the public;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6cfde12-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–14/d/3/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" responsibilities of Federal, State, and local agencies for—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb6cfde13-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–14/d/3/A/vi/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collecting and analyzing samples;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb6cfde14-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–14/d/3/A/vi/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reporting results; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb6cfde15-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–14/d/3/A/vi/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" taking appropriate response actions; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6cfde16-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–14/d/3/A/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" capabilities and capacity within the Federal Government to conduct appropriate environmental monitoring and response in the event of a disaster, including a terrorist attack; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6cfde17-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–14/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other issues specified by the Secretary of Health and Human Services, the Secretary of Homeland Security, and the Administrator of the Environmental Protection Agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6cfde18-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–14/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums as are necessary to carry out this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb6cfde19-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/347/tVII/s709"},"text":"Pub. L. 109–347, title VII, § 709","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-13"},"text":"Oct. 13, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1947"},"text":"120 Stat. 1947","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb6cfde1a-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb6cfde1b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb6cfde1c-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 264(c) of the Health Insurance Portability and Accountability Act of 1996, referred to in subsec. (b)(7), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/191/s264/c"},"text":"section 264(c) of Pub. L. 104–191","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320d–2"},"text":"section 1320d–2 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb6cfde1d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Security and Accountability For Every Port Act of 2006, also known as the SAFE Port Act, and not as part of the Public Health Service Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
