{"tag":"section","attrib":{"id":"idbcbc223b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4273"},"text":null,"children":[{"tag":"num","attrib":{"value":"4273"},"text":"§ 4273.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership of Commission; appointment of members; term","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbcbc223c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4273/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Number of members; appointment; qualifications","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commission shall be composed of twenty-six members, as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbcbc223d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4273/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Six appointed by the President of the United States, three of whom shall be officers of the executive branch of the Government, and three private citizens, all of whom shall have had experience or familiarity with relations between the levels of government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcbc223e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4273/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Three appointed by the President of the Senate, who shall be Members of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcbc223f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4273/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Three appointed by the Speaker of the House of Representatives, who shall be Members of the House;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcbc2240-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4273/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Four appointed by the President from a panel of at least eight Governors submitted by the Governors’ Conference;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcbc2241-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4273/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Three appointed by the President from a panel of at least six members of State legislative bodies submitted by the board of managers of the Council of State Governments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcbc2242-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4273/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Four appointed by the President from a panel of at least eight mayors submitted jointly by the National League of Cities and the United States Conference of Mayors; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcbc2243-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4273/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Three appointed by the President from a panel of at least six elected county officers submitted by the National Association of Counties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcbc2244-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4273/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Political and geographical composition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The members appointed from private life under paragraph (1) of subsection (a) shall be appointed without regard to political affiliation; of each class of members enumerated in paragraphs (2) and (3) of subsection (a), two shall be from the majority party of the respective houses; of each class of members enumerated in paragraphs (4), (5), (6), and (7) of subsection (a), not more than two shall be from any one political party; of each class of members enumerated in paragraphs (5), (6) and (7) of subsection (a), not more than one shall be from any one State; at least two of the appointees under paragraph (6) of subsection (a) shall be from cities under five hundred thousand population.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcbc2245-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4273/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term of office; reappointment; period of service","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term of office of each member of the Commission shall be two years; members shall be eligible for reappointment; and, except as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4274/d"},"text":"section 4274(d) of this title","children":[],"tail":", members shall serve until their successors are appointed."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbcbc2246-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/380/s3"},"text":"Pub. L. 86–380, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1959-09-24"},"text":"Sept. 24, 1959","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/73/704"},"text":"73 Stat. 704","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/733"},"text":"Pub. L. 89–733","children":[],"tail":", §§ 1, 2, "},{"tag":"date","attrib":{"date":"1966-11-02"},"text":"Nov. 2, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1162"},"text":"80 Stat. 1162","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbcbc2247-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbcbc2248-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbcbc2249-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s2373"},"text":"section 2373 of Title 5","children":[],"tail":" prior to the general revision and enactment of Title 5, Government Organization and Employees, by "},{"tag":"ref","attrib":{"href":"/us/pl/89/554/s1"},"text":"Pub. L. 89–554, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/378"},"text":"80 Stat. 378","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbcbc224a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1966—Subsec. (a)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/733/s1"},"text":"Pub. L. 89–733, § 1","children":[],"tail":", substituted “National League of Cities” for “American Municipal Association”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/733/s1"},"text":"Pub. L. 89–733, § 1","children":[],"tail":", substituted “National Association of Counties” for “National Association of County Officials”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/733/s2"},"text":"Pub. L. 89–733, § 2","children":[],"tail":", inserted provision that members shall serve until their successors are appointed, except as provided in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4274/d"},"text":"section 4274(d) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
