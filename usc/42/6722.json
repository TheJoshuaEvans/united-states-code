{"tag":"section","attrib":{"id":"idbdb8f88f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6722"},"text":null,"children":[{"tag":"num","attrib":{"value":"6722"},"text":"§ 6722.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbdb8f890-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6722/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments to State and local governments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of the Treasury (hereafter in this subchapter referred to as the “Secretary”) shall, in accordance with the provisions of this subchapter, make payments to States and to local governments to coordinate budget-related actions by such governments with Federal Government efforts to stimulate economic recovery.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdb8f891-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6722/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to the provisions of subsections (c) and (d), there are authorized to be appropriated for each of the five succeeding calendar quarters (beginning with the calendar quarter which begins on ","children":[{"tag":"date","attrib":{"date":"1977-07-01"},"text":"July 1, 1977","children":[],"tail":") for the purpose of payments under this subchapter—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbdb8f892-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6722/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $125,000,000, plus","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdb8f893-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6722/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $30,000,000 multiplied by the number of whole one-tenth percentage points by which the rate of seasonally adjusted national unemployment for the most recent calendar quarter which ended three months before the beginning of such quarter exceeded 6 per centum.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdb8f894-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6722/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Aggregate authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In no case shall the aggregate amount authorized to be appropriated under the provisions of subsection (b) for the five successive calendar quarters beginning with the calendar quarter which begins ","children":[{"tag":"date","attrib":{"date":"1977-07-01"},"text":"July 1, 1977","children":[],"tail":", exceed $2,250,000,000."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdb8f895-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6722/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No amount is authorized to be appropriated under the provisions of subsection (b) for any calendar quarter if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbdb8f896-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6722/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the average rate of national unemployment during the most recent calendar quarter which ended three months before the beginning of such calendar quarter did not exceed 6 percent, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdb8f897-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6722/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the rate of national unemployment for the last month of the most recent calendar quarter which ended three months before the beginning of such calendar quarter did not exceed 6 percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbdb8f898-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/369/tII/s202"},"text":"Pub. L. 94–369, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-07-22"},"text":"July 22, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1002"},"text":"90 Stat. 1002","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/447/tII/s201/1"},"text":"Pub. L. 94–447, title II, § 201(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-01"},"text":"Oct. 1, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1498"},"text":"90 Stat. 1498","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/30/tVI/s602"},"text":"Pub. L. 95–30, title VI, § 602","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-05-23"},"text":"May 23, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/164"},"text":"91 Stat. 164","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbdb8f899-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbdb8f89a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbdb8f89b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1977—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/30/s602/a"},"text":"Pub. L. 95–30, § 602(a)","children":[],"tail":", substituted “"},{"tag":"date","attrib":{"date":"1977-07-01"},"text":"July 1, 1977","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"1976-07-01"},"text":"July 1, 1976","children":[],"tail":"” in introductory provisions preceding par. (1) and in par. (2) substituted “$30,000,000 multiplied by the number of whole one-tenth” for “$62,500,000 multiplied by the number of one-half” and “such quarter exceeded 6 per centum” for “such calendar quarter exceeded 6 percent”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/30/s602/b"},"text":"Pub. L. 95–30, § 602(b)","children":[],"tail":", substituted “five successive calendar quarters beginning with the calendar quarter which begins "},{"tag":"date","attrib":{"date":"1977-07-01"},"text":"July 1, 1977","children":[],"tail":", exceed $2,250,000,000” for “five calendar quarters beginning with the calendar quarter which begins "},{"tag":"date","attrib":{"date":"1976-07-01"},"text":"July 1, 1976","children":[],"tail":", exceed $1,250,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/447"},"text":"Pub. L. 94–447","children":[],"tail":" substituted “6 percent, or” for “6 percent, and”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
