{"tag":"section","attrib":{"id":"idbea776e7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8852"},"text":null,"children":[{"tag":"num","attrib":{"value":"8852"},"text":"§ 8852.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination of research and extension activities; consultative requirements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbea776e8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8852/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Agriculture shall coordinate the applied research and extension programs conducted under this subchapter ","children":[{"tag":"ref","attrib":{"idref":"fn003856"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003856"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" and under the amendments made by this subchapter to section 1419 ["},{"tag":"ref","attrib":{"href":"/us/usc/t7/s3154"},"text":"7 U.S.C. 3154","children":[],"tail":"]"},{"tag":"ref","attrib":{"idref":"fn003856"},"text":"1","children":[],"tail":" and subtitle B of the National Agricultural Research, Extension, and Teaching Policy Act of 1977 ["},{"tag":"ref","attrib":{"href":"/us/usc/t7/s3129"},"text":"7 U.S.C. 3129","children":[],"tail":"],"},{"tag":"ref","attrib":{"idref":"fn003856"},"text":"1","children":[],"tail":" section 1 of the Bankhead-Jones Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t7/s3104"},"text":"7 U.S.C. 3104","children":[],"tail":"], section 3 of the Forest and Rangeland Renewable Resources Research Act of 1978 ["},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1642"},"text":"16 U.S.C. 1642","children":[],"tail":"], and sections 1 and 2 of the Smith-Lever Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t7/s341"},"text":"7 U.S.C. 341","children":[],"tail":", 342] with the programs of the Department of Energy."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbea776e9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8852/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In carrying out this subchapter and the amendments made by this subchapter, the Secretary of Agriculture shall consult on a continuing basis with—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbea776ea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8852/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Subcommittee on Food, Agricultural, and Forestry Research of the Federal Coordinating Council for Science, Engineering, and Technology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbea776eb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8852/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Joint Council on Food and Agricultural Sciences; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbea776ec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8852/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Agricultural Research and Extension Users Advisory Board;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"for the purpose of coordinating research and extension activities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbea776ed-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/294/tII/s257"},"text":"Pub. L. 96–294, title II, §