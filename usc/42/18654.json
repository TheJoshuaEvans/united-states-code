{"tag":"section","attrib":{"id":"idc06098c8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18654"},"text":null,"children":[{"tag":"num","attrib":{"value":"18654"},"text":"§ 18654.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Midscale instrumentation and research equipment program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc06098c9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18654/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall establish a midscale instrumentation and research equipment program to develop, acquire, and commercialize research instrumentation and equipment needed to meet the missions of the Department and to provide platform technologies for the broader scientific community.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc06098ca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18654/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Under the program established under subsection (a), the Director shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc06098cb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18654/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" enable the development and acquisition of novel, state-of-the-art instruments that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc06098cc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18654/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" range in cost from $1,000,000 to $20,000,000 each; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06098cd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18654/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" would significantly accelerate scientific breakthroughs at user facilities; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06098ce-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18654/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" strongly encourage partnerships among—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc06098cf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18654/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" National Laboratories;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06098d0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18654/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" user facilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06098d1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18654/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc06098d2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18654/b/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" institutions in a State receiving funding under the Established Program to Stimulate Competitive Research established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s13503/b/3"},"text":"section 13503(b)(3) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc06098d3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18654/b/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" historically Black colleges or universities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc06098d4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18654/b/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" minority-serving institutions of higher education; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc06098d5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18654/b/2/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" institutions of higher education in a rural area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc06098d6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18654/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with other programs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall coordinate the program established under subsection (a) with all other programs carried out by the Office of Science of the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc06098d7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18654/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research equipment and technology development coordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall encourage coordination among the Office of Science, the National Laboratories, the Office of Technology Transitions, and relevant academic and private sector entities to identify, disseminate, and commercialize research instruments, equipment, and related technologies developed to aid basic science research discoveries that meet the mission of the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc06098d8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18654/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Out of funds authorized to be appropriated for the Office of Science in a fiscal year, there is authorized to be appropriated to carry out this section $150,000,000 for each of fiscals ","children":[{"tag":"ref","attrib":{"idref":"fn004366"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004366"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “fiscal”."}],"tail":" years 2023 through 2027."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc06098d9-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/246/tIII/s316"},"text":"Pub. L. 115–246, title III, § 316","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/tI/s10112/a"},"text":"Pub. L. 117–167, div. B, title I, § 10112(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1463"},"text":"136 Stat. 1463","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
