{"tag":"section","attrib":{"id":"idb54b132f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280l"},"text":null,"children":[{"tag":"num","attrib":{"value":"280l"},"text":"§ 280l.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance for employer-based wellness programs","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In order to expand the utilization of evidence-based prevention and health promotion approaches in the workplace, the Director shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb54b1330-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280l/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide employers (including small, medium, and large employers, as determined by the Director) with technical assistance, consultation, tools, and other resources in evaluating such employers’ employer-based wellness programs, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb54b1331-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280l/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" measuring the participation and methods to increase participation of employees in such programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb54b1332-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280l/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing standardized measures that assess policy, environmental and systems changes necessary to have a positive health impact on employees’ health behaviors, health outcomes, and health care expenditures; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb54b1333-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280l/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluating such programs as they relate to changes in the health status of employees, the absenteeism of employees, the productivity of employees, the rate of workplace injury, and the medical costs incurred by employees; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb54b1334-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280l/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" build evaluation capacity among workplace staff by training employers on how to evaluate employer-based wellness programs and ensuring evaluation resources, technical assistance, and consultation are available to workplace staff as needed through such mechanisms as web portals, call centers, or other means.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb54b1335-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title III, § 399MM, as added and amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tIV/s4303"},"text":"Pub. L. 111–148, title IV, § 4303","children":[],"tail":", title X, § 10404, "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/583"},"text":"124 Stat. 583","children":[],"tail":", 975.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb54b1336-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb54b1337-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb54b1338-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/s10404"},"text":"Pub. L. 111–148, § 10404","children":[],"tail":", substituted “and ensuring” for “by ensuring”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb54b1339-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb54b133a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Grants for Small Businesses To Provide Comprehensive Workplace Wellness Programs","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/tX/s10408"},"text":"Pub. L. 111–148, title X, § 10408","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/977"},"text":"124 Stat. 977","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/148/tX/s10408"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall award grants to eligible employers to provide their employees with access to comprehensive workplace wellness programs (as described under subsection (c)).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Scope.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duration","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The grant program established under this section shall be conducted for a 5-year period.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible employer","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term ‘eligible employer’ means an employer (including a non-profit employer) that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" employs less than 100 employees who work 25 hours or greater per week; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not provide a workplace wellness program as of the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Comprehensive Workplace Wellness Programs.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Criteria","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall develop program criteria for comprehensive workplace wellness programs under this section that are based on and consistent with evidence-based research and best practices, including research and practices as provided in the Guide to Community Preventive Services, the Guide to Clinical Preventive Services, and the National Registry for Effective Programs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A comprehensive workplace wellness program shall be made available by an eligible employer to all employees and include the following components:","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Health awareness initiatives (including health education, preventive screenings, and health risk assessments).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Efforts to maximize employee engagement (including mechanisms to encourage employee participation).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Initiatives to change unhealthy behaviors and lifestyle choices (including counseling, seminars, online programs, and self-help materials).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"“(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Supportive environment efforts (including workplace policies to encourage healthy lifestyles, healthy eating, increased physical activity, and improved mental health).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An eligible employer desiring to participate in the grant program under this section shall submit an application to the Secretary, in such manner and containing such information as the Secretary may require, which shall include a proposal for a comprehensive workplace wellness program that meet [sic] the criteria and requirements described under subsection (c).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"“(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorization of Appropriation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of carrying out the grant program under this section, there is authorized to be appropriated $200,000,000 for the period of fiscal years 2011 through 2015. Amounts appropriated pursuant to this subsection shall remain available until expended.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
