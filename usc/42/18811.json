{"tag":"section","attrib":{"id":"idc06c7faf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18811"},"text":null,"children":[{"tag":"num","attrib":{"value":"18811"},"text":"§ 18811.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this part:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc06c7fb0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18811/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Energy management system","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “energy management system” means a business management process based on standards of the American National Standards Institute that enables an organization to follow a systematic approach in achieving continual improvement of energy performance, including energy efficiency, security, use, and consumption.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06c7fb1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18811/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Industrial research and assessment center","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “industrial research and assessment center” means a center located at an institution of higher education, a trade school, a community college, or a union training program that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc06c7fb2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18811/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" receives funding from the Department;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06c7fb3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18811/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides an in-depth assessment of small- and medium-size manufacturer plant sites to evaluate the facilities, services, and manufacturing operations of the plant site; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06c7fb4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18811/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifies opportunities for potential savings for small- and medium-size manufacturer plant sites from energy efficiency improvements, waste minimization, pollution prevention, and productivity improvement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06c7fb5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18811/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information and communication technology","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “information and communication technology” means any electronic system or equipment (including the content contained in the system or equipment) used to create, convert, communicate, or duplicate data or information, including computer hardware, firmware, software, communication protocols, networks, and data interfaces.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06c7fb6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18811/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Institution of higher education","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “institution of higher education” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001/a"},"text":"section 1001(a) of title 20","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06c7fb7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18811/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" North American Industry Classification System","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “North American Industry Classification System” means the standard used by Federal statistical agencies in classifying business establishments for the purpose of collecting, analyzing, and publishing statistical data relating to the business economy of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06c7fb8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18811/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Small and medium manufacturers","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “small and medium manufacturers” means manufacturing firms—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc06c7fb9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18811/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" classified in the North American Industry Classification System as any of sectors 31 through 33;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06c7fba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18811/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with gross annual sales of less than $100,000,000;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06c7fbb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18811/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with fewer than 500 employees at the plant site; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06c7fbc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18811/6/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with annual energy bills totaling more than $100,000 and less than $3,500,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06c7fbd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18811/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Smart manufacturing","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “smart manufacturing” means advanced technologies in information, automation, monitoring, computation, sensing, modeling, artificial intelligence, analytics, and networking that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc06c7fbe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18811/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" digitally—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc06c7fbf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18811/7/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" simulate manufacturing production lines;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc06c7fc0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18811/7/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operate computer-controlled manufacturing equipment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc06c7fc1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18811/7/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" monitor and communicate production line status; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc06c7fc2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18811/7/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" manage and optimize energy productivity and cost throughout production;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06c7fc3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18811/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" model, simulate, and optimize the energy efficiency of a factory building;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06c7fc4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18811/7/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" monitor and optimize building energy performance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06c7fc5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18811/7/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" model, simulate, and optimize the design of energy efficient and sustainable products, including the use of digital prototyping and additive manufacturing to enhance product design;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06c7fc6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18811/7/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" connect manufactured products in networks to monitor and optimize the performance of the networks, including automated network operations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06c7fc7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18811/7/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" digitally connect the supply chain network.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc06c7fc8-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dD/tV/s40531"},"text":"Pub. L. 117–58, div. D, title V, § 40531","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1068"},"text":"135 Stat. 1068","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc06c7fc9-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc06c7fca-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc06c7fcb-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Wage Rate Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions relating to rates of wages to be paid to laborers and mechanics on projects for construction, alteration, or repair work funded under div. D or an amendment by div. D of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":", including authority of Secretary of Labor, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s18851"},"text":"section 18851 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
