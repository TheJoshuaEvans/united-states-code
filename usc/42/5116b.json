, § 401(a)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd06232a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/320"},"text":"Pub. L. 111–320","children":[],"tail":" inserted subpar. headings."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—Subsec. (b)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/36/s123/1"},"text":"Pub. L. 108–36, § 123(1)","children":[],"tail":", substituted “as the amount of private, State or other non-Federal funds leveraged and directed through the currently designated” for “as the amount leveraged by the State from private, State, or other non-Federal sources and directed through the”, “State lead entity” for “State lead agency”, and “the current lead entity” for “the lead agency”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/36/s123/2"},"text":"Pub. L. 108–36, § 123(2)","children":[],"tail":", substituted “subsection (b)” for “subsection (a)”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
