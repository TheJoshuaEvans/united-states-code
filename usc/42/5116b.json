{"tag":"section","attrib":{"id":"idbd06231b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5116b"},"text":null,"children":[{"tag":"num","attrib":{"value":"5116b"},"text":"§ 5116b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of grant","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd06231c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5116b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reservation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall reserve 1 percent of the amount appropriated under section 5116i ","children":[{"tag":"ref","attrib":{"idref":"fn003399"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003399"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title for a fiscal year to make allotments to Indian tribes and tribal organizations and migrant programs."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd06231d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5116b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Remaining amounts","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd06231e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5116b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall allot the amount appropriated under section 5116i ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of this title for a fiscal year and remaining after the reservation under subsection (a) among the States as follows:"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd06231f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5116b/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" 70 percent","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"70 percent of such amount appropriated shall be allotted among the States by allotting to each State an amount that bears the same proportion to such amount appropriated as the number of children under the age of 18 residing in the State bears to the total number of children under the age of 18 residing in all States (except that no State shall receive less than $175,000 under this subparagraph).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd062320-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5116b/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" 30 percent","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"30 percent of such amount appropriated shall be allotted among the States by allotting to each State an amount that bears the same proportion to such amount appropriated as the amount of private, State or other non-Federal funds leveraged and directed through the currently designated State lead entity in the preceding fiscal year bears to the aggregate of the amounts leveraged by all States from private, State, or other non-Federal sources and directed through the current lead entity of such States in the preceding fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd062321-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5116b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide allotments under paragraph (1) to the State lead entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd062322-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5116b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Funds allotted to a State under this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd062323-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5116b/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be for a 3-year period; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd062324-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5116b/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be provided by the Secretary to the State on an annual basis, as described in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd062325-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/247/tII/s203"},"text":"Pub. L. 93–247, title II, § 203","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/235/tI/s121"},"text":"Pub. L. 104–235, title I, § 121","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-1