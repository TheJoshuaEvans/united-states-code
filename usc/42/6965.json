{"tag":"section","attrib":{"id":"idbddf1e47-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6965"},"text":null,"children":[{"tag":"num","attrib":{"value":"6965"},"text":"§ 6965.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chief Financial Officer report","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Chief Financial Officer of each affected agency shall submit to Congress an annual report containing, to the extent practicable, a detailed description of the compliance activities undertaken by the agency for mixed waste streams, and an accounting of the fines and penalties imposed on the agency for violations involving mixed waste.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbddf1e48-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/386/tI/s110"},"text":"Pub. L. 102–386, title I, § 110","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-06"},"text":"Oct. 6, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1516"},"text":"106 Stat. 1516","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbddf1e49-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbddf1e4a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbddf1e4b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Federal Facility Compliance Act of 1992, and not as part of the Solid Waste Disposal Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
