{"tag":"section","attrib":{"id":"idbc63efd0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3056b"},"text":null,"children":[{"tag":"num","attrib":{"value":"3056b"},"text":"§ 3056b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Participants not Federal employees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbc63efd1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3056b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inapplicability of certain provisions covering Federal employees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Eligible individuals who are participants in any project funded under this subchapter shall not be considered to be Federal employees as a result of such participation and shall not be subject to part III of title 5.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc63efd2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3056b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Workers’ compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No grant or subgrant shall be made and no contract or subcontract shall be entered into under this subchapter with an entity who is, or whose employees are, under State law, exempted from operation of the State workers’ compensation law, generally applicable to employees, unless the entity shall undertake to provide either through insurance by a recognized carrier or by self-insurance, as authorized by State law, that the persons employed under the grant, subgrant, contract, or subcontract shall enjoy workers’ compensation coverage equal to that provided by law for covered employment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc63efd3-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/73/tV/s504"},"text":"Pub. L. 89–73, title V, § 504","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/365/tV/s501"},"text":"Pub. L. 109–365, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2575"},"text":"120 Stat. 2575","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc63efd4-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc63efd5-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbc63efd6-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 3056b, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/73/tV/s504"},"text":"Pub. L. 89–73, title V, § 504","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/501/tV/s501"},"text":"Pub. L. 106–501, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-13"},"text":"Nov. 13, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2276"},"text":"114 Stat. 2276","children":[],"tail":", related to participants not having status as Federal employees and contractual requirement of workmen’s compensation, prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/109/365"},"text":"Pub. L. 109–365","child