{"tag":"section","attrib":{"id":"idb63e4c65-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–3d"},"text":null,"children":[{"tag":"num","attrib":{"value":"300j–3d"},"text":"§ 300j–3d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Water supply cost savings","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb63e4c66-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–3d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Drinking water technology clearinghouse","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator, in consultation with the Secretary of Agriculture, shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb63e4c67-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–3d/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop a technology clearinghouse for information on the cost-effectiveness of innovative and alternative drinking water delivery systems, including wells and well systems; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb63e4c68-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–3d/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disseminate such information to the public and to communities and not-for-profit organizations seeking Federal funding for drinking water delivery systems serving 500 or fewer persons.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb63e4c69-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–3d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Water system assessment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In any application for a grant or loan for the purpose of construction, replacement, or rehabilitation of a drinking water delivery system serving 500 or fewer persons, the funding for which would come from the Federal Government (either directly or through a State), a unit of local government or not-for-profit organization shall self-certify that the unit of local government or organization has considered, as an alternative drinking water supply, drinking water delivery systems sourced by publicly owned—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb63e4c6a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–3d/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" individual wells;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb63e4c6b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–3d/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shared wells; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb63e4c6c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–3d/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" community wells.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb63e4c6d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–3d/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 3 years after ","children":[{"tag":"date","attrib":{"date":"2016-12-16"},"text":"December 16, 2016","children":[],"tail":", the Comptroller General of the United States shall submit to Congress a report that describes—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb63e4c6e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–3d/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use of innovative and alternative drinking water delivery systems described in this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb63e4c6f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–3d/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the range of cost savings for communities using innovative and alternative drinking water delivery systems described in this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb63e4c70-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–3d/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use of drinking water technical assistance programs operated by the Administrator and the Secretary of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb63e4c71-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/322/tII/s2108"},"text":"Pub. L. 114–322, title II, § 2108","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1728"},"text":"130 Stat. 1728","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb63e4c72-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb63e4c73-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb63e4c74-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Water and Waste Act of 2016, and also as part of the Water Infrastructure Improvements for the Nation Act, also known as the WIIN Act, and not as part of the Public Health Service Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb63e4c75-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idb63e4c76-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Definition of “Administrator”","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/322/tII/s2002"},"text":"Pub. L. 114–322, title II, § 2002","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1716"},"text":"130 Stat. 1716","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/322/tII/s2002"},"text":"“In this title [see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/322/s2001"},"text":"section 2001 of Pub. L. 114–322","children":[],"tail":", set out as a Short Title of 2016 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s201"},"text":"section 201 of this title","children":[],"tail":"], the term ‘Administrator’ means the Administrator of the Environmental Protection Agency.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
