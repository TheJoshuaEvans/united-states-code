{"tag":"section","attrib":{"id":"idbbb38c01-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1997f"},"text":null,"children":[{"tag":"num","attrib":{"value":"1997f"},"text":"§ 1997f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Attorney General shall include in the report to Congress on the business of the Department of Justice prepared pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s522"},"text":"section 522 of title 28","children":[],"tail":"—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbbb38c02-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1997f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a statement of the number, variety, and outcome of all actions instituted pursuant to this subchapter including the history of, precise reasons for, and procedures followed in initiation or intervention in each case in which action was commenced;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbb38c03-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1997f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a detailed explanation of the procedures by which the Department has received, reviewed and evaluated petitions or complaints regarding conditions in institutions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbb38c04-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1997f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an analysis of the impact of actions instituted pursuant to this subchapter, including, when feasible, an estimate of the costs incurred by States and other political subdivisions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbb38c05-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1997f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a statement of the financial, technical, or other assistance which has been made available from the United States to the State in order to assist in the correction of the conditions which are alleged to have deprived a person of rights, privileges, or immunities secured or protected by the Constitution or laws of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbb38c06-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1997f/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the progress made in each Federal institution toward meeting existing promulgated standards for such institutions or constitutionally guaranteed minima.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbbb38c07-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/247/s8"},"text":"Pub. L. 96–247, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-05-23"},"text":"May 23, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/353"},"text":"94 Stat. 353","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/256/tII/s201/b"},"text":"Pub. L. 97–256, title II, § 201(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-08"},"text":"Sept. 8, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/817"},"text":"96 Stat. 817","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/134/tI/s101"},"text":"Pub. L. 104–134, title I, § 101[(a)]","children":[],"tail":" [title VIII, § 803(e)], "},{"tag":"date","attrib":{"date":"1996-04-26"},"text":"Apr. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1321"},"text":"110 Stat. 1321","children":[],"tail":", 1321–73; renumbered title I, "},{"tag":"ref","attrib":{"href":"/us/pl/104/140/s1/a"},"text":"Pub. L. 104–140, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-05-02"},"text":"May 2, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1327"},"text":"110 Stat. 1327","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbbb38c08-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbbb38c09-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbbb38c0a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/134"},"text":"Pub. L. 104–134","children":[],"tail":" substituted “the report” for “his report” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/256"},"text":"Pub. L. 97–256","children":[],"tail":" substituted “Attorney General” for “Attorney”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
