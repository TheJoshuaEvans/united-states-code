{"tag":"section","attrib":{"id":"idbfa4267a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12853"},"text":null,"children":[{"tag":"num","attrib":{"value":"12853"},"text":"§ 12853.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Homeownership Trust Fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfa4267b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12853/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established in the Treasury of the United States a revolving fund, to be known as the National Homeownership Trust Fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfa4267c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12853/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assets","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Fund shall consist of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfa4267d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12853/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any amount approved in appropriation Acts under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12857"},"text":"section 12857 of this title","children":[],"tail":" for purposes of carrying out this subchapter;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfa4267e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12853/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any amount received by the Trust as repayment for payments made under this subchapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfa4267f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12853/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any amount received by the Trust under subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfa42680-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12853/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of amounts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Fund shall, to the extent approved in appropriations Acts, be available to the Trust for purposes of carrying out this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfa42681-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12853/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investment of excess amounts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any amounts in the Fund determined by the Trust to be in excess of the amounts currently required to carry out the provisions of this subchapter shall be invested by the Trust in obligations of, or obligations guaranteed as to both principal and interest by, the United States or any agency of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfa42682-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12853/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Demonstration programs","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Using not more than $20,000,000 of any amounts appropriated for the Fund under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12857"},"text":"section 12857 of this title","children":[],"tail":" in fiscal year 1991, the Secretary shall carry out demonstration programs for combining housing activities and economic development activities, as follows:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfa42683-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12853/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In Milwaukee, Wisconsin, in an amount not to exceed $4,200,000, for development, rehabilitation, and revitalization of 2 vacant structures in a blighted minority neighborhood.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfa42684-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12853/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In Washington, District of Columbia, in an amount not to exceed $10,000,000, for nonprofit neighborhood-based groups to acquire and rehabilitate vacant public and private housing for resale or rent to low- and moderate-income families and to the extent of and subject to engage in neighborhood-based economic development activities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfa42685-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12853/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In Philadelphia, Pennsylvania, in an amount not to exceed $1,000,000, for technical assistance and organizational support for a community development corporation that is a city-wide public/private partnership engaged in the provision of technical assistance to neighborhood community development corporations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfa42686-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12853/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In other areas, as the Secretary may determine.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfa42687-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/625/tIII/s304"},"text":"Pub. L. 101–625, title III, § 304","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4132"},"text":"104 Stat. 4132","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
