{"tag":"section","attrib":{"id":"idbe839b9f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8252"},"text":null,"children":[{"tag":"num","attrib":{"value":"8252"},"text":"§ 8252.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"It is the purpose of this part to promote the conservation and the efficient use of energy and water, and the use of renewable energy sources, by the Federal Government.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbe839ba0-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/619/tV/s542"},"text":"Pub. L. 95–619, title V, § 542","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-09"},"text":"Nov. 9, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3277"},"text":"92 Stat. 3277","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/615/s2/a"},"text":"Pub. L. 100–615, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-05"},"text":"Nov. 5, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3185"},"text":"102 Stat. 3185","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/486/tI/s152/a"},"text":"Pub. L. 102–486, title I, § 152(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2844"},"text":"106 Stat. 2844","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbe839ba1-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbe839ba2-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbe839ba3-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486"},"text":"Pub. L. 102–486","children":[],"tail":" inserted “and water, and the use of renewable energy sources,” after “use of energy”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/615"},"text":"Pub. L. 100–615","children":[],"tail":" amended section generally, substituting statement of purpose for policy statement declaring it to be United States policy for Federal Government to have the opportunity and responsibility, with participation of industry, to further develop, demonstrate, and promote use of energy conservation, solar heating and cooling, and other renewable energy sources in Federal buildings."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
