{"tag":"section","attrib":{"id":"idb578646a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285m–5"},"text":null,"children":[{"tag":"num","attrib":{"value":"285m–5"},"text":"§ 285m–5.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interagency Coordinating Committee","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb578646b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285m–5/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may establish a committee to be known as the Deafness and Other Communication Disorders Interagency Coordinating Committee (hereafter in this section referred to as the “Coordinating Committee”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb578646c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285m–5/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Coordinating Committee shall, with respect to deafness and other communication disorders—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb578646d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285m–5/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for the coordination of the activities of the national research institutes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb578646e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285m–5/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate the aspects of all Federal health programs and activities relating to deafness and other communication disorders in order to assure the adequacy and technical soundness of such programs and activities and in order to provide for the full communication and exchange of information necessary to maintain adequate coordination of such programs and activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb578646f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285m–5/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Composition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Coordinating Committee shall be composed of the directors of each of the national research institutes and divisions involved in research with respect to deafness and other communication disorders and representatives of all other Federal departments and agencies whose programs involve health functions or responsibilities relevant to deafness and other communication disorders.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5786470-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285m–5/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chairman; meetings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Coordinating Committee shall be chaired by the Director of NIH (or the designee of the Director). The Committee shall meet at the call of the chair, but not less often than four times a year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5786471-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title IV, § 464E, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/553/s2/4"},"text":"Pub. L. 100–553, § 2(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-28"},"text":"Oct. 28, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2774"},"text":"102 Stat. 2774","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tII/s2613/a/1"},"text":"Pub. L. 100–690, title II, § 2613(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4237"},"text":"102 Stat. 4237","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tII/s2613/b/2"},"text":"Pub. L. 100–690, title II, § 2613(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4238"},"text":"102 Stat. 4238","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/43/tXX/s2008/b/9"},"text":"Pub. L. 103–43, title XX, § 2008(b)(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-06-10"},"text":"June 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/211"},"text":"107 Stat. 211","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/482/tI/s104/b/1/K"},"text":"Pub. L. 109–482, title I, § 104(b)(1)(K)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-01-15"},"text":"Jan. 15, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3693"},"text":"120 Stat. 3693","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb5786472-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb5786473-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb5786474-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/553"},"text":"Pub. L. 100–553","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/s2613/a/1"},"text":"section 2613(a)(1) of Pub. L. 100–690","children":[],"tail":" contained identical provisions enacting this section. See 1988 Amendment note below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb5786475-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2007—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/482"},"text":"Pub. L. 109–482","children":[],"tail":" struck out subsec. (e) which read as follows: “Not later than 120 days after the end of each fiscal year, the Coordinating Committee shall prepare and transmit to the Secretary, the Director of NIH, the Director of the Institute, and the advisory council for the Institute a report detailing the activities of the Committee in such fiscal year in carrying out subsection (b) of this section.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsecs. (d), (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/43"},"text":"Pub. L. 103–43","children":[],"tail":" inserted “Coordinating” before “Committee” in first sentence of subsec. (d) and before first reference to “Committee” in subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/p