},"text":" The amendments made by section 605 [amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s8624"},"text":"section 8624 of this title","children":[],"tail":"] shall take effect on the first day of the first fiscal year beginning after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amendments made by section 606 [amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s8626"},"text":"section 8626 of this title","children":[],"tail":"] shall apply to amounts held available for fiscal years beginning after "},{"tag":"date","attrib":{"date":"1985-09-30"},"text":"September 30, 1985","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amendment made by section 607 [amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s8629"},"text":"section 8629 of this title","children":[],"tail":"] shall apply to data collected and compiled after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","children":[],"tail":"]. Section 2610 of the Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s8629"},"text":"section 8629 of this title","children":[],"tail":"] as in effect before the date of the enactment of this Act shall apply with respect to the report submitted under such section 2610 for fiscal year 1984.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idbe9b6989-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","at