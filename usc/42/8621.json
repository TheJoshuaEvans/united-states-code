ion, enacting provisions set out as notes under this section and sections 8623, 9801, and 10901 of this title, and amending provisions set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s9861"},"text":"section 9861 of this title","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1932"},"text":"section 1932 of Title 7","children":[],"tail":", Agriculture] shall take effect on "},{"tag":"date","attrib":{"date":"1986-10-01"},"text":"October 1, 1986","children":[],"tail":", or the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1986-09-30"},"text":"Sept. 30, 1986","children":[],"tail":"], whichever occurs later."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effective Date for Energy Crisis Intervention Amendments","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendments made by section 502(a) [amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s8623"},"text":"section 8623 of this title","children":[],"tail":" and enacting provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s8623"},"text":"section 8623 of this title","children":[],"tail":"] shall take effect on "},{"tag":"date","attrib":{"date":"1986-12-01"},"text":"December 1, 1986","children":[],"tail":", or 60 days after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1986-09-30"},"text":"Sept. 30, 1986","children":[],"tail":"], whichever occurs later."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application of Certain Other Amendments Relating to E