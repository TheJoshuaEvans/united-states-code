{"tag":"section","attrib":{"id":"idb6dbc477-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–38"},"text":null,"children":[{"tag":"num","attrib":{"value":"300jj–38"},"text":"§ 300jj–38.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization for appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"For the purposes of carrying out this part, there is authorized to be appropriated such sums as may be necessary for each of the fiscal years 2009 through 2013.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb6dbc478-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XXX, § 3018, as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/5/dA/tXIII/s13301"},"text":"Pub. L. 111–5, div. A, title XIII, § 13301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-02-17"},"text":"Feb. 17, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/258"},"text":"123 Stat. 258","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
