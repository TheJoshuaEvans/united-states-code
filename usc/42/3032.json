{"tag":"section","attrib":{"id":"idbc5cc3be-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032"},"text":null,"children":[{"tag":"num","attrib":{"value":"3032"},"text":"§ 3032.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program authorized","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbc5cc3bf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purpose of carrying out this section, the Assistant Secretary may make grants to and enter into contracts with States, public agencies, private nonprofit agencies, institutions of higher education, and organizations, including tribal organizations, for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc5cc3c0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" education and training to develop an adequately trained workforce to work with and on behalf of older individuals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc5cc3c1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" applied social research, aligned with evidence-based practice, and analysis to improve access to and delivery of services for older individuals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc5cc3c2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluation of the performance of the programs, activities, and services provided under this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc5cc3c3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development of methods and practices to improve the quality and effectiveness of the programs, services, and activities provided under this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc5cc3c4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the demonstration of new approaches to design, deliver, and coordinate programs and services for older individuals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc5cc3c5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" technical assistance in planning, developing, implementing, and improving the programs, services, and activities provided under this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc5cc3c6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordination with the designated State agency described in section 101(a)(2)(A)(i) of the Rehabilitation Act of 1973 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s721/a/2/A/i"},"text":"29 U.S.C. 721(a)(2)(A)(i)","children":[],"tail":") to provide services to older individuals who are blind as described in such Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t29/s701"},"text":"29 U.S.C. 701","children":[],"tail":" et seq.];"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc5cc3c7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the training of graduate level professionals specializing in the mental health needs of older individuals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc5cc3c8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" planning activities to prepare communities for the aging of the population, which activities may include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc5cc3c9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032/a/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" efforts to assess the aging population;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc5cc3ca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032/a/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" activities to coordinate the activities of State and local agencies in order to meet the needs of older individuals; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc5cc3cb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032/a/9/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" training and technical assistance to support States, area agencies on aging, and organizations receiving grants under subchapter X, in engaging in community planning activities;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc5cc3cc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development, implementation, and assessment of technology-based service models and best practices, to support the use of health monitoring and assessment technologies, communication devices, assistive technologies, and other technologies consistent with section 508 of the Rehabilitation Act of 1973 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s794d"},"text":"29 U.S.C. 794d","children":[],"tail":") that may remotely connect family and professional caregivers to frail older individuals residing in home and community-based settings or rural areas;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc5cc3cd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032/a/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" conducting activities of national significance to promote quality and continuous improvement in the support provided to family and other informal caregivers of older individuals through activities that include program evaluation, training, technical assistance, and research, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc5cc3ce-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032/a/11/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" programs addressing unique issues faced by rural caregivers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc5cc3cf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032/a/11/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" programs focusing on the needs of older individuals with cognitive impairment such as Alzheimer’s disease and related disorders with neurological and organic brain dysfunction, and their caregivers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc5cc3d0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032/a/11/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" programs supporting caregivers in the role they play in providing disease prevention and health promotion services;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc5cc3d1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032/a/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" building public awareness of cognitive impairments, such as Alzheimer’s disease and related disorders with neurological and organic brain dysfunction, depression, mental disorders, and traumatic brain injury;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc5cc3d2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032/a/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in coordination with the Secretary of Labor, the demonstration of new strategies for the recruitment, retention, or advancement of direct care workers, and the soliciting, development, and implementation of strategies—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc5cc3d3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032/a/13/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to reduce barriers to entry for a diverse and high-quality direct care workforce, including providing wages, benefits, and advancement opportunities needed to attract or retain direct care workers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc5cc3d4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032/a/13/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide education and workforce development programs for direct care workers that include supportive services and career planning;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc5cc3d5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032/a/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the establishment and operation of a national resource center that shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc5cc3d6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032/a/14/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide training and technical assistance to agencies in the aging network delivering services to older individuals experiencing the long-term and adverse consequences of trauma;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc5cc3d7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032/a/14/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" share best practices with the aging network; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc5cc3d8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032/a/14/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make subgrants to the agencies best positioned to advance and improve the delivery of person-centered, trauma-informed services for older individuals experiencing the long-term and adverse consequences of trauma;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc5cc3d9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032/a/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" bringing to scale and sustaining evidence-based falls prevention programs that will reduce the number of falls, fear of falling, and fall-related injuries in older individuals, including older individuals with disabilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc5cc3da-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032/a/16"},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"(16)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" bringing to scale and sustaining evidence-based chronic disease self-management programs that empower older individuals, including older individuals with disabilities, to better manage their chronic conditions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc5cc3db-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032/a/17"},"text":null,"children":[{"tag":"num","attrib":{"value":"17"},"text":"(17)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" continuing support for program integrity initiatives concerning the Medicare program under title XVIII of the Social Security Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395"},"text":"42 U.S.C. 1395","children":[],"tail":" et seq.) that train senior volunteers to prevent and identify health care fraud and abuse;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc5cc3dc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032/a/18"},"text":null,"children":[{"tag":"num","attrib":{"value":"18"},"text":"(18)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" projects that address negative health effects associated with social isolation among older individuals; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc5cc3dd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032/a/19"},"text":null,"children":[{"tag":"num","attrib":{"value":"19"},"text":"(19)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other activities that the Assistant Secretary determines will achieve the objectives of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc5cc3de-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated to carry out—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc5cc3df-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" aging network support activities under this section, $14,514,550 for fiscal year 2020, $15,385,423 for fiscal year 2021, $16,308,548 for fiscal year 2022, $17,287,061 for fiscal year 2023, and $18,324,285 for fiscal year 2024; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc5cc3e0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" elder rights support activities under this section, $15,613,440 for fiscal year 2020, $16,550,246 for fiscal year 2021, $17,543,261 for fiscal year 2022, $18,595,857 for fiscal year 2023, and $19,711,608 for fiscal year 2024.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc5cc3e1-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/73/tIV/s411"},"text":"Pub. L. 89–73, title IV, § 411","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/501/tIV/s401"},"text":"Pub. L. 106–501, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-13"},"text":"Nov. 13, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2257"},"text":"114 Stat. 2257","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/365/tIV/s402"},"text":"Pub. L. 109–365, title IV, § 402","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2552"},"text":"120 Stat. 2552","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/144/s5/a"},"text":"Pub. L. 114–144, § 5(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-04-19"},"text":"Apr. 19, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/341"},"text":"130 Stat. 341","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/131/tI"},"text":"Pub. L. 116–131, title I","children":[],"tail":", §§ 104(3), 119, 120, title III, §§ 301–304, "},{"tag":"date","attrib":{"date":"2020-03-25"},"text":"Mar. 25, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/