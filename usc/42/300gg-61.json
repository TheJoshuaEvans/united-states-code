{"tag":"section","attrib":{"id":"idb6b7e966-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–61"},"text":null,"children":[{"tag":"num","attrib":{"value":"300gg–61"},"text":"§ 300gg–61.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb6b7e967-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–61/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State enforcement","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6b7e968-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–61/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300gg–62"},"text":"section 300gg–62 of this title","children":[],"tail":", each State may require that health insurance issuers that issue, sell, renew, or offer health insurance coverage in the State in the individual market meet the requirements established under this part with respect to such issuers."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6b7e969-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–61/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to implement requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a State that fails to substantially enforce the requirements set forth in this part with respect to health insurance issuers in the State, the Secretary shall enforce the requirements of this part under subsection (b) insofar as they relate to the issuance, sale, renewal, and offering of health insurance coverage in the individual market in such State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6b7e96a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–61/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretarial enforcement authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall have the same authority in relation to enforcement of the provisions of this part with respect to issuers of health insurance coverage in the individual market in a State as the Secretary has under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300gg–22/b/2"},"text":"section 300gg–22(b)(2) of this title","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300gg–22/b/3"},"text":"section 300gg–22(b)(3) of this title","children":[],"tail":" "},{"tag":"ref","attrib":{"idref":"fn002481"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002481"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" with respect to violations of genetic nondiscrimination provisions, in relation to the enforcement of the provisions of part A with respect to issuers of health insurance coverage in the small group market in the State."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb6b7e96b-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XXVII, § 2761, formerly § 2745, as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/191/tI/s111/a