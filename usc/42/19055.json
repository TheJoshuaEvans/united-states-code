{"tag":"section","attrib":{"id":"idc0786639-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19055"},"text":null,"children":[{"tag":"num","attrib":{"value":"19055"},"text":"§ 19055.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Social, behavioral, and economic sciences","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Director shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc078663a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19055/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" actively communicate opportunities and solicit proposals for social, behavioral, and economic science researchers to participate in cross-cutting and interdisciplinary programs, including the Convergence Accelerator and agency priority activities, and the Mid-Scale Research Infrastructure program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc078663b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19055/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure social, behavioral, and economic science researchers are represented on relevant merit review panels for such activities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc078663c-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/tIII/s10346"},"text":"Pub. L. 117–167, div. B, title III, § 10346","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1560"},"text":"136 Stat. 1560","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
