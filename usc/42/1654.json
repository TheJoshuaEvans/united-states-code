{"tag":"section","attrib":{"id":"idbb411a05-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1654"},"text":null,"children":[{"tag":"num","attrib":{"value":"1654"},"text":"§ 1654.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Persons excluded from benefits","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"This chapter shall not apply in respect to the injury or death of (1) an employee subject to the provisions of subchapter I of chapter 81 of title 5; (2) an employee engaged in agriculture, domestic service, or any employment that is casual and not in the usual course of the trade, business, or profession of the employer; and (3) a master or member of a crew of any vessel.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbb411a06-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1941-08-16/ch357/s4"},"text":"Aug. 16, 1941, ch. 357, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/55/623"},"text":"55 Stat. 623","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbb411a07-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbb411a08-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbb411a09-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Subchapter I of chapter 81 of title 5” substituted for reference to act ","children":[{"tag":"date","attrib":{"date":"1916-09-07"},"text":"Sept. 7, 1916","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/39/742"},"text":"39 Stat. 742","children":[],"tail":"), known as the Federal Employees’ Compensation Act, on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/89/554/s7/b"},"text":"Pub. L. 89–554, § 7(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/631"},"text":"80 Stat. 631","children":[],"tail":", the first section of which enacted Title 5, Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
