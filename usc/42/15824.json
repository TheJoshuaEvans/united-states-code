{"tag":"section","attrib":{"id":"idbfe48b40-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15824"},"text":null,"children":[{"tag":"num","attrib":{"value":"15824"},"text":"§ 15824.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State Technologies Advancement Collaborative","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfe48b41-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15824/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in cooperation with the States, shall establish a cooperative program for research, development, demonstration, and deployment of technologies in which there is a common Federal and State energy efficiency, renewable energy, and fossil energy interest, to be known as the “State Technologies Advancement Collaborative” (referred to in this section as the “Collaborative”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfe48b42-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15824/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Collaborative shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfe48b43-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15824/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" leverage Federal and State funding through cost-shared activity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe48b44-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15824/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reduce redundancies in Federal and State funding; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe48b45-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15824/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" create multistate projects to be awarded through a competitive process.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfe48b46-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15824/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Collaborative shall be administered through an agreement between the Department and appropriate State-based organizations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfe48b47-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15824/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding sources","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Funding for the Collaborative may be provided from—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfe48b48-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15824/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" amounts specifically appropriated for the Collaborative; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe48b49-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15824/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" amounts that may be allocated from other appropriations without changing the purpose for which the amounts are appropriated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfe48b4a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15824/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to carry out this section such sums as are necessary for each of fiscal years 2006 through 2010.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfe48b4b-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tI/s127"},"text":"Pub. L. 109–58, title I, § 127","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/619"},"text":"119 Stat. 619","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
