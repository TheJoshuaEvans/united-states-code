{"tag":"section","attrib":{"id":"idbfdb1588-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15026"},"text":null,"children":[{"tag":"num","attrib":{"value":"15026"},"text":"§ 15026.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal and non-Federal share","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfdb1589-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15026/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Aggregate cost","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfdb158a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15026/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraphs (2) and (3), the Federal share of the cost of all projects in a State supported by an allotment to the State under this part may not be more than 75 percent of the aggregate necessary cost of such projects, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfdb158b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15026/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Urban or rural poverty areas","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of projects whose activities or products target individuals with developmental disabilities who live in urban or rural poverty areas, as determined by the Secretary, the Federal share of the cost of all such projects may not be more than 90 percent of the aggregate necessary cost of such projects, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfdb158c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15026/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State plan activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of projects undertaken by the Council or Council staff to implement State plan activities, the Federal share of the cost of all such projects may be not more than 100 percent of the aggregate necessary cost of such activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfdb158d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15026/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonduplication","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In determining the amount of any State’s Federal share of the cost of such projects incurred by such State under a State plan approved under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s15024"},"text":"section 15024 of this title","children":[],"tail":", the Secretary shall not consider—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfdb158e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15026/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any portion of such cost that is financed by Federal funds provided under any provision of law other than ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s15022"},"text":"section 15022 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfdb158f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15026/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of any non-Federal funds required to be expended as a condition of receipt of the Federal funds described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfdb1590-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15026/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-Federal share","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfdb1591-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15026/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In-kind contributions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The non-Federal share of the cost of any project supported by an allotment under this part may be provided in cash or in kind, fairly evaluated, including plant, equipment, or services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfdb1592-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15026/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contributions of political subdivisions and public or private entities","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfdb1593-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15026/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Contributions to projects by a political subdivision of a State or by a public or private entity under an agreement with the State shall, subject to such limitations and conditions as the Secretary may by regulation prescribe under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s15004/b"},"text":"section 15004(b) of this title","children":[],"tail":", be considered to be contributions by such State, in the case of a project supported under this part."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfdb1594-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15026/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State contributions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"State contributions, including contributions by the designated State agency to provide support services to the Council pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s15025/d/4"},"text":"section 15025(d)(4) of this title","children":[],"tail":", may be counted as part of such State’s non-Federal share of the cost of projects supported under this part."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfdb1595-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15026/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Variations of the non-Federal share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The non-Federal share required of each recipient of a grant from a Council under this part may vary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfdb1596-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/402/tI/s126"},"text":"Pub. L. 106–402, title I, § 126","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1710"},"text":"114 Stat. 1710","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
