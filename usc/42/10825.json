{"tag":"section","attrib":{"id":"idbf31b57c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10825"},"text":null,"children":[{"tag":"num","attrib":{"value":"10825"},"text":"§ 10825.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary shall use not more than 2 percent of the amounts appropriated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s10827"},"text":"section 10827 of this title","children":[],"tail":" to provide technical assistance to eligible systems with respect to activities carried out under this subchapter, consistent with requests by such systems for such assistance."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbf31b57d-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/319/tI/s115"},"text":"Pub. L. 99–319, title I, § 115","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-05-23"},"text":"May 23, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/484"},"text":"100 Stat. 484","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/509/s7/b/2"},"text":"Pub. L. 100–509, § 7(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-20"},"text":"Oct. 20, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2545"},"text":"102 Stat. 2545","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf31b57e-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf31b57f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbf31b580-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/509"},"text":"Pub. L. 100–509","children":[],"tail":" amended section generally. Prior to amendment, section read as follows: “The Secretary shall provide technical assistance to eligible systems with respect to activities carried out under this subchapter.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
