{"tag":"section","attrib":{"id":"idbd01680a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5106f"},"text":null,"children":[{"tag":"num","attrib":{"value":"5106f"},"text":"§ 5106f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd01680b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5106f/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination efforts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2010-12-20"},"text":"December 20, 2010","children":[],"tail":", the Secretary shall submit to the Committee on Education and Labor of the House of Representatives and the Committee on Health, Education, Labor, and Pensions of the Senate a report on efforts to coordinate the objectives and activities of agencies and organizations that are responsible for programs and activities related to child abuse and neglect. Not later than 3 years after "},{"tag":"date","attrib":{"date":"2010-12-20"},"text":"December 20, 2010","children":[],"tail":", the Secretary shall submit to those committees a second report on such efforts during the 3-year period following "},{"tag":"date","attrib":{"date":"2010-12-20"},"text":"December 20, 2010","children":[],"tail":". Not later than 5 years after "},{"tag":"date","attrib":{"date":"2010-12-20"},"text":"December 20, 2010","children":[],"tail":", the Secretary shall submit to those committees a third report on such efforts during the 5-year period following "},{"tag":"date","attrib":{"date":"2010-12-20"},"text":"December 20, 2010","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd01680c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5106f/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effectiveness of State programs and technical assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2010-12-20"},"text":"December 20, 2010","children":[],"tail":", and every 2 years thereafter, the Secretary shall submit to the Committee on Education and Labor of the House of Representatives and the Committee on Health, Education, Labor, and Pensions of the Senate a report evaluating the effectiveness of programs receiving assistance under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5106a"},"text":"section 5106a of this title","children":[],"tail":" in achieving the objectives of "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5106a"},"text":"section 5106a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd01680d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5106f/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study and report relating to citizen review panels","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd01680e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5106f/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall conduct a study to determine the effectiveness of citizen review panels, established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5106a/c"},"text":"section 5106a(c) of this title","children":[],"tail":", in achieving the stated function of such panels under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5106a/c/4/A"},"text":"section 5106a(c)(4)(A) of this title","children":[],"tail":" of—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd01680f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5106f/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" examining the policies, procedures, and practices of State and local child protection agencies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd016810-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5106f/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluating the extent to which such State and local child protection agencies are fulfilling their child protection responsibilities, as described in clauses (i) through (iii) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5106a/c/4/A"},"text":"section 5106a(c)(4)(A) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd016811-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5106f/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Content of study","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The study described in paragraph (1) shall be completed in a manner suited to the unique design of citizen review panels, including consideration of the variability among the panels within and between States. The study shall include the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd016812-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5106f/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Data describing the membership, organizational structure, operation, and administration of all citizen review panels and the total number of such panels in each State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd016813-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5106f/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A detailed summary of the extent to which collaboration and information-sharing occurs between citizen review panels and State child protective services agencies or any other entities or State agencies. The summary shall include a description of the outcomes that result from collaboration and information sharing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd016814-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5106f/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Evidence of the adherence and responsiveness to the reporting requirements under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5106a/c/6"},"text":"section 5106a(c)(6) of this title","children":[],"tail":" by citizen review panels and States."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd016815-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5106f/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2010-12-20"},"text":"December 20, 2010","children":[],"tail":", the Secretary shall submit to the Committee on Health, Education, Labor, and Pensions of the Senate and the Committee on Education and Labor of the House of Representatives a report that contains the results of the study conducted under paragraph (1)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd016816-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5106f/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study and report relating to immunity from prosecution for professional consultation in suspected and known instances of child abuse and neglect","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd016817-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5106f/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall complete a study, in consultation with experts in the provision of healthcare, law enforcement, education, and local child welfare administration, that examines how provisions for immunity from prosecution under State and local laws and regulations facilitate and inhibit individuals cooperating, consulting, or assisting in making good faith reports, including mandatory reports, of suspected or known instances of child abuse or neglect.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd016818-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5106f/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2010-12-20"},"text":"December 20, 2010","children":[],"tail":", the Secretary shall submit to the Committee on Health, Education, Labor, and Pensions of the Senate and the Committee on Education and Labor of the House of Representatives a report that contains the results of the study conducted under paragraph (1) and any recommendations for statutory or regulatory changes the Secretary determines appropriate. Such report may be submitted electronically."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd016819-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/247/tI/s110"},"text":"Pub. L. 93–247, title I, § 110","children":[],"tail":", formerly § 13, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/294/tI/s101"},"text":"Pub. L. 100–294, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-04-25"},"text":"Apr. 25, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/116"},"text":"102 Stat. 116","children":[],"tail":"; renumbered title I, § 112, and amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/126/s3/a/1"},"text":"Pub. L. 101–126, § 3(a)(1)","children":[],"tail":", (2), (b)(6), "},{"tag":"date","attrib":{"date":"1989-10-25"},"text":"Oct. 25, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/764"},"text":"103 Stat. 764","children":[],"tail":", 765; renumbered § 110 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/235/tI/s113/a/1/B"},"text":"Pub. L. 104–235, title I, § 113(a)(1)(B)","children":[],"tail":", (3), "},{"tag":"date","attrib":{"date":"1996-10-03"},"text":"Oct. 3, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3079"},"text":"110 Stat. 3079","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/36/tI/s118"},"text":"Pub. L. 108–36, title I, § 118","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-06-25"},"text":"June 25, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/813"},"text":"117 Stat. 813","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/320/tI/s118"},"text":"Pub. L. 111–320, title I, § 118","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-20"},"text":"Dec. 20, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3475"},"text":"124 Stat. 3475","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd01681a-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd01681b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbd01681c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/247/s110"},"text":"section 110 of Pub. L. 93–247","children":[],"tail":" was renumbered section 108 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5106d"},"text":"section 5106d of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd01681d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/320/s118/a"},"text":"Pub. L. 111–320, § 118(a)","children":[],"tail":", added subsec. (a) and struck out former subsec. (a) which required the Secretary to submit to the appropriate committees of Congress a biennial report on efforts to coordinate the objectives and activities of agencies and organizations which are responsible for programs and activities related to child abuse and neglect."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/320/s118/a"},"text":"Pub. L. 111–320, § 118(a)","children":[],"tail":", added subsec. (b) and struck out former subsec. (b). Prior to amendment, text read as follows: “Not later than two years after the first fiscal year for which funds are obligated under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s10603a"},"text":"section 10603a of this title","children":[],"tail":", the Secretary shall submit to the appropriate committees of Congress a report evaluating the effectiveness of assisted programs in achieving the objectives of "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5106c"},"text":"section 5106c of this title","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/320/s118/b"},"text":"Pub. L. 111–320, § 118(b)","children":[],"tail":", amended subsec. (c) generally. Prior to amendment, text read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) ","children":[{"tag":"inline","attrib":{},"text":"Study","children":[],"tail":".—The Secretary shall conduct a study by random sample of the effectiveness of the citizen review panels established under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5106a/c"},"text":"section 5106a(c) of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) ","children":[{"tag":"inline","attrib":{},"text":"Report","children":[],"tail":".—Not later than 3 years after "},{"tag":"date","attrib":{"date":"2003-06-25"},"text":"June 25, 2003","children":[],"tail":", the Secretary shall submit to the Committee on Education and the Workforce of the House of Representatives and the Committee on Health, Education, Labor, and Pensions of the Senate a report that contains the results of the study conducted under paragraph (1).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/320/s118/c"},"text":"Pub. L. 111–320, § 118(c)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/36"},"text":"Pub. L. 108–36","children":[],"tail":" added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/235"},"text":"Pub. L. 104–235","children":[],"tail":" substituted “effectiveness of assisted programs in achieving the objectives of "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5106c"},"text":"section 5106c of this title","children":[],"tail":"” for “effectiveness of—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) assisted programs in achieving the objectives of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5106c"},"text":"section 5106c of this title","children":[],"tail":"; and"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) the technical assistance provided under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5106b"},"text":"section 5106b of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/126/s3/b/6"},"text":"Pub. L. 101–126, § 3(b)(6)","children":[],"tail":", made technical amendments to references to sections 5106b and 5106c of this title to reflect renumbering of corresponding sections of original act."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbd03b20e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idbd03b20f-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Education and Labor of House of Representatives changed to Committee on Education and the Workforce of House of Representatives by House Resolution No. 5, One Hundred Eighteenth Congress, ","children":[{"tag":"date","attrib":{"date":"2023-01-09"},"text":"Jan. 9, 2023","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
