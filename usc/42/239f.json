{"tag":"section","attrib":{"id":"idb4879aed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s239f"},"text":null,"children":[{"tag":"num","attrib":{"value":"239f"},"text":"§ 239f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb4879aee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s239f/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration by agreement with other agency or agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may administer any or all of the provisions of this part through Memorandum of Agreement with the head of any appropriate Federal agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4879aef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s239f/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The head of the agency administering this part or provisions thereof (including any agency head administering such Act ","children":[{"tag":"ref","attrib":{"idref":"fn002025"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002025"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “part”."}],"tail":" or provisions through a Memorandum of Agreement under subsection (a)) may promulgate such implementing regulations as may be found necessary and appropriate. Initial implementing regulations may be interim final regulations."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb4879af0-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title II, § 267, as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/20/s2"},"text":"Pub. L. 108–20, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-04-30"},"text":"Apr. 30, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/645"},"text":"117 Stat. 645","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
