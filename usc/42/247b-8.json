{"tag":"section","attrib":{"id":"idb4a8df0a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–8"},"text":null,"children":[{"tag":"num","attrib":{"value":"247b–8"},"text":"§ 247b–8.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fellowship and training programs","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Director of the Centers for Disease Control and Prevention, shall establish fellowship and training programs to be conducted by such Centers to train individuals to develop skills in epidemiology, surveillance, laboratory analysis, and other disease detection and prevention methods. Such programs shall be designed to enable health professionals and health personnel trained under such programs to work, after receiving such training, in local, State, national, and international efforts toward the prevention and control of diseases, injuries, and disabilities. Such fellowships and training may be administered through the use of either appointment or nonappointment procedures.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb4a8df0b-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title III, § 317G, as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/115/tIV/s408/b/1"},"text":"Pub. L. 105–115, title IV, § 408(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-21"},"text":"Nov. 21, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2371"},"text":"111 Stat. 2371","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb4a8df0c-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb4a8df0d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb4a8df0e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/115/tIV/s408/b/2"},"text":"Pub. L. 105–115, title IV, § 408(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-21"},"text":"Nov. 21, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2371"},"text":"111 Stat. 2371","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/115/tIV/s408/b/2"},"text":"“The amendment made by this subsection [enacting this section] is deemed to have taken effect ","children":[{"tag":"date","attrib":{"date":"1995-07-01"},"text":"July 1, 1995","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
