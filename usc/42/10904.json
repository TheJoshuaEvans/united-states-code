{"tag":"section","attrib":{"id":"idbf3425fd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10904"},"text":null,"children":[{"tag":"num","attrib":{"value":"10904"},"text":"§ 10904.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report by States; contents; manner of payments pursuant to grants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf3425fe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10904/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each State receiving grants under this chapter shall annually submit to the Secretary information on the number of eligible individuals assisted under the grant program, and their positions and salaries before and after receiving the Child Development Associate credential.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf3425ff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10904/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Payments pursuant to grants made under this chapter may be made in installments, and in advance or by way of reimbursement, with necessary adjustments on account of overpayments or underpayments, as the Secretary may determine.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf342600-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/425/tVI/s605"},"text":"Pub. L. 99–425, title VI, § 605","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-09-30"},"text":"Sept. 