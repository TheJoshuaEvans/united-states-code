{"tag":"section","attrib":{"id":"idb6cafbdc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–10a"},"text":null,"children":[{"tag":"num","attrib":{"value":"300hh–10a"},"text":"§ 300hh–10a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public Health Emergency Medical Countermeasures Enterprise","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb6cafbdd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–10a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish the Public Health Emergency Medical Countermeasures Enterprise (referred to in this section as the “PHEMCE”). The Assistant Secretary for Preparedness and Response and the Director of the Office of Pandemic Preparedness and Response Policy shall serve as co-chairs of the PHEMCE.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6cafbde-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–10a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Members","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The PHEMCE shall include each of the following members, or the designee of such members:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6cafbdf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–10a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Assistant Secretary for Preparedness and Response.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6cafbe0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–10a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of the Centers for Disease Control and Prevention.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6cafbe1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–10a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of the National Institutes of Health.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6cafbe2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–10a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Commissioner of Food and Drugs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6cafbe3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–10a/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6cafbe4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–10a/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Homeland Security.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6cafbe5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–10a/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6cafbe6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–10a/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Veterans Affairs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6cafbe7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–10a/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of National Intelligence.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6cafbe8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–10a/b/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of the Office of Pandemic Preparedness and Response Policy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6cafbe9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–10a/b/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Representatives of any other Federal agency, which may include the Director of the Biomedical Advanced Research and Development Authority, the Director of the Strategic National Stockpile, the Director of the National Institute of Allergy and Infectious Diseases, and the Director of the Office of Public Health Preparedness and Response, as the Secretary determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6cafbea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–10a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6cafbeb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–10a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The functions of the PHEMCE shall include the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6cafbec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–10a/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Utilize a process to make recommendations to the Secretary regarding research, advanced research, development, procurement, stockpiling, deployment, distribution, and utilization with respect to countermeasures, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s247d–6b/c"},"text":"section 247d–6b(c) of this title","children":[],"tail":", including prioritization based on the health security needs of the United States. Such recommendations shall be informed by, when available and practicable, the National Health Security Strategy pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300hh–1"},"text":"section 300hh–1 of this title","children":[],"tail":", the Strategic National Stockpile needs pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s247d–6b"},"text":"section 247d–6b of this title","children":[],"tail":", and assessments of current national security threats, including chemical, biological, radiological, and nuclear threats, including emerging infectious diseases. In the event that members of the PHEMCE do not agree upon a recommendation, the Secretary shall provide a determination regarding such recommendation."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6cafbed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–10a/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Identify national health security needs, including gaps in public health preparedness and response related to countermeasures and challenges to addressing such needs (including any regulatory challenges), and support alignment of countermeasure procurement with recommendations to address such needs under subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6cd6bee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–10a/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Assist the Secretary in developing strategies related to logistics, deployment, distribution, dispensing, and use of countermeasures that may be applicable to the activities of the strategic national stockpile under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s247d–6b/a"},"text":"section 247d–6b(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6cd6bef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–10a/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Provide consultation for the development of the strategy and implementation plan under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300hh–10/d"},"text":"section 300hh–10(d) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6cd6bf0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–10a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Input","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out subparagraphs (B) and (C) of paragraph (1), the PHEMCE shall solicit and consider input from State, local, Tribal, and territorial public health departments or officials, as appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb6cd6bf1-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XXVIII, § 2811–1, as added "},{"tag":"ref","attrib":{"href":"/us/pl/116/22/tIV/s402/a"},"text":"Pub. L. 116–22, title IV, § 402(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-06-24"},"text":"June 24, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/942"},"text":"133 Stat. 942","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dFF/tII/s2104/k/1"},"text":"Pub. L. 117–328, div. FF, title II, § 2104(k)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5719"},"text":"136 Stat. 5719","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb6cd6bf2-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb6cd6bf3-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb6cd6bf4-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 300hh–10a, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373/tXXVIII/s2811A"},"text":"act July 1, 1944, ch. 373, title XXVIII, § 2811A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/113/5/tI/s103"},"text":"Pub. L. 113–5, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-03-13"},"text":"Mar. 13, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/168"},"text":"127 Stat. 168","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/22/tIII/s305/a"},"text":"Pub. L. 116–22, title III, § 305(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-06-24"},"text":"June 24, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/936"},"text":"133 Stat. 936","children":[],"tail":", which related to the National Advisory Committee on Children and Disasters, was transferred to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300hh–10b"},"text":"section 300hh–10b of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb6cd6bf5-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s2104/k/1/A"},"text":"Pub. L. 117–328, § 2104(k)(1)(A)","children":[],"tail":", substituted “and the Director of the Office of Pandemic Preparedness and Response Policy shall serve as co-chairs” for “shall serve as chair”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(10), (11). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s2104/k/1/B"},"text":"Pub. L. 117–328, § 2104(k)(1)(B)","children":[],"tail":", added par. (10) and redesignated former par. (10) as (11)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
