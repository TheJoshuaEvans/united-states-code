–33, title V, § 5592(a)(1)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/644"},"text":"111 Stat. 644","children":[],"tail":", related to reallotment, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/109/288"},"text":"Pub. L. 109–288","children":[],"tail":", §§ 6(b)(1), 12(a), "},{"tag":"date","attrib":{"date":"2006-09-28"},"text":"Sept. 28, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1244"},"text":"120 Stat. 1244","children":[],"tail":", 1255, effective "},{"tag":"date","attrib":{"date":"2006-10-01"},"text":"Oct. 1, 2006","children":[],"tail":", and applicable to payments under this part and part E of this subchapter for calendar quarters beginning on or after such date. See "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s623/e"},"text":"section 623(e) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb79ca3d5-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/258"},"text":"Pub. L. 118–258","children":[],"tail":" struck out par. (1)(A) designation before “Each State” and struck out pars. (1)(B) and (2) which related to reduction in allotment of funds to a State for failure to comply with child visitation requirements."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—Subsecs. (e), (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/34"},"text":"Pub. L. 112–34","children":[],"tail":" added subsec. (f) and struck out subsec. (e) relating to caseworker visitation standard."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/288/s11/a/2"},"text":"Pub. L. 109–288, § 11(a)(2)","children":[],"tail":", substituted “percent” for “per centum”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/288/s6/e/1"},"text":"Pub. L. 109–288, § 6(e)(1)","children":[],"tail":", added subsecs. (c) and (d) struck out former subsecs. (c) and (d) which related to prohibited payments and minimum State expenditures, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/288/s7/b"},"text":"Pub. L. 109–288, § 7(b)","children":[],"tail":", added subsec. (e) relating to caseworker visitation standard."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/288/s6/e/2/A"},"text":"Pub. L. 109–288, § 6(e)(2)(A)","children":[],"tail":", added subsec. (e) relating to limitation on reimbursement for administrative costs."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/432"},"text":"Pub. L. 103–432","children":[],"tail":" struck out “and in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s627"},"text":"section 627 of this title","children":[],"tail":"” after “set forth in this section”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/66"},"text":"Pub. L. 103–66","children":[],"tail":" substituted “under this subpart” for “under this part”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/272"},"text":"Pub. L. 96–272","children":[],"tail":" substituted provisions covering payments to States for provisions relating to allotment percentages and Federal share."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/273"},"text":"Pub. L. 94–273","children":[],"tail":" substituted “October” for “July” wherever appearing and “November 30” for “August 31”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb79ca3d6-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb79ca3d7-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2025 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/258"},"text":"Pub. L. 118–258","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2025-10-01"},"text":"Oct. 1, 2025","children":[],"tail":", and applicable to payments under this part for calendar quarters beginning on or after such date, with delay permitted if either State legislation or tribal action is required to meet additional requirements, see "},{"tag":"ref","attrib":{"href":"/us/pl/118/258/s117"},"text":"section 117 of Pub. L. 118–258","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s622"},"text":"section 622 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb79ca3d8-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2011 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/34"},"text":"Pub. L. 112–34","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2011-10-01"},"text":"Oct. 1, 2011","children":[],"tail":", and applicable to payments under this part and part E of this subchapter for calendar quarters beginning on or after such date, without regard to whether implementing regulations have been promulgated, and with delay permitted if State legislation is required to meet additional requirements, see "},{"tag":"ref","attrib":{"href":"/us/pl/112/34/s107"},"text":"section 107 of Pub. L. 112–34","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s622"},"text":"section 622 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb79ca3d9-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2006 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/288/s6/e/2/B"},"text":"Pub. L. 109–288, § 6(e)(2)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-09-28"},"text":"Sept. 28, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1247"},"text":"120 Stat. 1247","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/288/s6/e/2/B"},"text":"“The amendment made by subparagraph (A) [amending this section] shall apply to expenditures made on or after ","children":[{"tag":"date","attrib":{"date":"2007-10-01"},"text":"October 1, 2007","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/288"},"text":"Pub. L. 109–288","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2006-10-01"},"text":"Oct. 1, 2006","children":[],"tail":", except as otherwise provided, and applicable to payments under this part and part E of this subchapter for calendar quarters beginning on or after such date, without regard to whether implementing regulations have been promulgated, and with delay permitted if State legislation is required to meet additional requirements, see section 12(a), (b) of "},{"tag":"ref","attrib":{"href":"/us/pl/109/288"},"text":"Pub. L. 109–288","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s621"},"text":"section 621 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb79ca3da-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/432"},"text":"Pub. L. 103–432","children":[],"tail":" effective with respect to fiscal years beginning on or after "},{"tag":"date","attrib":{"date":"1996-04-01"},"text":"Apr. 1, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/432/s202/e"},"text":"section 202(e) of Pub. L. 103–432","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s622"},"text":"section 622 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb79ca3db-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1993 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/66"},"text":"Pub. L. 103–66","children":[],"tail":" effective with respect to calendar quarters beginning on or after "},{"tag":"date","attrib":{"date":"1993-10-01"},"text":"Oct. 1, 1993","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/66/s13711/c"},"text":"section 13711(c) of Pub. L. 103–66","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s622"},"text":"section 622 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
