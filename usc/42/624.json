{"tag":"section","attrib":{"id":"idb79ca3c7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s624"},"text":null,"children":[{"tag":"num","attrib":{"value":"624"},"text":"§ 624.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment to States","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb79ca3c8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s624/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment schedule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"From the sums appropriated therefor and the allotment under this subpart, subject to the conditions set forth in this section, the Secretary shall from time to time pay to each State that has a plan developed in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s622"},"text":"section 622 of this title","children":[],"tail":" an amount equal to 75 percent of the total sum expended under the plan (including the cost of administration of the plan) in meeting the costs of State, district, county, or other local child welfare services."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb79ca3c9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s624/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Computation and method of payment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The method of computing and making payments under this section shall be as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb79ca3ca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s624/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall, prior to the beginning of each period for which a payment is to be made, estimate the amount to be paid to the State for such period under the provisions of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb79ca3cb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s624/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" From the allotment available therefor, the Secretary shall pay the amount so estimated, reduced or increased, as the case may be, by any sum (not previously adjusted under this section) by which he finds that his estimate of the amount to be paid the State for any prior period under this section was greater or less than the amount which should have been paid to the State for such prior period under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb79ca3cc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s624/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on use of Federal funds for child care, foster care maintenance payments, or adoption assistance payments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The total amount of Federal payments under this subpart for a fiscal year beginning after ","children":[{"tag":"date","attrib":{"date":"2007-09-30"},"text":"September 30, 2007","children":[],"tail":", that may be used by a State for expenditures for child care, foster care maintenance payments, or adoption assistance payments shall not exceed the total amount of such payments for fiscal year 2005 that were so used by the State."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb79ca3cd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s624/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on use by States of non-Federal funds for foster care maintenance payments to match Federal funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For any fiscal year beginning after ","children":[{"tag":"date","attrib":{"date":"2007-09-30"},"text":"September 30, 2007","children":[],"tail":", State expenditures of non-Federal funds for foster care maintenance payments shall not be considered to be expenditures under the State plan developed under this subpart for the fiscal year to the extent that the total of such expenditures for the fiscal year exceeds the total of such expenditures under the State plan developed under this subpart for fiscal year 2005."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb79ca3ce-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s624/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on reimbursement for administrative costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A payment may not be made to a State under this section with respect to expenditures during a fiscal year for administrative costs, to the extent that the total amount of the expenditures exceeds 10 percent of the total expenditures of the State during the fiscal year for activities funded from amounts provided under this subpart.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb79ca3cf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s624/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Child visitation by caseworkers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each State shall take such steps as are necessary to ensure that the total number of visits made by caseworkers on a monthly basis to children in foster care under the responsibility of the State during a fiscal year is not less than 90 percent (or, in the case of fiscal year 2015 or thereafter, 95 percent) of the total number of such visits that would occur during the fiscal year if each such child were so visited once every month while in such care.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb79ca3d0-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title IV, § 424, formerly § 423, as added "},{"tag":"ref","attrib":{"href":"/us/pl/90/248/tII/s240/c"},"text":"Pub. L. 90–248, title II, § 240(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-01-02"},"text":"Jan. 2, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/913"},"text":"81 Stat. 913","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/273/s22"},"text":"Pub. L. 94–273, § 22","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-04-21"},"text":"Apr. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/379"},"text":"90 Stat. 379","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/272/tI/s103/a"},"text":"Pub. L. 96–272, title I, § 103(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-06-17"},"text":"June 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/518"},"text":"94 Stat. 518","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/66/tXIII/s13711/b/2"},"text":"Pub. L. 103–66, title XIII, § 13711(b)(2)","children":[],"tail":", "},{"tag":"da