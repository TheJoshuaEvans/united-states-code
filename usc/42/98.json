{"tag":"section","attrib":{"id":"idb4091bd1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s98"},"text":null,"children":[{"tag":"num","attrib":{"value":"98"},"text":"§ 98.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vessels for quarantine officers","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Navy is authorized, in his discretion, at the request of the Secretary of Health and Human Services, to place gratuitously, at the disposal of the proper quarantine authorities, at any of the ports of the United States, to be used temporarily for quarantine purposes, such vessels or hulks belonging to the United States as are not required for other uses of the national government, subject to such restrictions and regulations as the Secretary of the Navy may deem necessary to impose for the preservation thereof.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb4091bd2-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"date","attrib":{"date":"1879-06-14"},"text":"June 14, 1879","children":[],"tail":", No. 6, "},{"tag":"ref","attrib":{"href":"/us/stat/21/50"},"text":"21 Stat. 50","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1893-02-15/ch114"},"text":"Feb. 15, 1893, ch. 114","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/27/449"},"text":"27 Stat. 449","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1902-07-01/ch1370/s1"},"text":"July 1, 1902, ch. 1370, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/32/712"},"text":"32 Stat. 712","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1912-08-14/ch288/s1"},"text":"Aug. 14, 1912, ch. 288, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/37/309"},"text":"37 Stat. 309","children":[],"tail":"; 1939 Reorg. Plan No. I, § 201, eff. "},{"tag":"date","attrib":{"date":"