{"tag":"section","attrib":{"id":"idb495cbe4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s242r"},"text":null,"children":[{"tag":"num","attrib":{"value":"242r"},"text":"§ 242r.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Improvement and publication of data on food-related allergic responses","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb495cbe5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s242r/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Health and Human Services, acting through the Director of the Centers for Disease Control and Prevention and in consultation with the Commissioner of Food and Drugs, shall improve (including by educating physicians and other health care providers) the collection of, and publish as it becomes available, national data on—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb495cbe6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s242r/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the prevalence of food allergies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb495cbe7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s242r/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the incidence of clinically significant or serious adverse events related to food allergies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb495cbe8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s242r/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use of different modes of treatment for and prevention of allergic responses to foods.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb495cbe9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s242r/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of carrying out this section, there are authorized to be appropriated such sums as may be necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb495cbea-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/282/tII/s207"},"text":"Pub. L. 108–282, title II, § 207","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-08-02"},"text":"Aug. 2, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/910"},"text":"118 Stat. 910","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb495cbeb-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb495cbec-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb495cbed-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Food Allergen Labeling and Consumer Protection Act of 2004, and not as part of the Public Health Service Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
