{"tag":"section","attrib":{"id":"idbfa1b544-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12783"},"text":null,"children":[{"tag":"num","attrib":{"value":"12783"},"text":"§ 12783.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conditions of contracts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfa1b545-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12783/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible organizations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall carry out this part insofar as is practicable through contract with—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfa1b546-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12783/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a participating jurisdiction or agency thereof;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfa1b547-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12783/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a public purpose organization established pursuant to State or local legislation and responsible to the chief elected official of a participating jurisdiction;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfa1b548-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12783/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an agency or authority established by two or more participating jurisdictions to carry out activities consistent with the purposes of this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfa1b549-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12783/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a national or regional nonprofit organization that has a membership comprised predominantly of entities or officials of entities that qualify under paragraph (1), (2), or (3); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfa1b54a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12783/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a professional and technical services company or firm that has demonstrated capacity to provide services under this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfa1b54b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12783/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contract terms","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Contracts under this part shall be for not more than 3 years and shall provide not more than 20 percent of the operating budget of the contracting organization in any one year. Within any fiscal year, contracts with any one organization may not be entered into for a total of more than 40 percent of the funds appropriated under this part in that fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfa1b54c-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/625/tII/s243"},"text":"Pub. L. 101–625, title II, § 243","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4118"},"text":"104 Stat. 4118","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/8/dI/tII/s229/3"},"text":"Pub. L. 111–8, div. I, title II, § 229(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-03-11"},"text":"Mar. 11, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/978"},"text":"123 Stat. 978","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbfa1b54d-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbfa1b54e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbfa1b54f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2009—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/8"},"text":"Pub. L. 111–8","children":[],"tail":" substituted “40 percent of the funds” for “20 percent of the funds”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
