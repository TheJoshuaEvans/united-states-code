{"tag":"section","attrib":{"id":"idbf82bbe0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12619"},"text":null,"children":[{"tag":"num","attrib":{"value":"12619"},"text":"§ 12619.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative provisions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf82bbe1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12619/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supervision","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Chief Executive Officer shall monitor and supervise the administration of the National Civilian Community Corps Program authorized to be established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12612"},"text":"section 12612 of this title","children":[],"tail":". In carrying out this section, the Chief Executive Officer shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf82bbe2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12619/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" approve such guidelines, including those recommended by the Board, for the design, selection of members, and operation of the National Civilian Community Corps as the Chief Executive Officer considers appropriate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf82bbe3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12619/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluate the progress of the Corps in providing a basis for determining the matters set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12611"},"text":"section 12611 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf82bbe4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12619/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry out any other activities determined appropriate by the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf82bbe5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12619/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Monitoring and coordination","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Chief Executive Officer shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf82bbe6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12619/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" monitor the overall operation of the National Civilian Community Corps;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf82bbe7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12619/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate the activities of the Corps with other youth service programs administered by the Corporation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf82bbe8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12619/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry out any other activities determined appropriate by the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf82bbe9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12619/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Staff","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf82bbea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12619/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf82bbeb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12619/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon the establishment of the Program, the Chief Executive Officer shall appoint a Director. The Director may be selected from among retired commissioned officers of the Armed Forces of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf82bbec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12619/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbf82bbed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12619/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" design, develop, and administer the National Civilian Community Corps programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf82bbee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12619/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be responsible for managing the daily operations of the Corps; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf82bbef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12619/c/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" report to the Chief Executive Officer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf82bbf0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12619/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to employ staff","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director may employ such staff as is necessary to carry out this division. The Director shall, to the maximum extent practicable, utilize in staff positions personnel who are detailed from departments and agencies of the Federal Government and, to the extent the Director considers appropriate, shall request and accept detail of personnel from such departments and agencies in order to do so.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf82bbf1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12619/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Permanent cadre","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf82bbf2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12619/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Chief Executive Officer shall establish a permanent cadre that includes the Director and other appointed supervisors and training instructors for National Civilian Community Corps programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf82bbf3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12619/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Chief Executive Officer shall consider the recommendations of the Director in appointing the other members of the permanent cadre.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf82bbf4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12619/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employment considerations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In appointing individuals to cadre positions, the Chief Executive Officer shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbf82bbf5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12619/c/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" give consideration to retired, discharged, and other inactive members and former members of the Armed Forces recommended under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12622/b"},"text":"section 12622(b) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf82bbf6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12619/c/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" give consideration to former VISTA, Peace Corps, and youth service program personnel;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf82bbf7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12619/c/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that the cadre is comprised of males and females of diverse ethnic, economic, professional, and geographic backgrounds;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf82bbf8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12619/c/2/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" give consideration to retired and other former law enforcement, fire, rescue, and emergency personnel, and other individuals with backgrounds in disaster preparedness, relief, and recovery; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf82bbf9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12619/c/2/C/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consider applicants’ experience in other youth service programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf82bbfa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12619/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Community service credit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Service as a member of the cadre shall be considered as a community service opportunity for purposes of section 4403 of the National Defense Authorization Act for Fiscal Year 1993.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf82bbfb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12619/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall provide to other members of the permanent cadre appropriate training in youth development techniques, including techniques for working with and enhancing the development of disadvantaged youth, and the principles of service-learning. All members of the permanent cadre shall be required to participate in the training.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf82bbfc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12619/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inapplicability of certain civil service laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director, other members of the permanent cadre, and the other staff personnel shall be appointed without regard to the provisions of title 5 governing appointments in the competitive service. The rates of pay of such persons may be established without regard to the provisions of chapter 51 and subchapter III of chapter 53 of such title. In the case of a member of the permanent cadre who was recommended for appointment in accordance with 12622(b)(1) ","children":[{"tag":"ref","attrib":{"idref":"fn004070"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004070"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be preceded by “section”."}],"tail":" of this title and is entitled to retired or retainer pay, section 5532 "},{"tag":"ref","attrib":{"idref":"fn004071"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004071"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" See References in Text note below."}],"tail":" of title 5 shall not apply to reduce the member’s retired or retainer pay by reason of the member being paid as a member of the cadre."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf82bbfd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12619/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Voluntary services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, the Director may accept the voluntary services of individuals. While away from their homes or regular places of business on the business of the Corps, such individuals may be allowed travel expenses, including per diem in lieu of subsistence, in the same amounts and to the same extent, as authorized under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5703"},"text":"section 5703 of title 5","children":[],"tail":" for persons employed intermittently in Federal Government service."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf82bbfe-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/610/tI/s159"},"text":"Pub. L. 101–610, title I, § 159","children":[],"tail":", formerly § 195H, as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/484/dA/tX/s1092/a/1"},"text":"Pub. L. 102–484, div. A, title X, § 1092(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2528"},"text":"106 Stat. 2528","children":[],"tail":"; renumbered § 159 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/tI/s104/b"},"text":"Pub. L. 103–82, title I, § 104(b)","children":[],"tail":", (e)(2)(E), title IV, §§ 402(b)(1), 403(a)(1)–(3), (b), "},{"tag":"date","attrib":{"date":"1993-09-21"},"text":"Sept. 21, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/840"},"text":"107 Stat. 840","children":[],"tail":", 847, 918–920; "},{"tag":"ref","attrib":{"href":"/us/pl/103/304/s3/b/5/B"},"text":"Pub. L. 103–304, § 3(b)(5)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-08-23"},"text":"Aug. 23, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1567"},"text":"108 Stat. 1567","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tVI/s640"},"text":"Pub. L. 103–337, div. A, title VI, § 640","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2791"},"text":"108 Stat. 2791","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/13/tI/s1509"},"text":"Pub. L. 111–13, title I, § 1509","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-04-21"},"text":"Apr. 21, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1525"},"text":"123 Stat. 1525","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tV/s553/b/3"},"text":"Pub. L. 115–232, div. A, title V, § 553(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1772"},"text":"132 Stat. 1772","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf82bbff-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf82bc00-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbf82bc01-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 4403 of the National Defense Authorization Act for Fiscal Year 1993, referred to in subsec. (c)(2)(D), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/484/s4403"},"text":"section 4403 of Pub. L. 102–484","children":[],"tail":" which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1293"},"text":"section 1293 of Title 10","children":[],"tail":", Armed Forces."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5532"},"text":"Section 5532 of title 5","children":[],"tail":", referred to in subsec. (c)(3), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tVI/s651/a/1"},"text":"Pub. L. 106–65, div. A, title VI, § 651(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/664"},"text":"113 Stat. 664","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbf82bc02-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12653h"},"text":"section 12653h of this title","children":[],"tail":" prior to renumbering by "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/s104/b"},"text":"Pub. L. 103–82, § 104(b)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbf82bc03-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (c)(2)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" struck out “and as employment with a public service or community service organization for purposes of section 4464 of that Act” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2009—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1509/1/A"},"text":"Pub. L. 111–13, § 1509(1)(A)","children":[],"tail":", substituted “National Civilian Community Corps Program” for “Civilian Community Corps Demonstration Program” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1509/1/B"},"text":"Pub. L. 111–13, § 1509(1)(B)","children":[],"tail":", inserted “including those” before “recommended” and “National” before “Civilian Community Corps”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1509/2"},"text":"Pub. L. 111–13, § 1509(2)","children":[],"tail":", inserted “National” before “Civilian Community Corps”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(B)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1509/3/A"},"text":"Pub. L. 111–13, § 1509(3)(A)","children":[],"tail":", inserted “National” before “Civilian Community Corps”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1509/3/B/i"},"text":"Pub. L. 111–13, § 1509(3)(B)(i)","children":[],"tail":", substituted “The Chief Executive Officer shall establish a permanent cadre that includes the Director and other appointed” for “The Director shall establish a permanent cadre of” and inserted “National” before “Civilian Community Corps”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1509/3/B/ii"},"text":"Pub. L. 111–13, § 1509(3)(B)(ii)","children":[],"tail":", substituted “The Chief Executive Officer shall consider the recommendations of the Director in appointing the other members” for “The Director shall appoint the members”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1509/3/B/iii/I"},"text":"Pub. L. 111–13, § 1509(3)(B)(iii)(I)","children":[],"tail":", substituted “the Chief Executive Officer” for “the Director” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(C)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1509/3/B/iii/II"},"text":"Pub. L. 111–13, § 1509(3)(B)(iii)(II)","children":[],"tail":", substituted “section 12622(b)” for “section 12622(a)(2)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(C)(iv), (v). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1509/3/B/iii/III"},"text":"Pub. L. 111–13, § 1509(3)(B)(iii)(III)","children":[],"tail":"–(V), added cl. (iv) and redesignated former cl. (iv) as (v)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1509/3/B/iv"},"text":"Pub. L. 111–13, § 1509(3)(B)(iv)","children":[],"tail":", substituted “to other members” for “to members”, inserted “, including techniques for working with and enhancing the development of disadvantaged youth,” after “techniques”, and substituted “service-learning” for “service learning”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1509/3/C"},"text":"Pub. L. 111–13, § 1509(3)(C)","children":[],"tail":", substituted “other members” for “the members” and “12622(b)(1)” for “section 12622(a)(2)(A)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (c)(2)(C)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/304"},"text":"Pub. L. 103–304","children":[],"tail":" substituted “section 12622(a)(2)” for “section section 12622(a)(2)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337"},"text":"Pub. L. 103–337","children":[],"tail":" inserted at end “In the case of a member of the permanent cadre who was recommended for appointment in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12622/a/2/A"},"text":"section 12622(a)(2)(A) of this title","children":[],"tail":" and is entitled to retired or retainer pay, "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5532"},"text":"section 5532 of title 5","children":[],"tail":" shall not apply to reduce the member’s retired or retainer pay by reason of the member being paid as a member of the cadre.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/82/s403/a/1/A"},"text":"Pub. L. 103–82, § 403(a)(1)(A)","children":[],"tail":", (B), substituted “Supervision” for “Board” in heading and “The Chief Executive Officer shall monitor” for “The Board shall monitor” and “the Chief Executive Officer shall—” for “the Board shall—” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/82/s104/e/2/E/i/I"},"text":"Pub. L. 103–82, § 104(e)(2)(E)(i)(I)","children":[],"tail":", substituted “section 12612” for “section 12653a” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/82/s403/a/1/B"},"text":"Pub. L. 103–82, § 403(a)(1)(B)","children":[],"tail":", (C), substituted “by the Board” for “by the Director” and “as the Chief Executive Officer” for “as the Board”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/82/s104/e/2/E/i/II"},"text":"Pub. L. 103–82, § 104(e)(2)(E)(i)(II)","children":[],"tail":", substituted “section 12611” for “section 12653”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/82/s403/a/2"},"text":"Pub. L. 103–82, § 403(a)(2)","children":[],"tail":", substituted “Monitoring and coordination” for “Executive Director” in heading and “The Chief Executive Officer shall” for “The Executive Director of the Commission on National and Community Service shall” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/82/s402/b/1"},"text":"Pub. L. 103–82, § 402(b)(1)","children":[],"tail":", substituted “by the Corporation” for “by the Commission”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/82/s403/a/3/A"},"text":"Pub. L. 103–82, § 403(a)(3)(A)","children":[],"tail":", (b), substituted “the Chief Executive Officer shall appoint a Director” for “the Board, in consultation with the Executive Director, shall appoint a Director of the Civilian Community Corps”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(B)(iii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/82/s403/a/3/B"},"text":"Pub. L. 103–82, § 403(a)(3)(B)","children":[],"tail":", substituted “the Chief Executive Officer” for “the Board through the Executive Director”."}],"tail":"\n"},{"tag":"p","attrib":{},"text"