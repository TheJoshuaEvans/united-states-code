{"tag":"section","attrib":{"id":"idc05e2814-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18647"},"text":null,"children":[{"tag":"num","attrib":{"value":"18647"},"text":"§ 18647.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Science laboratories infrastructure program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc05e2815-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18647/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall carry out a program to improve the safety, efficiency, and mission readiness of infrastructure at laboratories of the Office of Science.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc05e2816-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18647/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The program under subsection (a) shall include projects—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc05e2817-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18647/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to renovate or replace space that does not meet research needs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc05e2818-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18647/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to replace facilities that are no longer cost effective to renovate or operate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc05e2819-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18647/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to modernize utility systems to prevent failures and ensure efficiency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc05e281a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18647/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to remove excess facilities to allow safe and efficient operations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc05e281b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18647/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to construct modern facilities to conduct advanced research in controlled environmental conditions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc05e281c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18647/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approach","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the program under subsection (a), the Director shall use all available approaches and mechanisms, as the Secretary determines to be appropriate, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc05e281d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18647/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" capital line items;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc05e281e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18647/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" minor construction projects;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc05e281f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18647/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" energy savings performance contracts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc05e2820-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18647/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" utility energy service contracts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc05e2821-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18647/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" alternative financing; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc05e2822-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18647/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expense funding.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc05e2823-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18647/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For each fiscal year through fiscal year 2027, at the same time as the annual budget submission of the President, the Secretary shall submit to the Committee on Appropriations and the Committee on Energy and Natural Resources of the Senate and the Committee on Appropriations and the Committee on Science, Space, and Technology of the House of Representatives a list of projects for which the Secretary will provide funding under this section, including a description of each project and the funding profile for the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc05e2824-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18647/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Out of funds authorized to be appropriated for the Office of Science in a fiscal year, there is authorized to be appropriated to the Secretary to carry out the activities described in this section $550,000,000 for each of fiscal years 2023 through 2027.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc05e2825-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/246/tIII/s309"},"text":"Pub. L. 115–246, title III, § 309","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-09-28"},"text":"Sept. 28, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3150"},"text":"132 Stat. 3150","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/tI/s10108"},"text":"Pub. L. 117–167, div. B, title I, § 10108","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1450"},"text":"136 Stat. 1450","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc05e2826-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc05e2827-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc05e2828-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsecs. (c) to (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167"},"text":"Pub. L. 117–167","children":[],"tail":" added subsecs. (c) to (e)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
