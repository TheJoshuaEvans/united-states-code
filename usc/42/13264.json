{"tag":"section","attrib":{"id":"idbfb73a3d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13264"},"text":null,"children":[{"tag":"num","attrib":{"value":"13264"},"text":"§ 13264.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to the Secretary for carrying out this subchapter $10,000,000 for each of the fiscal years 1993 through 1997, and such sums as may be necessary for fiscal years 1998 through 2000.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbfb73a3e-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/tV/s515"},"text":"Pub. L. 102–486, title V, § 515","children":[],"tail":", formerly § 514, "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2899"},"text":"106 Stat. 2899","children":[],"tail":"; renumbered § 515, "},{"tag":"ref","attrib":{"href":"/us/pl/109/58/tVII/s703/a/1"},"text":"Pub. L. 109–58, title VII, § 703(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/815"},"text":"119 Stat. 815","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
