{"tag":"section","attrib":{"id":"idb888b122-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395"},"text":null,"children":[{"tag":"num","attrib":{"value":"1395"},"text":"§ 1395.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition against any Federal interference","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing in this subchapter shall be construed to authorize any Federal officer or employee to exercise any supervision or control over the practice of medicine or the manner in which medical services are provided, or over the selection, tenure, or compensation of any officer or employee of any institution, agency, or person providing health services; or to exercise any supervision or control over the administration or operation of any such institution, agency, or person.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb888b123-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title XVIII, § 1801, as added "},{"tag":"ref","attrib":{"href":"/us/pl/89/97/tI/s102/a"},"text":"Pub. L. 89–97, title I, § 102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-07-30"},"text":"July 30, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/291"},"text":"79 Stat. 291","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb888b124-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb888b125-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"idb888b126-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For short title of title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/97"},"text":"Pub. L. 89–97","children":[],"tail":", which enacted this subchapter as the “Health Insurance for the Aged Act”, see "},{"tag":"ref","attrib":{"href":"/us/pl/89/97/s100"},"text":"section 100 of Pub. L. 89–97","children":[],"tail":", set out as a Short Title of 1965 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1305"},"text":"section 1305 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb888b127-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Protecting and Improving Guaranteed Medicare Benefits","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/tIII/s3601"},"text":"Pub. L. 111–148, title III, § 3601","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/538"},"text":"124 Stat. 538","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/148/tIII/s3601"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Protecting Guaranteed Medicare Benefits","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in the provisions of, or amendments made by, this Act [see Short Title note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s18001"},"text":"section 18001 of this title","children":[],"tail":"] shall result in a reduction of guaranteed benefits under title XVIII of the Social Security Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395"},"text":"42 U.S.C. 1395","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Ensuring That Medicare Savings Benefit the Medicare Program and Medicare Beneficiaries","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Savings generated for the Medicare program under title XVIII of the Social Security Act under the provisions of, and amendments made by, this Act shall extend the solvency of the Medicare trust funds, reduce Medicare premiums and other cost-sharing for beneficiaries, and improve or expand guaranteed Medicare benefits and protect access to Medicare providers.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
