{"tag":"section","attrib":{"id":"idbc95fc03-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3614–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"3614–1"},"text":"§ 3614–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Incentives for self-testing and self-correction","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbc95fc04-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3614–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Privileged information","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc95fc05-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3614–1/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conditions for privilege","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A report or result of a self-test (as that term is defined by regulation of the Secretary) shall be considered to be privileged under paragraph (2) if any person—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc95fc06-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3614–1/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conducts, or authorizes an independent third party to conduct, a self-test of any aspect of a residential real estate related lending transaction of that person, or any part of that transaction, in order to determine the level or effectiveness of compliance with this subchapter by that person; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc95fc07-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3614–1/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has identified any possible violation of this subchapter by that person and has taken, or is taking, appropriate corrective action to address any such possible violation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc95fc08-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3614–1/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Privileged self-test","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a person meets the conditions specified in subparagraphs (A) and (B) of paragraph (1) with respect to a self-test described in that paragraph, any report or results of that self-test—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc95fc09-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3614–1/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be privileged; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc95fc0a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3614–1/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" may not be obtained or used by any applicant, department, or agency in any—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbc95fc0b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3614–1/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" proceeding or civil action in which one or more violations of this subchapter are alleged; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc95fc0c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3614–1/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" examination or investigation relating to compliance with this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc95fc0d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3614–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Results of self-testing","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc95fc0e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3614–1/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No provision of this section may be construed to prevent an aggrieved person, complainant, department, or agency from obtaining or using a report or results of any self-test in any proceeding or civil action in which a violation of this subchapter is alleged, or in any examination or investigation of compliance with this subchapter if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc95fc0f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3614–1/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the person to whom the self-test relates or any person with lawful access to the report or the results—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbc95fc10-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3614–1/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" voluntarily releases or discloses all, or any part of, the report or results to the aggrieved person, complainant, department, or agency, or to the general public; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc95fc11-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3614–1/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" refers to or describes the report or results as a defense to charges of violations of this subchapter against the person to whom the self-test relates; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc95fc12-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3614–1/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the report or results are sought in conjunction with an adjudication or admission of a violation of this subchapter for the sole purpose of determining an appropriate penalty or remedy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc95fc13-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3614–1/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosure for determination of penalty or remedy","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any report or results of a self-test that are disclosed for the purpose specified in paragraph (1)(B)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc95fc14-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3614–1/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be used only for the particular proceeding in which the adjudication or admission referred to in paragraph (1)(B) is made; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc95fc15-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3614–1/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not be used in any other action or proceeding.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc95fc16-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3614–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjudication","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An aggrieved person, complainant, department, or agency that challenges a privilege asserted under this section may seek a determination of the existence and application of that privilege in—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc95fc17-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3614–1/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a court of competent jurisdiction; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc95fc18-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3614–1/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an administrative law proceeding with appropriate jurisdiction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc95fc19-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/284/tVIII/s814A"},"text":"Pub. L. 90–284, title VIII, § 814A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/dA/tII/s2302/b/1"},"text":"Pub. L. 104–208, div. A, title II, § 2302(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-421"},"text":"110 Stat. 3009–421","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc95fc1a-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbc95fc1b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbc95fc1c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Privilege provided for in this section applicable to self-test conducted before, on, or after effective date of regulations prescribed under ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/s2302/b/2"},"text":"section 2302(b)(2) of Pub. L. 104–208","children":[],"tail":", set out below, with certain exception, see "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/s2302/c"},"text":"section 2302(c) of Pub. L. 104–208","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1691c–1"},"text":"section 1691c–1 of Title 15","children":[],"tail":", Commerce and Trade."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbc95fc1d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/dA/tII/s2302/b/2"},"text":"Pub. L. 104–208, div. A, title II, § 2302(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-423"},"text":"110 Stat. 3009–423","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/208/dA/tII/s2302/b/2"},"text":"\n","children":[{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 6 months after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":"], in consultation with the Board and after providing notice and an opportunity for public comment, the Secretary of Housing and Urban Development shall prescribe final regulations to implement section 814A of the Fair Housing Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3614–1"},"text":"42 U.S.C. 3614–1","children":[],"tail":"], as added by this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Self-test.—","children":[],"tail":null}],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The regulations prescribed by the Secretary under subparagraph (A) shall include a definition of the term “self-test” for purposes of section 814A of the Fair Housing Act, as added by this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirement for self-test","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The regulations prescribed by the Secretary under subparagraph (A) shall specify that a self-test shall be sufficiently extensive to constitute a determination of the level and effectiveness of the compliance by a person engaged in residential real estate related lending activities with the Fair Housing Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3601"},"text":"42 U.S.C. 3601","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"“(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Substantial similarity to certain equal credit opportunity act regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The regulations prescribed under subparagraph (A) shall be substantially similar to the regulations prescribed by the Board to carry out section 704A of the Equal Credit Opportunity Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1691c–1"},"text":"15 U.S.C. 1691c–1","children":[],"tail":"], as added by this section.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
