{"tag":"section","attrib":{"id":"idbf4256df-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11344"},"text":null,"children":[{"tag":"num","attrib":{"value":"11344"},"text":"§ 11344.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on certain costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Not more than 5 percent of the total amount appropriated for the emergency food and shelter program for each fiscal year may be expended for the costs of administration.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbf4256e0-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/77/tIII/s314"},"text":"Pub. L. 100–77, title III, § 314","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-07-22"},"text":"July 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/492"},"text":"101 Stat. 492","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
