{"tag":"section","attrib":{"id":"idbdc023e4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6864d"},"text":null,"children":[{"tag":"num","attrib":{"value":"6864d"},"text":"§ 6864d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial assistance for WAP enhancement and innovation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbdc023e5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6864d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of this section are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbdc023e6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6864d/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to expand the number of dwelling units that are occupied by low-income persons that receive weatherization assistance by making such dwelling units weatherization-ready;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdc023e7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6864d/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to promote the deployment of renewable energy in dwelling units that are occupied by low-income persons;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdc023e8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6864d/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to ensure healthy indoor environments by enhancing or expanding health and safety measures and resources available to dwellings that are occupied by low-income persons;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdc023e9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6864d/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to disseminate new methods and best practices among entities providing weatherization assistance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdc023ea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6864d/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to encourage entities providing weatherization assistance to hire and retain employees who are individuals—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbdc023eb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6864d/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" from the community in which the assistance is provided; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbdc023ec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6864d/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" from communities or groups that are underrepresented in the home energy performance workforce, including religious and ethnic minorities, women, veterans, individuals with disabilities, and individuals who are socioeconomically disadvantaged.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdc023ed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6864d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial assistance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall, to the extent funds are made available, award financial assistance, on an annual basis, through a competitive process to entities receiving funding from the Federal Government or from a State, tribal organization, or unit of general purpose local government through a weatherization program under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6863"},"text":"section 6863 of this title","children":[],"tail":" or "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s6864"},"text":"section 6864 of this title","children":[],"tail":", or to nonprofit entities, to be used by such an entity—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbdc023ee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6864d/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" with respect to dwelling units that are occupied by low-income persons, to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbdc023ef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6864d/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" implement measures to make such dwelling units weatherization-ready by addressing structural, plumbing, roofing, and electrical issues, environmental hazards, or other measures that the Secretary determines to be appropriate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbdc023f0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6864d/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" install energy efficiency technologies, including home energy management systems, smart devices, and other technologies the Secretary determines to be appropriate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbdc023f1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6864d/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" install renewable energy systems (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6865/c/6/A"},"text":"section 6865(c)(6)(A) of this title","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbdc023f2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6864d/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" implement measures to ensure healthy indoor environments by improving indoor air quality, accessibility, and other healthy homes measures as determined by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdc023f3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6864d/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to improve the capability of the entity—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbdc023f4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6864d/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to significantly increase the number of energy retrofits performed by such entity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbdc023f5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6864d/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to replicate best practices for work performed pursuant to this section on a larger scale;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbdc023f6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6864d/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to leverage additional funds to sustain the provision of weatherization assistance and other work performed pursuant to this section after financial assistance awarded under this section is expended; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbdc023f7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6864d/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to hire and retain employees who are individuals described ","children":[{"tag":"ref","attrib":{"idref":"fn003510"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003510"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be followed by “in”."}],"tail":" subsection (a)(5);"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdc023f8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6864d/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for innovative outreach and education regarding the benefits and availability of weatherization assistance and other assistance available pursuant to this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdc023f9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6864d/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for quality control of work performed pursuant to this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdc023fa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6864d/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for data collection, measurement, and verification with respect to such work;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdc023fb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6864d/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for program monitoring, oversight, evaluation, and reporting regarding such work;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdc023fc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6864d/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for labor, training, and technical assistance relating to such work;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdc023fd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6864d/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for planning, management, and administration (up to a maximum of 15 percent of the assistance provided); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdc023fe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6864d/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for such other activities as the Secretary determines to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdc023ff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6864d/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Award factors","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In awarding financial assistance under this section, the Secretary shall consider—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbdc02400-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6864d/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the applicant’s record of constructing, renovating, repairing, or making energy efficient single-family, multifamily, or manufactured homes that are occupied by low-income persons, either directly or through affiliates, chapters, or other partners (using the most recent year for which data are available);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdc02401-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6864d/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of dwelling units occupied by low-income persons that the applicant has built, renovated, repaired, weatherized, or made more energy efficient in the 5 years preceding the date of the application;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdc02402-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6864d/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the qualifications, experience, and past performance of the applicant, including experience successfully managing and administering Federal funds;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdc02403-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6864d/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the strength of an applicant’s proposal to achieve one or more of the purposes under subsection (a);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdc02404-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6864d/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which such applicant will utilize partnerships and regional coordination to achieve one or more of the purposes under subsection (a);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdc02405-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6864d/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" regional and climate zone diversity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdc02406-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6864d/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" urban, suburban, and rural localities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdc02407-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6864d/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other factors as the Secretary determines to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdc02408-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6864d/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbdc02409-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6864d/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be eligible for an award of financial assistance under this section, an applicant shall submit to the Secretary an application in such manner and containing such information as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdc0240a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6864d/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Awards","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the availability of appropriations, not later than 270 days after ","children":[{"tag":"date","attrib":{"date":"2020-12-27"},"text":"December 27, 2020","children":[],"tail":", the Secretary shall make a first award of financial assistance under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdc0240b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6864d/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum amount and term","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbdc0240c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6864d/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The total amount of financial assistance awarded to an entity under this section shall not exceed $2,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdc0240d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6864d/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical and training assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The total amount of financial assistance awarded to an entity under this section shall be reduced by the cost of any technical and training assistance provided by the Secretary that relates to such financial assistance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdc0240e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6864d/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term of an award of financial assistance under this section shall not exceed 3 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdc0240f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6864d/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relationship to formula grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An entity may use financial assistance awarded to such entity under this section in conjunction with other financial assistance provided to such entity under this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdc02410-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6864d/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"2020-12-27"},"text":"December 27, 2020","children":[],"tail":", the Secretary shall issue requirements to implement this section, including, for entities receiving financial assistance under this section—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbdc02411-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6864d/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" standards for allowable expenditures;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdc02412-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6864d/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a minimum saving-to-investment ratio; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdc02413-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6864d/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" standards for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbdc02414-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6864d/f/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" training programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbdc02415-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6864d/f/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" energy audits;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbdc02416-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6864d/f/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the provision of technical assistance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbdc02417-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6864d/f/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" monitoring activities carried out using such financial assistance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbdc02418-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6864d/f/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" verification of energy and cost savings;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbdc02419-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6864d/f/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" liability insurance requirements; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbdc0241a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6864d/f/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recordkeeping and reporting requirements, which shall include reporting to the Office of Weatherization and Intergovernmental Programs of the Department of Energy applicable data on each dwelling unit retrofitted or otherwise assisted pursuant to this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdc0241b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6864d/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compliance with State and local law","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section supersedes or otherwise affects any State or local law, to the extent that the State or local law contains a requirement that is more stringent than the applicable requirement of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdc0241c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6864d/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review and evaluation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall review and evaluate the performance of each entity that receives an award of financial assistance under this section (which may include an audit).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdc0241d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6864d/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall submit to Congress an annual report that provides a description of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbdc0241e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6864d/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" actions taken under this section to achieve the purposes of this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdc0241f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6864d/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accomplishments as a result of such actions, including energy and cost savings achieved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdc02420-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6864d/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbdc02421-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6864d/j/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amounts","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbdc02422-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6864d/j/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For each of fiscal years 2021 through 2025, of the amount made available under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6872"},"text":"section 6872 of this title","children":[],"tail":" for such fiscal year to carry out the weatherization program under this part (not including any of such amount made available for Department of Energy headquarters training or technical assistance), not more than—"}],"tail":null},{"tag":"clause","attrib":{"id":"idbdc02423-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6864d/j/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 2 percent of such amount (if such amount is $225,000,000 or more but less than $260,000,000) may be used to carry out this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbdc02424-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6864d/j/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 4 percent of such amount (if such amount is $260,000,000 or more but less than $300,000,000) may be used to carry out this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbdc02425-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6864d/j/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 6 percent of such amount (if such amount is $300,000,000 or more) may be used to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbdc02426-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6864d/j/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For each of fiscal years 2021 through 2025, if the amount made available under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6872"},"text":"section 6872 of this title","children":[],"tail":" (not including any of such amount made available for Department of Energy headquarters training or technical assistance) for such fiscal year is less than $225,000,000, no funds shall be made available to carry out this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdc02427-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6864d/j/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For any fiscal year, the Secretary may not use more than $25,000,000 of the amount made available under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6872"},"text":"section 6872 of this title","children":[],"tail":" to carry out this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdc02428-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6864d/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may not award financial assistance under this section after ","children":[{"tag":"date","attrib":{"date":"2025-09-30"},"text":"September 30, 2025","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbdc02429-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/385/tIV/s414D"},"text":"Pub. L. 94–385, title IV, § 414D","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dZ/tI/s1011/e/1"},"text":"Pub. L. 116–260, div. Z, title I, 