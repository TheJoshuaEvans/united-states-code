{"tag":"section","attrib":{"id":"idbe3294f5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7477"},"text":null,"children":[{"tag":"num","attrib":{"value":"7477"},"text":"§ 7477.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Administrator shall, and a State may, take such measures, including issuance of an order, or seeking injunctive relief, as necessary to prevent the construction or modification of a major emitting facility which does not conform to the requirements of this part, or which is proposed to be constructed in any area designated pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7407/d"},"text":"section 7407(d) of this title","children":[],"tail":" as attainment or unclassifiable and which is not subject to an implementation plan which meets the requirements of this part."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbe3294f6-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1955-07-14/ch360"},"text":"July 14, 1955, ch. 360","children":[],"tail":", title I, § 167, as added "},{"tag":"ref","attrib":{"href":"/us/pl/95/95/tI/s127/a"},"text":"Pub. L. 95–95, title I, § 127(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-08-07"},"text":"Aug. 7, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/740"},"text":"91 Stat. 740","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/549/tI/s110/3"},"text":"Pub. L. 101–549, title I, § 110(3)","children":[],"tail":", title VII, § 708, "},{"tag":"date","attrib":{"date":"1990-11-15"},"text":"Nov. 15, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2470"},"text":"104 Stat. 2470","children":[],"tail":", 2684.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbe3294f7-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbe3294f8-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbe3294f9-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1990—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/549/s708"},"text":"Pub. L. 101–549, § 708","children":[],"tail":", substituted “construction or modification of a major emitting facility” for “construction of a major emitting facility”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/549/s110/3"},"text":"Pub. L. 101–549, § 110(3)","children":[],"tail":", substituted “designated pursuant to section 7407(d) as attainment or unclassifiable” for “included in the list promulgated pursuant to paragraph (1)(D) or (E) of subsection (d) of "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s7407"},"text":"section 7407 of this title","children":[],"tail":"”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
