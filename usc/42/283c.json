{"tag":"section","attrib":{"id":"idb5596a52-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s283c"},"text":null,"children":[{"tag":"num","attrib":{"value":"283c"},"text":"§ 283c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of Behavioral and Social Sciences Research","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5596a53-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s283c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is established within the Office of the Director of NIH an office to be known as the Office of Behavioral and Social Sciences Research (in this section referred to as the “Office”). The Office shall be headed by a director, who shall be appointed by the Director of NIH.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5596a54-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s283c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5596a55-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s283c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" With respect to research on the relationship between human behavior and the development, treatment, and prevention of medical conditions, the Director of the Office shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5596a56-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s283c/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate research conducted or supported by the agencies of the National Institutes of Health; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5596a57-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s283c/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify projects of behavioral and social sciences research that should be conducted or supported by the national research institutes, and develop such projects in cooperation with such institutes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5596a58-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s283c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Research authorized under paragraph (1) includes research on teen pregnancy, infant mortality, violent behavior, suicide, and homelessness. Such research does not include neurobiological research, or research in which the behavior of an organism is observed for the purpose of determining activity at the cellular or molecular level.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5596a59-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title IV, § 404A, as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/43/tII/s203/a"},"text":"Pub. L. 103–43, title II, § 203(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-06-10"},"text":"June 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/145"},"text":"107 Stat. 145","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb5596a5a-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb5596a5b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb5596a5c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/43/tII/s203/c"},"text":"Pub. L. 103–43, title II, § 203(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-06-10"},"text":"June 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/146"},"text":"107 Stat. 146","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/43/tII/s203/c"},"text":"“The amendment described in subsection (a) [enacting this section] is made upon the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1993-06-10"},"text":"June 10, 1993","children":[],"tail":"] and takes effect "},{"tag":"date","attrib":{"date":"1993-07-01"},"text":"July 1, 1993","children":[],"tail":". Subsection (b) ["},{"tag":"ref","attrib":{"href":"/us/stat/107/145"},"text":"107 Stat. 145","children":[],"tail":"] takes effect on such date.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
