{"tag":"section","attrib":{"id":"idb4d6304e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–7f"},"text":null,"children":[{"tag":"num","attrib":{"value":"247d–7f"},"text":"§ 247d–7f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collaboration and coordination","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb4d6304f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–7f/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limited antitrust exemption","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4d63050-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–7f/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings and consultations to discuss security countermeasures, qualified countermeasures, or qualified pandemic or epidemic product development","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4d63051-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–7f/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to conduct meetings and consultations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in coordination with the Attorney General and the Secretary of Homeland Security, may conduct meetings and consultations with persons engaged in the development of a security countermeasure (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s247d–6b"},"text":"section 247d–6b of this title","children":[],"tail":"), a qualified countermeasure (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s247d–6a"},"text":"section 247d–6a of this title","children":[],"tail":"), or a qualified pandemic or epidemic product (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s247d–6d"},"text":"section 247d–6d of this title","children":[],"tail":") for the purpose of the development, manufacture, distribution, purchase, or storage of a countermeasure or product. The Secretary may convene such meeting or consultation at the request of the Secretary of Homeland Security, the Attorney General, the Chairman of the Federal Trade Commission (referred to in this section as the “Chairman”), or any interested person, or upon initiation by the Secretary. The Secretary shall give prior notice of any such meeting or consultation, and the topics to be discussed, to the Attorney General, the Chairman, and the Secretary of Homeland Security."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4d63052-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–7f/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meeting and consultation conditions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A meeting or consultation conducted under subparagraph (A) shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb4d63053-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–7f/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be chaired or, in the case of a consultation, facilitated by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb4d63054-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–7f/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be open to persons involved in the development, manufacture, distribution, purchase, or storage of a countermeasure or product, as determined by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb4d63055-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–7f/a/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be open to the Attorney General, the Secretary of Homeland Security, and the Chairman;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb4d63056-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–7f/a/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be limited to discussions involving covered activities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb4d63057-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–7f/a/1/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be conducted in such manner as to ensure that no national security, confidential commercial, or proprietary information is disclosed outside the meeting or consultation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4d63058-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–7f/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may not require participants to disclose confidential commercial or proprietary information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4d63059-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–7f/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transcript","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall maintain a complete verbatim transcript of each meeting or consultation conducted under this subsection. Such transcript (or a portion thereof) shall not be disclosed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552"},"text":"section 552 of title 5","children":[],"tail":" to the extent that the Secretary, in consultation with the Attorney General and the Secretary of Homeland Security, determines that disclosure of such transcript (or portion thereof) would pose a threat to national security. The transcript (or portion thereof) with respect to which the Secretary has made such a determination shall be deemed to be information described in subsection (b)(3) of such section 552."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4d6305a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–7f/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb4d6305b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–7f/a/1/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to clause (ii), it shall not be a violation of the antitrust laws for any person to participate in a meeting or consultation conducted in accordance with this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb4d6305c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–7f/a/1/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Clause (i) shall not apply to any agreement or conduct that results from a meeting or consultation and that is not covered by an exemption granted under paragraph (4).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4d6305d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–7f/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission of written agreements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall submit each written agreement regarding covered activities that is made pursuant to meetings or consultations conducted under paragraph (1) to the Attorney General and the Chairman for consideration. In addition to the proposed agreement itself, any submission shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4d6305e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–7f/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an explanation of the intended purpose of the agreement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4d6305f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–7f/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a specific statement of the substance of the agreement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4d63060-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–7f/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the methods that will be utilized to achieve the objectives of the agreement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4d63061-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–7f/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an explanation of the necessity for a cooperative effort among the particular participating persons to achieve the objectives of the agreement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4d63062-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–7f/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other relevant information determined necessary by the Attorney General, in consultation with the Chairman and the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4d63063-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–7f/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption for conduct under approved agreement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It shall not be a violation of the antitrust laws for a person to engage in conduct in accordance with a written agreement to the extent that such agreement has been granted an exemption under paragraph (4), during the period for which the exemption is in effect.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4d63064-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–7f/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Action on written agreements","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4d63065-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–7f/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General, in consultation with the Chairman, shall grant, deny, grant in part and deny in part, or propose modifications to an exemption request regarding a written agreement submitted under paragraph (2), in a written statement to the Secretary, within 15 business days of the receipt of such request. An exemption granted under this paragraph shall take effect immediately.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4d63066-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–7f/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extension","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General may extend the 15-day period referred to in subparagraph (A) for an additional period of not to exceed 10 business days.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4d63067-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–7f/a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An exemption shall be granted regarding a written agreement submitted in accordance with paragraph (2) only to the extent that the Attorney General, in consultation with the Chairman and the Secretary, finds that the conduct that will be exempted will not have any substantial anticompetitive effect that is not reasonably necessary for ensuring the availability of the countermeasure or product involved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4d63068-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–7f/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on and renewal of exemptions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An exemption granted under paragraph (4) shall be limited to covered activities, and such exemption shall be renewed (with modifications, as appropriate, consistent with the finding described in paragraph (4)(C)), on the date that is 3 years after the date on which the exemption is granted unless the Attorney General in consultation with the Chairman determines that the exemption should not be renewed (with modifications, as appropriate) considering the factors described in paragraph (4).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4d63069-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–7f/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to obtain information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Consideration by the Attorney General for granting or renewing an exemption submitted under this section shall be considered an antitrust investigation for purposes of the Antitrust Civil Process Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1311"},"text":"15 U.S.C. 1311","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4d6306a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–7f/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on parties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The use of any information acquired under an agreement for which an exemption has been granted under paragraph (4), for any purpose other than specified in the exemption, shall be subject to the antitrust laws and any other applicable laws.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4d8a16b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–7f/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than one year after the date of enactment of this Act ","children":[{"tag":"ref","attrib":{"idref":"fn002070"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002070"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" and biannually thereafter, the Attorney General and the Chairman shall report to Congress on the use of the exemption from the antitrust laws provided by this subsection."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4d8a16c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–7f/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sunset","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The applicability of this section shall expire after ","children":[{"tag":"date","attrib":{"date":"2026-12-31"},"text":"December 31, 2026","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4d8a16d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–7f/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4d8a16e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–7f/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Antitrust laws","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “antitrust laws”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4d8a16f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–7f/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has the meaning given such term in subsection (a) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s12"},"text":"section 12 of title 15","children":[],"tail":", except that such term includes "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s45"},"text":"section 45 of title 15","children":[],"tail":" to the extent such "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s45"},"text":"section 45 of title 15","children":[],"tail":" applies to unfair methods of competition; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4d8a170-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–7f/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes any State law similar to the laws referred to in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4d8a171-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–7f/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Countermeasure or product","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “countermeasure or product” refers to a security countermeasure, qualified countermeasure, or qualified pandemic or epidemic product (as those terms are defined in subsection (a)(1)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4d8a172-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–7f/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered activities","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4d8a173-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–7f/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subparagraph (B), the term “covered activities” includes any activity relating to the development, manufacture, distribution, purchase, or storage of a countermeasure or product.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4d8a174-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–7f/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “covered activities” shall not include, with respect to a meeting or consultation conducted under subsection (a)(1) or an agreement for which an exemption has been granted under subsection (a)(4), the following activities involving 2 or more persons:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb4d8a175-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–7f/c/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Exchanging information among competitors relating to costs, profitability, or distribution of any product, process, or service if such information is not reasonably necessary to carry out covered activities—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb4d8a176-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–7f/c/3/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to a countermeasure or product regarding which such meeting or consultation is being conducted; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb4d8a177-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–7f/c/3/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that are described in the agreement as exempted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb4d8a178-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–7f/c/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Entering into any agreement or engaging in any other conduct—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb4d8a179-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–7f/c/3/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to restrict or require the sale, licensing, or sharing of inventions, developments, products, processes, or services not developed through, produced by, or distributed or sold through such covered activities; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb4d8a17a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–7f/c/3/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to restrict or require participation, by any person participating in such covered activities, in other research and development activities, except as reasonably necessary to prevent the misappropriation of proprietary information contributed by any person participating in such covered activities or of the results of such covered activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb4d8a17b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–7f/c/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Entering into any agreement or engaging in any other conduct allocating a market with a competitor that is not expressly exempted from the antitrust laws under subsection (a)(4).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb4d8a17c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–7f/c/3/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Exchanging information among competitors relating to production (other than production by such covered activities) of a product, process, or service if such information is not reasonably necessary to carry out such covered activities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb4d8a17d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–7f/c/3/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Entering into any agreement or engaging in any other conduct restricting, requiring, or otherwise involving the production of a product, process, or service that is not expressly exempted from the antitrust laws under subsection (a)(4).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb4d8a17e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–7f/c/3/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as otherwise provided in this subsection, entering into any agreement or engaging in any other conduct to restrict or require participation by any person participating in such covered activities, in any unilateral or joint activity that is not reasonably necessary to carry out such covered activities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb4d8a17f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–7f/c/3/B/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Entering into any agreement or engaging in any other conduct restricting or setting the price at which a countermeasure or product is offered for sale, whether by bid or otherwise.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb4d8a180-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title III, § 319L–1, formerly "},{"tag":"ref","attrib":{"href":"/us/pl/109/417/tIV/s405"},"text":"Pub. L. 109–417, title IV, § 405","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-19"},"text":"Dec. 19, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2875"},"text":"120 Stat. 2875","children":[],"tail":", as amended "},{"tag":"ref","attrib":{"href":"/us/pl/113/5/s402/e/1"},"text":"Pub. L. 113–5, § 402(e)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-03-13"},"text":"Mar. 13, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/195"},"text":"127 Stat. 195","children":[],"tail":"; renumbered § 319L–1 of act "},{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", and amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/22/tVII/s701/e/1"},"text":"Pub. L. 116–22, title VII, § 701(e)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-06-24"},"text":"June 24, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/961"},"text":"133 Stat. 961","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/22/dB/tII/s203/c"},"text":"Pub. L. 118–22, div. B, title II, § 203(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-11-17"},"text":"Nov. 17, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/120"},"text":"137 Stat. 120","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/35/dB/tI/s103/c"},"text":"Pub. L. 118–35, div. B, title I, § 103(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-01-19"},"text":"Jan. 19, 2024","