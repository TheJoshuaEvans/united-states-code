","attrib":{"href":"/us/pl/119/75"},"text":"Pub. L. 119–75","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2026-12-31"},"text":"December 31, 2026","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2026-01-30"},"text":"January 30, 2026","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2025—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/37"},"text":"Pub. L. 119–37","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2026-01-30"},"text":"January 30, 2026","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2025-09-30"},"text":"September 30, 2025","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/4"},"text":"Pub. L. 119–4","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2025-09-30"},"text":"September 30, 2025","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2025-03-31"},"text":"March 31, 2025","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2024—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/158"},"text":"Pub. L. 118–158","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2025-03-31"},"text":"March 31, 2025","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2024-12-31"},"text":"December 31, 2024","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/42"},"text":"Pub. L. 118–42","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2024-12-31"},"text":"December 31, 2024","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2024-03-08"},"text":"March 8, 2024","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/35"},"text":"Pub. L. 118–35","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2024-03-08"},"text":"March 8, 2024","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2024-01-19"},"text":"January 19, 2024","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2023—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/22"},"text":"Pub. L. 118–22","children":[],"tail":" substituted “after "},{"tag":"date","attrib":{"date":"2024-01-19"},"text":"January 19, 2024","children":[],"tail":"” for “at the end of the 17-year period that begins on the date of enactment of this Act”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2019—Subsec. (a)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/22/s701/e/1/A"},"text":"Pub. L. 116–22, § 701(e)(1)(A)","children":[],"tail":", substituted “The Secretary, in coordination” for “The Secretary of Health and Human Services (referred to in this subsection as the ‘Secretary’), in coordination” and made technical amendments to references in original act which appear in text as references to sections 247d–6b, 247d–6a, and 247d–6d of this title."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/22/s701/e/1/B"},"text":"Pub. L. 116–22, § 701(e)(1)(B)","children":[],"tail":", substituted “17-year” for “12-year”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/5"},"text":"Pub. L. 113–5","children":[],"tail":" substituted “12-year” for “6-year”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb4d8a187-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb4d8a188-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2013 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/5/tIV/s402/e/2"},"text":"Pub. L. 113–5, title IV, § 402(e)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-03-13"},"text":"Mar. 13, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/195"},"text":"127 Stat. 195","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/113/5/tIV/s402/e/2"},"text":"“This subsection [amending this section] shall take effect as if enacted on ","children":[{"tag":"date","attrib":{"date":"2012-12-17"},"text":"December 17, 2012","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
