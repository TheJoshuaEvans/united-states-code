{"tag":"section","attrib":{"id":"idb48e9fd3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s242c–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"242c–1"},"text":"§ 242c–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisory committee to the Director","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb48e9fd4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s242c–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 60 days after ","children":[{"tag":"date","attrib":{"date":"2022-12-29"},"text":"December 29, 2022","children":[],"tail":", the Secretary, acting through the Director of the Centers for Disease Control and Prevention (referred to in this section as the “Director”), shall maintain or establish an advisory committee within the Centers for Disease Control and Prevention to advise the Director on policy and strategies that enable the agency to fulfill its mission."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb48e9fd5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s242c–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions and activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Advisory Committee may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb48e9fd6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s242c–1/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make recommendations to the Director regarding ways to prioritize the activities of the agency in alignment with the CDC Strategic Plan required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s242c/c"},"text":"section 242c(c) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb48e9fd7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s242c–1/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advise on ways to achieve or improve performance metrics in relation to the CDC Strategic Plan, and other relevant metrics, as appropriate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb48e9fd8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s242c–1/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide advice and recommendations on the development of the CDC Strategic Plan, and any subsequent updates, as appropriate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb48e9fd9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s242c–1/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advise on grants, cooperative agreements, contracts, or other transactions, as applicable;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb48e9fda-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s242c–1/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide other advice to the Director, as requested, to fulfill duties under sections 241 and 243 of this title; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb48e9fdb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s242c–1/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appoint subcommittees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb48e9fdc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s242c–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb48e9fdd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s242c–1/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Advisory Committee shall consist of not more than 15 non-Federal members, including the Chair, to be appointed by the Secretary under paragraph (3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb48e9fde-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s242c–1/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ex officio members","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any ex officio members of the Advisory Council ","children":[{"tag":"ref","attrib":{"idref":"fn002030"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002030"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original."}],"tail":" may consist of—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb48e9fdf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s242c–1/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb48e9fe0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s242c–1/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Assistant Secretary for Health;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb48e9fe1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s242c–1/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Director; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb48e9fe2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s242c–1/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such additional officers or employees of the United States as the Secretary determines necessary for the advisory committee to effectively carry out its functions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb48e9fe3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s242c–1/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointed members","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Individuals shall be appointed to the Advisory Committee under paragraph (1) as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb48e9fe4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s242c–1/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Twelve of the members shall be appointed by the Director from among the leading representatives of the health disciplines (including public health, global health, health disparities, biomedical research, public health preparedness, and other fields, as applicable) relevant to the activities of the agency or center, as applicable.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb48e9fe5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s242c–1/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Three of the members may be appointed by the Secretary from the general public and may include leaders in fields of innovation, public policy, public relations, law, economics, or management.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb48e9fe6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s242c–1/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Ex officio members of the Advisory Council ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" who are officers or employees of the United States shall not receive any compensation for service on the advisory committee. The remaining members of the advisory committee may receive, for each day (including travel time) they are engaged in the performance of the functions of the advisory committee, compensation at rates not to exceed the daily equivalent to the annual rate of basic pay for level III of the Executive Schedule under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5314"},"text":"section 5314 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb48e9fe7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s242c–1/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms of office","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb48e9fe8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s242c–1/c/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term of office of a member of the advisory committee appointed under paragraph (3) shall be 4 years, except that any member appointed to fill a vacancy for an unexpired term shall serve for the remainder of such term. The Secretary shall make appointments to the advisory committee in such a manner as to ensure that the terms of the members not all expire in the same year. A member of the advisory committee may serve after the expiration of such member’s term until a successor has been appointed and taken office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb48e9fe9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s242c–1/c/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reappointments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A member who has been appointed to the advisory committee for a term of 4 years may not be reappointed to the advisory committee during the 2-year period beginning on the date on which such 4-year term expired.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb48e9fea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s242c–1/c/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time for appointment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a vacancy occurs in the advisory committee among the members appointed under paragraph (3), the Secretary shall make an appointment to fill such vacancy within 90 days from the date the vacancy occurs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb48e9feb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s242c–1/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chair","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall select a member of the advisory committee to serve as the Chair of the committee. The Secretary may so select an individual from among the appointed members. The term of office of the chair shall be 2 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb48e9fec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s242c–1/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The advisory committee shall meet at the call of the Chair or upon request of the Director, but in no event less than 2 times during each fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb48e9fed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s242c–1/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Executive secretary and staff","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall designate a member of the staff of the agency to serve as the executive secretary of the advisory committee. The Director shall make available to the advisory committee such staff, information, and other assistance as it may require to carry out its functions. The Director shall provide orientation and training for new members of the advisory committee to provide for their effective participation in the functions of the advisory committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb48e9fee-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title III, § 305A, as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dFF/tII/s2102"},"text":"Pub. L. 117–328, div. FF, title II, § 2102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5709"},"text":"136 Stat. 5709","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
