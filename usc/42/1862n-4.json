{"tag":"section","attrib":{"id":"idbb8d661e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862n–4"},"text":null,"children":[{"tag":"num","attrib":{"value":"1862n–4"},"text":"§ 1862n–4.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Major research equipment and facilities construction plan","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbb8d661f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862n–4/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prioritization of proposed major research equipment and facilities construction","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb8d6620-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862n–4/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Development of priorities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbb8d6621-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862n–4/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop a list indicating by number the relative priority for funding under the major research equipment and facilities construction account that the Director assigns to each project the Board has approved for inclusion in a future budget request; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb8d6622-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862n–4/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit the list described in subparagraph (A) to the Board for approval.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb8d6623-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862n–4/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall include in the criteria for developing the list under paragraph (1) the readiness of plans for construction and operation, including confidence in the estimates of the full life-cycle cost (as defined in section 2 of the National Science Foundation Authorization Act of 1998 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1862k"},"text":"42 U.S.C. 1862k","children":[],"tail":" note)) and the proposed schedule of completion."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb8d6624-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862n–4/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Updates","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall update the list prepared under paragraph (1) each time the Board approves a new project that would receive funding under the major research equipment and facilities construction account and periodically submit any updated list to the Board for approval.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb8d6625-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862n–4/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Project management","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No national research facility project funded under the major research equipment and facilities construction account shall be managed by an individual whose appointment to the Foundation is temporary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb8d6626-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862n–4/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Board approval of major research equipment and facilities projects","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall explicitly approve any project to be funded out of the major research equipment and facilities construction account before any funds may be obligated from such account for such project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbb8d6627-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/368/s14"},"text":"Pub. L. 107–368, § 14","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-19"},"text":"Dec. 19, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/3056"},"text":"116 Stat. 3056","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/329/tII/s204/c"},"text":"Pub. L. 114–329, title II, § 204(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-01-06"},"text":"Jan. 6, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/3000"},"text":"130 Stat. 3000","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbb8d6628-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbb8d6629-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbb8d662a-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 2 of the National Science Foundation Authorization Act of 1998, referred to in subsec. (a)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/207/s2"},"text":"section 2 of Pub. L. 105–207","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-07-29"},"text":"July 29, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/869"},"text":"112 Stat. 869","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1862k"},"text":"section 1862k of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbb8d662b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/368/s14"},"text":"section 14 of Pub. L. 107–368","children":[],"tail":". As originally enacted, subsec. (b)(1), (2) of "},{"tag":"ref","attrib":{"href":"/us/pl/107/368/s14"},"text":"section 14 of Pub. L. 107–368","children":[],"tail":" amended section 1862"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":" of this title, and subsec. (b)(3) of "},{"tag":"ref","attrib":{"href":"/us/pl/107/368/s14"},"text":"section 14 of Pub. L. 107–368","children":[],"tail":" amended provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1862k"},"text":"section 1862k of this title","children":[],"tail":". Subsec. (c) of "},{"tag":"ref","attrib":{"href":"/us/pl/107/368/s14"},"text":"section 14 of Pub. L. 107–368","children":[],"tail":" was redesignated subsec. (b) by "},{"tag":"ref","attrib":{"href":"/us/pl/114/329/s204/c/3"},"text":"section 204(c)(3) of Pub. L. 114–329","children":[],"tail":" without reference to the original amendments made by subsec. (b) of "},{"tag":"ref","attrib":{"href":"/us/pl/107/368/s14"},"text":"section 14 of Pub. L. 107–368","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the National Science Foundation Authorization Act of 2002, and not as part of the National Science Foundation Act of 1950 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbb8d662c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/329/s204/c/1"},"text":"Pub. L. 114–329, § 204(c)(1)","children":[],"tail":", amended subsec. (a) generally. Prior to amendment, subsec. (a) related to prioritization of proposed major research equipment and facilities construction and annual reports."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/329/s204/c/3"},"text":"Pub. L. 114–329, § 204(c)(3)","children":[],"tail":", redesignated subsec. (c) as (b). Prior to amendment, subsec. (b) had been omitted from this section, see Codification note above."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/329/s204/c/3"},"text":"Pub. L. 114–329, § 204(c)(3)","children":[],"tail":", (4), redesignated subsec. (d) as (c) and amended it generally. Prior to amendment, subsec. (c) related to Board approval of major research equipment and facilities projects. Former subsec. (c) redesignated (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/329/s204/c/2"},"text":"Pub. L. 114–329, § 204(c)(2)","children":[],"tail":", struck out subsec. (e) which related to National Academy of Sciences study on major research equipment and facilities construction."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbb8d662d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idbb8d662e-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definitions of terms used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/368/s4"},"text":"section 4 of Pub. L. 107–368","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1862n"},"text":"section 1862n of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
