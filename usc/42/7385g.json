{"tag":"section","attrib":{"id":"idbe0c703d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385g"},"text":null,"children":[{"tag":"num","attrib":{"value":"7385g"},"text":"§ 7385g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Attorney fees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbe0c703e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385g/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any contract, the representative of an individual may not receive, for services rendered in connection with the claim of an individual for payment of lump-sum compensation under part B, more than that percentage specified in subsection (b) of a payment made under part B on such claim.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe0c703f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385g/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicable percentage limitations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The percentage referred to in subsection (a) is—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe0c7040-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385g/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 2 percent for the filing of an initial claim for payment of lump-sum compensation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe0c7041-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385g/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 10 percent with respect to objections to a recommended decision denying payment of lump-sum compensation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe0c7042-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385g/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inapplicability to other services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall not apply with respect to services rendered that are not in connection with such a claim for payment of lump-sum compensation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe0c7043-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385g/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalty","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any such representative who violates this section shall be fined not more than $5,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbe0c7044-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dC/tXXXVI/s3648"},"text":"Pub. L. 106–398, § 1 [div. C, title XXXVI, § 3648]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–511; "},{"tag":"ref","attrib":{"href":"/us/pl/107/107/dC/tXXXI/s3151/a/6"},"text":"Pub. L. 107–107, div. C, title XXXI, § 3151(a)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1375"},"text":"115 Stat. 1375","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbe0c7045-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbe0c7046-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbe0c7047-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2001—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107/s3151/a/6/A"},"text":"Pub. L. 107–107, § 3151(a)(6)(A)","children":[],"tail":", inserted “for payment of lump-sum compensation” after “the claim of an individual”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107/s3151/a/6/B"},"text":"Pub. L. 107–107, § 3151(a)(6)(B)","children":[],"tail":", inserted “for payment of lump-sum compensation” after “initial claim”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107/s3151/a/6/C"},"text":"Pub. L. 107–107, § 3151(a)(6)(C)","children":[],"tail":", substituted “with respect to objections to a recommended decision denying payment of lump-sum compensation” for “with respect to any claim with respect to which a representative has made a contract for services before "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"October 30, 2000","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107/s3151/a/6/D"},"text":"Pub. L. 107–107, § 3151(a)(6)(D)","children":[],"tail":", (E), added subsec. (c) and redesignated former subsec. (c) as (d)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
