{"tag":"section","attrib":{"id":"idb8b14811-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395j"},"text":null,"children":[{"tag":"num","attrib":{"value":"1395j"},"text":"§ 1395j.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of supplementary medical insurance program for aged and disabled","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There is hereby established a voluntary insurance program to provide medical insurance benefits in accordance with the provisions of this part for aged and disabled individuals who elect to enroll under such program, to be financed from premium payments by enrollees together with contributions from funds appropriated by the Federal Government.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb8b14812-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title XVIII, § 1831, as added "},{"tag":"ref","attrib":{"href":"/us/pl/89/97/tI/s102/a"},"text":"Pub. L. 89–97, title I, § 102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-07-30"},"text":"July 30, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/301"},"text":"79 Stat. 301","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/92/603/tII/s201/a/3"},"text":"Pub. L. 92–603, title II, § 201(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-30"},"text":"Oct. 30, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1371"},"text":"86 Stat. 1371","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8b14813-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8b14814-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8b14815-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1972—","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/603"},"text":"Pub. L. 92–603","children":[],"tail":" substituted “aged and disabled individuals” for “individuals 65 years of age or over”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8b14816-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb8b14817-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Study Regarding Coverage Under Part B of Medicare for Nonreimbursable Services Provided by Optometrists for Prosthetic Lenses for Patients With Aphakia","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/182/tI/s109"},"text":"Pub. L. 94–182, title I, § 109","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-12-31"},"text":"Dec. 31, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/1053"},"text":"89 Stat. 1053","children":[],"tail":", provided that the Secretary of Health, Education, and Welfare conduct a study on the appropriateness of reimbursement under the insurance program established by this part for services performed by optometrists with respect to the provision of prosthetic lenses for patients with aphakia and submit such study to Congress not later than 4 months after "},{"tag":"date","attrib":{"date":"1975-12-31"},"text":"Dec. 31, 1975","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb8b14818-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Study To Determine Feasibility of Inclusion of Certain Additional Services Under Part B","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/90/248/tI/s141"},"text":"Pub. L. 90–248, title I, § 141","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-01-02"},"text":"Jan. 2, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/855"},"text":"81 Stat. 855","children":[],"tail":", directed Secretary to conduct a study relating to inclusion under the supplementary medical insurance program under this part of services of additional types of licensed practitioners performing health services in independent practice and submit such study to Congress prior to "},{"tag":"date","attrib":{"date":"1969-01-01"},"text":"Jan. 1, 1969","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
