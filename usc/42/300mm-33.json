{"tag":"section","attrib":{"id":"idb6e539ed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–33"},"text":null,"children":[{"tag":"num","attrib":{"value":"300mm–33"},"text":"§ 300mm–33.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Followup monitoring and treatment of other individuals with WTC-related health conditions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb6e539ee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–33/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subsection (c), the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300mm–32"},"text":"section 300mm–32 of this title","children":[],"tail":" shall apply to the followup monitoring and treatment of WTC-related health conditions in the case of individuals described in subsection (b) in the same manner as such provisions apply to the followup monitoring and treatment of WTC-related health conditions for certified-eligible WTC survivors."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6e539ef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–33/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Individuals described","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An individual described in this subsection is an individual who, regardless of location of residence—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6e539f0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–33/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not an enrolled WTC responder or a certified-eligible WTC survivor; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6e539f1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–33/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is diagnosed at a Clinical Center of Excellence with a WTC-related health condition for certified-eligible WTC survivors.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6e539f2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–33/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6e539f3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–33/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The WTC Program Administrator shall limit benefits for any fiscal year under subsection (a) in a manner so that payments under this section for such fiscal year do not exceed the amount specified in paragraph (2) for such fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6e539f4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–33/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount specified in this paragraph for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6e539f5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–33/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the last calendar quarter of fiscal year 2011 is $5,000,000;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6e539f6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–33/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fiscal year 2012 is $20,000,000; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6e539f7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–33/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a succeeding fiscal year is the amount specified in this paragraph for the previous fiscal year increased by the annual percentage increase in the medical care component of the consumer price index for all urban consumers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb6e539f8-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XXXIII, § 3323, as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/347/tI/s101"},"text":"Pub. L. 111–347, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-02"},"text":"Jan. 2, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3652"},"text":"124 Stat. 3652","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
