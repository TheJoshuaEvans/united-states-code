{"tag":"section","attrib":{"id":"idbb0c9cf6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437z–10"},"text":null,"children":[{"tag":"num","attrib":{"value":"1437z–10"},"text":"§ 1437z–10.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Small public housing agencies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbb0c9cf7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437z–10/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb0c9cf8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437z–10/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Housing voucher program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “housing voucher program” means a program for tenant-based assistance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1437f"},"text":"section 1437f of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb0c9cf9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437z–10/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Small public housing agency","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “small public housing agency” means a public housing agency—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbb0c9cfa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437z–10/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for which the sum of the number of public housing dwelling units administered by the agency and the number of vouchers under section 1437f(","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":") of this title administered by the agency is 550 or fewer; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb0c9cfb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437z–10/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that predominantly operates in a rural area, as described in section 1026.35(b)(2)(iv)(A) of title 12, Code of Federal Regulations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb0c9cfc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437z–10/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Troubled small public housing agency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “troubled small public housing agency” means a small public housing agency designated by the Secretary as a troubled small public housing agency under subsection (c)(3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb0c9cfd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437z–10/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as otherwise provided in this section, a small public housing agency shall be subject to the same requirements as a public housing agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb0c9cfe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437z–10/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program inspections and evaluations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb0c9cff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437z–10/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public housing projects","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbb0c9d00-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437z–10/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Frequency of inspections by Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall carry out an inspection of the physical condition of a small public housing agency’s public housing projects not more frequently than once every 3 years, unless the agency has been designated by the Secretary as a troubled small public housing agency based on deficiencies in the physical condition of its public housing projects. Nothing contained in this subparagraph relieves the Secretary from conducting lead safety inspections or assessments in accordance with procedures established by the Secretary under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4822"},"text":"section 4822 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb0c9d01-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437z–10/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standards","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall apply to small public housing agencies the same standards for the acceptable condition of public housing projects that apply to projects assisted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1437f"},"text":"section 1437f of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb0c9d02-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437z–10/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Housing voucher program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as required by section 1437f(","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":")(8)(F) of this title, a small public housing agency administering assistance under section 1437f("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":") of this title shall make periodic physical inspections of each assisted dwelling unit not less frequently than once every 3 years to determine whether the unit is maintained in accordance with the requirements under section 1437f("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":")(8)(A) of this title. Nothing contained in this paragraph relieves a small public housing agency from conducting lead safety inspections or assessments in accordance with procedures established by the Secretary under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4822"},"text":"section 4822 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb0c9d03-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437z–10/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Troubled small public housing agencies","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbb0c9d04-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437z–10/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public housing program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, the Secretary may designate a small public housing agency as a troubled small public housing agency with respect to the public housing program of the small public housing agency if the Secretary determines that the agency has failed to maintain the public housing units of the small public housing agency in a satisfactory physical condition, based upon an inspection conducted by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb0c9d05-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437z–10/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Housing voucher program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, the Secretary may designate a small public housing agency as a troubled small public housing agency with respect to the housing voucher program of the small public housing agency if the Secretary determines that the agency has failed to comply with the inspection requirements under paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb0c9d06-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437z–10/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appeals","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbb0c9d07-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437z–10/c/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish an appeals process under which a small public housing agency may dispute a designation as a troubled small public housing agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbb0c9d08-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437z–10/c/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Official","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The appeals process established under clause (i) shall provide for a decision by an official who has not been involved, and is not subordinate to a person who has been involved, in the original determination to designate a small public housing agency as a troubled small public housing agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb0c9d09-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437z–10/c/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Corrective action agreement","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbb0c9d0a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437z–10/c/3/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreement required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 60 days after the date on which a small public housing agency is designated as a troubled public housing agency under subparagraph (A) or (B), the Secretary and the small public housing agency shall enter into a corrective action agreement under which the small public housing agency shall undertake actions to correct the deficiencies upon which the designation is based.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbb0c9d0b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437z–10/c/3/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms of agreement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A corrective action agreement entered into under clause (i) shall—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbb0c9d0c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437z–10/c/3/D/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have a term of 1 year, and shall be renewable at the option of the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbb0c9d0d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437z–10/c/3/D/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide, where feasible, for technical assistance to assist the public housing agency in curing its deficiencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbb0c9d0e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437z–10/c/3/D/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide for—","children":[],"tail":null},{"tag":"item","attrib":{"id":"idbb0c9d0f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437z–10/c/3/D/ii/III/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reconsideration of the designation of the small public housing agency as a troubled small public housing agency not less frequently than annually; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idbb0c9d10-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437z–10/c/3/D/ii/III/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" termination of the agreement when the Secretary determines that the small public housing agency is no longer a troubled small public housing agency; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbb0c9d11-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437z–10/c/3/D/ii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide that in the event of substantial noncompliance by the small public housing agency under the agreement, the Secretary may—","children":[],"tail":null},{"tag":"item","attrib":{"id":"idbb0c9d12-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437z–10/c/3/D/ii/IV/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contract with another public housing agency or a private entity to manage the public housing of the troubled small public housing agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idbb0c9d13-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437z–10/c/3/D/ii/IV/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" withhold funds otherwise distributable to the troubled small public housing agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idbb0c9d14-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437z–10/c/3/D/ii/IV/cc"},"text":null,"children":[{"tag":"num","attrib":{"value":"cc"},"text":"(cc)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assume possession of, and direct responsibility for, managing the public housing of the troubled small public housing agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idbb0c9d15-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437z–10/c/3/D/ii/IV/dd"},"text":null,"children":[{"tag":"num","attrib":{"value":"dd"},"text":"(dd)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" petition for the appointment of a receiver, in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1437d/j/3/A/ii"},"text":"section 1437d(j)(3)(A)(ii) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idbb0c9d16-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437z–10/c/3/D/ii/IV/ee"},"text":null,"children":[{"tag":"num","attrib":{"value":"ee"},"text":"(ee)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exercise any other remedy available to the Secretary in the event of default under the public housing annual contributions contract entered into by the small public housing agency under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1437c"},"text":"section 1437c of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb0c9d17-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437z–10/c/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emergency actions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this paragraph may be construed to prohibit the Secretary from taking any emergency action necessary to protect Federal financial resources or the health or safety of residents of public housing projects.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb0c9d18-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437z–10/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reduction of administrative burdens","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb0c9d19-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437z–10/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, a small public housing agency shall be exempt from any environmental review requirements with respect to a development or modernization project having a total cost of not more than $100,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb0c9d1a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437z–10/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Streamlined procedures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall, by rule, establish streamlined procedures for environmental reviews of small public housing agency development and modernization projects having a total cost of more than $100,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbb0c9d1b-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1937-09-01/ch896"},"text":"Sept. 1, 1937, ch. 896","children":[],"tail":", title I, § 38, as added "},{"tag":"ref","attrib":{"href":"/us/pl/115/174/tII/s209/a"},"text":"Pub. L. 115–174, title II, § 209(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-05-24"},"text":"May 24, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1313"},"text":"132 Stat. 1313","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbb0c9d1c-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbb0c9d1d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbb0c9d1e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 60 days after ","children":[{"tag":"date","attrib":{"date":"2018-05-24"},"text":"May 24, 2018","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/115/174/s209/d"},"text":"section 209(d) of Pub. L. 115–174","children":[],"tail":", set out as an Effective Date of 2018 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1437g"},"text":"section 1437g of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
