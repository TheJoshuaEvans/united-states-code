{"tag":"section","attrib":{"id":"idb6de0eca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300kk"},"text":null,"children":[{"tag":"num","attrib":{"value":"300kk"},"text":"§ 300kk.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data collection, analysis, and quality","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb6de0ecb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300kk/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data collection","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6de0ecc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300kk/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall ensure that, by not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2010-03-23"},"text":"March 23, 2010","children":[],"tail":", any federally conducted or supported health care or public health program, activity or survey (including Current Population Surveys and American Community Surveys conducted by the Bureau of Labor Statistics and the Bureau of the Census) collects and reports, to the extent practicable—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6de0ecd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300kk/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" data on race, ethnicity, sex, primary language, and disability status for applicants, recipients, or participants;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6de0ece-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300kk/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" data at the smallest geographic level such as State, local, or institutional levels if such data can be aggregated;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6de0ecf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300kk/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sufficient data to generate statistically reliable estimates by racial, ethnic, sex, primary language, and disability status subgroups for applicants, recipients or participants using, if needed, statistical oversamples of these subpopulations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6de0ed0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300kk/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other demographic data as deemed appropriate by the Secretary regarding health disparities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6de0ed1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300kk/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collection standards","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In collecting data described in paragraph (1), the Secretary or designee shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6de0ed2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300kk/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use Office of Management and Budget standards, at a minimum, for race and ethnicity measures;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6de0ed3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300kk/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop standards for the measurement of sex, primary language, and disability status;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6de0ed4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300kk/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" develop standards for the collection of data described in paragraph (1) that, at a minimum—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb6de0ed5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300kk/a/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collects self-reported data by the applicant, recipient, or participant; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6de0ed6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300kk/a/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collects data from a parent or legal guardian if the applicant, recipient, or participant is a minor or legally incapacitated;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6de0ed7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300kk/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" survey health care providers and establish other procedures in order to assess access to care and treatment for individuals with disabilities and to identify—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb6de0ed8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300kk/a/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" locations where individuals with disabilities access primary, acute (including intensive), and long-term care;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6de0ed9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300kk/a/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of providers with accessible facilities and equipment to meet the needs of the individuals with disabilities, including medical diagnostic equipment that meets the minimum technical criteria set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s794f"},"text":"section 794f of title 29","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6de0eda-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300kk/a/2/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of employees of health care providers trained in disability awareness and patient care of individuals with disabilities; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6de0edb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300kk/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require that any reporting requirement imposed for purposes of measuring quality under any ongoing or federally conducted or supported health care or public health program, activity, or survey includes requirements for the collection of data on individuals receiving health care items or services under such programs activities ","children":[{"tag":"ref","attrib":{"idref":"fn002536"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002536"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original."}],"tail":" by race, ethnicity, sex, primary language, and disability status."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6de0edc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300kk/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data management","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In collecting data described in paragraph (1), the Secretary, acting through the National Coordinator for Health Information Technology shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6de0edd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300kk/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop national standards for the management of data collected; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6de0ede-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300kk/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop interoperability and security systems for data management.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6de0edf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300kk/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data analysis","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6de0ee0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300kk/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"idref":"fn002537"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002537"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. No par. (2) has been enacted."}],"tail":" In general"}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For each federally conducted or supported health care or public health program or activity, the Secretary shall analyze data collected under paragraph (a) to detect and monitor trends in health disparities (as defined for purposes of section 285t ","children":[{"tag":"ref","attrib":{"idref":"fn002538"},"text":"3","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002538"},"text":null,"children":[{"tag":"num","attrib":{},"text":"3","children":[],"tail":" See References in Text note below."}],"tail":" of this title) at the Federal and State levels."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6de0ee1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300kk/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data reporting and dissemination","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6de0ee2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300kk/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall make the analyses described in (b) ","children":[{"tag":"ref","attrib":{"idref":"fn002539"},"text":"4","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002539"},"text":null,"children":[{"tag":"num","attrib":{},"text":"4","children":[],"tail":" So in original. Probably should be preceded by “subsection”."}],"tail":" available to—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6de0ee3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300kk/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Office of Minority Health;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6de0ee4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300kk/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Center on Minority Health and Health Disparities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6de0ee5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300kk/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Agency for Healthcare Research and Quality;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6de0ee6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300kk/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Centers for Disease Control and Prevention;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6de0ee7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300kk/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Centers for Medicare & Medicaid Services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6de0ee8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300kk/c/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Indian Health Service and epidemiology centers funded under the Indian Health Care Improvement Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1601"},"text":"25 U.S.C. 1601","children":[],"tail":" et seq.];"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6de0ee9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300kk/c/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Office of Rural health; ","children":[{"tag":"ref","attrib":{"idref":"fn002540"},"text":"5","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002540"},"text":null,"children":[{"tag":"num","attrib":{},"text":"5","children":[],"tail":" So in original. Probably should be “Health;”."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6de0eea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300kk/c/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other agencies within the Department of Health and Human Services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6de0eeb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300kk/c/1/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other entities as determined appropriate by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6de0eec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300kk/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting of data","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall report data and analyses described in (a) ","children":[{"tag":"ref","attrib":{"idref":"fn002541"},"text":"6","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002541"},"text":null,"children":[{"tag":"num","attrib":{},"text":"6","children":[],"tail":" So in original. Probably should be preceded by “subsections”."}],"tail":" and (b) through—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6de0eed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300kk/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" public postings on the Internet websites of the Department of Health and Human Services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6de0eee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300kk/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other reporting or dissemination mechanisms determined appropriate by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6de0eef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300kk/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of data","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may make data described in (a) and (b) available for additional research, analyses, and dissemination to other Federal agencies, non-governmental entities, and the public, in accordance with any Federal agency’s data user agreements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6de0ef0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300kk/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on use of data","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed to permit the use of information collected under this section in a manner that would adversely affect any individual.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6de0ef1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300kk/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protection and sharing of data","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6de0ef2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300kk/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Privacy and other safeguards","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall ensure (through the promulgation of regulations or otherwise) that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6de0ef3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300kk/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" all data collected pursuant to subsection (a) is protected—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb6de0ef4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300kk/e/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under privacy protections that are at least as broad as those that the Secretary applies to other health data under the regulations promulgated under section 264(c) of the Health Insurance Portability and Accountability Act of 1996 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/191"},"text":"Public Law 104–191","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/110/2033"},"text":"110 Stat. 2033","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6de0ef5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300kk/e/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" from all inappropriate internal use by any entity that collects, stores, or receives the data, including use of such data in determinations of eligibility (or continued eligibility) in health plans, and from other inappropriate uses, as defined by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6de0ef6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300kk/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all appropriate information security safeguards are used in the collection, analysis, and sharing of data collected pursuant to subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6de0ef7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300kk/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data sharing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish procedures for sharing data collected pursuant to subsection (a), measures relating to such data, and analyses of such data, with other relevant Federal and State agencies including the agencies, centers, and entities within the Department of Health and Human Services specified in subsection (c)(1)..","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6de0ef8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300kk/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data on rural underserved populations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall ensure that any data collected in accordance with this section regarding racial and ethnic minority groups are also collected regarding underserved rural and frontier populations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6de0ef9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300kk/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of carrying out this section, there are authorized to be appropriated such sums as may be necessary for each of fiscal years 2010 through 2014.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6de0efa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300kk/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement for implementation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of this section, data may not be collected under this section unless funds are directly appropriated for such purpose in an appropriations Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6de0efb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300kk/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall consult with the Director of the Office of Personnel Management, the Secretary of Defense, the Secretary of Veterans Affairs, the Director of the Bureau of the Census, the Commissioner of Social Security, and the head of other appropriate Federal agencies in carrying out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb6de0efc-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XXXI, § 3101, as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tIV/s4302/a"},"text":"Pub. L. 111–148, title IV, § 4302(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/578"},"text":"124 Stat. 578","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb6de0efd-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb6de0efe-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb6de0eff-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s285t"},"text":"Section 285t of this title","children":[],"tail":", referred to in subsec. (b)(1), was in the original “section 485E”, meaning section 485E of act "},{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", which was renumbered section 464z–3 by "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tX/s10334/c/1/D/i"},"text":"Pub. L. 111–148, title X, § 10334(c)(1)(D)(i)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/973"},"text":"124 Stat. 973","children":[],"tail":", and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s285t"},"text":"section 285t of this title","children":[],"tail":". The act of "},{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", no longer contains a section 485E."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Indian Health Care Improvement Act, referred to in subsec. (c)(1)(F), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437"},"text":"Pub. L. 94–437","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-09-30"},"text":"Sept. 30, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1400"},"text":"90 Stat. 1400","children":[],"tail":", which is classified principally to chapter 18 (§ 1601 et seq.) of Title 25, Indians. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s1601"},"text":"section 1601 of Title 25","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 264(c) of the Health Insurance Portability and Accountability Act of 1996 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/191"},"text":"Public Law 104–191","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/110/2033"},"text":"110 Stat. 2033","children":[],"tail":"), referred to in subsec. (e)(1)(A)(i), is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320d–2"},"text":"section 1320d–2 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
