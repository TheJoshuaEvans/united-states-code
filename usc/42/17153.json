{"tag":"section","attrib":{"id":"idc029aaf2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17153"},"text":null,"children":[{"tag":"num","attrib":{"value":"17153"},"text":"§ 17153.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation of funds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc029aaf3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17153/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Of amounts made available to provide grants under this part for each fiscal year, the Secretary shall allocate—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc029aaf4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17153/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 34 percent to eligible units of local government—alternative 1, in accordance with subsection (b);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc029aaf5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17153/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 34 percent to eligible units of local government—alternative 2, in accordance with subsection (b);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc029aaf6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17153/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 28 percent to States in accordance with subsection (c);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc029aaf7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17153/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 2 percent to Indian tribes in accordance with subsection (d); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc029aaf8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17153/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 2 percent for competitive grants under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s17156"},"text":"section 17156 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc029aaf9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17153/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible units of local government","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Of amounts available for distribution to eligible units of local government under subsection (a)(1) or (2), the Secretary shall provide grants to eligible units of local government under this section based on a formula established by the Secretary according to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc029aafa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17153/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the populations served by the eligible units of local government, according to the latest available decennial census; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc029aafb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17153/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the daytime populations of the eligible units of local government and other similar factors (such as square footage of commercial, office, and industrial space), as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc029aafc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17153/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" States","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Of amounts available for distribution to States under subsection (a)(2), the Secretary shall provide—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc029aafd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17153/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than 1.25 percent to each State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc029aafe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17153/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the remainder among the States, based on a formula to be established by the Secretary that takes into account—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc029aaff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17153/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the population of each State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc029ab00-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17153/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other criteria that the Secretary determines to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc029ab01-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17153/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian tribes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of amounts available for distribution to Indian tribes under subsection (a)(3), the Secretary shall establish a formula for allocation of the amounts to Indian tribes, taking into account any factors that the Secretary determines to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc029ab02-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17153/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication of allocation formulas","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 90 days before the beginning of each fiscal year for which grants are provided under this part, the Secretary shall publish in the Federal Register the formulas for allocation established under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc029ab03-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17153/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State and local advisory committee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a State and local advisory committee to advise the Secretary regarding administration, implementation, and evaluation of the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc029ab04-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/tV/s543"},"text":"Pub. L. 110–140, title V, § 543","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1668"},"text":"121 Stat. 1668","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/5/dA/tIV/s404/a"},"text":"Pub. L. 111–5, div. A, title IV, § 404(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2009-02-17"},"text":"Feb. 17, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/143"},"text":"123 Stat. 143","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc029ab05-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc029ab06-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc029ab07-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2009—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/5/s404/a/2"},"text":"Pub. L. 111–5, § 404(a)(2)","children":[],"tail":", added par. (1) and struck out former par. (1) which read as follows: “68 percent to eligible units of local government in accordance with subsection (b);”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2) to (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/5/s404/a"},"text":"Pub. L. 111–5, § 404(a)","children":[],"tail":", added par. (2) and redesignated former pars. (2) to (4) as (3) to (5), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/5/s404/b"},"text":"Pub. L. 111–5, § 404(b)","children":[],"tail":", substituted “subsection (a)(1) or (2)” for “subsection (a)(1)” in introductory provisions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc029ab08-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc029ab09-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the date that is 1 day after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/s1601"},"text":"section 1601 of Pub. L. 110–140","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1824"},"text":"section 1824 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
