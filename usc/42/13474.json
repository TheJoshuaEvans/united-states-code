{"tag":"section","attrib":{"id":"idbfc3211e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13474"},"text":null,"children":[{"tag":"num","attrib":{"value":"13474"},"text":"§ 13474.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fusion energy","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfc3211f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13474/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall conduct a fusion energy 5-year program, in accordance with sections 13541 and 13542 of this title, that by the year 2010 will result in a technology demonstration which verifies the practicability of commercial electric power production.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfc32120-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13474/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program goals","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The goals of the program established under subsection (a) shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfc32121-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13474/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a broad based fusion energy program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc32122-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13474/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" United States participation in the Engineering Design Activity of the International Thermonuclear Experimental Reactor (ITER) program and in the related research and technology development efforts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc32123-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13474/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development of technology for fusion power and industrial participation in the development of such technology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc32124-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13474/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the design and construction of a major new machine for fusion research and technology development consistent with paragraphs (2) and (3); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc32125-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13474/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" research and development for Inertial Confinement Fusion Energy and development of a Heavy Ion Inertial Confinement Fusion experiment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfc32126-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13474/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management plan","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfc32127-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13474/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Within 180 days after ","children":[{"tag":"date","attrib":{"date":"1992-10-24"},"text":"October 24, 1992","children":[],"tail":", the Secretary shall prepare a comprehensive management plan for the fusion energy program. The plan shall include specific program objectives, milestones and schedules for technology development, and cost estimates and program management resource requirements."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc32128-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13474/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The plan shall also include a description of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfc32129-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13474/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" United States participation in the Engineering Design Activity of ITER, including industrial participation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfc3212a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13474/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" potential United States participation in the construction and operation of an ITER facility; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfc3212b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13474/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the requirements needed to build and test an inertial fusion energy reactor for the purpose of power production.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc3212c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13474/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" As part of the plan required under paragraph (1), the Secretary shall evaluate the status of international fusion programs and evaluate whether the Federal Government should initiate efforts to strengthen existing international cooperative agreements in fusion energy or enter into new cooperative agreements to accomplish the purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc3212d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13474/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The plan shall also evaluate the extent to which university or private sector participation is appropriate or necessary in order to carry out the purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc3212e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13474/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The President shall include in the budget submitted to the Congress each year under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105"},"text":"section 1105 of title 31","children":[],"tail":" a report prepared by the Secretary describing the progress made in meeting the program objectives, milestones, and schedules established in the management plan. Each such report shall also describe the organization of the program, the personnel assigned and funds committed to the program, and expenditures made in carrying out the program objectives. The report shall be submitted with the plan required under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s13523"},"text":"section 13523 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfc3212f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13474/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to the Secretary for carrying out this section $339,710,000 for fiscal year 1993 and $380,000,000 for fiscal year 1994.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfc32130-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/tXXI/s2114"},"text":"Pub. L. 102–486, title XXI, § 2114","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3073"},"text":"106 Stat. 3073","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/66/tI/s1052/i"},"text":"Pub. L. 104–66, title I, § 1052(i)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-21"},"text":"Dec. 21, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/719"},"text":"109 Stat. 719","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbfc32131-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbfc32132-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbfc32133-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1995—Subsec. (c)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/66"},"text":"Pub. L. 104–66","children":[],"tail":" inserted first sentence and struck out former first sentence which read as follows: “Within 1 year after "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"October 24, 1992","children":[],"tail":", and every 2 years thereafter, the Secretary shall issue a report describing the progress made in meeting the program objectives, milestones, and schedules established in the management plan.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
