{"tag":"section","attrib":{"id":"idbfc320b1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13455"},"text":null,"children":[{"tag":"num","attrib":{"value":"13455"},"text":"§ 13455.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Electric drives","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfc320b2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13455/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall conduct a 5-year program, in accordance with sections 13541 and 13542 of this title, to increase the efficiency of electric drive technologies, including adjustable speed drives, high speed motors, and high efficiency motors.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfc320b3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13455/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Proposals","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Within 1 year after ","children":[{"tag":"date","attrib":{"date":"1992-10-24"},"text":"October 24, 1992","children":[],"tail":", the Secretary shall solicit proposals for projects under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfc320b4-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/tXXI/s2105"},"text":"Pub. L. 102–486, title XXI, § 2105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3070"},"text":"106 Stat. 3070","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
