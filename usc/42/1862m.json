{"tag":"section","attrib":{"id":"idbb8883aa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862m"},"text":null,"children":[{"tag":"num","attrib":{"value":"1862m"},"text":"§ 1862m.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial disclosure","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Persons temporarily employed by or at the Foundation shall be subject to the same financial disclosure requirements and related sanctions under chapter 131 of title 5 as are permanent employees of the Foundation in equivalent positions.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbb8883ab-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/207/tII/s204"},"text":"Pub. L. 105–207, title II, § 204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-07-29"},"text":"July 29, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/876"},"text":"112 Stat. 876","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/c/44"},"text":"Pub. L. 117–286, § 4(c)(44)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4359"},"text":"136 Stat. 4359","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbb8883ac-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbb8883ad-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbb8883ae-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the National Science Foundation Authorization Act of 1998, and not as part of the National Science Foundation Act of 1950 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbb8883af-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":" substituted “chapter 131 of title 5” for “the Ethics in Government Act of 1978 (5 U.S.C. App.)”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
