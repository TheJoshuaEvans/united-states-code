{"tag":"section","attrib":{"id":"idbdbb4240-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6806"},"text":null,"children":[{"tag":"num","attrib":{"value":"6806"},"text":"§ 6806.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statement in annual report","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary shall include in each annual report submitted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7267"},"text":"section 7267 of this title","children":[],"tail":" a statement with respect to activities conducted under this subchapter and recommendations as to the need for and types of further Federal legislation."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbdbb4241-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/385/tII/s206"},"text":"Pub. L. 94–385, title II, § 206","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-08-14"},"text":"Aug. 14, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1144"},"text":"90 Stat. 1144","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/617/tI/s143"},"text":"Pub. L. 95–617, title I, § 143","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-09"},"text":"Nov. 9, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3134"},"text":"92 Stat. 3134","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/470/tII/s203/g"},"text":"Pub. L. 96–470, title II, § 203(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-19"},"text":"Oct. 19, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2243"},"text":"94 Stat. 2243","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbdbb4242-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbdbb4243-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbdbb4244-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1980—","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/470"},"text":"Pub. L. 96–470","children":[],"tail":" substituted “The Secretary shall include in each annual report submitted under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s7267"},"text":"section 7267 of this title","children":[],"tail":" a statement” for “Not later than the last day in December in each year, the Secretary shall transmit to the Congress a report”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/617"},"text":"Pub. L. 95–617","children":[],"tail":" substituted “Secretary” for “Administrator”, meaning Administrator of the Federal Energy Administration."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
