{"tag":"section","attrib":{"id":"idb9c1315e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395rr–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1395rr–1"},"text":"§ 1395rr–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Medicare coverage for individuals exposed to environmental health hazards","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb9c1315f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395rr–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deeming of individuals as eligible for medicare benefits","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9c13160-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395rr–1/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of eligibility for benefits under this subchapter, an individual determined under subsection (c) to be an environmental exposure affected individual described in subsection (e)(2) shall be deemed to meet the conditions specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s426/a"},"text":"section 426(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9c13161-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395rr–1/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Discretionary deeming","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of eligibility for benefits under this subchapter, the Secretary may deem an individual determined under subsection (c) to be an environmental exposure affected individual described in subsection (e)(3) to meet the conditions specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s426/a"},"text":"section 426(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9c13162-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395rr–1/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date of coverage","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An Individual ","children":[{"tag":"ref","attrib":{"idref":"fn002940"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002940"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should not be capitalized."}],"tail":" who is deemed eligible for benefits under this subchapter under paragraph (1) or (2) shall be—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9c13163-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395rr–1/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" entitled to benefits under the program under Part ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" A as of the date of such deeming; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9c13164-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395rr–1/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" eligible to enroll in the program under Part ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" B beginning with the month in which such deeming occurs."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9c13165-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395rr–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pilot program for care of certain individuals residing in emergency declaration areas","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9c13166-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395rr–1/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program; purpose","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9c13167-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395rr–1/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Primary pilot program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a pilot program in accordance with this subsection to provide innovative approaches to furnishing comprehensive, coordinated, and cost-effective care under this subchapter to individuals described in paragraph (2)(A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9c13168-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395rr–1/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Optional pilot programs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may establish a separate pilot program, in accordance with this subsection, with respect to each geographic area subject to an emergency declaration (other than the declaration of ","children":[{"tag":"date","attrib":{"date":"2009-06-17"},"text":"June 17, 2009","children":[],"tail":"), in order to furnish such comprehensive, coordinated and cost-effective care to individuals described in subparagraph (2)(B) who reside in each such area."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9c13169-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395rr–1/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Individual described","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of paragraph (1), an individual described in this paragraph is an individual who enrolls in part B, submits to the Secretary an application to participate in the applicable pilot program under this subsection, and—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9c1316a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395rr–1/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is an environmental exposure affected individual described in subsection (e)(2) who resides in or around the geographic area subject to an emergency declaration made as of ","children":[{"tag":"date","attrib":{"date":"2009-06-17"},"text":"June 17, 2009","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9c1316b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395rr–1/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is an environmental exposure affected individual described in subsection (e)(3) who—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb9c1316c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395rr–1/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is deemed under subsection (a)(2); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb9c1316d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395rr–1/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meets such other criteria or conditions for participation in a pilot program under paragraph (1)(B) as the Secretary specifies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9c1316e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395rr–1/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Flexible benefits and services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A pilot program under this subsection may provide for the furnishing of benefits, items, or services not otherwise covered or authorized under this subchapter, if the Secretary determines that furnishing such benefits, items, or services will further the purposes of such pilot program (as described in paragraph (1)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9c1316f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395rr–1/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Innovative reimbursement methodologies","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of the pilot program under this subsection, the Secretary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9c13170-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395rr–1/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall develop and implement appropriate methodologies to reimburse providers for furnishing benefits, items, or services for which payment is not otherwise covered or authorized under this subchapter, if such benefits, items, or services are furnished pursuant to paragraph (3); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9c13171-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395rr–1/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may develop and implement innovative approaches to reimbursing providers for any benefits, items, or services furnished under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9c13172-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395rr–1/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Consistent with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395y/b"},"text":"section 1395y(b) of this title","children":[],"tail":", no payment shall be made under the pilot program under this subsection with respect to benefits, items, or services furnished to an environmental exposure affected individual (as defined in subsection (e)) to the extent that such individual is eligible to receive such benefits, items, or services through any other public or private benefits plan or legal agreement."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9c13173-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395rr–1/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may waive such provisions of this subchapter and subchapter XI as are necessary to carry out pilot programs under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9c13174-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395rr–1/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of carrying out pilot programs under this subsection, the Secretary shall provide for the transfer, from the Federal Hospital Insurance Trust Fund under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395i"},"text":"section 1395i of this title","children":[],"tail":" and the Federal Supplementary Medical Insurance Trust Fund under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395t"},"text":"section 1395t of this title","children":[],"tail":", in such proportion as the Secretary determines appropriate, of such sums as the Secretary determines necessary, to the Centers for Medicare & Medicaid Services Program Management Account."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9c13175-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395rr–1/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver of budget neutrality","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall not require that pilot programs under this subsection be budget neutral with respect to expenditures under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9c13176-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395rr–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determinations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9c13177-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395rr–1/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" By the Commissioner of Social Security","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the Commissioner of Social Security, in consultation with the Secretary, and using the cost allocation method prescribed in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s401/g"},"text":"section 401(g) of this title","children":[],"tail":", shall determine whether individuals are environmental exposure affected individuals."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9c13178-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395rr–1/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" By the Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall determine eligibility for pilot programs under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9c13179-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395rr–1/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emergency declaration defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “emergency declaration” means a declaration of a public health emergency under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s9604/a"},"text":"section 9604(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9c1317a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395rr–1/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Environmental exposure affected individual defined","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9c1317b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395rr–1/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “environmental exposure affected individual” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9c1317c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395rr–1/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an individual described in paragraph (2); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9c1317d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395rr–1/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an individual described in paragraph (3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9c1317e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395rr–1/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Individual described","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9c1317f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395rr–1/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An individual described in this paragraph is any individual who—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb9c13180-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395rr–1/e/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is diagnosed with 1 or more conditions described in subparagraph (B);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb9c13181-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395rr–1/e/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" as demonstrated in such manner as the Secretary determines appropriate, has been present for an aggregate total of 6 months in the geographic area subject to an emergency declaration specified in subsection (b)(2)(A), during a period ending—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb9c13182-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395rr–1/e/2/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than 10 years prior to such diagnosis; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb9c13183-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395rr–1/e/2/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prior to the implementation of all the remedial and removal actions specified in the Record of Decision for Operating Unit 4 and the Record of Decision for Operating Unit 7;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb9c13184-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395rr–1/e/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" files an application for benefits under this subchapter (or has an application filed on behalf of the individual), including pursuant to this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb9c13185-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395rr–1/e/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is determined under this section to meet the criteria in this subparagraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9c13186-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395rr–1/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conditions described","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subparagraph (A), the following conditions are described in this subparagraph:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb9c13187-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395rr–1/e/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Asbestosis, pleural thickening, or pleural plaques as established by—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb9c13188-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395rr–1/e/2/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" interpretation by a “B Reader” qualified physician of a plain chest x-ray or interpretation of a computed tomographic radiograph of the chest by a qualified physician, as determined by the Secretary; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb9c13189-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395rr–1/e/2/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other diagnostic standards as the Secretary specifies,","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":" except that this clause shall not apply to pleural thickening or pleural plaques unless there are symptoms or conditions requiring medical treatment as a result of these diagnoses.","children":[],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb9c1318a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395rr–1/e/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Mesothelioma, or malignancies of the lung, colon, rectum, larynx, stomach, esophagus, pharynx, or ovary, as established by—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb9c1318b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395rr–1/e/2/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pathologic examination of biopsy tissue;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb9c1318c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395rr–1/e/2/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cytology from bronchioalveolar lavage; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb9c1318d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395rr–1/e/2/B/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other diagnostic standards as the Secretary specifies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb9c1318e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395rr–1/e/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other diagnosis which the Secretary, in consultation with the Commissioner of Social Security, determines is an asbestos-related medical condition, as established by such diagnostic standards as the Secretary specifies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9c1318f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395rr–1/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other individual described","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An individual described in this paragraph is any individual who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9c13190-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395rr–1/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not an individual described in paragraph (2);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9c13191-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395rr–1/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is diagnosed with a medical condition caused by the exposure of the individual to a public health hazard to which an emergency declaration applies, based on such medical conditions, diagnostic standards, and other criteria as the Secretary specifies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9c13192-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395rr–1/e/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as demonstrated in such manner as the Secretary determines appropriate, has been present for an aggregate total of 6 months in the geographic area subject to the emergency declaration involved, during a period determined appropriate by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9c13193-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395rr–1/e/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" files an application for benefits under this subchapter (or has an application filed on behalf of the individual), including pursuant to this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9c13194-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395rr–1/e/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is determined under this section to meet the criteria in this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb9c13195-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title XVIII, § 1881A, as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tX/s10323/a"},"text":"Pub. L. 111–148, title X, § 10323(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/954"},"text":"124 Stat. 954","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9c13196-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb9c13197-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb9c13198-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Parts A and B, referred to in subsecs. (a)(3) and (b)(2), are classified to sections 1395c et seq. and 1395j et seq., respectively, of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
