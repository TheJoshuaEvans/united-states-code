{"tag":"section","attrib":{"id":"idbfdfcff4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15097"},"text":null,"children":[{"tag":"num","attrib":{"value":"15097"},"text":"§ 15097.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"A State that receives a grant under this subchapter shall prepare and submit to the Secretary, at the end of the grant period, a report containing the results of State efforts to develop and implement, or expand and enhance, a statewide system of family support services for families of children with disabilities.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbfdfcff5-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/402/tII/s208"},"text":"Pub. L. 106–402, title II, § 208","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1732"},"text":"114 Stat. 1732","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
