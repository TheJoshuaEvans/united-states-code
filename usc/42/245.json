{"tag":"section","attrib":{"id":"idb49aade3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s245"},"text":null,"children":[{"tag":"num","attrib":{"value":"245"},"text":"§ 245.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public awareness campaign on the importance of vaccinations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb49aade4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s245/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Director of the Centers for Disease Control and Prevention and in coordination with other offices and agencies, as appropriate, shall award competitive grants or contracts to one or more public or private entities to carry out a national, evidence-based campaign to increase awareness and knowledge of the safety and effectiveness of vaccines for the prevention and control of diseases, combat misinformation about vaccines, and disseminate scientific and evidence-based vaccine-related information, with the goal of increasing rates of vaccination across all ages, as applicable, particularly in communities with low rates of vaccination, to reduce and eliminate vaccine-preventable diseases.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb49aade5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s245/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out the campaign under this section, the Secretary shall consult with appropriate public health and medical experts, including the National Academy of Medicine and medical and public health associations and nonprofit organizations, in the development, implementation, and evaluation of the evidence-based public awareness campaign.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb49aade6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s245/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The campaign under this section shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb49aade7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s245/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be a nationwide, evidence-based media and public engagement initiative;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb49aade8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s245/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include the development of resources for communities with low rates of vaccination, including culturally and linguistically appropriate resources, as applicable;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb49aade9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s245/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include the dissemination of vaccine information and communication resources to public health departments, health care providers, and health care facilities, including such providers and facilities that provide prenatal and pediatric care;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb49aadea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s245/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be complementary to, and coordinated with, any other Federal, State, local, or Tribal efforts, as appropriate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb49aadeb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s245/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assess the effectiveness of communication strategies to increase rates of vaccination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb49aadec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s245/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The campaign under this section may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb49aaded-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s245/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include the use of television, radio, the internet, and other media and telecommunications technologies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb49aadee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s245/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include the use of in-person activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb49aadef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s245/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be focused to address specific needs of communities and populations with low rates of vaccination; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb49aadf0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s245/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" include the dissemination of scientific and evidence-based vaccine-related information, such as—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb49aadf1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s245/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advancements in evidence-based research related to diseases that may be prevented by vaccines and vaccine development;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb49aadf2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s245/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information on vaccinations for individuals and communities, including individuals for whom vaccines are not recommended by the Advisory Committee for Immunization Practices, and the effects of low vaccination rates within a community on such individuals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb49aadf3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s245/d/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information on diseases that may be prevented by vaccines; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb49aadf4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s245/d/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information on vaccine safety and the systems in place to monitor vaccine safety.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb49aadf5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s245/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb49aadf6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s245/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish benchmarks and metrics to quantitatively measure and evaluate the awareness campaign under this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb49aadf7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s245/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct qualitative assessments regarding the awareness campaign under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb49aadf8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s245/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prepare and submit to the Committee on Health, Education, Labor, and Pensions of the Senate and Committee on Energy and Commerce of the House of Representatives an evaluation of the awareness campaign under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb49aadf9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s245/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supplement not supplant","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds appropriated under this section shall be used to supplement and not supplant other Federal, State, and local public funds provided for activities described in this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb49aadfa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s245/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this section and subsections (k) and (n) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s247b"},"text":"section 247b of this title","children":[],"tail":", $15,000,000 for each of fiscal years 2021 through 2025."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb49aadfb-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title III, § 313, as added "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dBB/tIII/s311/a"},"text":"Pub. L. 116–260, div. BB, title III, § 311(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2923"},"text":"134 Stat. 2923","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb49aadfc-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb49aadfd-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb49aadfe-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 245, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373/tIII/s313"},"text":"act July 1, 1944, ch. 373, title III, § 313","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/188/tI/s159/c"},"text":"Pub. L. 107–188, title I, § 159(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-06-12"},"text":"June 12, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/636"},"text":"116 Stat. 636","children":[],"tail":", provided for public access defibrillation demonstration projects, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dBB/tIII/s311/a"},"text":"Pub. L. 116–260, div. BB, title III, § 311(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2923"},"text":"134 Stat. 2923","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 245, acts ","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title III, § 313, "},{"tag":"ref","attrib":{"href":"/us/stat/58/693"},"text":"58 Stat. 693","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1970-10-30"},"text":"Oct. 30, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/91/515/tII/s282"},"text":"Pub. L. 91–515, title II, § 282","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1308"},"text":"84 Stat. 1308","children":[],"tail":", provided for collection of vital statistics, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/93/353/tI/s102/a"},"text":"Pub. L. 93–353, title I, § 102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-07-23"},"text":"July 23, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/362"},"text":"88 Stat. 362","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s242k/g"},"text":"section 242k(g) of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior section 313 of act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s245a"},"text":"section 245a of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/94/484"},"text":"Pub. L. 94–484","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb49aadff-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb49aae00-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Maternal Vaccination Awareness","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/dP/tI/s135"},"text":"Pub. L. 117–103, div. P, title I, § 135","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/797"},"text":"136 Stat. 797","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/103/dP/tI/s135"},"text":"“In carrying out the public awareness initiative related to vaccinations pursuant to section 313 of the Public Health Service Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s245"},"text":"42 U.S.C. 245","children":[],"tail":"), the Secretary of Health and Human Services shall take into consideration the importance of increasing awareness and knowledge of the safety and effectiveness of vaccines to prevent disease in pregnant and postpartum women and in infants and the need to improve vaccination rates in communities and populations with low rates of vaccination.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
