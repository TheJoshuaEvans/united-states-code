{"tag":"section","attrib":{"id":"idbf7e00d0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12603"},"text":null,"children":[{"tag":"num","attrib":{"value":"12603"},"text":"§ 12603.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of the amount of the educational award","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf7e00d1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12603/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount for full-time national service","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subsection (c), an individual described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12602/a"},"text":"section 12602(a) of this title","children":[],"tail":" who successfully completes a required term of full-time national service in an approved national service position shall receive a national service educational award having a value equal to the maximum amount of a Federal Pell Grant under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070a"},"text":"section 1070a of title 20","children":[],"tail":" that a student eligible for such Grant may receive in the aggregate (without regard to whether the funds are provided through discretionary or mandatory appropriations), for the award year for which the national service position is approved by the Corporation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf7e00d2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12603/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount for part-time national service","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subsection (c), an individual described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12602/a"},"text":"section 12602(a) of this title","children":[],"tail":" who successfully completes a required term of part-time national service in an approved national service position shall receive a national service educational award having a value equal to 50 percent of value of the national service educational award determined under subsection (a)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf7e00d3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12603/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Award for partial completion of service","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If an individual serving in an approved national service position is released in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12593/c/1/A"},"text":"section 12593(c)(1)(A) of this title","children":[],"tail":" from completing the full-time or part-time term of service agreed to by the individual, the Corporation may provide the individual with that portion of the national service educational award approved for the individual that corresponds to the quantity of the term of service actually completed by the individual."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf7e00d4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12603/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount for summer of service","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An individual described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12602/a"},"text":"section 12602(a) of this title","children":[],"tail":" who successfully completes a required summer of service term shall receive a summer of service educational award having a value, for each of not more than 2 of such terms of service, equal to $500 (or, at the discretion of the Chief Executive Officer, equal to $750 in the case of a participant who is economically disadvantaged)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf7e00d5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12603/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount for silver scholars","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An individual described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12602/a"},"text":"section 12602(a) of this title","children":[],"tail":" who successfully completes a required silver scholar term shall receive a silver scholar educational award having a value of $1,000."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf7e00d6-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/610/tI/s147"},"text":"Pub. L. 101–610, title I, § 147","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/tI/s102/a"},"text":"Pub. L. 103–82, title I, § 102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-09-21"},"text":"Sept. 21, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/819"},"text":"107 Stat. 819","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/13/tI/s1404"},"text":"Pub. L. 111–13, title I, § 1404","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-04-21"},"text":"Apr. 21, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1515"},"t