{"tag":"section","attrib":{"id":"idbdbb41d8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6730"},"text":null,"children":[{"tag":"num","attrib":{"value":"6730"},"text":"§ 6730.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbdbb41d9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6730/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time and amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"From the amount allocated for State and local governments under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6723"},"text":"section 6723 of this title","children":[],"tail":", the Secretary shall pay not later than five days after the beginning of each quarter to each State and to each local government which has filed a statement of assurances under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s6725"},"text":"section 6725 of this title","children":[],"tail":", an amount equal to the amount allocated to such State or local government under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s6723"},"text":"section 6723 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdbb41da-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6730/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Payments under this subchapter may be made with necessary adjustments on account of overpayments or underpayments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdbb41db-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6730/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No amount shall be paid to any State or local government under the provisions of this section for any calendar quarter if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbdbb41dc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6730/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the average rate of unemployment within the jurisdiction of such State or local government during the most recent calendar quarter which ended three months before the beginning of such calendar quarter was less than 4.5 percent, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdbb41dd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6730/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the rate of unemployment within the jurisdiction of such government for the last month of the most recent calendar quarter which ended three months before the beginning of such calendar quarter did not exceed 4.5 percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbdbb41de-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/369/tII/s210"},"text":"Pub. L. 94–369, title II, § 210","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-07-22"},"text":"July 22, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1009"},"text":"90 Stat. 1009","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/447/tII/s201"},"text":"Pub. L. 94–447, title II, § 201","children":[],"tail":" (5), "},{"tag":"date","attrib":{"date":"1976-10-01"},"text":"Oct. 1, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1498"},"text":"90 Stat. 1498","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbdbb41df-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbdbb41e0-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbdbb41e1-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1976—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/447"},"text":"Pub. L. 94–447","children":[],"tail":" substituted “4.5 percent, or” for “4.5 percent, and”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
