{"tag":"section","attrib":{"id":"idbf31b5cc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10851"},"text":null,"children":[{"tag":"num","attrib":{"value":"10851"},"text":"§ 10851.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction of subchapters I and II; “individual with mental illness” defined","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf31b5cd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10851/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subchapters I and II shall not be construed as establishing any new rights for individuals with mental illness.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf31b5ce-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10851/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of this section, the term “individual with mental illness” has the same meaning as in section 10802(3) ","children":[{"tag":"ref","attrib":{"idref":"fn003978"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003978"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf31b5cf-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/319/tIII/s301"},"text":"Pub. L. 99–319, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-05-23"},"text":"May 23, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/489"},"text":"100 Stat. 489","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/173/s10"},"text":"Pub. L. 102–173, § 10","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-11-27"},"text":"Nov. 27, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1219"},"text":"105 Stat. 1219","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf31b5d0-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf31b5d1-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbf31b5d2-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s10802/3"},"text":"Section 10802(3) of this title","children":[],"tail":", referred to in subsec. (b), was redesignated "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s10802/4"},"text":"section 10802(4) of this title","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/102/173/s4/1"},"text":"Pub. L. 102–173, § 4(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-11-27"},"text":"Nov. 27, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1217"},"text":"105 Stat. 1217","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbf31b5d3-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/173"},"text":"Pub. L. 102–173","children":[],"tail":", substituted “individuals with mental illness” for “mentally ill individuals” in subsec. (a) and “individual with mental illness” for “mentally ill individual” in subsec. (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
