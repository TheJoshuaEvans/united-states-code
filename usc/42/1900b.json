{"tag":"section","attrib":{"id":"idbba0783b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1900b"},"text":null,"children":[{"tag":"num","attrib":{"value":"1900b"},"text":"§ 1900b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amendment, modification, or repeal of authorizations for execution of contracts for research","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing contained in this chapter is intended to amend, modify, or repeal any provisions of law administered by the Secretary of the Interior which authorize the making of contracts for research.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbba0783c-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/672/s3"},"text":"Pub. L. 89–672, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-10-15"},"text":"Oct. 15, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/951"},"text":"80 Stat. 951","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
