{"tag":"section","attrib":{"id":"idc06a0e97-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18773"},"text":null,"children":[{"tag":"num","attrib":{"value":"18773"},"text":"§ 18773.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expansion of energy consumption surveys","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc06a0e98-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18773/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2021-11-15"},"text":"November 15, 2021","children":[],"tail":", the Administrator shall implement measures to expand the Manufacturing Energy Consumption Survey, the Commercial Building Energy Consumption Survey, and the Residential Energy Consumption Survey to include data on energy end use in order to facilitate the identification of—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc06a0e99-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18773/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" opportunities to improve energy efficiency and energy productivity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06a0e9a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18773/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" changing patterns of energy use; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06a0e9b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18773/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" opportunities to better understand and manage miscellaneous electric loads.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc06a0e9c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18773/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc06a0e9d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18773/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out subsection (a), the Administrator shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc06a0e9e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18773/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase the scope and frequency of data collection on energy end uses and services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06a0e9f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18773/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" use new data collection methods and tools in order to obtain more comprehensive data and reduce the burden on survey respondents, including by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc06a0ea0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18773/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accessing other existing data sources; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc06a0ea1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18773/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if feasible, developing online and real-time reporting systems;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06a0ea2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18773/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" identify and report community-level economic and environmental impacts, including with respect to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc06a0ea3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18773/b/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reliability and security of the energy supply; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc06a0ea4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18773/b/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" local areas with households with a high energy burden; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06a0ea5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18773/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" improve the presentation of data, including by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc06a0ea6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18773/b/1/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enabling the presentation of data in an interactive cartographic format on a national, regional, State, and local level with the functionality of viewing various economic, energy, and demographic measures on an individual basis or in combination; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc06a0ea7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18773/b/1/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" incorporating the results of the data collection, methods, and tools described in subparagraphs (A) and (B) into existing and new digital distribution methods.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06a0ea8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18773/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Manufacturing Energy Consumption Survey","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to the Manufacturing Energy Consumption Survey, the Administrator shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc06a0ea9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18773/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" implement measures to provide more detailed representations of data by region;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06a0eaa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18773/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for large manufacturing facilities, break out process heat use by required process temperatures in order to facilitate the identification of opportunities for cost reductions and energy efficiency or energy productivity improvements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06a0eab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18773/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" collect information on—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc06a0eac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18773/b/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" energy source-switching capabilities, especially with respect to thermal processes and the efficiency of thermal processes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc06a0ead-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18773/b/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use of electricity, biofuels, hydrogen, or other alternative fuels to produce process heat; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc06a0eae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18773/b/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use of demand response; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06a0eaf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18773/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" identify current and potential future industrial clusters in which multiple firms and facilities in a defined geographic area share the costs and benefits of infrastructure for clean manufacturing, such as—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc06a0eb0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18773/b/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hydrogen generation, production, transport, use, and storage infrastructure; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc06a0eb1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18773/b/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carbon dioxide capture, transport, use, and storage infrastructure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06a0eb2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18773/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Residential Energy Consumption Survey","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to the Residential Energy Consumption Survey, the Administrator shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc06a0eb3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18773/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" implement measures to provide more detailed representations of data by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc06a0eb4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18773/b/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" geographic area, including by State (for each State);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc06a0eb5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18773/b/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" building type, including multi-family buildings;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc06a0eb6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18773/b/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" household income;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc06a0eb7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18773/b/3/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" location in a rural area; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc06a0eb8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18773/b/3/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other demographic characteristics, as determined by the Administrator; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06a0eb9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18773/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" report measures of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc06a0eba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18773/b/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" household electrical service capacity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc06a0ebb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18773/b/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" access to utility demand-side management programs and bill credits;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc06a0ebc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18773/b/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" characteristics of the energy mix used to generate electricity in different regions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc06a0ebd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18773/b/3/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the household energy burden for households—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idc06a0ebe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18773/b/3/B/iv/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in different geographic areas;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc06a0ebf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18773/b/3/B/iv/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by electricity, heating, and other end-uses; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc06a0ec0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18773/b/3/B/iv/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" with different demographic characteristics that correlate with increased household energy burden, including—","children":[],"tail":null},{"tag":"item","attrib":{"id":"idc06a0ec1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18773/b/3/B/iv/III/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" having a low household income;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idc06a0ec2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18773/b/3/B/iv/III/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" being a minority household;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idc06a0ec3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18773/b/3/B/iv/III/cc"},"text":null,"children":[{"tag":"num","attrib":{"value":"cc"},"text":"(cc)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" residing in manufactured or multifamily housing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idc06a0ec4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18773/b/3/B/iv/III/dd"},"text":null,"children":[{"tag":"num","attrib":{"value":"dd"},"text":"(dd)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" being in a fixed or retirement income household;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idc06a0ec5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18773/b/3/B/iv/III/ee"},"text":null,"children":[{"tag":"num","attrib":{"value":"ee"},"text":"(ee)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" residing in rental housing; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idc06a0ec6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18773/b/3/B/iv/III/ff"},"text":null,"children":[{"tag":"num","attrib":{"value":"ff"},"text":"(ff)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other factors, as determined by the Administrator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc06a0ec7-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dD/tIV/s40413"},"text":"Pub. L. 117–58, div. D, title IV, § 40413","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1042"},"text":"135 Stat. 1042","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc06a0ec8-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc06a0ec9-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc06a0eca-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Wage Rate Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions relating to rates of wages to be paid to laborers and mechanics on projects for construction, alteration, or repair work funded under div. D or an amendment by div. D of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":", including authority of Secretary of Labor, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s18851"},"text":"section 18851 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
