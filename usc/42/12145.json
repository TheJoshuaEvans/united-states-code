{"tag":"section","attrib":{"id":"idbf615181-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12145"},"text":null,"children":[{"tag":"num","attrib":{"value":"12145"},"text":"§ 12145.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Temporary relief where lifts are unavailable","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf615182-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12145/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Granting","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to the purchase of new buses, a public entity may apply for, and the Secretary may temporarily relieve such public entity from the obligation under section 12142(a) or 12144 of this title to purchase new buses that are readily accessible to and usable by individuals with disabilities if such public entity demonstrates to the satisfaction of the Secretary—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf615183-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12145/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that the initial solicitation for new buses made by the public entity specified that all new buses were to be lift-equipped and were to be otherwise accessible to and usable by individuals with disabilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf615184-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12145/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the unavailability from any qualified manufacturer of hydraulic, electromechanical, or other lifts for such new buses;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf615185-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12145/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that the public entity seeking temporary relief has made good faith efforts to locate a qualified manufacturer to supply the lifts to the manufacturer of such buses in sufficient time to comply with such solicitation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf615186-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12145/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that any further delay in purchasing new buses necessary to obtain such lifts would significantly impair transportation services in the community served by the public entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf615187-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12145/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration and notice to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any relief granted under subsection (a) shall be limited in duration by a specified date, and the appropriate committees of Congress shall be notified of any such relief granted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf615188-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12145/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fraudulent application","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If, at any time, the Secretary has reasonable cause to believe that any relief granted under subsection (a) was fraudulently applied for, the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf615189-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12145/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cancel such relief if such relief is still in effect; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf61518a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12145/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take such other action as the Secretary considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf61518b-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/336/tII/s225"},"text":"Pub. L. 101–336, title II, § 225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-07-26"},"text":"July 26, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/343"},"text":"104 Stat. 343","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf61518c-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbf61518d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbf61518e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1990-07-26"},"text":"July 26, 1990","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/101/336/s231/b"},"text":"section 231(b) of Pub. L. 101–336","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12141"},"text":"section 12141 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
