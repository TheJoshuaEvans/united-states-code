{"tag":"section","attrib":{"id":"idb495cbde-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s242q–5"},"text":null,"children":[{"tag":"num","attrib":{"value":"242q–5"},"text":"§ 242q–5.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"For the purpose of carrying out sections 242q to 242q–5 of this title, there are authorized to be appropriated such sums as may be necessary for each of the fiscal years 1991 through 1993.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb495cbdf-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/557/tIII/s305"},"text":"Pub. L. 101–557, title III, § 305","children":[],"tail":", formerly § 306, "},{"tag":"date","attrib":{"date":"1990-11-15"},"text":"Nov. 15, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2770"},"text":"104 Stat. 2770","children":[],"tail":"; renumbered § 305, "},{"tag":"ref","attrib":{"href":"/us/pl/109/482/tI/s104/b/3/B"},"text":"Pub. L. 109–482, title I, § 104(b)(3)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-01-15"},"text":"Jan. 15, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3694"},"text":"120 Stat. 3694","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb495cbe0-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb495cbe1-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb495cbe2-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{