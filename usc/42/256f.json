{"tag":"section","attrib":{"id":"idb5083c5c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256f"},"text":null,"children":[{"tag":"num","attrib":{"value":"256f"},"text":"§ 256f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designated dental health professional shortage area","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In this subpart, the term “designated dental health professional shortage area” means an area, population group, or facility that is designated by the Secretary as a dental health professional shortage area under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s254e"},"text":"section 254e of this title","children":[],"tail":" or designated by the applicable State as having a dental health professional shortage."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb5083c5d-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title III, § 340F, as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/251/tIV/s403"},"text":"Pub. L. 107–251, title IV, § 403","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-10-26"},"text":"Oct. 26, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1660"},"text":"116 Stat. 1660","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
