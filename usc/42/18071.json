{"tag":"section","attrib":{"id":"idc04d863e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18071"},"text":null,"children":[{"tag":"num","attrib":{"value":"18071"},"text":"§ 18071.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reduced cost-sharing for individuals enrolling in qualified health plans","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc04d863f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18071/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of an eligible insured enrolled in a qualified health plan—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc04d8640-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18071/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary shall notify the issuer of the plan of such eligibility; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc04d8641-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18071/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the issuer shall reduce the cost-sharing under the plan at the level and in the manner specified in subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc04d8642-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18071/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible insured","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “eligible insured” means an individual—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc04d8643-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18071/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who enrolls in a qualified health plan in the silver level of coverage in the individual market offered through an Exchange; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc04d8644-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18071/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whose household income exceeds 100 percent but does not exceed 400 percent of the poverty line for a family of the size involved.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"In the case of an individual described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s36B/c/1/B"},"text":"section 36B(c)(1)(B) of title 26","children":[],"tail":", the individual shall be treated as having household income equal to 100 percent for purposes of applying this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc04d8645-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18071/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of reduction in cost-sharing","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc04fcf36-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18071/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reduction in out-of-pocket limit","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc04fcf37-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18071/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The reduction in cost-sharing under this subsection shall first be achieved by reducing the applicable out-of pocket ","children":[{"tag":"ref","attrib":{"idref":"fn004331"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004331"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “out-of-pocket”."}],"tail":" limit under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s18022/c/1"},"text":"section 18022(c)(1) of this title","children":[],"tail":" in the case of—"}],"tail":null},{"tag":"clause","attrib":{"id":"idc04fcf38-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18071/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an eligible insured whose household income is more than 100 percent but not more than 200 percent of the poverty line for a family of the size involved, by two-thirds;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc04fcf39-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18071/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an eligible insured whose household income is more than 200 percent but not more than 300 percent of the poverty line for a family of the size involved, by one-half; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc04fcf3a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18071/c/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an eligible insured whose household income is more than 300 percent but not more than 400 percent of the poverty line for a family of the size involved, by one-third.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc04fcf3b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18071/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with actuarial value limits","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc04fcf3c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18071/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall ensure the reduction under this paragraph shall not result in an increase in the plan’s share of the total allowed costs of benefits provided under the plan above—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idc04fcf3d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18071/c/1/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 94 percent in the case of an eligible insured described in paragraph (2)(A);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc04fcf3e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18071/c/1/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 87 percent in the case of an eligible insured described in paragraph (2)(B);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc04fcf3f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18071/c/1/B/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 73 percent in the case of an eligible insured whose household income is more than 200 percent but not more than 250 percent of the poverty line for a family of the size involved; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc04fcf40-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18071/c/1/B/i/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 70 percent in the case of an eligible insured whose household income is more than 250 percent but not more than 400 percent of the poverty line for a family of the size involved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc04fcf41-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18071/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall adjust the out-of pocket ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" limits under paragraph (1) if necessary to ensure that such limits do not cause the respective actuarial values to exceed the levels specified in clause (i)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc04fcf42-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18071/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional reduction for lower income insureds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall establish procedures under which the issuer of a qualified health plan to which this section applies shall further reduce cost-sharing under the plan in a manner sufficient to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc04fcf43-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18071/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an eligible insured whose household income is not less than 100 percent but not more than 150 percent of the poverty line for a family of the size involved, increase the plan’s share of the total allowed costs of benefits provided under the plan to 94 percent of such costs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc04fcf44-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18071/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an eligible insured whose household income is more than 150 percent but not more than 200 percent of the poverty line for a family of the size involved, increase the plan’s share of the total allowed costs of benefits provided under the plan to 87 percent of such costs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc04fcf45-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18071/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an eligible insured whose household income is more than 200 percent but not more than 250 percent of the poverty line for a family of the size involved, increase the plan’s share of the total allowed costs of benefits provided under the plan to 73 percent of such costs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc04fcf46-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18071/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Methods for reducing cost-sharing","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc04fcf47-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18071/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An issuer of a qualified health plan making reductions under this subsection shall notify the Secretary of such reductions and the Secretary shall make periodic and timely payments to the issuer equal to the value of the reductions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc04fcf48-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18071/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Capitated payments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may establish a capitated payment system to carry out the payment of cost-sharing reductions under this section. Any such system shall take into account the value of the reductions and make appropriate risk adjustments to such payments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc04fcf49-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18071/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional benefits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a qualified health plan under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s18022/b/5"},"text":"section 18022(b)(5) of this title","children":[],"tail":" offers benefits in addition to the essential health benefits required to be provided by the plan, or a State requires a qualified health plan under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s18031/d/3/B"},"text":"section 18031(d)(3)(B) of this title","children":[],"tail":" to cover benefits in addition to the essential health benefits required to be provided by the plan, the reductions in cost-sharing under this section shall not apply to such additional benefits."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc04fcf4a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18071/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule for pediatric dental plans","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If an individual enrolls in both a qualified health plan and a plan described in section 18031(d)(2)(B)(ii)(I) ","children":[{"tag":"ref","attrib":{"idref":"fn004332"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004332"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be “18031(d)(3)(B)(ii)(I)”."}],"tail":" of this title for any plan year, subsection (a) shall not apply to that portion of any reduction in cost-sharing under subsection (c) that (under regulations prescribed by the Secretary) is properly allocable to pediatric dental benefits which are included in the essential health benefits required to be provided by a qualified health plan under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s18022/b/1/J"},"text":"section 18022(b)(1)(J) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc04fcf4b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18071/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules for Indians","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc04fcf4c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18071/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indians under 300 percent of poverty","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If an individual enrolled in any qualified health plan in the individual market through an Exchange is an Indian (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304/d"},"text":"section 5304(d) of title 25","children":[],"tail":") whose household income is not more than 300 percent of the poverty line for a family of the size involved, then, for purposes of this section—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc04fcf4d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18071/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such individual shall be treated as an eligible insured; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc04fcf4e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18071/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the issuer of the plan shall eliminate any cost-sharing under the plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc04fcf4f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18071/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Items or services furnished through Indian health providers","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If an Indian (as so defined) enrolled in a qualified health plan is furnished an item or service directly by the Indian Health Service, an Indian Tribe, Tribal Organization, or Urban Indian Organization or through referral under contract health services—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc04fcf50-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18071/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no cost-sharing under the plan shall be imposed under the plan for such item or service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc04fcf51-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18071/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the issuer of the plan shall not reduce the payment to any such entity for such item or service by the amount of any cost-sharing that would be due from the Indian but for subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc04fcf52-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18071/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall pay to the issuer of a qualified health plan the amount necessary to reflect the increase in actuarial value of the plan required by reason of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc04fcf53-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18071/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules for individuals not lawfully present","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc04fcf54-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18071/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If an individual who is an eligible insured is not lawfully present—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc04fcf55-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18071/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no cost-sharing reduction under this section shall apply with respect to the individual; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc04fcf56-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18071/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for purposes of applying this section, the determination as to what percentage a taxpayer’s household income bears to the poverty level for a family of the size involved shall be made under one of the following methods:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc04fcf57-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18071/e/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A method under which—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idc04fcf58-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18071/e/1/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the taxpayer’s family size is determined by not taking such individuals into account, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc04fcf59-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18071/e/1/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the taxpayer’s household income is equal to the product of the taxpayer’s household income (determined without regard to this subsection) and a fraction—","children":[],"tail":null},{"tag":"item","attrib":{"id":"idc04fcf5a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18071/e/1/B/i/II/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the numerator of which is the poverty line for the taxpayer’s family size determined after application of subclause (I), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idc04fcf5b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18071/e/1/B/i/II/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the denominator of which is the poverty line for the taxpayer’s family size determined without regard to subclause (I).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc04fcf5c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18071/e/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A comparable method reaching the same result as the method under clause (i).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc04fcf5d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18071/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lawfully present","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, an individual shall be treated as lawfully present only if the individual is, and is reasonably expected to be for the entire period of enrollment for which the cost-sharing reduction under this section is being claimed, a citizen or national of the United States or an alien lawfully present in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc04fcf5e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18071/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretarial authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in consultation with the Secretary of the Treasury, shall prescribe rules setting forth the methods by which calculations of family size and household income are made for purposes of this subsection. Such rules shall be designed to ensure that the least burden is placed on individuals enrolling in qualified health plans through an Exchange and taxpayers eligible for the credit allowable under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc04fcf5f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18071/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule for individuals who receive unemployment compensation during 2021","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, in the case of an individual who has received, or has been approved to receive, unemployment compensation for any week beginning during 2021, for the plan year in which such week begins—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc04fcf60-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18071/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such individual shall be treated as meeting the requirements of subsection (b)(2), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc04fcf61-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18071/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for purposes of subsections (c) and (d), there shall not be taken into account any household income of the individual in excess of 133 percent of the poverty line for a family of the size involved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc04fcf62-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18071/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions and special rules","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc04fcf63-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18071/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any term used in this section which is also used in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s36B"},"text":"section 36B of title 26","children":[],"tail":" shall have the meaning given such term by such section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc04fcf64-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18071/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on reduction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No cost-sharing reduction shall be allowed under this section with respect to coverage for any month unless the month is a coverage month with respect to which a credit is allowed to the insured (or an applicable taxpayer on behalf of the insured) under section 36B of such title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc04fcf65-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18071/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data used for eligibility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any determination under this section shall be made on the basis of the taxable year for which the advance determination is made under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s18082"},"text":"section 18082 of this title","children":[],"tail":" and not the taxable year for which the credit under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s36B"},"text":"section 36B of title 26","children":[],"tail":" is allowed."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc04fcf66-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/tI/s1402"},"text":"Pub. L. 111–148, title I, § 1402","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/220"},"text":"124 Stat. 220","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/152/tI/s1001/b"},"text":"Pub. L. 111–152, title I, § 1001(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-30"},"text":"Mar. 30, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1031"},"text":"124 Stat. 1031","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/2/tII/s2305/a"},"text":"Pub. L. 117–2, title II, § 2305(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-03-11"},"text":"Mar. 11, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/39"},"text":"135 Stat. 39","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc04fcf67-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc04fcf68-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc04fcf69-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsecs. (f), (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/2"},"text":"Pub. L. 117–2","children":[],"tail":" added subsec. (f) and redesignated former subsec. (f) as (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—Subsec. (c)(1)(B)(i)(I). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/152/s1001/b/1/A"},"text":"Pub. L. 111–152, § 1001(b)(1)(A)","children":[],"tail":", substituted “94” for “90”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(B)(i)(II). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/152/s1001/b/1/B/i"},"text":"Pub. L. 111–152, § 1001(b)(1)(B)(i)","children":[],"tail":", substituted “87” for “80”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(B)(i)(III), (IV). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/152/s1001/b/1/B/ii"},"text":"Pub. L. 111–152, § 1001(b)(1)(B)(ii)","children":[],"tail":", (C), added subcls. (III) and (IV) and struck out former subcl. (III). Prior to amendment, subcl. (III) read as follows: “70 percent in the case of an eligible insured described in clause (ii) or (iii) of subparagraph (A).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/152/s1001/b/2/A/i"},"text":"Pub. L. 111–152, § 1001(b)(2)(A)(i)","children":[],"tail":", substituted “94” for “90”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/152/s1001/b/2/B/i"},"text":"Pub. L. 111–152, § 1001(b)(2)(B)(i)","children":[],"tail":", substituted “87” for “80”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/152/s1001/b/2/A/ii"},"text":"Pub. L. 111–152, § 1001(b)(2)(A)(ii)","children":[],"tail":", (B)(ii), (C), added subpar. (C)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc04fcf6a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc04fcf6b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2021 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/2/tII/s2305/b"},"text":"Pub. L. 117–2, title II, § 2305(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-03-11"},"text":"Mar. 11, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/40"},"text":"135 Stat. 40","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/2/tII/s2305/b"},"text":"“The amendment made by this section [amending this section] shall apply to plan years beginning after ","children":[{"tag":"date","attrib":{"date":"2020-12-31"},"text":"December 31, 2020","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
