{"tag":"section","attrib":{"id":"idbc74b892-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3151"},"text":null,"children":[{"tag":"num","attrib":{"value":"3151"},"text":"§ 3151.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds in projects constructed under projected cost","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbc74b893-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3151/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a grant to a recipient for a construction project under section 3141 or 3149 of this title, if the Secretary determines, before closeout of the project, that the cost of the project, based on the designs and specifications that were the basis of the grant, has decreased because of decreases in costs, the Secretary may approve, without further appropriation, the use of the excess funds (or a portion of the excess funds) by the recipient—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc74b894-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3151/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to increase the Federal share of the cost of a project under this title to the maximum percentage allowable under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3144"},"text":"section 3144 of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc74b895-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3151/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to improve the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc74b896-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3151/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other uses of excess funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any amount of excess funds remaining after application of subsection (a) may be used by the Secretary for providing assistance under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc74b897-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3151/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transferred funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of excess funds described in subsection (a) in projects using funds transferred from other Federal agencies pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3214"},"text":"section 3214 of this title","children":[],"tail":", the Secretary shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc74b898-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3151/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use the funds in accordance with subsection (a), with the approval of the originating agency; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc74b899-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3151/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" return the funds to the originating agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc74b89a-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/136/tII/s211"},"text":"Pub. L. 89–136, title II, § 211","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/393/tI/s102/a"},"text":"Pub. L. 105–393, title I, § 102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3606"},"text":"112 Stat. 3606","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/373/tII/s208"},"text":"Pub. L. 108–373, title II, § 208","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-27"},"text":"Oct. 27, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1763"},"text":"118 Stat. 1763","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/8/dG/tI/s1301/b"},"text":"Pub. L. 111–8, div. G, title I, § 1301(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-03-11"},"text":"Mar. 11, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/829"},"text":"123 Stat. 829","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/68/dA/tI/s1501/a"},"text":"Pub. L. 111–68, div. A, title I, § 1501(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-01"},"text":"Oct. 1, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2041"},"text":"123 Stat. 2041","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc74b89b-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc74b89c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbc74b89d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Prior sections 3151 and 3151a were repealed by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/393/s102/a"},"text":"Pub. L. 105–393, § 102(a)","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 3151, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/136/tIII/s301"},"text":"Pub. L. 89–136, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-08-26"},"text":"Aug. 26, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/558"},"text":"79 Stat. 558","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/123/tIII/s302"},"text":"Pub. L. 91–123, title III, § 302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-11-25"},"text":"Nov. 25, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/219"},"text":"83 Stat. 219","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/46/s3/a"},"text":"Pub. L. 93–46, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-06-18"},"text":"June 18, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/96"},"text":"87 Stat. 96","children":[],"tail":", authorized technical assistance to alleviate or prevent excessive unemployment or underemployment."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 3151a, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/136/tIII/s302"},"text":"Pub. L. 89–136, title III, § 302","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/93/423/s5/b"},"text":"Pub. L. 93–423, § 5(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-09-27"},"text":"Sept. 27, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1159"},"text":"88 Stat. 1159","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/487/tI/s110"},"text":"Pub. L. 94–487, title I, § 110","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-12"},"text":"Oct. 12, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2333"},"text":"90 Stat. 2333","children":[],"tail":", authorized grants for economic development planning."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbc74b89e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2009—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/68"},"text":"Pub. L. 111–68","children":[],"tail":" struck out subsec. (d). Text read as follows: “The Comptroller General of the United States shall regularly review the implementation of this section.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/8"},"text":"Pub. L. 111–8","children":[],"tail":" added subsec. (d) and struck out former subsec. (d) which required the Comptroller General to review and report on the implementation of this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/373"},"text":"Pub. L. 108–373","children":[],"tail":" reenacted section catchline without change and amended text generally. Prior to amendment, text read as follows: “In any case in which a grant (including a supplementary grant described in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3145"},"text":"section 3145 of this title","children":[],"tail":") has been made by the Secretary under this subchapter (or made under this chapter, as in effect on the day before the effective date of the Economic Development Administration Reform Act of 1998) for a construction project, and, after the grant has been made but before completion of the project, the cost of the project based on the designs and specifications that was the basis of the grant has decreased because of decreases in costs—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) the Secretary may approve, subject to the availability of appropriations, the use of the excess funds or a portion of the funds to improve the project; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) any amount of excess funds remaining after application of paragraph (1) shall be deposited in the general fund of the Treasury.”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbc74b89f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbc74b8a0-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1999-02-11"},"text":"Feb. 11, 1999","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/393/s105"},"text":"section 105 of Pub. L. 105–393","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3121"},"text":"section 3121 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
