{"tag":"section","attrib":{"id":"idbf5a4c6f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11907"},"text":null,"children":[{"tag":"num","attrib":{"value":"11907"},"text":"§ 11907.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Monitoring","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf5a4c70-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11907/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall audit and monitor the programs funded under this subchapter to ensure that assistance provided under this subchapter is administered in accordance with the provisions of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf5a4c71-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11907/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition of funding baseline services","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf5a4c72-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11907/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts provided under this subchapter may not be used to reimburse or support any local law enforcement agency or unit of general local government for the provision of services that are included in the baseline of services required to be provided by any such entity pursuant to a local cooperation agreement under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1437c/e/2"},"text":"section 1437c(e)(2) of this title","children":[],"tail":" or any provision of an annual contributions contract for payments in lieu of taxation pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1437d/d"},"text":"section 1437d(d) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf5a4c73-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11907/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Description","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each public housing agency that receives grant amounts under this subchapter shall describe, in the report under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11906/a"},"text":"section 11906(a) of this title","children":[],"tail":", such baseline of services for the unit of general local government in which the jurisdiction of the agency is located."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf5a4c74-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11907/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide for the effective enforcement of this section, which may include the use of on-site monitoring, independent public audit requirements, certification by local law enforcement or local government officials regarding the performance of baseline services referred to in subsection (b), and entering into agreements with the Attorney General to achieve compliance, and verification of compliance, with the provisions of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf5a4c75-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690/tV/s5128"},"text":"Pub. L. 100–690, title V, § 5128","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/276/tV/s586/g"},"text":"Pub. L. 105–276, title V, § 586(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2649"},"text":"112 Stat. 2649","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf5a4c76-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf5a4c77-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbf5a4c78-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 11907, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690/tV/s5128"},"text":"Pub. L. 100–690, title V, § 5128","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4303"},"text":"102 Stat. 4303","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/625/tV/s581/a"},"text":"Pub. L. 101–625, title V, § 581(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4248"},"text":"104 Stat. 4248","children":[],"tail":", related to provision of periodic reports by grantees, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/105/276/tV"},"text":"Pub. L. 105–276, title V","children":[],"tail":", §§ 503, 586(g), "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2521"},"text":"112 Stat. 2521","children":[],"tail":", 2649, effective and applicable beginning upon "},{"tag":"date","attrib":{"date":"1999-10-01"},"text":"Oct. 1, 1999","children":[],"tail":", except as otherwise provided, with provision that Secretary may implement the repeal before such date, except to extent otherwise provided, and with savings provision."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbf5a4c79-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbf5a4c7a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective and applicable beginning upon ","children":[{"tag":"date","attrib":{"date":"1999-10-01"},"text":"Oct. 1, 1999","children":[],"tail":", except as otherwise provided, with provision that Secretary may implement section before such date, except to extent otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/105/276/s503"},"text":"section 503 of Pub. L. 105–276","children":[],"tail":", set out as an Effective Date of 1998 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1437"},"text":"section 1437 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbf5a4c7b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Review of Drug Elimination Program Contracts","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/276/tV/s587"},"text":"Pub. L. 105–276, title V, § 587","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2650"},"text":"112 Stat. 2650","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/276/tV/s587"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Housing and Urban Development shall investigate all security contracts awarded by grantees under the Public and Assisted Housing Drug Elimination Act of 1990 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11901"},"text":"42 U.S.C. 11901","children":[],"tail":" et seq.) that are public housing agencies that own or operate more than 4,500 public housing dwelling units—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to determine whether the contractors under such contracts have complied with all laws and regulations regarding prohibition of discrimination in hiring practices;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to determine whether such contracts were awarded in accordance with the applicable laws and regulations regarding the award of such contracts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to determine how many such contracts were awarded under emergency contracting procedures; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to evaluate the effectiveness of the contracts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 180 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":"], the Secretary shall complete the investigation required under subsection (a) and submit a report to the Congress regarding the findings under the investigation. With respect to each such contract, the report shall (1) state whether the contract was made and is operating, or was not made or is not operating, in full compliance with applicable laws and regulations, and (2) for each contract that the Secretary determines is in such compliance issue a certification of such compliance by the Secretary of Housing and Urban Development."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Actions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For each contract that is described in the report under subsection (b) as not made or not operating in full compliance with applicable laws and regulations, the Secretary of Housing and Urban Development shall promptly take any actions available under law or regulation that are necessary—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to bring such contract into compliance; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to terminate the contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effective Date","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section shall take effect on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
