{"tag":"section","attrib":{"id":"idbf9384f6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653s"},"text":null,"children":[{"tag":"num","attrib":{"value":"12653s"},"text":"§ 12653s.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonprofit capacity building","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf9384f7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653s/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf9384f8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653s/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Intermediary nonprofit grantee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “intermediary nonprofit grantee” means an intermediary nonprofit organization that receives a grant under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf9384f9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653s/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Intermediary nonprofit organization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “intermediary nonprofit organization” means an experienced and capable nonprofit entity with meaningful prior experience in providing organizational development assistance, or capacity building assistance, focused on small and midsize nonprofit organizations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf9384fa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653s/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonprofit","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “nonprofit”, used with respect to an entity or organization, means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf9384fb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653s/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an entity or organization described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s501/c/3"},"text":"section 501(c)(3) of title 26","children":[],"tail":" and exempt from taxation under section 501(a) of such title; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf9384fc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653s/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an entity or organization described in paragraph (1) or (2) of section 170(c) of such title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf9384fd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653s/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State” means each of the several States, and the District of Columbia.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf9384fe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653s/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Corporation shall establish a Nonprofit Capacity Building Program to make grants to intermediary nonprofit organizations to serve as intermediary nonprofit grantees. The Corporation shall make the grants to enable the intermediary nonprofit grantees to pay for the Federal share of the cost of delivering organizational development assistance, including training on best practices, financial planning, grantwriting, and compliance with the applicable tax laws, for small and midsize nonprofit organizations, especially those nonprofit organizations facing resource hardship challenges. Each of the grantees shall match the grant funds by providing a non-Federal share as described in subsection (f).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf9384ff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653s/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the extent practicable, the Corporation shall make such a grant to an intermediary nonprofit organization in each State, and shall make such grant in an amount of not less than $200,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf938500-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653s/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be eligible to receive a grant under this section, an intermediary nonprofit organization shall submit an application to the Corporation at such time, in such manner, and containing such information as the Corporation may require. The intermediary nonprofit organization shall submit in the application information demonstrating that the organization has secured sufficient resources to meet the requirements of subsection (f).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf938501-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653s/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preference and considerations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf938502-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653s/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preference","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In making such grants, the Corporation shall give preference to intermediary nonprofit organizations seeking to become intermediary nonprofit grantees in areas where nonprofit organizations face significant resource hardship challenges.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf938503-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653s/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Considerations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In determining whether to make a grant the Corporation shall consider—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf938504-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653s/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of small and midsize nonprofit organizations that will be served by the grant;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf938505-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653s/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the degree to which the activities proposed to be provided through the grant will assist a wide number of nonprofit organizations within a State, relative to the proposed amount of the grant; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf938506-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653s/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the quality of the organizational development assistance to be delivered by the intermediary nonprofit grantee, including the qualifications of its administrators and representatives, and its record in providing services to small and midsize nonprofit organizations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf938507-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653s/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal share","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf938508-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653s/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal share of the cost as referenced in subsection (b) shall be 50 percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf938509-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653s/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-Federal share","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf93850a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653s/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The non-Federal share of the cost as referenced in subsection (b) shall be 50 percent and shall be provided in cash.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf93850b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653s/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Third party contributions","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbf93850c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653s/f/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in clause (ii), an intermediary nonprofit grantee shall provide the non-Federal share of the cost through contributions from third parties. The third parties may include charitable grantmaking entities and grantmaking vehicles within existing organizations, entities of corporate philanthropy, corporations, individual donors, and regional, State, or local government agencies, or other non-Federal sources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf93850d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653s/f/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the intermediary nonprofit grantee is a private foundation (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s509/a"},"text":"section 509(a) of title 26","children":[],"tail":"), a donor advised fund (as defined in section 4966(d)(2) of such title), an organization which is described in section 4966(d)(4)(A)(i) of such title, or an organization which is described in section 4966(d)(4)(B) of such title, the grantee shall provide the non-Federal share from within that grantee’s own funds."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf93850e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653s/f/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maintenance of effort, prior year third-party funding levels","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of maintaining private sector support levels for the activities specified by this program, a non-Federal share that includes donations by third parties shall be composed in a way that does not decrease prior levels of funding from the same third parties granted to the nonprofit intermediary grantee in the preceding year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf93850f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653s/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reservation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the amount authorized to provide financial assistance under this division, there shall be made available to carry out this section $5,000,000 for each of fiscal years 2010 through 2014.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf938510-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/610/tI/s198S"},"text":"Pub. L. 101–610, title I, § 198S","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/13/tI/s1809"},"text":"Pub. L. 111–13, title I, § 1809","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-04-21"},"text":"Apr. 21, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1575"},"text":"123 Stat. 1575","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf938511-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbf938512-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbf938513-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2009-10-01"},"text":"Oct. 1, 2009","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/111/13/s6101/a"},"text":"section 6101(a) of Pub. L. 111–13","children":[],"tail":", set out as an Effective Date of 2009 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4950"},"text":"section 4950 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
