{"tag":"section","attrib":{"id":"idc016977f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16511"},"text":null,"children":[{"tag":"num","attrib":{"value":"16511"},"text":"§ 16511.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this subchapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0169780-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16511/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commercial technology","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0169781-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16511/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “commercial technology” means a technology in general use in the commercial marketplace.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0169782-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16511/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “commercial technology” does not include a technology solely by use of the technology in a demonstration project funded by the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0169783-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16511/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “cost” has the meaning given the term “cost of a loan guarantee” within the meaning of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s661a/5/C"},"text":"section 661a(5)(C) of title 2","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0169784-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16511/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible project","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “eligible project” means a project described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16513"},"text":"section 16513 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0169785-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16511/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guarantee","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0169786-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16511/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “guarantee” has the meaning given the term “loan guarantee” in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s661a"},"text":"section 661a of title 2","children":[],"tail":", except that a loan guarantee may guarantee any debt obligation of a non-Federal borrower to any Eligible Lender (as defined in section 609.2 of title 10, Code of Federal Regulations)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0169787-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16511/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “guarantee” includes a loan guarantee commitment (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s661a"},"text":"section 661a of title 2","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0169788-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16511/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Obligation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “obligation” means the loan or other debt obligation that is guaranteed under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0169789-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16511/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6802"},"text":"section 6802 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc016978a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16511/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State energy financing institution","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc016978b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16511/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “State energy financing institution” means a quasi-independent entity or an entity within a State agency or financing authority established by a State—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc016978c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16511/7/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide financing support or credit enhancements, including loan guarantees and loan loss reserves, for eligible projects; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc016978d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16511/7/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to create liquid markets for eligible projects, including warehousing and securitization, or take other steps to reduce financial barriers to the deployment of existing and new eligible projects.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc016978e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16511/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State energy financing institution” includes an entity or organization established to achieve the purposes described in clauses (i) and (ii) of subparagraph (A) by an Indian Tribal entity or an Alaska Native Corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc016978f-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tXVII/s1701"},"text":"Pub. L. 109–58, title XVII, § 1701","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1117"},"text":"119 Stat. 1117","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/dD/tIV/s40401/c/1"},"text":"Pub. L. 117–58, div. D, title IV, § 40401(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1037"},"text":"135 Stat. 1037","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/169/tV/s50141/e"},"text":"Pub. L. 117–169, title V, § 50141(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-16"},"text":"Aug. 16, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2043"},"text":"136 Stat. 2043","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc0169790-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc0169791-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc0169792-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Par. (4)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/169"},"text":"Pub. L. 117–169","children":[],"tail":" inserted “, except that a loan guarantee may guarantee any debt obligation of a non-Federal borrower to any Eligible Lender (as defined in section 609.2 of title 10, Code of Federal Regulations)” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—Pars. (6), (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":" added pars. (6) and (7)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc0169793-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc0169794-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Wage Rate Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions relating to rates of wages to be paid to laborers and mechanics on projects for construction, alteration, or repair work funded under div. D or an amendment by div. D of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":", including authority of Secretary of Labor, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s18851"},"text":"section 18851 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
