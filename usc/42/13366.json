{"tag":"section","attrib":{"id":"idbfbe6552-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13366"},"text":null,"children":[{"tag":"num","attrib":{"value":"13366"},"text":"§ 13366.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National clearinghouse","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfbe6553-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13366/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Feasibility","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfbe6554-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13366/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall assess the feasibility of establishing a national clearinghouse for the exchange and dissemination of technical information on technology relating to coal and coal-derived fuels.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfbe6555-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13366/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In assessing the feasibility, the Secretary shall consider whether such a clearinghouse would be appropriate for purposes of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfbe6556-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13366/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collecting information and data on technology relating to coal, and coal-derived fuels, which can be utilized to improve environmental quality and increase energy independence;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfbe6557-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13366/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disseminating to appropriate individuals, governmental departments, agencies, and instrumentalities, institutions of higher education, and other entities, information and data collected pursuant to this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfbe6558-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13366/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintaining a library of technology publications and treatises relating to technology information and data collected pursuant to this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfbe6559-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13366/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" organizing and conducting seminars for government officials, utilities, coal companies, and other entities or institutions relating to technology using coal and coal-derived fuels that will improve environmental quality and increase energy independence;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfbe655a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13366/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" gathering information on research grants made for the purpose of improving or enhancing technology relating to the use of coal, and coal-derived fuels, which will improve environmental quality and increase energy independence;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfbe655b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13366/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" translating into English foreign research papers, articles, seminar proceedings, test results that affect, or could affect, clean coal use technology, and other documents;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfbe655c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13366/a/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encouraging, during the testing of technologies, the use of coal from a variety of domestic sources, and collecting or developing, or both, complete listings of test results using coals from all sources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfbe655d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13366/a/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing and maintaining an index or compilation of research projects relating to clean coal technology carried out throughout the world; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfbe655e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13366/a/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conducting economic modeling for feasibility of projects.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfbe655f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13366/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to establish clearinghouse","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Based upon the assessment under subsection (a), the Secretary may establish a clearinghouse.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfbe6560-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/tXIII/s1337"},"text":"Pub. L. 102–486, title XIII, § 1337","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2985"},"text":"106 Stat. 2985","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
