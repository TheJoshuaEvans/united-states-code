{"tag":"section","attrib":{"id":"idb8059eec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1006"},"text":null,"children":[{"tag":"num","attrib":{"value":"1006"},"text":"§ 1006.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications and furnishing of information","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8059eed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1006/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commissioner of Social Security shall, subject to subsection (b), prescribe such requirements with respect to the filing of applications, the furnishing of information and other material, and the reporting of events and changes in circumstances, as may be necessary for the effective and efficient administration of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8059eee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1006/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Verification requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The requirements prescribed by the Commissioner of Social Security under subsection (a) shall preclude any determination of entitlement to benefits under this subchapter solely on the basis of declarations by the individual concerning qualifications or other material facts, and shall provide for verification of material information from independent or collateral sources, and the procurement of additional information as necessary in order to ensure that the benefits are provided only to qualified individuals (or their representative payees) in correct amounts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8059eef-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title VIII, § 806, as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/169/tII/s251/a"},"text":"Pub. L. 106–169, title II, § 251(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-12-14"},"text":"Dec. 14, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1846"},"text":"113 Stat. 1846","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8059ef0-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8059ef1-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb8059ef2-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For prior provisions, see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1001"},"text":"section 1001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
