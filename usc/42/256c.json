{"tag":"section","attrib":{"id":"idb505f2e1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256c"},"text":null,"children":[{"tag":"num","attrib":{"value":"256c"},"text":"§ 256c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bulk purchases of vaccines for certain programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb505f2e2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreements for purchases","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb505f2e3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256c/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"1992-10-27"},"text":"October 27, 1992","children":[],"tail":", the Secretary, acting through the Director of the Centers for Disease Control and Prevention and in consultation with the Administrator of the Health Resources and Services Administration, shall enter into negotiations with manufacturers of vaccines for the purpose of establishing and maintaining agreements under which entities described in paragraph (2) may purchase vaccines from the manufacturers at the prices specified in the agreements."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb505f2e4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256c/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relevant entities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The entities referred to in paragraph (1) are entities that provide immunizations against vaccine-preventable diseases with assistance provided under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s254b"},"text":"section 254b of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb505f2e5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Negotiation of prices","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out subsection (a), the Secretary shall, to the extent practicable, ensure that the prices provided for in agreements under such subsection are comparable to the prices provided for in agreements negotiated by the Secretary on behalf of grantees under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s247b/j/1"},"text":"section 247b(j)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb505f2e6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out subsection (a), the Secretary, in the discretion of the Secretary, may enter into the agreements described in such subsection (and may decline to enter into such agreements), may modify such agreements, may extend such agreements, and may terminate such agreements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb505f2e7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256c/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section may not be construed as requiring any State to reduce or terminate the supply of vaccines provided by the State to any of the entities described in subsection (a)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb505f2e8-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title III, § 340C, formerly § 340B, as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/531/tIII/s305"},"text":"Pub. L. 102–531, title III, § 305","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-27"},"text":"Oct. 27, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3494"},"text":"106 Stat. 3494","children":[],"tail":"; renumbered § 340C, "},{"tag":"ref","attrib":{"href":"/us/pl/103/43/tXX/s2008/i/2/A/ii"},"text":"Pub. L. 103–43, title XX, § 2008(i)(2)(A)(ii)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-06-10"},"text":"June 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/213"},"text":"107 Stat. 213","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/299/s4/a/2"},"text":"Pub. L. 104–299, § 4(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3645"},"text":"110 Stat. 3645","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb505f2e9-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb505f2ea-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb505f2eb-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/299"},"text":"Pub. L. 104–299","children":[],"tail":" substituted “with assistance provided under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s254b"},"text":"section 254b of this title","children":[],"tail":"” for “under the programs established in sections 254b, 254c, 256, and 256a of this title.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb505f2ec-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb505f2ed-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/299"},"text":"Pub. L. 104–299","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1996-10-01"},"text":"Oct. 1, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/299/s5"},"text":"section 5 of Pub. L. 104–299","children":[],"tail":", as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s233"},"text":"section 233 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
