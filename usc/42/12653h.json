{"tag":"section","attrib":{"id":"idbf9113fb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653h"},"text":null,"children":[{"tag":"num","attrib":{"value":"12653h"},"text":"§ 12653h.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Service Reserve Corps","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf9113fc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653h/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf9113fd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653h/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “National Service Reserve Corps member” means an individual who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf9113fe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653h/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has completed a term of national service or is a veteran;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf9113ff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653h/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has successfully completed training described in subsection (c) within the previous 2 years;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf911400-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653h/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" completes not less than 10 hours of volunteering each year (which may include the training session described in subparagraph (B)); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf911401-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653h/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has indicated interest to the Corporation in responding to disasters and emergencies in a timely manner through the National Service Reserve Corps; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf911402-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653h/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “term of national service” means a term or period of service under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12573"},"text":"section 12573 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf911403-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653h/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of National Service Reserve Corps","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf911404-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653h/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In consultation with the Federal Emergency Management Agency, the Corporation shall establish a National Service Reserve Corps to prepare and deploy National Service Reserve Corps members to respond to disasters and emergencies in support of national service programs and other requesting programs and agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf911405-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653h/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants or contracts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out this section, the Corporation may enter into a grant or contract with an organization experienced in responding to disasters or in coordinating individuals who have completed a term of national service or are veterans, or may directly deploy National Service Reserve Corps members, as the Corporation determines necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf911406-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653h/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual training","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Corporation shall conduct or coordinate annual training sessions, consistent with the training requirements of the Federal Emergency Management Agency, for individuals who have completed a term of national service or are veterans, and who wish to join the National Service Reserve Corps.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf911407-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653h/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation of organizations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf911408-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653h/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Corporation shall designate organizations with demonstrated experience in responding to disasters or emergencies, including through using volunteers, for participation in the program under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf911409-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653h/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Corporation shall ensure that every designated organization is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf91140a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653h/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prepared to respond to disasters or emergencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf91140b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653h/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prepared and able to utilize National Service Reserve Corps members in responding to disasters or emergencies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf91140c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653h/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" willing to respond in a timely manner when notified by the Corporation of a disaster or emergency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf91140d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653h/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Databases","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Corporation shall develop or contract with an outside organization to develop—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf91140e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653h/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a database of all National Service Reserve Corps members; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf91140f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653h/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a database of all nonprofit organizations that have been designated by the Corporation under subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf911410-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653h/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deployment of National Service Reserve Corps","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf911411-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653h/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Major disasters or emergencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a major disaster or emergency is declared by the President pursuant to section 102 of the Robert T. Stafford Disaster Relief and Assistance Act ","children":[{"tag":"ref","attrib":{"idref":"fn004089"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004089"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5122"},"text":"42 U.S.C. 5122","children":[],"tail":"), the Administrator of the Federal Emergency Management Agency, in consultation with the Corporation, may task the National Service Reserve Corps to assist in response."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf911412-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653h/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other disasters or emergencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For a disaster or emergency that is not declared a major disaster or emergency under section 102 of the Robert T. Stafford Disaster Relief and Assistance Act ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5122"},"text":"42 U.S.C. 5122","children":[],"tail":"), the Corporation may directly, or through a grant or contract, deploy the National Service Reserve Corps."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf911413-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653h/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deployment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Under paragraph (1) or (2), the Corporation may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf911414-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653h/f/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deploy interested National Service Reserve Corps members on assignments of not more than 30 days to assist with local needs related to preparing or recovering from the incident in the affected area, either directly or through organizations designated under subsection (d);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf911415-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653h/f/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make travel arrangements for the deployed National Service Reserve Corps members to the site of the incident; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf911416-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653h/f/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide funds to those organizations that are responding to the incident with deployed National Service Reserve Corps members, to enable the organizations to coordinate and provide housing, living stipends, and insurance for those deployed members.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf911417-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653h/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allowance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any amounts that are utilized by the Corporation from funds appropriated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12681/a/4/D"},"text":"section 12681(a)(4)(D) of this title","children":[],"tail":" to carry out paragraph (1) for a fiscal year shall be kept in a separate fund. Any amounts in such fund that are not used during a fiscal year shall remain available to use to pay National Service Reserve Corps members an allowance, determined by the Corporation, for out-of-pocket expenses."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf911418-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653h/f/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf911419-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653h/f/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National service participants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Corporation, the State Commissions, and entities receiving financial assistance for programs under division C of this subchapter,","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" or under part A of title I of the Domestic Volunteer Service Act of 1973 ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4951"},"text":"42 U.S.C. 4951","children":[],"tail":" et seq.), shall inform participants about the National Service Reserve Corps upon the participants’ completion of their term of national service."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf91141a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653h/f/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Veterans","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Veterans Affairs, in consultation with the Secretary of Defense, shall inform veterans who are recently discharged, released, or separated from the Armed Forces about the National Service Reserve Corps.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf91141b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653h/f/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In deploying National Service Reserve Corps members under this subsection, the Corporation shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf91141c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653h/f/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" avoid duplication of activities directed by the Federal Emergency Management Agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf91141d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653h/f/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consult and, as appropriate, partner with Citizen Corps programs and other local disaster agencies, including State and local emergency management agencies, voluntary organizations active in disaster, State Commissions, and similar organizations, in the affected area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf91141e-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/610/tI/s198H"},"text":"Pub. L. 101–610, title I, § 198H","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/13/tI/s1806"},"text":"Pub. L. 111–13, title I, § 1806","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-04-21"},"text":"Apr. 21, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1562"},"text":"123 Stat. 1562","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf91141f-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf911420-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbf911421-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 102 of the Robert T. Stafford Disaster Relief and Assistance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5122"},"text":"42 U.S.C. 5122","children":[],"tail":"), referred to in subsec. (f)(1), (2), probably means "},{"tag":"ref","attrib":{"href":"/us/pl/93/288/s102"},"text":"section 102 of Pub. L. 93–288","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-05-22"},"text":"May 22, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/143"},"text":"88 Stat. 143","children":[],"tail":", known as the Robert T. Stafford Disaster Relief and Emergency Assistance Act, which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5122"},"text":"section 5122 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Division C of this subchapter, referred to in subsec. (f)(5)(A), was in the original “subtitle C of this Act” which was translated as meaning subtitle C of title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/610"},"text":"Pub. L. 101–610","children":[],"tail":", to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Domestic Volunteer Service Act of 1973, referred to in subsec. (f)(5)(A), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/113"},"text":"Pub. L. 93–113","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-10-01"},"text":"Oct. 1, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/394"},"text":"87 Stat. 394","children":[],"tail":". Part A of title I of the Act is classified generally to part A of subchapter I (§ 4951 et seq.) of chapter 66 of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4950"},"text":"section 4950 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbf911422-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 12653h, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/610/tI/s195H"},"text":"Pub. L. 101–610, title I, § 195H","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/484/dA/tX/s1092/a/1"},"text":"Pub. L. 102–484, div. A, title X, § 1092(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2528"},"text":"106 Stat. 2528","children":[],"tail":", which related to administration of the Corps, was renumbered "},{"tag":"ref","attrib":{"href":"/us/pl/101/610/s159"},"text":"section 159 of Pub. L. 101–610","children":[],"tail":" and transferred to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12619"},"text":"section 12619 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Prior sections 12653i and 12653j were renumbered by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/82/s104/b"},"text":"section 104(b) of Pub. L. 103–82","children":[],"tail":" and transferred as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 12653i, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/610/tI/s195I"},"text":"Pub. L. 101–610, title I, § 195I","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/484/dA/tX/s1092/a/1"},"text":"Pub. L. 102–484, div. A, title X, § 1092(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2530"},"text":"106 Stat. 2530","children":[],"tail":", which related to status of Corps members and Corps personnel under Federal law, was renumbered "},{"tag":"ref","attrib":{"href":"/us/pl/101/610/s160"},"text":"section 160 of Pub. L. 101–610","children":[],"tail":" and transferred to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12620"},"text":"section 12620 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 12653j, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/610/tI/s195J"},"text":"Pub. L. 101–610, title I, § 195J","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/484/dA/tX/s1092/a/1"},"text":"Pub. L. 102–484, div. A, title X, § 1092(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"ta