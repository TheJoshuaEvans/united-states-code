{"tag":"section","attrib":{"id":"idc08dea5f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19401"},"text":null,"children":[{"tag":"num","attrib":{"value":"19401"},"text":"§ 19401.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Congress finds the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc08dea60-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19401/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Sexual harassment and assault remain pervasive in the workplace and throughout civic society, affecting millions of Americans.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc08dea61-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19401/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Eighty-one percent of women and 43 percent of men have experienced some form of sexual harassment or assault throughout their lifetime.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc08dea62-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19401/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One in 3 women has faced sexual harassment in the workplace during her career, and an estimated 87 to 94 percent of those who experience sexual harassment never file a formal complaint.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc08dea63-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19401/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Sexual harassment in the workplace forces many women to leave their occupation or industry, or pass up opportunities for advancement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc08dea64-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19401/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In order to combat sexual harassment and assault, it is essential that victims and survivors have the freedom to report and publicly disclose their abuse.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc08dea65-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19401/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nondisclosure and nondisparagement provisions in agreements between employers and current, former, and prospective employees, and independent contractors, and between providers of goods and services and consumers, can perpetuate illegal conduct by silencing those who are survivors of illegal sexual harassment and assault or illegal retaliation, or have knowledge of such conduct, while shielding perpetrators and enabling them to continue their abuse.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc08dea66-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19401/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Prohibiting nondisclosure and nondisparagement clauses will empower survivors to come forward, hold perpetrators accountable for abuse, improve transparency around illegal conduct, enable the pursuit of justice, and make workplaces safer and more productive for everyone.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc08dea67-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/224/s2"},"text":"Pub. L. 117–224, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-07"},"text":"Dec. 7, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2290"},"text":"136 Stat. 2290","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc08dea68-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc08dea69-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"idc08dea6a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/224/s1"},"text":"Pub. L. 117–224, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-07"},"text":"Dec. 7, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2290"},"text":"136 Stat. 2290","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/224/s1"},"text":"“This Act [enacting this chapter] may be cited as the ‘Speak Out Act’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
