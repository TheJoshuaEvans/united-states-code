{"tag":"section","attrib":{"id":"idc03347f3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17302"},"text":null,"children":[{"tag":"num","attrib":{"value":"17302"},"text":"§ 17302.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on false information","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"It is unlawful for any person to report information related to the wholesale price of crude oil ","children":[{"tag":"ref","attrib":{"idref":"fn004272"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004272"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. A comma probably should appear."}],"tail":" gasoline or petroleum distillates to a Federal department or agency if—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc03347f4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17302/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the person knew, or reasonably should have known, the information to be false or misleading;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc03347f5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17302/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the information was required by law to be reported; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc03347f6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17302/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the person intended the false or misleading data to affect data compiled by the department or agency for statistical or analytical purposes with respect to the market for crude oil, gasoline, or petroleum distillates.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc03347f7-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/tVIII/s812"},"text":"Pub. L. 110–140, title VIII, § 812","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1723"},"text":"121 Stat. 1723","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc03347f8-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc03347f9-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc03347fa-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the date that is 1 day after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/s1601"},"text":"section 1601 of Pub. L. 110–140","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1824"},"text":"section 1824 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
