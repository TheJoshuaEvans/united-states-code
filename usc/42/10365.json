{"tag":"section","attrib":{"id":"idbf25ce9c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10365"},"text":null,"children":[{"tag":"num","attrib":{"value":"10365"},"text":"§ 10365.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hydroelectric power assessment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf25ce9d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10365/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duty of Secretary of Energy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Energy, in consultation with the Administrator of each Federal Power Marketing Administration, shall assess each effect of, and risk resulting from, global climate change with respect to water supplies that are required for the generation of hydroelectric power at each Federal water project that is applicable to a Federal Power Marketing Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf25ce9e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10365/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Access to appropriate data","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf25ce9f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10365/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out each assessment under subsection (a), the Secretary of Energy shall consult with the United States Geological Survey, the National Oceanic and Atmospheric Administration, the program, and each appropriate State water resource agency, to ensure that the Secretary of Energy has access to the best available scientific information with respect to presently observed impacts and projected future impacts of global climate change on water supplies that are used to produce hydroelectric power.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf25cea0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10365/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Access to data for certain assessments","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out each assessment under subsection (a), with respect to the Bonneville Power Administration and the Western Area Power Administration, the Secretary of Energy shall consult with the Commissioner to access data and other information that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf25cea1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10365/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is collected by the Commissioner; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf25cea2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10365/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Energy determines to be necessary for the conduct of the assessment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf25cea3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10365/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2009-03-30"},"text":"March 30, 2009","children":[],"tail":", and every 5 years thereafter, the Secretary of Energy shall submit to the appropriate committees of Congress a report that describes—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf25cea4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10365/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" each effect of, and risk resulting from, global climate change with respect to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf25cea5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10365/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" water supplies used for hydroelectric power generation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf25cea6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10365/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" power supplies marketed by each Federal Power Marketing Administration, pursuant to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbf25cea7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10365/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" long-term power contracts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf25cea8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10365/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contingent capacity contracts; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf25cea9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10365/c/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" short-term sales; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf25ceaa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10365/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each recommendation of the Administrator of each Federal Power Marketing Administration relating to any change in any operation or contracting practice of each Federal Power Marketing Administration to address each effect and risk described in paragraph (1), including the use of purchased power to meet long-term commitments of each Federal Power Marketing Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf25ceab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10365/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Energy may enter into contracts, grants, or other agreements with appropriate entities to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf25ceac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10365/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Costs","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf25cead-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10365/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonreimbursable","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any costs incurred by the Secretary of Energy in carrying out this section shall be nonreimbursable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf25ceae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10365/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" PMA costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each Federal Power Marketing Administration shall incur costs in carrying out this section only to the extent that appropriated funds are provided by the Secretary of Energy for that purpose.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf25ceaf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10365/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums as are necessary to carry out this section for each of fiscal years 2009 through 2023, to remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf25ceb0-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11/tIX/s9505"},"text":"Pub. L. 111–11, title IX, § 9505","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-03-30"},"text":"Mar. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1336"},"text":"123 Stat. 1336","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
