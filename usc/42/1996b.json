{"tag":"section","attrib":{"id":"idbbb38b86-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1996b"},"text":null,"children":[{"tag":"num","attrib":{"value":"1996b"},"text":"§ 1996b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interethnic adoption","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbbb38b87-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1996b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibited conduct","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A person or government that is involved in adoption or foster care placements may not—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbbb38b88-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1996b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deny to any individual the opportunity to become an adoptive or a foster parent, on the basis of the race, color, or national origin of the individual, or of the child, involved; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbbb38b89-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1996b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" delay or deny the placement of a child for adoption or into foster care, on the basis of the race, color, or national origin of the adoptive or foster parent, or the child, involved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbb38b8a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1996b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Noncompliance with paragraph (1) is deemed a violation of title VI of the Civil Rights Act of 1964 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2000d"},"text":"42 U.S.C. 2000d","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbb38b8b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1996b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No effect on the Indian Child Welfare Act of 1978","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This subsection shall not be construed to affect the application of the Indian Child Welfare Act of 1978 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1901"},"text":"25 U.S.C. 1901","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbbb38b8c-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/188/tI/s1808/c"},"text":"Pub. L. 104–188, title I, § 1808(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1904"},"text":"110 Stat. 1904","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbbb38b8d-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbbb38b8e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbbb38b8f-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Civil Rights Act of 1964, referred to in par. (2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/352"},"text":"Pub. L. 88–352","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-07-02"},"text":"July 2, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/241"},"text":"78 Stat. 241","children":[],"tail":". Title VI of the Act is classified generally to subchapter V (§ 2000d et seq.) of this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2000a"},"text":"section 2000a of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Indian Child Welfare Act of 1978, referred to in par. (3), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/608"},"text":"Pub. L. 95–608","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-08"},"text":"Nov. 8, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3069"},"text":"92 Stat. 3069","children":[],"tail":", which is classified principally to chapter 21 (§ 1901 et seq.) of Title 25, Indians. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s1901"},"text":"section 1901 of Title 25","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
