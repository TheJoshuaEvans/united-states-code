{"tag":"section","attrib":{"id":"idbb2b96e3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1490j"},"text":null,"children":[{"tag":"num","attrib":{"value":"1490j"},"text":"§ 1490j.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conditions on rent increases in projects receiving assistance under other provisions of law","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary may not approve any increase in rental payments, with respect to units in which the tenants are paying rentals in excess of 30 per centum of their incomes, in any project which is assisted under section 1484, 1485, or 1487 of this title and under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1490a/a/1/B"},"text":"section 1490a(a)(1)(B) of this title","children":[],"tail":" unless the project owner is receiving, or has applied for (within the most recent period of 180 days prior to the effective date of such increase), assistance payments with respect to such project under section 1490a(a)(2)(A) or 1490a(a)(5) of this title or "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1437f"},"text":"section 1437f of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbb2b96e4-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-07-15/ch338"},"text":"July 15, 1949, ch. 338","children":[],"tail":", title V, § 530, as added "},{"tag":"ref","attrib":{"href":"/us/pl/96/399/tV/s509"},"text":"Pub. L. 96–399, title V, § 509","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-08"},"text":"Oct. 8, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1670"},"text":"94 Stat. 1670","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/98/181/tI"},"text":"Pub. L. 98–181, title I","children":[],"tail":" [title V, § 517(d)], "},{"tag":"date","attrib":{"date":"1983-11-30"},"text":"Nov. 30, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/1248"},"text":"97 Stat. 1248","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/276/tV/s599C/e/2/G"},"text":"Pub. L. 105–276, title V, § 599C(e)(2)(G)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2663"},"text":"112 Stat. 2663","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbb2b96e5-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbb2b96e6-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbb2b96e7-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/276"},"text":"Pub. L. 105–276","children":[],"tail":" substituted “assistance payments with respect to such project under section 1490a(a)(2)(A) or 1490a(a)(5) of this title” for “rental assistance payments with respect to such project under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1490a/a/2/A"},"text":"section 1490a(a)(2)(A) of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/181"},"text":"Pub. L. 98–181","children":[],"tail":" substituted “30 per centum” for “25 per centum”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbb2b96e8-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null