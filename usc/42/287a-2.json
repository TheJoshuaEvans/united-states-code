{"tag":"section","attrib":{"id":"idb5844a67-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s287a–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"287a–2"},"text":"§ 287a–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rare disease regional centers of excellence","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5844a68-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s287a–2/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperative agreements and grants","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5844a69-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s287a–2/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the Office of Rare Diseases (in this section referred to as the “Director”), in collaboration with the directors of the other relevant institutes and centers of the National Institutes of Health, may enter into cooperative agreements with and make grants to public or private nonprofit entities to pay all or part of the cost of planning, establishing, or strengthening, and providing basic operating support for regional centers of excellence for clinical research into, training in, and demonstration of diagnostic, prevention, control, and treatment methods for rare diseases.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5844a6a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s287a–2/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Policies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A cooperative agreement or grant under paragraph (1) shall be entered into in accordance with policies established by the Director of NIH.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5844a6b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s287a–2/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with other institutes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall coordinate the activities under this section with similar activities conducted by other national research institutes, centers and agencies of the National Institutes of Health and by the Food and Drug Administration to the extent that such institutes, centers and agencies have responsibilities that are related to rare diseases.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5844a6c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s287a–2/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uses for Federal payments under cooperative agreements or grants","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Federal payments made under a cooperative agreement or grant under subsection (a) may be used for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5844a6d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s287a–2/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" staffing, administrative, and other basic operating costs, including such patient care costs as are required for research;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5844a6e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s287a–2/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" clinical training, including training for allied health professionals, continuing education for health professionals and allied health professions personnel, and information programs for the public with respect to rare diseases; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5844a6f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s287a–2/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" clinical research and demonstration programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5844a70-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s287a–2/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Period of support; additional periods","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Support of a center under subsection (a) may be for a period of not to exceed 5 years. Such period may be extended by the Director for additional periods of not more than 5 years if the operations of such center have been reviewed by an appropriate technical and scientific peer review group established by the Director and if such group has recommended to the Director that such period should be extended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5844a71-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title IV, § 481A, formerly § 404G, as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/280/s4"},"text":"Pub. L. 107–280, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-06"},"text":"Nov. 6, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1990"},"text":"116 Stat. 1990","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/482/tI/s103/b/6"},"text":"Pub. L. 109–482, title I, § 103(b)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-01-15"},"text":"Jan. 15, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3687"},"text":"120 Stat. 3687","children":[],"tail":"; renumbered § 481A, "},{"tag":"ref","attrib":{"href":"/us/pl/112/74/dF/tII/s221/c/3"},"text":"Pub. L. 112–74, div. F, title II, § 221(c)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-23"},"text":"Dec. 23, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1089"},"text":"125 Stat. 1089","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb5844a72-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb5844a73-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb5844a74-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s283i"},"text":"section 283i of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb5844a75-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 481A of act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", was renumbered section 404I, and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s283k"},"text":"section 283k of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb5844a76-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2007—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/482"},"text":"Pub. L. 109–482","children":[],"tail":" struck out heading and text of subsec. (e). Text read as follows: “For the purpose of carrying out this section, there are authorized to be appropriated such sums as already have been appropriated for fiscal year 2002, and $20,000,000 for each of the fiscal years 2003 through 2006.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb5844a77-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb5844a78-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2007 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/482"},"text":"Pub. L. 109–482","children":[],"tail":" applicable only with respect to amounts appropriated for fiscal year 2007 or subsequent fiscal years, see "},{"tag":"ref","attrib":{"href":"/us/pl/109/482/s109"},"text":"section 109 of Pub. L. 109–482","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s281"},"text":"section 281 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
