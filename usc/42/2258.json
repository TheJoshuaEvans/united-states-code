{"tag":"section","attrib":{"id":"idbc10789d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2258"},"text":null,"children":[{"tag":"num","attrib":{"value":"2258"},"text":"§ 2258.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Joint Committee on Atomic Energy abolished","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbc10789e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2258/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Abolition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Joint Committee on Atomic Energy is abolished.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc10789f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2258/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" References in rules, etc., on and after ","children":[{"tag":"date","attrib":{"date":"1977-09-20"},"text":"September 20, 1977","children":[],"tail":null}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any reference in any rule, resolution, or order of the Senate or the House of Representatives or in any law, regulation, or Executive order to the Joint Committee on Atomic Energy shall, on and after ","children":[{"tag":"date","attrib":{"date":"1977-09-20"},"text":"September 20, 1977","children":[],"tail":", be considered as referring to the committees of the Senate and the House of Representatives which, under the rules of the Senate and the House, have jurisdiction over the subject matter of such reference."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc1078a0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2258/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of records, data, etc.; copies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All records, data, charts, and files of the Joint Committee on Atomic Energy are transferred to the committees of the Senate and House of Representatives which, under the rules of the Senate and the House, have jurisdiction over the subject matters to which such records, data, charts, and files relate. In the event that any record, data, chart, or file shall be within the jurisdiction of more than one committee, duplicate copies shall be provided upon request.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc1078a1-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-08-01/ch724"},"text":"Aug. 1, 1946, ch. 724","children":[],"tail":", title I, § 301, as added "},{"tag":"ref","attrib":{"href":"/us/pl/95/110/s1"},"text":"Pub. L. 95–110, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-09-20"},"text":"Sept. 20, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/884"},"text":"91 Stat. 884","children":[],"tail":"; renumbered title I, "},{"tag":"ref","attrib":{"href":"/us/pl/102/486/tIX/s902/a/8"},"text":"Pub. L. 102–486, title IX, § 902(a)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2944"},"text":"106 Stat. 2944","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
