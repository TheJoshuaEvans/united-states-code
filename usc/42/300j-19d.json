{"tag":"section","attrib":{"id":"idb64ca34c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19d"},"text":null,"children":[{"tag":"num","attrib":{"value":"300j–19d"},"text":"§ 300j–19d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review of technologies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb64ca34d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator, after consultation with appropriate departments and agencies of the Federal Government and with State and local governments, shall review (or enter into contracts or cooperative agreements to provide for a review of) existing and potential methods, means, equipment, and technologies (including review of cost, availability, and efficacy of such methods, means, equipment, and technologies) that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb64ca34e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19d/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure the physical integrity of community water systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb64ca34f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19d/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prevent, detect, and respond to any contaminant for which a national primary drinking water regulation has been promulgated in community water systems and source water for community water systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb64ca350-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19d/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allow for use of alternate drinking water supplies from nontraditional sources; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb64ca351-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19d/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitate source water assessment and protection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb64ca352-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The review under subsection (a) shall include review of methods, means, equipment, and technologies—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb64ca353-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19d/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that are used for corrosion protection, metering, leak detection, or protection against water loss;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb64ca354-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19d/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that are intelligent systems, including hardware, software, or other technology, used to assist in protection and detection described in paragraph (1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb64ca355-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19d/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that are point-of-use devices or point-of-entry devices;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb64ca356-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19d/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that are physical or electronic systems that monitor, or assist in monitoring, contaminants in drinking water in real-time; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb64ca357-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19d/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that allow for the use of nontraditional sources for drinking water, including physical separation and chemical and biological transformation technologies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb64ca358-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19d/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall make the results of the review under subsection (a) available to the public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb64ca359-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19d/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to the Administrator to carry out this section $10,000,000 for fiscal year 2019, which shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb64ca35a-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XIV, § 1459D, as added "},{"tag":"ref","attrib":{"href":"/us/pl/115/270/tII/s2017"},"text":"Pub. L. 115–270, title II, § 2017","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-23"},"text":"Oct. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3856"},"text":"132 Stat. 3856","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
