{"tag":"section","attrib":{"id":"idbdbdb2f9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6836"},"text":null,"children":[{"tag":"num","attrib":{"value":"6836"},"text":"§ 6836.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Support for voluntary building energy codes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbdbdb2fa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6836/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"1992-10-24"},"text":"October 24, 1992","children":[],"tail":", the Secretary, after consulting with the Secretary of Housing and Urban Development, the Secretary of Veterans Affairs, other appropriate Federal agencies, CABO, ASHRAE, the National Conference of States on Building Codes and Standards, and any other appropriate building codes and standards organization, shall support the upgrading of voluntary building energy codes for new residential and commercial buildings. Such support shall include—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbdbdb2fb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6836/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a compilation of data and other information regarding building energy efficiency standards and codes in the possession of the Federal Government, State and local governments, and industry organizations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdbdb2fc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6836/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assistance in improving the technical basis for such standards and codes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdbdb2fd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6836/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assistance in determining the cost-effectiveness and the technical feasibility of the energy efficiency measures included in such standards and codes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdbdb2fe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6836/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assistance in identifying appropriate measures with regard to radon and other indoor air pollutants.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdbdb2ff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6836/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall periodically review the technical and economic basis of voluntary building energy codes and, based upon ongoing research activities—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbdbdb300-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6836/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommend amendments to such codes including measures with regard to radon and other indoor air pollutants;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdbdb301-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6836/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" seek adoption of all technologically feasible and economically justified energy efficiency measures; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdbdb302-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6836/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" otherwise participate in any industry process for review and modification of such codes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbdbdb303-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/385/tIII/s307"},"text":"Pub. L. 94–385, title III, § 307","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/486/tI/s101/a/2"},"text":"Pub. L. 102–486, title I, § 101(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2785"},"text":"106 Stat. 2785","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbdbdb304-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbdbdb305-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbdbdb306-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 6836, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/385/tIII/s307"},"text":"Pub. L. 94–385, title III, § 307","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-08-14"},"text":"Aug. 14, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1149"},"text":"90 Stat. 1149","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/619/tII/s255"},"text":"Pub. L. 95–619, title II, § 255","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-09"},"text":"Nov. 9, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3238"},"text":"92 Stat. 3238","children":[],"tail":", set forth provisions respecting grants to States for adoption and implementation of performance standards, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tX/s1041/b"},"text":"Pub. L. 97–35, title X, § 1041(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/621"},"text":"95 Stat. 621","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
