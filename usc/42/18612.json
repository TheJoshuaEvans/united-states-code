{"tag":"section","attrib":{"id":"idc0596d10-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18612"},"text":null,"children":[{"tag":"num","attrib":{"value":"18612"},"text":"§ 18612.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restoration of laboratory directed research and development program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc0596d11-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18612/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subsection (b), the Secretary shall ensure that laboratory operating contractors do not allocate costs of general and administrative overhead to laboratory directed research and development.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0596d12-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18612/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for national security laboratories","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall not apply to the national security laboratories with respect to which section 3119 ","children":[{"tag":"ref","attrib":{"idref":"fn004360"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004360"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of the National Defense Authorization Act for Fiscal Year 2017 ("},{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Public Law 114–328","children":[],"tail":") applies."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc0596d13-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/246/tI/s104"},"text":"Pub. L. 115–246, title I, § 104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-09-28"},"text":"Sept. 28, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3132"},"text":"132 Stat. 3132","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc0596d14-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc0596d15-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc0596d16-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 3119 of the National Defense Authorization Act for Fiscal Year 2017, referred to in subsec. (b), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s3119"},"text":"section 3119 of Pub. L. 114–328","children":[],"tail":", which was set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s2791"},"text":"section 2791 of Title 50","children":[],"tail":", War and National Defense, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dC/tXXXI/s3116/b"},"text":"Pub. L. 117–263, div. C, title XXXI, § 3116(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3054"},"text":"136 Stat. 3054","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
