{"tag":"section","attrib":{"id":"idb565512b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284m–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"284m–1"},"text":"§ 284m–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pediatric Advisory Committee","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb565512c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284m–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Health and Human Services shall, under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s217a"},"text":"section 217a of this title","children":[],"tail":" or other appropriate authority, convene and consult an advisory committee on pediatric therapeutics (including drugs and biological products) and medical devices (referred to in this section as the “advisory committee”)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb565512d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284m–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb565512e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284m–1/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The advisory committee shall advise and make recommendations to the Secretary, through the Commissioner of Food and Drugs, on matters relating to pediatric therapeutics (including drugs and biological products) and medical devices.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb565512f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284m–1/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matters included","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The matters referred to in paragraph (1) include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5655130-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284m–1/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pediatric research conducted under sections 262, 284m, and 290b of this title and sections 351, 352, 355, 355a, 355c, 360(k), 360e, and 360j(m) of title 21;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5655131-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284m–1/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identification of research priorities related to therapeutics (including drugs and biological products) and medical devices for pediatric populations and the need for additional diagnostics and treatments for specific pediatric diseases or conditions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5655132-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284m–1/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the ethics, design, and analysis of clinical trials related to pediatric therapeutics (including drugs and biological products) and medical devices; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5655133-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284m–1/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development of countermeasures (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s360bbb–4/a"},"text":"section 360bbb–4(a) of title 21","children":[],"tail":") for pediatric populations."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5655134-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284m–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Composition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The advisory committee shall include representatives of pediatric health organizations, pediatric researchers, relevant patient and patient-family organizations, and other experts selected by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5655135-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284m–1/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continuation of Operation of Committee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s1013"},"text":"section 1013 of title 5","children":[],"tail":", the advisory committee shall continue to operate to carry out the advisory committee’s responsibilities under sections 355a, 355c, and 360j(m) of title 21."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5655136-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/109/s14"},"text":"Pub. L. 107–109, § 14","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-04"},"text":"Jan. 4, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1419"},"text":"115 Stat. 1419","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/108/155/s3/b/2"},"text":"Pub. L. 108–155, § 3(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-03"},"text":"Dec. 3, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1941"},"text":"117 Stat. 1941","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/85/tIII/s306/b"},"text":"Pub. L. 110–85, title III, § 306(b)","children":[],"tail":", title V, § 502(d), "},{"tag":"date","attrib":{"date":"2007-09-27"},"text":"Sept. 27, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/865"},"text":"121 Stat. 865","children":[],"tail":", 889; "},{"tag":"ref","attrib":{"href":"/us/pl/112/144/tV/s507/a"},"text":"Pub. L. 112–144, title V, § 507(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-09"},"text":"July 9, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1045"},"text":"126 Stat. 1045","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/5/tIII/s307/c"},"text":"Pub. L. 113–5, title III, § 307(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-03-13"},"text":"Mar. 13, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/192"},"text":"127 Stat. 192","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/233"},"text":"Pub. L. 117–286, § 4(a)(233)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4331"},"text":"136 Stat. 4331","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb5655137-3a