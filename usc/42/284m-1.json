f title 21” for “during the five-year period beginning on "},{"tag":"date","attrib":{"date":"2007-09-27"},"text":"September 27, 2007","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2007—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/85/s306/b/1"},"text":"Pub. L. 110–85, § 306(b)(1)","children":[],"tail":", inserted “(including drugs and biological products) and medical devices” after “therapeutics”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/85/s306/b/2/A"},"text":"Pub. L. 110–85, § 306(b)(2)(A)","children":[],"tail":", inserted “(including drugs and biological products) and medical devices” after “therapeutics”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/85/s306/b/2/B/i"},"text":"Pub. L. 110–85, § 306(b)(2)(B)(i)","children":[],"tail":", substituted “355c, 360(k), 360e, and 360j(m)” for “and 355c”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/85/s306/b/2/B/ii"},"text":"Pub. L. 110–85, § 306(b)(2)(B)(ii)","children":[],"tail":", added subpar. (B) and struck out former subpar. (B) which read as follows: “identification of research priorities related to pediatric therapeutics and the need for additional treatments of specific pediatric diseases or conditions; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/85/s306/b/2/B/iii"},"text":"Pub. L. 110–85, § 306(b)(2)(B)(iii)","children":[],"tail":", inserted “(including drugs and biological products) and medical devices” after “therapeutics”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/85/s502/d"},"text":"Pub. L. 110–85, § 502(d)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/155/s3/b/2/A"},"text":"Pub. L. 108–155, § 3(b)(2)(A)","children":[],"tail":", struck out “Pharmacology” after “Pediatric” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/155/s3/b/2/D"},"text":"Pub. L. 108–155, § 3(b)(2)(D)","children":[],"tail":", substituted “therapeutics” for “pharmacology”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/155/s3/b/2/B"},"text":"Pub. L. 108–155, § 3(b)(2)(B)","children":[],"tail":", inserted “or other appropriate authority” after “217a of this title”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/155/s3/b/2/D"},"text":"Pub. L. 108–155, § 3(b)(2)(D)","children":[],"tail":", substituted “therapeutics” for “pharmacology”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/155/s3/b/2/C/i"},"text":"Pub. L. 108–155, § 3(b)(2)(C)(i)","children":[],"tail":", struck out “and in consultation with the Director of the National Institutes of Health” after “Commissioner of Food and Drugs”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/155/s3/b/2/C/ii"},"text":"Pub. L. 108–155, § 3(b)(2)(C)(ii)","children":[],"tail":", substituted “355a, and 355c” for “and 355a”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(B), (C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/155/s3/b/2/D"},"text":"Pub. L. 108–155, § 3(b)(2)(D)","children":[],"tail":", substituted “therapeutics” for “pharmacology”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb565513b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb565513c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2003 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/155"},"text":"Pub. L. 108–155","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2003-12-03"},"text":"Dec. 3, 2003","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/108/155/s4"},"text":"section 4 of Pub. L. 108–155","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s355c"},"text":"section 355c of Title 21","children":[],"tail":", Food and Drugs."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
