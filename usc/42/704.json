{"tag":"section","attrib":{"id":"idb7eb5f7b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s704"},"text":null,"children":[{"tag":"num","attrib":{"value":"704"},"text":"§ 704.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of allotment funds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb7eb5f7c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s704/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as otherwise provided under this section, a State may use amounts paid to it under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s703"},"text":"section 703 of this title","children":[],"tail":" for the provision of health services and related activities (including planning, administration, education, and evaluation and including payment of salaries and other related expenses of National Health Service Corps personnel) consistent with its application transmitted under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s705/a"},"text":"section 705(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7eb5f7d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s704/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restrictions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Amounts described in subsection (a) may not be used for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7eb5f7e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s704/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inpatient services, other than inpatient services provided to children with special health care needs or to high-risk pregnant women and infants and such other inpatient services as the Secretary may approve;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7eb5f7f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s704/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cash payments to intended recipients of health services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7eb5f80-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s704/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the purchase or improvement of land, the purchase, construction, or permanent improvement (other than minor remodeling) of any building or other facility, or the purchase of major medical equipment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7eb5f81-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s704/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" satisfying any requirement for the expenditure of non-Federal funds as a condition for the receipt of Federal funds;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7eb5f82-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s704/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing funds for research or training to any entity other than a public or nonprofit private entity; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7eb5f83-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s704/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" payment for any item or service (other than an emergency item or service) furnished—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb7eb5f84-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s704/b/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by an individual or entity during the period when such individual or entity is excluded under this subchapter or subchapter XVIII, XIX, or XX pursuant to section 1320a–7, 1320a–7a, 1320c–5, or 1395u(j)(2) of this title, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7eb5f85-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s704/b/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at the medical direction or on the prescription of a physician during the period when the physician is excluded under this subchapter or subchapter XVIII, XIX, or XX pursuant to section 1320a–7, 1320a–7a, 1320c–5, or 1395u(j)(2) of this title and when the person furnishing such item or service knew or had reason to know of the exclusion (after a reasonable time period after reasonable notice has been furnished to the person).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The Secretary may waive the limitation contained in paragraph (3) upon the request of a State if the Secretary finds that there are extraordinary circumstances to justify the waiver and that granting the waiver will assist in carrying out this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7eb5f86-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s704/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of portion of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State may use a portion of the amounts described in subsection (a) for the purpose of purchasing technical assistance from public or private entities if the State determines that such assistance is required in developing, implementing, and administering programs funded under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7eb5f87-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s704/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on use of funds for administrative costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the amounts paid to a State under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s703"},"text":"section 703 of this title","children":[],"tail":" from an allotment for a fiscal year under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s702/c"},"text":"section 702(c) of this title","children":[],"tail":", not more than 10 percent may be used for administering the funds paid under such section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb7eb5f88-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title V, § 504, as added "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tXXI/s2192/a"},"text":"Pub. L. 97–35, title XXI, § 2192(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/821"},"text":"95 Stat. 821","c