{"tag":"section","attrib":{"id":"idbc44f61c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3016"},"text":null,"children":[{"tag":"num","attrib":{"value":"3016"},"text":"§ 3016.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of Assistant Secretary","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbc44f61d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3016/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultative services and technical assistance; short-term training and technical instruction; research and demonstrations; preparation and dissemination of informational materials; staff and technical assistance to Federal Council on the Aging; designation of full-time nutrition professional as administrator of nutrition services","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc44f61e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3016/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In carrying out the objectives of this chapter, the Assistant Secretary is authorized to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc44f61f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3016/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide consultative services and technical assistance to public or nonprofit private agencies and organizations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc44f620-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3016/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide short-term training and technical instruction;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc44f621-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3016/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct research and demonstrations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc44f622-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3016/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collect, prepare, publish, and disseminate special educational or informational materials, including reports of the projects for which funds are provided under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc44f623-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3016/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc44f624-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3016/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Assistant Secretary shall designate an officer or employee who shall serve on a full-time basis and who shall be responsible for the administration of the nutrition services described in subparts I and II of part C of subchapter III and shall have duties that include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbc44f625-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3016/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designing, implementing, and evaluating evidence-based programs to support improved nutrition and regular physical activity for older individuals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc44f626-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3016/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing guidelines for nutrition providers concerning safety, sanitary handling of food, equipment, preparation, and food storage;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc44f627-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3016/a/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conducting outreach and disseminating evidence-based information to nutrition service providers about the benefits of healthful diets and regular physical activity, including information about the most current Dietary Guidelines for Americans published under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s5341"},"text":"section 5341 of title 7","children":[],"tail":", the Food Guidance System of the Department of Agriculture, and advances in nutrition science;"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc44f628-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3016/a/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promoting coordination between nutrition service providers and community-based organizations serving older individuals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc44f629-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3016/a/2/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing guidelines on cost containment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc44f62a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3016/a/2/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" defining a long range role for the nutrition services in community-based care systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc44f62b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3016/a/2/A/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing model menus and other appropriate materials for serving special needs populations and meeting cultural meal preferences;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc44f62c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3016/a/2/A/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disseminating guidance that describes strategies for improving the nutritional quality of meals provided under subchapter III, including strategies for increasing the consumption of whole grains, lowfat dairy products, fruits, and vegetables;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc44f62d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3016/a/2/A/ix"},"text":null,"children":[{"tag":"num","attrib":{"value":"ix"},"text":"(ix)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing and disseminating guidelines for conducting nutrient analyses of meals provided under subparts I and II of part C of subchapter III, including guidelines for averaging key nutrients over an appropriate period of time; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc44f62e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3016/a/2/A/x"},"text":null,"children":[{"tag":"num","attrib":{"value":"x"},"text":"(x)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing technical assistance to the regional offices of the Administration with respect to each duty described in clauses (i) through (ix).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc44f62f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3016/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The regional offices of the Administration shall be responsible for disseminating, and providing technical assistance regarding, the guidelines and information described in clauses (ii), (iii), and (v) of subparagraph (A) to State agencies, area agencies on aging, and persons that provide nutrition services under part C of subchapter III.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc44f630-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3016/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Assistant Secretary may provide technical assistance, including through the regional offices of the Administration, to State agencies, area agencies on aging, local government agencies, or leaders in age-friendly communities (as defined, for purposes of this subparagraph, in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3013/c/9"},"text":"section 3013(c)(9) of this title","children":[],"tail":") regarding—"}],"tail":null},{"tag":"clause","attrib":{"id":"idbc44f631-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3016/a/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" dissemination of, or consideration of ways to implement, best practices and recommendations from the Interagency Coordinating Committee on Healthy Aging and Age-Friendly Communities established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3013/c"},"text":"section 3013(c) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc44f632-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3016/a/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" methods for managing and coordinating existing programs to meet the needs of growing age-friendly communities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc44f633-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3016/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The officer or employee designated under subparagraph (A) shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbc44f634-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3016/a/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have expertise in nutrition, energy balance, and meal planning; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc44f635-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3016/a/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be a registered dietitian or registered dietitian nutritionist.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc44f636-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3016/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Utilization of services and facilities of Federal and other public or nonprofit agencies; advance or reimbursement payments for such use","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In administering the functions of the Administration under this chapter, the Assistant Secretary may utilize the services and facilities of any agency of the Federal Government and of any other public or nonprofit agency or organization, in accordance with agreements between the Assistant Secretary and the head thereof, and is authorized to pay therefor, in advance or by way of reimbursement, as may be provided in the agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc44f637-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/73/tII/s205"},"text":"Pub. L. 89–73, title II, § 205","children":[],"tail":", formerly § 206, as added "},{"tag":"ref","attrib":{"href":"/us/pl/93/29/tII/s201/c"},"text":"Pub. L. 93–29, title II, § 201(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-05-03"},"text":"May 3, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/34"},"text":"87 Stat. 34","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/95/478/tI/s102/f"},"text":"Pub. L. 95–478, title I, § 102(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-18"},"text":"Oct. 18, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1515"},"text":"92 Stat. 1515","children":[],"tail":"; renumbered § 205 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/97/115/s2/e/2"},"text":"Pub. L. 97–115, § 2(e)(2)","children":[],"tail":", (g), "},{"tag":"date","attrib":{"date":"1981-12-29"},"text":"Dec. 29, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1596"},"text":"95 Stat. 1596","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/459/tII/s205"},"text":"Pub. L. 98–459, title II, § 205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-09"},"text":"Oct. 9, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1770"},"text":"98 Stat. 1770","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/175/tI"},"text":"Pub. L. 100–175, title I","children":[],"tail":", §§ 109, 110, "},{"tag":"date","attrib":{"date":"1987-11-29"},"text":"Nov. 29, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/932"},"text":"101 Stat. 932","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/375/tII/s206"},"text":"Pub. L. 102–375, title II, § 206","children":[],"tail":", title IX, § 904(a)(7), "},{"tag":"date","attrib":{"date":"1992-09-30"},"text":"Sept. 30, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1212"},"text":"106 Stat. 1212","children":[],"tail":", 1306; "},{"tag":"ref","attrib":{"href":"/us/pl/103/171/s3/a/13"},"text":"Pub. L. 103–171, § 3(a)(13)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-02"},"text":"Dec. 2, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1990"},"text":"107 Stat. 1990","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/501/tII/s202/3"},"text":"Pub. L. 106–501, title II, § 202(3)","children":[],"tail":", title VIII, § 801(b)(3), "},{"tag":"date","attrib":{"date":"2000-11-13"},"text":"Nov. 13, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2231"},"text":"114 Stat. 2231","children":[],"tail":", 2292; "},{"tag":"ref","attrib":{"href":"/us/pl/109/365/tII/s204"},"text":"Pub. L. 109–365, title II, § 204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2535"},"text":"120 Stat. 2535","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/144/s3/c"},"text":"Pub. L. 114–144, § 3(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-04-19"},"text":"Apr. 19, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/337"},"text":"130 Stat. 337","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/131/tI"},"text":"Pub. L. 116–131, title I","children":[],"tail":", §§ 124(c), 125, "},{"tag":"date","attrib":{"date":"2020-03-25"},"text":"Mar. 25, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/250"},"text":"134 Stat. 250","children":[],"tail":", 251.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc44f638-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc44f639-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbc44f63a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/73/s205"},"text":"section 205 of Pub. L. 89–73","children":[],"tail":" was renumbered section 204 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3015"},"text":"section 3015 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbc44f63b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—Subsec. (a)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/131/s124/c/2"},"text":"Pub. L. 116–131, § 124(c)(2)","children":[],"tail":", added subpar. (C). Former subpar. (C) redesignated (D)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/131/s124/c/1"},"text":"Pub. L. 116–131, § 124(c)(1)","children":[],"tail":", redesignated subpar. (C) as (D)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(D)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/131/s125"},"text":"Pub. L. 116–131, § 125","children":[],"tail":", amended cl. (ii) generally. Prior to amendment, cl. (ii) read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(I) be a registered dietitian;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(II) be a credentialed nutrition professional; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(III) have education and training that is substantially equivalent to the education and training for a registered dietitian or a credentialed nutrition professional.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/144"},"text":"Pub. L. 114–144","children":[],"tail":" struck out subsec. (c). Text read as follows: “For the purpose of carrying out this section, there are authorized to be appropriated such sums as may be necessary.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (a)(1)(C) to (E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/365/s204/1/A"},"text":"Pub. L. 109–365, § 204(1)(A)","children":[],"tail":", in subpar. (C) inserted “and” at end, in subpar. (D) substituted period for “; and” at end, and struck out subpar. (E) which read as follows: “provide staff and other technical assistance to the Federal Council on the Aging.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(A)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/365/s204/1/B/i/I"},"text":"Pub. L. 109–365, § 204(1)(B)(i)(I)","children":[],"tail":", amended cl. (i) generally. Prior to amendment, cl. (i) read as follows: “designing, implementing, and evaluating nutrition programs;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(A)(iii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/365/s204/1/B/i/II"},"text":"Pub. L. 109–365, § 204(1)(B)(i)(II)","children":[],"tail":", amended cl. (iii) generally. Prior to amendment, cl. (iii) read as follows: “disseminating information to nutrition service providers about nutrition advancements and developments;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(A)(viii) to (x). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/365/s204/1/B/i/III"},"text":"Pub. L. 109–365, § 204(1)(B)(i)(III)","children":[],"tail":", (IV), added cls. (viii) to (x) and struck out former cl. (viii) which read as follows: “providing technical assistance to the regional offices of the Administration with respect to each duty described in clauses (i) through (vii).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(C)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/365/s204/1/B/ii"},"text":"Pub. L. 109–365, § 204(1)(B)(ii)","children":[],"tail":", amended cl. (i) generally. Prior to amendment, cl. (i) read as follows: “have expertise in nutrition and dietary services and planning; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (a)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/501/s801/b/3"},"text":"Pub. L. 106–501, § 801(b)(3)","children":[],"tail":", substituted “subparts I and II” for “subparts I, II, and III” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c) to (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/501/s202/3"},"text":"Pub. L. 106–501, § 202(3)","children":[],"tail":", redesignated subsec. (e) as (c) and struck out former subsecs. (c) and (d) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(c) Not later than 120 days after ","children":[{"tag":"date","attrib":{"date":"1987-10-09"},"text":"October 9, 1987","children":[],"tail":", the Secretary shall issue and publish in the Federal Register proposed regulations for the administration of this chapter. After allowing a reasonable period for public comment on such proposed rules and not later than 90 days after such publication, the Secretary shall issue, in final form, regulations for the administration of this chapter."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(d) Not later than September 1 of each fiscal year, the Assistant Secretary shall make available to the public, for the purpose of facilitating informed public comment, a statement of proposed specific goals to be achieved by implementing this chapter in the first fiscal year beginning after the date on which such statement is made available.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsecs. (a), (b), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/171"},"text":"Pub. L. 103–171","children":[],"tail":" substituted “Assistant Secretary” for “Commissioner” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/375"},"text":"Pub. L. 102–375","children":[],"tail":" designated existing provisions as par. (1), substituted “objectives” for “purposes” and “to—” for “to:” in introductory provisions, redesignated former pars. (1) to (5) as subpars. (A) to (E), respectively, and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/175/s109"},"text":"Pub. L. 100–175, § 109","children":[],"tail":", substituted “"},{"tag":"date","attrib":{"date":"1987-10-09"},"text":"October 9, 1987","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"1984-10-09"},"text":"October 9, 1984","children":[],"tail":"”."}],"