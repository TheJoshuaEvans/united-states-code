{"tag":"section","attrib":{"id":"idb575f36a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285i"},"text":null,"children":[{"tag":"num","attrib":{"value":"285i"},"text":"§ 285i.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose of Institute","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The general purpose of the National Eye Institute (hereafter in this subpart referred to as the “Institute”) is the conduct and support of research, training, health information dissemination, and other programs with respect to blinding eye diseases, visual disorders, mechanisms of visual function, preservation of sight, and the special health problems and requirements of the blind. Subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s285i–1"},"text":"section 285i–1 of this title","children":[],"tail":", the Director of the Institute may carry out a program of grants for public and private nonprofit vision research facilities."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb575f36b-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title IV, § 455, as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/158/s2"},"text":"Pub. L. 99–158, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-11-20"},"text":"Nov. 20, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/856"},"text":"99 Stat. 856","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/43/tXI/s1101/b"},"text":"Pub. L. 103–43, title XI, § 1101(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-06-10"},"text":"June 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/169"},"text":"107 Stat. 169","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb575f36c-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb575f36d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb575f36e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1993—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/43"},"text":"Pub. L. 103–43","children":[],"tail":" substituted “Subject to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s285i–1"},"text":"section 285i–1 of this title","children":[],"tail":", the Director” for “The Director” in second sentence."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
