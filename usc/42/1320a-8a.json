{"tag":"section","attrib":{"id":"idb84391fb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–8a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1320a–8a"},"text":"§ 1320a–8a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative procedure for imposing penalties for false or misleading statements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb84391fc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–8a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any person who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb84391fd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–8a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" makes, or causes to be made, a statement or representation of a material fact, for use in determining any initial or continuing right to or the amount of monthly insurance benefits under subchapter II or benefits or payments under subchapter XVI that the person knows or should know is false or misleading,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb84391fe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–8a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" makes such a statement or representation for such use with knowing disregard for the truth, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb84391ff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–8a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" omits from a statement or representation for such use, or otherwise withholds disclosure of, a fact which the person knows or should know is material to the determination of any initial or continuing right to or the amount of monthly insurance benefits under subchapter II or benefits or payments under subchapter XVI, if the person knows, or should know, that the statement or representation with such omission is false or misleading or that the withholding of such disclosure is misleading,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be subject to, in addition to any other penalties that may be prescribed by law, a penalty described in subsection (b) to be imposed by the Commissioner of Social Security.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8439200-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–8a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalty","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The penalty described in this subsection is—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8439201-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–8a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nonpayment of benefits under subchapter II that would otherwise be payable to the person; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8439202-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–8a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ineligibility for cash benefits under subchapter XVI,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"for each month that begins during the applicable period described in subsection (c).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8439203-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–8a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration of penalty","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The duration of the applicable period, with respect to a determination by the Commissioner under subsection (a) that a person has engaged in conduct described in subsection (a), shall be—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8439204-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–8a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" six consecutive months, in the case of the first such determination with respect to the person;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8439205-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–8a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" twelve consecutive months, in the case of the second such determination with respect to the person; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8439206-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–8a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" twenty-four consecutive months, in the case of the third or subsequent such determination with respect to the person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8439207-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–8a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect on other assistance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A person subject to a period of nonpayment of benefits under subchapter II or ineligibility for subchapter XVI benefits by reason of this section nevertheless shall be considered to be eligible for and receiving such benefits, to the extent that the person would be receiving or eligible for such benefits but for the imposition of the penalty, for purposes of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8439208-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–8a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determination of the eligibility of the person for benefits under subchapters XVIII and XIX; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8439209-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–8a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determination of the eligibility or amount of benefits payable under subchapter II or XVI to another person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb843920a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–8a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “benefits under subchapter VIII or XVI” includes State supplementary payments made by the Commissioner pursuant to an agreement under section 1010a or 1382e(a) of this title or ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/66/s212/b"},"text":"section 212(b) of Public Law 93–66","children":[],"tail":", as the case may be."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb843920b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–8a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commissioner of Social Security shall consult with the Inspector General of the Social Security Administration regarding initiating actions under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb843920c-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title XI, § 1129A, as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/169/tII/s207/a"},"text":"Pub. L. 106–169, title II, § 207(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-12-14"},"text":"Dec. 14, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1837"},"text":"113 Stat. 1837","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/1/tV/s518/b/2"},"text":"Pub. L. 106–554, § 1(a)(1) [title V, § 518(b)(2)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–74; "},{"tag":"ref","attrib":{"href":"/us/pl/108/203/tII/s201/a/2"},"text":"Pub. L. 108–203, title II, § 201(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-03-02"},"text":"Mar. 2, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/508"},"text":"118 Stat. 508","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb843920d-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb843920e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb843920f-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/93/66/s212/b"},"text":"Section 212(b) of Public Law 93–66","children":[],"tail":", referred to in subsec. (e), is "},{"tag":"ref","attrib":{"href":"/us/pl/93/66/s212/b"},"text":"section 212(b) of Pub. L. 93–66","children":[],"tail":", title II, "},{"tag":"date","attrib":{"date":"1973-07-09"},"text":"July 9, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/155"},"text":"87 Stat. 155","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1382"},"text":"section 1382 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8439210-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/203"},"text":"Pub. L. 108–203","children":[],"tail":" substantially rewrote text of subsec. (a). Prior to amendment, text read as follows: “Any person who makes, or causes to be made, a statement or representation of a material fact for use in determining any initial or continuing right to or the amount of—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) monthly insurance benefits under subchapter II of this chapter; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) benefits or payments under subchapter XVI of this chapter,","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"that the person knows or should know is false or misleading or knows or should know omits a material fact or who makes such a statement with knowing disregard for the truth shall be subject to, in addition to any other penalties that may be prescribed by law, a penalty described in subsection (b) to be imposed by the Commissioner of Social Security.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/1/tV/s518/b/2/B"},"text":"Pub. L. 106–554, § 1(a)(1) [title V, § 518(b)(2)(B), (D)]","children":[],"tail":", inserted “1010a or” after “agreement under section” and “, as the case may be” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/1/tV/s518/b/2/C"},"text":"Pub. L. 106–554, § 1(a)(1) [title V, § 518(b)(2)(C)]","children":[],"tail":", which directed the amendment of subsec. (e) by inserting “1010A or” before “1382(e)(a)”, could not be executed because “1382(e)(a)” does not appear in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/1/tV/s518/b/2/A"},"text":"Pub. L. 106–554, § 1(a)(1) [title V, § 518(b)(2)(A)]","children":[],"tail":", which directed the amendment of subsec. (e) by inserting “VIII or” after “benefits under”, was executed by making the insertion after “benefits under subchapter” to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8439211-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb8439212-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2004 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/203"},"text":"Pub. L. 108–203","children":[],"tail":" applicable with respect to violations committed after "},{"tag":"date","attrib":{"date":"2006-11-27"},"text":"Nov. 27, 2006","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/108/203/s201/d"},"text":"section 201(d) of Pub. L. 108–203","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320a–8"},"text":"section 1320a–8 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb8439213-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to statements and representations made on or after ","children":[{"tag":"date","attrib":{"date":"1999-12-14"},"text":"Dec. 14, 1999","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/106/169/s207/e"},"text":"section 207(e) of Pub. L. 106–169","children":[],"tail":", set out as an Effective Date of 1999 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s402"},"text":"section 402 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb8439214-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/169/tII/s207/d"},"text":"Pub. L. 106–169, title II, § 207(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-12-14"},"text":"Dec. 14, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1838"},"text":"113 Stat. 1838","children":[],"tail":", required, within 6 months after "},{"tag":"date","attrib":{"date":"1999-12-14"},"text":"Dec. 14, 1999","children":[],"tail":", the development of regulations prescribing the administrative process for making determinations under this section and guidance on discretion in imposing penalties."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
