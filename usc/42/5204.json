{"tag":"section","attrib":{"id":"idbd310305-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5204"},"text":null,"children":[{"tag":"num","attrib":{"value":"5204"},"text":"§ 5204.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Insular areas disaster survival and recovery; definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in sections 5204 to 5204c of this title—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd310306-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5204/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “insular area” means any of the following: American Samoa, the Federated States of Micronesia, Guam, the Marshall Islands, the Northern Mariana Islands, the Trust Territory of the Pacific Islands, and the Virgin Islands;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd310307-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5204/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “disaster” means a declaration of a major disaster by the President after ","children":[{"tag":"date","attrib":{"date":"1989-09-01"},"text":"September 1, 1989","children":[],"tail":", pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5170"},"text":"section 5170 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd310308-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5204/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Secretary” means the Secretary of the Interior.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd310309-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/247/tII/s201"},"text":"Pub. L. 102–247, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-02-24"},"text":"Feb. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/37"},"text":"106 Stat. 37","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd31030a-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd31030b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbd31030c-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Sections 5204 to 5204c of this title, referred to in text, was in the original “this title”, meaning title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/247"},"text":"Pub. L. 102–247","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-02-24"},"text":"Feb. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/37"},"text":"106 Stat. 37","children":[],"tail":", which enacted sections 5204 to 5204c of this title and amended "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5122"},"text":"section 5122 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbd31030d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Omnibus Insular Areas Act of 1992, and not as part of the Robert T. Stafford Disaster Relief and Emergency Assistance Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idbd31030e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbd31030f-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Termination of Trust Territory of the Pacific Islands","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For termination of Trust Territory of the Pacific Islands, see note set out preceding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s1681"},"text":"section 1681 of Title 48","children":[],"tail":", Territories and Insular Possessions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
