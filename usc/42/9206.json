{"tag":"section","attrib":{"id":"idbeb0ed9e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9206"},"text":null,"children":[{"tag":"num","attrib":{"value":"9206"},"text":"§ 9206.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Wind resource assessment","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary shall initiate a three-year national wind resource assessment program. As part of such program, the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbeb0ed9f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9206/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct activities to validate existing assessments of known wind resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbeb0eda0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9206/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" perform wind resource assessments in regions of the United States where the use of wind energy may prove feasible;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbeb0eda1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9206/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" initiate a general site prospecting program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbeb0eda2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9206/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish standard wind data collection and siting techniques; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbeb0eda3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9206/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish, in consultation with the Administrator of the National Oceanic and Atmospheric Administration, the Administrator of the National Aeronautics and Space Administration, and the Administrator of the Environmental Protection Agency, a national wind data center which shall make public information available on the known wind energy resources of various regions throughout the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbeb0eda4-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/345/s7"},"text":"Pub. L. 96–345, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-09-08"},"text":"Sept. 8, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1143"},"text":"94 Stat. 1143","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
