{"tag":"section","attrib":{"id":"idbc82e9be-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3505b"},"text":null,"children":[{"tag":"num","attrib":{"value":"3505b"},"text":"§ 3505b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions and duties of Deputy Assistant Secretary for Population Affairs","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary shall utilize the Deputy Assistant Secretary for Population Affairs—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc82e9bf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3505b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to administer all Federal laws for which the Secretary has administrative responsibility and which provide for or authorize the making of grants or contracts related to population research and family planning programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc82e9c0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3505b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to administer and be responsible for all population and family planning research carried on directly by the Department of Health and Human Services or supported by the Department through grants to, or contracts with, entities and individuals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc82e9c1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3505b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to act as a clearinghouse for information pertaining to domestic and international population research and family planning programs for use by all interested persons and public and private entities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc82e9c2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3505b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide a liaison with the activities carried on by other agencies and instrumentalities of the Federal Government relating to population research and family planning;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc82e9c3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3505b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide or support training for necessary manpower for domestic programs of population research and family planning programs of service and research; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc82e9c4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3505b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to coordinate and be responsible for the evaluation of the other Department of Health and Human Services programs related to population research and family planning and to make periodic recommendations to the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc82e9c5-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/572/s4"},"text":"Pub. L. 91–572, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-24"},"text":"Dec. 24, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1505"},"text":"84 Stat. 1505","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/88/tV/s509/b"},"text":"Pub. L. 96–88, title V, § 509(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-10-17"},"text":"Oct. 17, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/695"},"text":"93 Stat. 695","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc82e9c6-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbc82e9c7-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idbc82e9c8-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Department of Health and Human Services” substituted for “Department of Health, Education, and Welfare” in pars. (2) and (6) pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/88/s509/b"},"text":"section 509(b) of Pub. L. 96–88","children":[],"tail":", which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s3508/b"},"text":"section 3508(b) of Title 20","children":[],"tail":", Education."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
