{"tag":"section","attrib":{"id":"idb40b8d59-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s194"},"text":null,"children":[{"tag":"num","attrib":{"value":"194"},"text":"§ 194.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quarters for bureau","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of Health and Human Services is directed to furnish sufficient quarters for the work of this bureau at an annual rental not to exceed $2,000.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb40b8d5a-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1912-04-09/ch73/s4"},"text":"Apr. 9, 1912, ch. 73, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/37/80"},"text":"37 Stat. 80","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1913-03-04/ch141/s3"},"text":"Mar. 4, 1913, ch. 141, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/37/737"},"text":"37 Stat. 737","children":[],"tail":"; 1946 Reorg. Plan No. 2, § 1, eff. "},{"tag":"date","attrib":{"date":"1946-07-16"},"text":"July 16, 1946","children":[],"tail":", 11 F.R. 7873, "},{"tag":"ref","attrib":{"href":"/us/stat/60/1095"},"text":"60 Stat. 1095","children":[],"tail":"; 1953 Reorg. Plan No. 1, §§ 5, 8, eff. "},{"tag":"date","attrib":{"date":"1953-04-11"},"text":"Apr. 11, 1953","children":[],"tail":", 18 F.R. 2053, "},{"tag":"ref","attrib":{"href":"/us/stat/67/631"},"text":"67 Stat. 631","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/88/tV/s509/b"},"text":"Pub. L. 96–88, title V, § 509(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-10-17"},"text":"Oct. 17, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/695"},"text":"93 Stat. 695","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb40b8d5b-