{"tag":"section","attrib":{"id":"idbd90617b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6312"},"text":null,"children":[{"tag":"num","attrib":{"value":"6312"},"text":"§ 6312.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes and coverage","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd90617c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6312/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional statement of purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It is the purpose of this part to improve the efficiency of electric motors and pumps and certain other industrial equipment in order to conserve the energy resources of the Nation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd90617d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6312/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusion of industrial equipment as covered equipment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may, by rule, include a type of industrial equipment as covered equipment if he determines that to do so is necessary to carry out the purposes of this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd90617e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6312/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusion of component parts of consumer products as industrial equipment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may, by rule, include as industrial equipment articles which are component parts of consumer products, if he determines that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd90617f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6312/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such articles are, to a significant extent, distributed in commerce other than as component parts for consumer products; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd906180-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6312/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such articles meet the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6311/2/A"},"text":"section 6311(2)(A) of this title","children":[],"tail":" (other than clauses (ii) and (iii))."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd906181-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/163/tIII/s341"},"text":"Pub. L. 94–163, title III, § 341","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/95/619/tIV/s441/a"},"text":"Pub. L. 95–619, title IV, § 441(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-09"},"text":"Nov. 9, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3268"},"text":"92 Stat. 3268","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
