{"tag":"section","attrib":{"id":"idbd526e2f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5416"},"text":null,"children":[{"tag":"num","attrib":{"value":"5416"},"text":"§ 5416.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consumer’s manual; contents","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary shall develop guidelines for a consumer’s manual to be provided to manufactured home purchasers by the manufacturer. These manuals should identify and explain the purchasers’ responsibilities for operation, maintenance, and repair of their manufactured homes.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbd526e30-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/383/tVI/s617"},"text":"Pub. L. 93–383, title VI, § 617","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-08-22"},"text":"Aug. 22, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/711"},"text":"88 Stat. 711","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/399/tIII/s308/c/4"},"text":"Pub. L. 96–399, title III, § 308(c)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-08"},"text":"Oct. 8, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1641"},"text":"94 Stat. 1641","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tIII/s339B/c"},"text":"Pub. L. 97–35, title III, § 339B(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/417"},"text":"95 Stat. 417","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd526e31-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd526e32-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbd526e33-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"References to “mobile homes”, wherever appearing in text, changed to “manufactured homes” in view of the amendment of title VI of the Housing and Community Development Act of 1974 (this chapter) by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/399/s308/c/4"},"text":"section 308(c)(4) of Pub. L. 96–399","children":[],"tail":" requiring the substitution of “manufactured home” for “mobile home” wherever appearing in title VI of the Housing and Community Development Act of 1974, and "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/s339B/c"},"text":"section 339B(c) of Pub. L. 97–35","children":[],"tail":" (set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1703"},"text":"section 1703 of Title 12","children":[],"tail":", Banks and Banking) providing that the terms “mobile home” and “manufactured home” shall be deemed to include the terms “mobile homes” and “manufactured homes”, respectively."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd526e34-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1980—","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/399"},"text":"Pub. L. 96–399","children":[],"tail":" substituted “manufactured home” for “mobile home”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbd526e35-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbd526e36-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective upon the expiration of 180 days following ","children":[{"tag":"date","attrib":{"date":"1974-08-22"},"text":"Aug. 22, 1974","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/93/383/s627"},"text":"section 627 of Pub. L. 93–383","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5401"},"text":"section 5401 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
