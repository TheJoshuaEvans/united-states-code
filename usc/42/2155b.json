{"tag":"section","attrib":{"id":"idbbf17ea6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2155b"},"text":null,"children":[{"tag":"num","attrib":{"value":"2155b"},"text":"§ 2155b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" International nuclear export and innovation activities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbbf17ea7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2155b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commission coordination","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbbf17ea8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2155b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commission shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbbf17ea9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2155b/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" coordinate all work of the Commission relating to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbbf17eaa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2155b/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" import and export licensing for nuclear reactors and radioactive materials; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbbf17eab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2155b/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" international regulatory cooperation and assistance relating to nuclear reactors and radioactive materials, including with countries that are members of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbbf17eac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2155b/a/1/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Organisation for Economic Co-operation and Development; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbbf17ead-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2155b/a/1/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Nuclear Energy Agency; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbbf17eae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2155b/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" support interagency and international coordination with respect to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbbf17eaf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2155b/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the consideration of international technical standards to establish the licensing and regulatory basis to assist the design, construction, and operation of nuclear reactors and use of radioactive materials;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbbf17eb0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2155b/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" efforts to help build competent nuclear regulatory organizations and legal frameworks in foreign countries that are seeking to develop civil nuclear industries; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbbf17eb1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2155b/a/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exchange programs and training provided, in coordination with the Secretary of State, to foreign countries relating to civil nuclear licensing and oversight to improve the regulation of nuclear reactors and radioactive materials, in accordance with paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbf17eb2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2155b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exchange programs and training","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to the exchange programs and training described in paragraph (1)(B)(iii), the Commission shall coordinate, as applicable, with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbbf17eb3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2155b/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Energy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbbf17eb4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2155b/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbbf17eb5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2155b/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Laboratories;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbbf17eb6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2155b/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the private sector; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbbf17eb7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2155b/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" institutions of higher education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbbf17eb8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2155b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to establish branch","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission may establish within the Office of International Programs a branch, to be known as the “International Nuclear Export and Innovation Branch”, to carry out the international nuclear export and innovation activities described in subsection (a) as the Commission determines to be appropriate and within the mission of the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbbf17eb9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2155b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbbf17eba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2155b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interagency coordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall coordinate all international activities under this section with the Secretary of State, the Secretary of Energy, and other applicable agencies, as appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbbf17ebb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2155b/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Savings clause","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section alters the authority of the Commission to license and regulate the civilian use of radioactive materials.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbbf17ebc-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/67/dB/tI/s101"},"text":"Pub. L. 118–67, div. B, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-07-09"},"text":"July 9, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1450"},"text":"138 Stat. 1450","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbbf17ebd-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbbf17ebe-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbbf17ebf-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Accelerating Deployment of Versatile, Advanced Nuclear for Clean Energy Act of 2024, also known as the ADVANCE Act of 2024, and not as part of the Atomic Energy Act of 1954 which comprises this chapter.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/67/dB/s101"},"text":"section 101 of div. B of Pub. L. 118–67","children":[],"tail":". Subsec. (c) of "},{"tag":"ref","attrib":{"href":"/us/pl/118/67/dB/s101"},"text":"section 101 of div. B of Pub. L. 118–67","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2215"},"text":"section 2215 of this title","children":[],"tail":" and enacted provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2215"},"text":"section 2215 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbbf17ec0-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idbbf17ec1-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definitions of terms used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/67/dB/s2"},"text":"section 2 of div. B of Pub. L. 118–67","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2011"},"text":"section 2011 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
