{"tag":"section","attrib":{"id":"idbb2b96ec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1490l"},"text":null,"children":[{"tag":"num","attrib":{"value":"1490l"},"text":"§ 1490l.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Processing of applications","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbb2b96ed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1490l/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as otherwise provided in subsection (c), the Secretary shall, in making assistance available under this subchapter, give a priority to applications submitted by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb2b96ee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1490l/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" persons and families that have the greatest housing assistance needs because of their low income and their residing in inadequate dwellings;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb2b96ef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1490l/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" applicants applying for assistance for projects that will serve such persons and families; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb2b96f0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1490l/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" applicants residing in areas which are the most rural in character.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb2b96f1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1490l/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preliminary reservation of assistance at time of initial approval of project","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In making available the assistance authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1483"},"text":"section 1483 of this title","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1490a/a"},"text":"section 1490a(a) of this title","children":[],"tail":" with respect to projects involving insured and guaranteed loans and interest credits and rental assistance payments, the Secretary shall process and approve requests for such assistance in a manner that provides for a preliminary reservation of assistance at the time of initial approval of the project."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb2b96f2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1490l/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prioritization of section 1485 housing assistance","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb2b96f3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1490l/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall make assistance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1485"},"text":"section 1485 of this title","children":[],"tail":" available pursuant to an objective procedure established by the Secretary, under which the Secretary shall identify counties and communities having the greatest need for such assistance and designate such counties and communities to receive such assistance."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb2b96f4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1490l/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Objective measures","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall use the following objective measures to determine the need for rental housing assistance under paragraph (1):","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbb2b96f5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1490l/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The incidence of poverty.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb2b96f6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1490l/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The lack of affordable housing and the existence of substandard housing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb2b96f7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1490l/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The lack of mortgage credit.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb2b96f8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1490l/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The rural characteristics of the location.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb2b96f9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1490l/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Other factors as determined by the Secretary, demonstrating the need for affordable housing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb2b96fa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1490l/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In administering this subsection, the Secretary shall use information from the most recent decennial census of the United States, relevant comprehensive affordable housing strategies under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12705"},"text":"section 12705 of this title","children":[],"tail":", and other reliable sources obtained by the Secretary which demonstrate the need for affordable housing in rural areas."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb2b96fb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1490l/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A designation under this subsection shall not be effective for a period of more than 3 years, but may be renewed by the Secretary in accordance with the procedure set forth in this subsection. The Secretary shall take such other reasonable actions as the Secretary considers to be appropriate to notify the public of such designations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbb2b96fc-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-07-15/ch338"},"text":"July 15, 1949, ch. 338","children":[],"tail":", title V, § 532, as added "},{"tag":"ref","attrib":{"href":"/us/pl/98/181/tI"},"text":"Pub. L. 98–181, title I","children":[],"tail":" [title V, § 521], "},{"tag":"date","attrib":{"date":"1983-11-30"},"text":"Nov. 30, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/1250"},"text":"97 Stat. 1250","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/180/tVII/s734/f"},"text":"Pub. L. 104–180, title VII, § 734(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-06"},"text":"Aug. 6, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1604"},"text":"110 Stat. 1604","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbb2b96fd-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbb2b96fe-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbb2b96ff-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/180/s734/f/1"},"text":"Pub. L. 104–180, § 734(f)(1)","children":[],"tail":", substituted “Except as otherwise provided in subsection (c), the Secretary” for “The Secretary” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/180/s734/f/2"},"text":"Pub. L. 104–180, § 734(f)(2)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
