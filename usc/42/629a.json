{"tag":"section","attrib":{"id":"idb79f14b5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629a"},"text":null,"children":[{"tag":"num","attrib":{"value":"629a"},"text":"§ 629a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb79f14b6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As used in this subpart:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb79f14b7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Family preservation services","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “family preservation services” means services for children, youth, and families designed to help families (including kinship and adoptive families) at risk or in crisis, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb79f14b8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629a/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" service programs designed to help children—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb79f14b9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629a/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" where safe and appropriate, return to families from which they have been removed; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb79f14ba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629a/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be placed for adoption, with a legal guardian, or, if adoption or legal guardianship is determined not to be safe and appropriate for a child, in some other planned, permanent living arrangement;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb79f14bb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629a/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preplacement preventive services programs, such as intensive family preservation programs, designed to help children at risk of foster care placement remain safely with their families;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb79f14bc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629a/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" service programs designed to provide followup care to families to whom a child has been returned after a foster care placement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb79f14bd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629a/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" respite care of children to provide temporary relief for parents, kinship caregivers, and foster parents;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb79f14be-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629a/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" services designed to improve parenting skills (by reinforcing parents’ confidence in their strengths, and helping them to identify where improvement is needed and to obtain assistance in improving those skills) with respect to matters such as child development, family budgeting, coping with stress, health, and nutrition;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb79f14bf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629a/a/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" infant safe haven programs to provide a way for a parent to safely relinquish a newborn infant at a safe haven designated pursuant to a State law;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb79f14c0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629a/a/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb79f14c1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629a/a/1/G/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" peer-to-peer mentoring and support programs with demonstrated experience fostering constructive relationships between children and families and mentors with relevant lived experience or interactions with the child welfare system; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb79f14c2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629a/a/1/G/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for purposes of this subpart, an expenditure for a service described in clause (i) may be treated as an expenditure for any 1 or more of family support services, family preservation services, family reunification services, or adoption promotion and support services, as long as the expenditure is related to serving the children and families in the specified category and consistent with the overall purpose of the category; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb79f14c3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629a/a/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb79f14c4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629a/a/1/H/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" services providing nonrecurring short term benefits (including supports related to housing instability, utilities, transportation, and food assistance, among other basic needs) that address immediate needs related to a specific crisis, situation, or event affecting the ability of a child to remain in a home established for the child that is not intended to meet an ongoing need; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb79f14c5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629a/a/1/H/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for purposes of this subpart, an expenditure for a service described in clause (i) may be treated as an expenditure for any 1 or more of family support services, family preservation services, family reunification services, or adoption promotion and support services as long as the expenditure is related to serving the children and families in the specified category and consistent with the overall purpose of the category.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb79f14c6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Family support services","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb79f14c7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629a/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “family support services” means community-based services, including services provided by family resource centers, designed to carry out the purposes described in subparagraph (B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb79f14c8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629a/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes described","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes described in this subparagraph are the following:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb79f14c9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629a/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To promote the safety and well-being of children, youth, and families.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb79f14ca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629a/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To increase the strength and stability of families (including adoptive, foster, and kinship families).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb79f14cb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629a/a/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To support and retain foster families so they can provide quality family-based settings for children in foster care.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb79f14cc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629a/a/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To increase parents’ confidence and competence in their parenting abilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb79f14cd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629a/a/2/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To afford children a safe, stable, and supportive family environment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb79f14ce-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629a/a/2/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To strengthen parental relationships and promote healthy marriages.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb79f14cf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629a/a/2/B/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To enhance child development, including through mentoring.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb79f14d0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State agency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State agency” means the State agency responsible for administering the program under subpart 1.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb79f14d1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629a/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State” includes an Indian tribe or tribal organization, in addition to the meaning given such term for purposes of subpart 1.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb79f14d2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629a/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian tribe","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Indian tribe” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s628/d"},"text":"section 628(d) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb79f14d3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629a/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tribal organization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “tribal organization” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s628/d"},"text":"section 628(d) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb79f14d4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629a/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Family reunification services","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb79f14d5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629a/a/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “family reunification services” means the services and activities described in subparagraph (B) that are provided to a child that is removed from the child’s home and placed with kinship caregivers or in a foster family home or a child care institution or a child who has been returned home and to the parents or primary caregiver of such a child, in order to facilitate the reunification of the child safely and appropriately within a timely fashion and to ensure the strength and stability of the reunification. In the case of a child who has been returned home, the services and activities shall only be provided during the 15-month period that begins on the date that the child returns home.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb79f14d6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629a/a/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Services and activities described","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The services and activities described in this subparagraph are the following:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb79f14d7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629a/a/7/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Individual, group, and family counseling.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb79f14d8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629a/a/7/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Inpatient, residential, or outpatient substance abuse treatment services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb79f14d9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629a/a/7/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Mental health services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb79f14da-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629a/a/7/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Assistance to address domestic violence.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb79f14db-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629a/a/7/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Services designed to provide temporary child care and therapeutic services for families, including crisis nurseries.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb79f14dc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629a/a/7/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Peer-to-peer mentoring and support groups for parents and primary caregivers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb79f14dd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629a/a/7/B/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Services and activities designed to facilitate access to and visitation of children by parents and siblings.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb79f14de-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629a/a/7/B/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Transportation to or from any of the services and activities described in this subparagraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb79f14df-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629a/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adoption promotion and support services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “adoption promotion and support services” means services and activities designed to encourage more adoptions out of the foster care system, when adoptions promote the best interests of children, including such activities as pre- and post-adoptive services and activities designed to expedite the adoption process and support adoptive families.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb79f14e0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629a/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-Federal funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “non-Federal funds” means State funds, or at the option of a State, State and local funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb79f14e1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629a/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Family resource center","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb79f14e2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629a/a/10/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “family resource center” means a community or school-based hub of support services for families that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb79f14e3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629a/a/10/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" utilizes an approach that is multi-generational, strengths-based, and family-centered;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb79f14e4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629a/a/10/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reflects, and is responsive to, community needs and interests;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb79f14e5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629a/a/10/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides support at no or low cost for participants; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb79f14e6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629a/a/10/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" builds communities of peer support for families, including kinship families, to develop social connections that reduce isolation and stress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb79f14e7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629a/a/10/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subpart, an expenditure for a service provided by a family resource center may be treated as an expenditure for any 1 or more of family support services, family preservation services, family reunification services, or adoption promotion and support services as long as the expenditure is related to serving the children and families in the specified category and consistent with the overall purpose of the category.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb79f14e8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629a/a/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Youth","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “youth” means an individual who has not attained 26 years of age.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb79f14e9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629a/a/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mentoring","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “mentoring” means a structured, managed program in which children are appropriately matched with screened and trained adult volunteers for one on-one relationships, involving meetings and activities on a regular basis, intended to meet, in part, the child’s need for involvement with a caring and supportive adult who provides a positive role model.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb79f14ea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other terms","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For other definitions of other terms used in this subpart, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s675"},"text":"section 675 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb79f14eb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of technology","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb79f14ec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of portal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The services referred to in subsection (a) may include the means of access to and use of an electronic or digital portal to facilitate the provision of community support to care for and meet specific needs of families and children.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb79f14ed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Such a portal shall not retain or share personally identifiable information about a beneficiary without consent or for any purpose other than referral.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb79f14ee-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title IV, § 431, as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/66/tXIII/s13711/a/2"},"text":"Pub. L. 103–66, title XIII, § 13711(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-10"},"text":"Aug. 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/650"},"text":"107 Stat. 650","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/89/tIII/s305/b/2"},"text":"Pub. L. 105–89, title III, § 305(b)(2)","children":[],"tail":", (c)(2), (d)(1), "},{"tag":"