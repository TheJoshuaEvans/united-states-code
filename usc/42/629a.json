, "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2951"},"text":"138 Stat. 2951","children":[],"tail":", 2955, 2959, 2961, 2967.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb79f14ef-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb79f14f0-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb79f14f1-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 431 of act ","children":[{"tag":"date","attrib":{"date":"1935-08-14"},"text":"Aug. 14, 1935","children":[],"tail":", was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s631"},"text":"section 631 of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/100/485"},"text":"Pub. L. 100–485","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb79f14f2-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/258/s110/a/1/A"},"text":"Pub. L. 118–258, § 110(a)(1)(A)","children":[],"tail":", substituted “children, youth,” for “children” and “kinship and adoptive” for “adoptive and extended” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/258/s110/a/1/B"},"text":"Pub. L. 118–258, § 110(a)(1)(B)","children":[],"tail":", substituted “parents, kinship caregivers, and foster parents” for “parents and other caregivers (including foster parents)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(G). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/258/s110/a/1/C"},"text":"Pub. L. 118–258, § 110(a)(1)(C)","children":[],"tail":"–(E), added subpar. (G)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(H). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/258/s111/a"},"text":"Pub. L. 118–258, § 111(a)","children":[],"tail":", added subpar. (H)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/258/s106/b/1"},"text":"Pub. L. 118–258, § 106(b)(1)","children":[],"tail":", inserted “, including services provided by family resource centers,” before “designed”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(B)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/258/s110/a/2/A"},"text":"Pub. L. 118–258, § 110(a)(2)(A)","children":[],"tail":", substituted “children, youth,” for “children”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(B)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/258/s110/a/2/B"},"text":"Pub. L. 118–258, § 110(a)(2)(B)","children":[],"tail":", substituted “kinship” for “extended”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(B)(vii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/258/s113/b/1"},"text":"Pub. L. 118–258, § 113(b)(1)","children":[],"tail":", struck out “(as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s629i/b/2"},"text":"section 629i(b)(2) of this title","children":[],"tail":")” after “through mentoring”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(5), (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/258/s107/a/3/B"},"text":"Pub. L. 118–258, § 107(a)(3)(B)","children":[],"tail":", substituted “628(d) of this title” for “628(c) of this title”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(7)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/258/s110/a/3"},"text":"Pub. L. 118–258, § 110(a)(3)","children":[],"tail":", inserted “with kinship caregivers or” before “in a foster family home”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(10). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/258/s106/b/2"},"text":"Pub. L. 118–258, § 106(b)(2)","children":[],"tail":", added par. (10)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(11). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/258/s110/a/4"},"text":"Pub. L. 118–258, § 110(a)(4)","children":[],"tail":", added par. (11)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(12). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/258/s113/b/2"},"text":"Pub. L. 118–258, § 113(b)(2)","children":[],"tail":", added par. (12)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/258/s106/a"},"text":"Pub. L. 118–258, § 106(a)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (a)(2)(B)(iii) to (vii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/123/s50751/a"},"text":"Pub. L. 115–123, § 50751(a)","children":[],"tail":", added cl. (iii) and redesignated former cls. (iii) to (vi) as (iv) to (vii), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/123/s50721/a/1"},"text":"Pub. L. 115–123, § 50721(a)(1)","children":[],"tail":", substituted “Family” for “Time-limited family” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(7)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/123/s50721/a/2"},"text":"Pub. L. 115–123, § 50721(a)(2)","children":[],"tail":", struck out “time-limited” before “family reunification”, inserted “or a child who has been returned home” after “child care institution”, and substituted “and to ensure the strength and stability of the reunification. In the case of a child who has been returned home, the services and activities shall only be provided during the 15-month period that begins on the date that the child returns home” for “, but only during the 15-month period that begins on the date that the child, pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s675/5/F"},"text":"section 675(5)(F) of this title","children":[],"tail":", is considered to have entered foster care”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/34/s102/c/1"},"text":"Pub. L. 112–34, § 102(c)(1)","children":[],"tail":", amended par. (2) generally. Prior to amendment, text read as follows: “The term ‘family support services’ means community-based services to promote the safety and well-being of children and families designed to increase the strength and stability of families (including adoptive, foster, and extended families), to increase parents’ confidence and competence in their parenting abilities, to afford children a safe, stable, and supportive family environment, to strengthen parental relationships and promote healthy marriages, and otherwise to enhance child development.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(5), (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/34/s102/d"},"text":"Pub. L. 112–34, § 102(d)","children":[],"tail":", added pars. (5) and (6) and struck out former pars. (5) and (6) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(5) ","children":[{"tag":"inline","attrib":{},"text":"Tribal organization","children":[],"tail":".—The term ‘tribal organization’ means the recognized governing body of any Indian tribe."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(6) ","children":[{"tag":"inline","attrib":{},"text":"Indian tribe","children":[],"tail":".—The term ‘Indian tribe’ means any Indian tribe (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s682/i/5"},"text":"section 682(i)(5) of this title","children":[],"tail":", as in effect before "},{"tag":"date","attrib":{"date":"1996-08-22"},"text":"August 22, 1996","children":[],"tail":") and any Alaska Native organization (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s682/i/7/A"},"text":"section 682(i)(7)(A) of this title","children":[],"tail":", as so in effect).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(7)(B)(vi) to (viii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/34/s102/c/2"},"text":"Pub. L. 112–34, § 102(c)(2)","children":[],"tail":", added cls. (vi) and (vii) and redesignated former cl. (vi) as (viii)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (a)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/288"},"text":"Pub. L. 109–288","children":[],"tail":" substituted “1996” for “1986”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (a)(1)(F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/133/s102/a"},"text":"Pub. L. 107–133, § 102(a)","children":[],"tail":", added subpar. (F)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/133/s102/b"},"text":"Pub. L. 107–133, § 102(b)","children":[],"tail":", inserted “to strengthen parental relationships and promote healthy marriages,” after “environment,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Subsec. (a)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/169"},"text":"Pub. L. 106–169","children":[],"tail":" inserted “, as in effect before "},{"tag":"date","attrib":{"date":"1986-08-22"},"text":"August 22, 1986","children":[],"tail":"” after “682(i)(5) of this title” and “, as so in effect” after “682(i)(7)(A) of this title”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (a)(1)(A). ","children":[{"tag":"ref","attrib":{"hre