{"tag":"section","attrib":{"id":"idbddf1dd3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6956"},"text":null,"children":[{"tag":"num","attrib":{"value":"6956"},"text":"§ 6956.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to the Secretary of Commerce $5,000,000 for each of fiscal years 1980, 1981, and 1982 and $1,500,000 for each of the fiscal years 1985 through 1988 to carry out the purposes of this subchapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbddf1dd4-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/272/tII/s5006"},"text":"Pub. L. 89–272, title II, § 5006","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/96/482/s31/f/1"},"text":"Pub. L. 96–482, § 31(f)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-21"},"text":"Oct. 21, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2353"},"text":"94 Stat. 2353","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/98/616/s2/h"},"text":"Pub. L. 98–616, § 2(h)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-11-08"},"text":"Nov. 8, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3223"},"text":"98 Stat. 3223","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbddf1dd5-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbddf1dd6-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbddf1dd7-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1984—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/616"},"text":"Pub. L. 98–616","children":[],"tail":" authorized appropriation of $1,500,000 for each of fiscal years 1985 through 1988."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
