{"tag":"section","attrib":{"id":"idbf5f0753-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12102"},"text":null,"children":[{"tag":"num","attrib":{"value":"12102"},"text":"§ 12102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of disability","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf5f0754-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12102/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disability","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “disability” means, with respect to an individual—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf5f0755-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12102/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a physical or mental impairment that substantially limits one or more major life activities of such individual;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf5f0756-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12102/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a record of such an impairment; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf5f0757-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12102/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" being regarded as having such an impairment (as described in paragraph (3)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf5f0758-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12102/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Major life activities","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf5f0759-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12102/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of paragraph (1), major life activities include, but are not limited to, caring for oneself, performing manual tasks, seeing, hearing, eating, sleeping, walking, standing, lifting, bending, speaking, breathing, learning, reading, concentrating, thinking, communicating, and working.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf5f075a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12102/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Major bodily functions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of paragraph (1), a major life activity also includes the operation of a major bodily function, including but not limited to, functions of the immune system, normal cell growth, digestive, bowel, bladder, neurological, brain, respiratory, circulatory, endocrine, and reproductive functions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf5f075b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12102/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regarded as having such an impairment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of paragraph (1)(C):","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf5f075c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12102/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An individual meets the requirement of “being regarded as having such an impairment” if the individual establishes that he or she has been subjected to an action prohibited under this chapter because of an actual or perceived physical or mental impairment whether or not the impairment limits or is perceived to limit a major life activity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf5f075d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12102/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Paragraph (1)(C) shall not apply to impairments that are transitory and minor. A transitory impairment is an impairment with an actual or expected duration of 6 months or less.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf5f075e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12102/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules of construction regarding the definition of disability","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The definition of “disability” in paragraph (1) shall be construed in accordance with the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf5f075f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12102/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The definition of disability in this chapter shall be construed in favor of broad coverage of individuals under this chapter, to the maximum extent permitted by the terms of this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf5f0760-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12102/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “substantially limits” shall be interpreted consistently with the findings and purposes of the ADA Amendments Act of 2008.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf5f0761-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12102/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An impairment that substantially limits one major life activity need not limit other major life activities in order to be considered a disability.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf5f0762-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12102/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An impairment that is episodic or in remission is a disability if it would substantially limit a major life activity when active.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf5f0763-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12102/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbf5f0764-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12102/4/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The determination of whether an impairment substantially limits a major life activity shall be made without regard to the ameliorative effects of mitigating measures such as—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbf5f0765-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12102/4/E/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" medication, medical supplies, equipment, or appliances, low-vision devices (which do not include ordinary eyeglasses or contact lenses), prosthetics including limbs and devices, hearing aids and cochlear implants or other implantable hearing devices, mobility devices, or oxygen therapy equipment and supplies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbf5f0766-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12102/4/E/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use of assistive technology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbf5f0767-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12102/4/E/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reasonable accommodations or auxiliary aids or services; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbf5f0768-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12102/4/E/i/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" learned behavioral or adaptive neurological modifications.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf5f0769-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12102/4/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The ameliorative effects of the mitigating measures of ordinary eyeglasses or contact lenses shall be considered in determining whether an impairment substantially limits a major life activity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf5f076a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12102/4/E/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" As used in this subparagraph—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbf5f076b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12102/4/E/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “ordinary eyeglasses or contact lenses” means lenses that are intended to fully correct visual acuity or eliminate refractive error; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbf5f076c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12102/4/E/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “low-vision devices” means devices that magnify, enhance, or otherwise augment a visual image.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf5f076d-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/336/s3"},"text":"Pub. L. 101–336, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-07-26"},"text":"July 26, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/329"},"text":"104 Stat. 329","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/325/s4/a"},"text":"Pub. L. 110–325, § 4(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-09-25"},"text":"Sept. 25, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3555"},"text":"122 Stat. 3555","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf5f076e-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf5f076f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbf5f0770-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/336"},"text":"Pub. L. 101–336","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-07-26"},"text":"July 26, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/327"},"text":"104 Stat. 327","children":[],"tail":", which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12101"},"text":"section 12101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The ADA Amendments Act of 2008, referred to in par. (4)(B), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/325"},"text":"Pub. L. 110–325","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-09-25"},"text":"Sept. 25, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3553"},"text":"122 Stat. 3553","children":[],"tail":". Section 2 of the Act, relating to the findings and purposes of the Act, is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12101"},"text":"section 12101 of this title","children":[],"tail":". For complete classification of this Act to the Code, see Short Title of 2008 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12101"},"text":"section 12101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbf5f0771-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/325"},"text":"Pub. L. 110–325","children":[],"tail":" amended section generally. Prior to amendment, section consisted of pars. (1) to (3) defining for purposes of this chapter “auxiliary aids and services”, “disability”, and “State”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbf5f0772-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbf5f0773-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/325"},"text":"Pub. L. 110–325","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2009-01-01"},"text":"Jan. 1, 2009","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/325/s8"},"text":"section 8 of Pub. L. 110–325","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s705"},"text":"section 705 of Title 29","children":[],"tail":", Labor."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
