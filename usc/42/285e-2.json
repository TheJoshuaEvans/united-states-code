{"tag":"section","attrib":{"id":"idb5713812-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285e–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"285e–2"},"text":"§ 285e–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Alzheimer’s Disease centers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5713813-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285e–2/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperative agreements and grants for establishing and supporting","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5713814-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285e–2/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of the Institute may enter into cooperative agreements with and make grants to public or private nonprofit entities (including university medical centers) to pay all or part of the cost of planning, establishing, or strengthening, and providing basic operating support (including staffing) for centers for basic and clinical research (including multidisciplinary research) into, training in, and demonstration of advanced diagnostic, prevention, and treatment methods for Alzheimer’s disease.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5713815-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285e–2/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A cooperative agreement or grant under paragraph (1) shall be entered into in accordance with policies established by the Director of NIH and after consultation with the Institute’s advisory council.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5713816-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285e–2/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of Federal payments under cooperative agreement or grant","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5713817-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285e–2/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Federal payments made under a cooperative agreement or grant under subsection (a) may, with respect to Alzheimer’s disease, be used for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5713818-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285e–2/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" diagnostic examinations, patient assessments, patient care costs, and other costs necessary for conducting research;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5713819-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285e–2/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" training, including training for allied health professionals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb571381a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285e–2/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" diagnostic and treatment clinics designed to meet the special needs of minority and rural populations and other underserved populations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb571381b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285e–2/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" activities to educate the public; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb571381c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285e–2/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the dissemination of information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb571381d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285e–2/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of paragraph (1), the term “training” does not include research training for which Ruth L. Kirschstein National Research Service Awards may be provided under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s288"},"text":"section 288 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb571381e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285e–2/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Support period; additional periods","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Support of a center under subsection (a) may be for a period of not to exceed five years. Such period may be extended by the Director for additional periods of not more than five years each if the operations of such center have been reviewed by an appropriate technical and scientific peer review group established by the Director and if such group has recommended to the Director that such period should be extended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb571381f-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title IV, § 445, as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/158/s2"},"text":"Pub. L. 99–158, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-11-20"},"text":"Nov. 20, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/855"},"text":"99 Stat. 855","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/557/tII/s201"},"text":"Pub. L. 101–557, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-15"},"text":"Nov. 15, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2767"},"text":"104 Stat. 2767","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/206/tI/s804/c"},"text":"Pub. L. 107–206, title I, § 804(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-02"},"text":"Aug. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/874"},"text":"116 Stat. 874","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb5713820-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb5713821-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb5713822-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/206"},"text":"Pub. L. 107–206","children":[],"tail":" substituted “Ruth L. Kirschstein National Research Service Awards” for “National Research Service Awards”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/557/s201/1"},"text":"Pub. L. 101–557, § 201(1)","children":[],"tail":", inserted “(including university medical centers)” after “nonprofit entities”, “(including staffing)” after “operating support”, and “(including multidisciplinary research)” after “clinical research” and substituted “Alzheimer’s disease” for “Alzheimer’s Disease”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/557/s201/2"},"text":"Pub. L. 101–557, § 201(2)","children":[],"tail":", amended subsec. (b) generally. Prior to amendment, subsec. (b) read as follows: “Federal payments made under a cooperative agreement or grant under subsection (a) of this section may be used for—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) construction (notwithstanding any limitation under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s289e"},"text":"section 289e of this title","children":[],"tail":");"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) staffing and other basic operating costs, including such patient care costs as are required for research;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) training, including training for allied health professionals; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(4) demonstration purposes.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"As used in this subsection, the term ‘construction’ does not include the acquisition of land, and the term ‘training’ does not include research training for which National Research Service Awards may be provided under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s288"},"text":"section 288 of this title","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb5713823-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb5713824-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Alzheimer’s Disease Research","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/175/tIII"},"text":"Pub. L. 100–175, title III","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-11-29"},"text":"Nov. 29, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/972"},"text":"101 Stat. 972","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/175/tIII"},"text":"\n","children":[{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"301"},"text":"“SEC. 301.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" REQUIREMENT FOR CLINICAL TRIALS.","children":[],"tail":null},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Director of the National Institute on Aging shall provide for the conduct of clinical trials on the efficacy of the use of such promising therapeutic agents as have been or may be discovered and recommended for further scientific analysis by the National Institute on Aging and the Food and Drug Administration to treat individuals with Alzheimer’s disease, to retard the progression of symptoms of Alzheimer’s disease, or to improve the functioning of individuals with such disease.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rule of Construction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this title shall be construed to affect adversely any research being conducted as of the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1987-11-29"},"text":"Nov. 29, 1987","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"302"},"text":"“SEC. 302.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" AUTHORIZATION OF APPROPRIATIONS.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"“For the purpose of carrying out section 301, there is authorized to be appropriated $2,000,000 for fiscal year 1988.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb5713825-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Alzheimer’s Disease Registry","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/158/s12"},"text":"Section 12 of Pub. L. 99–158","children":[],"tail":", which was formerly set out as a note under this section, was renumbered section 445G of the Public Health Service Act by "},{"tag":"ref","attrib":{"href":"/us/pl/103/43/tVIII/s801/a"},"text":"Pub. L. 103–43, title VIII, § 801(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-06-10"},"text":"June 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/163"},"text":"107 Stat. 163","children":[],"tail":", and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s285e–9"},"text":"section 285e–9 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
