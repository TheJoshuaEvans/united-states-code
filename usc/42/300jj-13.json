{"tag":"section","attrib":{"id":"idb6d6e1f4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–13"},"text":null,"children":[{"tag":"num","attrib":{"value":"300jj–13"},"text":"§ 300jj–13.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Setting priorities for standards adoption","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb6d6e1f5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–13/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Identifying priorities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6d6e1f6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–13/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 6 months after the date on which the HIT Advisory Committee first meets, the National Coordinator shall periodically convene the HIT Advisory Committee to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6d6e1f7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–13/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" identify priority uses of health information technology, focusing on priorities—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb6d6e1f8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–13/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" arising from the implementation of the incentive programs for the meaningful use of certified EHR technology, the Merit-based Incentive Payment System, Alternative Payment Models, the Hospital Value-Based Purchasing Program, and any other value-based payment program determined appropriate by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6d6e1f9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–13/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" related to the quality of patient care;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6d6e1fa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–13/a/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" related to public health;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6d6e1fb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–13/a/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" related to clinical research;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6d6e1fc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–13/a/1/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" related to the privacy and security of electronic health information;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6d6e1fd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–13/a/1/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" related to innovation in the field of health information technology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6d6e1fe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–13/a/1/A/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" related to patient safety;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6d6e1ff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–13/a/1/A/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" related to the usability of health information technology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6d6e200-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–13/a/1/A/ix"},"text":null,"children":[{"tag":"num","attrib":{"value":"ix"},"text":"(ix)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" related to individuals’ access to electronic health information; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6d6e201-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–13/a/1/A/x"},"text":null,"children":[{"tag":"num","attrib":{"value":"x"},"text":"(x)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other priorities determined appropriate by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6d6e202-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–13/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify existing standards and implementation specifications that support the use and exchange of electronic health information needed to meet the priorities identified in subparagraph (A); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6d6e203-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–13/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" publish a report summarizing the findings of the analysis conducted under subparagraphs (A) and (B) and make appropriate recommendations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6d6e204-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–13/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prioritization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In identifying such standards and implementation specifications under paragraph (1)(B), the HIT Advisory Committee shall prioritize standards and implementation specifications developed by consensus-based standards development organizations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6d6e205-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–13/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guidelines for review of existing standards and specifications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In consultation with the consensus-based entity described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395aaa"},"text":"section 1395aaa of this title","children":[],"tail":" and other appropriate Federal agencies, the analysis of existing standards under paragraph (1)(B) shall include an evaluation of the need for a core set of common data elements and associated value sets to enhance the ability of certified health information technology to capture, use, and exchange structured electronic health information."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6d6e206-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–13/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review of adopted standards","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6d6e207-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–13/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Beginning 5 years after ","children":[{"tag":"date","attrib":{"date":"2016-12-13"},"text":"December 13, 2016","children":[],"tail":", and every 3 years thereafter, the National Coordinator shall convene stakeholders to review the existing set of adopted standards and implementation specifications and make recommendations with respect to whether to—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6d6e208-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–13/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain the use of such standards and implementation specifications; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6d6e209-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–13/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" phase out such standards and implementation specifications.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6d6e20a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–13/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priorities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The HIT Advisory Committee, in collaboration with the National Institute for Standards and Technology, shall annually and through the use of public input, review and publish priorities for the use of health information technology, standards, and implementation specifications to support those priorities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6d6e20b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–13/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed to prevent the use or adoption of novel standards that improve upon the existing health information technology infrastructure and facilitate the secure exchange of health information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb6d6e20c-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XXX, § 3003, as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/255/dA/tIV/s4003/f"},"text":"Pub. L. 114–255, div. A, title IV, § 4003(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-13"},"text":"Dec. 13, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1175"},"text":"130 Stat. 1175","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb6d6e20d-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb6d6e20e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb6d6e20f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 300jj–13, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373/tXXX/s3003"},"text":"act July 1, 1944, ch. 373, title XXX, § 3003","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/5/dA/tXIII/s13101"},"text":"Pub. L. 111–5, div. A, title XIII, § 13101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-02-17"},"text":"Feb. 17, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/238"},"text":"123 Stat. 238","children":[],"tail":", related to the establishment, duties, and membership of the HIT Standards Committee, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/114/255/dA/tIV/s4003/e/1"},"text":"Pub. L. 114–255, div. A, title IV, § 4003(e)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-13"},"text":"Dec. 13, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1168"},"text":"130 Stat. 1168","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
