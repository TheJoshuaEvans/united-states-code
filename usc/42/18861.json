{"tag":"section","attrib":{"id":"idc06ec8bd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18861"},"text":null,"children":[{"tag":"num","attrib":{"value":"18861"},"text":"§ 18861.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of Clean Energy Demonstrations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc06ec8be-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18861/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc06ec8bf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18861/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered project","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “covered project” means a demonstration project of the Department that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc06ec8c0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18861/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" receives or is eligible to receive funding from the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06ec8c1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18861/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is authorized under—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc06ec8c2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18861/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" this division; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc06ec8c3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18861/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Energy Act of 2020 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Public Law 116–260","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/134/1182"},"text":"134 Stat. 1182","children":[],"tail":")."},{"tag":"ref","attrib":{"idref":"fn004375"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004375"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06ec8c4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18861/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “program” means the program established under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc06ec8c5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18861/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, in coordination with the heads of relevant program offices of the Department, including the Office of Technology Transitions, the Loan Program Office, and all applied program offices, shall establish a program to conduct project management and oversight of covered projects, including by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc06ec8c6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18861/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conducting evaluations of proposals for covered projects before the selection of a covered project for funding;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06ec8c7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18861/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conducting independent oversight of the execution of a covered project after funding has been awarded for that covered project; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06ec8c8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18861/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensuring a balanced portfolio of investments in covered projects.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc06ec8c9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18861/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall appoint a head of the program who shall, in coordination with the heads of relevant program offices of the Department—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc06ec8ca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18861/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluate proposals for covered projects, including scope, technical specifications, maturity of design, funding profile, estimated costs, proposed schedule, proposed technical and financial milestones, and potential for commercial success based on economic and policy projections;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06ec8cb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18861/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop independent cost estimates for a proposal for a covered project, if appropriate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06ec8cc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18861/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommend to the head of a program office of the Department, as appropriate, whether to fund a proposal for a covered project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06ec8cd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18861/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" oversee the execution of covered projects that receive funding from the Secretary, including reconciling estimated costs as compared to actual costs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06ec8ce-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18861/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" conduct reviews of ongoing covered projects, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc06ec8cf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18861/c/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluating the progress of a covered project based on the proposed schedule and technical and financial milestones; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06ec8d0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18861/c/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing the evaluations under subparagraph (A) to the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06ec8d1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18861/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assess the lessons learned in overseeing covered projects and implement improvements in the process of evaluating and overseeing covered projects.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc06ec8d2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18861/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To carry out the program, the Secretary may hire appropriate personnel, including by using the authorities in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s19321"},"text":"section 19321 of this title","children":[],"tail":", to perform the duties of the program."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc06ec8d3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18861/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may solicit, select, and manage covered projects directly through the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc06ec8d4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18861/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Project termination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Should an ongoing covered project receive an unfavorable review under subsection (c)(5), the Secretary or their designee may cease funding the covered project and reallocate the remaining funds to new or existing covered projects carried out by that program office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc06ec8d5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18861/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the program, the head of the program shall coordinate with—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc06ec8d6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18861/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" project management and acquisition management entities with the Department, including the Office of Project Management; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06ec8d7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18861/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" professional organizations in project management, construction, cost estimation, and other relevant fields.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc06ec8d8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18861/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc06ec8d9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18861/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report by Secretary","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16391a"},"text":"section 16391a of this title","children":[],"tail":", the Secretary shall include in each updated technology transfer execution plan submitted under subsection (h)(2) of "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s16391"},"text":"section 16391 of this title","children":[],"tail":" information on the implementation of and progress made under the program, including, for the year covered by the report—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc06ec8da-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18861/h/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the covered projects under the purview of the program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06ec8db-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18861/h/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the review of each covered project carried out under subsection (c)(5).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06ec8dc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18861/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report by Comptroller General","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 3 years after ","children":[{"tag":"date","attrib":{"date":"2021-11-15"},"text":"November 15, 2021","children":[],"tail":", the Comptroller General of the United States shall submit to the Committee on Energy and Natural Resources of the Senate and the Committee on Science, Space, and Technology of the House of Representatives a report evaluating the operation of the program, including—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc06ec8dd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18861/h/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the processes and procedures used by the program to evaluate proposals of covered projects and the oversight of covered projects; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06ec8de-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18861/h/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any recommended changes in the program, including changes to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc06ec8df-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18861/h/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the processes and procedures described in subparagraph (A); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc06ec8e0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18861/h/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the structure of the program, for the purpose of better carrying out the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc06ec8e1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18861/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc06ec8e2-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dD/tXII/s41201"},"text":"Pub. L. 117–58, div. D, title XII, § 41201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1130"},"text":"135 Stat. 1130","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/tVI/s10723"},"text":"Pub. L. 117–167, div. B, title VI, § 10723","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1709"},"text":"136 Stat. 1709","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc06ec8e3-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc06ec8e4-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc06ec8e5-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This division, referred to in subsec. (a)(1)(B)(i), is div. D of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/923"},"text":"135 Stat. 923","children":[],"tail":", which enacted this chapter and enacted and amended numerous other sections and notes in the Code. For complete classification of div. D to the Code, see Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Energy Act of 2020, referred to in subsec. (a)(1)(B)(ii), is div. Z of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Pub. L. 116–260","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2418"},"text":"134 Stat. 2418","children":[],"tail":". For complete classification of div. Z to the Code, see Short Title of 2020 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s17001"},"text":"section 17001 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idc06ec8e6-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dD/s41201"},"text":"section 41201 of div. D of Pub. L. 117–58","children":[],"tail":". Subsec. (g) (now subsec. (i)) of "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/dD/s41201"},"text":"section 41201 of div. D of Pub. L. 117–58","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s16391"},"text":"section 16391 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc06ec8e7-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/s10723/1"},"text":"Pub. L. 117–167, § 10723(1)","children":[],"tail":", inserted “including the Office of Technology Transitions, the Loan Program Office, and all applied program offices,” after “Department,” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/s10723/2"},"text":"Pub. L. 117–167, § 10723(2)","children":[],"tail":", inserted “, including by using the authorities in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s19321"},"text":"section 19321 of this title","children":[],"tail":",” after “personnel”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (e) to (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/s10723/3"},"text":"Pub. L. 117–167, § 10723(3)","children":[],"tail":"–(5), added subsecs. (e) and (f), redesignated former subsecs. (e) to (g) as (g) to (i), respectively, and in introductory provisions of subsec. (h)(1), as redesignated, substituted “In accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s16391a"},"text":"section 16391a of this title","children":[],"tail":", the Secretary” for “The Secretary”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc06ec8e8-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc06ec8e9-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Wage Rate Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions relating to rates of wages to be paid to laborers and mechanics on projects for construction, alteration, or repair work funded under div. D or an amendment by div. D of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":", including authority of Secretary of Labor, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s18851"},"text":"section 18851 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
