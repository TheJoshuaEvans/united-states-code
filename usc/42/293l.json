{"tag":"section","attrib":{"id":"idb5da3393-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s293l"},"text":null,"children":[{"tag":"num","attrib":{"value":"293l"},"text":"§ 293l.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisory Committee on Training in Primary Care Medicine and Dentistry","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5da3394-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s293l/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish an advisory committee to be known as the Advisory Committee on Training in Primary Care Medicine and Dentistry (in this section referred to as the “Advisory Committee”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5da3395-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s293l/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Composition","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5da3396-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s293l/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall determine the appropriate number of individuals to serve on the Advisory Committee. Such individuals shall not be officers or employees of the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5da3397-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s293l/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"1998-11-13"},"text":"November 13, 1998","children":[],"tail":", the Secretary shall appoint the members of the Advisory Committee from among individuals who are health professionals. In making such appointments, the Secretary shall ensure a fair balance between the health professions, that at least 75 percent of the members of the Advisory Committee are health professionals, a broad geographic representation of members and a balance between urban and rural members. Members shall be appointed based on their competence, interest, and knowledge of the mission of the profession involved."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5da3398-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s293l/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minority representation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In appointing the members of the Advisory Committee under paragraph (2), the Secretary shall ensure the adequate representation of women and minorities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5da3399-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s293l/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5da339a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s293l/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A member of the Advisory Committee shall be appointed for a term of 3 years, except that of the members first appointed—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5da339b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s293l/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ⅓ of such members shall serve for a term of 1 year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5da339c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s293l/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ⅓ of such members shall serve for a term of 2 years; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5da339d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s293l/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ⅓ of such members shall serve for a term of 3 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5da339e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s293l/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vacancies","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5da339f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s293l/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A vacancy on the Advisory Committee shall be filled in the manner in which the original appointment was made and shall be subject to any conditions which applied with respect to the original appointment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5da33a0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s293l/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Filling unexpired term","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An individual chosen to fill a vacancy shall be appointed for the unexpired term of the member replaced.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5da33a1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s293l/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Advisory Committee shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5da33a2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s293l/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide advice and recommendations to the Secretary concerning policy and program development and other matters of significance concerning the activities under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s293k"},"text":"section 293k of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5da33a3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s293l/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 3 years after ","children":[{"tag":"date","attrib":{"date":"1998-11-13"},"text":"November 13, 1998","children":[],"tail":", and annually thereafter, prepare and submit to the Secretary, and the Committee on Health, Education, Labor, and Pensions of the Senate, and the Committee on Energy and Commerce of the House of Representatives, a report describing the activities of the Committee, including findings and recommendations made by the Committee concerning the activities under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s293k"},"text":"section 293k of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5da33a4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s293l/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop, publish, and implement performance measures for programs under this part;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5da33a5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s293l/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop and publish guidelines for longitudinal evaluations (as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s294n/d/2"},"text":"section 294n(d)(2) of this title","children":[],"tail":") for programs under this part; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5da33a6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s293l/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommend appropriation levels for programs under this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5da33a7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s293l/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings and documents","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5da33a8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s293l/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Advisory Committee shall meet not less than 2 times each year. Such meetings shall be held jointly with other related entities established under this subchapter where appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5da33a9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s293l/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Documents","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 14 days prior to the convening of a meeting under paragraph (1), the Advisory Committee shall prepare and make available an agenda of the matters to be considered by the Advisory Committee at such meeting. At any such meeting, the Advisory Council ","children":[{"tag":"ref","attrib":{"idref":"fn002266"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002266"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “Committee”."}],"tail":" shall distribute materials with respect to the issues to be addressed at the meeting. Not later than 30 days after the adjourning of such a meeting, the Advisory Committee shall prepare and make available a summary of the meeting and any actions taken by the Committee based upon the meeting."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5dca3aa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s293l/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation and expenses","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5dca3ab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s293l/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each member of the Advisory Committee shall be compensated at a rate equal to the daily equivalent of the annual rate of basic pay prescribed for level IV of the Executive Schedule under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5315"},"text":"section 5315 of title 5","children":[],"tail":" for each day (including travel time) during which such member is engaged in the performance of the duties of the Committee."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5dca3ac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s293l/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The members of the Advisory Committee shall be allowed travel expenses, including per diem in lieu of subsistence, at rates authorized for employees of agencies under subchapter I of chapter 57 of title 5 while away from their homes or regular places of business in the performance of services for the Committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5dca3ad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s293l/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chapter 10 of title 5","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Chapter 10 of title 5 shall apply to the Advisory Committee under this section only to the extent that the provisions of chapter 10 of title 5 do not conflict with the requirements of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5dca3ae-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title VII, § 749, formerly § 748, as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/392/tI/s102/4"},"text":"Pub. L. 105–392, title I, § 102(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3539"},"text":"112 Stat. 3539","children":[],"tail":"; renumbered § 749 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tV"},"text":"Pub. L. 111–148, title V","children":[],"tail":", §§ 5103(d)(1), 5303(1), "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/605"},"text":"124 Stat. 605","children":[],"tail":", 618; "},{"tag":"ref","attrib":{"href":"/us/pl/116/136/dA/tIII/s3401/5"},"text":"Pub. L. 116–136, div. A, title III, § 3401(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-03-27"},"text":"Mar. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/386"},"text":"134 Stat. 386","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/237"},"text":"Pub. L. 117–286, § 4(a)(237)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4331"},"text":"136 Stat. 4331","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb5dca3af-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb5dca3b0-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb5dca3b1-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"date","attrib":{"date":"1998-11-13"},"text":"November 13, 1998","children":[],"tail":", referred to in subsec. (b)(2), was in the original “the date of enactment of this Act”, which was translated as meaning the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/105/392"},"text":"Pub. L. 105–392","children":[],"tail":", which enacted this section, to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb5dca3b2-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 293","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373/tVII/s748"},"text":"act July 1, 1944, ch. 373, title VII, § 748","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/408/tI/s102"},"text":"Pub. L. 102–408, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-13"},"text":"Oct. 13, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2043"},"text":"106 Stat. 2043","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/531/tIII/s313/a/3"},"text":"Pub. L. 102–531, title III, § 313(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-27"},"text":"Oct. 27, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3507"},"text":"106 Stat. 3507","children":[],"tail":", authorized grants and contracts for development of general internal medicine and general pediatrics training programs, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/105/392/tI/s102/4"},"text":"Pub. L. 105–392, title I, § 102(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3539"},"text":"112 Stat. 3539","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior section 749 of act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s293m"},"text":"section 293m of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/105/392"},"text":"Pub. L. 105–392","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 749 of act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s294s"},"text":"section 294s of this title","children":[],"tail":" prior to renumbering by "},{"tag":"ref","attrib":{"href":"/us/pl/97/35"},"text":"Pub. L. 97–35","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb5dca3b3-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":" substituted “Chapter 10 of title 5” for “FACA” in heading and “Chapter 10 of title 5 shall apply to the Advisory Committee under this section only to the extent that the provisions of chapter 10 of title 5” for “The Federal Advisory Committee Act shall apply to the Advisory Committee under this section only to the extent that the provisions of such Act” in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2020—Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/136"},"text":"Pub. L. 116–136","children":[],"tail":" substituted “Committee on Health, Education, Labor, and Pensions of the Senate, and the Committee on Energy and Commerce of the House of Representatives” for “Committee on Labor and Human Resources of the Senate, and the Committee on Commerce of the House of Representatives”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—Subsec. (d)(3) to (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/s5103/d/1"},"text":"Pub. L. 111–148, § 5103(d)(1)","children":[],"tail":", added pars. (3) to (5)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb5dca3b4-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb5dca3b5-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Advisory Committees","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/93/641/s6"},"text":"Pub. L. 93–641, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-04"},"text":"Jan. 4, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2275"},"text":"88 Stat. 2275","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s217a"},"text":"section 217a of this title","children":[],"tail":", provided that an advisory committee established pursuant to the Public Health Service Act shall terminate at such time as may be specifically prescribed by an Act of Congress enacted after "},{"tag":"date","attrib":{"date":"1975-01-04"},"text":"Jan. 4, 1975","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
