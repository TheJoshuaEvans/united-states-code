{"tag":"section","attrib":{"id":"idbcc82fb1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4343"},"text":null,"children":[{"tag":"num","attrib":{"value":"4343"},"text":"§ 4343.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employment of personnel, experts and consultants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbcc82fb2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4343/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Council may employ such officers and employees as may be necessary to carry out its functions under this chapter. In addition, the Council may employ and fix the compensation of such experts and consultants as may be necessary for the carrying out of its functions under this chapter, in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3109"},"text":"section 3109 of title 5","children":[],"tail":" (but without regard to the last sentence thereof)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcc82fb3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4343/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1342"},"text":"section 1342 of title 31","children":[],"tail":", the Council may accept and employ voluntary and uncompensated services in furtherance of the purposes of the Council."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbcc82fb4-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/190/tII/s203"},"text":"Pub. L. 91–190, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-01-01"},"text":"Jan. 1, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/855"},"text":"83 Stat. 855","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/52/s2"},"text":"Pub. L. 94–52, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-07-03"},"text":"July 3, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/258"},"text":"89 Stat. 258","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbcc82fb5-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbcc82fb6-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbcc82fb7-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The last sentence of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3109"},"text":"section 3109 of title 5","children":[],"tail":", referred to in subsec. (a), probably means the last sentence of "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s3109/b"},"text":"section 3109(b) of title 5","children":[],"tail":", which was the last sentence of that section when the reference was enacted. Since then, "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s3109"},"text":"section 3109 of title 5","children":[],"tail":" has been amended to add subsecs. (c) to (e) at the end."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbcc82fb8-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsec. (b), “","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1342"},"text":"section 1342 of title 31","children":[],"tail":"” substituted for “section 3679(b) of the Revised Statutes ("},{"tag":"ref","attrib":{"href":"/us/usc/t31/s665/b"},"text":"31 U.S.C. 665(b)","children":[],"tail":")” on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/97/258/s4/b"},"text":"Pub. L. 97–258, § 4(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1067"},"text":"96 Stat. 1067","children":[],"tail":", the first section of which enacted Title 31, Money and Finance."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbcc82fb9-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1975—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/52"},"text":"Pub. L. 94–52","children":[],"tail":" designated existing provisions as subsec. (a) and added subsec. (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
