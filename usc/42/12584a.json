{"tag":"section","attrib":{"id":"idbf7b8fba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12584a"},"text":null,"children":[{"tag":"num","attrib":{"value":"12584a"},"text":"§ 12584a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibited activities and ineligible organizations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf7b8fbb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12584a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibited activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An approved national service position under this division may not be used for the following activities:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf7b8fbc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12584a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Attempting to influence legislation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf7b8fbd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12584a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Organizing or engaging in protests, petitions, boycotts, or strikes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf7b8fbe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12584a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Assisting, promoting, or deterring union organizing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf7b8fbf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12584a/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Impairing existing contracts for services or collective bargaining agreements.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf7b8fc0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12584a/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Engaging in partisan political activities, or other activities designed to influence the outcome of an election to Federal office or the outcome of an election to a State or local public office.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf7b8fc1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12584a/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Participating in, or endorsing, events or activities that are likely to include advocacy for or against political parties, political platforms, political candidates, proposed legislation, or elected officials.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf7b8fc2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12584a/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Engaging in religious instruction, conducting worship services, providing instruction as part of a program that includes mandatory religious instruction or worship, constructing or operating facilities devoted to religious instruction or worship, maintaining facilities primarily or inherently devoted to religious instruction or worship, or engaging in any form of proselytization, consistent with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12584"},"text":"section 12584 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf7b8fc3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12584a/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Consistent with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12584"},"text":"section 12584 of this title","children":[],"tail":", providing a direct benefit to any—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf7b8fc4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12584a/a/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" business organized for profit;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf7b8fc5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12584a/a/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" labor union;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf7b8fc6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12584a/a/8/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" partisan political organization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf7b8fc7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12584a/a/8/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nonprofit organization that fails to comply with the restrictions contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s501/c"},"text":"section 501(c) of title 26","children":[],"tail":", except that nothing in this paragraph shall be construed to prevent participants from engaging in advocacy activities undertaken at their own initiative; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf7b8fc8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12584a/a/8/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" organization engaged in the religious activities described in paragraph (7), unless the position is not used to support those religious activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf7b8fc9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12584a/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Providing abortion services or referrals for receipt of such services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf7b8fca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12584a/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Conducting a voter registration drive or using Corporation funds to conduct a voter registration drive.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf7b8fcb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12584a/a/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Carrying out such other activities as the Corporation may prohibit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf7b8fcc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12584a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ineligibility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No assistance provided under this division may be provided to any organization that has violated a Federal criminal statute.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf7b8fcd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12584a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nondisplacement of employed workers or other volunteers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A participant in an approved national service position under this division may not be directed to perform any services or duties, or to engage in any activities, prohibited under the nonduplication, nondisplacement, or nonsupplantation requirements relating to employees and volunteers in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12637"},"text":"section 12637 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf7b8fce-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/610/tI/s132A"},"text":"Pub. L. 101–610, title I, § 132A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/13/tI/s1310"},"text":"Pub. L. 111–13, title I, § 1310","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-04-21"},"text":"Apr. 21, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1507"},"text":"123 Stat. 1507","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf7b8fcf-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbf7b8fd0-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbf7b8fd1-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2009-10-01"},"text":"Oct. 1, 2009","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/111/13/s6101/a"},"text":"section 6101(a) of Pub. L. 111–13","children":[],"tail":", set out as an Effective Date of 2009 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4950"},"text":"section 4950 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
