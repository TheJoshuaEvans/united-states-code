{"tag":"section","attrib":{"id":"idba5e825c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396e–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1396e–1"},"text":"§ 1396e–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Premium assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idba5e825d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396e–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State may elect to offer a premium assistance subsidy (as defined in subsection (c)) for qualified employer-sponsored coverage (as defined in subsection (b)) to all individuals who are entitled to medical assistance under this subchapter (and, in the case of an individual under age 19, to the parent of such an individual) who have access to such coverage if the State meets the requirements of this section and the offering of such a subsidy is cost-effective, as defined for purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1397ee/c/3/A"},"text":"section 1397ee(c)(3)(A) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idba5e825e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396e–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified employer-sponsored coverage","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idba5e825f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396e–1/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to paragraph (2)),","children":[{"tag":"ref","attrib":{"idref":"fn003023"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003023"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The second closing parenthesis probably should not appear."}],"tail":" in this paragraph, the term “qualified employer-sponsored coverage” means a group health plan or health insurance coverage offered through an employer—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idba5e8260-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396e–1/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that qualifies as creditable coverage as a group health plan under section 2701(c)(1) of the Public Health Service Act; ","children":[{"tag":"ref","attrib":{"idref":"fn003024"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003024"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idba5e8261-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396e–1/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for which the employer contribution toward any premium for such coverage is at least 40 percent; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idba5e8262-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396e–1/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is offered to all individuals in a manner that would be considered a nondiscriminatory eligibility classification for purposes of paragraph (3)(A)(ii) of section 105(h) of the Internal Revenue Code of 1986 (but determined without regard to clause (i) of subparagraph (B) of such paragraph).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idba5e8263-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396e–1/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Such term does not include coverage consisting of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idba5e8264-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396e–1/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" benefits provided under a health flexible spending arrangement (as defined in section 106(c)(2) of the Internal Revenue Code of 1986); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idba5e8265-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396e–1/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a high deductible health plan (as defined in section 223(c)(2) of such Code), without regard to whether the plan is purchased in conjunction with a health savings account (as defined under section 223(d) of such Code).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idba5e8266-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396e–1/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment as third party liability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The State shall treat the coverage provided under qualified employer-sponsored coverage as a third party liability under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1396a/a/25"},"text":"section 1396a(a)(25) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idba5e8267-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396e–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Premium assistance subsidy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “premium assistance subsidy” means the amount of the employee contribution for enrollment in the qualified employer-sponsored coverage by the individual or by the individual’s family. Premium assistance subsidies under this section shall be considered, for purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1396b/a"},"text":"section 1396b(a) of this title","children":[],"tail":", to be a payment for medical assistance."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idba5e8268-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396e–1/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Voluntary participation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idba5e8269-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396e–1/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Participation by an employer in a premium assistance subsidy offered by a State under this section shall be voluntary. An employer may notify a State that it elects to opt-out of being directly paid a premium assistance subsidy on behalf of an employee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idba5e826a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396e–1/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Beneficiaries","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No subsidy shall be provided to an individual under this section unless the individual (or the individual’s parent) voluntarily elects to receive such a subsidy. A State may not require such an election as a condition of receipt of medical assistance. A State may not require, as a condition of an individual (or the individual’s parent) being or remaining eligible for medical assistance under this subchapter, that the individual (or the individual’s parent) apply for enrollment in qualified employer-sponsored coverage under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idba5e826b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396e–1/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Opt-out permitted for any month","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State shall establish a process for permitting an individual (or the parent of an individual) receiving a premium assistance subsidy to disenroll the individual from the qualified employer-sponsored coverage.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idba5e826c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396e–1/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement to pay premiums and cost-sharing and provide supplemental coverage","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of the participation of an individual (or the individual’s parent) in a premium assistance subsidy under this section for qualified employer-sponsored coverage, the State shall provide for payment of all enrollee premiums for enrollment in such coverage and all deductibles, coinsurance, and other cost-sharing obligations for items and services otherwise covered under the State plan under this subchapter (exceeding the amount otherwise permitted under section 1396","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":" of this title or, if applicable, section 1396"},{"tag":"i","attrib":{},"text":"o","children":[],"tail":"–1 of this title). The fact that an individual (or a parent) elects to enroll in qualified employer-sponsored coverage under this section shall not change the individual’s (or parent’s) eligibility for medical assistance under the State plan, except insofar as "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1396a/a/25"},"text":"section 1396a(a)(25) of this title","children":[],"tail":" provides that payments for such assistance shall first be made under such coverage."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idba60f36d-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title XIX, § 1906A, as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/3/tIII/s301/b"},"text":"Pub. L. 111–3, title III, § 301(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-02-04"},"text":"Feb. 4, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/61"},"text":"123 Stat. 61","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tII/s2003/a"},"text":"Pub. L. 111–148, title II, § 2003(a)","children":[],"tail":", (b), title X, § 10203(b)(2), "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/282"},"text":"124 Stat. 282","children":[],"tail":", 283, 927.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idba60f36e-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idba60f36f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idba60f370-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 2701 of the Public Health Service Act, referred to in subsec. (b)(1)(A), is section 2701 of act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", which was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300gg"},"text":"section 300gg of this title","children":[],"tail":", was renumbered section 2704, effective for plan years beginning on or after "},{"tag":"date","attrib":{"date":"2014-01-01"},"text":"Jan. 1, 2014","children":[],"tail":", with certain exceptions, and amended, by "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tI"},"text":"Pub. L. 111–148, title I","children":[],"tail":", §§ 1201(2), 1563(c)(1), formerly § 1562(c)(1), title X, § 10107(b)(1), "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/154"},"text":"124 Stat. 154","children":[],"tail":", 264, 911, and was transferred to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300gg–3"},"text":"section 300gg–3 of this title","children":[],"tail":". A new section 2701 of act "},{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", related to fair health insurance premiums, was added, effective for plan years beginning on or after "},{"tag":"date","attrib":{"date":"2014-01-01"},"text":"Jan. 1, 2014","children":[],"tail":", and amended, by "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tI/s1201/4"},"text":"Pub. L. 111–148, title I, § 1201(4)","children":[],"tail":", title X, § 10103(a), "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/155"},"text":"124 Stat. 155","children":[],"tail":", 892, and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300gg"},"text":"section 300gg of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Internal Revenue Code of 1986, referred to in subsec. (b)(1)(C), (2), is classified generally to Title 26, Internal Revenue Code.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idba60f371-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/s2003/b"},"text":"Pub. L. 111–148, § 2003(b)","children":[],"tail":", struck out “option for children” after “assistance” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/s10203/b/2/A"},"text":"Pub. L. 111–148, § 10203(b)(2)(A)","children":[],"tail":", inserted “and the offering of such a subsidy is cost-effective, as defined for purposes of "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1397ee/c/3/A"},"text":"section 1397ee(c)(3)(A) of this title","children":[],"tail":"” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/s2003/a/1/B"},"text":"Pub. L. 111–148, § 2003(a)(1)(B)","children":[],"tail":", (C), struck out “under age 19” after “all individuals” and inserted “, in the case of an individual under age 19,” after “(and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/s2003/a/1/A"},"text":"Pub. L. 111–148, § 2003(a)(1)(A)","children":[],"tail":", which directed substitution of “shall” for “may elect to”, was not executed because of "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/s10203/b/2/B"},"text":"Pub. L. 111–148, § 10203(b)(2)(B)","children":[],"tail":", set out as a note under this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/s2003/a/2"},"text":"Pub. L. 111–148, § 2003(a)(2)","children":[],"tail":", struck out “under age 19” after “by the individual”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/s2003/a/3/A"},"text":"Pub. L. 111–148, § 2003(a)(3)(A)","children":[],"tail":", struck out “under age 19” after “to an individual” and substituted “A State may not require, as a condition of an individual (or the individual’s parent) being or remaining eligible for medical assistance under this subchapter, that the individual (or the individual’s parent) apply for enrollment in qualified employer-sponsored coverage under this section.” for “State may not require, as a condition of an individual under age 19 (or the individual’s parent) being or remaining eligible for medical assistance under this subchapter, apply for enrollment in qualified employer-sponsored coverage under this section.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/s2003/a/3/B"},"text":"Pub. L. 111–148, § 2003(a)(3)(B)","children":[],"tail":", substituted “an individual (or the parent of an individual)” for “the parent of an individual under age 19”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/s2003/a/4"},"text":"Pub. L. 111–148, § 2003(a)(4)","children":[],"tail":", struck out “under age 19” after “an individual” in two places."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idba60f372-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idba60f373-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/tII/s2003/c"},"text":"Pub. L. 111–148, title II, § 2003(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/283"},"text":"124 Stat. 283","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/148/tII/s2003/c"},"text":"“The amendments made by this section [amending this section] take effect on ","children":[{"tag":"date","attrib":{"date":"2014-01-01"},"text":"January 1, 2014","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/tX/s10203/b"},"text":"Pub. L. 111–148, title X, § 10203(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/927"},"text":"124 Stat. 927","children":[],"tail":", provided that the amendment made by "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/s10203/b/2/A"},"text":"section 10203(b)(2)(A) of Pub. L. 111–148","children":[],"tail":" is effective as if included in the enactment of the Children’s Health Insurance Program Reauthorization Act of 2009 ("},{"tag":"ref","attrib":{"href":"/us/pl/111/3"},"text":"Pub. L. 111–3","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idba60f374-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2009-04-01"},"text":"Apr. 1, 2009","children":[],"tail":", and applicable to child health assistance and medical assistance provided on or after that date, with certain exceptions, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/3/s3"},"text":"section 3 of Pub. L. 111–3","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1396"},"text":"section 1396 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idba60f375-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effect of Certain Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148"},"text":"Pub. L. 111–148","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/tX/s10203/b/2/B"},"text":"Pub. L. 111–148, title X, § 10203(b)(2)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/927"},"text":"124 Stat. 927","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/148/tX/s10203/b/2/B"},"text":"“This Act shall be applied without regard to subparagraph (A) of section 2003(a)(1) of this Act [amending this section] and that subparagraph and the amendment made by that subparagraph are hereby deemed null, void, and of no effect.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
