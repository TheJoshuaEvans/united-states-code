{"tag":"section","attrib":{"id":"idc0203501-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17022"},"text":null,"children":[{"tag":"num","attrib":{"value":"17022"},"text":"§ 17022.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants for production of advanced biofuels","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc0203502-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17022/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Energy shall establish a grant program to encourage the production of advanced biofuels.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0203503-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17022/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements and priority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In making grants under this section, the Secretary—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0203504-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17022/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall make awards to the proposals for advanced biofuels with the greatest reduction in lifecycle greenhouse gas emissions compared to the comparable motor vehicle fuel lifecycle emissions during calendar year 2005; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0203505-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17022/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not make an award to a project that does not achieve at least an 80 percent reduction in such lifecycle greenhouse gas emissions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0203506-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17022/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this section $500,000,000 for the period of fiscal years 2008 through 2015, except that the amount authorized to be appropriated to carry out this section not appropriated as of ","children":[{"tag":"date","attrib":{"date":"2013-10-02"},"text":"October 2, 2013","children":[],"tail":", shall be reduced by $6,000,000."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc0203507-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/tII/s207"},"text":"Pub. L. 110–140, title II, § 207","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1531"},"text":"121 Stat. 1531","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/40/s10/f"},"text":"Pub. L. 113–40, § 10(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-10-02"},"text":"Oct. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/546"},"text":"127 Stat. 546","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc0203508-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc0203509-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc020350a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2013—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/40"},"text":"Pub. L. 113–40","children":[],"tail":" inserted “, except that the amount authorized to be appropriated to carry out this section not appropriated as of "},{"tag":"date","attrib":{"date":"2013-10-02"},"text":"October 2, 2013","children":[],"tail":", shall be reduced by $6,000,000” before period at end."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc020350b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc020350c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the date that is 1 day after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/s1601"},"text":"section 1601 of Pub. L. 110–140","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1824"},"text":"section 1824 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
