{"tag":"section","attrib":{"id":"idbc6d8ca2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058ff"},"text":null,"children":[{"tag":"num","attrib":{"value":"3058ff"},"text":"§ 3058ff.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Nothing in this subchapter shall be construed to interfere with or abridge the right of an older individual to practice the individual’s religion through reliance on prayer alone for healing, in a case in which a decision to so practice the religion—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc6d8ca3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058ff/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is contemporaneously expressed by the older individual—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc6d8ca4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058ff/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" either orally or in writing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc6d8ca5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058ff/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to a specific illness or injury that the older individual has at the time of the decision; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc6d8ca6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058ff/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" when the older individual is competent to make the decision;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc6d8ca7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058ff/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is set forth prior to the occurrence of the illness or injury in a living will, health care proxy, or other advance directive document that is validly executed and applied under State law; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc6d8ca8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058ff/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be unambiguously deduced from the older individual’s life history.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc6d8ca9-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/73/tVII/s765"},"text":"Pub. L. 89–73, title VII, § 765","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/365/tVII/s705"},"text":"Pub. L. 109–365, title VII, § 705","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2594"},"text":"120 Stat. 2594","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
