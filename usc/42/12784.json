{"tag":"section","attrib":{"id":"idbfa1b550-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12784"},"text":null,"children":[{"tag":"num","attrib":{"value":"12784"},"text":"§ 12784.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research in housing affordability","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to support, through contracts with eligible organizations and otherwise, such research and to publish such reports as will assist in the achievement of the purposes of this subchapter. Activities authorized by the previous sentence may include an ongoing analysis of the impact of public policies at the Federal, State, and local levels, both individually and in the aggregate, on the incentives to expand and maintain the supply of energy-efficient affordable housing in the United States, particularly in areas with severe problems of housing affordability, through the use of cost-saving innovative building technology and construction techniques. For purposes of this section, agencies of the United States, government-sponsored mortgage finance corporations, and qualified research organizations shall be included as eligible organizations in addition to eligible organizations specified under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12783"},"text":"section 12783 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbfa1b551-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/625/tII/s244"},"text":"Pub. L. 101–625, title II, § 244","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4118"},"text":"104 Stat. 4118","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/550/tII/s215"},"text":"Pub. L. 102–550, title II, § 215","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3759"},"text":"106 Stat. 3759","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbfa1b552-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbfa1b553-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbfa1b554-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550"},"text":"Pub. L. 102–550","children":[],"tail":" inserted before period at end of second sentence “, through the use of cost-saving innovative building technology and construction techniques”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbfa1b555-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbfa1b556-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1992 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550"},"text":"Pub. L. 102–550","children":[],"tail":" applicable to unexpended funds allocated under subchapter II of this chapter in fiscal year 1992, except as otherwise specifically provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/102/550/s223"},"text":"section 223 of Pub. L. 102–550","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12704"},"text":"section 12704 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
