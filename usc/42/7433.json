{"tag":"section","attrib":{"id":"idbe3023e1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7433"},"text":null,"children":[{"tag":"num","attrib":{"value":"7433"},"text":"§ 7433.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants to reduce air pollution at ports","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbe3023e2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7433/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe3023e3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7433/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General assistance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In addition to amounts otherwise available, there is appropriated to the Administrator for fiscal year 2022, out of any money in the Treasury not otherwise appropriated, $2,250,000,000, to remain available until ","children":[{"tag":"date","attrib":{"date":"2027-09-30"},"text":"September 30, 2027","children":[],"tail":", to award rebates and grants to eligible recipients on a competitive basis—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbe3023e4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7433/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to purchase or install zero-emission port equipment or technology for use at, or to directly serve, one or more ports;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe3023e5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7433/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to conduct any relevant planning or permitting in connection with the purchase or installation of such zero-emission port equipment or technology; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe3023e6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7433/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop qualified climate action plans.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe3023e7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7433/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonattainment areas","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to amounts otherwise available, there is appropriated to the Administrator for fiscal year 2022, out of any money in the Treasury not otherwise appropriated, $750,000,000, to remain available until ","children":[{"tag":"date","attrib":{"date":"2027-09-30"},"text":"September 30, 2027","children":[],"tail":", to award rebates and grants to eligible recipients to carry out activities described in paragraph (1) with respect to ports located in air quality areas designated pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s7407"},"text":"section 7407 of this title","children":[],"tail":" as nonattainment for an air pollutant."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe3023e8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7433/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds awarded under this section shall not be used by any recipient or subrecipient to purchase or install zero-emission port equipment or technology that will not be located at, or directly serve, the one or more ports involved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe3023e9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7433/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the funds made available by this section, the Administrator shall reserve 2 percent for administrative costs necessary to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe3023ea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7433/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe3023eb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7433/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible recipient","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible recipient” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbe3023ec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7433/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a port authority;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe3023ed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7433/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State, regional, local, or Tribal agency that has jurisdiction over a port authority or a port;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe3023ee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7433/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an air pollution control agency; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe3023ef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7433/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a private entity that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbe3023f0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7433/d/1/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" applies for a grant under this section in partnership with an entity described in any of subparagraphs (A) through (C); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbe3023f1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7433/d/1/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" owns, operates, or uses the facilities, cargo-handling equipment, transportation equipment, or related technology of a port.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe3023f2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7433/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Greenhouse gas","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “greenhouse gas” means the air pollutants carbon dioxide, hydrofluorocarbons, methane, nitrous oxide, perfluorocarbons, and sulfur hexafluoride.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe3023f3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7433/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified climate action plan","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “qualified climate action plan” means a detailed and strategic plan that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbe3023f4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7433/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" establishes goals, implementation strategies, and accounting and inventory practices to reduce emissions at one or more ports of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbe3023f5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7433/d/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" greenhouse gases;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbe3023f6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7433/d/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an air pollutant that is listed pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7408/a"},"text":"section 7408(a) of this title","children":[],"tail":" (or any precursor to such an air pollutant); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbe3023f7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7433/d/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hazardous air pollutants;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe3023f8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7433/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes a strategy to collaborate with, communicate with, and address potential effects on low-income and disadvantaged near-port communities and other stakeholders that may be affected by implementation of the plan; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe3023f9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7433/d/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describes how an eligible recipient has implemented or will implement measures to increase the resilience of the one or more ports involved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe3023fa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7433/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Zero-emission port equipment or technology","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “zero-emission port equipment or technology” means human-operated equipment or human-maintained technology that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbe3023fb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7433/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" produces zero emissions of any air pollutant that is listed pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7408/a"},"text":"section 7408(a) of this title","children":[],"tail":" (or any precursor to such an air pollutant) and any greenhouse gas other than water vapor; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe3023fc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7433/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" captures 100 percent of the emissions described in subparagraph (A) that are produced by an ocean-going vessel at berth.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbe3023fd-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1955-07-14/ch360"},"text":"July 14, 1955, ch. 360","children":[],"tail":", title I, § 133, as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/169/tVI/s60102"},"text":"Pub. L. 117–169, title VI, § 60102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-16"},"text":"Aug. 16, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2064"},"text":"136 Stat. 2064","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
