{"tag":"section","attrib":{"id":"idbe0c706a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385s–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"7385s–1"},"text":"§ 7385s–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation to be provided","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Subject to the other provisions of this part:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe0c706b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385s–1/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contractor employees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A covered DOE contractor employee shall receive contractor employee compensation under this part in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7385s–2"},"text":"section 7385s–2 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe0c706c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385s–1/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Survivors","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"After the death of a covered DOE contractor employee, compensation referred to in paragraph (1) shall not be paid. Instead, the survivor of that employee shall receive compensation as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbe0c706d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385s–1/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in subparagraph (B), the survivor of that employee shall receive contractor employee compensation under this part in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7385s–3"},"text":"section 7385s–3 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe0c706e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385s–1/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In a case in which the employee’s death occurred after the employee applied under this part and before compensation was paid under paragraph (1), and the employee’s death occurred from a cause other than the covered illness of the employee, the survivor of that employee may elect to receive, in lieu of compensation under subparagraph (A), the amount of contractor employee compensation that the employee would have received in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7385s–2"},"text":"section 7385s–2 of this title","children":[],"tail":" if the employee’s death had not occurred before compensation was paid under paragraph (1)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbe0c706f-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dC/tXXXVI/s3672"},"text":"Pub. L. 106–398, § 1 [div. C, title XXXVI, § 3672]","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/375/dC/tXXXI/s3161"},"text":"Pub. L. 108–375, div. C, title XXXI, § 3161","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-28"},"text":"Oct. 28, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2178"},"text":"118 Stat. 2178","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
