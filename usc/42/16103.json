{"tag":"section","attrib":{"id":"idbff2e2d6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16103"},"text":null,"children":[{"tag":"num","attrib":{"value":"16103"},"text":"§ 16103.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conserve by Bicycling Program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbff2e2d7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16103/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbff2e2d8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16103/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “program” means the Conserve by Bicycling Program established by subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff2e2d9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16103/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of Transportation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff2e2da-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16103/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established within the Department of Transportation a program to be known as the “Conserve by Bicycling Program”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff2e2db-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16103/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Projects","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbff2e2dc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16103/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the program, the Secretary shall establish not more than 10 pilot projects that are—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbff2e2dd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16103/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" dispersed geographically throughout the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff2e2de-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16103/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designed to conserve energy resources by encouraging the use of bicycles in place of motor vehicles.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff2e2df-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16103/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A pilot project described in paragraph (1) shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbff2e2e0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16103/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use education and marketing to convert motor vehicle trips to bicycle trips;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff2e2e1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16103/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" document project results and energy savings (in estimated units of energy conserved);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff2e2e2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16103/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" facilitate partnerships among interested parties in at least 2 of the fields of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbff2e2e3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16103/c/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transportation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbff2e2e4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16103/c/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" law enforcement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbff2e2e5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16103/c/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbff2e2e6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16103/c/2/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" public health;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbff2e2e7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16103/c/2/C/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" environment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbff2e2e8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16103/c/2/C/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" energy;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff2e2e9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16103/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maximize bicycle facility investments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff2e2ea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16103/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrate methods that may be used in other regions of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff2e2eb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16103/c/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitate the continuation of ongoing programs that are sustained by local resources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff2e2ec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16103/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost sharing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"At least 20 percent of the cost of each pilot project described in paragraph (1) shall be provided from non-Federal sources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff2e2ed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16103/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Energy and bicycling research study","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbff2e2ee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16103/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":", the Secretary shall enter into a contract with the National Academy of Sciences for, and the National Academy of Sciences shall conduct and submit to Congress a report on, a study on the feasibility of converting motor vehicle trips to bicycle trips."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff2e2ef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16103/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Components","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The study shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbff2e2f0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16103/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" document the results or progress of the pilot projects under subsection (c);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff2e2f1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16103/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" determine the type and duration of motor vehicle trips that people in the United States may feasibly make by bicycle, taking into consideration factors such as—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbff2e2f2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16103/d/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" weather;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbff2e2f3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16103/d/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" land use and traffic patterns;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbff2e2f4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16103/d/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the carrying capacity of bicycles; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbff2e2f5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16103/d/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" bicycle infrastructure;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff2e2f6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16103/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determine any energy savings that would result from the conversion of motor vehicle trips to bicycle trips;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff2e2f7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16103/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include a cost-benefit analysis of bicycle infrastructure investments; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff2e2f8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16103/d/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include a description of any factors that would encourage more motor vehicle trips to be replaced with bicycle trips.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff2e2f9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16103/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is authorized to be appropriated to the Secretary to carry out this section $6,200,000, to remain available until expended, of which—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbff2e2fa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16103/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $5,150,000 shall be used to carry out pilot projects described in subsection (c);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff2e2fb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16103/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $300,000 shall be used by the Secretary to coordinate, publicize, and disseminate the results of the program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff2e2fc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16103/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $750,000 shall be used to carry out subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbff2e2fd-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tVII/s755"},"text":"Pub. L. 109–58, title VII, § 755","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/828"},"text":"119 Stat. 828","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
