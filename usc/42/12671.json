 "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3185"},"text":"104 Stat. 3185","children":[],"tail":", provided that model Good Samaritan Food Donation Act was intended only to serve as model law for enactment by States, District of Columbia, Commonwealth of Puerto Rico, and territories and possessions of United States, and that enactment of "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12672"},"text":"section 12672 of this title","children":[],"tail":" was to have no force or effect in law, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/104/210/s1/a/1"},"text":"Pub. L. 104–210, § 1(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-01"},"text":"Oct. 1, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3011"},"text":"110 Stat. 3011","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbf95ce48-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2009—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1831/b/1"},"text":"Pub. L. 111–13, § 1831(b)(1)","children":[],"tail":", substituted “term ‘administrative organization’ means a nonprofit private organization that enters into an agreement with the Corporation to carry out this section.” for “term ‘Foundation’ means the Points of Light Foundation funded under section 301, or another nonprofit private organization, that enters into an agreement with the Corporation to carry out this section.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b), (d), (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1831/b/2"},"text":"Pub. L. 111–13, § 1831(b)(2)","children":[],"tail":", substituted “administrative organization” for “Foundation” wherever appearing."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbf95ce49-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbf95ce4a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2009 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13"},"text":"Pub. L. 111–13","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2009-10-01"},"text":"Oct. 1, 2009","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/111/13/s6101/a"},"text":"section 6101(a) of Pub. L. 111–13","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4950"},"text":"section 4950 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
