{"tag":"section","attrib":{"id":"idbf9ab0db-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12724"},"text":null,"children":[{"tag":"num","attrib":{"value":"12724"},"text":"§ 12724.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated to carry out this subchapter $2,086,000,000 for fiscal year 1993, and $2,173,612,000 for fiscal year 1994, of which—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf9ab0dc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12724/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not more than $14,000,000 for fiscal year 1993, and $25,000,000 for fiscal year 1994, shall be for community housing partnership activities authorized under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12773"},"text":"section 12773 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf9ab0dd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12724/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not more than $11,000,000 for fiscal year 1993, and $22,000,000 for fiscal year 1994, shall be for activities in support of State and local housing strategies authorized under part C.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf9ab0de-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/625/tII/s205"},"text":"Pub. L. 101–625, title II, § 205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4096"},"text":"104 Stat. 4096","children":[],"tail":"; "},{"tag":"ref"