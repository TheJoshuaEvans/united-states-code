{"tag":"section","attrib":{"id":"idb8080f89-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1010"},"text":null,"children":[{"tag":"num","attrib":{"value":"1010"},"text":"§ 1010.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other administrative provisions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8080f8a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1010/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations and administrative arrangements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commissioner of Social Security may prescribe such regulations, and make such administrative and other arrangements, as may be necessary or appropriate to carry out this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8080f8b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1010/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment of benefits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Benefits under this subchapter shall be paid at such time or times and in such installments as the Commissioner of Social Security determines are in the interests of economy and efficiency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8080f8c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1010/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Entitlement redeterminations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An individual’s entitlement to benefits under this subchapter, and the amount of the benefits, may be redetermined at such time or times as the Commissioner of Social Security determines to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8080f8d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1010/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Suspension and termination of benefits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Regulations prescribed by the Commissioner of Social Security under subsection (a) may provide for the suspension and termination of entitlement to benefits under this subchapter as the Commissioner determines is appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8080f8e-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title VIII, § 810, as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/169/tII/s251/a"},"text":"Pub. L. 106–169, title II, § 251(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-12-14"},"text":"Dec. 14, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1852"},"text":"113 Stat. 1852","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8080f8f-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8080f90-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb8080f91-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For prior provisions, see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1001"},"text":"section 1001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
