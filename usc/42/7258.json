{"tag":"section","attrib":{"id":"idbdfba713-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7258"},"text":null,"children":[{"tag":"num","attrib":{"value":"7258"},"text":"§ 7258.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Facilities construction","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbdfba714-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7258/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employees and dependents stationed at remote locations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As necessary and when not otherwise available, the Secretary is authorized to provide for, construct, or maintain the following for employees and their dependents stationed at remote locations:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbdfba715-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7258/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Emergency medical services and supplies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdfba716-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7258/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Food and other subsistence supplies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdfba717-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7258/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Messing facilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdfba718-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7258/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Audio-visual equipment, accessories, and supplies for recreation and training;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdfba719-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7258/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Reimbursement for food, clothing, medicine, and other supplies furnished by such employees in emergencies for the temporary relief of distressed persons;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdfba71a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7258/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Living and working quarters and facilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdfba71b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7258/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Transportation of schoolage dependents of employees to the nearest appropriate educational facilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdfe171c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7258/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Medical treatment at reasonable prices","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The furnishing of medical treatment under paragraph (1) of subsection (a) and the furnishing of services and supplies under paragraphs (2) and (3) of subsection (a) shall be at prices reflecting reasonable value as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdfe171d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7258/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of reimbursement proceeds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Proceeds from reimbursements under this section shall be deposited in the Treasury and may be withdrawn by the Secretary to pay directly the cost of such work or services, to repay or make advances to appropriations of funds which will initially bear all or a part of such cost, or to refund excess sums when necessary. Such payments may be credited to a working capital fund otherwise established by law, including the fund established pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7263"},"text":"section 7263 of this title","children":[],"tail":", and used under the law governing such fund, if the fund is available for use by the Department for performing the work or services for which payment is received."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbdfe171e-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/91/tVI/s648"},"text":"Pub. L. 95–91, title VI, § 648","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-08-04"},"text":"Aug. 4, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/600"},"text":"91 Stat. 600","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
