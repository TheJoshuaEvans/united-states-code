{"tag":"section","attrib":{"id":"idc0227e92-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17081"},"text":null,"children":[{"tag":"num","attrib":{"value":"17081"},"text":"§ 17081.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commercial high-performance green buildings","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc0227e93-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17081/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director of Commercial High-Performance Green Buildings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of law, the Secretary, acting through the Assistant Secretary of Energy Efficiency and Renewable Energy, shall appoint a Director of Commercial High-Performance Green Buildings to a position in the career-reserved Senior Executive service, with the principal responsibility to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0227e94-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17081/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish and manage the Office of Commercial High-Performance Green Buildings; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0227e95-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17081/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry out other duties as required under this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0227e96-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17081/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commercial Director shall be an individual, who by reason of professional background and experience, is specifically qualified to carry out the duties required under this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0227e97-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17081/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commercial Director shall, with respect to development of high-performance green buildings and zero-energy commercial buildings nationwide—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0227e98-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17081/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate the activities of the Office of Commercial High-Performance Green Buildings with the activities of the Office of Federal High-Performance Green Buildings;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0227e99-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17081/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop the legal predicates and agreements for, negotiate, and establish one or more public-private partnerships with the Consortium, members of the Consortium, and other capable parties meeting the qualifications of the Consortium, to further such development;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0227e9a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17081/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" represent the public and the Department in negotiating and performing in accord with such public-private partnerships;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0227e9b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17081/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use appropriated funds in an effective manner to encourage the maximum investment of private funds to achieve such development;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0227e9c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17081/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote research and development of high-performance green buildings, consistent with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s17083"},"text":"section 17083 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0227e9d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17081/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" jointly establish with the Federal Director a national high-performance green building clearinghouse in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s17083/1"},"text":"section 17083(1) of this title","children":[],"tail":", which shall provide high-performance green building information and disseminate research results through—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0227e9e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17081/c/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" outreach;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0227e9f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17081/c/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" education; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0227ea0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17081/c/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the provision of technical assistance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0227ea1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17081/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commercial Director shall report directly to the Assistant Secretary for Energy Efficiency and Renewable Energy, or to other senior officials in a way that facilitates the integrated program of this part for both energy efficiency and renewable energy and both technology development and technology deployment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0227ea2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17081/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commercial Director shall ensure full coordination of high-performance green building information and activities, including activities under this part, within the Federal Government by working with the General Services Administration and all relevant agencies, including, at a minimum—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0227ea3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17081/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Environmental Protection Agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0227ea4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17081/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Office of the Federal Environmental Executive;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0227ea5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17081/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Office of Federal Procurement Policy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0227ea6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17081/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of Energy, particularly the Federal Energy Management Program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0227ea7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17081/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of Health and Human Services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0227ea8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17081/e/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of Housing and Urban Development;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0227ea9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17081/e/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of Defense;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0227eaa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17081/e/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Institute of Standards and Technology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0227eab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17081/e/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of Transportation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0227eac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17081/e/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Office of Science Technology and Policy; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0227ead-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17081/e/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such nonprofit high-performance green building rating and analysis entities as the Commercial Director determines can offer support, expertise, and review services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0227eae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17081/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" High-Performance Green Building Partnership Consortium","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0227eaf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17081/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recognition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"December 19, 2007","children":[],"tail":", the Commercial Director shall formally recognize one or more groups that qualify as a high-performance green building partnership consortium."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0227eb0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17081/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Representation to qualify","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To qualify under this section, any consortium shall include representation from—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0227eb1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17081/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the design professions, including national associations of architects and of professional engineers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0227eb2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17081/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development, construction, financial, and real estate industries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0227eb3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17081/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" building owners and operators from the public and private sectors;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0227eb4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17081/f/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" academic and research organizations, including at least one national laboratory with extensive commercial building energy expertise;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0227eb5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17081/f/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" building code agencies and organizations, including a model energy code-setting organization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0227eb6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17081/f/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" independent high-performance green building associations or councils;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0227eb7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17081/f/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" experts in indoor air quality and environmental factors;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0227eb8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17081/f/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" experts in intelligent buildings and integrated building information systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0227eb9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17081/f/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" utility energy efficiency programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0227eba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17081/f/2/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" manufacturers and providers of equipment and techniques used in high-performance green buildings;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0227ebb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17081/f/2/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" public transportation industry experts; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0227ebc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17081/f/2/L"},"text":null,"children":[{"tag":"num","attrib":{"value":"L"},"text":"(L)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nongovernmental energy efficiency organizations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0227ebd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17081/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may make payments to the Consortium pursuant to the terms of a public-private partnership for such activities of the Consortium undertaken under such a partnership as described in this part directly to the Consortium or through one or more of its members.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0227ebe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17081/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"December 19, 2007","children":[],"tail":", and biennially thereafter, the Commercial Director, in consultation with the Consortium, shall submit to Congress a report that—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0227ebf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17081/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" describes the status of the high-performance green building initiatives under this part and other Federal programs affecting commercial high-performance green buildings in effect as of the date of the report, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0227ec0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17081/g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which the programs are being carried out in accordance with this part; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0227ec1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17081/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the status of funding requests and appropriations for those programs; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0227ec2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17081/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" summarizes and highlights development, at the State and local level, of high-performance green building initiatives, including executive orders, policies, or laws adopted promoting high-performance green building (including the status of implementation of those initiatives).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc0227ec3-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/tIV/s421"},"text":"Pub. L. 110–140, title IV, § 421","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1602"},"text":"121 Stat. 1602","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc0227ec4-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc0227ec5-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc0227ec6-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the date that is 1 day after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/s1601"},"text":"section 1601 of Pub. L. 110–140","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1824"},"text":"section 1824 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idc0227ec7-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idc0227ec8-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Office of the Federal Environmental Executive reestablished as the Office of the Chief Sustainability Officer by Ex. Ord. No. 13693, § 6, ","children":[{"tag":"date","attrib":{"date":"2015-03-19"},"text":"Mar. 19, 2015","children":[],"tail":", 80 F.R. 15877, formerly set out in a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"section 4321 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
