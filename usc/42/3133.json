{"tag":"section","attrib":{"id":"idbc72476d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3133"},"text":null,"children":[{"tag":"num","attrib":{"value":"3133"},"text":"§ 3133.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbc72476e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3133/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall coordinate activities relating to the preparation and implementation of comprehensive economic development strategies under this chapter with Federal agencies carrying out other Federal programs, States, economic development districts, Indian tribes, and other appropriate planning and development organizations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc72476f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3133/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc724770-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3133/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To carry out subsection (a), or for any other purpose relating to economic development activities, the Secretary may convene meetings with Federal agencies, State and local governments, economic development districts, Indian tribes, and other appropriate planning and development organizations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc724771-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3133/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regional commissions","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc724772-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3133/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to meetings described in paragraph (1), not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2025-01-04"},"text":"January 4, 2025","children":[],"tail":", and not less frequently than every 2 years thereafter, the Secretary shall convene a meeting with the Regional Commissions in furtherance of subsection (a)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc724773-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3133/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Attendees","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The attendees for a meeting convened under this paragraph shall consist of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbc724774-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3133/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary, acting through the Assistant Secretary of Commerce for Economic Development, serving as Chair;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc724775-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3133/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Cochairpersons of the Regional Commissions, or their designees; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc724776-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3133/b/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State Cochairpersons of the Regional Commissions, or their designees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc724777-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3133/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of a meeting convened under this paragraph shall include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbc724778-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3133/b/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to enhance coordination between the Economic Development Administration and the Regional Commissions in carrying out economic development programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc724779-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3133/b/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to reduce duplication of efforts by the Economic Development Administration and the Regional Commissions in carrying out economic development programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc72477a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3133/b/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop best practices and strategies for fostering regional economic development; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc72477b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3133/b/2/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other purposes as determined appropriate by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc72477c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3133/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Where applicable and pursuant to subparagraph (C), not later than 1 year after a meeting under this paragraph, the Secretary shall prepare and make publicly available a report detailing, at a minimum—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbc72477d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3133/b/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the planned actions by the Economic Development Administration and the Regional Commissions to enhance coordination or reduce duplication of efforts and a timeline for implementing those actions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc72477e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3133/b/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any best practices and strategies developed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc72477f-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/136/tI/s103"},"text":"Pub. L. 89–136, title I, § 103","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/393/tI/s102/a"},"text":"Pub. L. 105–393, title I, § 102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3601"},"text":"112 Stat. 3601","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/373/tI/s104"},"text":"Pub. L. 108–373, title I, § 104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-27"},"text":"Oct. 27, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1759"},"text":"118 Stat. 1759","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/272/dB/tII/s2212"},"text":"Pub. L. 118–272, div. B, title II, § 2212","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/3178"},"text":"138 Stat. 3178","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc724780-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc724781-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbc724782-3a70-11f1-ae07-e4213316b5fa"