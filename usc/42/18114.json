{"tag":"section","attrib":{"id":"idc0524068-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18114"},"text":null,"children":[{"tag":"num","attrib":{"value":"18114"},"text":"§ 18114.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Access to therapies","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of this Act, the Secretary of Health and Human Services shall not promulgate any regulation that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0524069-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18114/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" creates any unreasonable barriers to the ability of individuals to obtain appropriate medical care;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc052406a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18114/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" impedes timely access to health care services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc052406b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18114/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" interferes with communications regarding a full range of treatment options between the patient and the provider;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc052406c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18114/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" restricts the ability of health care providers to provide full disclosure of all relevant information to patients making health care decisions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc052406d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18114/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" violates the principles of informed consent and the ethical standards of health care professionals; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc052406e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18114/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" limits the availability of health care treatment for the full duration of a patient’s medical needs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc052406f-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/tI/s1554"},"text":"Pub. L. 111–148, title I, § 1554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/259"},"text":"124 Stat. 259","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc0524070-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc0524071-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc0524072-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in text, is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148"},"text":"Pub. L. 111–148","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/119"},"text":"124 Stat. 119","children":[],"tail":", known as the Patient Protection and Affordable Care Act. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s18001"},"text":"section 18001 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
