{"tag":"section","attrib":{"id":"idbd1b7fca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5174b"},"text":null,"children":[{"tag":"num","attrib":{"value":"5174b"},"text":"§ 5174b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Critical document fee waiver","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd1b7fcb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5174b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s214"},"text":"section 214 of title 22","children":[],"tail":" or any other provision of law, the President, in consultation with the Governor of a State, may provide a waiver under this subsection to an individual or household described in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5174/e/1"},"text":"section 5174(e)(1) of this title","children":[],"tail":" for the following document replacement fees:"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd1b7fcc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5174b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The passport application fee for individuals who lost their United States passport in a major disaster within the preceding three calendar years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd1b7fcd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5174b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The file search fee for a United States passport.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd1b7fce-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5174b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Application for Waiver of Passport and/or Visa form (Form I–193) fee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd1b7fcf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5174b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Permanent Resident Card replacement form (Form I–90) filing fee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd1b7fd0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5174b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Declaration of Intention form (Form N–300) filing fee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd1b7fd1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5174b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Naturalization/Citizenship Document replacement form (Form N–565) filing fee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd1b7fd2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5174b/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Employment Authorization form (Form I–765) filing fee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd1b7fd3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5174b/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The biometric service fee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd1b7fd4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5174b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption from form requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The authority of the President to waive fees under subparagraphs (C) through (H) of paragraph (1) applies regardless of whether the individual or household qualifies for a Form I–912 Request for Fee Waiver, or any successor thereto.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd1b7fd5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5174b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption from assistance maximum","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The assistance limit in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5174/h"},"text":"section 5174(h) of this title","children":[],"tail":" shall not apply to any fee waived under this subsection."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd1b7fd6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5174b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 365 days after ","children":[{"tag":"date","attrib":{"date":"2018-10-05"},"text":"October 5, 2018","children":[],"tail":", the Administrator and the head of any other agency given critical document fee waiver authority under this subsection shall submit a report to the Committee on Homeland Security and Governmental Affairs of the Senate and the Committee on Transportation and Infrastructure of the House of Representatives on the costs associated with providing critical document fee waivers as described in paragraph (1)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd1b7fd7-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/dD/s1238/a"},"text":"Pub. L. 115–254, div. D, § 1238(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3465"},"text":"132 Stat. 3465","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd1b7fd8-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd1b7fd9-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbd1b7fda-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Disaster Recovery Reform Act of 2018 and as part of the FAA Reauthorization Act of 2018, and not as part of the Robert T. Stafford Disaster Relief and Emergency Assistance Act which comprises this chapter.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of subsec. (a) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/s1238"},"text":"section 1238 of Pub. L. 115–254","children":[],"tail":". Subsecs. (b) and (c) of "},{"tag":"ref","attrib":{"href":"/us/pl/115/254/s1238"},"text":"section 1238 of Pub. L. 115–254","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5122"},"text":"section 5122 of this title","children":[],"tail":" and enacted provisions set out as a note under that section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbd1b7fdb-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbd1b7fdc-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Authorities provided under div. D of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254"},"text":"Pub. L. 115–254","children":[],"tail":", which enacted this section, applicable to each major disaster and emergency declared by the President under "},{"tag":"ref","attrib":{"href":"/us/pl/93/288"},"text":"Pub. L. 93–288","children":[],"tail":" on or after "},{"tag":"date","attrib":{"date":"2016-01-01"},"text":"Jan. 1, 2016","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/254/s1202/b"},"text":"section 1202(b) of Pub. L. 115–254","children":[],"tail":", set out in an Effective Date of 2018 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5121"},"text":"section 5121 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idbd1b7fdd-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definitions of terms used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/s1203"},"text":"section 1203 of Pub. L. 115–254","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5122"},"text":"section 5122 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idbd1b7fde-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbd1b7fdf-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions and Authorities Under Section 1238 of the FAA Reauthorization Act of 2018","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Memorandum of President of the United States, ","children":[{"tag":"date","attrib":{"date":"2018-12-21"},"text":"Dec. 21, 2018","children":[],"tail":", 84 F.R. 3957, provided:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Memorandum for the Secretary of State [and] the Secretary of Homeland Security","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"By the authority vested in me as President by the Constitution and the laws of the United States of America, including ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t3/s301"},"text":"section 301 of title 3","children":[],"tail":", United States Code, I hereby:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"(1) delegate to the Secretary of State the functions and authorities vested in the President by sections 1238(a)(1)(A)–(B) of the FAA Reauthorization Act of 2018 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254"},"text":"Public Law 115–254","children":[],"tail":") ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5174b/a/1/A"},"text":"42 U.S.C. 5174b(a)(1)(A)","children":[],"tail":"–(B)]; and"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"(2) delegate to the Secretary of Homeland Security the functions and authorities vested in the President by sections 1238(a)(1)(C)–(H) of the FAA Reauthorization Act of 2018.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The delegations in this memorandum shall apply to any provisions of any future public law that are the same or substantially the same as the provisions referenced in this memorandum. The Secretary of State and the Secretary of Homeland Security may redelegate within their departments the functions and authorities delegated by this memorandum to the extent authorized by law.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Secretary of State is authorized and directed to publish this memorandum in the Federal Register.","children":[],"tail":"\n"},{"tag":"signature","attrib":{},"text":"\n","children":[{"tag":"name","attrib":{},"text":"Donald J. Trump.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
