{"tag":"section","attrib":{"id":"idbf17767d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10164"},"text":null,"children":[{"tag":"num","attrib":{"value":"10164"},"text":"§ 10164.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Survey","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"After the MRS Commission submits its report to the Congress under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s10163"},"text":"section 10163 of this title","children":[],"tail":", the Secretary may conduct a survey and evaluation of potentially suitable sites for a monitored retrievable storage facility. In conducting such survey and evaluation, the Secretary shall consider the extent to which siting a monitored retrievable storage facility at each site surveyed would—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf17767e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10164/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhance the reliability and flexibility of the system for the disposal of spent nuclear fuel and high-level radioactive waste established under this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf17767f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10164/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" minimize the impacts of transportation and handling of such fuel and waste;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf177680-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10164/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for public confidence in the ability of such system to safely dispose of the fuel and waste;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf177681-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10164/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" impose minimal adverse effects on the local community and the local environment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf177682-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10164/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide a high probability that the facility will meet applicable environmental, health, and safety requirements in a timely fashion;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf177683-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10164/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide such other benefits to the system for the disposal of spent nuclear fuel and high-level radioactive waste as the Secretary deems appropriate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf177684-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10164/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" unduly burden a State in which significant volumes of high-level radioactive waste resulting from atomic energy defense activities are stored.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf177685-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/425/tI/s144"},"text":"Pub. L. 97–425, title I, § 144","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/202/s101/d/tIII/s300"},"text":"Pub. L. 100–202, § 101(d) [title III, § 300]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1329-104"},"text":"101 Stat. 1329–104","children":[],"tail":", 1329–121; "},{"tag":"ref","attrib":{"href":"/us/pl/100/203/tV/s5021"},"text":"Pub. L. 100–203, title V, § 5021","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1330-234"},"text":"101 Stat. 1330–234","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf177686-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf177687-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbf177688-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/202"},"text":"Pub. L. 100–202","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/100/203"},"text":"Pub. L. 100–203","children":[],"tail":" added identical sections."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
