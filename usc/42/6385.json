{"tag":"section","attrib":{"id":"idbda37446-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6385"},"text":null,"children":[{"tag":"num","attrib":{"value":"6385"},"text":"§ 6385.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Petroleum product information","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The President or his delegate shall, pursuant to authority otherwise available to the President or his delegate under any other provision of law, collect information on the pricing, supply, and distribution of petroleum products by product category at the wholesale and retail levels, on a State-by-State basis, which was collected as of ","children":[{"tag":"date","attrib":{"date":"1981-09-01"},"text":"September 1, 1981","children":[],"tail":", by the Energy Information Administration."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbda37447-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/163/tV/s507"},"text":"Pub. L. 94–163, title V, § 507","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/97/229/s5/a"},"text":"Pub. L. 97–229, § 5(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-08-03"},"text":"Aug. 3, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/252"},"text":"96 Stat. 252","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
