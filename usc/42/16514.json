{"tag":"section","attrib":{"id":"idc0190838-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16514"},"text":null,"children":[{"tag":"num","attrib":{"value":"16514"},"text":"§ 16514.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc0190839-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16514/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums as are necessary to provide the cost of guarantees under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc019083a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16514/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of other appropriated funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Department may use amounts awarded under the Clean Coal Power Initiative to carry out the project described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16513/c/1/C"},"text":"section 16513(c)(1)(C) of this title","children":[],"tail":", on the request of the recipient of such award, for a loan guarantee, to the extent that the amounts have not yet been disbursed to, or have been repaid by, the recipient."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc019083b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16514/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative and other expenses","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc019083c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16514/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $32,000,000 for each of fiscal years 2021 through 2025 to carry out this subchapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc019083d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16514/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for fiscal year 2021, in addition to amounts authorized under paragraph (1), $25,000,000, to remain available until expended, for administrative expenses described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16512/h/1"},"text":"section 16512(h)(1) of this title","children":[],"tail":" that are not covered by fees collected pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s16512/h"},"text":"section 16512(h) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc019083e-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tXVII/s1704"},"text":"Pub. L. 109–58, title XVII, § 1704","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1122"},"text":"119 Stat. 1122","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/168/s1/b/2"},"text":"Pub. L. 109–168, § 1(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-10"},"text":"Jan. 10, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3580"}