{"tag":"section","attrib":{"id":"idb54b1311-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280k–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"280k–1"},"text":"§ 280k–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research-based dental caries disease management","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb54b1312-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280k–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Director of the Centers for Disease Control and Prevention, shall award demonstration grants to eligible entities to demonstrate the effectiveness of research-based dental caries disease management activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb54b1313-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280k–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible for a grant under this section, an entity shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb54b1314-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280k–1/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be a community-based provider of dental services (as defined by the Secretary), including a Federally-qualified health center, a clinic of a hospital owned or operated by a State (or by an instrumentality or a unit of government within a State), a State or local department of health, a dental program of the Indian Health Service, an Indian tribe or tribal organization, or an urban Indian organization (as such terms are defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1603"},"text":"section 1603 of title 25","children":[],"tail":"), a health system provider, a private provider of dental services, medical, dental, public health, nursing, nutrition educational institutions, or national organizations involved in improving children’s oral health; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb54b1315-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280k–1/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit to the Secretary an application at such time, in such manner, and containing such information as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb54b1316-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280k–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A grantee shall use amounts received under a grant under this section to demonstrate the effectiveness of research-based dental caries disease management activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb54b1317-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280k–1/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall, as practicable and appropriate, utilize information generated from grantees under this section in planning and implementing the oral health education campaign and action for dental health program under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s280k"},"text":"section 280k of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb54b1318-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title III, § 399LL–1, as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tIV/s4102/a"},"text":"Pub. L. 111–148, title IV, § 4102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/551"},"text":"124 Stat. 551","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/302/s2/b"},"text":"Pub. L. 115–302, § 2(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-11"},"text":"Dec. 11, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4397"},"text":"132 Stat. 4397","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb54b1319-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb54b131a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb54b131b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/302"},"text":"Pub. L. 115–302","children":[],"tail":" substituted “shall, as practicable and appropriate,” for “shall” and “oral health education campaign and action for dental health program” for “public education campaign”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
