{"tag":"section","attrib":{"id":"idbaaf891b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397n–6"},"text":null,"children":[{"tag":"num","attrib":{"value":"1397n–6"},"text":"§ 1397n–6.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commission on Social Impact Partnerships","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbaaf891c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397n–6/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established the Commission on Social Impact Partnerships (in this section referred to as the “Commission”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbaaf891d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397n–6/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The duties of the Commission shall be to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbaaf891e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397n–6/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist the Secretary and the Federal Interagency Council on Social Impact Partnerships in reviewing applications for funding under this division;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaaf891f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397n–6/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make recommendations to the Secretary and the Federal Interagency Council on Social Impact Partnerships regarding the funding of social impact partnership agreements and feasibility studies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaaf8920-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397n–6/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide other assistance and information as requested by the Secretary or the Federal Interagency Council on Social Impact Partnerships.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbaaf8921-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397n–6/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Composition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commission shall be composed of nine members, of whom—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbaaf8922-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397n–6/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one shall be appointed by the President, who will serve as the Chair of the Commission;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaaf8923-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397n–6/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one shall be appointed by the Majority Leader of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaaf8924-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397n–6/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one shall be appointed by the Minority Leader of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaaf8925-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397n–6/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one shall be appointed by the Speaker of the House of Representatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaaf8926-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397n–6/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one shall be appointed by the Minority Leader of the House of Representatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaaf8927-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397n–6/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one shall be appointed by the Chairman of the Committee on Finance of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaaf8928-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397n–6/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one shall be appointed by the ranking member of the Committee on Finance of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaaf8929-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397n–6/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one member shall be appointed by the Chairman of the Committee on Ways and Means of the House of Representatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaaf892a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397n–6/c/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one shall be appointed by the ranking member of the Committee on Ways and Means of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbaaf892b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397n–6/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifications of Commission members","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The members of the Commission shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbaaf892c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397n–6/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be experienced in finance, economics, pay for performance, or program evaluation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaaf892d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397n–6/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have relevant professional or personal experience in a field related to one or more of the outcomes listed in this division; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaaf892e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397n–6/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be qualified to review applications for social impact partnership projects to determine whether the proposed metrics and evaluation methodologies are appropriately rigorous and reliant upon independent data and evidence-based research.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbaaf892f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397n–6/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timing of appointments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The appointments of the members of the Commission shall be made not later than 120 days after ","children":[{"tag":"date","attrib":{"date":"2018-02-09"},"text":"February 9, 2018","children":[],"tail":", or, in the event of a vacancy, not later than 90 days after the date the vacancy arises. If a member of Congress fails to appoint a member by that date, the President may select a member of the President’s choice on behalf of the member of Congress. Notwithstanding the preceding sentence, if not all appointments have been made to the Commission as of that date, the Commission may operate with no fewer than five members until all appointments have been made."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbaaf8930-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397n–6/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term of appointments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbaaf8931-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397n–6/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The members appointed under subsection (c) shall serve as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbaaf8932-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397n–6/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Three members shall serve for 2 years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaaf8933-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397n–6/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Three members shall serve for 3 years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaaf8934-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397n–6/f/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Three members (one of which shall be Chair of the Commission appointed by the President) shall serve for 4 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaaf8935-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397n–6/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assignment of terms","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall designate the term length that each member appointed under subsection (c) shall serve by unanimous agreement. In the event that unanimous agreement cannot be reached, term lengths shall be assigned to the members by a random process.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbaaf8936-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397n–6/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vacancies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subsection (e), in the event of a vacancy in the Commission, whether due to the resignation of a member, the expiration of a member’s term, or any other reason, the vacancy shall be filled in the manner in which the original appointment was made and shall not affect the powers of the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbaaf8937-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397n–6/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment power","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Members of the Commission appointed under subsection (c) shall not be subject to confirmation by the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbaaf8938-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title XX, § 2057, as added "},{"tag":"ref","attrib":{"href":"/us/pl/115/123/dE/tVIII/s50802/2"},"text":"Pub. L. 115–123, div. E, title VIII, § 50802(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-02-09"},"text":"Feb. 9, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/279"},"text":"132 Stat. 279","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
