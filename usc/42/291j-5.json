{"tag":"section","attrib":{"id":"idb5cbdae8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s291j–5"},"text":null,"children":[{"tag":"num","attrib":{"value":"291j–5"},"text":"§ 291j–5.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on amounts of loans guaranteed or directly made","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The cumulative total of the principal of the loans outstanding at any time with respect to which guarantees have been issued, or which have been directly made, under this part may not exceed the lesser of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5cbdae9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s291j–5/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such limitations as may be specified in appropriations Acts, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5cbdaea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s291j–5/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of loans covered by allotments for the fiscal year ending ","children":[{"tag":"date","attrib":{"date":"1971-06-30"},"text":"June 30, 1971","children":[],"tail":", $500,000,000; for the fiscal year ending "},{"tag":"date","attrib":{"date":"1972-06-30"},"text":"June 30, 1972","children":[],"tail":", $1,000,000,000; and for each of the fiscal years ending "},{"tag":"date","attrib":{"date":"1973-06-30"},"text":"June 30, 1973","children":[],"tail":", and "},{"tag":"date","attrib":{"date":"1974-06-30"},"text":"June 30, 1974","children":[],"tail":", $1,500,000,000."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5cbdaeb-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"