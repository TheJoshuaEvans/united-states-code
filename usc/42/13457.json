{"tag":"section","attrib":{"id":"idbfc320c3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13457"},"text":null,"children":[{"tag":"num","attrib":{"value":"13457"},"text":"§ 13457.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Energy efficient environmental program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfc320c4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13457/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program direction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, in consultation with the Administrator of the Environmental Protection Agency, is authorized to continue to carry out a 5-year program to improve the energy efficiency and cost effectiveness of pollution prevention technologies and processes, including source reduction and waste minimization technologies and processes. The purposes of this section shall be to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfc320c5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13457/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" apply a systems approach to minimizing adverse environmental effects of industrial production in the most cost effective and energy efficient manner; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc320c6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13457/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" incorporate consideration of the entire materials and energy cycle with the goal of minimizing adverse environmental impacts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfc320c7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13457/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Identification of opportunities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Within 9 months after ","children":[{"tag":"date","attrib":{"date":"1992-10-24"},"text":"October 24, 1992","children":[],"tail":", the Secretary, in consultation with the Administrator of the Environmental Protection Agency, shall identify opportunities for the demonstration of energy efficient pollution prevention technologies and processes."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfc320c8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13457/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Within 1 year after ","children":[{"tag":"date","attrib":{"date":"1992-10-24"},"text":"October 24, 1992","children":[],"tail":", the Secretary shall submit a report to Congress evaluating the opportunities identified under subsection (b). Such report shall include—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfc320c9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13457/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of the technologies available to increase productivity and simultaneously reduce the consumption of energy and material resources and the production of wastes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc320ca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13457/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of the current use of such technologies by industry in the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc320cb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13457/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the status of any such technologies currently being developed, together with projected schedules of their commercial availability;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc320cc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13457/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the energy savings resulting from the use of such technologies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc320cd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13457/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the environmental benefits of such technologies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc320ce-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13457/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the costs of such technologies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc320cf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13457/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an evaluation of any existing Federal or State regulatory disincentives for the employment of such technologies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc320d0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13457/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an evaluation of any other barriers to the use of such technologies.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"In preparing the report required by this subsection, the Secretary shall consult with the Administrator of the Environmental Protection Agency, any other Federal, State, or local official the Secretary considers necessary, representatives of appropriate industries, members of organizations formed to further the goals of environmental protection or energy efficiency, and other appropriate interested members of the public, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfc320d1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13457/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Proposals","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Within 1 year after ","children":[{"tag":"date","attrib":{"date":"1992-10-24"},"text":"October 24, 1992","children":[],"tail":", the Secretary, in consultation with the Administrator of the Environmental Protection Agency, shall solicit proposals for activities under this section. Proposals selected under this subsection shall demonstrate—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfc320d2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13457/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" technical viability and cost effectiveness; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc320d3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13457/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" procedures for technology transfer and information outreach during and after completion of the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfc320d4-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/tXXI/s2108"},"text":"Pub. L. 102–486, title XXI, § 2108","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3071"},"text":"106 Stat. 3071","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
