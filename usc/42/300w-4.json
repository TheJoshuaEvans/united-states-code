ag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb6622826-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendments by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/646"},"text":"Pub. L. 99–646","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/99/654"},"text":"Pub. L. 99–654","children":[],"tail":" effective 30 days after "},{"tag":"date","attrib":{"date":"1986-11-10"},"text":"Nov. 10, 1986","children":[],"tail":", and 30 days after "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", respectively, see "},{"tag":"ref","attrib":{"href":"/us/pl/99/646/s87/e"},"text":"section 87(e) of Pub. L. 99–646","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/99/654/s4"},"text":"section 4 of Pub. L. 99–654","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s2241"},"text":"section 2241 of Title 18","children":[],"tail":", Crimes and Criminal Procedure."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb6622827-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1981-10-01"},"text":"Oct. 1, 1981","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/s901"},"text":"section 901 of Pub. L. 97–35","children":[],"tail":", set out in part as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300w"},"text":"section 300w of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb6622828-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Delayed Applicability of Requirement Regarding Advisory Committees","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/531/tI/s103/b"},"text":"Pub. L. 102–531, title I, § 103(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-27"},"text":"Oct. 27, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3473"},"text":"106 Stat. 3473","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/531/tI/s103/b"},"text":"“With respect to compliance with the requirement established in subsection (c)(2) of section 1905 of the Public Health Service Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300w–4/c/2"},"text":"42 U.S.C. 300w–4(c)(2)","children":[],"tail":"] (as amended by subsection (a) of this section), a State is deemed, notwithstanding such section, to be in compliance with such requirement if the State establishes an advisory committee in accordance with subsection (d) of such section not later than 180 days after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1992-10-27"},"text":"Oct. 27, 1992","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
