{"tag":"section","attrib":{"id":"idbe5d753f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7641"},"text":null,"children":[{"tag":"num","attrib":{"value":"7641"},"text":"§ 7641.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Noise abatement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbe5d7540-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7641/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of Noise Abatement and Control","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall establish within the Environmental Protection Agency an Office of Noise Abatement and Control, and shall carry out through such Office a full and complete investigation and study of noise and its effect on the public health and welfare in order to (1) identify and classify causes and sources of noise, and (2) determine—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbe5d7541-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7641/a/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" effects at various levels;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe5d7542-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7641/a/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" projected growth of noise levels in urban areas through the year 2000;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe5d7543-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7641/a/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the psychological and physiological effect on humans;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe5d7544-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7641/a/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" effects of sporadic extreme noise (such as jet noise near airports) as compared with constant noise;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe5d7545-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7641/a/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" effect on wildlife and property (including values);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe5d7546-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7641/a/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" effect of sonic booms on property (including values); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe5d7547-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7641/a/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other matters as may be of interest in the public welfare.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe5d7548-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7641/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investigation techniques; report and recommendations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In conducting such investigation, the Administrator shall hold public hearings, conduct research, experiments, demonstrations, and studies. The Administrator shall report the results of such investigation and study, together with his recommendations for legislation or other action, to the President and the Congress not later than one year after ","children":[{"tag":"date","attrib":{"date":"1970-12-31"},"text":"December 31, 1970","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe5d7549-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7641/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Abatement of noise from Federal activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In any case where any Federal department or agency is carrying out or sponsoring any activity resulting in noise which the Administrator determines amounts to a public nuisance or is otherwise objectionable, such department or agency shall consult with the Administrator to determine possible means of abating such noise.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbe5d754a-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1955-07-14/ch360"},"text":"July 14, 1955, ch. 360","children":[],"tail":", title IV, § 402, as added "},{"tag":"ref","attrib":{"href":"/us/pl/91/604/s14"},"text":"Pub. L. 91–604, § 14","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-31"},"text":"Dec. 31, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1709"},"text":"84 Stat. 1709","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbe5d754b-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbe5d754c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbe5d754d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another section 402 of act ","children":[{"tag":"date","attrib":{"date":"1955-07-14"},"text":"July 14, 1955","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/101/549/tIV/s401"},"text":"Pub. L. 101–549, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-15"},"text":"Nov. 15, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2585"},"text":"104 Stat. 2585","children":[],"tail":", is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s7651a"},"text":"section 7651a of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1858"},"text":"section 1858 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
