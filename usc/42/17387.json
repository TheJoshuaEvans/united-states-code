{"tag":"section","attrib":{"id":"idc03a735b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17387"},"text":null,"children":[{"tag":"num","attrib":{"value":"17387"},"text":"§ 17387.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Integrated energy systems","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc03a735c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17387/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2020-12-27"},"text":"December 27, 2020","children":[],"tail":", the Secretary shall establish a research, development, and demonstration program to develop cost-effective integrated energy systems, including—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc03a735d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17387/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" development of computer modeling to design different configurations of integrated energy systems and to optimize system operation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc03a735e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17387/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" research on system integration needed to plan, design, build, and operate integrated energy systems, including interconnection requirements with the electric grid;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc03a735f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17387/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" development of integrated energy systems for various applications, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc03a7360-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17387/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" thermal energy generation and storage for buildings and manufacturing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc03a7361-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17387/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" electricity storage coupled with energy generation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc03a7362-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17387/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" desalination;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc03a7363-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17387/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" production of liquid and gaseous fuels; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc03a7364-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17387/a/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" production of chemicals such as ammonia and ethylene;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc03a7365-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17387/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" development of testing facilities for integrated energy systems; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc03a7366-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17387/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" research on incorporation of various technologies for integrated energy systems, including nuclear energy, renewable energy, storage, and carbon capture, utilization, and sequestration technologies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc03a7367-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17387/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Strategic plan","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc03a7368-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17387/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2020-12-27"},"text":"December 27, 2020","children":[],"tail":", the Secretary shall submit to the Committee on Science, Space, and Technology of the House of Representatives and the Committee on Energy and Natural Resources of the Senate a strategic plan that identifies opportunities, challenges, and standards needed for the development and commercial application of integrated energy systems. The strategic plan shall include—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc03a7369-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17387/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" analysis of the potential benefits of development of integrated electric systems on the electric grid;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc03a736a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17387/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" analysis of the potential contributions of integrated energy systems to different grid architecture scenarios;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc03a736b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17387/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" research and development goals for various integrated energy systems, including those identified in subsection (a);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc03a736c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17387/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assessment of policy and market barriers to the adoption of integrated energy systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc03a736d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17387/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" analysis of the technical and economic feasibility of adoption of different integrated energy systems; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc03a736e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17387/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a 10-year roadmap to guide the program established under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc03a736f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17387/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Updates","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not less than once every 3 years for the duration of this research program, the Secretary shall submit an updated version of the strategic plan to the Committee on Science, Space, and Technology of the House of Representatives and the Committee on Energy and Natural Resources of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc03a7370-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17387/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program implementation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the research, development, demonstration, and commercial application aims of subsection (a), the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc03a7371-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17387/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" implement the recommendations set forth in the strategic plan in subsection (b);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc03a7372-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17387/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" coordinate across all relevant program offices at the Department, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc03a7373-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17387/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Office of Energy Efficiency and Renewable Energy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc03a7374-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17387/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Office of Nuclear Energy; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc03a7375-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17387/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Office of Fossil Energy;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc03a7376-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17387/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" leverage existing programs and resources of the Department; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc03a7377-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17387/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prioritize activities that accelerate the development of integrated electricity generation, storage, and distribution systems with net zero greenhouse gas emissions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc03a7378-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17387/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Integrated energy system defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “integrated energy system” means a system composed of 2 or more co-located or jointly operated sub-systems of energy generation, energy storage, or other energy technologies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc03a7379-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/tXIII/s1310"},"text":"Pub. L. 110–140, title XIII, § 1310","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dZ/tVIII/s8003"},"text":"Pub. L. 116–260, div. Z, title VIII, § 8003","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2581"},"text":"134 Stat. 2581","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
