{"tag":"section","attrib":{"id":"idc029aae3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17152"},"text":null,"children":[{"tag":"num","attrib":{"value":"17152"},"text":"§ 17152.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Energy Efficiency and Conservation Block Grant Program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc029aae4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17152/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a program, to be known as the “Energy Efficiency and Conservation Block Grant Program”, under which the Secretary shall provide grants to eligible entities in accordance with this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc029aae5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17152/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purpose of the program shall be to assist eligible entities in implementing strategies—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc029aae6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17152/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to reduce fossil fuel emissions created as a result of activities within the jurisdictions of eligible entities in a manner that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc029aae7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17152/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is environmentally sustainable; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc029aae8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17152/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the maximum extent practicable, maximizes benefits for local and regional communities;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc029aae9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17152/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to reduce the total energy use of the eligible entities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc029aaea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17152/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to improve energy efficiency in—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc029aaeb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17152/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the transportation sector;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc029aaec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17152/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the building sector; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc029aaed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17152/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other appropriate sectors.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc029aaee-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/tV/s542"},"text":"Pub. L. 110–140, title V, § 542","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1668"},"text":"121 Stat. 1668","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc029aaef-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc029aaf0-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc029aaf1-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the date that is 1 day after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/s1601"},"text":"section 1601 of Pub. L. 110–140","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1824"},"text":"section 1824 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
