{"tag":"section","attrib":{"id":"idb8866719-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1391"},"text":null,"children":[{"tag":"num","attrib":{"value":"1391"},"text":"§ 1391.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"For the purpose of assisting the States (including the District of Columbia, the Commonwealth of Puerto Rico, the Virgin Islands, Guam, and American Samoa) to plan for and take other steps leading to comprehensive State and community action to combat mental retardation, there is authorized to be appropriated the sum of $2,200,000. There are also authorized to be appropriated, for assisting such States in initiating the implementation and carrying out of planning and other steps to combat mental retardation, $2,750,000 for the fiscal year ending ","children":[{"tag":"date","attrib":{"date":"1966-06-30"},"text":"June 30, 1966","children":[],"tail":", and $2,750,000 for the fiscal year ending "},{"tag":"date","attrib":{"date":"1967-06-30"},"text":"June 30, 1967","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb886671a-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title XVII, § 1701, as added "},{"tag":"ref","attrib":{"href":"/us/pl/88/156/s5"},"text":"Pub. L. 88–156, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1963-10-24"},"text":"Oct. 24, 1963","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/77/275"},"text":"77 Stat. 275","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/89/97/tII/s211/a"},"text":"Pub. L. 89–97, title II, § 211(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-07-30"},"text":"July 30, 1965","children":[],"tail":", "},{"t