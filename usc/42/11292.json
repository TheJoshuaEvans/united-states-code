{"tag":"section","attrib":{"id":"idbf3d9c87-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11292"},"text":null,"children":[{"tag":"num","attrib":{"value":"11292"},"text":"§ 11292.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Education of public, individuals with Alzheimer’s disease and their families, and health and long-term care providers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf3d9c88-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11292/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training models grants","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf3d9c89-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11292/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director of the National Institute on Aging may award grants to eligible entities to assist the entities in developing and evaluating model training programs—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf3d9c8a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11292/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbf3d9c8b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11292/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" health care professionals, including mental health professionals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf3d9c8c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11292/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" health care paraprofessionals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf3d9c8d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11292/a/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" personnel, including information and referral, case management, and in-home services personnel (including personnel receiving support under the Older Americans Act of 1965 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3001"},"text":"42 U.S.C. 3001","children":[],"tail":" et seq.)), providing supportive services to the elderly and the families of the elderly;"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf3d9c8e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11292/a/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" family caregivers providing care and treatment for individuals with Alzheimer’s disease and related disorders; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf3d9c8f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11292/a/1/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" personnel of local organizations (including community groups, business and labor groups, and religious, educational, and charitable organizations) that have traditionally not been involved in planning and developing long-term care services; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf3d9c90-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11292/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" with attention to such variables as—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbf3d9c91-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11292/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" curricula development for training and continuing education programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf3d9c92-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11292/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" care setting; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf3d9c93-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11292/a/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" intervention technique.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf3d9c94-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11292/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to receive grants under this subsection, an entity shall be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf3d9c95-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11292/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an educational institution providing training and education in medicine, psychology, nursing, social work, gerontology, or health care administration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf3d9c96-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11292/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an educational institution providing preparatory training and education of personnel for nursing homes, hospitals, and home or community settings; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf3d9c97-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11292/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an Alzheimer’s Disease Research Center described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s285e–2/a"},"text":"section 285e–2(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf3d9c98-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11292/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Educational grants","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director of the National Institute on Aging is authorized to make grants to public and nonprofit private entities to assist such entities in establishing programs, for educating health care providers and the families of individuals with Alzheimer’s disease or related disorders, regarding—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf3d9c99-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11292/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" caring for individuals with such diseases or disorders; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf3d9c9a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11292/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the availability in the community of public and private sources of assistance, including financial assistance, for caring for such individuals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf3d9c9b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11292/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Award of grants","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In awarding grants under this section, the Director of the National Institute on Aging shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf3d9c9c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11292/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" award the grants on the basis of merit;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf3d9c9d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11292/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" award the grants in a manner that will ensure access to the programs described in subsections (a) and (b) by rural, minority, and underserved populations throughout the country; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf3d9c9e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11292/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that the grants are distributed among the principal geographic regions of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf3d9c9f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11292/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be eligible to receive a grant under this section, an entity shall submit an application to the Director of the National Institute on Aging at such time, in such manner, and containing or accompanied by such information, as the Director may reasonably require, including, at a minimum, an assurance that the entity will coordinate programs provided under this section with the State agency designated under section 305(a)(1) of the Older Americans Act of 1965 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3025/a/1"},"text":"42 U.S.C. 3025(a)(1)","children":[],"tail":"], in the State in which the entity will provide such programs."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf3d9ca0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11292/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the National Institute on Aging shall coordinate the award of grants under this section with the heads of other appropriate agencies, including the Commissioner of the Administration on Aging.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf3d9ca1-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/660/tIX/s962"},"text":"Pub. L. 99–660, title IX, § 962","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3814"},"text":"100 Stat. 3814","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/507/s8/a"},"text":"Pub. L. 102–507, § 8(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3286"},"text":"106 Stat. 3286","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf3d9ca2-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf3d9ca3-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbf3d9ca4-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Older Americans Act of 1965, referred to in subsec. (a)(1)(A)(iii), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/73"},"text":"Pub. L. 89–73","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-07-14"},"text":"July 14, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/218"},"text":"79 Stat. 218","children":[],"tail":", which is classified generally to chapter 35 (§ 3001 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3001"},"text":"section 3001 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbf3d9ca5-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/507"},"text":"Pub. L. 102–507","children":[],"tail":" amended section generally. Prior to amendment, section read as follows: “The Director of the National Institute on Aging, through centers supported under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s285e–2"},"text":"section 285e–2 of this title","children":[],"tail":", professional associations, and continuing education programs, shall conduct education and information dissemination activities concerning the special problems of individuals with Alzheimer’s disease and their families. Such activities shall be designed to enhance the understanding of such problems by individuals who provide care for individuals with Alzheimer’s disease and related dementias, including physicians, nurses, psychologists, social workers, occupational therapists, nursing home administrators, nurses, and health care aides.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
