{"tag":"section","attrib":{"id":"idc06a0fc3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795"},"text":null,"children":[{"tag":"num","attrib":{"value":"18795"},"text":"§ 18795.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Home energy performance-based, whole-house rebates","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc06a0fc4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc06a0fc5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to amounts otherwise available, there is appropriated to the Secretary for fiscal year 2022, out of any money in the Treasury not otherwise appropriated, $4,300,000,000, to remain available through ","children":[{"tag":"date","attrib":{"date":"2031-09-30"},"text":"September 30, 2031","children":[],"tail":", to carry out a program to award grants to State energy offices to develop and implement a HOMES rebate program."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06a0fc6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation of funds","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc06a0fc7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall reserve funds made available under paragraph (1) for each State energy office—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc06a0fc8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in accordance with the allocation formula for the State Energy Program in effect on ","children":[{"tag":"date","attrib":{"date":"2022-01-01"},"text":"January 1, 2022","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc06a0fc9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to be distributed to a State energy office if the application of the State energy office under subsection (b) is approved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06a0fca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not earlier than 2 years after ","children":[{"tag":"date","attrib":{"date":"2022-08-16"},"text":"August 16, 2022","children":[],"tail":", any money reserved under subparagraph (A) but not distributed under clause (ii) of that subparagraph shall be redistributed to the State energy offices operating a HOMES rebate program using a grant received under this section in proportion to the amount distributed to those State energy offices under subparagraph (A)(ii)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06a0fcb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative expenses","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Of the funds made available under paragraph (1), the Secretary shall use not more than 3 percent for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc06a0fcc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" administrative purposes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06a0fcd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing technical assistance relating to activities carried out under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc06a0fce-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A State energy office seeking a grant under this section shall submit to the Secretary an application that includes a plan to implement a HOMES rebate program, including a plan—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc06a0fcf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to use procedures, as approved by the Secretary, for determining the reductions in home energy use resulting from the implementation of a home energy efficiency retrofit that are calibrated to historical energy usage for a home consistent with BPI 2400, for purposes of modeled performance home rebates;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06a0fd0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to use open-source advanced measurement and verification software, as approved by the Secretary, for determining and documenting the monthly and hourly (if available) weather-normalized energy use of a home before and after the implementation of a home energy efficiency retrofit, for purposes of measured performance home rebates;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06a0fd1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to value savings based on time, location, or greenhouse gas emissions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06a0fd2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for quality monitoring to ensure that each home energy efficiency retrofit for which a rebate is provided is documented in a certificate that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc06a0fd3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is provided by the contractor and certified by a third party to the homeowner; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06a0fd4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" details the work performed, the equipment and materials installed, and the projected energy savings or energy generation to support accurate valuation of the retrofit;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06a0fd5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide a contractor performing a home energy efficiency retrofit or an aggregator who has the right to claim a rebate $200 for each home located in a disadvantaged community that receives a home energy efficiency retrofit for which a rebate is provided under the program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06a0fd6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to ensure that a homeowner or aggregator does not receive a rebate for the same upgrade through both a HOMES rebate program and any other Federal grant or rebate program, pursuant to subsection (c)(7).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc06a0fd7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" HOMES rebate program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc06a0fd8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A HOMES rebate program carried out by a State energy office receiving a grant pursuant to this section shall provide rebates to homeowners and aggregators for whole-house energy saving retrofits begun on or after ","children":[{"tag":"date","attrib":{"date":"2022-08-16"},"text":"August 16, 2022","children":[],"tail":", and completed by not later than "},{"tag":"date","attrib":{"date":"2031-09-30"},"text":"September 30, 2031","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06a0fd9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of rebate","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to paragraph (3), under a HOMES rebate program, the amount of a rebate shall not exceed—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc06a0fda-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for individuals and aggregators carrying out energy efficiency upgrades of single-family homes—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc06a0fdb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of a retrofit that achieves modeled energy system savings of not less than 20 percent but less than 35 percent, the lesser of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idc06a0fdc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795/c/2/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $2,000; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc06a0fdd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795/c/2/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 50 percent of the project cost;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc06a0fde-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of a retrofit that achieves modeled energy system savings of not less than 35 percent, the lesser of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idc06a0fdf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795/c/2/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $4,000; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc06a0fe0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795/c/2/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 50 percent of the project cost; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc06a0fe1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795/c/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for measured energy savings, in the case of a home or portfolio of homes that achieves energy savings of not less than 15 percent—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idc06a0fe2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795/c/2/A/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a payment rate per kilowatt hour saved, or kilowatt hour-equivalent saved, equal to $2,000 for a 20 percent reduction of energy use for the average home in the State; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc06a0fe3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795/c/2/A/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 50 percent of the project cost;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06a0fe4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for multifamily building owners and aggregators carrying out energy efficiency upgrades of multifamily buildings—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc06a0fe5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a retrofit that achieves modeled energy system savings of not less than 20 percent but less than 35 percent, $2,000 per dwelling unit, with a maximum of $200,000 per multifamily building;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc06a0fe6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a retrofit that achieves modeled energy system savings of not less than 35 percent, $4,000 per dwelling unit, with a maximum of $400,000 per multifamily building; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc06a0fe7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795/c/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for measured energy savings, in the case of a multifamily building or portfolio of multifamily buildings that achieves energy savings of not less than 15 percent—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idc06a0fe8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795/c/2/B/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a payment rate per kilowatt hour saved, or kilowatt hour-equivalent saved, equal to $2,000 for a 20 percent reduction of energy use per dwelling unit for the average multifamily building in the State; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc06a0fe9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795/c/2/B/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 50 percent of the project cost; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06a0fea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for individuals and aggregators carrying out energy efficiency upgrades of a single-family home occupied by a low- or moderate-income household or a multifamily building not less than 50 percent of the dwelling units of which are occupied by low- or moderate-income households—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc06a0feb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795/c/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of a retrofit that achieves modeled energy system savings of not less than 20 percent but less than 35 percent, the lesser of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idc06a0fec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795/c/2/C/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $4,000 per single-family home or dwelling unit; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc06a0fed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795/c/2/C/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 80 percent of the project cost;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc06a0fee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795/c/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of a retrofit that achieves modeled energy system savings of not less than 35 percent, the lesser of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idc06a0fef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795/c/2/C/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $8,000 per single-family home or dwelling unit; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc06a0ff0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795/c/2/C/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 80 percent of the project cost; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc06a0ff1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795/c/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for measured energy savings, in the case of a single-family home, multifamily building, or portfolio of single-family homes or multifamily buildings that achieves energy savings of not less than 15 percent—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idc06a0ff2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795/c/2/C/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a payment rate per kilowatt hour saved, or kilowatt hour-equivalent saved, equal to $4,000 for a 20 percent reduction of energy use per single-family home or dwelling unit, as applicable, for the average single-family home or multifamily building in the State; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc06a0ff3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795/c/2/C/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 80 percent of the project cost.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06a0ff4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rebates to low- or moderate-income households","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On approval from the Secretary, notwithstanding paragraph (2), a State energy office carrying out a HOMES rebate program using a grant awarded pursuant to this section may increase rebate amounts for low- or moderate-income households.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06a0ff5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State energy office that receives a grant pursuant to this section may use not more than 20 percent of the grant amount for planning, administration, or technical assistance related to a HOMES rebate program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06a0ff6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data access guidelines","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall develop and publish guidelines for States relating to residential electric and natural gas energy data sharing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06a0ff7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Activities carried out by a State energy office using a grant awarded pursuant to this section shall not be subject to the expenditure prohibitions and limitations described in section 420.18 of title 10, Code of Federal Regulations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06a0ff8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on combining rebates","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A rebate provided by a State energy office under a HOMES rebate program may not be combined with any other Federal grant or rebate, including a rebate provided under a high-efficiency electric home rebate program (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s18795a/d"},"text":"section 18795a(d) of this title","children":[],"tail":"), for the same single upgrade."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc06a0ff9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc06a0ffa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disadvantaged community","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “disadvantaged community” means a community that the Secretary determines, based on appropriate data, indices, and screening tools, is economically, socially, or environmentally disadvantaged.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06a0ffb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" HOMES rebate program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “HOMES rebate program” means a Home Owner Managing Energy Savings rebate program established by a State energy office as part of an approved State energy conservation plan under the State Energy Program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06a0ffc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Low- or moderate-income household","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “low- or moderate-income household” means an individual or family the total annual income of which is less than 80 percent of the median income of the area in which the individual or family resides, as reported by the Department of Housing and Urban Development, including an individual or family that has demonstrated eligibility for another Federal program with income restrictions equal to or below 80 percent of area median income.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc06a0ffd-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/169/tV/s50121"},"text":"Pub. L. 117–169, title V, § 50121","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-16"},"text":"Aug. 16, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2033"},"text":"136 Stat. 2033","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc06a0ffe-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc06a0fff-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idc06a1000-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/169"},"text":"Pub. L. 117–169","children":[],"tail":", and not as part of div. D of "},{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":", which enacted this chapter."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc06a1001-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idc06a1002-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definitions of “greenhouse gas”, “Secretary”, “State”, “State energy office”, and “State Energy Program” as used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/169/s50111"},"text":"section 50111 of Pub. L. 117–169","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s17113b"},"text":"section 17113b of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
