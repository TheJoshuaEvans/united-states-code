{"tag":"section","attrib":{"id":"idc07d2133-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19114"},"text":null,"children":[{"tag":"num","attrib":{"value":"19114"},"text":"§ 19114.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research and development awards","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc07d2134-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19114/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"From amounts made available for the Directorate, the Director shall make awards, on a competitive basis, for research and technology development within the key technology focus areas, including investments that advance solutions to the challenges under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s19107"},"text":"section 19107 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc07d2135-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19114/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The purpose of the awards under this section shall be to accelerate technological advances and technology adoption in the key technology focus areas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc07d2136-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19114/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recipients","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Recipients of funds under this section may include institutions of higher education, research institutions, non-profit organizations, private sector entities, consortia, or other entities as defined by the Director.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc07d2137-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19114/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Metrics","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director may set metrics, including goals and deadlines, for the development and demonstration of technology as determined in the terms of the award, and may use such metrics to determine whether an award recipient shall be eligible for continued or follow-on funding.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc07d2138-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19114/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Short term technology deployment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall also make awards, including through the SBIR and STTR programs (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s638/e"},"text":"section 638(e) of title 15","children":[],"tail":"), to expedite short-term technology deployment within a period of no longer than 24 months."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc07d2139-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19114/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In selecting recipients for an award under this section, the Director shall consider, at a minimum—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc07d213a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19114/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the relevance of the project to the challenges and the key technology focus areas under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s19107"},"text":"section 19107 of this title","children":[],"tail":", and the potential of the project to result in transformational advances for such challenges and the key technology focus areas;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc07d213b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19114/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the current status of similar technology, the limits of current practice, and the novelty and risks of the proposed project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc07d213c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19114/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the ethical, societal, safety, and security implications relevant to the application of the technology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc07d213d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19114/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the appropriateness of quantitative goals and metrics for evaluating the project and a plan for evaluating those metrics; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc07d213e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19114/f/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the path for developing and, as appropriate, commercializing the technology into products and processes in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc07d213f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19114/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"From within funds authorized for the Directorate for Technology, Innovation, and Partnerships, there are authorized to carry out the activities under this section $1,000,000,000 for fiscal years 2023 through 2027.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc07d2140-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/tIII/s10394"},"text":"Pub. L. 117–167, div. B, title III, § 10394","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1591"},"text":"136 Stat. 1591","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
