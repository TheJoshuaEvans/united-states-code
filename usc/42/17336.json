{"tag":"section","attrib":{"id":"idc035915f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17336"},"text":null,"children":[{"tag":"num","attrib":{"value":"17336"},"text":"§ 17336.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deployment of international clean and efficient energy technologies and investment in global energy markets","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc0359160-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17336/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Task Force","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0359161-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17336/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"December 19, 2007","children":[],"tail":", the President shall establish a Task Force on International Cooperation for Clean and Efficient Energy Technologies (in this section referred to as the “Task Force”)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0359162-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17336/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Composition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Task Force shall be composed of representatives, appointed by the head of the respective Federal department or agency, of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0359163-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17336/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Council on Environmental Quality;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0359164-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17336/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of Energy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0359165-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17336/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of Commerce;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0359166-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17336/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of the Treasury;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0359167-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17336/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0359168-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17336/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Environmental Protection Agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0359169-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17336/a/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States Agency for International Development;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc035916a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17336/a/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Export-Import Bank of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc035916b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17336/a/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States International Development Finance Corporation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc035916c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17336/a/2/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Trade and Development Agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc035916d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17336/a/2/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Small Business Administration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc035916e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17336/a/2/L"},"text":null,"children":[{"tag":"num","attrib":{"value":"L"},"text":"(L)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Office of the United States Trade Representative; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc035916f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17336/a/2/M"},"text":null,"children":[{"tag":"num","attrib":{"value":"M"},"text":"(M)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other Federal departments and agencies, as determined by the President.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0359170-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17336/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chairperson","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall designate a Chairperson or Co-Chairpersons of the Task Force.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0359171-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17336/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Task Force—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0359172-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17336/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall develop and assist in the implementation of the strategy required under subsection (c); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0359173-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17336/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc0359174-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17336/a/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall analyze technology, policy, and market opportunities for the development, demonstration, and deployment of clean and efficient energy technologies on an international basis; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc0359175-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17336/a/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall examine relevant trade, tax, finance, international, and other policy issues to assess which policies, in the United States and in developing countries, would help open markets and improve the export of clean and efficient energy technologies from the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0359176-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17336/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Task Force, including any working group established by the Task Force pursuant to subsection (b), shall terminate 12 years after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"December 19, 2007","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0359177-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17336/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Working groups","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0359178-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17336/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Task Force—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0359179-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17336/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall establish an Interagency Working Group on the Export of Clean and Efficient Energy Technologies (in this section referred to as the “Interagency Working Group”); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc035917a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17336/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may establish other working groups as may be necessary to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc035917b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17336/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Composition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Interagency Working Group shall be composed of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc035917c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17336/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Energy, the Secretary of Commerce, and the Secretary of State, who shall serve as Co-Chairpersons of the Interagency Working Group; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc035917d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17336/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other members, as determined by the Chairperson or Co-Chairpersons of the Task Force.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc035917e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17336/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Interagency Working Group shall coordinate the resources and relevant programs of the Department of Energy, the Department of Commerce, the Department of State, and other relevant Federal departments and agencies to support the export of clean and efficient energy technologies developed or demonstrated in the United States to other countries and the deployment of such clean and efficient energy technologies in such other countries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc035917f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17336/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interagency Center","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Interagency Working Group—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0359180-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17336/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall establish an Interagency Center on the Export of Clean and Efficient Energy Technologies (in this section referred to as the “Interagency Center”) to assist the Interagency Working Group in carrying out its duties required under paragraph (3); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0359181-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17336/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall locate the Interagency Center at a site agreed upon by the Co-Chairpersons of the Interagency Working Group, with the approval of the Chairperson or Co-Chairpersons of the Task Force.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0359182-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17336/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Strategy","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0359183-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17336/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"December 19, 2007","children":[],"tail":", the Task Force shall develop and submit to the President and the appropriate congressional committees a strategy to—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0359184-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17336/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support the development and implementation of programs, policies, and initiatives in developing countries to promote the adoption and deployment of clean and efficient energy technologies, with an emphasis on those developing countries that are expected to experience the most significant growth in energy production and use over the next 20 years;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0359185-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17336/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" open and expand clean and efficient energy technology markets and facilitate the export of clean and efficient energy technologies to developing countries, in a manner consistent with United States obligations as a member of the World Trade Organization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0359186-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17336/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" integrate into the foreign policy objectives of the United States the promotion of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc0359187-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17336/c/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the deployment of clean and efficient energy technologies and the reduction of greenhouse gas emissions in developing countries; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc0359188-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17336/c/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the export of clean and efficient energy technologies; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0359189-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17336/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" develop financial mechanisms and instruments, including securities that mitigate the political and foreign exchange risks of uses that are consistent with the foreign policy objectives of the United States by combining the private sector market and government enhancements, that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc035918a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17336/c/1/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are cost-effective; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc035918b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17336/c/1/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitate private capital investment in clean and efficient energy technology projects in developing countries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc035918c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17336/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Updates","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 3 years after the date of submission of the strategy under paragraph (1), and every 3 years thereafter, the Task Force shall update the strategy in accordance with the requirements of paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc035918d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17336/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc035918e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17336/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 3 years after the date of submission of the strategy under subsection (c)(1), and every 3 years thereafter, the President shall transmit to the appropriate congressional committees a report on the implementation of this section for the prior 3-year period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc035918f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17336/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matters to be included","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The report required under paragraph (1) shall include the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0359190-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17336/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The update of the strategy required under subsection (c)(2) and a description of the actions taken by the Task Force to assist in the implementation of the strategy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0359191-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17336/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of actions taken by the Task Force to carry out the duties required under subsection (a)(4)(B).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0359192-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17336/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of assistance provided under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0359193-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17336/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The results of programs, projects, and activities carried out under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0359194-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17336/d/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of priorities for promoting the diffusion and adoption of clean and efficient energy technologies and strategies in developing countries, taking into account economic and security interests of the United States and opportunities for the export of technology of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0359195-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17336/d/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Recommendations to the heads of appropriate Federal departments and agencies on methods to streamline Federal programs and policies to improve the role of such Federal departments and agencies in the development, demonstration, and deployment of clean and efficient energy technologies on an international basis.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0359196-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17336/d/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Strategies to integrate representatives of the private sector and other interested groups on the export and deployment of clean and efficient energy technologies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0359197-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17336/d/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of programs to disseminate information to the private sector and the public on clean and efficient energy technologies and opportunities to transfer such clean and efficient energy technologies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0359198-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17336/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this section $5,000,000 for each of fiscal years 2008 through 2020.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc0359199-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/tIX/s916"},"text":"Pub. L. 110–140, title IX, § 916","children":[],"tail":", "}