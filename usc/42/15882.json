{"tag":"section","attrib":{"id":"idbfe48c37-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15882"},"text":null,"children":[{"tag":"num","attrib":{"value":"15882"},"text":"§ 15882.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hydroelectric efficiency improvement incentives","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfe48c38-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15882/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Incentive payments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall make incentive payments to the owners or operators of hydroelectric facilities at existing dams to be used to make capital improvements in the facilities that are directly related to improving the efficiency of such facilities by at least 3 percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfe6fb39-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15882/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Incentive payments under this section shall not exceed 30 percent of the costs of the capital improvement concerned and not more than 1 payment may be made with respect to improvements at a single facility. No payment in excess of $5,000,000 may be made with respect to improvements at a single facility in any 1 fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfe6fb3a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15882/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this section $75,000,000 for fiscal year 2022 to remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfe6fb3b-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tII/s243"},"text":"Pub. L. 109–58, title II, § 243","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/678"},"text":"119 Stat. 678","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dZ/tIII/s3005/b"},"text":"Pub. L. 116–260, div. Z, title III, § 3005(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2511"},"text":"134 Stat. 2511","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/dD/tIII/s40332/a"},"text":"Pub. L. 117–58, div. D, title III, § 40332(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1023"},"text":"135 Stat. 1023","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbfe6fb3c-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbfe6fb3d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbfe6fb3e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s40332/a/1"},"text":"Pub. L. 117–58, § 40332(a)(1)","children":[],"tail":", inserted “incentives” after “improvement” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s40332/a/2"},"text":"Pub. L. 117–58, § 40332(a)(2)","children":[],"tail":", substituted “30 percent” for “10 percent” and “$5,000,000” for “$750,000” and inserted “in any 1 fiscal year” before period."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s40332/a/3"},"text":"Pub. L. 117–58, § 40332(a)(3)","children":[],"tail":", added subsec. (c) and struck out former subsec. (c). Prior to amendment, text read as follows: “There are authorized to be appropriated to carry out this section not more than $10,000,000 for each of fiscal years 2021 through 2036.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2020—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Pub. L. 116–260","children":[],"tail":" substituted “each of fiscal years 2021 through 2036” for “each of the fiscal years 2006 through 2015”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbfe6fb3f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbfe6fb40-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Wage Rate Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions relating to rates of wages to be paid to laborers and mechanics on projects for construction, alteration, or repair work funded under div. D or an amendment by div. D of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":", including authority of Secretary of Labor, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s18851"},"text":"section 18851 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
