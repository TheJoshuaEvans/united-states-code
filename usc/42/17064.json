{"tag":"section","attrib":{"id":"idc0227e3c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17064"},"text":null,"children":[{"tag":"num","attrib":{"value":"17064"},"text":"§ 17064.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Smart building acceleration","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc0227e3d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17064/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0227e3e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17064/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Department","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Department” means the Department of Energy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0227e3f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17064/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “program” means the Federal Smart Building Program established under subsection (b)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0227e40-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17064/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of Energy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0227e41-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17064/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Smart building","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “smart building” means a building, or collection of buildings, with an energy system that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0227e42-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17064/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is flexible and automated;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0227e43-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17064/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has extensive operational monitoring and communication connectivity, allowing remote monitoring and analysis of all building functions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0227e44-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17064/a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" takes a systems-based approach in integrating the overall building operations for control of energy generation, consumption, and storage;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0227e45-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17064/a/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" communicates with utilities and other third-party commercial entities, if appropriate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0227e46-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17064/a/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protects the health and safety of occupants and workers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0227e47-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17064/a/4/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" incorporates cybersecurity best practices.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0227e48-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17064/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Smart building accelerator","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “smart building accelerator” means an initiative that is designed to demonstrate specific innovative policies and approaches—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0227e49-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17064/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with clear goals and a clear timeline; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0227e4a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17064/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that, on successful demonstration, would accelerate investment in energy efficiency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0227e4b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17064/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal Smart Building Program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0227e4c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17064/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2020-12-27"},"text":"December 27, 2020","children":[],"tail":", the Secretary shall, in consultation with the Administrator of General Services, establish a program to be known as the “Federal Smart Building Program”—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0227e4d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17064/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to implement smart building technology; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0227e4e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17064/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to demonstrate the costs and benefits of smart buildings.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0227e4f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17064/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0227e50-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17064/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall coordinate the selection of not fewer than 1 building from among each of several key Federal agencies, as described in paragraph (4), to compose an appropriately diverse set of smart buildings based on size, type, and geographic location.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0227e51-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17064/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusion of commercially operated buildings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In making selections under subparagraph (A), the Secretary may include buildings that are owned by the Federal Government but are commercially operated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0227e52-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17064/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Targets","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 18 months after ","children":[{"tag":"date","attrib":{"date":"2020-12-27"},"text":"December 27, 2020","children":[],"tail":", the Secretary shall establish targets for the number of smart buildings to be commissioned and evaluated by key Federal agencies by 3 years and 6 years after "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"December 27, 2020","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0227e53-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17064/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal agency described","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The key Federal agencies referred to paragraph (2)(A) shall include buildings operated by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0227e54-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17064/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of the Army;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0227e55-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17064/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of the Navy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0227e56-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17064/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of the Air Force;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0227e57-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17064/b/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0227e58-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17064/b/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of the Interior;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0227e59-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17064/b/4/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of Veterans Affairs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0227e5a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17064/b/4/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the General Services Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0227e5b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17064/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In implementing the program, the Secretary shall leverage existing financing mechanisms including energy savings performance contracts, utility energy service contracts, and annual appropriations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0227e5c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17064/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Using the guidelines of the Federal Energy Management Program relating to whole-building evaluation, measurement, and verification, the Secretary shall evaluate the costs and benefits of the buildings selected under paragraph (2), including an identification of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0227e5d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17064/b/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" which advanced building technologies—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc0227e5e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17064/b/6/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are most cost-effective; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc0227e5f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17064/b/6/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" show the most promise for—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idc0227e60-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17064/b/6/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increasing building energy savings;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc0227e61-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17064/b/6/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increasing service performance to building occupants;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc0227e62-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17064/b/6/A/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reducing environmental impacts; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc0227e63-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17064/b/6/A/ii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing cybersecurity; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0227e64-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17064/b/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other information the Secretary determines to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0227e65-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17064/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Awards","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may expand awards made under the Federal Energy Management Program and the Better Building Challenge to recognize specific agency achievements in accelerating the adoption of smart building technologies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0227e66-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17064/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Survey of private sector smart buildings","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0227e67-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17064/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Survey","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall conduct a survey of privately owned smart buildings throughout the United States, including commercial buildings, laboratory facilities, hospitals, multifamily residential buildings, and buildings owned by nonprofit organizations and institutions of higher education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0227e68-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17064/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"From among the smart buildings surveyed under paragraph (1), the Secretary shall select not fewer than 1 building each from an appropriate range of building sizes, types, and geographic locations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0227e69-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17064/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Using the guidelines of the Federal Energy Management Program relating to whole-building evaluation, measurement, and verification, the Secretary shall evaluate the costs and benefits of the buildings selected under paragraph (2), including an identification of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0227e6a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17064/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" which advanced building technologies and systems—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc0227e6b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17064/c/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are most cost-effective; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc0227e6c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17064/c/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" show the most promise for—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idc0227e6d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17064/c/3/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increasing building energy savings;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc0227e6e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17064/c/3/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increasing service performance to building occupants;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc0227e6f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17064/c/3/A/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reducing environmental impacts; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc0227e70-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17064/c/3/A/ii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing cybersecurity; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0227e71-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17064/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other information the Secretary determines to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0227e72-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17064/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Better building challenge","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As part of the Better Building Challenge of the Department, the Secretary, in consultation with major private sector property owners, shall develop smart building accelerators to demonstrate innovative policies and approaches that will accelerate the transition to smart buildings in the public, institutional, and commercial buildings sectors.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0227e73-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17064/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0227e74-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17064/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2020-12-27"},"text":"December 27, 2020","children":[],"tail":", and every 2 years thereafter until a total of 3 reports have been made, the Secretary shall submit to the Committee on Energy and Natural Resources of the Senate and the Committee on Energy and Commerce and the Committee on Science, Space, and Technology of the House of Representatives a report on—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0227e75-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17064/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the establishment of the Federal Smart Building Program and the evaluation of Federal smart buildings under subsection (b);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0227e76-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17064/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the survey and evaluation of private sector smart buildings under subsection (c); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0227e77-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17064/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any recommendations of the Secretary to further accelerate the transition to smart buildings.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc0227e78-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dZ/tI/s1007"},"text":"Pub. L. 116–260, div. Z, title I, § 1007","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2433"},"text":"134 Stat. 2433","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc0227e79-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc0227e7a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idc0227e7b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s1007"},"text":"section 1007 of Pub. L. 116–260","children":[],"tail":". Subsec. (e) of "},{"tag":"ref","attrib":{"href":"/us/pl/160/260/s1007"},"text":"section 1007 of Pub. L. 160–260","children":[],"tail":" enacted "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s17086"},"text":"section 17086 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Energy Act of 2020, and not as part of the Energy Independence and Security Act of 2007 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
