{"tag":"section","attrib":{"id":"idb6267ef6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300g"},"text":null,"children":[{"tag":"num","attrib":{"value":"300g"},"text":"§ 300g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coverage","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Subject to sections 300g–4 and 300g–5 of this title, national primary drinking water regulations under this part shall apply to each public water system in each State; except that such regulations shall not apply to a public water system—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6267ef7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which consists only of distribution and storage facilities (and does not have any collection and treatment facilities);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6267ef8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which obtains all of its water from, but is not owned or operated by, a public water system to which such regulations apply;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6267ef9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which does not sell water to any person; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6267efa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300g/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which is not a carrier which conveys passengers in interstate commerce.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb6267efb-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XIV, § 1411, as added "},{"tag":"ref","attrib":{"href":"/us/pl/93/523/s2/a"},"text":"Pub. L. 93–523, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-12-16"},"text":"Dec. 16, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1662"},"text":"88 Stat. 1662","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
