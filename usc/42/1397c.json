{"tag":"section","attrib":{"id":"idbaa85d41-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397c"},"text":null,"children":[{"tag":"num","attrib":{"value":"1397c"},"text":"§ 1397c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State reporting requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Prior to expenditure by a State of payments made to it under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1397a"},"text":"section 1397a of this title","children":[],"tail":" for any fiscal year, the State shall report on the intended use of the payments the State is to receive under this division, including information on the types of activities to be supported and the categories or characteristics of individuals to be served. The report shall be transmitted to the Secretary and made public within the State in such manner as to facilitate comment by any person (including any Federal or other public agency) during development of the report and after its completion. The report shall be revised throughout the year as may be necessary to reflect substantial changes in the activities assisted under this division, and any revision shall be subject to the requirements of the previous sentence."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbaa85d42-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title XX, § 2004, as added "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tXXIII/s2352/a"},"text":"Pub. L. 97–35, title XXIII, § 2352(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/869"},"text":"95 Stat. 869","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tVI/s6703/d/1/B"},"text":"Pub. L. 111–148, title VI, § 6703(d)(1)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/803"},"text":"124 Stat. 803","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbaa85d43-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbaa85d44-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbaa85d45-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1397c, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531/tXX/s2004"},"text":"act Aug. 14, 1935, ch. 531, title XX, § 2004","children":[],"tail":", as added "},{"tag":"date","attrib":{"date":"1975-01-04"},"text":"Jan. 4, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/93/647/s2"},"text":"Pub. L. 93–647, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2346"},"text":"88 Stat. 2346","children":[],"tail":"; amended "},{"tag":"date","attrib":{"date":"1980-06-17"},"text":"June 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/96/272/tII/s206/a"},"text":"Pub. L. 96–272, title II, § 206(a)","children":[],"tail":", (b), "},{"tag":"ref","attrib":{"href":"/us/stat/94/525"},"text":"94 Stat. 525","children":[],"tail":", related to services program planning, prior to the general revision of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/s2352/a"},"text":"section 2352(a) of Pub. L. 97–35","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbaa85d46-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148"},"text":"Pub. L. 111–148","children":[],"tail":", which directed substitution of “this division” for “this subchapter” wherever appearing in subtitle 1 of title XX of act "},{"tag":"date","attrib":{"date":"1935-08-14"},"text":"Aug. 14, 1935","children":[],"tail":", was executed by making the substitution in two places in this section, which is in subtitle A of title XX act "},{"tag":"date","attrib":{"date":"1935-08-14"},"text":"Aug. 14, 1935","children":[],"tail":", to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
