{"tag":"section","attrib":{"id":"idbfee28d3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16014"},"text":null,"children":[{"tag":"num","attrib":{"value":"16014"},"text":"§ 16014.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standby support for certain nuclear plant delays","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfee28d4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16014/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfee28d5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16014/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advanced nuclear facility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “advanced nuclear facility” means any nuclear facility the reactor design for which is approved after ","children":[{"tag":"date","attrib":{"date":"1993-12-31"},"text":"December 31, 1993","children":[],"tail":", by the Commission (and such design or a substantially similar design of comparable capacity was not approved on or before that date)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfee28d6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16014/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Combined license","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “combined license” means a combined construction and operating license for an advanced nuclear facility issued by the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfee28d7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16014/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Commission” means the Nuclear Regulatory Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfee28d8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16014/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sponsor","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “sponsor” means a person who has applied for or been granted a combined license.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfee28d9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16014/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contract authority","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfee28da-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16014/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may enter into contracts under this section with sponsors of an advanced nuclear facility that cover a total of 6 reactors, with the 6 reactors consisting of not more than 3 different reactor designs, in accordance with paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfee28db-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16014/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement for contracts","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfee28dc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16014/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of loan cost","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this paragraph, the term “loan cost” has the meaning given the term “cost of a loan guarantee” under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s661a/5/C"},"text":"section 661a(5)(C) of title 2","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfee28dd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16014/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of accounts","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is established in the Department 2 separate accounts, which shall be known as the—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbfee28de-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16014/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Standby Support Program Account”; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbfee28df-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16014/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Standby Support Grant Account”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfee28e0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16014/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall not enter into a contract under this section unless the Secretary deposits—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbfee28e1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16014/b/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the Standby Support Program Account established under subparagraph (B), funds appropriated to the Secretary in advance of the contract or a combination of appropriated funds and loan guarantee fees that are in an amount sufficient to cover the loan costs described in subsection (d)(5)(A); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbfee28e2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16014/b/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the Standby Support Grant Account established under subparagraph (B), funds appropriated to the Secretary in advance of the contract, paid to the Secretary by the sponsor of the advanced nuclear facility, or a combination of appropriations and payments that are in an amount sufficient ","children":[{"tag":"ref","attrib":{"idref":"fn004201"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004201"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be followed by “to”."}],"tail":" cover the costs described in subparagraphs (B), (C), and (D) of subsection (d)(5)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfee28e3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16014/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered delays","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfee28e4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16014/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Under each contract authorized by this section, the Secretary shall pay the costs specified in subsection (d), using funds appropriated or collected for the covered costs, if full power operation of the advanced nuclear facility is delayed by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfee28e5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16014/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the failure of the Commission to comply with schedules for review and approval of inspections, tests, analyses, and acceptance criteria established under the combined license or the conduct of preoperational hearings by the Commission for the advanced nuclear facility; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfee28e6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16014/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" litigation that delays the commencement of full-power operations of the advanced nuclear facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfee28e7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16014/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may not enter into any contract under this section that would obligate the Secretary to pay any costs resulting from—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfee28e8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16014/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the failure of the sponsor to take any action required by law or regulation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfee28e9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16014/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" events within the control of the sponsor; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfee28ea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16014/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" normal business risks.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfee28eb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16014/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered costs","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfee28ec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16014/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraphs (2), (3), and (4), the costs that shall be paid by the Secretary pursuant to a contract entered into under this section are the costs that result from a delay covered by the contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfee28ed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16014/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial 2 reactors","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of the first 2 reactors that receive combined licenses and on which construction is commenced, the Secretary shall pay—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfee28ee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16014/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 100 percent of the covered costs of delay; but","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfee28ef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16014/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not more than $500,000,000 per contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfee28f0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16014/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subsequent 4 reactors","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of the next 4 reactors that receive a combined license and on which construction is commenced, the Secretary shall pay—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfee28f1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16014/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 50 percent of the covered costs of delay that occur after the initial 180-day period of covered delay; but","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfee28f2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16014/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not more than $250,000,000 per contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfee28f3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16014/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conditions on payment of certain covered costs","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfee28f4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16014/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The obligation of the Secretary to pay the covered costs described in subparagraph (B) of paragraph (5) is subject to the Secretary receiving from appropriations or payments from other non-Federal sources amounts sufficient to pay the covered costs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfee28f5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16014/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-Federal sources","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may receive and accept payments from any non-Federal source, which shall be made available without further appropriation for the payment of the covered costs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfee28f6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16014/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Types of covered costs","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to paragraphs (2), (3), and (4), the contract entered into under this section for an advanced nuclear facility shall include as covered costs those costs that result from a delay during construction and in gaining approval for fuel loading and full-power operation, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfee28f7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16014/d/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" principal or interest on any debt obligation of an advanced nuclear facility owned by a non-Federal entity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfee28f8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16014/d/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the incremental difference between—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbfee28f9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16014/d/5/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the fair market price of power purchased to meet the contractual supply agreements that would have been met by the advanced nuclear facility but for the delay; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbfee28fa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16014/d/5/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the contractual price of power from the advanced nuclear facility subject to the delay.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfee28fb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16014/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any contract between a sponsor and the Secretary covering an advanced nuclear facility under this section shall require the sponsor to use due diligence to shorten, and to end, the delay covered by the contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfee28fc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16014/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For each advanced nuclear facility that is covered by a contract under this section, the Commission shall submit to Congress and the Secretary quarterly reports summarizing the status of licensing actions associated with the advanced nuclear facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfee28fd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16014/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfee28fe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16014/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraphs (2) and (3), the Secretary shall issue such regulations as are necessary to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfee28ff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16014/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interim final rulemaking","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 270 days after ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":", the Secretary shall issue for public comment an interim final rule regulating contracts authorized by this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfee2900-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16014/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice of final rulemaking","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":", the Secretary shall issue a notice of final rulemaking regulating the contracts."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfee2901-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16014/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums as are necessary to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfee2902-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tVI/s638"},"text":"Pub. L. 109–58, title VI, § 638","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/791"},"text":"119 Stat. 791","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
