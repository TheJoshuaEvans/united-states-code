{"tag":"section","attrib":{"id":"idbd120aab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5165d"},"text":null,"children":[{"tag":"num","attrib":{"value":"5165d"},"text":"§ 5165d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation of Small State and Rural Advocate","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd120aac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5165d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall designate in the Federal Emergency Management Agency a Small State and Rural Advocate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd120aad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5165d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Small State and Rural Advocate shall be an advocate for the fair treatment of small States and rural communities in the provision of assistance under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd120aae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5165d/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Small State and Rural Advocate shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd120aaf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5165d/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" participate in the disaster declaration process under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5170"},"text":"section 5170 of this title","children":[],"tail":" and the emergency declaration process under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5191"},"text":"section 5191 of this title","children":[],"tail":", to ensure that the needs of rural communities are being addressed;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd120ab0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5165d/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist small population States in the preparation of requests for major disaster or emergency declarations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd120ab1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5165d/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" assist States in the collection and presentation of material in the disaster or emergency declaration request relevant to demonstrate severe localized impacts within the State for a specific incident, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd120ab2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5165d/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the per capita personal income by local area, as calculated by the Bureau of Economic Analysis;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd120ab3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5165d/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the disaster impacted population profile, as reported by the Bureau of the Census, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbd120ab4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5165d/c/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the percentage of the population for whom poverty status is determined;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd120ab5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5165d/c/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the percentage of the population already receiving Government assistance such as Supplemental Security Income and Supplemental Nutrition Assistance Program benefits;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd120ab6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5165d/c/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the pre-disaster unemployment rate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd120ab7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5165d/c/3/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the percentage of the population that is 65 years old and older;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd120ab8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5165d/c/3/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the percentage of the population 18 years old and younger;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd120ab9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5165d/c/3/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the percentage of the population with a disability;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd120aba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5165d/c/3/B/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the percentage of the population who speak a language other than English and speak English less than “very well”; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd120abb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5165d/c/3/B/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any unique considerations regarding American Indian and Alaskan Native Tribal populations raised in the State’s request for a major disaster declaration that may not be reflected in the data points referenced in this subparagraph;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd120abc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5165d/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the impact to community infrastructure, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbd120abd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5165d/c/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disruptions to community life-saving and life-sustaining services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd120abe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5165d/c/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disruptions or increased demand for essential community services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd120abf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5165d/c/3/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disruptions to transportation, infrastructure, and utilities; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd120ac0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5165d/c/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other information relevant to demonstrate severe local impacts; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd120ac1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5165d/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct such other activities as the Administrator of the Federal Emergency Management Agency considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd120ac2-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/288/tIII/s326"},"text":"Pub. L. 93–288, title III, § 326","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/295/tVI/s689g/a"},"text":"Pub. L. 109–295, title VI, § 689g(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-04"},"text":"Oct. 4, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1453"},"text":"120 Stat. 1453","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/351/s3/c/2"},"text":"Pub. L. 111–351, § 3(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3864"},"text":"124 Stat. 3864","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dE/tLVI/s5601/a"},"text":"Pub. L. 117–263, div. E, title LVI, § 5601(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3402"},"text":"136 Stat. 3402","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd120ac3-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd120ac4-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbd120ac5-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (b), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/288"},"text":"Pub. L. 93–288","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-05-22"},"text":"May 22, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/143"},"text":"88 Stat. 143","children":[],"tail":". For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5121"},"text":"section 5121 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd120ac6-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (c)(3), (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":" added par. (3) and redesignated former par. (3) as (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/351"},"text":"Pub. L. 111–351","children":[],"tail":" substituted “Administrator” for “Director”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbd120ac7-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbd120ac8-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Construction","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/295/tVI/s689g/c"},"text":"Pub. L. 109–295, title VI, § 689g(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-04"},"text":"Oct. 4, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1453"},"text":"120 Stat. 1453","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/295/tVI/s689g/c"},"text":"“Nothing in this section [enacting this section] or the amendments made by this section shall be construed to authorize major disaster or emergency assistance that is not authorized as of the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2006-10-04"},"text":"Oct. 4, 2006","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
