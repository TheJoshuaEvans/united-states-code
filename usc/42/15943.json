{"tag":"section","attrib":{"id":"idbfebb69d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15943"},"text":null,"children":[{"tag":"num","attrib":{"value":"15943"},"text":"§ 15943.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain gathering lines located on Federal land and Indian land","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfebb69e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15943/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfebb69f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15943/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal land","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfebb6a0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15943/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Federal land” means land the title to which is held by the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfebb6a1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15943/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Federal land” does not include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbfebb6a2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15943/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a unit of the National Park System;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbfebb6a3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15943/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a unit of the National Wildlife Refuge System;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbfebb6a4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15943/a/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a component of the National Wilderness Preservation System;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbfebb6a5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15943/a/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a wilderness study area within the National Forest System; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbfebb6a6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15943/a/1/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Indian land.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfebb6a7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15943/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Gathering line and associated field compression or pumping unit","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfebb6a8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15943/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “gathering line and associated field compression or pumping unit” means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbfebb6a9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15943/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a pipeline that is installed to transport oil, natural gas and related constituents, or produced water from 1 or more wells drilled and completed to produce oil or gas; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbfebb6aa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15943/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if necessary, 1 or more compressors or pumps to raise the pressure of the transported oil, natural gas and related constituents, or produced water to higher pressures necessary to enable the oil, natural gas and related constituents, or produced water to flow into pipelines and other facilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfebb6ab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15943/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “gathering line and associated field compression or pumping unit” includes a pipeline or associated compression or pumping unit that is installed to transport oil or natural gas from a processing plant to a common carrier pipeline or facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfebb6ac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15943/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “gathering line and associated field compression or pumping unit” does not include a common carrier pipeline.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfebb6ad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15943/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian land","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Indian land” means land the title to which is held by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfebb6ae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15943/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States in trust for an Indian Tribe or an individual Indian; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfebb6af-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15943/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an Indian Tribe or an individual Indian subject to a restriction by the United States against alienation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfebb6b0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15943/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Produced water","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “produced water” means water produced from an oil or gas well bore that is not a fluid prepared at, or transported to, the well site to resolve a specific oil or gas well bore or reservoir condition.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfebb6b1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15943/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of the Interior.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfebb6b2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15943/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain gathering lines","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfebb6b3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15943/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to paragraph (2), the issuance of a sundry notice or right-of-way for a gathering line and associated field compression or pumping unit that is located on Federal land or Indian land and that services any oil or gas well may be considered by the Secretary to be an action that is categorically excluded (as defined in section 1508.1 of title 40, Code of Federal Regulations (as in effect on ","children":[{"tag":"date","attrib":{"date":"2021-11-15"},"text":"November 15, 2021","children":[],"tail":")) for purposes of the National Environmental Policy Act of 1969 ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"42 U.S.C. 4321","children":[],"tail":" et seq.) if the gathering line and associated field compression or pumping unit—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfebb6b4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15943/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are within a field or unit for which an approved land use plan or an environmental document prepared pursuant to the National Environmental Policy Act of 1969 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"42 U.S.C. 4321","children":[],"tail":" et seq.) analyzed transportation of oil, natural gas, or produced water from 1 or more oil or gas wells in the field or unit as a reasonably foreseeable activity;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfebb6b5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15943/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" are located adjacent to or within—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbfebb6b6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15943/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any existing disturbed area; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbfebb6b7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15943/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an existing corridor for a right-of-way; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfebb6b8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15943/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" would reduce—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbfebb6b9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15943/b/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a gathering line and associated field compression or pumping unit transporting methane, the total quantity of methane that would otherwise be vented, flared, or unintentionally emitted from the field or unit; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbfebb6ba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15943/b/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a gathering line and associated field compression or pumping unit not transporting methane, the vehicular traffic that would otherwise service the field or unit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfebb6bb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15943/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Paragraph (1) shall apply to Indian land, or a portion of Indian land—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfebb6bc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15943/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to which the National Environmental Policy Act of 1969 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"42 U.S.C. 4321","children":[],"tail":" et seq.) applies; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfebb6bd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15943/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for which the Indian Tribe with jurisdiction over the Indian land submits to the Secretary a written request that paragraph (1) apply to that Indian land (or portion of Indian land).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfebb6be-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15943/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect on other law","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfebb6bf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15943/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" affects or alters any requirement—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfebb6c0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15943/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" relating to prior consent under—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbfebb6c1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15943/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s324"},"text":"section 324 of title 25","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbfebb6c2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15943/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5123/e"},"text":"section 5123(e) of title 25","children":[],"tail":" (commonly known as the “Indian Reorganization Act” "},{"tag":"ref","attrib":{"idref":"fn004199"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004199"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":");"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfebb6c3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15943/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t54/s306108"},"text":"section 306108 of title 54","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfebb6c4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15943/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under any other Federal law (including regulations) relating to Tribal consent for rights-of-way across Indian land; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfebb6c5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15943/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" makes the National Environmental Policy Act of 1969 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"42 U.S.C. 4321","children":[],"tail":" et seq.) applicable to land to which that Act otherwise would not apply."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfebb6c6-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dA/tI/s11318"},"text":"Pub. L. 117–58, div. A, title I, § 11318","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/543"},"text":"135 Stat. 543","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbfebb6c7-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbfebb6c8-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbfebb6c9-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The National Environmental Policy Act of 1969, referred to in subsecs. (b)(1), (2)(A) and (c)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/190"},"text":"Pub. L. 91–190","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-01-01"},"text":"Jan. 1, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/852"},"text":"83 Stat. 852","children":[],"tail":", which is classified generally to chapter 55 (§ 4321 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"section 4321 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Indian Reorganization Act, referred to in subsec. (c)(1)(A)(ii), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-18/ch576"},"text":"act June 18, 1934, ch. 576","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/984"},"text":"48 Stat. 984","children":[],"tail":", which is classified generally to chapter 45 (§ 5101 et seq.) of Title 25, Indians. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5101"},"text":"section 5101 of Title 25","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbfebb6ca-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Surface Transportation Reauthorization Act of 2021, and also as part of the Infrastructure Investment and Jobs Act, and not as part of the Energy Policy Act of 2005 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbfebb6cb-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbfebb6cc-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2021-10-01"},"text":"Oct. 1, 2021","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/s10003"},"text":"section 10003 of Pub. L. 117–58","children":[],"tail":", set out as an Effective Date of 2021 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t23/s101"},"text":"section 101 of Title 23","children":[],"tail":", Highways."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
