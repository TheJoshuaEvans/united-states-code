{"tag":"section","attrib":{"id":"idb5786428-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285m–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"285m–2"},"text":"§ 285m–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data System and Information Clearinghouse","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5786429-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285m–2/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of the Institute shall establish a National Deafness and Other Communication Disorders Data System for the collection, storage, analysis, retrieval, and dissemination of data derived from patient populations with disorders of hearing or other communication processes, including where possible, data involving general populations for the purpose of identifying individuals at risk of developing such disorders.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb578642a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285m–2/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of the Institute shall establish a National Deafness and Other Communication Disorders Information Clearinghouse to facilitate and enhance, through the effective dissemination of information, knowledge and understanding of disorders of hearing and other communication processes by health professionals, patients, industry, and the public.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb578642b-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title IV, § 464B, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/553/s2/4"},"text":"Pub. L. 100–553, § 2(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-28"},"text":"Oct. 28, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2770"},"text":"102 Stat. 2770","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/100/607/tI/s101/4"},"text":"Pub. L. 100–607, title I, § 101(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-04"},"text":"Nov. 4, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3050"},"text":"102 Stat. 3050","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tII/s2613/b/2"},"text":"Pub. L. 100–690, title II, § 2613(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4238"},"text":"102 Stat. 4238","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb578642c-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb578642d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb578642e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/553"},"text":"Pub. L. 100–553","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/100/607"},"text":"Pub. L. 100–607","children":[],"tail":" contained identical provisions enacting this section. See 1988 Amendment note below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb578642f-3a70-11f1-ae07-e4213316b5fa"},"text":n