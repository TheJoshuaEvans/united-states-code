{"tag":"section","attrib":{"id":"idb615dc6e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–15"},"text":null,"children":[{"tag":"num","attrib":{"value":"300d–15"},"text":"§ 300d–15.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restrictions on use of payments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb615dc6f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–15/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may not, except as provided in subsection (b), make payments under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300d–11/a"},"text":"section 300d–11(a) of this title","children":[],"tail":" for a fiscal year unless the State involved agrees that the payments will not be expended—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb615dc70-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–15/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for any purpose other than developing, implementing, and monitoring the modifications required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300d–11/b"},"text":"section 300d–11(b) of this title","children":[],"tail":" to be made to the State plan for the provision of emergency medical services;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb615dc71-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–15/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to make cash payments to intended recipients of services provided pursuant to this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb615dc72-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–15/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to purchase or improve real property (other than minor remodeling of existing improvements to real property);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb615dc73-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–15/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to satisfy any requirement for the expenditure of non-Federal funds as a condition for the receipt of Federal funds; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb615dc74-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–15/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide financial assistance to any entity other than a public or nonprofit private entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb615dc75-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–15/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may waive a restriction under subsection (a) only if the Secretary determines that the activities outlined by the State plan submitted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300d–14/a"},"text":"section 300d–14(a) of this title","children":[],"tail":" by the State involved cannot otherwise be carried out."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb615dc76-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XII, § 1215, as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/590/s3"},"text":"Pub. L. 101–590, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2923"},"text":"104 Stat. 2923","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/23/s9"},"text":"Pub. L. 110–23, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-05-03"},"text":"May 3, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/97"},"text":"121 Stat. 97","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb615dc77-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb615dc78-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb615dc79-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2007—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/23"},"text":"Pub. L. 110–23","children":[],"tail":" amended section generally. Prior to amendment, section related to restrictions on use of payments."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
