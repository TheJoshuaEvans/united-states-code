{"tag":"section","attrib":{"id":"idbf091e9f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9912"},"text":null,"children":[{"tag":"num","attrib":{"value":"9912"},"text":"§ 9912.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of Community Services","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf091ea0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9912/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall carry out the functions of this chapter through an Office of Community Services, which shall be established in the Department of Health and Human Services. The Office shall be headed by a Director.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf091ea1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9912/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants, contracts, and cooperative agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall carry out functions of this chapter through grants, contracts, or cooperative agreements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf091ea2-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35/tVI/s678"},"text":"Pub. L. 97–35, title VI, § 678","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/285/tII/s201"},"text":"Pub. L. 105–285, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-27"},"text":"Oct. 27, 1998","children":[],"tail":", "},{"tag":"ref","attrib