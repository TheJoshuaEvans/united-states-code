{"tag":"section","attrib":{"id":"idb54b1341-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280l–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"280l–3"},"text":"§ 280l–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition of Federal workplace wellness requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of this part, any recommendations, data, or assessments carried out under this part shall not be used to mandate requirements for workplace wellness programs.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb54d8342-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title III, § 399MM–3, as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tIV/s4303"},"text":"Pub. L. 111–148, title IV, § 4303","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/583"},"text":"124 Stat. 583","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
