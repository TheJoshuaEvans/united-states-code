{"tag":"section","attrib":{"id":"idb6136b7b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d"},"text":null,"children":[{"tag":"num","attrib":{"value":"300d"},"text":"§ 300d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb6136b7c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall, with respect to trauma care—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6136b7d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct and support research, training, evaluations, and demonstration projects;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6136b7e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" foster the development of appropriate, modern systems of such care through the sharing of information among agencies and individuals involved in the study and provision of such care;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6136b7f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collect, compile, analyze, and disseminate information on the achievements of, and problems experienced by, State and local agencies and private entities in providing trauma care and emergency medical services and, in so doing, give special consideration to the unique needs of rural areas and medically underserved areas;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6136b80-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide to State and local agencies technical assistance to enhance each State’s capability to develop, implement, and sustain the trauma care component of each State’s plan for the provision of emergency medical services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6136b81-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote the collection and categorization of trauma data in a consistent and standardized manner.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6136b82-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Trauma care readiness and coordination","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, acting through the Assistant Secretary for Preparedness and Response, shall support the efforts of States and consortia of States to coordinate and improve emergency medical services and trauma care during a public health emergency declared by the Secretary pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s247d"},"text":"section 247d of this title","children":[],"tail":" or a major disaster or emergency declared by the President under section 5170 or 5191, respectively, of this title. Such support may include—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6136b83-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing, issuing, and updating guidance, as appropriate, to support the coordinated medical triage and evacuation to appropriate medical institutions based on patient medical need, taking into account regionalized systems of care;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6136b84-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disseminating, as appropriate, information on evidence-based or evidence-informed trauma care practices, taking into consideration emergency medical services and trauma care systems, including such practices identified through activities conducted under subsection (a) and which may include the identification and dissemination of performance metrics, as applicable and appropriate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6136b85-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other activities, as appropriate, to optimize a coordinated and flexible approach to the emergency response and medical surge capacity of hospitals, other health care facilities, critical care, and emergency medical systems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6136b86-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants, cooperative agreements, and contracts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may make grants, and enter into cooperative agreements and contracts, for the purpose of carrying out subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb6136b87-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XII, § 1201, as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/590/s3"},"text":"Pub. L. 101–590, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2916"},"text":"104 Stat. 2916","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/183/tVI/s601/a"},"text":"Pub. L. 103–183, title VI, § 601(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-14"},"text":"Dec. 14, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2238"},"text":"107 Stat. 2238","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/146/s12/b"},"text":"Pub. L. 104–146, § 12(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-05-20"},"text":"May 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1373"},"text":"110 Stat. 1373","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/23/s2"},"text":"Pub. L. 110–23, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-05-03"},"text":"May 3, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/90"},"text":"121 Stat. 90","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dFF/tII/s2113/a"},"text":"Pub. L. 117–328, div. FF, title II, § 2113(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5722"},"text":"136 Stat. 5722","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb6136b88-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb6136b89-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb6136b8a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 300d, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373/tXII/s1201"},"text":"act July 1, 1944, ch. 373, title XII, § 1201","children":[],"tail":", as added "},{"tag":"date","attrib":{"date":"1973-11-16"},"text":"Nov. 16, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/93/154/s2/a"},"text":"Pub. L. 93–154, § 2(a)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/594"},"text":"87 Stat. 594","children":[],"tail":"; amended "},{"tag":"date","attrib":{"date":"1976-10-12"},"text":"Oct. 12, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/94/484/tIX/s905/b/1"},"text":"Pub. L. 94–484, title IX, § 905(b)(1)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2325"},"text":"90 Stat. 2325","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/94/573"},"text":"Pub. L. 94–573","children":[],"tail":", §§ 2, 14(2), "},{"tag":"ref","attrib":{"href":"/us/stat/90/2709"},"text":"90 Stat. 2709","children":[],"tail":", 2718, defined terms applicable to this subchapter, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tIX/s902/d/1"},"text":"Pub. L. 97–35, title IX, § 902(d)(1)","children":[],"tail":", (h), "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/560"},"text":"95 Stat. 560","children":[],"tail":", 561, effective "},{"tag":"date","attrib":{"date":"1981-10-01"},"text":"Oct. 1, 1981","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior section 1201 of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373/tXII"},"text":"act July 1, 1944, ch. 373, title XII","children":[],"tail":", formerly § 1205, as added "},{"tag":"date","attrib":{"date":"1973-11-16"},"text":"Nov. 16, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/93/154/s2/a"},"text":"Pub. L. 93–154, § 2(a)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/597"},"text":"87 Stat. 597","children":[],"tail":", was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300d–4"},"text":"section 300d–4 of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/99/117/s12/e"},"text":"Pub. L. 99–117, § 12(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-10-07"},"text":"Oct. 7, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/495"},"text":"99 Stat. 495","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb6136b8b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s2113/a/1/A"},"text":"Pub. L. 117–328, § 2113(a)(1)(A)","children":[],"tail":", inserted “analyze,” after “compile,” and “and medically underserved areas” after “rural areas”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(5), (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s2113/a/1/B"},"text":"Pub. L. 117–328, § 2113(a)(1)(B)","children":[],"tail":"–(D), redesignated par. (6) as (5) and struck out former par. (5) which read as follows: “sponsor workshops and conferences; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s2113/a/2"},"text":"Pub. L. 117–328, § 2113(a)(2)","children":[],"tail":", (3), added subsec. (b) and redesignated former subsec. (b) as (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2007—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/23"},"text":"Pub. L. 110–23","children":[],"tail":" amended section generally. Prior to amendment, section required the Secretary to provide support to trauma care, authorized the Secretary to make grants and enter into agreements for such support, and required the Administrator of the Health Resources and Services Administration to ensure that the Division of Trauma and Emergency Medical Systems administered this subchapter."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/146"},"text":"Pub. L. 104–146","children":[],"tail":", in introductory provisions, substituted “The Secretary shall,” for “The Secretary, acting through the Administrator of the Health Resources and Services Administration, shall,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/183/s601/a/1"},"text":"Pub. L. 103–183, § 601(a)(1)","children":[],"tail":", in introductory provisions inserted “, acting through the Administrator of the Health Resources and Services Administration,” after “Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/183/s601/a/2"},"text":"Pub. L. 103–183, § 601(a)(2)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb6136b8c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb6136b8d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/146"},"text":"Pub. L. 104–146","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1996-10-01"},"text":"Oct. 1, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/146/s13"},"text":"section 13 of Pub. L. 104–146","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–11"},"text":"section 300ff–11 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb6136b8e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Congressional Statement of Findings","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/590/s2"},"text":"Pub. L. 101–590, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2915"},"text":"104 Stat. 2915","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/590/s2"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The Congress finds that—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Government and the governments of the States have established a history of cooperation in the development, implementation, and monitoring of integrated, comprehensive systems for the provision of emergency medical services throughout the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" physical trauma is the leading cause of death of Americans between the ages of 1 and 44 and is the third leading cause of death in the general population of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" physical trauma in the United States results in an aggregate annual cost of $180,000,000,000 in medical expenses, insurance, lost wages, and property damage;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" barriers to the provision of prompt and appropriate emergency medical services exist in many areas of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" few States and communities have developed and implemented trauma care systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"“(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" many trauma centers have incurred substantial uncompensated costs in providing trauma care, and such costs have caused many such centers to cease participation in trauma care systems; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"“(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of incidents of physical trauma in the United States is a serious medical and social problem, and the number of deaths resulting from such incidents can be substantially reduced by improving the trauma-care components of the systems for the provision of emergency medical services in the United States.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
