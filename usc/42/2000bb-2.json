ans religious exercise, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2000cc–5"},"text":"section 2000cc–5 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbbc69ed4-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/141/s5"},"text":"Pub. L. 103–141, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-11-16"},"text":"Nov. 16, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1489"},"text":"107 Stat. 1489","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/274/s7/a"},"text":"Pub. L. 106–274, § 7(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-09-22"},"text":"Sept. 22, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/806"},"text":"114 Stat. 806","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbbc69ed5-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbbc69ed6-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbbc69ed7-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/141"},"text":"Pub. L. 103–141","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-11-16"},"text":"Nov. 16, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1488"},"text":"107 Stat. 1488","children":[],"tail":", which is classified principally to thi