{"tag":"section","attrib":{"id":"idbf5a4ca1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12001"},"text":null,"children":[{"tag":"num","attrib":{"value":"12001"},"text":"§ 12001.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Finding, purpose, and general authority","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf5a4ca2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12001/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Finding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Congress finds that it is in the national security and economic interest of the United States to foster greater efficiency in the use of available energy supplies and greater use of renewable energy technologies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf5a4ca3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12001/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is the purpose of this chapter to authorize the Secretary of Energy, acting in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s13541"},"text":"section 13541 of this title","children":[],"tail":", to pursue an aggressive national program of research, development, demonstration, and commercial application of renewable energy and energy efficiency technologies in order to ensure a stable and secure future energy supply by—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf5c9594-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12001/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" achieving as soon as practicable cost competitive use of those technologies without need of Federal financial incentives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf5c9595-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12001/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing long-term Federal research goals and multiyear funding levels;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf5c9596-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12001/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" directing the Secretary to undertake initiatives to improve the ability of the private sector to commercialize in the near term renewable energy and energy efficiency technologies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf5c9597-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12001/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fostering collaborative efforts involving the private sector through government support of a program of demonstration and commercial application projects.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf5c9598-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12001/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General authority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, acting in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s13541"},"text":"section 13541 of this title","children":[],"tail":", is authorized and directed to—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf5c9599-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12001/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pursue a program of research, development, demonstration, and commercial application with the private sector, to achieve the purpose of this chapter, including the goals established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12003"},"text":"section 12003 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf5c959a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12001/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" undertake demonstration and commercial application projects as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12005"},"text":"section 12005 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf5c959b-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/218/s2"},"text":"Pub. L. 101–218, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-11"},"text":"Dec. 11, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1859"},"text":"103 Stat. 1859","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/486/tXII/s1202/d/1"},"text":"Pub. L. 102–486, title XII, § 1202(d)(1)","children":[],"tail":"–(3), "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2959"},"text":"106 Stat. 2959","children":[],"tail":", 2960.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf5c959c-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf5c959d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbf5c959e-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsecs. (b) and (c)(1), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/218"},"text":"Pub. L. 101–218","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-11"},"text":"Dec. 11, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1859"},"text":"103 Stat. 1859","children":[],"tail":", which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note below and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbf5c959f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/s1202/d/1"},"text":"Pub. L. 102–486, § 1202(d)(1)","children":[],"tail":", substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t42/s13541"},"text":"section 13541 of this title","children":[],"tail":"” for “authority contained in the Federal Nonnuclear Energy Research and Development Act of 1974 ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5901–592"},"text":"42 U.S.C. 5901–592","children":[],"tail":"0) and other law applicable to the Secretary” and “demonstration, and commercial application” for “and demonstration”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/s1202/d/2"},"text":"Pub. L. 102–486, § 1202(d)(2)","children":[],"tail":", substituted “efforts” for “research and development efforts” and “demonstration and commercial application projects” for “joint ventures”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/s1202/d/3"},"text":"Pub. L. 102–486, § 1202(d)(3)","children":[],"tail":", substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t42/s13541"},"text":"section 13541 of this title","children":[],"tail":", is authorized and directed to—” and pars. (1) and (2) for “the authority contained in the Federal Nonnuclear Energy Research and Development Act of 1974 ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5901–592"},"text":"42 U.S.C. 5901–592","children":[],"tail":"0) and other law applicable to the Secretary—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) is authorized and directed to—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) pursue a program of research, development, and demonstration, including the use of joint ventures with the private sector, to achieve the purpose of this chapter, including the goals established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12003"},"text":"section 12003 of this title","children":[],"tail":"; and"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) undertake joint ventures as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12005"},"text":"section 12005 of this title","children":[],"tail":"; and"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) is authorized to undertake, from time to time, joint ventures in technology areas other than those set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12005/c"},"text":"section 12005(c) of this title","children":[],"tail":", subject to the conditions set forth in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12005/b"},"text":"section 12005(b) of this title","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbf5c95a0-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"idbf5c95a1-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/218/s1"},"text":"Pub. L. 101–218, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-11"},"text":"Dec. 11, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1859"},"text":"103 Stat. 1859","children":[],"tail":", provided: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/218/s1"},"text":"“That this Act [enacting this chapter and amending sections 6276 and 8243 of this title, ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2857"},"text":"section 2857 of Title 10","children":[],"tail":", Armed Forces, and "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2194"},"text":"section 2194 of Title 22","children":[],"tail":", Foreign Relations and Intercourse] may be referred to as the ‘Renewable Energy and Energy Efficiency Technology Competitiveness Act of 1989’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
