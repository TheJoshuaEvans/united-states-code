{"tag":"section","attrib":{"id":"idbfa1b560-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12802"},"text":null,"children":[{"tag":"num","attrib":{"value":"12802"},"text":"§ 12802.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rental housing production","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfa1b561-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12802/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repayable advances","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfa1b562-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12802/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall make available a model program under which repayable advances may be made to public and private project sponsors in constructing, acquiring, or substantially rehabilitating projects to be used as affordable rental housing, including limited equity cooperatives and mutual housing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfa1b563-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12802/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum amount of advance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An advance under this model program shall not exceed 50 percent of the total costs associated with the construction, acquisition, or substantial rehabilitation of the project, as determined by the participating jurisdiction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfa1b564-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12802/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms of repayment","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfa1b565-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12802/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interest payments","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbfa1b566-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12802/a/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Under the model program, advances shall be repaid with interest calculated at a rate of not more than 3 percent per year, as determined by the participating jurisdiction to be appropriate. Interest shall begin to accrue 1 year after the completion of the construction, acquisition, or substantial rehabilitation of the project and shall be payable in annual installments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbfa1b567-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12802/a/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Interest and any accrued interest shall be payable only from the surplus cash flow of the project, after a minimum return on equity determined by the participating jurisdiction to be appropriate. As used in the previous sentence, the term “surplus cash flow” means the cash flow of the project after the payment of all amounts due under the first mortgage, operating expenses, and required replacement reserves, as determined by the participating jurisdiction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfa1b568-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12802/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional interest payments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Under the model program, for any year in which the sum of the surplus cash flow of a project and the return on equity exceeds all interest payments due under subparagraph (A), 50 percent of the excess surplus cash flow shall be paid to the participating jurisdiction’s HOME Investment Trust Fund as additional interest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfa1b569-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12802/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Principal and unpaid interest","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The principal amount of an advance under the model program, and any interest remaining unpaid pursuant to subparagraph (A)(ii) shall be repayable when the housing no longer qualifies as affordable housing in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12749/b"},"text":"section 12749(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfa1b56a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12802/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection guidelines","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfa1b56b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12802/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish guidelines for the selection of projects by participating jurisdictions for assistance under the model program. Such guidelines shall be designed to select projects in areas and for markets demonstrating the greatest need for the production of affordable rental housing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfa1b56c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12802/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specific requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The selection guidelines may include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfa1b56d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12802/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent of the shortage of rental housing in the area that is available to low-income families;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfa1b56e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12802/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent large families with children will be served by the project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfa1b56f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12802/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which the project provides congregate facilities and has available supportive services that will permit elderly or handicapped residents who become frail and are in need of assistance in living to continue to reside in the project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfa1b570-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12802/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent of very low-income and low-income occupancy in excess of the income targeting requirements in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12744"},"text":"section 12744 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfa1b571-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12802/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent of the project sponsor’s commitment of equity to the project (except that this criterion shall not apply to or affect the selection of applications submitted by public housing agencies and nonprofit entities);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfa1b572-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12802/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent of the project sponsor’s commitment of equity to the project in comparison to the value of all public assistance for the project, including assistance under this subchapter, other Federal assistance and financing, and State and local government contributions (except that this criterion shall not apply to or affect the selection of applications submitted by public housing agencies and nonprofit entities);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfa1b573-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12802/b/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent of non-Federal public or private assistance to the project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfa1b574-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12802/b/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which the project provides supportive services for persons with disabilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfa1b575-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12802/b/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other factor determined by the Secretary to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfa1b576-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12802/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guidelines","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall publish guidelines for the model program under this section not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"1990-11-28"},"text":"November 28, 1990","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfa1b577-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/625/tII/s252"},"text":"Pub. L. 101–625, title II, § 252","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4119"},"text":"104 Stat. 4119","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
