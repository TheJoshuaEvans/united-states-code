{"tag":"section","attrib":{"id":"idb6836bd5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–14"},"text":null,"children":[{"tag":"num","attrib":{"value":"300cc–14"},"text":"§ 300cc–14.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation of certain treatments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb6836bd6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–14/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6836bd7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–14/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" After consultation with the AIDS Research Advisory Committee established pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300cc–3"},"text":"section 300cc–3 of this title","children":[],"tail":", the Secretary shall establish a program for the evaluation of drugs that—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6836bd8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–14/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are not approved by the Commissioner of Food and Drugs for the purpose of treatments with respect to acquired immune deficiency syndrome; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6836bd9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–14/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are being utilized for such purpose by individuals infected with the etiologic agent for such syndrome.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6836bda-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–14/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The program established under paragraph (1) shall include evaluations of the effectiveness and the risks of the treatment involved, including the risks of foregoing treatments with respect to acquired immune deficiency syndrome that are approved by the Commissioner of Food and Drugs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6836bdb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–14/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority with respect to grants and contracts","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6836bdc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–14/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purpose of conducting evaluations required in subsection (a), the Secretary may make grants to, and enter into cooperative agreements and contracts with, public and nonprofit private entities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6836bdd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–14/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Nonprofit private entities under paragraph (1) may include nonprofit private organizations that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6836bde-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–14/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are established for the purpose of evaluating treatments with respect to acquired immune deficiency syndrome; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6836bdf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–14/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consist primarily of individuals infected with the etiologic agent for such syndrome.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6836be0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–14/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scientific and ethical guidelines","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6836be1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–14/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall establish appropriate scientific and ethical guidelines for the conduct of evaluations carried out pursuant to this section. The Secretary may not provide financial assistance under subsection (b)(1) unless the applicant for such assistance agrees to comply with such guidelines.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6836be2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–14/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary may establish the guidelines described in paragraph (1) only after consulting with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6836be3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–14/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" physicians whose clinical practice includes a significant number of individuals with acquired immune deficiency syndrome;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6836be4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–14/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" individuals who are infected with the etiologic agent for such syndrome; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6836be5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–14/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other individuals with appropriate expertise or experience.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6836be6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–14/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of carrying out this section, there are authorized to be appropriated such sums as may be necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb6836be7-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XXIII, § 2314, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/607/tII/s201/4"},"text":"Pub. L. 100–607, title II, § 201(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-04"},"text":"Nov. 4, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3069"},"text":"102 Stat. 3069","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/43/tXX/s2008/d/3"},"text":"Pub. L. 103–43, title XX, § 2008(d)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-06-10"},"text":"June 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/212"},"text":"107 Stat. 212","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb6836be8-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb6836be9-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb6836bea-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 300cc–14, act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", § 2315, was successively renumbered by subsequent acts and transferred, see section 238"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb6836beb-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1993—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/43"},"text":"Pub. L. 103–43","children":[],"tail":" substituted “AIDS Research Advisory Committee” for “Clinical Research Review Committee” in introductory provisions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
