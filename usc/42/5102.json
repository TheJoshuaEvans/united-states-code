{"tag":"section","attrib":{"id":"idbcf7cadc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5102"},"text":null,"children":[{"tag":"num","attrib":{"value":"5102"},"text":"§ 5102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisory board on child abuse and neglect","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbcf7cadd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5102/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may appoint an advisory board to make recommendations to the Secretary and to the appropriate committees of Congress concerning specific issues relating to child abuse and neglect.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcf7cade-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5102/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Solicitation of nominations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall publish a notice in the Federal Register soliciting nominations for the appointment of members of the advisory board under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcf7cadf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5102/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Composition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In establishing the board under subsection (a), the Secretary shall appoint members from the general public who are individuals knowledgeable in child abuse and neglect prevention, intervention, treatment, or research, and with due consideration to representation of ethnic or racial minorities and diverse geographic areas, and who represent—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbcf7cae0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5102/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" law (including the judiciary);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcf7cae1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5102/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" psychology (including child development);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcf7cae2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5102/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" social services (including child protective services);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcf7cae3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5102/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" health care providers (including pediatricians);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcf7cae4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5102/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State and local government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcf7cae5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5102/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" organizations providing services to disabled persons;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcf7cae6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5102/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" organizations providing services to adolescents;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcf7cae7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5102/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" teachers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcf7cae8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5102/c/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" parent self-help organizations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcf7cae9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5102/c/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" parents’ groups;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcf7caea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5102/c/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" voluntary groups;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcf7caeb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5102/c/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" family rights groups;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcf7caec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5102/c/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" children’s rights advocates; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcf7caed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5102/c/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Indian tribes or tribal organizations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcf7caee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5102/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vacancies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any vacancy in the membership of the board shall be filled in the same manner in which the original appointment was made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcf7caef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5102/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election of officers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The board shall elect a chairperson and vice-chairperson at its first meeting from among the members of the board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcf7caf0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5102/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after the establishment of the board under subsection (a), the board shall submit to the Secretary and the appropriate committees of Congress a report, or interim report, containing—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbcf7caf1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5102/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommendations on coordinating Federal, State, tribal, and local child abuse and neglect activities with similar activities at the Federal, State, tribal, and local level pertaining to family violence prevention;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcf7caf2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5102/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specific modifications needed in Federal, State, and tribal laws and programs to reduce the number of unfounded or unsubstantiated reports of child abuse or neglect while enhancing the ability to identify and substantiate legitimate cases of child abuse or neglect which place a child in danger; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcf7caf3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5102/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommendations for modifications needed to facilitate coordinated national data collection with respect to child protection and child welfare.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbcf7caf4-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/247/tI/s102"},"text":"Pub. L. 93–247, title I, § 102","children":[],"tail":", formerly § 3, "},{"tag":"date","attrib":{"date":"1974-01-31"},"text":"Jan. 31, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/5"},"text":"88 Stat. 5","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/266/tI/s102"},"text":"Pub. L. 95–266, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-04-24"},"text":"Apr. 24, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/206"},"text":"92 Stat. 206","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/457/tI"},"text":"Pub. L. 98–457, title I","children":[],"tail":", §§ 102, 121, "},{"tag":"date","attrib":{"date":"1984-10-09"},"text":"Oct. 9, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1750"},"text":"98 Stat. 1750","children":[],"tail":", 1752; "},{"tag":"ref","attrib":{"href":"/us/pl/100/294/tI/s101"},"text":"Pub. L. 100–294, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-04-25"},"text":"Apr. 25, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/103"},"text":"102 Stat. 103","children":[],"tail":"; renumbered title I, § 102, and amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/126/s3/a/1"},"text":"Pub. L. 101–126, § 3(a)(1)","children":[],"tail":", (2), (b)(1), "},{"tag":"date","attrib":{"date":"1989-10-25"},"text":"Oct. 25, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/764"},"text":"103 Stat. 764","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/295/tI/s111"},"text":"Pub. L. 102–295, title I, § 111","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-05-28"},"text":"May 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/190"},"text":"106 Stat. 190","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/235/tI/s102"},"text":"Pub. L. 104–235, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-03"},"text":"Oct. 3, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3065"},"text":"110 Stat. 3065","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/320/tI/s111"},"text":"Pub. L. 111–320, title I, § 111","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-20"},"text":"Dec. 20, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3460"},"text":"124 Stat. 3460","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbcf7caf5-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbcf7caf6-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbcf7caf7-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (c)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/320/s111/1/A"},"text":"Pub. L. 111–320, § 111(1)(A)","children":[],"tail":", substituted “health care providers (including pediatricians)” for “medicine (including pediatrics)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(14). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/320/s111/1/B"},"text":"Pub. L. 111–320, § 111(1)(B)","children":[],"tail":"–(D), added par. (14)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/320/s111/2/A"},"text":"Pub. L. 111–320, § 111(2)(A)","children":[],"tail":", inserted “tribal,” after “State,” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/320/s111/2/B"},"text":"Pub. L. 111–320, § 111(2)(B)","children":[],"tail":", substituted “Federal, State, and tribal” for “Federal and State” and “child abuse or neglect which” for “abuse or neglect which”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/235"},"text":"Pub. L. 104–235","children":[],"tail":" amended section generally, substituting present provisions for provisions which related to appointment of Advisory Board on Child Abuse and Neglect in subsec. (a); solicitation of nominations in subsec. (b); composition of Advisory Board in subsec. (c); election of officers in subsec. (d); meetings in subsec. (e); duties in subsec. (f); compensation in subsec. (g); and authorization of appropriations in subsec. (h)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (f)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/295/s111/a"},"text":"Pub. L. 102–295, § 111(a)","children":[],"tail":", added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/295/s111/b"},"text":"Pub. L. 102–295, § 111(b)","children":[],"tail":", added subsec. (h)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsecs. (c)(1)(A), (e), (f)(2)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/126/s3/b/1"},"text":"Pub. L. 101–126, § 3(b)(1)","children":[],"tail":", made technical amendments to references to sections 5103, 5105, and 5106 of this title to reflect renumbering of corresponding sections of original act."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/294"},"text":"Pub. L. 100–294","children":[],"tail":" amended section generally, substituting provisions relating to Advisory Board on Child Abuse and Neglect for provisions relating to definitions. See "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5106g"},"text":"section 5106g of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Cl. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/457/s121/1"},"text":"Pub. L. 98–457, § 121(1)","children":[],"tail":", designated provisions after opening phrase as cl. (1)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/457/s102/1"},"text":"Pub. L. 98–457, § 102(1)","children":[],"tail":", inserted “(including any employee of a residential facility or any staff person providing out-of-home care)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Cl. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/457/s102/2"},"text":"Pub. L. 98–457, § 102(2)","children":[],"tail":", (3), added cl. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Cl. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/457/s121/2"},"text":"Pub. L. 98–457, § 121(2)","children":[],"tail":", (3), added cl. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/266"},"text":"Pub. L. 95–266","children":[],"tail":" inserted “or exploitation” after “sexual abuse” and “, or the age specified by the child protection law of the State in question,” after “eighteen”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbcf7caf8-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbcf7caf9-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1989 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/126/s8"},"text":"Pub. L. 101–126, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-10-25"},"text":"Oct. 25, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/769"},"text":"103 Stat. 769","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/126/s8"},"text":"“This Act and the amendments made by this Act [see Short Title of 1989 Amendment note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5101"},"text":"section 5101 of this title","children":[],"tail":"] shall take effect "},{"tag":"date","attrib":{"date":"1989-10-01"},"text":"October 1, 1989","children":[],"tail":", or upon the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1989-10-25"},"text":"Oct. 25, 1989","children":[],"tail":"], whichever occurs later.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbcf7cafa-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/457/tI/s128"},"text":"Pub. L. 98–457, title I, § 128","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-09"},"text":"Oct. 9, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1755"},"text":"98 Stat. 1755","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/98/457/tI/s128"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in subsection (b), the provisions of this part or any amendment made by this part [part B (§§ 121–128) of title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/457"},"text":"Pub. L. 98–457","children":[],"tail":", amending this section and "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5103"},"text":"section 5103 of this title","children":[],"tail":" and enacting provisions set out as notes under sections 5101 and 5103 of this title] shall be effective on the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1984-10-09"},"text":"Oct. 9, 1984","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in paragraph (2), the amendments made by sections 122 and 123(b) of this Act [amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5103"},"text":"section 5103 of this title","children":[],"tail":"] shall become effective one year after the date of such enactment ["},{"tag":"date","attrib":{"date":"1984-10-09"},"text":"Oct. 9, 1984","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the event that, prior to such effective date, funds have not been appropriated pursuant to section 5 of the Act (as amended by section 104 of this Act) [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5104"},"text":"section 5104 of this title","children":[],"tail":"] for the purpose of grants under section 4(c)(1) of the Act (as added by section 123(a) of this Act) ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5103/c/1"},"text":"section 5103(c)(1) of this title","children":[],"tail":"], any State which has not met any requirement of section 4(b)(2)(K) of the Act (as added by section 122(3) of this Act) may be granted a waiver of such requirements for a period of not more than one year, if the Secretary finds that such State is making a good-faith effort to comply with such requirements.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbcf7cafb-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Advisory Boards","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Advisory boards established after ","children":[{"tag":"date","attrib":{"date":"1973-01-05"},"text":"Jan. 5, 1973","children":[],"tail":", to terminate not later than the expiration of the 2-year period beginning on the date of its establishment, unless, in the case of a board established by the President or an officer of the Federal Government, such board is renewed by appropriate action prior to the end of such period, or in the case of a board established by the Congress, its duration is otherwise provided by law, see sections 1001(2) and 1013 of Title 5, Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbcf7cafc-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Limitations on Use of Appropriated Funds","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/dA/s101/f/tII/s206"},"text":"Pub. L. 105–277, div. A, § 101(f) [title II, § 206]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-337"},"text":"112 Stat. 2681–337","children":[],"tail":", 2681–359, provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/277/dA/s101/f/tII/s206"},"text":"“None of the funds appropriated in this Act or subsequent Departments of Labor, Health and Human Services, and Education, and Related Agencies Appropriations Acts, may be obligated or expended for the Federal Council on Aging under the Older Americans Act [of 1965, ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3001"},"text":"42 U.S.C. 3001","children":[],"tail":" et seq.] or the Advisory Board on Child Abuse and Neglect under the Child Abuse Prevention and Treatment Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5101"},"text":"42 U.S.C. 5101","children":[],"tail":" et seq.].”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Similar provisions were contained in the following prior appropriation acts:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/78/tII/s206"},"text":"Pub. L. 105–78, title II, § 206","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-13"},"text":"Nov. 13, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1489"},"text":"111 Stat. 1489","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/dA/s101/e/tII/s208"},"text":"Pub. L. 104–208, div. A, § 101(e) [title II, § 208]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-233"},"text":"110 Stat. 3009–233","children":[],"tail":", 3009–254."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/134/tI/s101/d/tII/s209"},"text":"Pub. L. 104–134, title I, § 101(d) [title II, § 209]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-26"},"text":"Apr. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1321-211"},"text":"110 Stat. 1321–211","children":[],"tail":", 1321–228; renumbered title I, "},{"tag":"ref","attrib":{"href":"/us/pl/104/140/s1/a"},"text":"Pub. L. 104–140, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-05-02"},"text":"May 2, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1327"},"text":"110 Stat. 1327","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
