{"tag":"section","attrib":{"id":"idb8059eae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s914"},"text":null,"children":[{"tag":"num","attrib":{"value":"914"},"text":"§ 914.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of Women’s Health","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8059eaf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s914/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish within the Office of the Administrator of the Health Resources and Services Administration, an office to be known as the Office of Women’s Health. The Office shall be headed by a director who shall be appointed by the Administrator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8059eb0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s914/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director of the Office shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8059eb1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s914/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" report to the Administrator on the current Administration level of activity regarding women’s health across, where appropriate, age, biological, and sociocultural contexts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8059eb2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s914/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish short-range and long-range goals and objectives within the Health Resources and Services Administration for women’s health and, as relevant and appropriate, coordinate with other appropriate offices on activities within the Administration that relate to health care provider training, health service delivery, research, and demonstration projects, for issues of particular concern to women;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8059eb3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s914/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify projects in women’s health that should be conducted or supported by the bureaus of the Administration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8059eb4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s914/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consult with health professionals, nongovernmental organizations, consumer organizations, women’s health professionals, and other individuals and groups, as appropriate, on Administration policy with regard to women; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8059eb5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s914/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serve as a member of the Department of Health and Human Services Coordinating Committee on Women’s Health (established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s237a/b/4"},"text":"section 237a(b)(4) of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8059eb6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s914/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continued administration of existing programs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the Office shall assume the authority for the development, implementation, administration, and evaluation of any projects carried out through the Health Resources and Services Administration relating to women’s health on ","children":[{"tag":"date","attrib":{"date":"2010-03-23"},"text":"March 23, 2010","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8059eb7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s914/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8059eb8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s914/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Administration” means the Health Resources and Services Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8059eb9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s914/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrator","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Administrator” means the Administrator of the Health Resources and Services Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8059eba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s914/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Office” means the Office of Women’s Health established under this section in the Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8059ebb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s914/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of carrying out this section, there are authorized to be appropriated such sums as may be necessary for each of the fiscal years 2010 through 2014.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8059ebc-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title VII, § 713, as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tIII/s3509/f"},"text":"Pub. L. 111–148, title III, § 3509(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/535"},"text":"124 Stat. 535","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
