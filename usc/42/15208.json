{"tag":"section","attrib":{"id":"idbfdfd099-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15208"},"text":null,"children":[{"tag":"num","attrib":{"value":"15208"},"text":"§ 15208.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Law enforcement tribute acts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfdfd09a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15208/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Short title","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section may be cited as the “Law Enforcement Tribute Act”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfdfd09b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15208/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Congress finds the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfdfd09c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15208/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The well-being of all citizens of the United States is preserved and enhanced as a direct result of the vigilance and dedication of law enforcement and public safety personnel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfdfd09d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15208/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" More than 700,000 law enforcement officers, both men and women, at great risk to their personal safety, serve their fellow citizens as guardians of peace.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfdfd09e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15208/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nationwide, 51 law enforcement officers were killed in the line of duty in 2000, according to statistics released by the Federal Bureau of Investigation. This number is an increase of 9 from the 1999 total of 42.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfdfd09f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15208/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In 1999, 112 firefighters died while on duty, an increase of 21 deaths from the previous year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfdfd0a0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15208/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Every year, 1 in 9 peace officers is assaulted, 1 in 25 is injured, and 1 in 4,400 is killed in the line of duty.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfdfd0a1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15208/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In addition, recent statistics indicate that 83 officers were accidentally killed in the performance of their duties in 2000, an increase of 18 from the 65 accidental deaths in 1999.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfdfd0a2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15208/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A permanent tribute is a powerful means of honoring the men and women who have served our Nation with distinction. However, many law enforcement and public safety agencies lack the resources to honor their fallen colleagues.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfdfd0a3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15208/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program authorized","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"From amounts made available to carry out this section, the Attorney General may make grants to States, units of local government, and Indian tribes to carry out programs to honor, through permanent tributes, men and women of the United States who were killed or disabled while serving as law enforcement or public safety officers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfdfd0a4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15208/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uses of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Grants awarded under this section shall be distributed directly to the State, unit of local government, or Indian tribe, and shall be used for the purposes specified in subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfdfd0a5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15208/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" $150,000 limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A grant under this section may not exceed $150,000 to any single recipient.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfdfd0a6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15208/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matching funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfdfd0a7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15208/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Federal portion of the costs of a program provided by a grant under this section may not exceed 50 percent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfdfd0a8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15208/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any funds appropriated by Congress for the activities of any agency of an Indian tribal government or the Bureau of Indian Affairs performing law enforcement or public safety functions on any Indian lands may be used to provide the non-Federal share of a matching requirement funded under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfdfd0a9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15208/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To request a grant under this section, the chief executive of a State, unit of local government, or Indian tribe shall submit an application to the Attorney General at such time, in such manner, and accompanied by such information as the Attorney General may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfdfd0aa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15208/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than November 30 of each year, the Attorney General shall submit a report to the Congress regarding the activities carried out under this section. Each such report shall include, for the preceding fiscal year, the number of grants funded under this section, the amount of funds provided under those grants, and the activities for which those funds were used.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfdfd0ab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15208/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this section $3,000,000 for each of fiscal years 2002 through 2009.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfdfd0ac-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/273/dC/tI/s11001"},"text":"Pub. L. 107–273, div. C, title I, § 11001","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1815"},"text":"116 Stat. 1815","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/162/tXI/s1185"},"text":"Pub. L. 109–162, title XI, § 1185","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-05"},"text":"Jan. 5, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3127"},"text":"119 Stat. 3127","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbfdfd0ad-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbfdfd0ae-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbfdfd0af-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as the Law Enforcement Tribute Act, and also as part of the 21st Century Department of Justice Appropriations Authorization Act, and not as part of the Public Safety Officer Medal of Valor Act of 2001 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbfdfd0b0-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/162"},"text":"Pub. L. 109–162","children":[],"tail":" substituted “2009” for “2006”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
