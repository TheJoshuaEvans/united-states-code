{"tag":"section","attrib":{"id":"idb7a18539-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629c"},"text":null,"children":[{"tag":"num","attrib":{"value":"629c"},"text":"§ 629c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allotments to States","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb7a1853a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian tribes or tribal consortia","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"From the amount reserved pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s629f/b/2"},"text":"section 629f(b)(2) of this title","children":[],"tail":" for any fiscal year, the Secretary shall allot to each Indian tribe with a plan approved under this subpart an amount that bears the same ratio to such reserved amount as the number of children in the Indian tribe bears to the total number of children in all Indian tribes with State plans so approved, as determined by the Secretary on the basis of the most current and reliable information available to the Secretary. If a consortium of Indian tribes submits a plan approved under this subpart, the Secretary shall allot to the consortium an amount equal to the sum of the allotments determined for each Indian tribe that is part of the consortium."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7a1853b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Territories","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"From the amount described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s629f/a"},"text":"section 629f(a) of this title","children":[],"tail":" for any fiscal year that remains after applying "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s629f/b"},"text":"section 629f(b) of this title","children":[],"tail":" for the fiscal year, the Secretary shall allot to each of the jurisdictions of Puerto Rico, Guam, the Virgin Islands, the Northern Mariana Islands, and American Samoa an amount determined in the same manner as the allotment to each of such jurisdictions is determined under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s623"},"text":"section 623 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7a1853c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other States","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7a1853d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629c/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"From the amount described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s629f/a"},"text":"section 629f(a) of this title","children":[],"tail":" for any fiscal year that remains after applying "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s629f/b"},"text":"section 629f(b) of this title","children":[],"tail":" and subsection (b) of this section for the fiscal year, the Secretary shall allot to each State (other than an Indian tribe) which is not specified in subsection (b) of this section an amount equal to such remaining amount multiplied by the supplemental nutrition assistance program benefits percentage of the State for the fiscal year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7a1853e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629c/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supplemental nutrition assistance program benefits percentage defined","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb7a1853f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629c/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As used in paragraph (1) of this subsection, the term “supplemental nutrition assistance program benefits percentage” means, with respect to a State and a fiscal year, the average monthly number of children receiving supplemental nutrition assistance program benefits in the State for months in the 3 fiscal years referred to in subparagraph (B) of this paragraph, as determined from sample surveys made under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2025/c"},"text":"section 2025(c) of title 7","children":[],"tail":", expressed as a percentage of the average monthly number of children receiving supplemental nutrition assistance program benefits in the States described in such paragraph (1) for months in such 3 fiscal years, as so determined."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7a18540-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629c/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fiscal years used in calculation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of the calculation pursuant to subparagraph (A), the Secretary shall use data for the 3 most recent fiscal years, preceding the fiscal year for which the State’s allotment is calculated under this subsection, for which such data are available to the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7a18541-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629c/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reallotments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of any allotment to a State under subsection (a), (b), or (c) of this section for any fiscal year that the State certifies to the Secretary will not be required for carrying out the State plan under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s629b"},"text":"section 629b of this title","children":[],"tail":" shall be available for reallotment using the allotment methodology specified in subsection (a), (b), or (c) of this section. Any amount so reallotted to a State is deemed part of the allotment of the State under the preceding provisions of this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7a18542-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629c/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allotment of funds reserved to support monthly caseworker visits","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7a18543-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629c/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Base allotment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"From the amount reserved pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s629f/b/3/A"},"text":"section 629f(b)(3)(A) of this title","children":[],"tail":" for any fiscal year, the Secretary shall first allot to each State (other than an Indian tribe) that has provided to the Secretary such documentation as may be necessary to verify that the jurisdiction has complied with section 629f(b)(4)(B)(ii) "},{"tag":"ref","attrib":{"idref":"fn002618"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002618"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title during the fiscal year, a base allotment of $100,000, and shall then allot to each of those States an amount determined in paragraph (2) or (3) of this subsection, as applicable."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7a18544-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629c/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Territories","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"From the amount reserved pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s629f/b/3/A"},"text":"section 629f(b)(3)(A) of this title","children":[],"tail":" for any fiscal year that remains after applying paragraph (1) of this subsection for the fiscal year, the Secretary shall allot to each jurisdiction specified in subsection (b) of this section to which a base allotment is made under such paragraph (1) an amount determined in the same manner as the allotment to each of such jurisdictions is determined under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s623"},"text":"section 623 of this title","children":[],"tail":" (without regard to the initial allotment of $70,000 to each State)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7a18545-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629c/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"From the amount reserved pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s629f/b/3/A"},"text":"section 629f(b)(3)(A) of this title","children":[],"tail":" for any fiscal year that remains after applying paragraphs (1) and (2) of this subsection for the fiscal year, the Secretary shall allot to each State (other than an Indian tribe) not specified in subsection (b) of this section to which a base allotment was made under paragraph (1) of this subsection an amount equal to such remaining amount multiplied by the supplemental nutrition assistance program benefits percentage of the State (as defined in subsection (c)(2) of this section) for the fiscal year, except that in applying subsection (c)(2)(A) of this section, “subsection (e)(3)” shall be substituted for “such paragraph (1)”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb7a18546-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title IV, § 433, as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/66/tXIII/s13711/a/2"},"text":"Pub. L. 103–66, title XIII, § 13711(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-10"},"text":"Aug. 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/653"},"text":"107 Stat. 653","children":[],"tail":"; amended "},{"tag":"ref","a