ldren":[],"tail":" were repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb7a1854b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 433 of act ","children":[{"tag":"date","attrib":{"date":"1935-08-14"},"text":"Aug. 14, 1935","children":[],"tail":", was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s633"},"text":"section 633 of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/100/485"},"text":"Pub. L. 100–485","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb7a1854c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/258/s115/b/2/A"},"text":"Pub. L. 118–258, § 115(b)(2)(A)","children":[],"tail":", substituted “629f(b)(2) of this title” for “629f(b)(3) of this title”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/258/s115/b/2/B"},"text":"Pub. L. 118–258, § 115(b)(2)(B)","children":[],"tail":", substituted “629f(b)(3)(A) of this title” for “629f(b)(4)(A) of this title” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/258/s112/b"},"text":"Pub. L. 118–258, § 112(b)","children":[],"tail":", added pars. (1) to (3) and struck out former pars. (1) and (2) which related to the allotment of funds reserved to support monthly caseworker visits for territories and other States, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"201