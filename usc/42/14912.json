{"tag":"section","attrib":{"id":"idbfd3e966-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14912"},"text":null,"children":[{"tag":"num","attrib":{"value":"14912"},"text":"§ 14912.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibilities of the Secretary of State","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfd3e967-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14912/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liaison responsibilities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall have responsibility for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfd3e968-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14912/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" liaison with the central authorities of other Convention countries; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfd3e969-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14912/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the coordination of activities under the Convention by persons subject to the jurisdiction of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfd3e96a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14912/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information exchange","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall be responsible for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfd3e96b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14912/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" providing the central authorities of other Convention countries with information concerning—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfd3e96c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14912/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accredited agencies and approved persons, agencies and persons whose accreditation or approval has been suspended or canceled, and agencies and persons who have been temporarily or permanently debarred from accreditation or approval;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfd3e96d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14912/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal and State laws relevant to implementing the Convention; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfd3e96e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14912/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other matters necessary and appropriate for implementation of the Convention;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfd3e96f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14912/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than the date of the entry into force of the Convention for the United States (pursuant to Article 46(2)(a) of the Convention) and at least once during each subsequent calendar year, providing to the central authority of all other Convention countries a notice requesting the central authority of each such country to specify any requirements of such country regarding adoption, including restrictions on the eligibility of persons to adopt, with respect to which information on the prospective adoptive parent or parents in the United States would be relevant;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfd3e970-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14912/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" making responses to notices under paragraph (2) available to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfd3e971-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14912/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accredited agencies and approved persons; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfd3e972-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14912/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other persons or entities performing home studies under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s14921/b/1"},"text":"section 14921(b)(1) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfd3e973-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14912/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensuring the provision of a background report (home study) on prospective adoptive parent or parents (pursuant to the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s14923/b/1/A/ii"},"text":"section 14923(b)(1)(A)(ii) of this title","children":[],"tail":"), through the central authority of each child’s country of origin, to the court having jurisdiction over the adoption (or, in the case of a child emigrating to the United States for the purpose of adoption, to the competent authority in the child’s country of origin with responsibility for approving the child’s emigration) in adequate time to be considered prior to the granting of such adoption or approval;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfd3e974-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14912/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing Federal agencies, State courts, and accredited agencies and approved persons with an identification of Convention countries and persons authorized to perform functions under the Convention in each such country; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfd3e975-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14912/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitating the transmittal of other appropriate information to, and among, central authorities, Federal and State agencies (including State courts), and accredited agencies and approved persons.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfd3e976-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14912/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Accreditation and approval responsibilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall carry out the functions prescribed by the Convention with respect to the accreditation of agencies and the approval of persons to provide adoption services in the United States in cases subject to the Convention as provided in subchapter II. Such functions may not be delegated to any other Federal agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfd3e977-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14912/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional responsibilities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfd3e978-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14912/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall monitor individual Convention adoption cases involving United States citizens; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfd3e979-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14912/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may facilitate interactions between such citizens and officials of other Convention countries on matters relating to the Convention in any case in which an accredited agency or approved person is unwilling or unable to provide such facilitation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfd3e97a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14912/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of registry","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary and the Attorney General shall jointly establish a case registry of all adoptions involving immigration of children into the United States and emigration of children from the United States, regardless of whether the adoption occurs under the Convention. Such registry shall permit tracking of pending cases and retrieval of information on both pending and closed cases.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfd3e97b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14912/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Methods of performing responsibilities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfd3e97c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14912/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" authorize public or private entities to perform appropriate central authority functions for which the Secretary is responsible, pursuant to regulations or under agreements published in the Federal Register; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfd3e97d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14912/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry out central authority functions through grants to, or contracts with, any individual or public or private entity, except as may be otherwise specifically provided in this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfd3e97e-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/279/tI/s102"},"text":"Pub. L. 106–279, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-06"},"text":"Oct. 6, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/828"},"text":"114 Stat. 828","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbfd3e97f-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbfd3e980-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbfd3e981-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Subchapter II, referred to in subsec. (c), was in the original “title II”, meaning title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/279"},"text":"Pub. L. 106–279","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-06"},"text":"Oct. 6, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/830"},"text":"114 Stat. 830","children":[],"tail":", which enacted subchapter II of this chapter and amended "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s622"},"text":"section 622 of this title","children":[],"tail":". For complete classification of title II to the Code, see Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (f)(2), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/279"},"text":"Pub. L. 106–279","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-06"},"text":"Oct. 6, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/825"},"text":"114 Stat. 825","children":[],"tail":", known as the Intercountry Adoption Act of 2000, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s14901"},"text":"section 14901 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbfd3e982-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbfd3e983-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2000-10-06"},"text":"Oct. 6, 2000","children":[],"tail":", with transition rule, see section 505(a)(1), (b) of "},{"tag":"ref","attrib":{"href":"/us/pl/106/279"},"text":"Pub. L. 106–279","children":[],"tail":", set out as an Effective Dates; Transition Rule note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s14901"},"text":"section 14901 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
