{"tag":"section","attrib":{"id":"idbda373bd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6374a"},"text":null,"children":[{"tag":"num","attrib":{"value":"6374a"},"text":"§ 6374a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Alternative fuels truck commercial application program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbda373be-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6374a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in cooperation with manufacturers of heavy duty engines and with other Federal agencies, shall establish a commercial application program to study the use of alternative fuels in heavy duty trucks and, if appropriate, other heavy duty applications.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbda373bf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6374a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbda373c0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6374a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There are authorized to be appropriated to the Secretary for carrying out this section such sums as may be necessary for fiscal years 1993 through 1995, to remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbda373c1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6374a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The authority of the Secretary to obligate amounts to be expended under this section shall be effective for any fiscal year only to such extent or in such amounts as are provided in advance by appropriation Acts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbda373c2-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/163/tIII/s400BB"},"text":"Pub. L. 94–163, title III, § 400BB","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/494/s4/a"},"text":"Pub. L. 100–494, § 4(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-14"},"text":"Oct. 14, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2444"},"text":"102 Stat. 2444","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/486/tIV/s401"},"text":"Pub. L. 102–486, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2875"},"text":"106 Stat. 2875","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbda373c3-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbda373c4-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbda373c5-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/s401/a"},"text":"Pub. L. 102–486, § 401(a)","children":[],"tail":", substituted “alternative fuels” for “alcohol and natural gas”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/s401/b"},"text":"Pub. L. 102–486, § 401(b)","children":[],"tail":", amended par. (1) generally. Prior to amendment, par. (1) read as follows: “There are authorized to be appropriated for the period encompassing the fiscal years ending "},{"tag":"date","attrib":{"date":"1990-09-30"},"text":"September 30, 1990","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-09-30"},"text":"September 30, 1991","children":[],"tail":", and "},{"tag":"date","attrib":{"date":"1992-09-30"},"text":"September 30, 1992","children":[],"tail":", a total of $2,000,000 for alcohol powered vehicles and dual energy vehicles, and a total of $2,000,000 for natural gas powered vehicles and natural gas dual energy vehicles, to carry out the purposes of this section.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
