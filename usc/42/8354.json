{"tag":"section","attrib":{"id":"idbe9463a4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8354"},"text":null,"children":[{"tag":"num","attrib":{"value":"8354"},"text":"§ 8354.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms and conditions; compliance plans","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbe9463a5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8354/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms and conditions generally","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any exemption from any prohibition under this part shall be on such terms and conditions as the Secretary determines appropriate, including terms and conditions requiring the use of effective fuel conservation measures which are practicable and consistent with the purposes of this chapter. In the case of any temporary exemption, the terms and conditions (which may include a compliance plan meeting the requirements of subsection (b)) shall be designed to insure that upon the expiration of such exemption, the persons and powerplant covered by such exemption will comply with the applicable prohibitions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe9463a6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8354/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compliance plans","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A compliance plan meets the requirements of this subsection if it is approved by the Secretary and—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe9463a7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8354/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contains (A) a schedule indicating how compliance with applicable prohibition of this chapter will occur and (B) evidence of binding contracts for fuel, or facilities for the production of fuel, which would allow for such compliance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe9463a8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8354/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is revised at such times and to such extent as the Secretary may require to reflect changes in circumstances.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbe9463a9-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/620/tIII/s314"},"text":"Pub. L. 95–620, title III, § 314","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-09"},"text":"Nov. 9, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3314"},"text":"92 Stat. 3314","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/42/s1/c/10"},"text":"Pub. L. 100–42, § 1(c)(10)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-05-21"},"text":"May 21, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/313"},"text":"101 Stat. 313","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbe9463aa-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbe9463ab-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbe9463ac-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsecs. (a) and (b)(1)(A), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/620"},"text":"Pub. L. 95–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-09"},"text":"Nov. 9, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3289"},"text":"92 Stat. 3289","children":[],"tail":", known as the Powerplant and Industrial Fuel Use Act of 1978, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s8301"},"text":"section 8301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbe9463ad-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1987—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/42"},"text":"Pub. L. 100–42","children":[],"tail":" struck out “or installation” after “powerplant”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbe9463ae-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbe9463af-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Exemption for Certain Electric Powerplants as Effective Prior to 180 Days After ","children":[{"tag":"date","attrib":{"date":"1978-11-09"},"text":"November 9, 1978","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"For effectiveness of exemption for certain electric powerplants as prior to 180 days after ","children":[{"tag":"date","attrib":{"date":"1978-11-09"},"text":"Nov. 9, 1978","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/620/s902/a"},"text":"section 902(a) of Pub. L. 95–620","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s8301"},"text":"section 8301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
