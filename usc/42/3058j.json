{"tag":"section","attrib":{"id":"idbc6d8c45-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058j"},"text":null,"children":[{"tag":"num","attrib":{"value":"3058j"},"text":"§ 3058j.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State legal assistance development","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"A State agency shall provide the services of an individual who shall be known as a State legal assistance developer, and the services of other personnel, sufficient to ensure—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc6d8c46-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058j/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State leadership in securing and maintaining the legal rights of older individuals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc6d8c47-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058j/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State capacity for coordinating the provision of legal assistance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc6d8c48-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058j/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State capacity to provide technical assistance, training, and other supportive functions to area agencies on aging, legal assistance providers, ombudsmen, and other persons, as appropriate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc6d8c49-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058j/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State capacity to promote financial management services to older individuals at risk of conservatorship;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc6d8c4a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058j/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State capacity to assist older individuals in understanding their rights, exercising choices, benefiting from services and opportunities authorized by law, and maintaining the rights of older individuals at risk of guardianship; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc6d8c4b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058j/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State capacity to improve the quality and quantity of legal services provided to older individuals.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc6d8c4c-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/73/tVII/s731"},"text":"Pub. L. 89–73, title VII, § 731","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/501/tVII/s706"},"text":"Pub. L. 106–501, title VII, § 706","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-13"},"text":"Nov. 13, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2291"},"text":"114 Stat. 2291","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc6d8c4d-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc6d8c4e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbc6d8c4f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 3058j, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/73/tVII/s731"},"text":"Pub. L. 89–73, title VII, § 731","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/375/tVII/s704"},"text":"Pub. L. 102–375, title VII, § 704","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-09-30"},"text":"Sept. 30, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1285"},"text":"106 Stat. 1285","children":[],"tail":", related to State elder rights and legal assistance development, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/106/501/tVII/s706"},"text":"Pub. L. 106–501, title VII, § 706","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-13"},"text":"Nov. 13, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2291"},"text":"114 Stat. 2291","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
