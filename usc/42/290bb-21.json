{"tag":"section","attrib":{"id":"idb5a5b5eb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–21"},"text":null,"children":[{"tag":"num","attrib":{"value":"290bb–21"},"text":"§ 290bb–21.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Center for Substance Abuse Prevention","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5a5b5ec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–21/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment; Director","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established in the Administration a Center for Substance Abuse Prevention (hereafter referred to in this part as the “Prevention Center”). The Prevention Center shall be headed by a Director appointed by the Secretary from individuals with extensive experience or academic qualifications in the prevention of drug or alcohol abuse.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5a5b5ed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–21/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties of Director","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director of the Prevention Center shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5a5b5ee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–21/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sponsor regional workshops on the prevention of drug and alcohol abuse through the reduction of risk and the promotion of resiliency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5a5b5ef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–21/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate the findings of research sponsored by agencies of the Service on the prevention of drug and alcohol abuse;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5a5b5f0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–21/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collaborate with the Director of the National Institute on Drug Abuse, the Director of the National Institute on Alcohol Abuse and Alcoholism, and States to promote the study of substance abuse prevention and the dissemination and implementation of research findings that will improve the delivery and effectiveness of substance abuse prevention activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5a5b5f1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–21/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop effective drug and alcohol abuse prevention literature (including educational information on the effects of drugs abused by individuals, including drugs that are emerging as abused drugs);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5a5b5f2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–21/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in cooperation with the Secretary of Education, assure the widespread dissemination of prevention materials among States, political subdivisions, and school systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5a5b5f3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–21/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support clinical training programs for health professionals who provide substance use and misuse prevention and treatment services and other health professionals involved in illicit drug use education and prevention;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5a5b5f4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–21/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in cooperation with the Director of the Centers for Disease Control and Prevention, develop and disseminate educational materials to increase awareness for individuals at greatest risk for substance use disorders to prevent the transmission of communicable diseases, such as HIV, hepatitis, tuberculosis, and other communicable diseases;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5a5b5f5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–21/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct training, technical assistance, data collection, and evaluation activities of programs supported under the Drug Free Schools and Communities Act of 1986;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5a5b5f6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–21/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support the development of model, innovative, community-based programs that reduce the risk of alcohol and drug abuse among young people and promote resiliency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5a5b5f7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–21/b/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collaborate with the Attorney General of the Department of Justice to develop programs to prevent drug abuse among high risk youth;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5a5b5f8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–21/b/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prepare for distribution documentary films and public service announcements for television and radio to educate the public, especially adolescent audiences, concerning the dangers to health resulting from the consumption of alcohol and drugs and, to the extent feasible, use appropriate private organizations and business concerns in the preparation of such announcements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5a825f9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–21/b/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop and support innovative demonstration programs designed to identify and deter the improper use or abuse of anabolic steroids by students, especially students in secondary schools;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5a825fa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–21/b/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure the consistent documentation of the application of criteria when awarding grants and the ongoing oversight of grantees after such grants are awarded;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5a825fb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–21/b/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist and support States in preventing illicit drug use, including emerging illicit drug use issues; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5a825fc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–21/b/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in consultation with relevant stakeholders and in collaboration with the Director of the Centers for Disease Control and Prevention, develop educational materials for clinicians to use with pregnant women for shared decision making regarding pain management and the prevention of substance use disorders during pregnancy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5a825fd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–21/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants, contracts and cooperative agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director may make grants and enter into contracts and cooperative agreements in carrying out subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5a825fe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–21/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National data base","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the Prevention Center shall establish a national data base providing information on programs for the prevention of substance abuse. The data base shall contain information appropriate for use by public entities and information appropriate for use by nonprofit private entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5a825ff-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title V, § 515, formerly § 508, as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/570/tIV/s4005/a"},"text":"Pub. L. 99–570, title IV, § 4005(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3207-111"},"text":"100 Stat. 3207–111","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tII/s2051/a"},"text":"Pub. L. 100–690, title II, § 2051(a)","children":[],"tail":"–(c), "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4206"},"text":"102 Stat. 4206","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/93/s3/a"},"text":"Pub. L. 101–93, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-08-16"},"text":"Aug. 16, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/609"},"text":"103 Stat. 609","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/647/tXIX/s1906"},"text":"Pub. L. 101–647, title XIX, § 1906","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4854"},"text":"104 Stat. 4854","children":[],"tail":"; renumbered § 515 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/321/tI/s113/b"},"text":"Pub. L. 102–321, title I, § 113(b)","children":[],"tail":"–(e), "},{"tag":"date","attrib":{"date":"1992-07-10"},"text":"July 10, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/345"},"text":"106 Stat. 345","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/531/tIII/s312/d/10"},"text":"Pub. L. 102–531, title III, § 312(d)(10)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-27"},"text":"Oct. 27, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3505"},"text":"106 Stat. 3505","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/310/dB/tXXXI/s3112/b"},"text":"Pub. L. 106–310, div. B, title XXXI, § 3112(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-17"},"text":"Oct. 17, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1188"},"text":"114 Stat. 1188","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/255/dB/tVI/s6007/b"},"text":"Pub. L. 114–255, div. B, title VI, § 6007(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-13"},"text":"Dec. 13, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1212"},"text":"130 Stat. 1212","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/271/tVII/s7063/a"},"text":"Pub. L. 115–271, title VII, § 7063(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-24"},"text":"Oct. 24, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4020"},"text":"132 Stat. 4020","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb5a82600-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb5a82601-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb5a82602-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Drug-Free Schools and Communities Act of 1986, referred to in subsec. (b)(8), means title V of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10"},"text":"Pub. L. 89–10","children":[],"tail":" as added by "},{"tag":"ref","attrib":{"href":"/us/pl/100/297/tI/s1001"},"text":"Pub. L. 100–297, title I, § 1001","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-04-28"},"text":"Apr. 28, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/252"},"text":"102 Stat. 252","children":[],"tail":", which was classified generally to subchapter V (§ 3171 et seq.) of chapter 47 of Title 20, Education, prior to the general amendment of "},{"tag":"ref","attrib":{"href":"/us/pl/89/10"},"text":"Pub. L. 89–10","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/tI/s101"},"text":"Pub. L. 103–382, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3519"},"text":"108 Stat. 3519","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb5a82603-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s290aa–6"},"text":"section 290aa–6 of this title","children":[],"tail":" prior to renumbering by "},{"tag":"ref","attrib":{"href":"/us/pl/102/321"},"text":"Pub. L. 102–321","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb5a82604-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 515 of act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s290cc"},"text":"section 290cc of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/102/321/tI/s123/c"},"text":"Pub. L. 102–321, title I, § 123(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-10"},"text":"July 10, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/363"},"text":"106 Stat. 363","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 515 of act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", which was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s229d"},"text":"section 229d of this title","children":[],"tail":", was successively renumbered by subsequent acts and transferred, see section 238"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb5a82605-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (b)(15). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/271"},"text":"Pub. L. 115–271","children":[],"tail":" added par. (15)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255/s6007/b/1"},"text":"Pub. L. 114–255, § 6007(b)(1)","children":[],"tail":", substituted “Center” for “Office” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255/s6007/b/2"},"text":"Pub. L. 114–255, § 6007(b)(2)","children":[],"tail":", substituted “a Center” for “an Office” and “The Prevention Center” for “The Office”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255/s6007/b/3/A"},"text":"Pub. L. 114–255, § 6007(b)(3)(A)","children":[],"tail":", inserted “through the reduction of risk and the promotion of resiliency” before semicolon."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255/s6007/b/3/C"},"text":"Pub. L. 114–255, § 6007(b)(3)(C)","children":[],"tail":", added par. (3). Former par. (3) redesignated (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255/s6007/b/3/B"},"text":"Pub. L. 114–255, § 6007(b)(3)(B)","children":[],"tail":", (D), redesignated par. (3) as (4) and substituted “educational information on the effects of drugs abused by individuals, including drugs that are emerging as abused drugs” for “literature on the adverse effects of cocaine free base (known as ‘crack’)”. Former par. (4) redesignated (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255/s6007/b/3/B"},"text":"Pub. L. 114–255, § 6007(b)(3)(B)","children":[],"tail":", redesignated par. (4) as (5). Former par. (5) redesignated (6)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255/s6007/b/3/B"},"text":"Pub. L. 114–255, § 6007(b)(3)(B)","children":[],"tail":", (E), redesignated par. (5) as (6) and substituted “health professionals who provide substance use and misuse prevention and treatment services” for “substance abuse counselors” and “illicit drug use education and prevention” for “drug abuse education, prevention,”. Former par. (6) redesignated (7)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255/s6007/b/3/B"},"text":"Pub. L. 114–255, § 6007(b)(3)(B)","children":[],"tail":", (F), redesignated par. (6) as (7) and amended par. (7) generally. Prior to amendment, par. (7) read as follows: “in cooperation with the Director of the Centers for Disease Control and Prevention, develop educational materials to reduce the risks of acquired immune deficiency syndrome among intravenous drug abusers;”. Former par. (7) redesignated (8)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255/s6007/b/3/B"},"text":"Pub. L. 114–255, § 6007(b)(3)(B)","children":[],"tail":", redesignated par. (7) as (8). Former par. (8) redesignated (9)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255/s6007/b/3/B"},"text":"Pub. L. 114–255, § 6007(b)(3)(B)","children":[],"tail":", (G), redesignated par. (8) as (9) and substituted “that reduce the risk of” for “to discourage” and inserted “and promote resiliency” before semicolon. Former par. (9) redesignated (10)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(10) to (12). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255/s6007/b/3/B"},"text":"Pub. L. 114–255, § 6007(b)(3)(B)","children":[],"tail":", redesignated pars. (9) to (11) as (10) to (12), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(13), (14). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255/s6007/b/3/H"},"text":"Pub. L. 114–255, § 6007(b)(3)(H)","children":[],"tail":"–(J), added pars. (13) and (14)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (b)(9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/310/s3112/b/2"},"text":"Pub. L. 106–310, § 3112(b)(2)","children":[],"tail":", added par. (9). Former par. (9) redesignated (10)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(10). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/310/s3112/b/1"},"text":"Pub. L. 106–310, § 3112(b)(1)","children":[],"tail":", (3), redesignated par. (9) as (10) and substituted “educate the public, especially adolescent audiences, concerning” for “educate the public concerning”. Former par. (10) redesignated (11)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(11). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/310/s3112/b/1"},"text":"Pub. L. 106–310, § 3112(b)(1)","children":[],"tail":", redesignated par. (10) as (11)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/321/s113/e/1"},"text":"Pub. L. 102–321, § 113(e)(1)","children":[],"tail":", substituted “(hereafter referred to in this part as the ‘Prevention Center’)” for “(hereafter in this part referred to as the ‘Office’)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/321/s113/e/2"},"text":"Pub. L. 102–321, § 113(e)(2)","children":[],"tail":", substituted “Prevention Center” for “Office” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/321/s113/c/1"},"text":"Pub. L. 102–321, § 113(c)(1)","children":[],"tail":", struck out “and intervention” after “prevention,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/531"},"text":"Pub. L. 102–531","children":[],"tail":", which directed the amendment of “section 508(b)(6) ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s290aa–6/b/6"},"text":"42 U.S.C. 290aa–6(b)(6)","children":[],"tail":")” of act "},{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","c