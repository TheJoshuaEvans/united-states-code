{"tag":"section","attrib":{"id":"idbf9114b2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653o"},"text":null,"children":[{"tag":"num","attrib":{"value":"12653o"},"text":"§ 12653o.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National service programs clearinghouses","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf9114b3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653o/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Corporation shall provide assistance, by grant, contract, or cooperative agreement, to entities with expertise in the dissemination of information through clearinghouses to establish 1 or more clearinghouses for information regarding the national service laws, which shall include information on service-learning and on service through other programs receiving assistance under the national service laws.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf9114b4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653o/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Function of clearinghouse","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Such a clearinghouse may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf9114b5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653o/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist entities carrying out State or local service-learning and national service programs with needs assessments and planning;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf9114b6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653o/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct research and evaluations concerning service-learning or programs receiving assistance under the national service laws, except that such clearinghouse may not conduct such research and evaluations if the recipient of the grant, contract, or cooperative agreement establishing the clearinghouse under this section is receiving funds for such purpose under part III of division B or under this division (not including this section);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf9114b7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653o/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf9114b8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653o/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide leadership development and training to State and local service-learning program administrators, supervisors, service sponsors, and participants; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf9114b9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653o/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide training to persons who can provide the leadership development and training described in subparagraph (A);","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf9114ba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653o/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" facilitate communication among—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf9114bb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653o/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" entities carrying out service-learning programs and programs offered under the national service laws; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf9114bc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653o/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" participants in such programs;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf9114bd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653o/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide and disseminate information and curriculum materials relating to planning and operating service-learning programs and programs offered under the national service laws, to States, territories, Indian tribes, and local entities eligible to receive financial assistance under the national service laws;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf9114be-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653o/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide and disseminate information regarding methods to make service-learning programs and programs offered under the national service laws accessible to individuals with disabilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf9114bf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653o/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disseminate applications in languages other than English;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf9114c0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653o/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf9114c1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653o/b/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" gather and disseminate information on successful service-learning programs and programs offered under the national service laws, components of such successful programs, innovative curricula related to service-learning, and service-learning projects; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf9114c2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653o/b/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate the activities of the clearinghouse with appropriate entities to avoid duplication of effort;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf9114c3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653o/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make recommendations to State and local entities on quality controls to improve the quality of service-learning programs and programs offered under the national service laws;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf9114c4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653o/b/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist organizations in recruiting, screening, and placing a diverse population of service-learning coordinators and program sponsors;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf9114c5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653o/b/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disseminate effective strategies for working with disadvantaged youth in national service programs, as determined by organizations with an established expertise in working with such youth; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf9114c6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653o/b/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry out such other activities as the Chief Executive Officer determines to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf9114c7-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/610/tI/s198O"},"text":"Pub. L. 101–610, title I, § 198O","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/13/tI/s1808"},"text":"Pub. L. 111–13, title I, § 1808","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-04-21"},"text":"Apr. 21, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1572"},"text":"123 Stat. 1572","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf9114c8-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf9114c9-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbf9114ca-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 12653","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/101/610/tI/s195O"},"text":"Pub. L. 101–610, title I, § 195O","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/484/dA/tX/s1092/a/1"},"text":"Pub. L. 102–484, div. A, title X, § 1092(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2532"},"text":"106 Stat. 2532","children":[],"tail":", which defined terms used in former part H of this subchapter, was renumbered "},{"tag":"ref","attrib":{"href":"/us/pl/101/610/s166"},"text":"section 166 of Pub. L. 101–610","children":[],"tail":" and transferred to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12626"},"text":"section 12626 of this title","children":[],"tail":" and subsequently renumbered "},{"tag":"ref","attrib":{"href":"/us/pl/101/610/s165"},"text":"section 165 of Pub. L. 101–610","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1516/1"},"text":"section 1516(1) of Pub. L. 111–13","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbf9114cb-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbf9114cc-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2009-10-01"},"text":"Oct. 1, 2009","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/111/13/s6101/a"},"text":"section 6101(a) of Pub. L. 111–13","children":[],"tail":", set out as an Effective Date of 2009 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4950"},"text":"section 4950 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
