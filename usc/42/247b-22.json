{"tag":"section","attrib":{"id":"idb4adc0bc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–22"},"text":null,"children":[{"tag":"num","attrib":{"value":"247b–22"},"text":"§ 247b–22.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Microbicide research","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb4adc0bd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–22/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the Centers for Disease Control and Prevention is strongly encouraged to fully implement the Centers’ microbicide agenda to support research and development of microbicides for use to prevent the transmission of the human immunodeficiency virus.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4adc0be-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–22/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums as may be necessary for each of fiscal years 2009 through 2013 to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb4adc0bf-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title III, § 317T, as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/293/tII/s203/d"},"text":"Pub. L. 110–293, title II, § 203(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-07-30"},"text":"July 30, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2941"},"text":"122 Stat. 2941","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
