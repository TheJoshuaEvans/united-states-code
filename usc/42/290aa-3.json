01"},"text":"July 1, 1944","children":[],"tail":", by "},{"tag":"ref","attrib":{"href":"/us/pl/99/660"},"text":"Pub. L. 99–660","children":[],"tail":" and transferred to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300cc–3"},"text":"section 300cc–3 of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/98/621/s10/s"},"text":"Pub. L. 98–621, § 10(s)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-11-08"},"text":"Nov. 8, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3381"},"text":"98 Stat. 3381","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb59e89e1-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255/s6001/c/2"},"text":"Pub. L. 114–255, § 6001(c)(2)","children":[],"tail":", substituted “Assistant Secretary” for “Administrator”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255/s6009"},"text":"Pub. L. 114–255, § 6009","children":[],"tail":", inserted at end: “In the case of any such peer review group that is reviewing a grant, cooperative agreement, or contract related to mental illness treatment, not less than half of the members of such peer review group shall be licensed and experienced professionals in the prevention, diagnosis, or treatment of, or recovery from, mental illness or co-occurring mental illness and substance use disorders and have a medical degree, a doctoral degree in psychology, or an advanced degree in nursing or social work from an accredited program, and the Secretary, in consultation with the Assistant Secretary, shall, to the extent possible, ensure such peer review groups include broad geographic representation, including both urban and rural representatives.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/310"},"text":"Pub. L. 106–310","children":[],"tail":" reenacted section catchline without change and amended text generally, substituting, in subsec. (a), provisions requiring, after consultation with the Administrator of the Substance Abuse and Mental Health Services Administration, appropriate peer review of grants, cooperative agreements, and contracts to be administered through the agency that exceed the simple acquisition threshold as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t41/s403"},"text":"section 403 of title 41","children":[],"tail":" for provisions requiring such peer review after consultation with the Directors of the Center for Substance Abuse Treatment, the Center for Substance Abuse Prevention, and the Center for Mental Health Services, in subsec. (b), provisions relating to members of peer groups qualified to perform review functions under subsec. (a) for similar provisions in former subsec. (b) but which included reference to regulatory establishment of such groups, in subsec. (c), provisions relating to advisory council review for provisions relating to requirements and specification of regulations promulgated under subsec. (a), and in subsec. (d), provisions relating to Secretary’s authority to establish exceptions to the limitations in section regarding participation of Federal employees and advisory council approval for provisions relating to recommendations."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/392"},"text":"Pub. L. 105–392","children":[],"tail":" substituted “or cooperative agreement” for “cooperative agreement, or contract” wherever appearing in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/352"},"text":"Pub. L. 102–352","children":[],"tail":" struck out “by regulation” after “Center for Mental Health Services, shall” in subsec. (a)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/321"},"text":"Pub. L. 102–321","children":[],"tail":" amended section generally, substituting provisions relating to peer review of grants, cooperative agreements, and contracts administered through the Centers for Substance Abuse Treatment, Substance Abuse Prevention, and Mental Health Services for provisions relating to peer review of biomedical and behavioral research and development grants, cooperative agreements, and contracts administered through the National Institutes of Mental Health, Alcohol Abuse and Alcoholism, and Drug Abuse."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/570/s4007"},"text":"Pub. L. 99–570, § 4007","children":[],"tail":", inserted “applications made for” before “grants, cooperative” in introductory text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1985—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/158"},"text":"Pub. L. 99–158","children":[],"tail":" added subsec. (e)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb59e89e2-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb59e89e3-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1992 Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/352"},"text":"Pub. L. 102–352","children":[],"tail":" effective immediately upon effectuation of amendment made by "},{"tag":"ref","attrib":{"href":"/us/pl/102/321"},"text":"Pub. L. 102–321","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/102/352/s3/1"},"text":"section 3(1) of Pub. L. 102–352","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s285n"},"text":"section 285n of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/321"},"text":"Pub. L. 102–321","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1992-10-01"},"text":"Oct. 1, 1992","children":[],"tail":", with provision for programs providing financial assistance, see section 801(c), (d) of "},{"tag":"ref","attrib":{"href":"/us/pl/102/321"},"text":"Pub. L. 102–321","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s236"},"text":"section 236 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
