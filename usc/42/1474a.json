{"tag":"section","attrib":{"id":"idbb1af47a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1474a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1474a"},"text":"§ 1474a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Security for direct or insured rural housing loans to farmer applicants","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"On and after ","children":[{"tag":"date","attrib":{"date":"1968-08-08"},"text":"August 8, 1968","children":[],"tail":", farmer applicants for direct or insured rural housing loans shall be required to provide only such collateral security as is required of owners of nonfarm tracts."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbb1af47b-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/463/tII/s201"},"text":"Pub. L. 90–463, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-08-08"},"text":"Aug. 8, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/651"},"text":"82 Stat. 651","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbb1af47c-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbb1af47d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbb1af47e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Department of Agriculture and Related Agencies Appropriation Act, 1969, and not as part of the Housing Act of 1949 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
