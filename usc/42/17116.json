{"tag":"section","attrib":{"id":"idc029a99c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17116"},"text":null,"children":[{"tag":"num","attrib":{"value":"17116"},"text":"§ 17116.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Industrial research and assessment centers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc029a99d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17116/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc029a99e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17116/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered project","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “covered project” means a project—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc029a99f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17116/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that has been recommended in an energy assessment described in paragraph (2)(A) conducted for an eligible entity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc029a9a0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17116/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" with respect to which the plant site of that eligible entity—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc029a9a1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17116/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" improves—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idc029a9a2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17116/a/1/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" energy efficiency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc029a9a3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17116/a/1/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" material efficiency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc029a9a4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17116/a/1/B/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cybersecurity; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc029a9a5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17116/a/1/B/i/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" productivity; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc029a9a6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17116/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" reduces—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idc029a9a7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17116/a/1/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" waste production;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc029a9a8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17116/a/1/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" greenhouse gas emissions; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc029a9a9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17116/a/1/B/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nongreenhouse gas pollution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc029a9aa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17116/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible entity” means a small- or medium-sized manufacturer that has had an energy assessment completed by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc029a9ab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17116/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an industrial research and assessment center;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc029a9ac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17116/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Department of Energy Combined Heat and Power Technical Assistance Partnership jointly with an industrial research and assessment center; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc029a9ad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17116/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a third-party assessor that provides an assessment equivalent to an assessment described in subparagraph (A) or (B), as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc029a9ae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17116/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Energy service provider","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “energy service provider” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc029a9af-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17116/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any business providing technology or services to improve the energy efficiency, water efficiency, power factor, or load management of a manufacturing site or other industrial process in an energy-intensive industry (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s17111/a"},"text":"section 17111(a) of this title","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc029a9b0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17116/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any utility operating under a utility energy service project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc029a9b1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17116/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Industrial research and assessment center","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “industrial research and assessment center” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc029a9b2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17116/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an institution of higher education-based industrial research and assessment center that is funded by the Secretary under subsection (b); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc029a9b3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17116/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an industrial research and assessment center at a trade school, community college, or union training program that is funded by the Secretary under subsection (f).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc029a9b4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17116/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Program” means the program for implementation grants established under subsection (i)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc029a9b5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17116/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Small- or medium-sized manufacturer","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “small- or medium-sized manufacturer” means a manufacturing firm—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc029a9b6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17116/a/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the gross annual sales of which are less than $100,000,000;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc029a9b7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17116/a/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that has fewer than 500 employees at the plant site of the manufacturing firm; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc029a9b8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17116/a/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the annual energy bills of which total more than $100,000 but less than $3,500,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc029a9b9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17116/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Institution of higher education-based industrial research and assessment centers","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc029a9ba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17116/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide funding to institution of higher education-based industrial research and assessment centers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc029a9bb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17116/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purpose of each institution of higher education-based industrial research and assessment center shall be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc029a9bc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17116/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide in-depth assessments of small- and medium-sized manufacturer plant sites to evaluate the facilities, services, and manufacturing operations of the plant sites;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc029a9bd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17116/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to identify opportunities for optimizing energy efficiency and environmental performance, including implementation of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc029a9be-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17116/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" smart manufacturing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc029a9bf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17116/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" energy management systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc029a9c0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17116/b/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sustainable manufacturing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc029a9c1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17116/b/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information technology advancements for supply chain analysis, logistics, system monitoring, industrial and manufacturing processes, and other purposes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc029a9c2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17116/b/2/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" waste management systems;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc029a9c3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17116/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to promote applications of emerging concepts and technologies in small- and medium-sized manufacturers (including water and wastewater treatment facilities and federally owned manufacturing facilities);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc029a9c4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17116/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to promote research and development for the use of alternative energy sources to supply heat, power, and new feedstocks for energy-intensive industries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc029a9c5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17116/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to coordinate with appropriate Federal and State research offices;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc029a9c6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17116/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide a clearinghouse for industrial process and energy efficiency technical assistance resources; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc029a9c7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17116/b/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to coordinate with State-accredited technical training centers and community colleges, while ensuring appropriate services to all regions of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc029a9c8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17116/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To increase the value and capabilities of the industrial research and assessment centers, the centers shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc029a9c9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17116/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate with Manufacturing Extension Partnership Centers of the National Institute of Standards and Technology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc029a9ca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17116/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate with the Federal Energy Management Program and the Building Technologies Office of the Department of Energy to provide building assessment services to manufacturers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc029a9cb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17116/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase partnerships with the National Laboratories of the Department of Energy to leverage the expertise, technologies, and research and development capabilities of the National Laboratories for national industrial and manufacturing needs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc029a9cc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17116/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase partnerships with energy service providers and technology providers to leverage private sector expertise and accelerate deployment of new and existing technologies and processes for energy efficiency, power factor, and load management;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc029a9cd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17116/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify opportunities for reducing greenhouse gas emissions and other air emissions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc029a9ce-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17116/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote sustainable manufacturing practices for small- and medium-sized manufacturers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc029a9cf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17116/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Outreach","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall provide funding for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc029a9d0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17116/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" outreach activities by the industrial research and assessment centers to inform small- and medium-sized manufacturers of the information, technologies, and services available; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc029a9d1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17116/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" coordination activities by each industrial research and assessment center to leverage efforts with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc029a9d2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17116/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal, State, and Tribal efforts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc029a9d3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17116/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the efforts of utilities and energy service providers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc029a9d4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17116/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the efforts of regional energy efficiency organizations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc029a9d5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17116/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the efforts of other industrial research and assessment centers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc029a9d6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17116/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Centers of Excellence","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc029a9d7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17116/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a Center of Excellence at not more than 5 of the highest-performing industrial research and assessment centers, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc029a9d8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17116/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A Center of Excellence shall coordinate with and advise the industrial research and assessment centers located in the region of the Center of Excellence, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc029a9d9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17116/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" by mentoring new directors and staff of the industrial research and assessment centers with respect to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc029a9da-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17116/e/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the availability of resources; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc029a9db-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17116/e/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" best practices for carrying out assessments, including through the participation of the staff of the Center of Excellence in assessments carried out by new industrial research and assessment centers;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc029a9dc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17116/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by providing training to staff and students at the industrial research and assessment centers on new technologies, practices, and tools to expand the scope and impact of the assessments carried out by the centers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc029a9dd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17116/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by assisting the industrial research and assessment centers with specialized technical opportunities, including by providing a clearinghouse of available expertise and tools to assist the centers and clients of the centers in assessing and implementing those opportunities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc029a9de-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17116/e/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by identifying and coordinating with regional, State, local, Tribal, and utility energy efficiency programs for the purpose of facilitating efforts by industrial research and assessment centers to connect industrial facilities receiving assessments from those centers with regional, State, local, and utility energy efficiency programs that could aid the industrial facilities in implementing any recommendations resulting from the assessments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc029a9df-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17116/e/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by facilitating coordination between the industrial research and assessment centers and other Federal programs described in paragraphs (1) through (3) of subsection (c); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc029a9e0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17116/e/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by coordinating the outreach activities of the industrial research and assessment centers under subsection (d)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc029a9e1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17116/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For each fiscal year, out of any amounts made available to carry out this section under subsection (j), the Secretary shall use not less than $500,000 to support each Center of Excellence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc029a9e2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17116/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expansion of industrial research and assessment centers","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc029a9e3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17116/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide funding to establish additional industrial research and assessment centers at trade schools, community colleges, and union training programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc029a9e4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17116/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc029a9e5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17116/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subparagraph (B), to the maximum extent practicable, an industrial research and assessment center established under paragraph (1) shall have the same purpose as an institution of higher education-based industrial research center that is funded by the Secretary under subsection (b)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc029a9e6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17116/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consideration of capabilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In evaluating or establishing the purpose of an industrial research and assessment center established under paragraph (1), the Secretary shall take into consideration the varying capabilities of trade schools, community colleges, and union training programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc029a9e7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17116/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Workforce training","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc029a9e8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17116/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Internships","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall pay the Federal share of associated internship programs under which students work with or for industries, manufacturers, and energy service providers to implement the recommendations of industrial research and assessment centers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc029a9e9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17116/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Apprenticeships","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall pay the Federal share of associated apprenticeship programs under which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc029a9ea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17116/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" students work with or for industries, manufacturers, and energy service providers to implement the recommendations of industrial research and assessment centers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc029a9eb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17116/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" employees of facilities that have received an assessment from an industrial research and assessment center work with or for an industrial research and assessment center to gain knowledge on engineering practices and processes to improve productivity and energy savings.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc029a9ec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17116/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal share of the cost of carrying out internship programs described in paragraph (1) and apprenticeship programs described in paragraph (2) shall be 50 percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc029a9ed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17116/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Small business loans","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator of the Small Business Administration shall, to the maximum extent practicable, expedite consideration of applications from eligible small business concerns for loans under the Small Business Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s631"},"text":"15 U.S.C. 631","children":[],"tail":" et seq.) to implement recommendations developed by the industrial research and assessment centers."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc029a9ee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17116/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation grants","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc029a9ef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17116/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a program under which the Secretary shall provide grants to eligible entities to implement covered projects.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc029a9f0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17116/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An eligible entity seeking a grant under the Program shall submit to the Secretary an application at such time, in such manner, and containing such information as the Secretary may require, including a demonstration of need for financial assistance to implement the proposed covered project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc029a9f1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17116/i/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In awarding grants under the Program, the Secretary shall give priority to eligible entities that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc029a9f2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17116/i/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have had an energy assessment completed by an industrial research and assessment center; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc029a9f3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17116/i/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" propose to carry out a covered project with a greater potential for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc029a9f4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17116/i/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" energy efficiency gains; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc029a9f5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17116/i/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" greenhouse gas emissions reductions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc029a9f6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17116/i/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant amount","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc029a9f7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17116/i/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of a grant provided to an eligible entity under the Program shall not exceed $300,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc029a9f8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17116/i/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A grant awarded under the Program for a covered project shall be in an amount that is not more than 50 percent of the cost of the covered project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc029a9f9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17116/i/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supplement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A grant received by an eligible entity under the Program shall supplement, not supplant, any private or State funds available to the eligible entity to carry out the covered project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc029a9fa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17116/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated to the Secretary for the period of fiscal years 2022 through 2026—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc029a9fb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17116/j/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $150,000,000 to carry out subsections (a) through (h); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc029a9fc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17116/j/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $400,000,000 to carry out subsection (i).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc029a9fd-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/tIV/s457"},"text":"Pub. L. 110–140, title IV, § 457","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/dD/tV/s40521/b"},"text":"Pub. L. 117–58, div. D, title V, § 40521(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1062"},"text":"135 Stat. 1062","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc029a9fe-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc029a9ff-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc029aa00-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Small Business Act, referred to in subsec. (h), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/536/s2"},"text":"Pub. L. 85–536, § 2","children":[],"tail":"(1 et seq.), "},{"tag":"date","attrib":{"date":"1958-07-18"},"text":"July 18, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/384"},"text":"72 Stat. 384","children":[],"tail":", which is classified generally to chapter 14A (§ 631 et seq.) of Title 15, Commerce and Trade. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s631"},"text":"section 631 of Title 15","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc029aa01-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc029aa02-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Wage Rate Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions relating to rates of wages to be paid to laborers and mechanics on projects for construction, alteration, or repair work funded under div. D or an amendment by div. D of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":", including authority of Secretary of Labor, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s18851"},"text":"section 18851 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
