{"tag":"section","attrib":{"id":"idbcc8300a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4362a"},"text":null,"children":[{"tag":"num","attrib":{"value":"4362a"},"text":"§ 4362a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership of Task Force on Environmental Cancer and Heart and Lung Disease","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Director of the National Center for Health Statistics and the head of the Center for Disease Control (or the successor to such entity) shall each serve as members of the Task Force on Environmental Cancer and Heart and Lung Disease established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4362"},"text":"section 4362 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbcc8300b-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/623/s9"},"text":"Pub. L. 95–623, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-09"},"text":"Nov. 9, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3455"},"text":"92 Stat. 3455","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbcc8300c-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbcc8300d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbcc8300e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Health Services Research, Health Statistics, and Health Car