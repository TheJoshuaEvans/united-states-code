{"tag":"section","attrib":{"id":"idbd7fc006-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6294a"},"text":null,"children":[{"tag":"num","attrib":{"value":"6294a"},"text":"§ 6294a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Energy Star program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd7fc007-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6294a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established within the Department of Energy and the Environmental Protection Agency a voluntary program to identify and promote energy-efficient products and buildings in order to reduce energy consumption, improve energy security, and reduce pollution through voluntary labeling of, or other forms of communication about, products and buildings that meet the highest energy conservation standards.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd7fc008-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6294a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Division of responsibilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Responsibilities under the program shall be divided between the Department of Energy and the Environmental Protection Agency in accordance with the terms of applicable agreements between those agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd7fc009-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6294a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator and the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd7fc00a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6294a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" promote Energy Star compliant technologies as the preferred technologies in the marketplace for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd7fc00b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6294a/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" achieving energy efficiency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd7fc00c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6294a/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reducing pollution;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd7fc00d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6294a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" work to enhance public awareness of the Energy Star label, including by providing special outreach to small businesses;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd7fc00e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6294a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preserve the integrity of the Energy Star label;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd7fc00f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6294a/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" regularly update Energy Star product criteria for product categories;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd7fc010-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6294a/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" solicit comments from interested parties prior to establishing or revising an Energy Star product category, specification, or criterion (or prior to effective dates for any such product category, specification, or criterion);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd7fc011-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6294a/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" on adoption of a new or revised product category, specification, or criterion, provide reasonable notice to interested parties of any changes (including effective dates) in product categories, specifications, or criteria, along with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd7fc012-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6294a/c/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an explanation of the changes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd7fc013-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6294a/c/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as appropriate, responses to comments submitted by interested parties; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd7fc014-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6294a/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide appropriate lead time (which shall be 270 days, unless the Agency or Department specifies otherwise) prior to the applicable effective date for a new or a significant revision to a product category, specification, or criterion, taking into account the timing requirements of the manufacturing, product marketing, and distribution process for the specific product addressed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd7fc015-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6294a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deadlines","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall establish new qualifying levels—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd7fc016-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6294a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than ","children":[{"tag":"date","attrib":{"date":"2006-01-01"},"text":"January 1, 2006","children":[],"tail":", for clothes washers and dishwashers, effective beginning "},{"tag":"date","attrib":{"date":"2007-01-01"},"text":"January 1, 2007","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd7fc017-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6294a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than ","children":[{"tag":"date","attrib":{"date":"2008-01-01"},"text":"January 1, 2008","children":[],"tail":", for clothes washers, effective beginning "},{"tag":"date","attrib":{"date":"2009-07-01"},"text":"July 1, 2009","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd7fc018-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/163/tIII/s324A"},"text":"Pub. L. 94–163, title III, § 324A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/58/tI/s131/a"},"text":"Pub. L. 109–58, title I, § 131(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/620"},"text":"119 Stat. 620","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/tIII/s311/b"},"text":"Pub. L. 110–140, title III, § 311(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1564"},"text":"121 Stat. 1564","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd7fc019-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd7fc01a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd7fc01b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2007—Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140"},"text":"Pub. L. 110–140","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2009-07-01"},"text":"July 1, 2009","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2010-01-01"},"text":"January 1, 2010","children":[],"tail":"”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbd7fc01c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbd7fc01d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2007 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140"},"text":"Pub. L. 110–140","children":[],"tail":" effective on the date that is 1 day after "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/s1601"},"text":"section 1601 of Pub. L. 110–140","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1824"},"text":"section 1824 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
