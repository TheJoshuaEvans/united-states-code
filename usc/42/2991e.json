{"tag":"section","attrib":{"id":"idbc2f724c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2991e"},"text":null,"children":[{"tag":"num","attrib":{"value":"2991e"},"text":"§ 2991e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Announcement of research, demonstration, or pilot projects","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbc2f724d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2991e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Commissioner shall make a public announcement concerning—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc2f724e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2991e/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the title, purpose, intended completion date, identity of the grantee or contractor, and proposed cost of any grant or contract with a private or non-Federal public agency for a research, demonstration, or pilot project; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc2f724f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2991e/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except in cases in which the Commissioner determines that it would not be consistent with the purposes of this subchapter, the results, findings, data, or recommendations made or reported as a result of such activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc2f7250-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2991e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The public announcements required by subsection (a) shall be made within thirty days of making such grants or contracts, and the public announcements required by subsection (b) of this section shall be made within thirty days of the receipt of such results.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc31e251-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/452/tVIII/s807"},"text":"Pub. L. 88–452, title VIII, § 807","children":[],"tail":", formerly § 806, as added "},{"tag":"ref","attrib":{"href":"/us/pl/93/644/s11"},"text":"Pub. L. 93–644, § 11","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-04"},"text":"Jan. 4, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2325"},"text":"88 Stat. 2325","children":[],"tail":"; renumbered § 807, "},{"tag":"ref","attrib":{"href":"/us/pl/100/175/tV/s502/3"},"text":"Pub. L. 100–175, title V, § 502(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-11-29"},"text":"Nov. 29, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/973"},"text":"101 Stat. 973","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/375/tVIII/s822/7"},"text":"Pub. L. 102–375, title VIII, § 822(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-09-30"},"text":"Sept. 30, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1298"},"text":"106 Stat. 1298","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc31e252-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc31e253-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id"