{"tag":"section","attrib":{"id":"idbf12bba2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10145"},"text":null,"children":[{"tag":"num","attrib":{"value":"10145"},"text":"§ 10145.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of certain provisions","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Sections 10139 and 10140 of this title shall cease to have effect at such time as a repository developed under this part is licensed to receive and possess high-level radioactive waste and spent nuclear fuel.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbf12bba3-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/425/tI/s125"},"text":"Pub. L. 97–425, title I, § 125","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-07"},"text":"Jan. 7, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2229"},"text":"96 Stat. 2229","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
