{"tag":"section","attrib":{"id":"idbc12e8db-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2275"},"text":null,"children":[{"tag":"num","attrib":{"value":"2275"},"text":"§ 2275.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Receipt of Restricted Data","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever, with intent to injure the United States or with intent to secure an advantage to any foreign nation, acquires, or attempts or conspires to acquire any document, writing, sketch, photograph, plan, model, instrument, appliance, note, or information involving or incorporating Restricted Data, shall upon conviction thereof, be punished by imprisonment for life, or by imprisonment for any term of years or a fine of not more than $100,000 or both.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbc12e8dc-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-08-01/ch724"},"text":"Aug. 1, 1946, ch. 724","children":[],"tail":", title I, § 225, as added "},{"tag":"ref","attrib":{"href":"/us/act/1954-08-30/ch1073/s1"},"text":"Aug. 30, 1954, ch. 1073, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/959"},"text":"68 Stat. 959","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/91/161/s3/b"},"text":"Pub. L. 91–161, § 3(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-12-24"},"text":"Dec. 24, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/444"},"text":"83 Stat. 444","children":[],"tail":"; renumbered title I, "},{"tag":"ref","attrib":{"href":"/us/pl/102/486/tIX/s902/a/8"},"text":"Pub. L. 102–486, title IX, § 902(a)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2944"},"text":"106 Stat. 2944","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/65/dC/tXXXI/s3148/b"},"text":"Pub. L. 106–65, div. C, title XXXI, § 3148(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/938"},"text":"113 Stat. 938","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc12e8dd-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc12e8de-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbc12e8df-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1999—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65"},"text":"Pub. L. 106–65","children":[],"tail":" substituted “$100,000” for “$20,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1969—","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/161"},"text":"Pub. L. 91–161","children":[],"tail":" made death penalty inapplicable for willful violation, or attempted violation of this section with intent to injure the United States, or secure an advantage for any foreign nation."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbc12e8e0-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbc12e8e1-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading