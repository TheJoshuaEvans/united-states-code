{"tag":"section","attrib":{"id":"idbfb9aab5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13311"},"text":null,"children":[{"tag":"num","attrib":{"value":"13311"},"text":"§ 13311.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purposes of this subchapter are to promote—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfb9aab6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13311/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increases in the production and utilization of energy from renewable energy resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfb9aab7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13311/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" further advances of renewable energy technologies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfb9aab8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13311/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exports of United States renewable energy technologies and services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfb9aab9-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/tXII/s1201"},"text":"Pub. L. 102–486, title XII, § 1201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2956"},"text":"106 Stat. 2956","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbfb9aaba-3a70-1