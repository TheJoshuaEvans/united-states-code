{"tag":"section","attrib":{"id":"idb7a18553-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629d"},"text":null,"children":[{"tag":"num","attrib":{"value":"629d"},"text":"§ 629d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments to States","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb7a18554-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Entitlement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each State that has a plan approved under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s629b"},"text":"section 629b of this title","children":[],"tail":" shall, subject to subsection (d), be entitled to payment of the sum of—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7a18555-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629d/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the lesser of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb7a18556-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629d/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 75 percent of the total expenditures by the State for activities under the plan during the fiscal year or the immediately succeeding fiscal year; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7a18557-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629d/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the allotment of the State under subsection (a), (b), or (c) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s629c"},"text":"section 629c of this title","children":[],"tail":", whichever is applicable, for the fiscal year; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7a18558-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629d/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the lesser of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb7a18559-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629d/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 75 percent of the total expenditures by the State in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s629f/b/3/B"},"text":"section 629f(b)(3)(B) of this title","children":[],"tail":" during the fiscal year or the immediately succeeding fiscal year; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7a1855a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629d/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the allotment of the State under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s629c/e"},"text":"section 629c(e) of this title","children":[],"tail":" for the fiscal year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7a1855b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibitions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7a1855c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629d/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No use of other Federal funds for State match","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each State receiving an amount paid under subsection (a) may not expend any Federal funds to meet the costs of services under the State plan under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s629b"},"text":"section 629b of this title","children":[],"tail":" not covered by the amount so paid."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7a1855d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629d/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State may not expend any amount paid under subsection (a) for any fiscal year after the end of the immediately succeeding fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7a1855e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629d/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Direct payments to tribal organizations of Indian tribes or tribal consortia","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall pay any amount to which an Indian tribe or tribal consortium is entitled under this section directly to the tribal organization of the Indian tribe or in the case of a payment to a tribal consortium, such tribal organizations of, or entity established by, the Indian tribes that are part of the consortium as the consortium shall designate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7a1855f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629d/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on reimbursement for administrative costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall not make a payment to a State under this section with respect to expenditures for administrative costs during a fiscal year, to the extent that the total amount of the expenditures exceeds 10 percent of the total expenditures of the State during the fiscal year under the State plan approved under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s629b"},"text":"section 629b of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb7a18560-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title IV, § 434, as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/66/tXIII/s13711/a/2"},"text":"Pub. L. 103–66, title XIII, § 13711(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-10"},"text":"Aug. 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/653"},"text":"107 Stat. 653","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/133/tI/s104"},"text":"Pub. L. 107–133, title I, § 104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-17"},"text":"Jan. 17, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/2415"},"text":"115 Stat. 2415","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/288"},"text":"Pub. L. 109–288","children":[],"tail":", §§ 3(f)(1), 4(a)(3), 5(b)(3)(B), "},{"tag":"date","attrib":{"date":"2006-09-28"},"text":"Sept. 28, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1236"},"text":"120 Stat. 1236","children":[],"tail":", 1237, 1243; "},{"tag":"ref","attrib":{"href":"/us/pl/118/258/tI/s115/b/2/C"},"text":"Pub. L. 118–258, title I, § 115(b)(2)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2969"},"text":"138 Stat. 2969","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb7a18561-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb7a18562-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb7a18563-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 434 of act ","children":[{"tag":"date","attrib":{"date":"1935-08-14"},"text":"Aug. 14, 1935","children":[],"tail":", was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s634"},"text":"section 634 of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/100/485"},"text":"Pub. L. 100–485","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb7a18564-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (a)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/258"},"text":"Pub. L. 118–258","children":[],"tail":" substituted “629f(b)(3)(B) of this title” for “629f(b)(4)(B) of this title”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/288/s4/a/3"},"text":"Pub. L. 109–288, § 4(a)(3)","children":[],"tail":", substituted “the sum of—” for “the lesser of—” in introductory provisions, added pars. (1) and (2), and struck out former pars. (1) and (2) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) 75 percent of the total expenditures by the State for activities under the plan during the fiscal year or the immediately succeeding fiscal year; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) the allotment of the State under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s629c"},"text":"section 629c of this title","children":[],"tail":" for the fiscal year.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/288/s3/f/1/A"},"text":"Pub. L. 109–288, § 3(f)(1)(A)","children":[],"tail":", inserted “, subject to subsection (d),” after “shall” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/288/s5/b/3/B"},"text":"Pub. L. 109–288, § 5(b)(3)(B)","children":[],"tail":", in heading inserted “or tribal consortia” after “tribes” and in text inserted “or tribal consortium” after “to which an Indian tribe” and “or in the case of a payment to a tribal consortium, such tribal organizations of, or entity established by, the Indian tribes that are part of the consortium as the consortium shall designate” after “of the Indian tribe”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/288/s3/f/1/B"},"text":"Pub. L. 109–288, § 3(f)(1)(B)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/133/s104/a"},"text":"Pub. L. 107–133, § 104(a)","children":[],"tail":", struck out par. (1) designation and heading after subsec. heading, substituted “Each State that has a plan approved under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s629b"},"text":"section 629b of this title","children":[],"tail":" shall be entitled to payment of the lesser of—” for “Except as provided in paragraph (2) of this subsection, each State which has a plan approved under this subpart shall be entitled to payment of the lesser of—”, redesignated subpars. (A) and (B) of former par. (1) as pars. (1) and (2), respectively, and realigned their margins, and struck out former par. (2) which related to a special rule for fiscal year 1994."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/133/s104/b/1"},"text":"Pub. L. 107–133, § 104(b)(1)","children":[],"tail":", struck out “paragraph (1) or (2)(B) of” after “amount paid under” and substituted “under the State plan under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s629b"},"text":"section 629b of this title","children":[],"tail":"” for “described in this subpart”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/133/s104/b/2"},"text":"Pub. L. 107–133, § 104(b)(2)","children":[],"tail":", substituted “subsection (a)” for “subsection (a)(1)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb7a18565-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb7a18566-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2025 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/258"},"text":"Pub. L. 118–258","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2025-10-01"},"text":"Oct. 1, 2025","children":[],"tail":", and applicable to payments under this part for calendar quarters beginning on or after such date, with delay permitted if either State legislation or tribal action is required to meet additional requirements, see "},{"tag":"ref","attrib":{"href":"/us/pl/118/258/s117"},"text":"section 117 of Pub. L. 118–258","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s622"},"text":"section 622 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb7a18567-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2006 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/288/s3/f/2"},"text":"Pub. L. 109–288, § 3(f)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-09-28"},"text":"Sept. 28, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1236"},"text":"120 Stat. 1236","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/288/s3/f/2"},"text":"“The amendments made by paragraph (1) [amending this section] shall apply to expenditures made on or after ","children":[{"tag":"date","attrib":{"date":"2007-10-01"},"text":"October 1, 2007","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/288"},"text":"Pub. L. 109–288","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2006-10-01"},"text":"Oct. 1, 2006","children":[],"tail":", except as otherwise provided, and applicable to payments under this part and part E of this subchapter for calendar quarters beginning on or after such date, without regard to whether implementing regulations have been promulgated, and with delay permitted if State legislation is required to meet additional requirements, see section 12(a), (b) of "},{"tag":"ref","attrib":{"href":"/us/pl/109/288"},"text":"Pub. L. 109–288","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s621"},"text":"section 621 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb7a18568-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2002 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/133"},"text":"Pub. L. 107–133","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2002-01-17"},"text":"Jan. 17, 2002","children":[],"tail":", with delay permitted if State legislation is required, see "},{"tag":"ref","attrib":{"href":"/us/pl/107/133/s301"},"text":"section 301 of Pub. L. 107–133","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s629"},"text":"section 629 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb7a18569-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Emergency Funding for the Marylee Allen Promoting Safe and Stable Families Program","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dX/s6"},"text":"Pub. L. 116–260, div. X, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2413"},"text":"134 Stat. 2413","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/260/dX/s6"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Out of any money in the Treasury of the United States not otherwise appropriated, there are appropriated $85,000,000 to carry out section 436(a) of the Social Security Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s629f/a"},"text":"42 U.S.C. 629f(a)","children":[],"tail":"] for fiscal year 2021, in addition to any amounts otherwise made available for such purpose. For purposes of section 436(b) of such Act, the amount made available by the preceding sentence shall be considered part of the amount specified in such section 436(a)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inapplicability of State Matching Requirement to Additional Funds","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In making payments under section 434(a) of the Social Security Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s629d/a"},"text":"42 U.S.C. 629d(a)","children":[],"tail":"] from the additional funds made available as a result of subsection (a) of this section, the percentage specified in section 434(a)(1) of such Act is deemed to be 100 percent.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
