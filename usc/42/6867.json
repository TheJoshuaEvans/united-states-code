{"tag":"section","attrib":{"id":"idbdc26e59-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6867"},"text":null,"children":[{"tag":"num","attrib":{"value":"6867"},"text":"§ 6867.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration of projects receiving financial assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbdc26e5a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6867/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in consultation with the Director, by general or special orders, may require any recipient of financial assistance under this part to provide, in such form as he may prescribe, such reports or answers in writing to specific questions, surveys, or questionnaires as may be necessary to enable the Secretary and the Director to carry out their functions under this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdc26e5b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6867/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maintenance of records","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each person responsible for the administration of a weatherization assistance project receiving financial assistance under this part shall keep such records as the Secretary may prescribe in order to assure an effective financial audit and performance evaluation of such project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdc26e5c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6867/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Audit and examination of books, etc.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, the Director (with respect to community action agencies), and the Comptroller General of the United States, or any of their duly authorized representatives, shall have access for the purpose of audit and examination to any books, documents, papers, information, and records of any project receiving financial assistance under this part that are pertinent to the financial assistance received under this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdc26e5d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6867/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Method of payments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Payments under this part may be made in installments and in advance, or by way of reimbursement, with necessary adjustments on account of overpayments or underpayments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbdc26e5e-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/385/tIV/s417"},"text":"Pub. L. 94–385, title IV, § 417","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-08-14"},"text":"Aug. 14, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1156"},"text":"90 Stat. 1156","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/294/tV/s577/2"},"text":"Pub. L. 96–294, title V, § 577(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-06-30"},"text":"June 30, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/760"},"text":"94 Stat. 760","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbdc26e5f-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbdc26e60-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbdc26e61-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1980—Subsecs. (a) to (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/294"},"text":"Pub. L. 96–294","children":[],"tail":" substituted “Secretary” for “Administrator” wherever appearing."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
