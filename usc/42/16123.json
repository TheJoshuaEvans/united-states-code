{"tag":"section","attrib":{"id":"idbff2e380-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16123"},"text":null,"children":[{"tag":"num","attrib":{"value":"16123"},"text":"§ 16123.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal procurement of stationary, portable, and micro fuel cells","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbff2e381-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16123/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of this section are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbff2e382-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16123/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to stimulate acceptance by the market of stationary, portable, and micro fuel cells; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff2e383-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16123/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to support development of technologies relating to stationary, portable, and micro fuel cells.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff2e384-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16123/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal leases and purchases","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbff2e385-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16123/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2006-01-01"},"text":"January 1, 2006","children":[],"tail":", the head of any Federal agency that uses electrical power from stationary, portable, or microportable devices shall lease or purchase a stationary, portable, or micro fuel cell to meet any applicable energy savings goal described in subsection (c)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff2e386-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16123/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Costs of leases and purchases","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbff2e387-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16123/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in cooperation with the Task Force and the Technical Advisory Committee, shall pay the cost to Federal agencies (or share the cost under interagency agreements) of leasing or purchasing stationary, portable, and micro fuel cells under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff2e388-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16123/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Competitive costs and management structures","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out subparagraph (A), the Secretary, in consultation with the agency, may use the General Services Administration or any commercial vendor to ensure—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbff2e389-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16123/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a cost-effective purchase of a stationary, portable, or micro fuel cell; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbff2e38a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16123/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a cost-effective management structure of the lease of a stationary, portable, or micro fuel cell.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff2e38b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16123/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbff2e38c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16123/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary determines that the head of an agency described in paragraph (1) cannot find an appropriately efficient and reliable stationary, portable, or micro fuel cell in accordance with paragraph (1), that agency shall be excepted from compliance with paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff2e38d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16123/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consideration","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In making a determination under subparagraph (A), the Secretary shall consider—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbff2e38e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16123/b/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the needs of the agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbff2e38f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16123/b/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an evaluation performed by—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbff2e390-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16123/b/3/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Task Force; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbff2e391-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16123/b/3/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Technical Advisory Committee of the Task Force.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff2e392-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16123/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Energy savings goals","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An agency that leases or purchases a stationary, portable, or micro fuel cell in accordance with subsection (b)(1) may use that lease or purchase to count toward an energy savings goal described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16157"},"text":"section 16157 of this title","children":[],"tail":" that is applicable to the agency."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff2e393-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16123/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is authorized to be appropriated to carry out this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbff2e394-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16123/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $20,000,000 for fiscal year 2006;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff2e395-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16123/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $50,000,000 for fiscal year 2007;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff2e396-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16123/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $75,000,000 for fiscal year 2008;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff2e397-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16123/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $100,000,000 for fiscal year 2009;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff2e398-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16123/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $100,000,000 for fiscal year 2010; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff2e399-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16123/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such sums as are necessary for each of fiscal years 2011 through 2015.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbff2e39a-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tVII/s783"},"text":"Pub. L. 109–58, title VII, § 783","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/837"},"text":"119 Stat. 837","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
