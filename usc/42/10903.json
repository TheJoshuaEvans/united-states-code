{"tag":"section","attrib":{"id":"idbf31b5f1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10903"},"text":null,"children":[{"tag":"num","attrib":{"value":"10903"},"text":"§ 10903.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf31b5f2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10903/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “eligible individual” means a candidate for the Child Development Associate credential whose income does not exceed the ","children":[{"tag":"ref","attrib":{"idref":"fn003979"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003979"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The word “the” probably should not appear."}],"tail":" 130 percent of the lower living standard income level,"},{"tag":"ref","attrib":{"idref":"fn003980"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003980"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. The comma probably should not appear."}],"tail":" by more than 50 percent;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf31b5f3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10903/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “lower living standard income level” means that income level (adjusted for regional, metropolitan, urban, and rural differences and family size) determined annually by the Secretary of Labor and based on the most recent lower living family budget issued by the Secretary of Labor;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf31b5f4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10903/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Secretary” means the Secretary of Health and Human Services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf3425f5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10903/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “State” means each of the several States, the District of Columbia, the Commonwealth of Puerto Rico, Guam, American Samoa, the Virgin Islands, the Commonwealth of the Northern Mariana Islands, the Marshall Islands, the Federated States of Micronesia, and Palau.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf3425f6-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/425/tVI/s604"},"text":"Pub. L. 99–425, title VI, § 604","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-09-30"},"text":"Sept. 30, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/976"},"text":"100 Stat. 976","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/501/tV/s502"},"text":"Pub. L. 101–501, title V, § 502","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-03"},"text":"Nov. 3, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1256"},"text":"104 Stat. 1256","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf3425f7-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf3425f8-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":