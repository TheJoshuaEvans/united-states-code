{"tag":"section","attrib":{"id":"idb6e2f0a9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–31"},"text":null,"children":[{"tag":"num","attrib":{"value":"300mm–31"},"text":"§ 300mm–31.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Identification and initial health evaluation of screening-eligible and certified-eligible WTC survivors","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb6e2f0aa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–31/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Identification of screening-eligible WTC survivors and certified-eligible WTC survivors","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6e2f0ab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–31/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Screening-eligible WTC survivors","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6e2f0ac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–31/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subchapter, the term “screening-eligible WTC survivor” means, subject to subparagraph (C) and paragraph (3), an individual who is described in any of the following clauses:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb6e2f0ad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–31/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Currently identified survivor","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An individual, including a WTC responder, who has been identified as eligible for medical treatment and monitoring by the WTC Environmental Health Center as of ","children":[{"tag":"date","attrib":{"date":"2011-01-02"},"text":"January 2, 2011","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6e2f0ae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–31/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Survivor who meets current eligibility criteria","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An individual who is not a WTC responder, for purposes of the initial health evaluation under subsection (b), claims symptoms of a WTC-related health condition and meets any of the current eligibility criteria described in subparagraph (B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6e2f0af-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–31/a/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Survivor who meets modified eligibility criteria","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An individual who is not a WTC responder, for purposes of the initial health evaluation under subsection (b), claims symptoms of a WTC-related health condition and meets such eligibility criteria relating to exposure to airborne toxins, other hazards, or adverse conditions resulting from the ","children":[{"tag":"date","attrib":{"date":"2001-09-11"},"text":"September 11, 2001","children":[],"tail":", terrorist attacks as the WTC Administrator determines, after consultation with the Data Centers described in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300mm–4"},"text":"section 300mm–4 of this title","children":[],"tail":" and the WTC Scientific/Technical Advisory Committee and WTC Health Program Steering Committees under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300mm–1"},"text":"section 300mm–1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The Administrator shall not modify such criteria under clause (iii) on or after the date that the number of certifications for certified-eligible WTC survivors under paragraph (2)(B) has reached 80 percent of the limit described in paragraph (3) or on or after the date that the number of enrollments of WTC responders has reached 80 percent of the limit described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300mm–21/a/4"},"text":"section 300mm–21(a)(4) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6e2f0b0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–31/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Current eligibility criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The eligibility criteria described in this subparagraph for an individual are that the individual is described in any of the following clauses:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb6e2f0b1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–31/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A person who was present in the New York City disaster area in the dust or dust cloud on ","children":[{"tag":"date","attrib":{"date":"2001-09-11"},"text":"September 11, 2001","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6e2f0b2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–31/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A person who worked, resided, or attended school, childcare, or adult daycare in the New York City disaster area for—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb6e2f0b3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–31/a/1/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least 4 days during the 4-month period beginning on ","children":[{"tag":"date","attrib":{"date":"2001-09-11"},"text":"September 11, 2001","children":[],"tail":", and ending on "},{"tag":"date","attrib":{"date":"2002-01-10"},"text":"January 10, 2002","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb6e2f0b4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–31/a/1/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least 30 days during the period beginning on ","children":[{"tag":"date","attrib":{"date":"2001-09-11"},"text":"September 11, 2001","children":[],"tail":", and ending on "},{"tag":"date","attrib":{"date":"2002-07-31"},"text":"July 31, 2002","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6e2f0b5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–31/a/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any person who worked as a cleanup worker or performed maintenance work in the New York City disaster area during the 4-month period described in subparagraph (B)(i) and had extensive exposure to WTC dust as a result of such work.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6e2f0b6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–31/a/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A person who was deemed eligible to receive a grant from the Lower Manhattan Development Corporation Residential Grant Program, who possessed a lease for a residence or purchased a residence in the New York City disaster area, and who resided in such residence during the period beginning on ","children":[{"tag":"date","attrib":{"date":"2001-09-11"},"text":"September 11, 2001","children":[],"tail":", and ending on "},{"tag":"date","attrib":{"date":"2003-05-31"},"text":"May 31, 2003","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6e2f0b7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–31/a/1/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A person whose place of employment—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb6e2f0b8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–31/a/1/B/v/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at any time during the period beginning on ","children":[{"tag":"date","attrib":{"date":"2001-09-11"},"text":"September 11, 2001","children":[],"tail":", and ending on "},{"tag":"date","attrib":{"date":"2003-05-31"},"text":"May 31, 2003","children":[],"tail":", was in the New York City disaster area; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb6e2f0b9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–31/a/1/B/v/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was deemed eligible to receive a grant from the Lower Manhattan Development Corporation WTC Small Firms Attraction and Retention Act program or other government incentive program designed to revitalize the lower Manhattan economy after the ","children":[{"tag":"date","attrib":{"date":"2001-09-11"},"text":"September 11, 2001","children":[],"tail":", terrorist attacks."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6e2f0ba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–31/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application and determination process for screening eligibility","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb6e2f0bb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–31/a/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The WTC Program Administrator in consultation with the Data Centers shall establish a process for individuals, other than individuals described in subparagraph (A)(i), to be determined to be screening-eligible WTC survivors. Under such process—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb6e2f0bc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–31/a/1/C/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there shall be no fee charged to the applicant for making an application for such determination;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb6e2f0bd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–31/a/1/C/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Administrator shall make a determination on such an application not later than 60 days after the date of filing the application;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb6e2f0be-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–31/a/1/C/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Administrator shall make such a determination relating to an applicant’s compliance with this subchapter and shall not determine that an individual is not so eligible or deny written documentation under clause (ii) to such individual unless the Administrator determines that—","children":[],"tail":null},{"tag":"item","attrib":{"id":"idb6e2f0bf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–31/a/1/C/i/III/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" based on the application submitted, the individual does not meet the eligibility criteria; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idb6e2f0c0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–31/a/1/C/i/III/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the numerical limitation on certifications of certified-eligible WTC survivors set forth in paragraph (3) has been met; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb6e2f0c1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–31/a/1/C/i/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an individual who is determined not to be a screening-eligible WTC survivor shall have an opportunity to appeal such determination in a manner established under such process.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6e2f0c2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–31/a/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Written documentation of screening-eligibility","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb6e2f0c3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–31/a/1/C/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of an individual who is described in subparagraph (A)(i) or who is determined under clause (i) (consistent with paragraph (3)) to be a screening-eligible WTC survivor, the WTC Program Administrator shall provide an appropriate written documentation of such fact.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb6e2f0c4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–31/a/1/C/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timing","children":[],"tail":null},{"tag":"item","attrib":{"id":"idb6e2f0c5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–31/a/1/C/ii/II/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Currently identified survivors","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of an individual who is described in subparagraph (A)(i), the WTC Program Administrator shall provide the written documentation under subclause (I) not later than ","children":[{"tag":"date","attrib":{"date":"2011-07-01"},"text":"July 1, 2011","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idb6e2f0c6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–31/a/1/C/ii/II/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other members","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of another individual who is determined under clause (i) and consistent with paragraph (3) to be a screening-eligible WTC survivor, the WTC Program Administrator shall provide the written documentation under subclause (I) at the time of such determination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6e2f0c7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–31/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certified-eligible WTC survivors","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6e2f0c8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–31/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “certified-eligible WTC survivor” means, subject to paragraph (3), a screening-eligible WTC survivor who the WTC Program Administrator certifies under subparagraph (B) to be eligible for followup monitoring and treatment under this subpart.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6e2f0c9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–31/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification of eligibility for monitoring and treatment","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb6e2f0ca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–31/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The WTC Program Administrator shall establish a certification process under which the Administrator shall provide appropriate certification to screening-eligible WTC survivors who, pursuant to the initial health evaluation under subsection (b), are determined to be eligible for followup monitoring and treatment under this subpart.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6e2f0cb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–31/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timing","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb6e2f0cc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–31/a/2/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Currently identified survivors","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of an individual who is described in paragraph (1)(A)(i), the WTC Program Administrator shall provide the certification under clause (i) not later than ","children":[{"tag":"date","attrib":{"date":"2011-07-01"},"text":"July 1, 2011","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb6e2f0cd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–31/a/2/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other members","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of another individual who is determined under clause (i) to be eligible for followup monitoring and treatment, the WTC Program Administrator shall provide the certification under such clause at the time of such determination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6e2f0ce-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–31/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Numerical limitation on certified-eligible WTC survivors","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6e2f0cf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–31/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The total number of individuals not described in paragraph (1)(A)(i) who may be certified as certified-eligible WTC survivors under paragraph (2)(B) shall not exceed 75,000 at any time.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6e2f0d0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–31/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Process","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In implementing subparagraph (A), the WTC Program Administrator shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb6e2f0d1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–31/a/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" limit the number of certifications provided under paragraph (2)(B)—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb6e2f0d2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–31/a/3/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in accordance with such subparagraph; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb6e2f0d3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–31/a/3/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to such number, as determined by the Administrator based on the best available information and subject to amounts made available under this subchapter, that will ensure sufficient funds will be available to provide treatment and monitoring benefits under this subchapter, with respect to all individuals receiving such certifications; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6e2f0d4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–31/a/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide priority in such certifications in the order in which individuals apply for a determination under paragraph (2)(B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6e2f0d5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–31/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disqualification of individuals on terrorist watch list","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No individual who is on the terrorist watch list maintained by the Department of Homeland Security shall qualify as a screening-eligible WTC survivor or a certified-eligible WTC survivor. Before determining any individual to be a screening-eligible WTC survivor under paragraph (1) or certifying any individual as a certified eligible ","children":[{"tag":"ref","attrib":{"idref":"fn002547"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002547"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “certified-eligible”."}],"tail":" WTC survivor under paragraph (2), the Administrator, in consultation with the Secretary of Homeland Security, shall determine whether the individual is on such list."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6e2f0d6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–31/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial health evaluation to determine eligibility for followup monitoring or treatment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6e2f0d7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–31/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a screening-eligible WTC survivor, the WTC Program shall provide for an initial health evaluation to determine if the survivor has a WTC-related health condition and is eligible for followup monitoring and treatment benefits under the WTC Program. Initial health evaluation protocols under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300mm–4/a/2/A/ii"},"text":"section 300mm–4(a)(2)(A)(ii) of this title","children":[],"tail":" shall be subject to approval by the WTC Program Administrator."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6e2f0d8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–31/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial health evaluation providers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The initial health evaluation described in paragraph (1) shall be provided through a Clinical Center of Excellence with respect to the individual involved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6e2f0d9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–31/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on initial health evaluation benefits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Benefits for an initial health evaluation under this subpart for a screening-eligible WTC survivor shall consist only of a single medical initial health evaluation consistent with initial health evaluation protocols described in paragraph (1). Nothing in this paragraph shall be construed as preventing such an individual from seeking additional medical initial health evaluations at the expense of the individual.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb6e2f0da-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XXXIII, § 3321, as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/347/tI/s101"},"text":"Pub. L. 111–347, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-02"},"text":"Jan. 2, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3648"},"text":"124 Stat. 3648","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/113/dO/tIII/s302/f"},"text":"Pub. L. 114–113, div. O, title III, § 302(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-18"},"text":"Dec. 18, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/3000"},"text":"129 Stat. 3000","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/59/dB/tVI/s1602/b"},"text":"Pub. L. 116–59, div. B, title VI, § 1602(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-09-27"},"text":"Sept. 27, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1107"},"text":"133 Stat. 1107","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dFF/tVII/s7701/b/2"},"text":"Pub. L. 117–328, div. FF, title VII, § 7701(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5965"},"text":"136 Stat. 5965","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tXVIII/s1851/c/2"},"text":"Pub. L. 118–31, div. A, title XVIII, § 1851(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/708"},"text":"137 Stat. 708","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb6e2f0db-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb6e2f0dc-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb6e2f0dd-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2023—Subsec. (a)(3)(B)(i)(II). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31"},"text":"Pub. L. 118–31","children":[],"tail":" substituted “this subchapter” for “sections 300mm–61 and 300mm–62 of this title”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2022—Subsec. (a)(3)(B)(i)(II). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328"},"text":"Pub. L. 117–328","children":[],"tail":" substituted “sections 300mm–61 and 300mm–62 of this title” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300mm–61"},"text":"section 300mm–61 of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2019—Subsec. (a)(3)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/59"},"text":"Pub. L. 116–59","children":[],"tail":" substituted “75,000” for “25,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2015—Subsec. (a)(3)(B)(i)(II). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/113"},"text":"Pub. L. 114–113","children":[],"tail":" struck out “through the end of fiscal year 2020” after “certifications”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb6e2f0de-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb6e2f0df-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Rule of Construction","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Nothing in amendment made by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/59"},"text":"Pub. L. 116–59","children":[],"tail":" to alter the annual limitations on amounts appropriated to the World Trade Center Health Program Fund under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300mm–61/a/2"},"text":"section 300mm–61(a)(2) of this title","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/116/59/s1602/c"},"text":"section 1602(c) of Pub. L. 116–59","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300mm–21"},"text":"section 300mm–21 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
