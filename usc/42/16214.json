{"tag":"section","attrib":{"id":"idbffa0ea1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16214"},"text":null,"children":[{"tag":"num","attrib":{"value":"16214"},"text":"§ 16214.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distributed energy technology demonstration programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbffa0ea2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16214/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordinating consortia program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may provide financial assistance to coordinating consortia of interdisciplinary participants for demonstrations designed to accelerate the use of distributed energy technologies (such as fuel cells, microturbines, reciprocating engines, thermally activated technologies, and combined heat and power systems) in high-energy intensive commercial applications.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbffa0ea3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16214/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Small-scale portable power program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbffa0ea4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16214/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbffa0ea5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16214/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish a research, development, and demonstration program to develop working models of small scale portable power devices; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbffa0ea6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16214/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the fullest extent practicable, identify and utilize the resources of universities that have shown expertise with respect to advanced portable power devices for either civilian or military use.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbffa0ea7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16214/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Organization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The universities identified and utilized under paragraph (1)(B) are authorized to establish an organization to promote small scale portable power devices.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbffa0ea8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16214/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subsection, the term “small scale portable power device” means a field-deployable portable mechanical or electromechanical device that can be used for applications such as communications, computation, mobility enhancement, weapons systems, optical devices, cooling, sensors, medical devices, and active biological agent detection systems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbffa0ea9-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tIX/s924"},"text":"Pub. L. 109–58, title IX, § 924","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/865"},"text":"119 Stat. 865","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
