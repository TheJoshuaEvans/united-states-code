{"tag":"section","attrib":{"id":"idb66227c2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300w–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"300w–2"},"text":"§ 300w–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments under allotments to States","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb66227c3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300w–2/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb66227c4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300w–2/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For each fiscal year, the Secretary shall make payments, as provided by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s6503/a"},"text":"section 6503(a) of title 31","children":[],"tail":", to each State from its allotment under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300w–1"},"text":"section 300w–1 of this title","children":[],"tail":" (other than any amount reserved under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300w–1/d"},"text":"section 300w–1(d) of this title","children":[],"tail":") from amounts appropriated for that fiscal year."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb66227c5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300w–2/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any amount paid to a State for a fiscal year and remaining unobligated at the end of such year shall remain available for the next fiscal year to such State for the purposes for which it was made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb66227c6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300w–2/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary, at the request of a State, may reduce the amount of payments under subsection (a) by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb66227c7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300w–2/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the fair market value of any supplies or equipment furnished the State, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb66227c8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300w–2/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of the pay, allowances, and travel expenses of any officer or employee of the Government when detailed to the State and the amount of any other costs incurred in connection with the detail of such officer or employee,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"when the furnishing of supplies or equipment or the detail of an officer or employee is for the convenience of and at the request of the State and for the purpose of conducting activities described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300w–3"},"text":"section 300w–3 of this title","children":[],"tail":". The amount by which any payment is so reduced shall be available for payment by the Secretary of the costs incurred in furnishing the supplies or equipment or in detailing the personnel, on which the reduction of the payment is based, and the amount shall be deemed to be part of the payment and shall be deemed to have been paid to the State."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb66227c9-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XIX, § 1903, as added "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tIX/s901"},"text":"Pub. L. 97–35, title IX, § 901","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/537"},"text":"95 Stat. 537","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb66227ca-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb66227cb-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb66227cc-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsec. (a)(1), “","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s6503/a"},"text":"section 6503(a) of title 31","children":[],"tail":"” substituted for “section 203 of the Intergovernmental Cooperation Act of 1968 ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4213"},"text":"42 U.S.C. 4213","children":[],"tail":")” on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/97/258/s4/b"},"text":"Pub. L. 97–258, § 4(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1067"},"text":"96 Stat. 1067","children":[],"tail":", the first section of which enacted Title 31, Money and Finance."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb66227cd-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb66227ce-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1981-10-01"},"text":"Oct. 1, 1981","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/s901"},"text":"section 901 of Pub. L. 97–35","children":[],"tail":", set out in part as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300w"},"text":"section 300w of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
