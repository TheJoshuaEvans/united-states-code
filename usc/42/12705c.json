{"tag":"section","attrib":{"id":"idbf983f1a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12705c"},"text":null,"children":[{"tag":"num","attrib":{"value":"12705c"},"text":"§ 12705c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants for regulatory barrier removal strategies and implementation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf983f1b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12705c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated for grants under subsections (b) and (c) ","children":[{"tag":"ref","attrib":{"idref":"fn004102"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004102"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" such sums as may be necessary for each of fiscal years 2001, 2002, 2003, 2004, and 2005."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf983f1c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12705c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant authority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may make grants to States and units of general local government (including consortia of such governments) for the costs of developing and implementing strategies to remove regulatory barriers to affordable housing, including the costs of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf983f1d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12705c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying, assessing, and monitoring State and local regulatory barriers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf983f1e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12705c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying State and local policies (including laws and regulations) that permit or encourage regulatory barriers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf983f1f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12705c/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing legislation to provide State, local, or regional programs to reduce regulatory barriers and developing a strategy for adoption of such legislation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf983f20-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12705c/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing model State or local standards and ordinances to reduce regulatory barriers and assisting in the adoption and use of the standards and ordinances;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf983f21-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12705c/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carrying out the simplification and consolidation of administrative procedures and processes constituting regulatory barriers to affordable housing, including the issuance of permits; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf983f22-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12705c/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing technical assistance and information to units of general local government for implementation of legislative and administrative reform programs to remove regulatory barriers to affordable housing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf983f23-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12705c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repealed. ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/569/tI/s102/c"},"text":"Pub. L. 106–569, title I, § 102(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-27"},"text":"Dec. 27, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2947"},"text":"114 Stat. 2947","children":[],"tail":null}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf983f24-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12705c/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the terms “regulatory barriers to affordable housing” and “regulatory barriers” have the meaning given such terms in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12705b"},"text":"section 12705b of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf983f25-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12705c/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application and selection","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide for the form and manner of applications for grants under this section, which shall describe how grant amounts will assist the State or unit of general local government in developing and implementing strategies to remove regulatory barriers to affordable housing. The Secretary shall establish criteria for approval of applications under this subsection and such criteria shall require that grant amounts be used in a manner consistent with the strategy contained in the comprehensive housing affordability strategy for the jurisdiction pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12705/b/4"},"text":"section 12705(b)(4) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf983f26-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12705c/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection of grantees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the extent amounts are made available to carry out this section, the Secretary shall provide grants on a competitive basis to eligible grantees based on the proposed uses of such amounts, as provided in applications under subsection (e).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf983f27-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12705c/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with clearinghouse","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each State and unit of general local government receiving a grant under this section, shall consult, coordinate, and exchange information with the clearinghouse established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12705d"},"text":"section 12705d of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf983f28-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12705c/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports to Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each State and unit of general local government receiving a grant under this section shall submit a report to the Secretary, not less than 12 months after receiving the grant, describing any activities carried out with the grant amounts. The report shall contain an assessment of the impact of any regulatory barriers identified by the grantee on the housing patterns of minorities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf983f29-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550/tXII/s1204"},"text":"Pub. L. 102–550, title XII, § 1204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3938"},"text":"106 Stat. 3938","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/569/tI/s102/a"},"text":"Pub. L. 106–569, title I, § 102(a)","children":[],"tail":"–(e), "},{"tag":"date","attrib":{"date":"2000-12-27"},"text":"Dec. 27, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2946"},"text":"114 Stat. 2946","children":[],"tail":", 2947.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf983f2a-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf983f2b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbf983f2c-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Subsection (c) of this section, referred to in subsec. (a), was repealed by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/569/tI/s102/c"},"text":"Pub. L. 106–569, title I, § 102(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-27"},"text":"Dec. 27, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2947"},"text":"114 Stat. 2947","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbf983f2d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Removal of Regulatory Barriers to Affordable Housing Act of 1992, and also as part of the Housing and Community Development Act of 1992, and not as part of the Cranston-Gonzalez National Affordable Housing Act which comprises this chapter.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550/s1204"},"text":"section 1204 of Pub. L. 102–550","children":[],"tail":". Subsection (i) of "},{"tag":"ref","attrib":{"href":"/us/pl/102/550/s1204"},"text":"section 1204 of Pub. L. 102–550","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5306"},"text":"section 5306 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbf983f2e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/569/s102/a"},"text":"Pub. L. 106–569, § 102(a)","children":[],"tail":", amended heading and text of subsec. (a) generally. Prior to amendment, text read as follows: “The amounts set aside under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5307"},"text":"section 5307 of this title","children":[],"tail":" for the purpose of this subsection shall be available for grants under subsection (b) and (c) of this section.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/569/s102/b/1"},"text":"Pub. L. 106–569, § 102(b)(1)","children":[],"tail":", (2), substituted “Grant authority” for “State grants” in heading and inserted “and units of general local government (including consortia of such governments)” after “States” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/569/s102/b/3"},"text":"Pub. L. 106–569, § 102(b)(3)","children":[],"tail":", substituted “State, local, or regional programs to reduce” for “a State program to reduce State and local”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/569/s102/b/4"},"text":"Pub. L. 106–569, § 102(b)(4)","children":[],"tail":", inserted “or local” after “State”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/569/s102/b/5"},"text":"Pub. L. 106–569, § 102(b)(5)","children":[],"tail":", struck out “State” before “administrative procedures”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/569/s102/c"},"text":"Pub. L. 106–569, § 102(c)","children":[],"tail":", struck out heading and text of subsec. (c) which related to local grants."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/569/s102/d"},"text":"Pub. L. 106–569, § 102(d)","children":[],"tail":", substituted “and such criteria shall require that grant amounts be used in a manner consistent with the strategy contained in the comprehensive housing affordability strategy for the jurisdiction pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12705/b/4"},"text":"section 12705(b)(4) of this title","children":[],"tail":"” for “and for the selection of units of general local government to receive grants under subsection (f)(2) of this section” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/569/s102/e"},"text":"Pub. L. 106–569, § 102(e)","children":[],"tail":", amended heading and text of subsec. (f) generally, substituting provisions relating to selection of grantees for provisions relating to allocation of amounts."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
