{"tag":"section","attrib":{"id":"idbe05442d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381c–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"7381c–3"},"text":"§ 7381c–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expanding opportunities for highly skilled science, technology, engineering, and mathematics (STEM) professionals","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbe05442e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381c–3/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe05442f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381c–3/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expand opportunities and increase the number of highly skilled science, technology, engineering, and mathematics (STEM) professionals working in disciplines relevant to the mission of the Department; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe054430-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381c–3/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" broaden the recruitment pool to increase participation from and expand partnerships with Historically Black Colleges or Universities, Hispanic serving institutions, Tribal Colleges or Universities, minority-serving institutions, institutions in eligible jurisdictions, emerging research institutions, community colleges, and scientific societies in those disciplines.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe054431-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381c–3/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plan and outreach strategy","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe054432-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381c–3/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plan","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbe054433-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381c–3/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2022-08-09"},"text":"August 9, 2022","children":[],"tail":", the Secretary shall submit to the Committee on Science, Space, and Technology of the House of Representatives and the Committee on Energy and Natural Resources of the Senate a 10-year educational plan to fund and expand new or existing programs administered by the Office of Science and sited at the National Laboratories and Department user facilities to expand educational and workforce development opportunities for underrepresented individuals, including—"}],"tail":null},{"tag":"clause","attrib":{"id":"idbe054434-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381c–3/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" high school, undergraduate, and graduate students; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbe054435-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381c–3/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recent graduates, teachers, and faculty in STEM fields.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe054436-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381c–3/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The plan under subparagraph (A) may include paid internships, fellowships, temporary employment, training programs, visiting student and faculty programs, sabbaticals, and research support.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe054437-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381c–3/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Outreach capacity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall include in the plan under paragraph (1) an outreach strategy to improve the advertising, recruitment, and promotion of educational and workforce development programs to community colleges, Historically Black Colleges or Universities, Hispanic-serving institutions, Tribal Colleges or Universities, minority-serving institutions, institutions in eligible jurisdictions, and emerging research institutions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe054438-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381c–3/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Building research capacity","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe054439-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381c–3/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall develop programs that strengthen the research capacity relevant to Office of Science disciplines at emerging research institutions, including minority-serving institutions, Tribal Colleges or Universities, Historically Black Colleges or Universities, institutions in eligible jurisdictions (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s13503/b/3/A"},"text":"section 13503(b)(3)(A) of this title","children":[],"tail":"), institutions in communities with dislocated workers who were previously employed in manufacturing, energy production, including coal power plants, and mineral and material mining, and other institutions of higher education."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe05443a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381c–3/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The programs developed under paragraph (1) may include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbe05443b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381c–3/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enabling mutually beneficial and jointly managed partnerships between research-intensive institutions and emerging research institutions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe05443c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381c–3/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" soliciting research proposals, fellowships, training programs, and research support directly from emerging research institutions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe05443d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381c–3/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Traineeships","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe05443e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381c–3/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a university-led Traineeship Program to address workforce development needs in STEM fields relevant to the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe05443f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381c–3/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Focus","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The focus of the Traineeship Program established under paragraph (1) shall be on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbe054440-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381c–3/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supporting workforce development and research experiences for underrepresented undergraduate and graduate students; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe054441-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381c–3/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increasing participation from underrepresented populations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe054442-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381c–3/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The traineeships under the Traineeship Program established under paragraph (1) shall include opportunities to build the next-generation workforce in research areas critical to maintaining core competencies across the programs of the Office of Science.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe054443-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381c–3/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe054444-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381c–3/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish key performance indicators to measure and monitor progress of education and workforce programs and expand Departmental activities for data collection and analysis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe054445-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381c–3/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2022-08-09"},"text":"August 9, 2022","children":[],"tail":", and every 2 years thereafter, the Secretary shall submit to the Committee on Science, Space, and Technology and the Committee on Education and Labor of the House of Representatives and the Committee on Energy and Natural Resources and the Committee on Health, Education, Labor, and Pensions of the Senate a report summarizing progress toward meeting the key performance indicators established under paragraph (1)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe054446-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381c–3/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe054447-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381c–3/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Community college","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “community college” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbe054448-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381c–3/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a public institution of higher education, including additional locations, at which the highest awarded degree, or the predominantly awarded degree, is an associate degree; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe054449-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381c–3/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any Tribal college or university.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe05444a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381c–3/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dislocated worker","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “dislocated worker” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3102"},"text":"section 3102 of title 29","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe05444b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381c–3/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hispanic-serving institution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Hispanic-serving institution” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1101a/a"},"text":"section 1101a(a) of title 20","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe05444c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381c–3/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Historically Black College or University","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Historically Black College or University” has the meaning given the term “part B institution” in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1061"},"text":"section 1061 of title 20","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe05444d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381c–3/f/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Institution in an eligible jurisdiction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “institution in an eligible jurisdiction” means an institution of higher education (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of title 20","children":[],"tail":") that is located in an eligible jurisdiction (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s13503/b/3/A"},"text":"section 13503(b)(3)(A) of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe05444e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381c–3/f/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minority-serving institution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “minority-serving institution” includes the entities described in any of paragraphs (1) through (7) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1067q/a"},"text":"section 1067q(a) of title 20","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe05444f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381c–3/f/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" STEM","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “STEM” means the subjects listed in section 2 of the STEM Education Act of 2015 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6621"},"text":"42 U.S.C. 6621","children":[],"tail":" note; "},{"tag":"ref","attrib":{"href":"/us/pl/114/59"},"text":"Public Law 114–59","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe054450-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381c–3/f/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tribal College or University","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Tribal College or University” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1059c/b"},"text":"section 1059c(b) of title 20","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbe054451-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510/dC/tXXXI/s3167B"},"text":"Pub. L. 101–510, div. C, title XXXI, § 3167B","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/tI/s10111/c/1"},"text":"Pub. L. 117–167, div. B, title I, § 10111(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1457"},"text":"136 Stat. 1457","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbe054452-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbe054453-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idbe054454-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Education and Labor of House of Representatives changed to Committee on Education and the Workforce of House of Representatives by House Resolution No. 5, One Hundred Eighteenth Congress, ","children":[{"tag":"date","attrib":{"date":"2023-01-09"},"text":"Jan. 9, 2023","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
