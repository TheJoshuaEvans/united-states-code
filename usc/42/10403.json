{"tag":"section","attrib":{"id":"idbf28189f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10403"},"text":null,"children":[{"tag":"num","attrib":{"value":"10403"},"text":"§ 10403.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf2818a0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10403/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Formula grants to States","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf2818a1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10403/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out sections 10401 through 10412 of this title, $175,000,000 for each of fiscal years 2011 through 2015.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf2818a2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10403/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocations","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf2818a3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10403/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Formula grants to States","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbf2818a4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10403/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reservation of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For any fiscal year for which the amounts appropriated under paragraph (1) exceed $130,000,000, not less than 25 percent of such excess funds shall be made available to carry out ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s10412"},"text":"section 10412 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf2818a5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10403/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Formula grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the amounts appropriated under paragraph (1) for a fiscal year and not reserved under clause (i), not less than 70 percent shall be used for making grants under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s10406/a"},"text":"section 10406(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf2818a6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10403/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants to tribes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the amounts appropriated under paragraph (1) for a fiscal year and not reserved under subparagraph (A)(i), not less than 10 percent shall be used to carry out ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s10409"},"text":"section 10409 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf2818a7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10403/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance and training centers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the amounts appropriated under paragraph (1) for a fiscal year and not reserved under subparagraph (A)(i), not less than 6 percent shall be used by the Secretary for making grants under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s10410"},"text":"section 10410 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf2818a8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10403/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants for State Domestic Violence Coalitions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the amounts appropriated under paragraph (1) for a fiscal year and not reserved under subparagraph (A)(i), not less than 10 percent of such amounts shall be used by the Secretary for making grants under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s10411"},"text":"section 10411 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf2818a9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10403/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration, evaluation and monitoring","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the amount appropriated under paragraph (1) for a fiscal year and not reserved under subparagraph (A)(i), not more than 2.5 percent shall be used by the Secretary for evaluation, monitoring, and other administrative costs under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf2818aa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10403/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National domestic violence hotline","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s10413"},"text":"section 10413 of this title","children":[],"tail":" $3,500,000 for each of fiscal years 2011 through 2015."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf2818ab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10403/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Domestic Violence Prevention Enhancement and Leadership Through Alliances","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s10414"},"text":"section 10414 of this title","children":[],"tail":" $6,000,000 for each of fiscal years 2011 through 2015."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf2818ac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10403/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional funding","children":[],"tail":null},{"tag":"chape