},{"tag":"ref","attrib":{"href":"/us/usc/t42/s10408/d"},"text":"section 10408(d) of this title","children":[],"tail":"."}],"tail":" of this title shall not apply; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf2818b0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10403/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each reference in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s10405/e"},"text":"section 10405(e) of this title","children":[],"tail":" to “the end of the following fiscal year” shall be considered to be a reference to “the end of fiscal year 2025”; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf2818b1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10403/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" funds made available to a State in a grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s10406/a"},"text":"section 10406(a) of this title","children":[],"tail":" and obligated in a timely manner shall be available for expenditure, by the State or a recipient of funds from the grant, through the end of fiscal year 2025;"},{"tag":"ref","attrib":{"idref":"fn003964"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003964"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. The semicolon probably should be a period."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf2818b2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10403/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $18,000,000 to carry out ","children":[{"tag":"ref","attrib