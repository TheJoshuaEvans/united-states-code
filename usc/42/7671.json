{"tag":"section","attrib":{"id":"idbe671283-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7671"},"text":null,"children":[{"tag":"num","attrib":{"value":"7671"},"text":"§ 7671.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe671284-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7671/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appliance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “appliance” means any device which contains and uses a class I or class II substance as a refrigerant and which is used for household or commercial purposes, including any air conditioner, refrigerator, chiller, or freezer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe671285-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7671/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Baseline year","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “baseline year” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbe671286-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7671/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the calendar year 1986, in the case of any class I substance listed in Group I or II under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7671a/a"},"text":"section 7671a(a) of this title","children":[],"tail":","}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe671287-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7671/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the calendar year 1989, in the case of any class I substance listed in Group III, IV, or V under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7671a/a"},"text":"section 7671a(a) of this title","children":[],"tail":", and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe671288-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7671/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a representative calendar year selected by the Administrator, in the case of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbe671289-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7671/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any substance added to the list of class I substances after the publication of the initial list under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7671a/a"},"text":"section 7671a(a) of this title","children":[],"tail":", and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbe67128a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7671/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any class II substance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe67128b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7671/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Class I substance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “class I substance” means each of the substances listed as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7671a/a"},"text":"section 7671a(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe67128c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7671/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Class II substance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “class II substance” means each of the substances listed as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7671a/b"},"text":"section 7671a(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe67128d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7671/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commissioner","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Commissioner” means the Commissioner of the Food and Drug Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe67128e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7671/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consumption","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “consumption” means, with respect to any substance, the amount of that substance produced in the United States, plus the amount imported, minus the amount exported to Parties to the Montreal Protocol. Such term shall be construed in a manner consistent with the Montreal Protocol.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe67128f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7671/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Import","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “import” means to land on, bring into, or introduce into, or attempt to land on, bring into, or introduce into, any place subject to the jurisdiction of the United States, whether or not such landing, bringing, or introduction constitutes an importation within the meaning of the customs laws of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe671290-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7671/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Medical device","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “medical device” means any device (as defined in the Federal Food, Drug, and Cosmetic Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s321"},"text":"21 U.S.C. 321","children":[],"tail":")), diagnostic product, drug (as defined in the Federal Food, Drug, and Cosmetic Act), and drug delivery system—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbe671291-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7671/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if such device, product, drug, or drug delivery system utilizes a class I or class II substance for which no safe and effective alternative has been developed, and where necessary, approved by the Commissioner; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe671292-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7671/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if such device, product, drug, or drug delivery system, has, after notice and opportunity for public comment, been approved and determined to be essential by the Commissioner in consultation with the Administrator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe671293-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7671/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Montreal Protocol","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “Montreal Protocol” and “the Protocol” mean the Montreal Protocol on Substances that Deplete the Ozone Layer, a protocol to the Vienna Convention for the Protection of the Ozone Layer, including adjustments adopted by Parties thereto and amendments that have entered into force.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe671294-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7671/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ozone-depletion potential","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “ozone-depletion potential” means a factor established by the Administrator to reflect the ozone-depletion potential of a substance, on a mass per kilogram basis, as compared to chlorofluorocarbon-11 (CFC–11). Such factor shall be based upon the substance’s atmospheric lifetime, the molecular weight of bromine and chlorine, and the substance’s ability to be photolytically disassociated, and upon other factors determined to be an accurate measure of relative ozone-depletion potential.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe671295-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7671/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Produce, produced, and production","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The terms “produce”, “produced”, and “production”, refer to the manufacture of a substance from any raw material or feedstock chemical, but such terms do not include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbe671296-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7671/11/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the manufacture of a substance that is used and entirely consumed (except for trace quantities) in the manufacture of other chemicals, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe671297-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7671/11/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reuse or recycling of a substance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbe671298-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1955-07-14/ch360"},"text":"July 14, 1955, ch. 360","children":[],"tail":", title VI, § 601, as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/549/tVI/s602/a"},"text":"Pub. L. 101–549, title VI, § 602(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-15"},"text":"Nov. 15, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2649"},"text":"104 Stat. 2649","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbe671299-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbe67129a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbe67129b-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Food, Drug, and Cosmetic Act, referred to in par. (8), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch675"},"text":"act June 25, 1938, ch. 675","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/52/1040"},"text":"52 Stat. 1040","children":[],"tail":", which is classified generally to chapter 9 (§ 301 et seq.) of Title 21, Food and Drugs. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s301"},"text":"section 301 of Title 21","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
