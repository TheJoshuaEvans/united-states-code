{"tag":"section","attrib":{"id":"idbc93b29e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3611"},"text":null,"children":[{"tag":"num","attrib":{"value":"3611"},"text":"§ 3611.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subpoenas; giving of evidence","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbc93b29f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3611/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may, in accordance with this subsection, issue subpoenas and order discovery in aid of investigations and hearings under this subchapter. Such subpoenas and discovery may be ordered to the same extent and subject to the same limitations as would apply if the subpoenas or discovery were ordered or served in aid of a civil action in the United States district court for the district in which the investigation is taking place.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc93b2a0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3611/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Witness fees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Witnesses summoned by a subpoena under this subchapter shall be entitled to the same witness and mileage fees as witnesses in proceedings in United States district courts. Fees payable to a witness summoned by a subpoena issued at the request of a party shall be paid by that party or, where a party is unable to pay the fees, by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc93b2a1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3611/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criminal penalties","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc93b2a2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3611/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any person who willfully fails or neglects to attend and testify or to answer any lawful inquiry or to produce records, documents, or other evidence, if it is in such person’s power to do so, in obedience to the subpoena or other lawful order under subsection (a), shall be fined not more than $100,000 or imprisoned not more than one year, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc93b2a3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3611/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Any person who, with intent thereby to mislead another person in any proceeding under this subchapter—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc93b2a4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3611/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" makes or causes to be made any false entry or statement of fact in any report, account, record, or other document produced pursuant to subpoena or other lawful order under subsection (a);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc93b2a5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3611/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" willfully neglects or fails to make or to cause to be made full, true, and correct entries in such reports, accounts, records, or other documents; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc93b2a6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3611/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" willfully mutilates, alters, or by any other means falsifies any documentary evidence;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be fined not more than $100,000 or imprisoned not more than one year, or both.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc93b2a7-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/284/tVIII/s811"},"text":"Pub. L. 90–284, title VIII, § 811","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/430/s8/2"},"text":"Pub. L. 100–430, § 8(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-09-13"},"text":"Sept. 13, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1628"},"text":"102 Stat. 1628","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc93b2a8-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc93b2a9-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbc93b2aa-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 3611, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/284/tVIII/s811"},"text":"Pub. L. 90–284, title VIII, § 811","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-04-11"},"text":"Apr. 11, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/87"},"text":"82 Stat. 87","children":[],"tail":", related to evidence, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/100/430/s8/2"},"text":"Pub. L. 100–430, § 8(2)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbc93b2ab-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbc93b2ac-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on 180th day beginning after ","children":[{"tag":"date","attrib":{"date":"1988-09-13"},"text":"Sept. 13, 1988","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/430/s13/a"},"text":"section 13(a) of Pub. L. 100–430","children":[],"tail":", set out as an Effective Date of 1988 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3601"},"text":"section 3601 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
