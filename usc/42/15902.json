{"tag":"section","attrib":{"id":"idbfe6fb80-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15902"},"text":null,"children":[{"tag":"num","attrib":{"value":"15902"},"text":"§ 15902.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program on oil and gas royalties in-kind","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfe6fb81-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15902/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of section","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of law, this section applies to all royalty in-kind accepted by the Secretary on or after ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":", under any Federal oil or gas lease or permit under—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfe6fb82-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15902/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t30/s192"},"text":"section 192 of title 30","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe6fb83-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15902/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1353"},"text":"section 1353 of title 43","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe6fb84-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15902/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other Federal law governing leasing of Federal land for oil and gas development.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfe6fb85-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15902/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms and conditions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"All royalty accruing to the United States shall, on the demand of the Secretary, be paid in-kind. If the Secretary makes such a demand, the following provisions apply to the payment:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfe6fb86-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15902/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Satisfaction of royalty obligation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Delivery by, or on behalf of, the lessee of the royalty amount and quality due under the lease satisfies royalty obligation of the lessee for the amount delivered, except that transportation and processing reimbursements paid to, or deductions claimed by, the lessee shall be subject to review and audit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe6fb87-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15902/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Marketable condition","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfe6fb88-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15902/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of marketable condition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this paragraph, the term “in marketable condition” means sufficiently free from impurities and otherwise in a condition that the royalty production will be accepted by a purchaser under a sales contract typical of the field or area in which the royalty production was produced.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfe6fb89-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15902/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Royalty production shall be placed in marketable condition by the lessee at no cost to the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe6fb8a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15902/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposition by the Secretary","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfe6fb8b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15902/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sell or otherwise dispose of any royalty production taken in-kind (other than oil or gas transferred under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1353/a/3"},"text":"section 1353(a)(3) of title 43","children":[],"tail":" "},{"tag":"ref","attrib":{"idref":"fn004194"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004194"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be followed by a closing parenthesis."}],"tail":" for not less than the market price; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfe6fb8c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15902/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transport or process (or both) any royalty production taken in-kind.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe6fb8d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15902/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retention by the Secretary","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may, notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3302"},"text":"section 3302 of title 31","children":[],"tail":", retain and use a portion of the revenues from the sale of oil and gas taken in-kind that otherwise would be deposited to miscellaneous receipts, without regard to fiscal year limitation, or may use oil or gas received as royalty taken in-kind (referred to in this paragraph as “royalty production”) to pay the cost of—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfe6fb8e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15902/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transporting the royalty production;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfe6fb8f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15902/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" processing the royalty production;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfe6fb90-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15902/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disposing of the royalty production; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfe6fb91-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15902/b/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any combination of transporting, processing, and disposing of the royalty production.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe6fb92-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15902/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfe6fb93-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15902/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subparagraph (B), the Secretary may not use revenues from the sale of oil and gas taken in-kind to pay for personnel, travel, or other administrative costs of the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfe6fb94-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15902/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding subparagraph (A), the Secretary may use a portion of the revenues from royalty in-kind sales, without fiscal year limitation, to pay salaries and other administrative costs directly related to the royalty in-kind program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfe6fb95-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15902/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimbursement of cost","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the lessee, pursuant to an agreement with the United States or as provided in the lease, processes the royalty gas or delivers the royalty oil or gas at a point not on or adjacent to the lease area, the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfe6fb96-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15902/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reimburse the lessee for the reasonable costs of transportation (not including gathering) from the lease to the point of delivery or for processing costs; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe6fb97-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15902/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allow the lessee to deduct the transportation or processing costs in reporting and paying royalties in-value for other Federal oil and gas leases.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfe6fb98-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15902/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Benefit to the United States required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may receive oil or gas royalties in-kind only if the Secretary determines that receiving royalties in-kind provides benefits to the United States that are greater than or equal to the benefits that are likely to have been received had royalties been taken in-value.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfe6fb99-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15902/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deduction of expenses","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfe6fb9a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15902/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Before making payments under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t30/s191"},"text":"section 191 of title 30","children":[],"tail":" or "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1337/g"},"text":"section 1337(g) of title 43","children":[],"tail":" of revenues derived from the sale of royalty production taken in-kind from a lease, the Secretary shall deduct amounts paid or deducted under subsections (b)(4) and (c) and deposit the amount of the deductions in the miscellaneous receipts of the Treasury."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe6fb9b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15902/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Accounting for deductions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"When the Secretary allows the lessee to deduct transportation or processing costs under subsection (c), the Secretary may not reduce any payments to recipients of revenues derived from any other Federal oil and gas lease as a consequence of that deduction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfe6fb9c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15902/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation with States","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfe6fb9d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15902/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall consult with a State before conducting a royalty in-kind program under this part within the State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe6fb9e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15902/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may delegate management of any portion of the Federal royalty in-kind program to the State except as otherwise prohibited by Federal law; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe6fb9f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15902/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall consult annually with any State from which Federal oil or gas royalty is being taken in-kind to ensure, to the maximum extent practicable, that the royalty in-kind program provides revenues to the State greater than or equal to the revenues likely to have been received had royalties been taken in-value.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfe6fba0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15902/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Small refineries","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfe6fba1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15902/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preference","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary finds that sufficient supplies of crude oil are not available in the open market to refineries that do not have their own source of supply for crude oil, the Secretary may grant preference to those refineries in the sale of any royalty oil accruing or reserved to the United States under Federal oil and gas leases issued under any mineral leasing law, for processing or use in those refineries at private sale at not less than the market price.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe6fba2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15902/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Proration among refineries in production area","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In disposing of oil under this subsection, the Secretary may, at the discretion of the Secretary, prorate the oil among refineries described in paragraph (1) in the area in which the oil is produced.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfe6fba3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15902/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposition to Federal agencies","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfe6fba4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15902/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Onshore royalty","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any royalty oil or gas taken by the Secretary in-kind from onshore oil and gas leases may be sold at not less than the market price to any Federal agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe6fba5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15902/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Offshore royalty","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any royalty oil or gas taken in-kind from a Federal oil or gas lease on the outer Continental Shelf may be disposed of only under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1353"},"text":"section 1353 of title 43","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfe6fba6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15902/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal low-income energy assistance programs","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfe6fba7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15902/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preference","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In disposing of royalty oil or gas taken in-kind under this section, the Secretary may grant a preference to any person, including any Federal or State agency, for the purpose of providing additional resources to any Federal low-income energy assistance program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe6fba8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15902/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 3 years after ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":", the Secretary shall submit a report to Congress—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfe6fba9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15902/i/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assessing the effectiveness of granting preferences specified in paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfe6fbaa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15902/i/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing a specific recommendation on the continuation of authority to grant preferences.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfe6fbab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15902/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" McAlester Army Ammunition Plant","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"At the request of the Secretary of Defense, the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfe6fbac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15902/j/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take in-kind royalty gas from any lease on the McAlester Army Ammunition Plant in McAlester, Oklahoma; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe6fbad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15902/j/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sell such royalty gas to the Department of Defense in accordance with subsection (h)(1), for use only at that plant, only for energy resilience purposes, and only to the extent necessary to meet the natural gas needs of that plant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfe6fbae-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tIII/s342"},"text":"Pub. 