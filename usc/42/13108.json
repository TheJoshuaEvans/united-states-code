{"tag":"section","attrib":{"id":"idbfb00d07-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13108"},"text":null,"children":[{"tag":"num","attrib":{"value":"13108"},"text":"§ 13108.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Savings provisions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfb00d08-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13108/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nothing in this chapter shall be construed to modify or interfere with the implementation of title III of the Superfund Amendments and Reauthorization Act of 1986 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11001"},"text":"42 U.S.C. 11001","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfb00d09-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13108/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nothing contained in this chapter shall be construed, interpreted or applied to supplant, displace, preempt or otherwise diminish the responsibilities and liabilities under other State or Federal law, whether statutory or common.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfb00d0a-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508/tVI/s6609"},"text":"Pub. L. 101–508, title VI, § 6609","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-327"},"text":"104 Stat. 1388–327","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbfb00d0b-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbfb00d0c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbfb00d0d-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Title III of the Superfund Amendments and Reauthorization Act of 1986, referred to in subsec. (a), is title III of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/499"},"text":"Pub. L. 99–499","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-17"},"text":"Oct. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1728"},"text":"100 Stat. 1728","children":[],"tail":", known as the Emergency Planning and Community Right-To-Know Act of 1986, which is classified generally to chapter 116 (§ 11001 et seq.) of this title. For complete classification of title III to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s11001"},"text":"section 11001 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
