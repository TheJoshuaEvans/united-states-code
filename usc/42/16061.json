{"tag":"section","attrib":{"id":"idbff071a9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16061"},"text":null,"children":[{"tag":"num","attrib":{"value":"16061"},"text":"§ 16061.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hybrid vehicles","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary shall accelerate efforts directed toward the improvement of batteries and other rechargeable energy storage systems, power electronics, hybrid systems integration, and other technologies for use in hybrid vehicles.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbff071aa-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tVII/s711"},"text":"Pub. L. 109–58, title VII, § 711","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/818"},"text":"119 Stat. 818","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
