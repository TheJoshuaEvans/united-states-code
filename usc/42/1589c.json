{"tag":"section","attrib":{"id":"idbb377d91-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1589c"},"text":null,"children":[{"tag":"num","attrib":{"value":"1589c"},"text":"§ 1589c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of certain housing to Indians","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Upon a certification by the Secretary of the Interior that any surplus housing, classified by the Secretary of Housing and Urban Development as demountable, in the area of San Diego, California, is needed to provide dwelling accommodations for members of a tribe of Indians in Riverside County or San Diego County or Imperial County, California, the Secretary of Housing and Urban Development is authorized, notwithstanding any other provision of law, to transfer and convey such housing without consideration to such tribe, the members thereof, or the Secretary of the Interior in trust therefor, as the Secretary may prescribe: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That the term housing as used in this section shall not include land."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbb377d92-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-10-14/ch862"},"text":"Oct. 14, 1940, ch. 862","children":[],"tail":", title VI, § 613, as added "},{"tag":"ref","attrib":{"href":"/us/act/1954-08-02/ch649"},"text":"Aug. 2, 1954, ch. 649","children":[],"tail":", title VIII, § 805(3), "},{"tag":"ref","attrib":{"href":"/us/stat/68/645"},"text":"68 Stat. 645","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/89/174/s5/a"},"text":"Pub. L. 89–174, § 5(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-09-09"},"text":"Sept. 9, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/669"},"text":"79 Stat. 669","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbb377d93-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbb377d94-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"idbb377d95-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of functions to Secretary of Housing and Urban Development, see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1581"},"text":"section 1581 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
