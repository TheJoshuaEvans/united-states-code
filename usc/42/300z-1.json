{"tag":"section","attrib":{"id":"idb67058cc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300z–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"300z–1"},"text":"§ 300z–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions; regulations applicable","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb67058cd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300z–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For the purposes of this subchapter, the term—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb67058ce-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300z–1/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Secretary” means the Secretary of Health and Human Services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb67058cf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300z–1/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “eligible person” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb67058d0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300z–1/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with regard to the provision of care services, a pregnant adolescent, an adolescent parent, or the family of a pregnant adolescent or an adolescent parent; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb67058d1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300z–1/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with regard to the provision of prevention services and referral to such other services which may be appropriate, a nonpregnant adolescent;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb67058d2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300z–1/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “eligible grant recipient” means a public or nonprofit private organization or agency which demonstrates, to the satisfaction of the Secretary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb67058d3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300z–1/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an organization which will provide care services, the capability of providing all core services in a single setting or the capability of creating a network through which all core services would be provided; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb67058d4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300z–1/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an organization which will provide prevention services, the capability of providing such services;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb67058d5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300z–1/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “necessary services” means services which may be provided by grantees which are—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb67058d6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300z–1/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pregnancy testing and maternity counseling;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb67058d7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300z–1/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adoption counseling and referral services which present adoption as an option for pregnant adolescents, including referral to licensed adoption agencies in the community if the eligible grant recipient is not a licensed adoption agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb67058d8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300z–1/a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" primary and preventive health services including prenatal and postnatal care;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb67058d9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300z–1/a/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nutrition information and counseling;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb67058da-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300z–1/a/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" referral for screening and treatment of venereal disease;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb67058db-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300z–1/a/4/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" referral to appropriate pediatric care;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb67058dc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300z–1/a/4/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" educational services relating to family life and problems associated with adolescent premarital sexual relations, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb67058dd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300z–1/a/4/G/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information about adoption;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb67058de-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300z–1/a/4/G/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" education on the responsibilities of sexuality and parenting;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb67058df-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300z–1/a/4/G/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development of material to support the role of parents as the provider of sex education; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb67058e0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300z–1/a/4/G/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assistance to parents, schools, youth agencies, and health providers to educate adolescents and preadolescents concerning self-discipline and responsibility in human sexuality;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb67058e1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300z–1/a/4/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appropriate educational and vocational services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb67058e2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300z–1/a/4/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" referral to licensed residential care or maternity home services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb67058e3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300z–1/a/4/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" mental health services and referral to mental health services and to other appropriate physical health services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb67058e4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300z–1/a/4/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" child care sufficient to enable the adolescent parent to continue education or to enter into employment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb67058e5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300z–1/a/4/L"},"text":null,"children":[{"tag":"num","attrib":{"value":"L"},"text":"(L)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consumer education and homemaking;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb67058e6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300z–1/a/4/M"},"text":null,"children":[{"tag":"num","attrib":{"value":"M"},"text":"(M)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" counseling for the immediate and extended family members of the eligible person;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb67058e7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300z–1/a/4/N"},"text":null,"children":[{"tag":"num","attrib":{"value":"N"},"text":"(N)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transportation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb67058e8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300z–1/a/4/O"},"text":null,"children":[{"tag":"num","attrib":{"value":"O"},"text":"(O)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" outreach services to families of adolescents to discourage sexual relations among unemancipated minors;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb67058e9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300z–1/a/4/P"},"text":null,"children":[{"tag":"num","attrib":{"value":"P"},"text":"(P)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" family planning services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb67058ea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300z–1/a/4/Q"},"text":null,"children":[{"tag":"num","attrib":{"value":"Q"},"text":"(Q)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other services consistent with the purposes of this subchapter as the Secretary may approve in accordance with regulations promulgated by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb67058eb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300z–1/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “core services” means those services which shall be provided by a grantee, as determined by the Secretary by regulation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb67058ec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300z–1/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “supplemental services” means those services which may be provided by a grantee, as determined by the Secretary by regulation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb67058ed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300z–1/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “care services” means necessary services for the provision of care to pregnant adolescents and adolescent parents and includes all core services with respect to the provision of such care prescribed by the Secretary by regulation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb67058ee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300z–1/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “prevention services” means necessary services to prevent adolescent sexual relations, including the services described in subparagraphs (A), (D), (E), (G), (H), (M), (N), (O), and (Q) of paragraph (4);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb67058ef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300z–1/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “adolescent” means an individual under the age of nineteen; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb67058f0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300z–1/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “unemancipated minor” means a minor who is subject to the control, authority, and supervision of his or her parents or guardians, as determined under State law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb67058f1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300z–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Until such time as the Secretary promulgates regulations pursuant to the second sentence of this subsection, the Secretary shall use the regulations promulgated under title VI of the Health Services and Centers Amendments of 1978 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300a–21"},"text":"42 U.S.C. 300a–21","children":[],"tail":" et seq.] which were in effect on "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"August 13, 1981","children":[],"tail":", to determine which necessary services are core services for purposes of this subchapter. The Secretary may promulgate regulations to determine which necessary services are core services for purposes of this subchapter based upon an evaluation of and information concerning which necessary services are essential to carry out the purposes of this subchapter and taking into account (1) factors such as whether services are to be provided in urban or rural areas, the ethnic groups to be served, and the nature of the populations to be served, and (2) the results of the evaluations required under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300z–5/b"},"text":"section 300z–5(b) of this title","children":[],"tail":". The Secretary may from time to time revise such regulations."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb67058f2-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XX, § 2002, as added "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tIX/s955/a"},"text":"Pub. L. 97–35, title IX, § 955(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/580"},"text":"95 Stat. 580","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/98/512/s2/d"},"text":"Pub. L. 98–512, § 2(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2409"},"text":"98 Stat. 2409","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb67058f3-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb67058f4-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb67058f5-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Health Services and Centers Amendments of 1978, referred to in subsec. (b), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/626"},"text":"Pub. L. 95–626","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-10"},"text":"Nov. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3551"},"text":"92 Stat. 3551","children":[],"tail":". Title VI of the Health Services and Centers Amendments of 1978 was classified generally to part A (§ 300a–21 et seq.) of subchapter VIII–A of this chapter prior to its repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tIX/s955/b"},"text":"Pub. L. 97–35, title IX, § 955(b)","children":[],"tail":", title XXI, § 2193(f), "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/592"},"text":"95 Stat. 592","children":[],"tail":", 828. For complete classification of this Act to the Code, see Short Title of 1978 Amendments note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s201"},"text":"section 201 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb672c8f6-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1984—Subsec. (a)(4)(H). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/512"},"text":"Pub. L. 98–512","children":[],"tail":" struck out “and referral to such services” after “vocational services”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
