{"tag":"section","attrib":{"id":"idbd03b23d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5106i"},"text":null,"children":[{"tag":"num","attrib":{"value":"5106i"},"text":"§ 5106i.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd03b23e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5106i/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this subchapter and subchapter III shall be construed—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd03b23f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5106i/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as establishing a Federal requirement that a parent or legal guardian provide a child any medical service or treatment against the religious beliefs of the parent or legal guardian; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd03b240-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5106i/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to require that a State find, or to prohibit a State from finding, child abuse or neglect in cases in which a parent or legal guardian relies solely or partially upon spiritual means rather than medical treatment, in accordance with the religious beliefs of the parent or legal guardian.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd03b241-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5106i/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding subsection (a), a State shall, at a minimum, have in place authority under State law to permit the child protective services system of the State to pursue any legal remedies, including the authority to initiate legal proceedings in a court of competent jurisdiction, to provide medical care or treatment for a child when such care or treatment is necessary to prevent or remedy serious harm to the child, or to prevent the withholding of medically indicated treatment from children with life threatening conditions. Except with respect to the withholding of medically indicated treatments from disabled infants with life threatening conditions, case by case determinations concerning the exercise of the authority of this subsection shall be within the sole discretion of the State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd03b242-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/247/tI/s113"},"text":"Pub. L. 93–247, title I, § 113","children":[],"tail":", formerly § 115, as added and renumbered § 113, "},{"tag":"ref","attrib":{"href":"/us/pl/104/235/tI"},"text":"Pub. L. 104–235, title I","children":[],"tail":", §§ 112, 113(a)(1)(C), "},{"tag":"date","attrib":{"date":"1996-10-03"},"text":"Oct. 3, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3078"},"text":"110 Stat. 3078","children":[],"tail":", 3079; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/320/tI/s121"},"text":"Pub. L. 111–320, title I, § 121","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-20"},"text":"Dec. 20, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3478"},"text":"124 Stat. 3478","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd03b243-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd03b244-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd03b245-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/320"},"text":"Pub. L. 111–320","children":[],"tail":" substituted “child abuse or neglect” for “abuse or neglect”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
