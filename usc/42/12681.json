agraph","attrib":{"id":"idbf95ce70-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12681/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated for the administration of this chapter, including financial assistance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12576/a"},"text":"section 12576(a) of this title","children":[],"tail":", such sums as may be necessary for each of fiscal years 2010 through 2014."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf95ce71-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12681/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Corporation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the amounts appropriated under subparagraph (A) for a fiscal year, a portion shall be made available to provide financial assistance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12576/a"},"text":"section 12576(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf95ce72-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12681/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation, training, and technical assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding paragraphs (1), (2), and (4) and any other provision of law, of the amounts appropriated for a fiscal year under divisions B, C, and H of subchapter I of this chapter and under titles I and II of the Domestic Volunteer Service Act of 1973 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4951"},"text":"42 U.S.C. 4951","children":[],"tail":" et seq., 5000 et seq.], the Corporation shall reserve not more than 2.5 percent to carry out sections 12523(e) and 12639a of this title and division K of subchapter I,"},{"tag":"ref","attrib":{"idref":"fn004097"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004097"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of which $1,000,000 shall be used by the Corporation to carry out "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12639a"},"text":"section 12639a of this title","children":[],"tail":". Notwithstanding subsection (b), amounts so reserved shall be available only for the fiscal year for which the amounts are reserved."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf95ce73-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12681/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds appropriated under this section shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf95ce74-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/610/tV/s501"},"text":"Pub. L. 101–610, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3185"},"text":"104 Stat. 3185","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/384/s11"},"text":"Pub. L. 102–384, § 11","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-05"},"text":"Oct. 5, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1459"},"text":"106 Stat. 1459","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/tIII/s301/a"},"text":"Pub. L. 103–82, title III, § 301(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-09-21"},"text":"Sept. 21, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/897"},"text":"107 Stat. 897","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/13/tI/s1841"},"text":"Pub. L. 111–13, title I, § 1841","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-04-21"},"text":"Apr. 21, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1579"},"text":"123 Stat. 1579","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf95ce75-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf95ce76-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbf95ce77-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (a)(3)(B), (5)(A), (6), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/610"},"text":"Pub. L. 101–610","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3127"},"text":"104 Stat. 3127","children":[],"tail":", which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12501"},"text":"section 12501 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Domestic Volunteer Service Act of 1973, referred to in subsec. (a)(6), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/113"},"text":"Pub. L. 93–113","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-10-01"},"text":"Oct. 1, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/394"},"text":"87 Stat. 394","children":[],"tail":". Title I of the Act is classified generally to subchapter I (§ 4951 et seq.) of chapter 66 of this title. Title II of the Act is classified generally to subchapter II (§ 5000 et seq.) of chapter 66 of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4950"},"text":"section 4950 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Division K of subchapter I, referred to in subsec. (a)(6), was in the original “subtitle J” which was translated as meaning subtitle J of title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/610"},"text":"Pub. L. 101–610","children":[],"tail":", to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbf95ce78-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2009—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1841/1"},"text":"Pub. L. 111–13, § 1841(1)","children":[],"tail":", added subsec. (a) and struck out former subsec. (a) which authorized appropriations for subchapter I of this chapter."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b) to (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1841/2"},"text":"Pub. L. 111–13, § 1841(2)","children":[],"tail":", (3), redesignated subsec. (c) as (b) and struck out former subsec. (b), which authorized appropriations for subchapter II of this chapter, and subsec. (d), which specified the budget function for the appropriations authorized in this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/82"},"text":"Pub. L. 103–82","children":[],"tail":" amended section generally, substituting subsecs. (a) to (d) for former subsecs. (a) and (b) which authorized appropriations to carry out subchapter I for fiscal year 1993 and subchapter II for fiscal years 1991 to 1993."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/384/s11/a"},"text":"Pub. L. 102–384, § 11(a)","children":[],"tail":", amended par. (1) generally. Prior to amendment, par. (1) read as follows: “There are authorized to be appropriated to carry out subchapter I of this chapter, $56,000,000 for fiscal year 1991, $95,500,000 for fiscal year 1992, and $105,000,000 for fiscal year 1993.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/384/s11/b"},"text":"Pub. L. 102–384, § 11(b)","children":[],"tail":", substituted “paragraph (1)(A)” for “paragraph (1)” in introductory provisions, redesignated subpars. (B) to (D) as (A) to (C), respectively, added subpar. (D), and struck out former subpar. (A) which read as follows: “$2,000,000 shall be made available to carry out part G of subchapter I of this chapter in each such fiscal year;”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbf95ce79-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbf95ce7a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2009 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13"},"text":"Pub. L. 111–13","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2009-10-01"},"text":"Oct. 1, 2009","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/111/13/s6101/a"},"text":"section 6101(a) of Pub. L. 111–13","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4950"},"text":"section 4950 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbf95ce7b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1993 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/82/tIII/s301/b"},"text":"Pub. L. 103–82, title III, § 301(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-09-21"},"text":"Sept. 21, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/898"},"text":"107 Stat. 898","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/82/tIII/s301/b"},"text":"“The amendment made by subsection (a) [amending this section] shall take effect on ","children":[{"tag":"date","attrib":{"date":"1993-10-01"},"text":"October 1, 1993","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
