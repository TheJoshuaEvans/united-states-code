{"tag":"section","attrib":{"id":"idbf95ce4c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12681"},"text":null,"children":[{"tag":"num","attrib":{"value":"12681"},"text":"§ 12681.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf95ce4d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12681/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subchapter I","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf95ce4e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12681/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Division B","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf95ce4f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12681/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated to provide financial assistance under division B of subchapter I—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbf95ce50-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12681/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $97,000,000 for fiscal year 2010; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf95ce51-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12681/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such sums as may be necessary for each of fiscal years 2011 through 2014.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf95ce52-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12681/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Part IV reservation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the amount appropriated under subparagraph (A) for a fiscal year, the Corporation may reserve such sums as may be necessary to carry out part IV of division B of subchapter I.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf95ce53-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12681/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Section 12561a","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the amount appropriated under subparagraph (A) and not reserved under subparagraph (B) for a fiscal year, not more than $7,000,000 shall be made available for awards to Campuses of Service under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12561a"},"text":"section 12561a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf95ce54-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12681/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Section 12563(c)(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the amount appropriated under subparagraph (A) and not reserved under subparagraph (B) for a fiscal year, not more than $10,000,000 shall be made available for summer of service program grants under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12563/c/8"},"text":"section 12563(c)(8) of this title","children":[],"tail":", and not more than $10,000,000 shall be deposited in the National Service Trust to support summer of service educational awards, consistent with "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12563/c/8"},"text":"section 12563(c)(8) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf95ce55-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12681/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Section 12563(c)(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the amount appropriated under subparagraph (A) and not reserved under subparagraph (B) for a fiscal year, not more than $20,000,000 shall be made available for youth engagement zone programs under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12563/c/9"},"text":"section 12563(c)(9) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf95ce56-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12681/a/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General programs","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Of the amount remaining after the application of subparagraphs (A) through (E) for a fiscal year—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbf95ce57-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12681/a/1/F/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not more than 60 percent shall be available to provide financial assistance under part I of division B of subchapter I;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf95ce58-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12681/a/1/F/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not more than 25 percent shall be available to provide financial assistance under part II of such division; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf95ce59-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12681/a/1/F/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than 15 percent shall be available to provide financial assistance under part III of such division.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf95ce5a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12681/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Divisions C and D","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated, for each of fiscal years 2010 through 2014, such sums as may be necessary to provide financial assistance under division C of subchapter I and to provide national service educational awards under division D of subchapter I for the number of participants described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12571/f/1"},"text":"section 12571(f)(1) of this title","children":[],"tail":" for each such fiscal year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf95ce5b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12681/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Division E","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf95ce5c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12681/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to operate the National Civilian Community Corps and provide financial assistance under division E of subchapter I, such sums as may be necessary for each of fiscal years 2010 through 2014.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf95ce5d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12681/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of this chapter, in obligating the amounts made available pursuant to the authorization of appropriations in this paragraph, priority shall be given to programs carrying out activities in areas for which the President has declared the existence of a major disaster, in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5170"},"text":"section 5170 of this title","children":[],"tail":", including a major disaster as a consequence of Hurricane Katrina or Rita."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf95ce5e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12681/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Division H","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf95ce5f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12681/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums as may be necessary for each of fiscal years 2010 through 2014 to provide financial assistance under division H of subchapter I.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf95ce60-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12681/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Section 12653b","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the amount authorized under subparagraph (A) for a fiscal year, such sums as may be necessary shall be made available to provide financial assistance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12653b"},"text":"section 12653b of this title","children":[],"tail":" and to provide national service educational awards under division D of subchapter I to the number of participants in national service positions established or increased as provided in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12653b/b/3"},"text":"section 12653b(b)(3) of this title","children":[],"tail":" for such year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf95ce61-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12681/a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","