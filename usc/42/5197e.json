{"tag":"section","attrib":{"id":"idbd2e92c9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5197e"},"text":null,"children":[{"tag":"num","attrib":{"value":"5197e"},"text":"§ 5197e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations and transfers of funds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd2e92ca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5197e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums as may be necessary to carry out the provisions of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd2e92cb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5197e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds made available for the purposes of this subchapter may be allocated or transferred for any of the purposes of this subchapter, with the approval of the Director of the Office of Management and Budget, to any agency or government corporation designated to assist in carrying out this subchapter. Each such allocation or transfer shall be reported in full detail to the Congress within 30 days after such allocation or transfer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd2e92cc-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/288/tVI/s626"},"text":"Pub. L. 93–288, title VI, § 626","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/dC/tXXXIV/s3411/a/3"},"text":"Pub. L. 103–337, div. C, title XXXIV, § 3411(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3110"},"text":"108 Stat. 3110","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd2e92cd-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd2e92ce-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbd2e92cf-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in section 2260 of the former Appendix to Title 50, War and National Defense, prior to repeal by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s3412/a"},"text":"Pub. L. 103–337, § 3412(a)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
