,"attrib":{},"text":" For eliminating racial and ethnic disparities in the delivery of comprehensive, culturally and linguistically appropriate care services for HIV/AIDS for women, infants, children, and youth, the Secretary shall, of the amount appropriated under subsection (a), reserve the following, as applicable:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb6a4d61b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–121/b/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For fiscal year 2010, $20,448,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6a4d61c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–121/b/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For fiscal year 2011, $21,470,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6a4d61d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–121/b/2/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For fiscal year 2012, $22,543,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6a4d61e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–121/b/2/D/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For fiscal year 2013, $23,671,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6a4d61f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–121/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For increasing the training capacity of centers to expand the number of health care professionals with treatment expertise and knowledge about the most appropriate standards of HIV/AIDS-related treatments and medical care for racial and ethnic minority adults, adolescents, and children with HIV/AIDS, the Secretary shall, of the amount appropriated under subsection (a), reserve the following, as applicable:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb6a4d620-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–121/b/2/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For fiscal year 2010, $8,763,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6a4d621-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–121/b/2/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For fiscal year 2011, $9,201,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6a4d622-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–121/b/2/E/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For fiscal year 2012, $9,662,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6a4d623-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–121/b/2/E/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For fiscal year 2013, $10,144,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6a4d624-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–121/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consistency with prior program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to the purpose described in subsection (a), the Secretary shall carry out this section consistent with the activities carried out under this subchapter by the Secretary pursuant to the Departments of Labor, Health and Human Services, and Education, and Related Agencies Appropriations Act, 2002 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/116"},"text":"Public Law 107–116","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6a4d625-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–121/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Synchronization of minority AIDS initiative","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For fiscal year 2010 and each subsequent fiscal year, the Secretary shall incorporate and synchronize the schedule of application submissions and funding availability under this section with the schedule of application submissions and funding availability under the corresponding provisions of this subchapter as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6a4d626-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–121/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The schedule for carrying out subsection (b)(1)(A) shall be the same as the schedule applicable to emergency assistance under part A.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6a4d627-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–121/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The schedule for carrying out subsection (b)(1)(B) shall be the same as the schedule applicable to care grants under part B.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6a4d628-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–121/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The schedule for carrying out subsection (b)(1)(C) shall be the same as the schedule applicable to grants for early intervention services under part C.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6a4d629-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–121/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The schedule for carrying out subsection (b)(1)(D) shall be the same as the schedule applicable to grants for services through projects for HIV-related care under part D.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6a4d62a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–121/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The schedule for carrying out subsection (b)(1)(E) shall be the same as the schedule applicable to grants and contracts for activities through education and training centers under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–111"},"text":"section 300ff–111 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb6a4d62b-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XXVI, § 2693, as added and amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/415/tVI/s603"},"text":"Pub. L. 109–415, title VI, § 603","children":[],"tail":", title VII, §§ 702(3), 703, "},{"tag":"date","attrib":{"date":"2006-12-19"},"text":"Dec. 19, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2818"},"text":"120 Stat. 2818","children":[],"tail":", 2820; "},{"tag":"ref","attrib":{"href":"/us/pl/111/87/s2/a/1"},"text":"Pub. L. 111–87, § 2(a)(1)","children":[],"tail":", (3)(A), (f)(2), "},{"tag":"date","attrib":{"date":"2009-10-30"},"text":"Oct. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2885"},"text":"123 Stat. 2885","children":[],"tail":", 2886.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb6a4d62c-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb6a4d62d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb6a4d62e-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Departments of Labor, Health and Human Services, and Education, and Related Agencies Appropriations Act, 2002, referred to in subsec. (c), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/116"},"text":"Pub. L. 107–116","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-10"},"text":"Jan. 10, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/2177"},"text":"115 Stat. 2177","children":[],"tail":". For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb6a4d62f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2009—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/87/s2/a/1"},"text":"Pub. L. 111–87, § 2(a)(1)","children":[],"tail":", (3)(A), repealed "},{"tag":"ref","attrib":{"href":"/us/pl/109/415/s703"},"text":"Pub. L. 109–415, § 703","children":[],"tail":", and revived the provisions of this section as in effect on "},{"tag":"date","attrib":{"date":"2009-09-30"},"text":"Sept. 30, 2009","children":[],"tail":". See 2006 Amendment note and Effective Date of 2009 Amendment; Revival of Section note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/87/s2/f/2/A"},"text":"Pub. L. 111–87, § 2(f)(2)(A)","children":[],"tail":", substituted “$139,100,000 for fiscal year 2009, $146,055,000 for fiscal year 2010, $153,358,000 for fiscal year 2011, $161,026,000 for fiscal year 2012, and $169,077,000 for fiscal year 2013. The Secretary shall develop a formula for the awarding of grants under subsections (b)(1)(A) and (b)(1)(B) that ensures that funding is provided based on the distribution of populations disproportionately impacted by HIV/AIDS.” for “and $139,100,000 for fiscal year 2009.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/87/s2/f/2/B/i"},"text":"Pub. L. 111–87, § 2(f)(2)(B)(i)","children":[],"tail":", struck out “competitive,” before “supplemental” in introductory provisions and added cls. (iv) to (vii)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/87/s2/f/2/B/ii"},"text":"Pub. L. 111–87, § 2(f)(2)(B)(ii)","children":[],"tail":", struck out “competitive” before “grants” in introductory provisions and added cls. (iv) to (vii)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(C)(iv) to (vii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/87/s2/f/2/B/iii"},"text":"Pub. L. 111–87, § 2(f)(2)(B)(iii)","children":[],"tail":", added cls. (iv) to (vii)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/87/s2/f/2/B/iv"},"text":"Pub. L. 111–87, § 2(f)(2)(B)(iv)","children":[],"tail":", substituted “the following, as applicable:” for “$18,500,000 for each of the fiscal years 2007 through 2009.” and added cls. (i) to (iv)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/87/s2/f/2/B/v"},"text":"Pub. L. 111–87, § 2(f)(2)(B)(v)","children":[],"tail":", substituted “the following, as applicable:” for “$8,500,000 for each of the fiscal years 2007 through 2009.” and added cls. (i) to (iv)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/87/s2/f/2/C"},"text":"Pub. L. 111–87, § 2(f)(2)(C)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/415/s703"},"text":"Pub. L. 109–415, § 703","children":[],"tail":", which directed repeal of this section effective "},{"tag":"date","attrib":{"date":"2009-10-01"},"text":"Oct. 1, 2009","children":[],"tail":", was itself repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/111/87/s2/a/1"},"text":"Pub. L. 111–87, § 2(a)(1)","children":[],"tail":", effective "},{"tag":"date","attrib":{"date":"2009-09-30"},"text":"Sept. 30, 2009","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(D), (E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/415/s702/3"},"text":"Pub. L. 109–415, § 702(3)","children":[],"tail":", substituted “HIV/AIDS” for “HIV disease” wherever appearing."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb6a4d630-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb6a4d631-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2009 Amendment; Revival of Section","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions that repeal by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/87/s2/a/1"},"text":"section 2(a)(1) of Pub. L. 111–87","children":[],"tail":" of "},{"tag":"ref","attrib":{"href":"/us/pl/109/415/s703"},"text":"section 703 of Pub. L. 109–415","children":[],"tail":" be effective "},{"tag":"date","attrib":{"date":"2009-09-30"},"text":"Sept. 30, 2009","children":[],"tail":", that the provisions of this section as in effect on "},{"tag":"date","attrib":{"date":"2009-09-30"},"text":"Sept. 30, 2009","children":[],"tail":", be revived, and that amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/111/87/s2/f/2"},"text":"section 2(f)(2) of Pub. L. 111–87","children":[],"tail":" be applicable to this section as so revived and effective as if enacted on "},{"tag":"date","attrib":{"date":"2009-09-30"},"text":"Sept. 30, 2009","children":[],"tail":", see section 2(a)(2), (3) of "},{"tag":"ref","attrib":{"href":"/us/pl/111/87"},"text":"Pub. L. 111–87","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–11"},"text":"section 300ff–11 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
