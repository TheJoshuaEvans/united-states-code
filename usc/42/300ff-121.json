attrib":{},"text":" activities through education and training centers under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–111"},"text":"section 300ff–111 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6a4d601-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–121/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocations among activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Activities under paragraph (1) shall be carried out by the Secretary in accordance with the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6a4d602-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–121/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For supplemental grants to improve HIV-related health outcomes to reduce existing racial and ethnic health disparities, the Secretary shall, of the amount appropriated under subsection (a) for a fiscal year, reserve the following, as applicable:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb6a4d603-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–121/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For fiscal year 2007, $43,800,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6a4d604-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–121/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For fiscal year 2008, $45,400,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6a4d605-3a70-11f1-ae07-