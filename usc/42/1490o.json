{"tag":"section","attrib":{"id":"idbb2b974b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1490o"},"text":null,"children":[{"tag":"num","attrib":{"value":"1490o"},"text":"§ 1490o.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reciprocity in approval of housing subdivisions among Federal agencies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbb2b974c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1490o/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative approval of housing subdivisions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Agriculture, the Secretary of Housing and Urban Development, and the Secretary of Veterans Affairs shall each accept an administrative approval of any housing subdivision made by any of the others so that not later than ","children":[{"tag":"date","attrib":{"date":"1984-01-01"},"text":"January 1, 1984","children":[],"tail":", there is total reciprocity for housing subdivision approvals among the agencies which they head."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb2b974d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1490o/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certificates of reasonable value for one or more properties as constituting administrative approval of subdivision","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of complying with subsection (a), the Secretary of Housing and Urban Development shall consider the issuance by the Secretary of Veterans Affairs of a certificate of reasonable value for 1 or more properties in a subdivision to be an administrative approval for the entire subdivision. This subsection shall not apply after ","children":[{"tag":"date","attrib":{"date":"1994-09-30"},"text":"September 30, 1994","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb2b974e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1490o/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Before the expiration of the period referred to in subsection (b), the Secretary of Housing and Urban Development shall report to the Congress on housing subdivision approval policies and practices, if any, of the Departments of Housing and Urban Development and Agriculture and the Department of Veterans Affairs. The report shall focus on the administration of environmental laws in connection with any such policies and practices, and shall recommend any statutory, regulatory, and administrative changes needed to achieve total reciprocity for such housing subdivision approvals. The Secretary of Housing and Urban Development shall consult with the foregoing agencies, and such other agencies as the Secretary selects, in preparing the report.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb2b974f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1490o/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval by local, county, or State agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For loans made under this subchapter, the Secretary may accept subdivisions that have been approved by local, county, or State agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbb2b9750-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-07-15/ch338"},"text":"July 15, 1949, ch. 338","children":[],"tail":", title V, § 535, as added "},{"tag":"ref","attrib":{"href":"/us/pl/98/181/tI"},"text":"Pub. L. 98–181, title I","children":[],"tail":" [title V, § 523], "},{"tag":"date","attrib":{"date":"1983-11-30"},"text":"Nov. 30, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/1254"},"text":"97 Stat. 1254","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/628/tX/s1067"},"text":"Pub. L. 100–628, title X, § 1067","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-07"},"text":"Nov. 7, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3276"},"text":"102 Stat. 3276","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/235/tIII/s303"},"text":"Pub. L. 101–235, title III, § 303","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-15"},"text":"Dec. 15, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2044"},"text":"103 Stat. 2044","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/625/tVII/s718/a"},"text":"Pub. L. 101–625, title VII, § 718(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4297"},"text":"104 Stat. 4297","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/54/s13/q/5"},"text":"Pub. L. 102–54, § 13(q)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-06-13"},"text":"June 13, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/280"},"text":"105 Stat. 280","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/550/tVII/s716/a"},"text":"Pub. L. 102–550, title VII, § 716(a)","children":[],"tail":