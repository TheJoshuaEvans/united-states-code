":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbb2b9755-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Retroactivity of Approval of Housing Subdivisions Among Federal Agencies","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/120/s8/b"},"text":"Pub. L. 103–120, § 8(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-10-27"},"text":"Oct. 27, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1151"},"text":"107 Stat. 1151","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/120/s8/b"},"text":"“An administrative approval of a housing subdivision made after ","children":[{"tag":"date","attrib":{"date":"1993-06-15"},"text":"June 15, 1993","children":[],"tail":", and before the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1993-10-27"},"text":"Oct. 27, 1993","children":[],"tail":"] is approved and shall be considered to have been lawfully made, but only if otherwise made in accordance with the provisions of section 535(b) of the Housing Act of 1949 ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1490"},"text":"42 U.S.C. 1490","children":[],"tail":null},{"tag":"i","attrib":{},"text":"o","children":[],"tail":"(b)].”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550/tVII/s716/b"},"text":"Pub. L. 102–550, title VII, § 716(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3842"},"text":"106 Stat. 3842","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/550/tVII/s716/b"},"text":"“Any administrative approval of any housing subdivision made after the expiration of the 18-month period beginning on the date of the enactment of the Department of Housing and Urban Development Reform Act of 1989 [","children":[{"tag":"date","attrib":{"date":"1989-12-15"},"text":"Dec. 15, 1989","children":[],"tail":"] and before the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":"] is approved and shall be considered to have been lawfully made, but only if otherwise made in accordance with the provisions of section 535(b) of the Housing Act of 1949 ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1490"},"text":"42 U.S.C. 1490","children":[],"tail":null},{"tag":"i","attrib":{},"text":"o","children":[],"tail":"(b)].”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/625/tVII/s718/b"},"text":"Pub. L. 101–625, title VII, § 718(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4297"},"text":"104 Stat. 4297","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/625/tVII/s718/b"},"text":"“Any administrative approval of any housing subdivision made after the expiration of the 6-month period beginning on the date of the enactment of the Department of Housing and Urban Development Reform Act of 1989 [","children":[{"tag":"date","attrib":{"date":"1989-12-15"},"text":"Dec. 15, 1989","children":[],"tail":"] and before the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":"] is hereby approved and shall be considered to have been lawfully made, but only if otherwise made in accordance with the provisions of section 535(b) of the Housing Act of 1949 ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1490"},"text":"42 U.S.C. 1490","children":[],"tail":null},{"tag":"i","attrib":{},"text":"o","children":[],"tail":"(b)].”"}],"tail":"\n"}]