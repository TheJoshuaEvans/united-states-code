{"tag":"section","attrib":{"id":"idbbdbfa5f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2021d"},"text":null,"children":[{"tag":"num","attrib":{"value":"2021d"},"text":"§ 2021d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regional compacts for disposal of low-level radioactive waste","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbbdbfa60-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2021d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbbdbfa61-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2021d/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal policy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It is the policy of the Federal Government that the responsibilities of the States under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2021c"},"text":"section 2021c of this title","children":[],"tail":" for the disposal of low-level radioactive waste can be most safely and effectively managed on a regional basis."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbdbfa62-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2021d/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interstate compacts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To carry out the policy set forth in paragraph (1), the States may enter into such compacts as may be necessary to provide for the establishment and operation of regional disposal facilities for low-level radioactive waste.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbbdbfa63-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2021d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability to Federal activities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbbdbfa64-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2021d/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbbdbfa65-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2021d/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities of the Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subparagraph (B), no compact or action taken under a compact shall be applicable to the transportation, management, or disposal of any low-level radioactive waste designated in section 2021c(a)(1)(B)(i)–(iii) of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbbdbfa66-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2021d/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal low-level radioactive waste disposed of at non-Federal facilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Low-level radioactive waste owned or generated by the Federal Government that is disposed of at a regional disposal facility or non-Federal disposal facility within a State that is not a member of a compact shall be subject to the same conditions, regulations, requirements, fees, taxes, and surcharges imposed by the compact commission, and by the State in which such facility is located, in the same manner and to the same extent as any low-level radioactive waste not generated by the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbdbfa67-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2021d/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal low-level radioactive waste disposal facilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any low-level radioactive waste disposal facility established or operated exclusively for the disposal of low-level radioactive waste owned or generated by the Federal Government shall not be subject to any compact or any action taken under a compact.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbdbfa68-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2021d/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of compacts on Federal law","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing contained in sections 2021b to 2021j of this title or any compact may be construed to confer any new authority on any compact commission or State—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbbdbfa69-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2021d/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to regulate the packaging, generation, treatment, storage, disposal, or transportation of low-level radioactive waste in a manner incompatible with the regulations of the Nuclear Regulatory Commission or inconsistent with the regulations of the Department of Transportation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbbdbfa6a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2021d/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to regulate health, safety, or environmental hazards from source material, byproduct material, or special nuclear material;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbbdbfa6b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2021d/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to inspect the facilities of licensees of the Nuclear Regulatory Commission;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbbdbfa6c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2021d/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to inspect security areas or operations at the site of the generation of any low-level radioactive waste by the Federal Government, or to inspect classified information related to such areas or operations; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbbdbfa6d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2021d/b/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to require indemnification pursuant to the provisions of chapter 171 of title 28 (commonly referred to as the Federal Tort Claims Act), or ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2210"},"text":"section 2210 of this title","children":[],"tail":", whichever is applicable."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbdbfa6e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2021d/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as expressly provided in sections 2021b to 2021j of this title, nothing contained in sections 2021b to 2021j of this title or any compact may be construed to limit the applicability of any Federal law or to diminish or otherwise impair the jurisdiction of any Federal agency, or to alter, amend, or otherwise affect any Federal law governing the judicial review of any action taken pursuant to any compact.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbdbfa6f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2021d/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State authority preserved","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as expressly provided in sections 2021b to 2021j of this title, nothing contained in sections 2021b to 2021j of this title expands, diminishes, or otherwise affects State law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbbdbfa70-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2021d/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restricted use of regional disposal facilities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any authority in a compact to restrict the use of the regional disposal facilities under the compact to the disposal of low-level radioactive waste generated within the compact region shall not take effect before each of the following occurs:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbbdbfa71-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2021d/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"date","attrib":{"date":"1986-01-01"},"text":"January 1, 1986","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbdbfa72-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2021d/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Congress by law consents to the compact.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbbdbfa73-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2021d/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each compact shall provide that every 5 years after the compact has taken effect the Congress may by law withdraw its consent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbbdbfa74-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/573/s4"},"text":"Pub. L. 96–573, § 4","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/240/tI/s102"},"text":"Pub. L. 99–240, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-01-15"},"text":"Jan. 15, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1845"},"text":"99 Stat. 1845","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbbdbfa75-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbbdbfa76-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbbdbfa77-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Low-Level Radioactive Waste Policy Act, and not as part of the Atomic Energy Act of 1954 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbbdbfa78-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2021d, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/573/s4"},"text":"Pub. L. 96–573, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-22"},"text":"Dec. 22, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3348"},"text":"94 Stat. 3348","children":[],"tail":", related to policy of Federal Government concerning low-level radioactive waste disposal, implementation of that policy, and a report to Congress and the States to assist in carrying out the policy, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/99/240/s102"},"text":"Pub. L. 99–240, § 102","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbbdbfa79-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbbdbfa7a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Texas Low-Level Radioactive Waste Disposal Compact Consent Act","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/236"},"text":"Pub. L. 105–236","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-09-20"},"text":"Sept. 20, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1542"},"text":"112 Stat. 1542","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/236"},"text":"\n","children":[{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“SECTION 1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" SHORT TITLE.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"“This Act may be cited as the ‘Texas Low-Level Radioactive Waste Disposal Compact Consent Act’.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“SEC. 2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" CONGRESSIONAL FINDING.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"“The Congress finds that the compact set forth in section 5 is in furtherance of the Low-Level Radioactive Waste Policy Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2021b"},"text":"42 U.S.C. 2021b","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“SEC. 3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" CONDITIONS OF CONSENT TO COMPACT.","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"“The consent of the Congress to the compact set forth in section 5—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall become effective on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1998-09-20"},"text":"Sept. 20, 1998","children":[],"tail":"];"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is granted subject to the provisions of the Low-Level Radioactive Waste Policy Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2021b"},"text":"42 U.S.C. 2021b","children":[],"tail":" et seq.); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is granted only for so long as the regional commission established in the compact complies with all of the provisions of such Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“SEC. 4.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" CONGRESSIONAL REVIEW.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"“The Congress may alter, amend, or repeal this Act with respect to the compact set forth in section 5 after the expiration of the 10-year period following the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1998-09-20"},"text":"Sept. 20, 1998","children":[],"tail":"], and at such intervals thereafter as may be provided in such compact."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“SEC. 5.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" TEXAS LOW-LEVEL RADIOACTIVE WASTE COMPACT.","children":[],"tail":null},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consent of Congress","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In accordance with section 4(a)(2) of the Low-Level Radioactive Waste Policy Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2021d/a/2"},"text":"42 U.S.C. 2021d(a)(2)","children":[],"tail":"), the consent of Congress is given to the States of Texas, Maine, and Vermont to enter into the compact set forth in subsection (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Text of Compact","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The compact reads substantially as follows: [Text of compact appears at ","children":[{"tag":"ref","attrib":{"href":"/us/stat/112/1543"},"text":"112 Stat. 1543","children":[],"tail":"]”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbbdbfa7b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Southwestern Low-Level Radioactive Waste Disposal Compact Consent Act","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/712"},"text":"Pub. L. 100–712","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-23"},"text":"Nov. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4773"},"text":"102 Stat. 4773","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/712"},"text":"\n","children":[{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“SECTION 1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" SHORT TITLE.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"“This Act may be cited as the ‘Southwestern Low-Level Radioactive Waste Disposal Compact Consent Act’[.]","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“SEC. 2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" CONGRESSIONAL FINDING.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"“The Congress finds that the compact set forth in section 5 is in furtherance of the Low-Level Radioactive Waste Policy Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2021b–202"},"text":"42 U.S.C. 2021b–202","children":[],"tail":"1j]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“SEC. 3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" CONDITIONS OF CONSENT TO COMPACT.","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"“The consent of the Congress to the compact set forth in section 5—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall become effective on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1988-11-23"},"text":"Nov. 23, 1988","children":[],"tail":"];"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is granted subject to the provisions of the Low-Level Radioactive Waste Policy Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2021b–202"},"text":"42 U.S.C. 2021b–202","children":[],"tail":"1j]; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is granted only for so long as the regional commission established in the compact complies with all of the provisions of such Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“SEC. 4.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" CONGRESSIONAL REVIEW.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"“The Congress may alter, amend, or repeal this Act with respect to the compact set forth in section 5 after the expiration of the 10-year period following the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1988-11-23"},"text":"Nov. 23, 1988","children":[],"tail":"], and at such intervals thereafter as may be provided in such compact."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“SEC. 5.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" SOUTHWESTERN LOW-LEVEL RADIOACTIVE WASTE COMPACT.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"“In accordance with section 4(a)(2) of the Low-Level Radioactive Waste Policy Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2021d/a/2"},"text":"42 U.S.C. 2021d(a)(2)","children":[],"tail":"), the consent of Congress is given to the states of Arizona, California, and any eligible states, as defined in article VII of the Southwestern Low-Level Radioactive Waste Disposal Compact, to enter into such compact. Such compact is substantially as follows: [Text of compact appears at "},{"tag":"ref","attrib":{"href":"/us/stat/102/4773"},"text":"102 Stat. 4773","children":[],"tail":"]”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbbdbfa7c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Appalachian States Low-Level Radioactive Waste Compact Consent Act","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/319"},"text":"Pub. L. 100–319","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-05-19"},"text":"May 19, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/471"},"text":"102 Stat. 471","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/319"},"text":"\n","children":[{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“SECTION 1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" SHORT TITLE.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"“This Act may be cited as the ‘Appalachian States Low-Level Radioactive Waste Compact Consent Act’.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“SEC. 2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" CONGRESSIONAL FINDING.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"“The Congress finds that the compact set forth in section 5 is in furtherance of the Low-Level Radioactive Waste Policy Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2021b–202"},"text":"42 U.S.C. 2021b–202","children":[],"tail":"1j]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“SEC. 3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" CONDITIONS OF CONSENT TO COMPACT.","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"“The consent of the Congress to the compact set forth in section 5—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall become effective on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1988-05-19"},"text":"May 19, 1988","children":[],"tail":"],"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is granted subject to the provisions of the Low-Level Radioactive Waste Policy Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2021b–202"},"text":"42 U.S.C. 2021b–202","children":[],"tail":"1j], and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is granted only for so long as the Appalachian States Low-Level Radioactive Waste Commission, advisory committees, and regional boards established in the compact comply with all the provisions of such Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“SEC. 4.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" CONGRESSIONAL REVIEW.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"“The Congress may alter, amend, or repeal this Act with respect to the compact set forth in section 5 after the expiration of the 10-year period following the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1988-05-19"},"text":"May 19, 1988","children":[],"tail":"], and at such intervals thereafter as may be provided for in such compact."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“SEC. 5.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" APPALACHIAN STATES LOW-LEVEL RADIOACTIVE WASTE COMPACT.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"“In accordance with section 4(a)(2) of the Low-Level Radioactive Waste Policy Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2021d/A/2"},"text":"42 U.S.C. 2021d(A)(2)","children":[],"tail":" ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2021d/a/2"},"text":"42 U.S.C. 2021d(a)(2)","children":[],"tail":"]), the consent of Congress is given to the States of Pennsylvania, West Virginia, and any eligible States as defined in Article 5(A) of the Appalachian States Low-Level Radioactive Waste Compact to enter into such compact. Such compact is substantially as follows: [Text of compact appears at "},{"tag":"ref","attrib":{"href":"/us/stat/102/471"},"text":"102 Stat. 471","children":[],"tail":"]”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbbdbfa7d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Omnibus Low-Level Radioactive Waste Interstate Compact Consent Act","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/240/tII"},"text":"Pub. L. 99–240, title II","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-01-15"},"text":"Jan. 15, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1859"},"text":"99 Stat. 1859","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/240/tII"},"text":"\n","children":[{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"201"},"text":"“SEC. 201.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" SHORT TITLE.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"“This Title may be cited as the ‘Omnibus Low-Level Radioactive Waste Interstate Compact Consent Act’.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subtitle","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“Subtitle A—","children":[],"tail":null},{"tag":"heading","attrib":{},"text":"General Provisions","children":[],"tail":null},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"211"},"text":"“SEC. 211.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" CONGRESSIONAL FINDING.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"“The Congress hereby finds that each of the compacts set forth in subtitle B is in furtherance of the Low-Level Radioactive Waste Policy Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2021b–202"},"text":"42 U.S.C. 2021b–202","children":[],"tail":"1j]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"212"},"text":"“SEC. 212.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" CONDITIONS OF CONSENT TO COMPACTS.","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"“The consent of the Congress to each of the compacts set forth in subtitle B—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall become effective on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1986-01-15"},"text":"Jan. 15, 1986","children":[],"tail":"];"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is granted subject to the provisions of the Low-Level Radioactive Waste Policy Act, as amended [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2021b–202"},"text":"42 U.S.C. 2021b–202","children":[],"tail":"1j]; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is granted only for so long as the regional commission, committee, or board established in the compact complies with all of the provisions of such Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"213"},"text":"“SEC. 213.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" CONGRESSIONAL REVIEW.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"“The Congress may alter, amend, or repeal this Act with respect to any compact set forth in subtitle B after the expiration of the 10-year period following the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1986-01-15"},"text":"Jan. 15, 1986","children":[],"tail":"], and at such intervals thereafter as may be provided in such compact."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null},{"tag":"subtitle","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“Subtitle B—","children":[],"tail":null},{"tag":"heading","attrib":{},"text":"Congressional Consent to Compacts","children":[],"tail":null},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"221"},"text":"“SEC. 221.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" NORTHWEST INTERSTATE COMPACT ON LOW-LEVEL RADIOACTIVE WASTE MANAGEMENT.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"“The consent of Congress is hereby given to the states of Alaska, Hawaii, Idaho, Montana, Oregon, Utah, Washington, and Wyoming to enter into the Northwest Interstate Compact on Low-level Radioactive Waste Management, and to each and every part and article thereof. Such compact reads substantially as follows: [Text of compact appears at ","children":[{"tag":"ref","attrib":{"href":"/us/stat/99/1860"},"text":"99 Stat. 1860","children":[],"tail":".]"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"222"},"text":"“SEC. 222.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" CENTRAL INTERSTATE LOW-LEVEL RADIOACTIVE WASTE COMPACT.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"“The consent of Congress is hereby given to the states of Arkansas, Iowa, Kansas, Louisiana, Minnesota, Missouri, Nebraska, North Dakota, and Oklahoma to enter into the Central Interstate Low-Level Radioactive Waste Compact, and to each and every part and article thereof. Such compact reads substantially as follows: [Text of compact appears at ","children":[{"tag":"ref","attrib":{"href":"/us/stat/99/1863"},"text":"99 Stat. 1863","children":[],"tail":".]"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"223"},"text":"“SEC. 223.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" SOUTHEAST INTERSTATE LOW-LEVEL RADIOACTIVE WASTE MANAGEMENT COMPACT.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"“In accordance with section 4(a)(2) of the Low-Level Radioactive Waste Policy Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2021d/a/2"},"text":"42 U.S.C. 2021d(a)(2)","children":[],"tail":"), the consent of the Congress is hereby given to the States of Alabama, Florida, Georgia, Mississippi, North Carolina, South Carolina, Tennessee, and Virginia to enter into the Southeast Interstate Low-Level Radioactive Waste Management Compact. Such compact is substantially as follows: [Text of compact appears at "},{"tag":"ref","attrib":{"href":"/us/stat/99/1871"},"text":"99 Stat. 1871","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/103/1289"},"text":"103 Stat. 1289","children":[],"tail":".]"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"224"},"text":"“SEC. 224.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" CENTRAL MIDWEST INTERSTATE LOW-LEVEL RADIOACTIVE WASTE COMPACT.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"“In accordance with section 4(a)(2) of the Low-Level Radioactive Waste Policy Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2021d/a/2"},"text":"42 U.S.C. 2021d(a)(2)","children":[],"tail":"), the consent of the Congress hereby is given to the States of Illinois and Kentucky to enter into the Central Midwest Interstate Low-Level Radioactive Waste Compact. Such compact is substantially as follows: [Text of compact appears at "},{"tag":"ref","attrib":{"href":"/us/stat/99/1880"},"text":"99 Stat. 1880","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/108/4607"},"text":"108 Stat. 4607","children":[],"tail":".]"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"225"},"text":"“SEC. 225.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" MIDWEST INTERSTATE LOW-LEVEL RADIOACTIVE WASTE MANAGEMENT COMPACT.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"“The consent of Congress is hereby given to the States of Iowa, Indiana, Michigan, Minnesota, Missouri, Ohio, and Wisconsin to enter into the Midwest Interstate Compact on Low-level Radioactive Waste Management. Such compact is as follows: [Text of compact appears at ","children":[{"tag":"ref","attrib":{"href":"/us/stat/99/1892"},"text":"99 Stat. 1892","children":[],"tail":".]"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"226"},"text":"“SEC. 226.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ROCKY MOUNTAIN LOW-LEVEL RADIOACTIVE WASTE COMPACT.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"“In accordance with section 4(a)(2) of the Low-Level Radioactive Waste Policy Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2021d/a/2"},"text":"42 U.S.C. 2021d(a)(2)","children":[],"tail":"), the consent of the Congress hereby is given to the States of Arizona, Colorado, Nevada, New Mexico, Utah, and Wyoming to enter into the Rocky Mountain Interstate Low-Level Radioactive Waste Compact. Such compact is substantially as follows: [Text of compact appears at "},{"tag":"ref","attrib":{"href":"/us/stat/99/1902"},"text":"99 Stat. 1902","children":[],"tail":".]"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"227"},"text":"“SEC. 227.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" NORTHEAST INTERSTATE LOW-LEVEL RADIOACTIVE WASTE MANAGEMENT COMPACT.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"“In accordance with section 4(a)(2) of the Low-Level Radioactive Waste Policy Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2021d/a/2"},"text":"42 U.S.C. 2021d(a)(2)","children":[],"tail":"], the consent of the Congress is hereby given to the States of Connecticut, New Jersey, Delaware, and Maryland to enter into the Northeast Interstate Low-Level Radioactive Waste Management Compact. Such compact is substantially as follows: [Text of compact appears at "},{"tag":"ref","attrib":{"href":"/us/stat/99/1910"},"text":"99 Stat. 1910","children":[],"tail":".].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
