{"tag":"section","attrib":{"id":"idbdaf5c24-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6612"},"text":null,"children":[{"tag":"num","attrib":{"value":"6612"},"text":"§ 6612.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director; Associate Directors","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbdaf5c25-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6612/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There shall be at the head of the Office a Director who shall be appointed by the President, by and with the advice and consent of the Senate, and who shall be compensated at the rate provided for level II of the Executive Schedule in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5313"},"text":"section 5313 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdaf5c26-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6612/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Associate Directors","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President is authorized to appoint not more than four Associate Directors, by and with the advice and consent of the Senate, who shall be compensated at a rate not to exceed that provided for level III of the Executive Schedule in section 5314 of such title. Associate Directors shall perform such functions as the Director may prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdaf5c27-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6612/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chief Technology Officer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subsection (b), the President is authorized to designate 1 of the Associate Directors under that subsection as a United States Chief Technology Officer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbdaf5c28-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/282/tII/s203"},"text":"Pub. L. 94–282, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-05-11"},"text":"May 11, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/463"},"text":"90 Stat. 463","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/329/tVI/s604/b"},"text":"Pub. L. 114–329, title VI, § 604(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-01-06"},"text":"Jan. 6, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/3037"},"text":"130 Stat. 3037","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbdaf5c29-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbdaf5c2a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbdaf5c2b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/329/s604/b/1"},"text":"Pub. L. 114–329, § 604(b)(1)","children":[],"tail":", (2), designated first sentence of existing provisions as subsec. (a) and second and third sentences of existing provisions as subsec. (b) and inserted headings."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/329/s604/b/3"},"text":"Pub. L. 114–329, § 604(b)(3)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
