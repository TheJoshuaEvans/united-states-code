{"tag":"section","attrib":{"id":"idbc724755-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3131"},"text":null,"children":[{"tag":"num","attrib":{"value":"3131"},"text":"§ 3131.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of economic development partnerships","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbc724756-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3131/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In providing assistance under this subchapter, the Secretary shall cooperate with States and other entities to ensure that, consistent with national objectives, Federal programs are compatible with and further the objectives of State, regional, and local economic development plans and comprehensive economic development strategies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc724757-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3131/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may provide such technical assistance to States, political subdivisions of States, sub-State regional organizations (including organizations that cross State boundaries), multi-State regional organizations, and nonprofit organizations as the Secretary determines is appropriate to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc724758-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3131/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" alleviate economic distress;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc724759-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3131/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage and support public-private partnerships for the formation and improvement of economic development strategies that sustain and promote economic development across the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc72475a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3131/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote investment in infrastructure and technological capacity to keep pace with the changing global economy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc72475b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3131/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Intergovernmental review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall promulgate regulations to ensure that appropriate State and local government agencies have been given a reasonable opportunity to review and comment on proposed projects under this subchapter that the Secretary determines may have a significant direct impact on the economy of the area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc72475c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3131/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperation agreements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc72475d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3131/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may enter into a cooperation agreement with any 2 or more States, or an organization of any 2 or more States, in support of effective economic development.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc72475e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3131/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Participation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each cooperation agreement shall provide for suitable participation by other governmental and nongovernmental entities that are representative of significant interests in and perspectives on economic development in an area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc72475f-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/136/tI/s101"},"text":"Pub. L. 89–136, title I, § 101","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/393/tI/s102/a"},"text":"Pub. L. 105–393, title I, § 102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3600"},"text":"112 Stat. 3600","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/373/tI/s103"},"text":"Pub. L. 108–373, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-27"},"text":"Oct. 27, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1759"},"text":"118 Stat. 1759","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc724760-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc724761-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbc724762-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 3131, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/136/tI/s101"},"text":"Pub. L. 89–136, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-08-26"},"text":"Aug. 26, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/552"},"text":"79 Stat. 552","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/123/tIII/s301/1"},"text":"Pub. L. 91–123, title III, § 301(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-11-25"},"text":"Nov. 25, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/219"},"text":"83 Stat. 219","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/92/65/tI/s102"},"text":"Pub. L. 92–65, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-08-05"},"text":"Aug. 5, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/166"},"text":"85 Stat. 166","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/487/tI/s103"},"text":"Pub. L. 94–487, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-12"},"text":"Oct. 12, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2331"},"text":"90 Stat. 2331","children":[],"tail":", authorized direct and supplementary grants, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/105/393/s102/a"},"text":"Pub. L. 105–393, § 102(a)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbc724763-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/373/s103/1"},"text":"Pub. L. 108–373, § 103(1)","children":[],"tail":", substituted “multi-State regional organizations, and nonprofit organizations” for “and multi-State regional organizations” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/373/s103/2"},"text":"Pub. L. 108–373, § 103(2)","children":[],"tail":", struck out “adjoining” before “States” in two places."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbc724764-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbc724765-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1999-02-11"},"text":"Feb. 11, 1999","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/393/s105"},"text":"section 105 of Pub. L. 105–393","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3121"},"text":"section 3121 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
