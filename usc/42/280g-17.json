{"tag":"section","attrib":{"id":"idb54175de-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–17"},"text":null,"children":[{"tag":"num","attrib":{"value":"280g–17"},"text":"§ 280g–17.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation and investigation of potential cancer clusters","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb54175df-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–17/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb54175e0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–17/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cancer cluster","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “cancer cluster” means the incidence of a particular cancer within a population group, a geographical area, and a period of time that is greater than expected for such group, area, and period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb54175e1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–17/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Particular cancer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “particular cancer” means one specific type of cancer or a type of cancers scientifically proven to have the same cause.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb54175e2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–17/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Population group","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “population group” means a group, for purposes of calculating cancer rates, defined by factors such as race, ethnicity, age, or gender.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb54175e3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–17/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria for designation of potential cancer clusters","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb54175e4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–17/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Development of criteria","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall develop criteria for the designation of potential cancer clusters.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb54175e5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–17/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The criteria developed under paragraph (1) shall consider, as appropriate—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb54175e6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–17/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a standard for cancer cluster identification and reporting protocols used to determine when cancer incidence is greater than would be typically observed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb54175e7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–17/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" scientific screening standards that ensure that a cluster of a particular cancer involves the same type of cancer, or types of cancers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb54175e8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–17/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the population in which the cluster of a particular cancer occurs by factors such as race, ethnicity, age, and gender, for purposes of calculating cancer rates;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb54175e9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–17/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the boundaries of a geographic area in which a cluster of a particular cancer occurs so as not to create or obscure a potential cluster by selection of a specific area; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb54175ea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–17/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the time period over which the number of cases of a particular cancer, or the calculation of an expected number of cases, occurs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb54175eb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–17/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guidelines for investigation of potential cancer clusters","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, in consultation with the Council of State and Territorial Epidemiologists and representatives of State and local health departments, shall develop, publish, and periodically update guidelines for investigating potential cancer clusters. The guidelines shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb54175ec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–17/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" recommend that investigations of cancer clusters—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb54175ed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–17/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use the criteria developed under subsection (b);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb54175ee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–17/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use the best available science; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb54175ef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–17/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rely on a weight of the scientific evidence;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb54175f0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–17/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide standardized methods of reviewing and categorizing data, including from health surveillance systems and reports of potential cancer clusters; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb543e5f1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–17/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide guidance for using appropriate epidemiological and other approaches for investigations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb543e5f2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–17/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investigation of cancer clusters","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb543e5f3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–17/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary discretion","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb543e5f4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–17/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in consultation with representatives of the relevant State and local health departments, shall consider whether it is appropriate to conduct an investigation of a potential cancer cluster; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb543e5f5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–17/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in conducting investigations shall have the discretion to prioritize certain potential cancer clusters, based on the availability of resources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb543e5f6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–17/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In investigating potential cancer clusters, the Secretary shall coordinate with agencies within the Department of Health and Human Services and other Federal agencies, such as the Environmental Protection Agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb543e5f7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–17/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Biomonitoring","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In investigating potential cancer clusters, the Secretary shall rely on all appropriate biomonitoring information collected under other Federal programs, such as the National Health and Nutrition Examination Survey. The Secretary may provide technical assistance for relevant biomonitoring studies of other Federal agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb543e5f8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–17/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb543e5f9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–17/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that appropriate staff of agencies within the Department of Health and Human Services are prepared to provide timely assistance, to the extent practicable, upon receiving a request to investigate a potential cancer cluster from a State or local health authority;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb543e5fa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–17/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain staff expertise in epidemiology, toxicology, data analysis, environmental health and cancer surveillance, exposure assessment, pediatric health, pollution control, community outreach, health education, laboratory sampling and analysis, spatial mapping, and informatics;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb543e5fb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–17/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consult with community members as investigations into potential cancer clusters are conducted, as the Secretary determines appropriate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb543e5fc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–17/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collect, store, and disseminate reports on investigations of potential cancer clusters, the possible causes of such clusters, and the actions taken to address such clusters; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb543e5fd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–17/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide technical assistance for investigating cancer clusters to State and local health departments through existing programs, such as the Epi-Aids program of the Centers for Disease Control and Prevention and the Assessments of Chemical Exposures Program of the Agency for Toxic Substances and Disease Registry.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb543e5fe-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title III, § 399V–6, as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/182/tI/s21/b"},"text":"Pub. L. 114–182, title I, § 21(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-06-22"},"text":"June 22, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/510"},"text":"130 Stat. 510","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb543e5ff-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb543e600-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb543e601-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Purposes of Trevor’s Law","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/182/tI/s21/a"},"text":"Pub. L. 114–182, title I, § 21(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-06-22"},"text":"June 22, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/510"},"text":"130 Stat. 510","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/182/tI/s21/a"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The purposes of this section [enacting this section] are—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide the appropriate Federal agencies with the authority to help conduct investigations into potential cancer clusters;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to ensure that Federal agencies have the authority to undertake actions to help address cancer clusters and factors that may contribute to the creation of potential cancer clusters; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to enable Federal agencies to coordinate with other Federal, State, and local agencies, institutes of higher education, and the public in investigating and addressing cancer clusters.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
