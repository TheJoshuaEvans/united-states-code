{"tag":"section","attrib":{"id":"idb49f6942-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247a"},"text":null,"children":[{"tag":"num","attrib":{"value":"247a"},"text":"§ 247a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Family support groups for Alzheimer’s disease patients","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb49f6943-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment; priorities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to available appropriations, the Secretary, acting through the National Institute of Mental Health, the National Institutes of Health, and the Administration on Aging, shall promote the establishment of family support groups to provide, without charge, educational, emotional, and practical support to assist individuals with Alzheimer’s disease or a related memory disorder and members of the families of such individuals. In promoting the establishment of such groups, the Secretary shall give priority to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb49f6944-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" university medical centers and other appropriate health care facilities which receive Federal funds from the Secretary and which conduct research on Alzheimer’s disease or provide services to individuals with such disease; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb49f6945-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" community-based programs which receive funds from the Secretary, acting through the Administration on Aging.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb49f6946-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National network to coordinate groups","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall promote the establishment of a national network to coordinate the family support groups described in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb49f6947-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title III, § 316, as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/319/tIV/s401"},"text":"Pub. L. 99–319, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-05-23"},"text":"May 23, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/489"},"text":"100 Stat. 489","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/43/tXX/s2008/a"},"text":"Pub. L. 103–43, title XX, § 2008(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-06-10"},"text":"June 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/210"},"text":"107 Stat. 210","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb49f6948-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb49f6949-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"