§ 281","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1307"},"text":"84 Stat. 1307","children":[],"tail":", provided for establishment, composition, qualifications of members, terms of office, vacancies, reappointment, compensation, travel expenses, and functions of National Advisory Council on Comprehensive Health Planning Programs, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/93/641/s5/d"},"text":"Pub. L. 93–641, § 5(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-04"},"text":"Jan. 4, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2275"},"text":"88 Stat. 2275","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb49f694b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1993—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/43"},"text":"Pub. L. 103–43","children":[],"tail":" struck out subsec. (c) which read as follows: “The Secretary shall report to Congress, not later than one year after "},{"tag":"date","attrib":{"date":"1986-05-23"},"text":"May 23, 1986","children":[],"tail":", on family support groups and the network of such groups established pursuant to this section.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
