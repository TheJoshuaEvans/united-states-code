{"tag":"section","attrib":{"id":"idbe09ff2f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384m"},"text":null,"children":[{"tag":"num","attrib":{"value":"7384m"},"text":"§ 7384m.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expansion of list of beryllium vendors","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2002-12-31"},"text":"December 31, 2002","children":[],"tail":", the President may, in consultation with the Secretary of Energy, designate as a beryllium vendor for purposes of section 7384"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"(6) of this title any vendor, processor, or producer of beryllium or related products not previously listed under or designated for purposes of such section 7384"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"(6) of this title if the President finds that such vendor, processor, or producer has been engaged in activities related to the production or processing of beryllium for sale to, or use by, the Department of Energy in a manner similar to the entities listed in such section 7384"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"(6) of this title."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbe09ff30-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dC/tXXXVI/s3622"},"text":"Pub. L. 106–398, § 1 [div. C, title XXXVI, § 3622]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–502.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbe09ff31-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idbe09ff32-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"idbe09ff33-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For delegation of certain functions of the President under this section, see Ex. Ord. No. 13179, ","children":[{"tag":"date","attrib":{"date":"2000-12-07"},"text":"Dec. 7, 2000","children":[],"tail":", 65 F.R. 77487, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s7384"},"text":"section 7384 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
