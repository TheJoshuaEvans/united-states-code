{"tag":"section","attrib":{"id":"idbff071f1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16081"},"text":null,"children":[{"tag":"num","attrib":{"value":"16081"},"text":"§ 16081.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fuel cell transit bus demonstration","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbff071f2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16081/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in consultation with the Secretary of Transportation, shall establish a transit bus demonstration program to make competitive, merit-based awards for 5-year projects to demonstrate not more than 25 fuel cell transit buses (and necessary infrastructure) in 5 geographically dispersed localities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff071f3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16081/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preference","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In selecting projects under this section, the Secretary shall give preference to projects that are most likely to mitigate congestion and improve air quality.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff071f4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16081/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to the Secretary to carry out this section $10,000,000 for each of fiscal years 2006 through 2010.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbff071f5-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tVII/s731"},"text":"Pub. L. 109–58, title VII, § 731","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/821"},"text":"119 Stat. 821","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
