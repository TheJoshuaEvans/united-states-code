{"tag":"section","attrib":{"id":"idbfbbf4a1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13341"},"text":null,"children":[{"tag":"num","attrib":{"value":"13341"},"text":"§ 13341.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Magnetohydrodynamics","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfbbf4a2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13341/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall carry out a research, development, demonstration, and commercial application program in magnetohydrodynamics. The purpose of this program shall be to determine the adequacy of the engineering and design information completed to date under Department of Energy contracts related to magnetohydrodynamics retrofit systems and to determine whether any further Federal investment in this technology is warranted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfbbf4a3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13341/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Solicitation of proposals","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to carry out the program authorized in subsection (a), the Secretary may solicit proposals from the private sector and seek to enter into an agreement with appropriate parties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfbbf4a4-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/tXIII/s1311"},"text":"Pub. L. 102–486, title XIII, § 1311","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2976"},"text":"106 Stat. 2976","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
