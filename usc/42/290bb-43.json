{"tag":"section","attrib":{"id":"idb5b67e7e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–43"},"text":null,"children":[{"tag":"num","attrib":{"value":"290bb–43"},"text":"§ 290bb–43.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adult suicide prevention","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5b67e7f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–43/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5b67e80-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–43/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Assistant Secretary shall award grants to eligible entities described in paragraph (2) to implement suicide prevention and intervention programs, for adult individuals, that are designed to raise awareness of suicide prevention, establish referral processes, and improve care and outcomes for such individuals who are at risk of suicide.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5b67e81-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–43/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be eligible to receive a grant under this section, an entity shall be a community-based primary care or behavioral health care setting, an emergency department, a State mental health agency (or State health agency with mental or behavioral health functions), public health agency, a territory of the United States, or an Indian Tribe or Tribal organization (as the terms “Indian Tribe” and “Tribal organization” are defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304"},"text":"section 5304 of title 25","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5b67e82-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–43/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The grants awarded under paragraph (1) shall be used to implement programs, in accordance with such paragraph, that include one or more of the following components:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5b67e83-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–43/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Screening for suicide risk, suicide intervention services, and services for referral for treatment for individuals at risk for suicide.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5b67e84-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–43/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Implementing evidence-based practices to provide treatment for individuals at risk for suicide, including appropriate followup services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5b67e85-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–43/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Raising awareness of suicide prevention resources and promoting help seeking among those at risk for suicide.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5b67e86-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–43/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluations and technical assistance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Assistant Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5b67e87-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–43/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluate the activities supported by grants awarded under subsection (a), and disseminate, as appropriate, the findings from the evaluation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5b67e88-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–43/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide appropriate information, training, and technical assistance, as appropriate, to eligible entities that receive a grant under this section, in order to help such entities to meet the requirements of this section, including assistance with selection and implementation of evidence-based interventions and frameworks to prevent suicide; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5b67e89-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–43/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify best practices, as applicable, to improve the identification, assessment, treatment, and timely transition, as appropriate, to additional or follow-up care for individuals in emergency departments who are at risk for suicide and enhance the coordination of care for such individuals during and after discharge, in support of activities under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5b67e8a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–43/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A grant under this section shall be for a period of not more than 5 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5b67e8b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–43/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this section $30,000,000 for each of fiscal years 2023 through 2027.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5b67e8c-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title V, § 520L, as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/255/dB/tIX/s9009"},"text":"Pub. L. 114–255, div. B, title IX, § 9009","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-13"},"text":"Dec. 13, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1243"},"text":"130 Stat. 1243","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dFF/tI/s1122/c"},"text":"Pub. L. 117–328, div. FF, title I, § 1122(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5652"},"text":"136 Stat. 5652","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb5b67e8d-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb5b67e8e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb5b67e8f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s1122/c/1/A"},"text":"Pub. L. 117–328, § 1122(c)(1)(A)","children":[],"tail":", substituted “adult individuals” for “individuals who are 25 years of age or older” and inserted “prevention” after “raise awareness of suicide”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s1122/c/1/B"},"text":"Pub. L. 117–328, § 1122(c)(1)(B)","children":[],"tail":", in two places, substituted “Indian Tribe” for “Indian tribe” and “Tribal organization” for “tribal organization”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s1122/c/1/C"},"text":"Pub. L. 117–328, § 1122(c)(1)(C)","children":[],"tail":", amended subpar. (C) generally. Prior to amendment, subpar. (C) read as follows: “Raising awareness and reducing stigma of suicide.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s1122/c/2"},"text":"Pub. L. 117–328, § 1122(c)(2)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s1122/c/3"},"text":"Pub. L. 117–328, § 1122(c)(3)","children":[],"tail":", substituted “$30,000,000 for each of fiscal years 2023 through 2027” for “$30,000,000 for the period of fiscal years 2018 through 2022”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
