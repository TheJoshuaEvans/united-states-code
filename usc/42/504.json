},"text":"Oct. 13, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2353"},"text":"102 Stat. 2353","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/628/tIX/s904/c/1/B"},"text":"Pub. L. 100–628, title IX, § 904(c)(1)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-07"},"text":"Nov. 7, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3261"},"text":"102 Stat. 3261","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/152/s4/a/2"},"text":"Pub. L. 103–152, § 4(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-11-24"},"text":"Nov. 24, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1517"},"text":"107 Stat. 1517","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb77b8705-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb77b8706-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb77b8707-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1993—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/152"},"text":"Pub. L. 103–152","children":[],"tail":" substituted “(i), or (j)” for “or (i)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/628"},"text":"Pub. L. 100–628","children":[],"tail":" substituted “(e), (h), or (i)” for “(e), or (h)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/485"},"text":"Pub. L. 100–485","children":[],"tail":" substituted “(e), or (h)” for “or (e)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/620"},"text":"Pub. L. 98–620","children":[],"tail":" struck out subsec. (e) which provided that any judicial proceedings under this section were entitled to, and upon request of the Secretary or the State would receive, a preference and be heard and determined as expeditiously as possible."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/473"},"text":"Pub. L. 96–473","children":[],"tail":" inserted reference to subsec. (e) of "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s503"},"text":"section 503 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/96/249"},"text":"Pub. L. 96–249","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/96/265"},"text":"Pub. L. 96–265","children":[],"tail":" made identical amendments, substituting “subsection (b), (c), or (d)” for “subsection (b) or (c)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb77b8708-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb77b8709-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1993 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/152"},"text":"Pub. L. 103–152","children":[],"tail":" effective on the date one year after "},{"tag":"date","attrib":{"date":"1993-11-24"},"text":"Nov. 24, 1993","children":[