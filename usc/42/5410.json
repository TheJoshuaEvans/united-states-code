{"tag":"section","attrib":{"id":"idbd526dcf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5410"},"text":null,"children":[{"tag":"num","attrib":{"value":"5410"},"text":"§ 5410.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil and criminal penalties","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd526dd0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5410/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whoever violates any provision of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5409"},"text":"section 5409 of this title","children":[],"tail":", or any regulation or final order issued thereunder, shall be liable to the United States for a civil penalty of not to exceed $1,000 for each such violation. Each violation of a provision of "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5409"},"text":"section 5409 of this title","children":[],"tail":", or any regulation or order issued thereunder shall constitute, a separate violation with respect to each manufactured home or with respect to each failure or refusal to allow or perform an act required thereby, except that the maximum civil penalty may not exceed $1,000,000 for any related series of violations occurring within one year from the date of the first violation."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd526dd1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5410/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An individual or a director, officer, or agent of a corporation who knowingly and willfully violates ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5409"},"text":"section 5409 of this title","children":[],"tail":" in a manner which threatens the health or safety of any purchaser shall be fined not more than $1,000 or imprisoned not more than one year, or both."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd526dd2-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/383/tVI/s611"},"text":"Pub. L. 93–383, title VI, § 611","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-08-22"},"text":"Aug. 22, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/705"},"text":"88 Stat. 705","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/399/tIII/s308/c/4"},"text":"Pub. L. 96–399, title III, § 308(c)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-08"},"text":"Oct. 8, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1641"},"text":"94 Stat. 1641","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd526dd3-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd526dd4-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd526dd5-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1980—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/399"},"text":"Pub. L. 96–399","children":[],"tail":" substituted “manufactured home” for “mobile home”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbd526dd6-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbd526dd7-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective upon the expiration of 180 days following ","children":[{"tag":"date","attrib":{"date":"1974-08-22"},"text":"Aug. 22, 1974","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/93/383/s627"},"text":"section 627 of Pub. L. 93–383","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5401"},"text":"section 5401 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
