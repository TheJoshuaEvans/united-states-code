{"tag":"section","attrib":{"id":"idc00d2192-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16320"},"text":null,"children":[{"tag":"num","attrib":{"value":"16320"},"text":"§ 16320.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Spallation Neutron Source","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc00d2193-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16320/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc00d2194-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16320/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" SING","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “SING” means the Spallation Neutron Source Instruments Next Generation major item of equipment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00d2195-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16320/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" SNS power upgrade","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “SNS power upgrade” means the Spallation Neutron Source power upgrade described in the 20-year facilities plan of the Office of Science of the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00d2196-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16320/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" SNS second target station","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “SNS second target station” means the Spallation Neutron Source second target station described in the 20-year facilities plan of the Office of Science of the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00d2197-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16320/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Spallation Neutron Source Facility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “Spallation Neutron Source Facility” and “Facility” mean the completed Spallation Neutron Source scientific user facility located at Oak Ridge National Laboratory, Oak Ridge, Tennessee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00d2198-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16320/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Spallation Neutron Source Project","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “Spallation Neutron Source Project” and “Project” means Department Project 99–E–334, Oak Ridge National Laboratory, Oak Ridge, Tennessee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc00d2199-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16320/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Spallation Neutron Source Project","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc00d219a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16320/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall submit to Congress, as part of the annual budget request of the President submitted to Congress, a report on progress on the Spallation Neutron Source Project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00d219b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16320/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The report shall include for the Project—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc00d219c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16320/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the achievement of milestones;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00d219d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16320/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a comparison of actual costs to estimated costs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00d219e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16320/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any changes in estimated Project costs or schedule.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc00d219f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16320/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Spallation Neutron Source Facility plan","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc00d21a0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16320/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall develop an operational plan for the Spallation Neutron Source Facility that ensures that the Facility is employed to the full capability of the Facility in support of the study of advanced materials, nanoscience, and other missions of the Office of Science of the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00d21a1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16320/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plan","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The operational plan shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc00d21a2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16320/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" include a plan for the operation of an effective scientific user program that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc00d21a3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16320/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is based on peer review of proposals submitted for use of the Facility;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc00d21a4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16320/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes scientific and technical support to ensure that external users, including researchers based at institutions of higher education, are able to make full use of a variety of high quality scientific instruments; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc00d21a5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16320/c/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" phases in systems upgrades to ensure that the Facility remains at the forefront of international scientific endeavors in the field of the Facility throughout the operating life of the Facility;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00d21a6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16320/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include an ongoing program to develop new instruments that builds on the high performance neutron source and that allows neutron scattering techniques to be applied to a growing range of scientific problems and disciplines; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00d21a7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16320/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" address the status of and, to the maximum extent practicable, costs and schedules for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc00d21a8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16320/c/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" full user mode operations of the Facility;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc00d21a9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16320/c/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" instrumentation built at the Facility during the operating phase through full use of the experimental hall, including the SING;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc00d21aa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16320/c/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the SNS power upgrade; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc00d21ab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16320/c/2/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the SNS second target station.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc00d21ac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16320/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc00d21ad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16320/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Spallation Neutron Source Project","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is authorized to be appropriated to carry out the Spallation Neutron Source Project for the lifetime of the Project $1,411,700,000 for total project costs, of which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc00d21ae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16320/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $1,192,700,000 shall be used for the costs of construction; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00d21af-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16320/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $219,000,000 shall be used for other Project costs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00d21b0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16320/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Spallation Neutron Source Facility","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc00d21b1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16320/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subparagraph (B), there is authorized to be appropriated for the Spallation Neutron Source Facility for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc00d21b2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16320/d/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the SING, $75,000,000 for each of fiscal year 2007 through 2009; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc00d21b3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16320/d/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the SNS power upgrade, $160,000,000, to remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00d21b4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16320/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Insufficient stockpiles of heavy water","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If stockpiles of heavy water of the Department are insufficient to meet the needs of the Facility, there is authorized to be appropriated for the Facility $12,000,000 for fiscal year 2007.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc00d21b5-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tIX/s980"},"text":"Pub. L. 109–58, title IX, § 980","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/905"},"text":"119 Stat. 905","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
