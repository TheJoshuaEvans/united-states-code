{"tag":"section","attrib":{"id":"idbcf09f50-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5027a"},"text":null,"children":[{"tag":"num","attrib":{"value":"5027a"},"text":"§ 5027a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acceptance of donations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbcf09f51-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5027a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subsection (b), an entity receiving assistance under this subchapter may accept donations, including donations in cash or in kind fairly evaluated, including plant, equipment, or services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcf09f52-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5027a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An entity receiving assistance under this subchapter to carry out an activity shall not accept donations from the beneficiaries of the activity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbcf09f53-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/113/tII/s228"},"text":"Pub. L. 93–113, title II, § 228","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/13/tII/s2146/e"},"text":"Pub. L. 111–13, title II, § 2146(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-04-21"},"text":"Apr. 21, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1591"},"text":"123 Stat. 1591","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbcf09f54-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbcf09f55-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbcf09f56-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2009-10-01"},"text":"Oct. 1, 2009","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/111/13/s6101/a"},"text":"section 6101(a) of Pub. L. 111–13","children":[],"tail":", set out as an Effective Date of 2009 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4950"},"text":"section 4950 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
