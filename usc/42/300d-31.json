{"tag":"section","attrib":{"id":"idb615dcbb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–31"},"text":null,"children":[{"tag":"num","attrib":{"value":"300d–31"},"text":"§ 300d–31.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this part and parts A and B:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb615dcbc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–31/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designated trauma center","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “designated trauma center” means a trauma center designated in accordance with the modifications to the State plan described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300d–13"},"text":"section 300d–13 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb615dcbd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–31/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State plan regarding emergency medical services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State plan”, with respect to the provision of emergency medical services, means a plan for a comprehensive, organized system to provide for the access, response, triage, field stabilization, transport, hospital stabilization, definitive care, and rehabilitation of patients of all ages with respect to emergency medical services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb615dcbe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–31/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State” means each of the several States, the District of Columbia, the Commonwealth of Puerto Rico, the Virgin Islands, Guam, American Samoa, and the Commonwealth of the Northern Mariana Islands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb615dcbf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–31/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Trauma","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “trauma” means an injury resulting from exposure to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb615dcc0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–31/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a mechanical force; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb615dcc1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–31/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" another extrinsic agent, including an extrinsic agent that is thermal, electrical, chemical, or radioactive.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb615dcc2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–31/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Trauma care component of State plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “trauma care component”, with respect to components of the State plan for the provision of emergency medical services, means a plan for a comprehensive health care system, within rural and urban areas of the State, for the prompt recognition, prehospital care, emergency medical care, acute surgical and medical care, rehabilitation, and outcome evaluation of seriously injured patients.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb615dcc3-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XII, § 1231, as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/590/s3"},"text":"Pub. L. 101–590, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2926"},"text":"104 Stat. 2926","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/321/tVI/s602/2"},"text":"Pub. L. 102–321, title VI, § 602(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-10"},"text":"July 10, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/436"},"text":"106 Stat. 436","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/183/tVI/s601/f/4"},"text":"Pub. L. 103–183, title VI, § 601(f)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-14"},"text":"Dec. 14, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2239"},"text":"107 Stat. 2239","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/152/s2/a"},"text":"Pub. L. 113–152, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-08-08"},"text":"Aug. 8, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1825"},"text":"128 Stat. 1825","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb615dcc4-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb615dcc5-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb615dcc6-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Par. (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/152"},"text":"Pub. L. 113–152","children":[],"tail":" amended par. (4) generally. Prior to amendment, text read as follows: “The term ‘trauma’ means an injury resulting from exposure to a mechanical force.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/183"},"text":"Pub. L. 103–183","children":[],"tail":" substituted “Puerto Rico,” for “Puerto Rico;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/321"},"text":"Pub. L. 102–321","children":[],"tail":" substituted “this part and parts A and B” for “this subchapter” in introductory provisions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb61825b7-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb61825b8-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1992 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/321"},"text":"Pub. L. 102–321","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1992-07-10"},"text":"July 10, 1992","children":[],"tail":", with provision for programs providing financial assistance, see section 801(b), (d) of "},{"tag":"ref","attrib":{"href":"/us/pl/102/321"},"text":"Pub. L. 102–321","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s236"},"text":"section 236 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
