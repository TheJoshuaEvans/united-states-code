{"tag":"section","attrib":{"id":"idb83a1b6f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7c"},"text":null,"children":[{"tag":"num","attrib":{"value":"1320a–7c"},"text":"§ 1320a–7c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fraud and abuse control program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb83a1b70-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb83a1b71-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7c/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"1997-01-01"},"text":"January 1, 1997","children":[],"tail":", the Secretary, acting through the Office of the Inspector General of the Department of Health and Human Services, and the Attorney General shall establish a program—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb83a1b72-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7c/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to coordinate Federal, State, and local law enforcement programs to control fraud and abuse with respect to health plans,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb83a1b73-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7c/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to conduct investigations, audits, evaluations, and inspections relating to the delivery of and payment for health care in the United States,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb83a1b74-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7c/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to facilitate the enforcement of the provisions of sections 1320a–7, 1320a–7a, and 1320a–7b of this title and other statutes applicable to health care fraud and abuse, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb83a1b75-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7c/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide for the modification and establishment of safe harbors and to issue advisory opinions and special fraud alerts pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320a–7d"},"text":"section 1320a–7d of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb83a1b76-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7c/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with health plans","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out the program established under paragraph (1), the Secretary and the Attorney General shall consult with, and arrange for the sharing of data with representatives of health plans.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb83a1b77-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7c/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guidelines","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb83a1b78-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7c/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary and the Attorney General shall issue guidelines to carry out the program under paragraph (1). The provisions of sections 553, 556, and 557 of title 5 shall not apply in the issuance of such guidelines.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb83a1b79-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7c/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information guidelines","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb83a1b7a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7c/a/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Such guidelines shall include guidelines relating to the furnishing of information by health plans, providers, and others to enable the Secretary and the Attorney General to carry out the program (including coordination with health plans under paragraph (2)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb83a1b7b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7c/a/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Confidentiality","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Such guidelines shall include procedures to assure that such information is provided and utilized in a manner that appropriately protects the confidentiality of the information and the privacy of individuals receiving health care services and items.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb83a1b7c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7c/a/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified immunity for providing information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320c–6/a"},"text":"section 1320c–6(a) of this title","children":[],"tail":" (relating to limitation on liability) shall apply to a person providing information to the Secretary or the Attorney General in conjunction with their performance of duties under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb83a1b7d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7c/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ensuring access to documentation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Inspector General of the Department of Health and Human Services is authorized to exercise such authority described in paragraphs (3) through (9) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s406/a"},"text":"section 406(a) of title 5","children":[],"tail":" as necessary with respect to the activities under the fraud and abuse control program established under this subsection."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb83a1b7e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7c/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of Inspector General","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter shall be construed to diminish the authority of any Inspector General, including such authority as provided in chapter 4 of title 5.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb83a1b7f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7c/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public-private partnership for waste, fraud, and abuse detection","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb83a1b80-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7c/a/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Under the program described in paragraph (1), there is established a public-private partnership (in this paragraph referred to as the “partnership”) of health plans, Federal and State agencies, law enforcement agencies, health care anti-fraud organizations, and any other entity determined appropriate by the Secretary (in this paragraph referred to as “partners”) for purposes of detecting and preventing health care waste, fraud, and abuse.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb83a1b81-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7c/a/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contract with trusted third party","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out the partnership, the Secretary shall enter into a contract with a trusted third party for purposes of carrying out the duties of the partnership described in subparagraph (C).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb83a1b82-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7c/a/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties of partnership","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The partnership shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb83a1b83-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7c/a/6/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide technical and operational support to facilitate data sharing between partners in the partnership;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb83a1b84-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7c/a/6/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" analyze data so shared to identify fraudulent and aberrant billing patterns;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb83a1b85-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7c/a/6/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct aggregate analyses of health care data so shared across Federal, State, and private health plans for purposes of detecting fraud, waste, and abuse schemes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb83a1b86-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7c/a/6/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify outlier trends and potential vulnerabilities of partners in the partnership with respect to such schemes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb83a1b87-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7c/a/6/C/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" refer specific cases of potential unlawful conduct to appropriate governmental entities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb83a1b88-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7c/a/6/C/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" convene, not less than annually, meetings with partners in the partnership for purposes of providing updates on the partnership’s work and facilitating information sharing between the partners;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb83a1b89-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7c/a/6/C/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enter into data sharing and data use agreements with partners in the partnership in such a manner so as to ensure the partnership has access to data necessary to identify waste, fraud, and abuse while maintaining the confidentiality and integrity of such data;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb83a1b8a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7c/a/6/C/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide partners in the partnership with plan-specific, confidential feedback on any aberrant billing patterns or potential fraud identified by the partnership with respect to such partner;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb83a1b8b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7c/a/6/C/ix"},"text":null,"children":[{"tag":"num","attrib":{"value":"ix"},"text":"(ix)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish a process by which entities described in subparagraph (A) may enter the partnership and requirements such entities must meet to enter the partnership;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb83a1b8c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7c/a/6/C/x"},"text":null,"children":[{"tag":"num","attrib":{"value":"x"},"text":"(x)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide appropriate training, outreach, and education to partners based on the results of data analyses described in clauses (ii) and (iii); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb83a1b8d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7c/a/6/C/xi"},"text":null,"children":[{"tag":"num","attrib":{"value":"xi"},"text":"(xi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" perform such other duties as the Secretary determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb83a1b8e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7c/a/6/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Substance use disorder treatment analysis","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2020-12-27"},"text":"December 27, 2020","children":[],"tail":", the trusted third party with a contract in effect under subparagraph (B) shall perform an analysis of aberrant or fraudulent billing patterns and trends with respect to providers and suppliers of substance use disorder treatments from data shared with the partnership."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb83a1b8f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7c/a/6/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Executive board","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb83a1b90-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7c/a/6/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Executive board composition","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb83a1b91-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7c/a/6/E/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There shall be an executive board of the partnership comprised of representatives of the Federal Government and representatives of the private sector selected by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb83a1b92-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7c/a/6/E/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chairs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The executive board shall be co-chaired by one Federal Government official and one representative from the private sector.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb83a1b93-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7c/a/6/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The executive board of the partnership shall meet at least once per year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb83a1b94-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7c/a/6/E/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Executive board duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The duties of the executive board shall include the following:","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb83a1b95-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7c/a/6/E/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Providing strategic direction for the partnership, including membership criteria and a mission statement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb83a1b96-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7c/a/6/E/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Communicating with the leadership of the Department of Health and Human Services and the Department of Justice and the various private health sector associations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb83a1b97-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7c/a/6/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2023-01-01"},"text":"January 1, 2023","children":[],"tail":", and every 2 years thereafter, the Secretary shall submit to Congress and make available on the public website of the Centers for Medicare & Medicaid Services a report containing—"}],"tail":null},{"tag":"clause","attrib":{"id":"idb83a1b98-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7c/a/6/F/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a review of activities conducted by the partnership over the 2-year period ending on the date of the submission of such report, including any progress to any objectives established by the partnership;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb83a1b99-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7c/a/6/F/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any savings voluntarily reported by health plans participating in the partnership attributable to the partnership during such period;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb83a1b9a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7c/a/6/F/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any savings to the Federal Government attributable to the partnership during such period;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb83a1b9b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7c/a/6/F/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other outcomes attributable to the partnership, as determined by the Secretary, during such period; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb83a1b9c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7c/a/6/F/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a strategic plan for the 2-year period beginning on the day after the date of the submission of such report, including a description of any emerging fraud and abuse schemes, trends, or practices that the partnership intends to study during such period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb83a1b9d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7c/a/6/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The partnership shall be funded by amounts otherwise made available to the Secretary for carrying out the program described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb83a1b9e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7c/a/6/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transitional provisions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the extent consistent with this subsection, all functions, personnel, assets, liabilities, and administrative actions applicable on the date before ","children":[{"tag":"date","attrib":{"date":"2020-12-27"},"text":"December 27, 2020","children":[],"tail":", to the National Fraud Prevention Partnership established on "},{"tag":"date","attrib":{"date":"2012-09-17"},"text":"September 17, 2012","children":[],"tail":", by charter of the Secretary shall be transferred to the partnership established under subparagraph (A) as of "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"December 27, 2020","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb83a1b9f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7c/a/6/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonapplicability of FACA","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provisions of the Federal Advisory Committee Act shall not apply to the partnership established by subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb83a1ba0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7c/a/6/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, the Secretary may implement the partnership established by subparagraph (A) by program instruction or otherwise.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb83a1ba1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7c/a/6/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this paragraph, the term “trusted third party” means an entity that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb83a1ba2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7c/a/6/K/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrates the capability to carry out the duties of the partnership described in subparagraph (C);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb83a1ba3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7c/a/6/K/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" complies with such conflict of interest standards determined appropriate by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb83a1ba4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7c/a/6/K/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meets such other requirements as the Secretary may prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb83a1ba5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional use of funds by Inspector General","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb83a1ba6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimbursements for investigations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Inspector General of the Department of Health and Human Services is authorized to receive and retain for current use reimbursement for the costs of conducting investigations and audits and for monitoring compliance plans when such costs are ordered by a court, voluntarily agreed to by the payor, or otherwise.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb83a1ba7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Crediting","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds received by the Inspector General under paragraph (1) as reimbursement for costs of conducting investigations shall be deposited to the credit of the appropriation from which initially paid, or to appropriations for similar purposes currently available at the time of deposit, and shall remain available for obligation for 1 year from the date of the deposit of such funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb83a1ba8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Health plan” defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “health plan” means a plan or program that provides health benefits, whether directly, through insurance, or otherwise, and includes—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb83a1ba9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7c/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a policy of health insurance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb83a1baa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7c/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a contract of a service benefit organization; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb83a1bab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7c/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a membership agreement with a health maintenance organization or other prepaid health plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb83a1bac-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title XI, § 1128C, as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/191/tII/s201/a"},"text":"Pub. L. 104–191, title II, § 201(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-21"},"text":"Aug. 21, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1992"},"text":"110 Stat. 1992","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tVI/s6403/c"},"text":"Pub. L. 111–148, title VI, § 6403(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/766"},"text":"124 Stat. 766","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dCC/tI/s124/a"},"text":"Pub. L. 116–260, div. CC, title I, § 124(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2957"},"text":"134 Stat. 2957","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/b/78"},"text":"Pub. L. 117–286, § 4(b)(78)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4351"},"text":"136 Stat. 4351","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb83a1bad-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb83a1bae-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb83a1baf-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Advisory Committee Act, referred to in subsec. (a)(6)(I), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/463"},"text":"Pub. L. 92–463","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-06"},"text":"Oct. 6, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/770"},"text":"86 Stat. 770","children":[],"tail":", which was set out in the Appendix to Title 5, Government Organization and Employees, and was substantially repealed and restated in chapter 10 (§ 1001 et seq.) of Title 5 by "},{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":", §§ 3(a), 7, "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4197"},"text":"136 Stat. 4197","children":[],"tail":", 4361. For disposition of sections of the Act into chapter 10 of Title 5, see Disposition Table preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s101"},"text":"section 101 of Title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb83a1bb0-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/b/78/A"},"text":"Pub. L. 117–286, § 4(b)(78)(A)","children":[],"tail":", substituted “paragraphs (3) through (9) of "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s406/a"},"text":"section 406(a) of title 5","children":[],"tail":"” for “paragraphs (3) through (9) of section 6 of the Inspector General Act of 1978 (5 U.S.C. App.)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/b/78/B"},"text":"Pub. L. 117–286, § 4(b)(78)(B)","children":[],"tail":", substituted “chapter 4 of title 5.” for “the Inspector General Act of 1978 (5 U.S.C. App.).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2020—Subsec. (a)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Pub. L. 116–260","children":[],"tail":" added par. (6)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—Subsec. (a)(1)(C) to (E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148"},"text":"Pub. L. 111–148","children":[],"tail":" inserted “and” at end of subpar. (C), substituted period for “, and” at end of subpar. (D), and struck out subpar. (E) which read as follows: “to provide for the reporting and disclosure of certain final adverse actions against health care providers, suppliers, or practitioners pursuant to the data collection system established under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320a–7e"},"text":"section 1320a–7e of this title","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb83a1bb1-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb83a1bb2-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148"},"text":"Pub. L. 111–148","children":[],"tail":" effective on the first day after the final day of the transition period defined in "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/s6403/d/5"},"text":"section 6403(d)(5) of Pub. L. 111–148","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/s6403/d/6"},"text":"section 6403(d)(6) of Pub. L. 111–148","children":[],"tail":", set out as a Transition Process; Regulations; Effective Date of 2010 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320a–7e"},"text":"section 1320a–7e of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
