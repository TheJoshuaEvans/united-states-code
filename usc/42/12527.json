{"tag":"section","attrib":{"id":"idbf7219f2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12527"},"text":null,"children":[{"tag":"num","attrib":{"value":"12527"},"text":"§ 12527.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Participation of students and teachers from private schools","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf7219f3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12527/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To the extent consistent with the number of students in the State, in the territory, or served by the Indian tribe or in the school district of the local educational agency involved who are enrolled in private nonprofit elementary schools and secondary schools, such State, territory, or Indian tribe, or agency shall (after consultation with appropriate private school representatives) make provision—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf7219f4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12527/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the inclusion of services and arrangements for the benefit of such students so as to allow for the equitable participation of such students in the programs implemented to carry out the objectives and provide the benefits described in this part; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf7219f5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12527/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the training of the teachers of such students so as to allow for the equitable participation of such teachers in the programs implemented to carry out the objectives and provide the benefits described in this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf7219f6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12527/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a State, territory, Indian tribe, or local educational agency is prohibited by law from providing for the participation of students or teachers from private nonprofit schools as required by subsection (a), or if the Corporation determines that a State, territory, Indian tribe, or local educational agency substantially fails or is unwilling to provide for such participation on an equitable basis, the Chief Executive Officer shall waive such requirements and shall arrange for the provision of services to such students and teachers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf7219f7-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/610/tI/s115"},"text":"Pub. L. 101–610, title I, § 115","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/13/tI/s1201"},"text":"Pub. L. 111–13, title I, § 1201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-04-21"},"text":"Apr. 21, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1473"},"text":"123 Stat. 1473","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf7219f8-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf7219f9-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbf7219fa-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 12527, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/610/tI/s115"},"text":"Pub. L. 101–610, title I, § 115","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/tI/s103/a/2"},"text":"Pub. L. 103–82, title I, § 103(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-09-21"},"text":"Sept. 21, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/830"},"text":"107 Stat. 830","children":[],"tail":", related to consideration of applications, prior to the general amendment of this part by "},{"tag":"ref","attrib":{"href":"/us/pl/111/13"},"text":"Pub. L. 111–13","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 12527, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/610/tI/s117"},"text":"Pub. L. 101–610, title I, § 117","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3138"},"text":"104 Stat. 3138","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/10/s4/5"},"text":"Pub. L. 102–10, § 4(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-03-12"},"text":"Mar. 12, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/30"},"text":"105 Stat. 30","children":[],"tail":", prescribed authorized uses of funds, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/s103/a/2"},"text":"Pub. L. 103–82, § 103(a)(2)","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag"