{"tag":"section","attrib":{"id":"idbcca797d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4368a"},"text":null,"children":[{"tag":"num","attrib":{"value":"4368a"},"text":"§ 4368a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Utilization of talents of older Americans in projects of pollution prevention, abatement, and control","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbcca797e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4368a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance to environmental agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law relating to Federal grants and cooperative agreements, the Administrator of the Environmental Protection Agency is authorized to make grants to, or enter into cooperative agreements with, private nonprofit organizations designated by the Secretary of Labor under title V of the Older Americans Act of 1965 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3056"},"text":"42 U.S.C. 3056","children":[],"tail":" et seq.] to utilize the talents of older Americans in programs authorized by other provisions of law administered by the Administrator (and consistent with such provisions of law) in providing technical assistance to Federal, State, and local environmental agencies for projects of pollution prevention, abatement, and control. Funding for such grants or agreements may be made available from such programs or through title V of the Older Americans Act of 1965 and subtitle D of title I of the Workforce Innovation and Opportunity Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t29/s3221"},"text":"29 U.S.C. 3221","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcca797f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4368a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pre-award certifications","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Prior to awarding any grant or agreement under subsection (a), the applicable Federal, State, or local environmental agency shall certify to the Administrator that such grants or agreements will not—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbcca7980-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4368a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" result in the displacement of individuals currently employed by the environmental agency concerned (including partial displacement through reduction of nonovertime hours, wages, or employment benefits);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcca7981-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4368a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" result in the employment of any individual when any other person is in a layoff status from the same or substantially equivalent job within the jurisdiction of the environmental agency concerned; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcca7982-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4368a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" affect existing contracts for services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcca7983-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4368a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prior appropriation Acts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Grants or agreements awarded under this section shall be subject to prior appropriation Acts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbcca7984-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/313/s2"},"text":"Pub. L. 98–313, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-06-12"},"text":"June 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/235"},"text":"98 Stat. 235","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dA/s101/f/tVIII/s405/d/35"},"text":"Pub. L. 105–277, div. A, § 101(f) [title VIII, § 405(d)(35), (f)(27)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-337"},"text":"112 Stat. 2681–337","children":[],"tail":", 2681–426, 2681–434; "},{"tag":"ref","attrib":{"href":"/us/pl/113/128/tV/s512/j"},"text":"Pub. L. 113–128, title V, § 512(j)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1709"},"text":"128 Stat. 1709","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbcca7985-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbcca7986-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbcca7987-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Older Americans Act of 1965, referred to in subsec. (a), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/73"},"text":"Pub. L. 89–73","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-07-14"},"text":"July 14, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/218"},"text":"79 Stat. 218","children":[],"tail":". Title V of the Act, known as the “Community Service Senior Opportunities Act”, is classified generally to subchapter IX (§ 3056 et seq.) of chapter 35 of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3001"},"text":"section 3001 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Workforce Innovation and Opportunity Act, referred to in subsec. (a), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128"},"text":"Pub. L. 113–128","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1425"},"text":"128 Stat. 1425","children":[],"tail":". Subsection D of title I of the Act is classified generally to part D (§ 3221 et seq.) of subchapter I of chapter 32 of Title 29, Labor. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s3101"},"text":"section 3101 of Title 29","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbcca7988-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Environmental Programs Assistance Act of 1984, and not as part of the National Environmental Policy Act of 1969 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbcca7989-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128"},"text":"Pub. L. 113–128","children":[],"tail":" substituted “Funding for such grants or agreements may be made available from such programs or through title V of the Older Americans Act of 1965 and subtitle D of title I of the Workforce Innovation and Opportunity Act” for “Funding for such grants or agreements may be made available from such programs or through title V of the Older Americans Act of 1965 and subtitle D of title I of the Workforce Investment Act of 1998”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/s101/f/tVIII/s405/f/27"},"text":"Pub. L. 105–277, § 101(f) [title VIII, § 405(f)(27)]","children":[],"tail":", struck out “title IV of the Job Training Partnership Act or” after “title V of the Older Americans Act of 1965 and” in last sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/s101/f/tVIII/s405/d/35"},"text":"Pub. L. 105–277, § 101(f) [title VIII, § 405(d)(35)]","children":[],"tail":", substituted “and title IV of the Job Training Partnership Act or subtitle D of title I of the Workforce Investment Act of 1998” for “and title IV of the Job Training Partnership Act” in second sentence."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbcca798a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbcca798b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2014 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128"},"text":"Pub. L. 113–128","children":[],"tail":" effective on the first day of the first full program year after "},{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":" ("},{"tag":"date","attrib":{"date":"2015-07-01"},"text":"July 1, 2015","children":[],"tail":"), see "},{"tag":"ref","attrib":{"href":"/us/pl/113/128/s506"},"text":"section 506 of Pub. L. 113–128","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s3101"},"text":"section 3101 of Title 29","children":[],"tail":", Labor."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbcca798c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by section 101(f) [title VIII, § 405(d)(35)] of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277"},"text":"Pub. L. 105–277","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", and amendment by section 101(f) [title VIII, § 405(f)(27)] of "},{"tag":"ref","attrib":{"href":"/us/pl/105/277"},"text":"Pub. L. 105–277","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2000-07-01"},"text":"July 1, 2000","children":[],"tail":", see section 101(f) [title VIII, § 405(g)(1), (2)(B)] of "},{"tag":"ref","attrib":{"href":"/us/pl/105/277"},"text":"Pub. L. 105–277","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s3502"},"text":"section 3502 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"idbcca798d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/313/s1"},"text":"Pub. L. 98–313, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-06-12"},"text":"June 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/235"},"text":"98 Stat. 235","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/98/313/s1"},"text":"“This Act [enacting this section] may be cited as the ‘Environmental Programs Assistance Act of 1984’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
