{"tag":"section","attrib":{"id":"idbf0e0159-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10105"},"text":null,"children":[{"tag":"num","attrib":{"value":"10105"},"text":"§ 10105.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on spending authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The authority under this chapter to incur indebtedness, or enter into contracts, obligating amounts to be expended by the Federal Government shall be effective for any fiscal year only to such extent or in such amounts as are provided in advance by appropriation Acts.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbf0e015a-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/425/s6"},"text":"Pub. L. 97–425, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-07"},"text":"Jan. 7, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2205"},"text":"96 Stat. 2205","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
