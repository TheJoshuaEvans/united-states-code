{"tag":"section","attrib":{"id":"idb562dfcd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284l"},"text":null,"children":[{"tag":"num","attrib":{"value":"284l"},"text":"§ 284l.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enhancement awards","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb562dfce-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284l/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mentored Patient-Oriented Research Career Development Awards","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb562dfcf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284l/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb562dfd0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284l/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the National Institutes of Health shall make grants (to be referred to as “Mentored Patient-Oriented Research Career Development Awards”) to support individual careers in clinical research at general clinical research centers or at other institutions that have the infrastructure and resources deemed appropriate for conducting patient-oriented clinical research.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb562dfd1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284l/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Grants under subparagraph (A) shall be used to support clinical investigators in the early phases of their independent careers by providing salary and such other support for a period of supervised study.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb562dfd2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284l/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An application for a grant under this subsection shall be submitted by an individual scientist at such time as the Director may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb562dfd3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284l/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mid-Career Investigator Awards in Patient-Oriented Research","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb562dfd4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284l/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb562dfd5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284l/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the National Institutes of Health shall make grants (to be referred to as “Mid-Career Investigator Awards in Patient-Oriented Research”) to support individual clinical research projects at general clinical research centers or at other institutions that have the infrastructure and resources deemed appropriate for conducting patient-oriented clinical research.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb562dfd6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284l/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Grants under subparagraph (A) shall be used to provide support for mid-career level clinicians to allow such clinicians to devote time to clinical research and to act as mentors for beginning clinical investigators.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb562dfd7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284l/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An application for a grant under this subsection shall be submitted by an individual scientist at such time as the Director requires.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb562dfd8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284l/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Graduate Training in Clinical Investigation Award","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb562dfd9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284l/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the National Institutes of Health shall make grants (to be referred to as “Graduate Training in Clinical Investigation Awards”) to support individuals pursuing master’s or doctoral degrees in clinical investigation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb562dfda-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284l/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An application for a grant under this subsection shall be submitted by an individual scientist at such time as the Director may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb562dfdb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284l/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Grants under this subsection shall be for terms of 2 years or more and shall provide stipend, tuition, and institutional support for individual advanced degree programs in clinical investigation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb562dfdc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284l/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As used in this subsection, the term “advanced degree programs in clinical investigation” means programs that award a master’s or Ph.D. degree in clinical investigation after 2 or more years of training in areas such as the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb562dfdd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284l/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Analytical methods, biostatistics, and study design.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb562dfde-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284l/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Principles of clinical pharmacology and pharmacokinetics.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb562dfdf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284l/c/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Clinical epidemiology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb562dfe0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284l/c/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Computer data management and medical informatics.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb562dfe1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284l/c/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Ethical and regulatory issues.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb562dfe2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284l/c/4/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Biomedical writing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb562dfe3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284l/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Clinical Research Curriculum Awards","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb562dfe4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284l/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director of the National Institutes of Health shall make grants (to be referred to as “Clinical Research Curriculum Awards”) to institutions for the development and support of programs of core curricula for training clinical investigators, including medical students. Such core curricula may include training in areas such as the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb562dfe5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284l/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Analytical methods, biostatistics, and study design.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb562dfe6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284l/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Principles of clinical pharmacology and pharmacokinetics.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb562dfe7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284l/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Clinical epidemiology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb562dfe8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284l/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Computer data management and medical informatics.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb562dfe9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284l/d/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Ethical and regulatory issues.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb562dfea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284l/d/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Biomedical writing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb562dfeb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284l/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An application for a grant under this subsection shall be submitted by an individual institution or a consortium of institutions at such time as the Director may require. An institution may submit only one such application.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb562dfec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284l/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Grants under this subsection shall be for terms of up to 5 years and may be renewable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb562dfed-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title IV, § 409H, formerly § 409D, as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/505/tII/s204/b"},"text":"Pub. L. 106–505, title II, § 204(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-13"},"text":"Nov. 13, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2327"},"text":"114 Stat. 2327","children":[],"tail":"; renumbered § 409H, "},{"tag":"ref","attrib":{"href":"/us/pl/107/109/s3/2"},"text":"Pub. L. 107–109, § 3(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-04"},"text":"Jan. 4, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1408"},"text":"115 Stat. 1408","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/482/tI/s103/b/13"},"text":"Pub. L. 109–482, title I, § 103(b)(13)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-01-15"},"text":"Jan. 15, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3687"},"text":"120 Stat. 3687","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb562dfee-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb562dfef-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb562dff0-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2007—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/482/s103/b/13/A"},"text":"Pub. L. 109–482, § 103(b)(13)(A)","children":[],"tail":", struck out heading and text of par. (3). Text read as follows: “For the purpose of carrying out this subsection, there are authorized to be appropriated such sums as may be necessary for each fiscal year.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/482/s103/b/13/B"},"text":"Pub. L. 109–482, § 103(b)(13)(B)","children":[],"tail":", struck out heading and text of par. (3). Text read as follows: “For the purpose of carrying out this subsection, there are authorized to be appropriated such sums as may be necessary for each fiscal year.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/482/s103/b/13/C"},"text":"Pub. L. 109–482, § 103(b)(13)(C)","children":[],"tail":", struck out heading and text of par. (5). Text read as follows: “For the purpose of carrying out this subsection, there are authorized to be appropriated such sums as may be necessary for each fiscal year.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/482/s103/b/13/D"},"text":"Pub. L. 109–482, § 103(b)(13)(D)","children":[],"tail":", struck out heading and text of par. (4). Text read as follows: “For the purpose of carrying out this subsection, there are authorized to be appropriated such sums as may be necessary for each fiscal year.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb562dff1-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb562dff2-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2007 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/482"},"text":"Pub. L. 109–482","children":[],"tail":" applicable only with respect to amounts appropriated for fiscal year 2007 or subsequent fiscal years, see "},{"tag":"ref","attrib":{"href":"/us/pl/109/482/s109"},"text":"section 109 of Pub. L. 109–482","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s281"},"text":"section 281 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
