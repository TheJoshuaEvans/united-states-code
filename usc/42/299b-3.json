{"tag":"section","attrib":{"id":"idb600587f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"299b–3"},"text":"§ 299b–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information systems for health care improvement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb6005880-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–3/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In order to foster a range of innovative approaches to the management and communication of health information, the Agency shall conduct and support research, evaluations, and initiatives to advance—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6005881-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–3/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use of information systems for the study of health care quality and outcomes, including the generation of both individual provider and plan-level comparative performance data;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6005882-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–3/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" training for health care practitioners and researchers in the use of information systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6005883-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–3/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the creation of effective linkages between various sources of health information, including the development of information networks;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6005884-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–3/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the delivery and coordination of evidence-based health care services, including the use of real-time health care decision-support programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6005885-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–3/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the utility and comparability of health information data and medical vocabularies by addressing issues related to the content, structure, definitions and coding of such information and data in consultation with appropriate Federal, State and private entities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6005886-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–3/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use of computer-based health records in all settings for the development of personal health records for individual health assessment and maintenance, and for monitoring public health and outcomes of care within populations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6005887-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–3/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the protection of individually identifiable information in health services research and health care quality improvement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6005888-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–3/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Demonstration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Agency shall support demonstrations into the use of new information tools aimed at improving shared decision-making between patients and their care-givers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6005889-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–3/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Facilitating public access to information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall work with appropriate public and private sector entities to facilitate public access to information regarding the quality of and consumer satisfaction with health care.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb600588a-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title IX, § 914, as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/129/s2/a"},"text":"Pub. L. 106–129, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-12-06"},"text":"Dec. 6, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1658"},"text":"113 Stat. 1658","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb600588b-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb600588c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb600588d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 299b–3, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373/tIX/s914"},"text":"act July 1, 1944, ch. 373, title IX, § 914","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/239/tVI/s6103/a"},"text":"Pub. L. 101–239, title VI, § 6103(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2193"},"text":"103 Stat. 2193","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/410"},"text":"Pub. L. 102–410","children":[],"tail":", §§ 5(c)(3), 6(a), 7, "},{"tag":"date","attrib":{"date":"1992-10-13"},"text":"Oct. 13, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2097"},"text":"106 Stat. 2097","children":[],"tail":", 2099, 2100; "},{"tag":"ref","attrib":{"href":"/us/pl/103/43/tXX/s2013/2"},"text":"Pub. L. 103–43, title XX, § 2013(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-06-10"},"text":"June 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/215"},"text":"107 Stat. 215","children":[],"tail":", related to creation of an agenda and additional requirements, prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/106/129"},"text":"Pub. L. 106–129","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
