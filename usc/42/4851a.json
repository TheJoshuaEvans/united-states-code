{"tag":"section","attrib":{"id":"idbce24773-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4851a"},"text":null,"children":[{"tag":"num","attrib":{"value":"4851a"},"text":"§ 4851a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purposes of this chapter are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbce24774-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4851a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop a national strategy to build the infrastructure necessary to eliminate lead-based paint hazards in all housing as expeditiously as possible;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbce24775-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4851a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to reorient the national approach to the presence of lead-based paint in housing to implement, on a priority basis, a broad program to evaluate and reduce lead-based paint hazards in the Nation’s housing stock;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbce24776-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4851a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to encourage effective action to prevent childhood lead poisoning by establishing a workable framework for lead-based paint hazard evaluation and reduction and by ending the current confusion over reasonable standards of care;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbce24777-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4851a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to ensure that the existence of lead-based paint hazards is taken into account in the development of Government housing policies and in the sale, rental, and renovation of homes and apartments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbce24778-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4851a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to mobilize national resources expeditiously, through a partnership among all levels of government and the private sector, to develop the most promising, cost-effective methods for evaluating and reducing lead-based paint hazards;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbce24779-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4851a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to reduce the threat of childhood lead poisoning in housing owned, assisted, or transferred by the Federal Government; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbce2477a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4851a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to educate the public concerning the hazards and sources of lead-based paint poisoning and steps to reduce and eliminate such hazards.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbce2477b-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550/tX/s1003"},"text":"Pub. L. 102–550, title X, § 1003","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3897"},"text":"106 Stat. 3897","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbce2477c-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbce2477d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbce2477e-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this Act”, meaning title X of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550"},"text":"Pub. L. 102–550","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3897"},"text":"106 Stat. 3897","children":[],"tail":", known as the Residential Lead-Based Paint Hazard Reduction Act of 1992. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4851"},"text":"section 4851 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
