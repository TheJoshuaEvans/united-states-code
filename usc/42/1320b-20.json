{"tag":"section","attrib":{"id":"idb851e9da-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–20"},"text":null,"children":[{"tag":"num","attrib":{"value":"1320b–20"},"text":"§ 1320b–20.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Work incentives outreach program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb851e9db-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–20/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb851e9dc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–20/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commissioner, in consultation with the Ticket to Work and Work Incentives Advisory Panel established under section 101(f) of the Ticket to Work and Work Incentives Improvement Act of 1999, shall establish a community-based work incentives planning and assistance program for the purpose of disseminating accurate information to disabled beneficiaries on work incentives programs and issues related to such programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb851e9dd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–20/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants, cooperative agreements, contracts, and outreach","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Under the program established under this section, the Commissioner shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb851e9de-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–20/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish a competitive program of grants, cooperative agreements, or contracts to provide benefits planning and assistance, including information on the availability of protection and advocacy services, to disabled beneficiaries, including individuals participating in the Ticket to Work and Self-Sufficiency Program established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320b–19"},"text":"section 1320b–19 of this title","children":[],"tail":", the program established under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1382h"},"text":"section 1382h of this title","children":[],"tail":", and other programs that are designed to encourage disabled beneficiaries to work;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb851e9df-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–20/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" conduct directly, or through grants, cooperative agreements, or contracts, ongoing outreach efforts to disabled beneficiaries (and to the families of such beneficiaries) who are potentially eligible to participate in Federal or State work incentive programs that are designed to assist disabled beneficiaries to work, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb851e9e0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–20/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preparing and disseminating information explaining such programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb851e9e1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–20/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" working in cooperation with other Federal, State, and private agencies and nonprofit organizations that serve disabled beneficiaries, and with agencies and organizations that focus on vocational rehabilitation and work-related training and counseling;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb851e9e2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–20/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" establish a corps of trained, accessible, and responsive work incentives specialists within the Social Security Administration who will specialize in disability work incentives under subchapters II and XVI for the purpose of disseminating accurate information with respect to inquiries and issues relating to work incentives to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb8545ae3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–20/a/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disabled beneficiaries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8545ae4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–20/a/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" benefit applicants under subchapters II and XVI; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8545ae5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–20/a/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" individuals or entities awarded grants under subparagraphs ","children":[{"tag":"ref","attrib":{"idref":"fn002719"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002719"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “subparagraph”."}],"tail":" (A) or (B); and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8545ae6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–20/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb8545ae7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–20/a/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" training for work incentives specialists and individuals providing planning assistance described in subparagraph (C); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8545ae8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–20/a/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" technical assistance to organizations and entities that are designed to encourage disabled beneficiaries to return to work.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8545ae9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–20/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with other programs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The responsibilities of the Commissioner established under this section shall be coordinated with other public and private programs that provide information and assistance regarding rehabilitation services and independent living supports and benefits planning for disabled beneficiaries including the program under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1382h"},"text":"section 1382h of this title","children":[],"tail":", the plans for achieving self-support program (PASS), and any other Federal or State work incentives programs that are designed to assist disabled beneficiaries, including educational agencies that provide information and assistance regarding rehabilitation, school-to-work programs, transition services (as defined in, and provided in accordance with, the Individuals with Disabilities Education Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1400"},"text":"20 U.S.C. 1400","children":[],"tail":" et seq.)), a one-stop delivery system established under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s3151/e"},"text":"section 3151(e) of title 29","children":[],"tail":", and other services."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8545aea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–20/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conditions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8545aeb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–20/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection of entities","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8545aec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–20/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An entity shall submit an application for a grant, cooperative agreement, or contract to provide benefits planning and assistance to the Commissioner at such time, in such manner, and containing such information as the Commissioner may determine is necessary to meet the requirements of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8545aed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–20/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statewideness","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commissioner shall ensure that the planning, assistance, and information described in paragraph (2) shall be available on a statewide basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8545aee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–20/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility of States and private organizations","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb8545aef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–20/b/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commissioner may award a grant, cooperative agreement, or contract under this section to a State or a private agency or organization (other than Social Security Administration Field Offices and the State agency administering the State medicaid program under subchapter XIX, including any agency or entity described in clause (ii), that the Commissioner determines is qualified to provide the planning, assistance, and information described in paragraph (2)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8545af0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–20/b/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agencies and entities described","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The agencies and entities described in this clause are the following:","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb8545af1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–20/b/1/C/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any public or private agency or organization (including Centers for Independent Living established under title VII of the Rehabilitation Act of 1973 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s796"},"text":"29 U.S.C. 796","children":[],"tail":" et seq.), protection and advocacy organizations, client assistance programs established in accordance with section 112 of the Rehabilitation Act of 1973 ("},{"tag":"ref","attrib":{"href":"/us/usc/t29/s732"},"text":"29 U.S.C. 732","children":[],"tail":"), and State Developmental Disabilities Councils established in accordance with section 6024 "},{"tag":"ref","attrib":{"idref":"fn002720"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002720"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" See References in Text note below."}],"tail":" of this title) that the Commissioner determines satisfies the requirements of this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb8545af2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–20/b/1/C/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The State agency administering the State program funded under part A of subchapter IV.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8545af3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–20/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusion for conflict of interest","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commissioner may not award a grant, cooperative agreement, or contract under this section to any entity that the Commissioner determines would have a conflict of interest if the entity were to receive a grant, cooperative agreement, or contract under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8545af4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–20/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Services provided","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A recipient of a grant, cooperative agreement, or contract to provide benefits planning and assistance shall select individuals who will act as planners and provide information, guidance, and planning to disabled beneficiaries on the—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8545af5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–20/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" availability and interrelation of any Federal or State work incentives programs designed to assist disabled beneficiaries that the individual may be eligible to participate in;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8545af6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–20/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adequacy of any health benefits coverage that may be offered by an employer of the individual and the extent to which other health benefits coverage may be available to the individual; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8545af7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–20/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" availability of protection and advocacy services for disabled beneficiaries and how to access such services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8545af8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–20/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of grants, cooperative agreements, or contracts","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8545af9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–20/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Based on population of disabled beneficiaries","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subparagraph (B), the Commissioner shall award a grant, cooperative agreement, or contract under this section to an entity based on the percentage of the population of the State where the entity is located who are disabled beneficiaries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8545afa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–20/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb8545afb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–20/b/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Per grant","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No entity shall receive a grant, cooperative agreement, or contract under this section for a fiscal year that is less than $50,000 or more than $300,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8545afc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–20/b/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Total amount for all grants, cooperative agreements, and contracts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The total amount of all grants, cooperative agreements, and contracts awarded under this section for a fiscal year may not exceed $23,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8545afd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–20/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8545afe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–20/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation of costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The costs of carrying out this section shall be paid from amounts made available for the administration of subchapter II and amounts made available for the administration of subchapter XVI, and shall be allocated among those amounts as appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8545aff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–20/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Carryover","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An amount not in excess of 10 percent of the total amount obligated through a grant, cooperative agreement, or contract awarded under this section for a fiscal year to a State or a private agency or organization shall remain available for obligation to such State or private agency or organization until the end of the succeeding fiscal year. Any such amount remaining available for obligation during such succeeding fiscal year shall be available for providing benefits planning and assistance only for individuals who are within the caseload of the recipient of the grant, agreement, or contract as of immediately before the beginning of such fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8545b00-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–20/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each entity awarded a grant, cooperative agreement, or contract under this section shall submit an annual report to the Commissioner on the benefits planning and assistance provided to individuals under such grant, agreement, or contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8545b01-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–20/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8545b02-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–20/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commissioner","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Commissioner” means the Commissioner of Social Security.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8545b03-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–20/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disabled beneficiary","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “disabled beneficiary” means an individual—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8545b04-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–20/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who is a disabled beneficiary as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320b–19/k/2"},"text":"section 1320b–19(k)(2) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8545b05-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–20/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who is receiving a cash payment described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1382e/a"},"text":"section 1382e(a) of this title","children":[],"tail":" or a supplementary payment described in "},{"tag":"ref","attrib":{"href":"/us/pl/93/66/s212/a/3"},"text":"section 212(a)(3) of Public Law 93–66","children":[],"tail":" (without regard to whether such payment is paid by the Commissioner pursuant to an agreement under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1382e/a"},"text":"section 1382e(a) of this title","children":[],"tail":" or under "},{"tag":"ref","attrib":{"href":"/us/pl/93/66/s212/b"},"text":"section 212(b) of Public Law 93–66","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8545b06-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–20/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who, pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1382h/b"},"text":"section 1382h(b) of this title","children":[],"tail":", is considered to be receiving benefits under subchapter XVI of this chapter; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb854