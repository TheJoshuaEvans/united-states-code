this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Individuals with Disabilities Education Act, referred to in subsec. (a)(3), is title VI of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/230"},"text":"Pub. L. 91–230","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-04-13"},"text":"Apr. 13, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/175"},"text":"84 Stat. 175","children":[],"tail":", which is classified generally to chapter 33 (§ 1400 et seq.) of Title 20, Education. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1400"},"text":"section 1400 of Title 20","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Rehabilitation Act of 1973, referred to in subsec. (b)(1)(C)(ii)(I), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/112"},"text":"Pub. L. 93–112","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-09-26"},"text":"Sept. 26, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/355"},"text":"87 Stat. 355","children":[],"tail":". Title VII of the Act is classified generally to subchapter VII (§ 796 et seq.) of chapter 16 of Title 29, Labor. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s701"},"text":"section 701 of Title 29","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6024"},"text":"Section 6024 of this title","children":[],"tail":", referred to in subsec. (b)(1)(C)(ii)(I), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/106/402/tIV/s401/a"},"text":"Pub. L. 106–402, title IV, § 401(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1737"},"text":"114 Stat. 1737","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s15025"},"text":"section 15025 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/93/66/s212"},"text":"Section 212 of Public Law 93–66","children":[],"tail":", referred to in subsec. (d)(2)(B), is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1382"},"text":"section 1382 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8545b0d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128"},"text":"Pub. L. 113–128","children":[],"tail":" substituted “a one-stop delivery system established under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s3151/e"},"text":"section 3151(e) of title 29","children":[],"tail":"” for “a one-stop delivery system established under subtitle B of title I of the Workforce Investment Act of 1998 ("},{"tag":"ref","attrib":{"href":"/us/usc/t29/s2811"},"text":"29 U.S.C. 2811","children":[],"tail":" et seq.)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/280/s3/b/1"},"text":"Pub. L. 111–280, § 3(b)(1)","children":[],"tail":", substituted “Funding” for “Allocation of costs” in par. (4) heading, designated existing provisions as subpar. (A), inserted subpar. (A) heading, and added subpar. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/280/s3/a"},"text":"Pub. L. 111–280, § 3(a)","children":[],"tail":", added subsec. (c). Former subsec. (c) redesignated (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/280/s3/a"},"text":"Pub. L. 111–280, § 3(a)","children":[],"tail":", redesignated subsec. (c) as (d). Former subsec. (d) redesignated (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/280/s2/a"},"text":"Pub. L. 111–280, § 2(a)","children":[],"tail":", substituted “2011” for “2010”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/280/s3/a"},"text":"Pub. L. 111–280, § 3(a)","children":[],"tail":", redesignated subsec. (d) as (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2009—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/63"},"text":"Pub. L. 111–63","children":[],"tail":" substituted “2010” for “2009”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/203/s404/a/1"},"text":"Pub. L. 108–203, § 404(a)(1)","children":[],"tail":", reenacted heading without change and amended text generally. Prior to amendment, text read as follows: “The term ‘disabled beneficiary’ has the meaning given that term in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320b–19/k/2"},"text":"section 1320b–19(k)(2) of this title","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/203/s407/a"},"text":"Pub. L. 108–203, § 407(a)","children":[],"tail":", substituted “2009” for “2004”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8545b0e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb8545b0f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children"