{"tag":"section","attrib":{"id":"idb54175c7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–16"},"text":null,"children":[{"tag":"num","attrib":{"value":"280g–16"},"text":"§ 280g–16.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Food Safety Integrated Centers of Excellence","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb54175c8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–16/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2011-01-04"},"text":"January 4, 2011","children":[],"tail":", the Secretary, acting through the Director of the Centers for Disease Control and Prevention and in consultation with the working group described in subsection (b)(2), shall designate 5 Integrated Food Safety Centers of Excellence (referred to in this section as the “Centers of Excellence”) to serve as resources for Federal, State, and local public health professionals to respond to foodborne illness outbreaks. The Centers of Excellence shall be headquartered at selected State health departments."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb54175c9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–16/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection of Centers of Excellence","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb54175ca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–16/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to be designated as a Center of Excellence under subsection (a), an entity shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb54175cb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–16/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be a State health department;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb54175cc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–16/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" partner with 1 or more institutions of higher education that have demonstrated knowledge, expertise, and meaningful experience with regional or national food production, processing, and distribution, as well as leadership in the laboratory, epidemiological, and environmental detection and investigation of foodborne illness; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb54175cd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–16/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide to the Secretary such information, at such time, and in such manner, as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb54175ce-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–16/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Working group","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2011-01-04"},"text":"January 4, 2011","children":[],"tail":", the Secretary shall establish a diverse working group of experts and stakeholders from Federal, State, and local food safety and health agencies, the food industry, including food retailers and food manufacturers, consumer organizations, and academia to make recommendations to the Secretary regarding designations of the Centers of Excellence."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb54175cf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–16/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional Centers of Excellence","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may designate eligible entities to be regional Food Safety Centers of Excellence, in addition to the 5 Centers designated under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb54175d0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–16/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Under the leadership of the Director of the Centers for Disease Control and Prevention, each Center of Excellence shall be based out of a selected State health department, which shall provide assistance to other regional, State, and local departments of health through activities that include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb54175d1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–16/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing resources, including timely information concerning symptoms and tests, for frontline health professionals interviewing individuals as part of routine surveillance and outbreak investigations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb54175d2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–16/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing analysis of the timeliness and effectiveness of foodborne disease surveillance and outbreak response activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb54175d3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–16/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing training for epidemiological and environmental investigation of foodborne illness, including suggestions for streamlining and standardizing the investigation process;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb54175d4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–16/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing fellowships, stipends, and scholarships to train future epidemiological and food-safety leaders and to address critical workforce shortages;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb54175d5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–16/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" training and coordinating State and local personnel;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb54175d6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–16/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" strengthening capacity to participate in existing or new foodborne illness surveillance and environmental assessment information systems; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb54175d7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–16/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conducting research and outreach activities focused on increasing prevention, communication, and education regarding food safety.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb54175d8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–16/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2011-01-04"},"text":"January 4, 2011","children":[],"tail":", the Secretary shall submit to Congress a report that—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb54175d9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–16/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describes the effectiveness of the Centers of Excellence; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb54175da-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–16/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides legislative recommendations or describes additional resources required by the Centers of Excellence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb54175db-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–16/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated such sums as may be necessary to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb54175dc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–16/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No duplication of effort","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out activities of the Centers of Excellence or other programs under this section, the Secretary shall not duplicate other Federal foodborne illness response efforts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb54175dd-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title III, § 399V–5, as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/353/tII/s210/b"},"text":"Pub. L. 111–353, title II, § 210(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3950"},"text":"124 Stat. 3950","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
