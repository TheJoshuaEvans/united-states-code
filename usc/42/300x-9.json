{"tag":"section","attrib":{"id":"idb6695353-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–9"},"text":null,"children":[{"tag":"num","attrib":{"value":"300x–9"},"text":"§ 300x–9.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb6695354-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–9/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of carrying out this subpart, and subpart III and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s290aa–4/c"},"text":"section 290aa–4(c) of this title","children":[],"tail":" with respect to mental health, there are authorized to be appropriated $857,571,000 for each of fiscal years 2023 through 2027."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6695355-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–9/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocations for technical assistance, data collection, and program evaluation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6695356-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–9/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of carrying out ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x–58/a"},"text":"section 300x–58(a) of this title","children":[],"tail":" with respect to mental health and the purposes specified in paragraphs (2) and (3), the Secretary shall obligate 5 percent of the amounts appropriated under subsection (a) for a fiscal year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6695357-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–9/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data collection","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The purpose specified in this paragraph is carrying out sections 290aa–4(c) and 300y of this title with respect to mental health.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6695358-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–9/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program evaluation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The purpose specified in this paragraph is the conduct of evaluations of prevention and treatment programs and services with respect to mental health to determine methods for improving the availability and quality of such programs and services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6695359-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–9/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Early serious mental illness","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb669535a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–9/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), a State shall expend not less than 10 percent of the amount the State receives for carrying out this section for each fiscal year to support evidence-based programs that address the needs of individuals with early serious mental illness, including psychotic disorders, regardless of the age of the individual at onset.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb669535b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–9/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State flexibility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In lieu of expending 10 percent of the amount the State receives under this section for a fiscal year as required under paragraph (1), a State may elect to expend not less than 20 percent of such amount by the end of such succeeding fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb669535c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–9/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Crisis care","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb669535d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–9/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (3), a State shall expend at least 5 percent of the amount the State receives pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x"},"text":"section 300x of this title","children":[],"tail":" for each fiscal year to support evidenced-based programs that address the crisis care needs of individuals with serious mental illnesses and children with serious emotional disturbances, which may include individuals (including children and adolescents) experiencing mental health crises demonstrating serious mental illness or serious emotional disturbance, as applicable."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb669535e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–9/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Core elements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"At the discretion of the single State agency responsible for the administration of the program of the State under a grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x"},"text":"section 300x of this title","children":[],"tail":", funds expended pursuant to paragraph (1) may be used to fund some or all of the core crisis care service components, as applicable and appropriate, including the following:"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb669535f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–9/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Crisis call centers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6695360-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–9/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 24/7 mobile crisis services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6695361-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–9/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Crisis stabilization programs offering acute care or subacute care in a hospital or appropriately licensed facility, as determined by such State, with referrals to inpatient or outpatient care.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6695362-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–9/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State flexibility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In lieu of expending 5 percent of the amount the State receives pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x"},"text":"section 300x of this title","children":[],"tail":" for a fiscal year to support evidence-based programs as required by paragraph (1), a State may elect to expend not less than 10 percent of such amount to support such programs by the end of two consecutive fiscal years."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6695363-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–9/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Section 300x–1(b)(1)(A)(vi) shall not be construed as limiting the provision of crisis care services pursuant to paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb669