{"tag":"section","attrib":{"id":"idc056fc5d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18401"},"text":null,"children":[{"tag":"num","attrib":{"value":"18401"},"text":"§ 18401.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Aeronautics research goals","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Administrator should ensure that NASA maintains a strong aeronautics research portfolio ranging from fundamental research through systems research with specific research goals, including the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc056fc5e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18401/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Airspace capacity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"NASA’s Aeronautics Research Mission Directorate shall address research needs of the Next Generation Air Transportation System, including the ability of the National Airspace System to handle up to 3 times the current travel demand by 2025.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc056fc5f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18401/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Environmental sustainability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Directorate shall consider and pursue concepts to reduce noise, emissions, and fuel consumption while maintaining high safety standards and shall pursue research related to alternative fuels.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc056fc60-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18401/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Aviation safety","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Directorate shall proactively address safety challenges with new and current air vehicles and with operations in the Nation’s current and future air transportation system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc056fc61-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/267/tIX/s902"},"text":"Pub. L. 111–267, title IX, § 902","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-11"},"text":"Oct. 11, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2835"},"text":"124 Stat. 2835","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
