{"tag":"section","attrib":{"id":"idc01696aa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16454"},"text":null,"children":[{"tag":"num","attrib":{"value":"16454"},"text":"§ 16454.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption authority","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc01696ab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16454/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rulemaking","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 90 days after the effective date of this part, the Commission shall issue a final rule to exempt from the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16452"},"text":"section 16452 of this title","children":[],"tail":" (relating to Federal access to books and records) any person that is a holding company, solely with respect to one or more—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc01696ac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16454/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" qualifying facilities under the Public Utility Regulatory Policies Act of 1978 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s2601"},"text":"16 U.S.C. 2601","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc01696ad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16454/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exempt wholesale generators; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc01696ae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16454/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" foreign utility companies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc01696af-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16454/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other authority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commission shall exempt a person or transaction from the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16452"},"text":"section 16452 of this title","children":[],"tail":" (relating to Federal access to books and records) if, upon application or upon the motion of the Commission—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc01696b0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16454/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Commission finds that the books, accounts, memoranda, and other records of any person are not relevant to the jurisdictional rates of a public utility or natural gas company; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc01696b1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16454/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Commission finds that any class of transactions is not relevant to the jurisdictional rates of a public utility or natural gas company.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc01696b2-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tXII/s1266"},"text":"Pub. L. 109–58, title XII, § 1266","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/975"},"text":"119 Stat. 975","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc01696b3-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc01696b4-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc01696b5-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For the effective date of this part, referred to in subsec. (a), see Effective Date note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16451"},"text":"section 16451 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Public Utility Regulatory Policies Act of 1978, referred to in subsec. (a)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/617"},"text":"Pub. L. 95–617","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-09"},"text":"Nov. 9, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3117"},"text":"92 Stat. 3117","children":[],"tail":". For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s2601"},"text":"section 2601 of Title 16","children":[],"tail":", Conservation, and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
