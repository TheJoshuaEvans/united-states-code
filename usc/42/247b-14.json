{"tag":"section","attrib":{"id":"idb4ab4fcd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–14"},"text":null,"children":[{"tag":"num","attrib":{"value":"247b–14"},"text":"§ 247b–14.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Oral health promotion and disease prevention","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb4ab4fce-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–14/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants to increase resources for community water fluoridation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4ab4fcf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–14/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Director of the Centers for Disease Control and Prevention, may make grants to States and Indian tribes for the purpose of increasing the resources available for community water fluoridation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4ab4fd0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–14/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A State shall use amounts provided under a grant under paragraph (1)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4ab4fd1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–14/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to purchase fluoridation equipment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4ab4fd2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–14/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to train fluoridation engineers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4ab4fd3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–14/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop educational materials on the benefits of fluoridation; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4ab4fd4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–14/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to support the infrastructure necessary to monitor and maintain the quality of water fluoridation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4ab4fd5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–14/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Community water fluoridation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4ab4fd6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–14/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Director of the Centers for Disease Control and Prevention and in collaboration with the Director of the Indian Health Service, shall establish a demonstration project that is designed to assist rural water systems in successfully implementing the water fluoridation guidelines of the Centers for Disease Control and Prevention that are entitled “Engineering and Administrative Recommendations for Water Fluoridation, 1995” (referred to in this subsection as the “EARWF”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4ab4fd7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–14/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4ab4fd8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–14/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collaboration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In collaborating under paragraph (1), the Directors referred to in such paragraph shall ensure that technical assistance and training are provided to tribal programs located in each of the 12 areas of the Indian Health Service. The Director of the Indian Health Service shall provide coordination and administrative support to tribes under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4ab4fd9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–14/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General use of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts made available under paragraph (1) shall be used to assist small water systems in improving the effectiveness of water fluoridation and to meet the recommendations of the EARWF.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4ab4fda-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–14/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fluoridation specialists","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb4ab4fdb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–14/b/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out this subsection, the Secretary shall provide for the establishment of fluoridation specialist engineering positions in each of the Dental Clinical and Preventive Support Centers through which technical assistance and training will be provided to tribal water operators, tribal utility operators and other Indian Health Service personnel working directly with fluoridation projects.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb4ab4fdc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–14/b/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liaison","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A fluoridation specialist shall serve as the principal technical liaison between the Indian Health Service and the Centers for Disease Control and Prevention with respect to engineering and fluoridation issues.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb4ab4fdd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–14/b/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" CDC","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the Centers for Disease Control and Prevention shall appoint individuals to serve as the fluoridation specialists.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4ab4fde-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–14/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The project established under this subsection shall be planned, implemented and evaluated over the 5-year period beginning on the date on which funds are appropriated under this section and shall be designed to serve as a model for improving the effectiveness of water fluoridation systems of small rural communities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4ab4fdf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–14/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In conducting the ongoing evaluation as provided for in paragraph (2)(D), the Secretary shall ensure that such evaluation includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4ab4fe0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–14/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the measurement of changes in water fluoridation compliance levels resulting from assistance provided under this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4ab4fe1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–14/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the identification of the administrative, technical and operational challenges that are unique to the fluoridation of small water systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4ab4fe2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–14/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development of a practical model that may be easily utilized by other tribal, State, county or local governments in improving the quality of water fluoridation with emphasis on small water systems; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4ab4fe3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–14/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the measurement of any increased percentage of Native Americans or Alaskan Natives who receive the benefits of optimally fluoridated water.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4ab4fe4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–14/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" School-based dental sealant program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4ab4fe5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–14/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Director of the Centers for Disease Control and Prevention and in collaboration with the Administrator of the Health Resources and Services Administration, shall award a grant to each of the 50 States and territories and to Indians, Indian tribes, tribal organizations and urban Indian organizations (as such terms are defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1603"},"text":"section 1603 of title 25","children":[],"tail":") to provide for the development of school-based dental sealant programs to improve the access of children to sealants."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4ab4fe6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–14/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State shall use amounts received under a grant under paragraph (1) to provide funds to eligible school-based entities or to public elementary or secondary schools to enable such entities or schools to provide children with access to dental care and dental sealant services. Such services shall be provided by licensed dental health professionals in accordance with State practice licensing laws.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4ab4fe7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–14/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to receive funds under paragraph (1), an entity shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4ab4fe8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–14/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prepare and submit to the State an application at such time, in such manner and containing such information as the State may require; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4ab4fe9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–14/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" be a public elementary or secondary school—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb4ab4fea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–14/c/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is located in an urban area in which and ","children":[{"tag":"ref","attrib":{"idref":"fn002050"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002050"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The word “and” probably should not appear."}],"tail":" more than 50 percent of the student population is participating in Federal or State free or reduced meal programs; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb4ab4feb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–14/c/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is located in a rural area and, with respect to the school district in which the school is located, the district involved has a median income that is at or below 235 percent of the poverty line, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s9902/2"},"text":"section 9902(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4ab4fec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–14/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Oral health infrastructure","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4ab4fed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–14/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperative agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Director of the Centers for Disease Control and Prevention, shall enter into cooperative agreements with State, territorial, and Indian tribes or tribal organizations (as those terms are defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1603"},"text":"section 1603 of title 25","children":[],"tail":") to establish oral health leadership and program guidance, oral health data collection and interpretation,"},{"tag":"ref","attrib":{"idref":"fn002051"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002051"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. The comma probably should not appear."}],"tail":" (including determinants of poor oral health among vulnerable populations), a multi-dimensional delivery system for oral health, and to implement science-based programs (including dental sealants and community water fluoridation) to improve oral health."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4ab4fee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–14/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated such sums as necessary to carry out this subsection for fiscal years 2010 through 2014.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4ab4fef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–14/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “Indian tribe” means an Indian tribe or tribal organization as defined in section 5304(b) and section 5304(c) ","children":[{"tag":"ref","attrib":{"idref":"fn002052"},"text":"3","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002052"},"text":null,"children":[{"tag":"num","attrib":{},"text":"3","children":[],"tail":" See References in Text note below."}],"tail":" of title 25."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4ab4ff0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–14/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of carrying out this section, there are authorized to be appropriated such sums as may be necessary for each of the fiscal years 2001 through 2005.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb4ab4ff1-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title III, § 317M, as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/310/dA/tXVI/s1602"},"text":"Pub. L. 106–310, div. A, title XVI, § 1602","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-17"},"text":"Oct. 17, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1148"},"text":"114 Stat. 1148","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tIV/s4102/b"},"text":"Pub. L. 111–148, title IV, § 4102(b)","children":[],"tail":", (c), "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/551"},"text":"124 Stat. 551","children":[],"tail":", 552.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb4ab4ff2-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb4ab4ff3-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb4ab4ff4-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304"},"text":"Section 5304 of title 25","children":[],"tail":", referred to in subsec. (e), has been amended, and subsecs. (b) and (c) of section 5304 no longer define the terms “Indian tribe” and “tribal organization”. However, such terms are defined elsewhere in that section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb4ab4ff5-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/s4102/b"},"text":"Pub. L. 111–148, § 4102(b)","children":[],"tail":", substituted “shall award a grant to each of the 50 States and territories and to Indians, Indian tribes, tribal organizations and urban Indian organizations (as such terms are defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s1603"},"text":"section 1603 of title 25","children":[],"tail":")” for “may award grants to States and Indian tribes”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (d) to (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/s4102/c"},"text":"Pub. L. 111–148, § 4102(c)","children":[],"tail":", added subsec. (d) and redesignated former subsecs. (d) and (e) as (e) and (f), respectively."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
