{"tag":"section","attrib":{"id":"idb8163fe9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1304"},"text":null,"children":[{"tag":"num","attrib":{"value":"1304"},"text":"§ 1304.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reservation of right to amend or repeal","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The right to alter, amend, or repeal any provision of this chapter is hereby reserved to the Congress.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb8163fea-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title XI, § 1104, "},{"tag":"ref","attrib":{"href":"/us/stat/49/648"},"text":"49 Stat. 648","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
