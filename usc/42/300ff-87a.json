{"tag":"section","attrib":{"id":"idb6a28c97-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–87a"},"text":null,"children":[{"tag":"num","attrib":{"value":"300ff–87a"},"text":"§ 300ff–87a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National HIV/AIDS testing goal","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb6a28c98-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–87a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2010-01-01"},"text":"January 1, 2010","children":[],"tail":", the Secretary shall establish a national HIV/AIDS testing goal of 5,000,000 tests for HIV/AIDS annually through federally-supported HIV/AIDS prevention, treatment, and care programs, including programs under this subchapter and other programs administered by the Centers for Disease Control and Prevention."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6a28c99-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–87a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2011-01-01"},"text":"January 1, 2011","children":[],"tail":", and annually thereafter, the Secretary, acting through the Director of the Centers for Disease Control and Prevention, shall submit to Congress a report describing, with regard to the preceding 12-month reporting period—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6a28c9a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–87a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether the testing goal described in subsection (a) has been met;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6a28c9b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–87a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total number of individuals tested through federally-supported and other HIV/AIDS prevention, treatment, and care programs in each State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6a28c9c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–87a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the number of individuals who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6a28c9d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–87a/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prior to such 12-month period, were unaware of their HIV status; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6a28c9e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–87a/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" through federally-supported and other HIV/AIDS prevention, treatment, and care programs, were diagnosed and referred into treatment and care during such period;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6a28c9f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–87a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any barriers, including State laws and regulations, that the Secretary determines to be a barrier to meeting the testing goal described in subsection (a);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6a28ca0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–87a/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of funding the Secretary determines necessary to meet the annual testing goal in the following 12 months and the amount of Federal funding expended to meet the testing goal in the prior 12-month period; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6a28ca1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–87a/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the most cost-effective strategies for identifying and diagnosing individuals who were unaware of their HIV status, including voluntary testing with pre-test counseling, routine screening including opt-out testing, partner counseling and referral services, and mass media campaigns.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6a28ca2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–87a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review of program effectiveness","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2009-10-30"},"text":"October 30, 2009","children":[],"tail":", the Secretary, in consultation with the Director of the Centers for Disease Control and Prevention, shall submit a report to Congress based on a comprehensive review of each of the programs and activities conducted by the Centers for Disease Control and Prevention as part of the Domestic HIV/AIDS Prevention Activities, including the following:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6a28ca3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–87a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amount of funding provided for each program or activity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6a28ca4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–87a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The primary purpose of each program or activity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6a28ca5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–87a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The annual goals for each program or activity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6a28ca6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–87a/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The relative effectiveness of each program or activity with relation to the other programs and activities conducted by the Centers for Disease Control and Prevention, based on the—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6a28ca7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–87a/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" number of previously undiagnosed individuals with HIV/AIDS made aware of their status and referred into the appropriate treatment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6a28ca8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–87a/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" amount of funding provided for each program or activity compared to the number of undiagnosed individuals with HIV/AIDS made aware of their status;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6a28ca9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–87a/c/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" program’s contribution to the National HIV/AIDS testing goal; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6a28caa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–87a/c/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" progress made toward the goals described in paragraph (3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6a28cab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–87a/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Recommendations if any to Congress on ways to allocate funding for domestic HIV/AIDS prevention activities and programs in order to achieve the National HIV/AIDS testing goal.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6a28cac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–87a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with other Federal activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In pursuing the National HIV/AIDS testing goal, the Secretary, where appropriate, shall consider and coordinate with other national strategies conducted by the Federal Government to address HIV/AIDS.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb6a28cad-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XXVI, § 2688, as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/87/s12/2"},"text":"Pub. L. 111–87, § 12(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-30"},"text":"Oct. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2896"},"text":"123 Stat. 2896","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb6a28cae-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb6a28caf-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb6a28cb0-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2688 of act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", was renumbered section 2689 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–88"},"text":"section 300ff–88 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 2688 of act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–88"},"text":"section 300ff–88 of this title","children":[],"tail":" prior to the general amendment of this part by "},{"tag":"ref","attrib":{"href":"/us/pl/109/415"},"text":"Pub. L. 109–415","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb6a28cb1-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb6a28cb2-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective as if enacted on ","children":[{"tag":"date","attrib":{"date":"2009-09-30"},"text":"Sept. 30, 2009","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/111/87/s2/a/3/B"},"text":"section 2(a)(3)(B) of Pub. L. 111–87","children":[],"tail":", set out as an Effective Date of 2009 Amendment; Revival of Section note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–11"},"text":"section 300ff–11 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
