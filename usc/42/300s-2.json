{"tag":"section","attrib":{"id":"idb656401e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300s–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"300s–2"},"text":"§ 300s–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State supervision or control of operations of facilities receiving funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Except as otherwise specifically provided, nothing in this subchapter shall be construed as conferring on any Federal officer or employee, the right to exercise any supervision or control over the administration, personnel, maintenance, or operation of any facility with respect to which any funds have been or may be expended under this subchapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb656401f-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XVI, § 1623, formerly § 1632, as added "},{"tag":"ref","attrib":{"href":"/us/pl/93/641/s4"},"text":"Pub. L. 93–641, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-04"},"text":"Jan. 4, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2270"},"text":"88 Stat. 2270","children":[],"tail":"; renumbered § 1623, "},{"tag":"ref","attrib":{"href":"/us/pl/96/79/tII/s202/b"},"text":"Pub. L. 96–79, title II, § 202(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-10-04"},"text":"Oct. 4, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/632"},"text":"93 Stat. 632","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
