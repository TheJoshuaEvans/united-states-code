{"tag":"section","attrib":{"id":"idb5b8c80a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290cc–25"},"text":null,"children":[{"tag":"num","attrib":{"value":"290cc–25"},"text":"§ 290cc–25.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conversion to categorical program in event of failure of State regarding expenditure of grants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5b8c80b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290cc–25/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subsection (c), the Secretary shall, from the amounts specified in subsection (b), make grants to public and nonprofit private entities for the purpose of providing to eligible homeless individuals the services specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s290cc–22/b"},"text":"section 290cc–22(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5b8c80c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290cc–25/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specification of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amounts referred to in subsection (a) are any amounts made available in appropriations Acts for allotments under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s290cc–21"},"text":"section 290cc–21 of this title","children":[],"tail":" that are not paid to a State as a result of—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5b8c80d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290cc–25/b/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the failure of the State to submit an application under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s290cc–29"},"text":"section 290cc–29 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5b8c80e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290cc–25/b/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the failure of the State, in the determination of the Secretary, to prepare the application in accordance with such section or to submit the application within a reasonable period of time; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5b8c80f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290cc–25/b/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State informing the Secretary that the State does not intend to expend the full amount of the allotment made to the State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5b8c810-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290cc–25/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement of provision of services in State involved","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to grants under subsection (a), amounts made available under subsection (b) as a result of the State involved shall be available only for grants to provide services in such State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5b8c811-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title V, § 525, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/77/tVI/s611/3"},"text":"Pub. L. 100–77, title VI, § 611(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-07-22"},"text":"July 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/518"},"text":"101 Stat. 518","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/645/tV/s511"},"text":"Pub. L. 101–645, title V, § 511","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4729"},"text":"104 Stat. 4729","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb5b8c812-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb5b8c813-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb5b8c814-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 525 of act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", was renumbered section 546 by "},{"tag":"ref","attrib":{"href":"/us/pl/100/77/s611/2"},"text":"section 611(2) of Pub. L. 100–77","children":[],"tail":" and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s290ee–1"},"text":"section 290ee–1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb5b8c815-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1990—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/645"},"text":"Pub. L. 101–645","children":[],"tail":" amended section generally, substituting provisions relating to conversion to categorical program in event of failure of State regarding expenditure of grants for provisions relating to restrictions on use of payments."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
