{"tag":"section","attrib":{"id":"idb56a0bf1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–11b"},"text":null,"children":[{"tag":"num","attrib":{"value":"285a–11b"},"text":"§ 285a–11b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Best practices for long-term follow-up services for pediatric cancer survivors","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary of Health and Human Services may facilitate the identification of best practices for childhood and adolescent cancer survivorship care, and, as appropriate, may consult with individuals who have expertise in late effects of disease and treatment of childhood and adolescent cancers, which may include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb56a0bf2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–11b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" oncologists, which may include pediatric oncologists;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56a0bf3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–11b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" primary care providers engaged in survivorship care;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56a0bf4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–11b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" survivors of childhood and adolescent cancer;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56a0bf5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–11b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" parents of children and adolescents who have been diagnosed with and treated for cancer and parents of long-term survivors;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56a0bf6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–11b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nurses and social workers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56a0bf7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–11b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" mental health professionals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56a0bf8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–11b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allied health professionals, including physical therapists and occupational therapists; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56a0bf9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–11b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" others, as the Secretary determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb56a0bfa-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/180/tII/s203"},"text":"Pub. L. 115–180, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-06-05"},"text":"June 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1389"},"text":"132 Stat. 1389","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb56a0bfb-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb56a0bfc-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb56a0bfd-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Childhood Cancer Survivorship, Treatment, Access, and Research Act of 2018, also known as the Childhood Cancer STAR Act, and not as part of the Public Health Service Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
