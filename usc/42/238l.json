il":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1716"},"text":"105 Stat. 1716","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/239/s1"},"text":"Pub. L. 102–239, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-17"},"text":"Dec. 17, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1912"},"text":"105 Stat. 1912","children":[],"tail":"; renumbered title II, § 243, "},{"tag":"ref","attrib":{"href":"/us/pl/103/43/tXX/s2010/a/1"},"text":"Pub. L. 103–43, title XX, § 2010(a)(1)","children":[],"tail":"–(3), "},{"tag":"date","attrib":{"date":"1993-06-10"},"text":"June 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/213"},"text":"107 Stat. 213","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb4852a17-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb4852a18-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb4852a19-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Community Mental Health Centers Act, referred to in subsec. (a), is title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/164"},"text":"Pub. L. 88–164","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/94/63/tIII/s303"},"text":"Pub. L. 94–63, title III, § 303","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-07-29"},"text":"July 29, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/309"},"text":"89 Stat. 309","children":[],"tail":", and amended, which was classified principally to subchapter III (§ 2689 et seq.) of chapter 33 of this title prior to its repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tIX/s902/e/2/B"},"text":"Pub. L. 97–35, title IX, § 902(e)(2)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/560"},"text":"95 Stat. 560","children":[],"tail":". Section 222 of the Community Mental Health Centers Act was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2689j"},"text":"section 2689j of this title","children":[],"tail":" prior to its repeal."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb4852a1a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300aaa–12"},"text":"section 300aaa–12 of this title","children":[],"tail":" prior to renumbering by "},{"tag":"ref","attrib":{"href":"/us/pl/103/43"},"text":"Pub. L. 103–43","children":[],"tail":", to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300cc–14"},"text":"section 300cc–14 of this title","children":[],"tail":" prior to renumbering by "},{"tag":"ref","attrib":{"href":"/us/pl/100/607"},"text":"Pub. L. 100–607","children":[],"tail":", to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300aa–14"},"text":"section 300aa–14 of this title","children":[],"tail":" prior to renumbering by "},{"tag":"ref","attrib":{"href":"/us/pl/99/660"},"text":"Pub. L. 99–660","children":[],"tail":", to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s229d"},"text":"section 229d of this title","children":[],"tail":" prior to renumbering by "},{"tag":"ref","attrib":{"href":"/us/pl/98/24"},"text":"Pub. L. 98–24","children":[],"tail":", and to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2689m"},"text":"section 2689m of this title","children":[],"tail":" prior to renumbering by "},{"tag":"ref","attrib":{"href":"/us/pl/97/35"},"text":"Pub. L. 97–35","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb4852a1b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/229"},"text":"Pub. L. 102–229","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/102/239"},"text":"Pub. L. 102–239","children":[],"tail":" amended subsec. (d) identically, substituting “subsection (a)” for “subsection (a)(2)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1985—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/129"},"text":"Pub. L. 99–129","children":[],"tail":" amended section generally. Prior to amendment, section read as follows: “If any facility of a community mental health center acquired, remodeled, constructed, or expanded with funds provided under the Community Mental Health Centers Act is, at any time within twenty years after the completion of such remodeling, construction, or expansion or after the date of its acquisition with such funds—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) sold or transferred to any person or entity (A) which is not qualified to file an application under section 222 of the Community Mental Health Centers Act, or (B) which is not approved as a transferee by the State agency of the State in which such facility is located, or its successor; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) not used by a community mental health center in the provision of comprehensive mental health services, and the Secretary has not determined that there is good cause for termination of such use,","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"the United States shall be entitled to recover from either the transferor or the transferee in the case of a sale or transfer or from the owner in the case of termination of use an amount bearing the same ratio to the then value (as determined by the agreement of the parties or by action brought in the United States district court for the district in which the center is situated) of so much of such facility or center as constituted an approved project or projects, as the amount of the Federal participation bore to the acquisition, remodeling, construction, or expansion cost of such project or projects. Such right of recovery shall not constitute a lien upon such facility or center prior to judgment.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35"},"text":"Pub. L. 97–35","children":[],"tail":" substituted “the Community Mental Health Centers Act” for “this subchapter” and “section 222 of the Community Mental Health Centers Act” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2689j"},"text":"section 2689j of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/622"},"text":"Pub. L. 95–622","children":[],"tail":" substituted “this subchapter” for “this part”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb4852a1c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb4852a1d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1985 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/129/tII/s226/b"},"text":"Pub. L. 99–129, title II, § 226(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-10-22"},"text":"Oct. 22, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/547"},"text":"99 Stat. 547","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/129/tII/s226/b"},"text":"“In the case of any facility that was or is constructed, remodeled, expanded, or acquired on or before the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1985-10-22"},"text":"Oct. 22, 1985","children":[],"tail":"] or within 180 days after the date of enactment of this Act, the period described in clause (i) or (ii), as the case may be, of section 2115(c)(2)(B) [now 243(c)(2)(B)] of the Public Health Service Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s238"},"text":"42 U.S.C. 238","children":[],"tail":null},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"(c)(2)(B)(i), (ii)] (as amended by subsection (a) of this section) shall begin no earlier than 181 days after the date of enactment of this Act.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb4852a1e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1981 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35/tIX/s902/h"},"text":"Pub. L. 97–35, title IX, § 902(h)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/561"},"text":"95 Stat. 561","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/97/35/tIX/s902/h"},"text":"“The amendments made by this section [amending this section and sections 201, 225a [now 238d], 229b [now 238j], 243, 246, 289k–1, 300d–4, 300d–6, 300","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":"–2, 300m, 300m–3, 9412, and 9511 of this title, repealing sections 247b–1, 247b–2, 255, 300d to 300d–3, 300d–5, 300d–7 to 300d–9, 300d–21, 2689 to 2689"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":", 2689n to 2689p, 2689r to 2689aa, 9411, 9421 to 9423, 9431 to 9438, 9451, 9452, 9461 to 9465, 9471 to 9473, 9481, 9491 to 9493, 9502, 9512, 9521, and 9523 of this title, repealing provisions set out as notes under sections 246 and 2689 of this title, and transferring section 2689m to section 229d [now 238"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"] of this title] shall take effect "},{"tag":"date","attrib":{"date":"1981-10-01"},"text":"October 1, 1981","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb4852a1f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1978 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/622/tI/s110/c"},"text":"Pub. L. 95–622, title I, § 110(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-09"},"text":"Nov. 9, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3420"},"text":"92 Stat. 3420","children":[],"tail":", provided that the amendment made by that section is effective "},{"tag":"date","attrib":{"date":"1975-07-29"},"text":"July 29, 1975","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb4852a20-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1975-07-01"},"text":"July 1, 1975","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/94/63/s608"},"text":"section 608 of Pub. L. 94–