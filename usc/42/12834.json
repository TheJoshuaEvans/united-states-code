{"tag":"section","attrib":{"id":"idbfa1b5f7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12834"},"text":null,"children":[{"tag":"num","attrib":{"value":"12834"},"text":"§ 12834.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uniform recordkeeping and reports to Congress","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfa1b5f8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12834/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uniform requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall develop and establish uniform recordkeeping, performance reporting, and auditing requirements for use by participating jurisdictions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfa1b5f9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12834/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfa1b5fa-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/625/tII/s284"},"text":"Pub. L. 101–625, title II, § 284","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4126"},"text":"104 Stat. 4126","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbfa1b5fb-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbfa1b5fc-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbfa1b5fd-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b) of this section, which required the Secretary to make an annual report to Congress that summarizes and assesses the results of reports provided under this section, terminated, effective ","children":[{"tag":"date","attrib":{"date":"2000-05-15"},"text":"May 15, 2000","children":[],"tail":", pursuant to "},{"tag":"ref","attrib":{"href":"/us/pl/104/66/s3003"},"text":"section 3003 of Pub. L. 104–66","children":[],"tail":", as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1113"},"text":"section 1113 of Title 31","children":[],"tail":", Money and Finance. See, also, the 3rd item on page 102 of House Document No. 103–7."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
