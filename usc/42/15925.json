{"tag":"section","attrib":{"id":"idbfebb60a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15925"},"text":null,"children":[{"tag":"num","attrib":{"value":"15925"},"text":"§ 15925.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fair market value determinations for linear rights-of-way across public lands and national forests","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfebb60b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15925/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Update of fee schedule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":"—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfebb60c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15925/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of the Interior shall update section 2806.20 of title 43, Code of Federal Regulations, as in effect on ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":", to revise the per acre rental fee zone value schedule by State, county, and type of linear right-of-way use to reflect current values of land in each zone; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfebb60d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15925/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Agriculture shall make the same revision for linear rights-of-way granted, issued, or renewed under title V of the Federal Lands Policy and Management Act of 1976 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1761"},"text":"43 U.S.C. 1761","children":[],"tail":" et seq.) on National Forest System land."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfebb60e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15925/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fair market value rental determination for linear rights-of-way","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The fair market value rent of a linear right-of-way across public lands or National Forest System lands issued under section 504 of the Federal Land Policy and Management Act of 1976 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1764"},"text":"43 U.S.C. 1764","children":[],"tail":") or "},{"tag":"ref","attrib":{"href":"/us/usc/t30/s185"},"text":"section 185 of title 30","children":[],"tail":" shall be determined in accordance with subpart 2806 of title 43, Code of Federal Regulations, as in effect on "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":" (including the annual or periodic updates specified in the regulations), and as updated in accordance with subsection (a)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfebb60f-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tIII/s367"},"text":"Pub. L. 109–58, title III, § 367","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/726"},"text":"119 Stat. 726","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbfebb610-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbfebb611-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbfebb612-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Land Policy and Management Act of 1976, referred to in subsec. (a)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/579"},"text":"Pub. L. 94–579","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2743"},"text":"90 Stat. 2743","children":[],"tail":". Title V of the Act is classified generally to subchapter V (§ 1761 et seq.) of chapter 35 of Title 43, Public Lands. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1701"},"text":"section 1701 of Title 43","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
