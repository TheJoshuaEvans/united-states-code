{"tag":"section","attrib":{"id":"idc0169710-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16493"},"text":null,"children":[{"tag":"num","attrib":{"value":"16493"},"text":"§ 16493.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Priority Project Designation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc0169711-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16493/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation of National Priority Projects","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0169712-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16493/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established the National Priority Project Designation (referred to in this section as the “Designation”), which shall be evidenced by a medal bearing the inscription “National Priority Project”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0169713-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16493/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Design and materials","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The medal shall be of such design and materials and bear such additional inscriptions as the President may prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0169714-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16493/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Making and presentation of Designation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0169715-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16493/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President, on the basis of recommendations made by the Secretary, shall annually designate organizations that have—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0169716-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16493/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advanced the field of renewable energy technology and contributed to North American energy independence; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0169717-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16493/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" been certified by the Secretary under subsection (e).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0169718-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16493/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Presentation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall designate projects with such ceremonies as the President may prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0169719-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16493/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of Designation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An organization that receives a Designation under this section may publicize the Designation of the organization as a National Priority Project in advertising.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc016971a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16493/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Categories in which the Designation may be given","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Separate Designations shall be made to qualifying projects in each of the following categories:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc016971b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16493/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Wind and biomass energy generation projects.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc016971c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16493/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Photovoltaic and fuel cell energy generation projects.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc016971d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16493/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Energy efficient building and renewable energy projects.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc016971e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16493/b/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" First-in-Class projects.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc016971f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16493/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection criteria","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0169720-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16493/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Certification and selection of the projects to receive the Designation shall be based on criteria established under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0169721-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16493/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Wind, biomass, and building projects","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a wind, biomass, or building project, the project shall demonstrate that the project will install not less than 30 megawatts of renewable energy generation capacity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0169722-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16493/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Solar photovoltaic and fuel cell projects","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a solar photovoltaic or fuel cell project, the project shall demonstrate that the project will install not less than 3 megawatts of renewable energy generation capacity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0169723-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16493/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Energy efficient building and renewable energy projects","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of an energy efficient building or renewable energy project, in addition to meeting the criteria established under paragraph (2), each building project shall demonstrate that the project will—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0169724-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16493/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" comply with third-party certification standards for high-performance, sustainable buildings;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0169725-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16493/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use whole-building integration of energy efficiency and environmental performance design and technology, including advanced building controls;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0169726-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16493/c/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use renewable energy for at least 50 percent of the energy consumption of the project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0169727-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16493/c/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" comply with applicable Energy Star standards; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0169728-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16493/c/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include at least 5,000,000 square feet of enclosed space.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0169729-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16493/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" First-in-Class use","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding paragraphs (2) through (4), a new building project may qualify under this section if the Secretary determines that the project—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc016972a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16493/c/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" represents a First-In-Class use of renewable energy; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc016972b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16493/c/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" otherwise establishes a new paradigm of building integrated renewable energy use or energy efficiency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc016972c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16493/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc016972d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16493/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial applications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No later than 120 days after ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":", and annually thereafter, the Secretary shall publish in the Federal Register an invitation and guidelines for submitting applications, consistent with this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc016972e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16493/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The application shall describe the project, or planned project, and the plans to meet the criteria established under subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc016972f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16493/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0169730-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16493/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 60 days after the application period described in subsection (d), and annually thereafter, the Secretary shall certify projects that are reasonably expected to meet the criteria established under subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0169731-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16493/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certified projects","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall designate personnel of the Department to work with persons carrying out each certified project and ensure that the personnel—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0169732-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16493/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide each certified project with guidance in meeting the criteria established under subsection (c);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0169733-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16493/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify programs of the Department, including National Laboratories and Technology Centers, that will assist each project in meeting the criteria established under subsection (c); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0169734-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16493/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that knowledge and transfer of the most current technology between the applicable resources of the Federal Government (including the National Laboratories and Technology Centers, the Department, and the Environmental Protection Agency) and the certified projects is being facilitated to accelerate commercialization of work developed through those resources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0169735-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16493/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums as are necessary to carry out this section for each of fiscal years 2006 through 2010.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc0169736-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tXIV/s1405"},"text":"Pub. L. 109–58, title XIV, § 1405","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1062"},"text":"119 Stat. 1062","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
