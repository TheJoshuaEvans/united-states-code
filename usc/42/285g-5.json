{"tag":"section","attrib":{"id":"idb575f31b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285g–5"},"text":null,"children":[{"tag":"num","attrib":{"value":"285g–5"},"text":"§ 285g–5.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research centers with respect to contraception and infertility","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb575f31c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285g–5/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants and contracts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the Institute, after consultation with the advisory council for the Institute, shall make grants to, or enter into contracts with, public or nonprofit private entities for the development and operation of centers to conduct activities for the purpose of improving methods of contraception and centers to conduct activities for the purpose of improving methods of diagnosis and treatment of infertility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb575f31d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285g–5/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Number of centers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out subsection (a), the Director of the Institute shall, subject to the extent of amounts made available in appropriations Acts, provide for the establishment of three centers with respect to contraception and for two centers with respect to infertility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb575f31e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285g–5/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb575f31f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285g–5/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Each center assisted under this section shall, in carrying out the purpose of the center involved—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb575f320-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285g–5/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" conduct clinical and other applied research, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb575f321-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285g–5/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for centers with respect to contraception, clinical trials of new or improved drugs and devices for use by males and females (including barrier methods); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb575f322-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285g–5/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for centers with respect to infertility, clinical trials of new or improved drugs and devices for the diagnosis and treatment of infertility in males and females;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb575f323-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285g–5/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop protocols for training physicians, scientists, nurses, and other health and allied health professionals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb575f324-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285g–5/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct training programs for such individuals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb575f325-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285g–5/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop model continuing education programs for such professionals; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb575f326-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285g–5/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disseminate information to such professionals and the public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb575f327-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285g–5/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A center may use funds provided under subsection (a) to provide stipends for health and allied health professionals enrolled in programs described in subparagraph (C) of paragraph (1), and to provide fees to individuals serving as subjects in clinical trials conducted under such paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb575f328-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285g–5/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination of information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the Institute shall, as appropriate, provide for the coordination of information among the centers assisted under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb575f329-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285g–5/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Facilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each center assisted under subsection (a) shall use the facilities of a single institution, or be formed from a consortium of cooperating institutions, meeting such requirements as may be prescribed by the Director of the Institute.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb575f32a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285g–5/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Period of support","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Support of a center under subsection (a) may be for a period not exceeding 5 years. Such period may be extended for one or more additional periods not exceeding 5 years if the operations of such center have been reviewed by an appropriate technical and scientific peer review group established by the Director and if such group has recommended to the Director that such period should be extended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb575f32b-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title IV, § 452A, as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/43/tX/s1001"},"text":"Pub. L. 103–43, title X, § 1001","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-06-10"},"text":"June 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/165"},"text":"107 Stat. 165","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/482/tI/s103/b/29"},"text":"Pub. L. 109–482, title I, § 103(b)(29)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-01-15"},"text":"Jan. 15, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3688"},"text":"120 Stat. 3688","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb575f32c-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb575f32d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb575f32e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2007—Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/482"},"text":"Pub. L. 109–482","children":[],"tail":" struck out subsec. (g) which read as follows: “For the purpose of carrying out this section, there are authorized to be appropriated $30,000,000 for fiscal year 1994, and such sums as may be necessary for each of the fiscal years 1995 and 1996.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb575f32f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb575f330-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2007 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/482"},"text":"Pub. L. 109–482","children":[],"tail":" applicable only with respect to amounts appropriated for fiscal year 2007 or subsequent fiscal years, see "},{"tag":"ref","attrib":{"href":"/us/pl/109/482/s109"},"text":"section 109 of Pub. L. 109–482","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s281"},"text":"section 281 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
