{"tag":"section","attrib":{"id":"idbfdb15a3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15029"},"text":null,"children":[{"tag":"num","attrib":{"value":"15029"},"text":"§ 15029.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfdd5e94-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15029/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding for State allotments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as described in subsection (b), there are authorized to be appropriated for allotments under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s15022"},"text":"section 15022 of this title","children":[],"tail":" $76,000,000 for fiscal year 2001 and such sums as may be necessary for each of fiscal years 2002 through 2007."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfdd5e95-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15029/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reservation for technical assistance","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfdd5e96-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15029/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lower appropriation years","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For any fiscal year for which the amount appropriated under subsection (a) is less than $76,000,000, the Secretary shall reserve funds in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s15083/c"},"text":"section 15083(c) of this title","children":[],"tail":" to provide technical assistance to entities funded under this part."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfdd5e97-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15029/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Higher appropriation years","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For any fiscal year for which the amount appropriated under subsection (a) is not less than $76,000,000, the Secretary shall reserve not less than $300,000 and not more than 1 percent of the amount appropriated under subsection (a) to provide technical assistance to entities funded under this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfdd5e98-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/402/tI/s129"},"text":"Pub. L. 106–402, title I, § 129","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1712"},"text":"114 Stat. 1712","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
