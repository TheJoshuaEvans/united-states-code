{"tag":"section","attrib":{"id":"idbea77708-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8901"},"text":null,"children":[{"tag":"num","attrib":{"value":"8901"},"text":"§ 8901.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Introductory provisions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbea77709-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8901/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional statement of findings and purpose","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Congress finds and declares that acid precipitation resulting from other than natural sources—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbea7770a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8901/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" could contribute to the increasing pollution of natural and man-made water systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbea7770b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8901/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" could adversely affect agricultural and forest crops;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbea7770c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8901/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" could adversely affect fish and wildlife and natural ecosystems generally;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbea7770d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8901/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" could contribute to corrosion of metals, wood, paint, and masonry used in construction and ornamentation of buildings and public monuments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbea7770e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8901/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" could adversely affect public health and welfare; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbea7770f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8901/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" could affect areas distant from sources and thus involve issues of national and international policy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbea77710-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8901/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional declaration of purpose","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Congress declares that it is the purpose of this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbea77711-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8901/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to identify the causes and sources of acid precipitation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbea77712-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8901/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to evaluate the environmental, social, and economic effects of acid precipitation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbea77713-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8901/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" based on the results of the research program established by this subchapter and to the extent consistent with existing law, to take action to the extent necessary and practicable (A) to limit or eliminate the identified emissions which are sources of acid precipitation, and (B) to remedy or otherwise ameliorate the harmful effects which may result from acid precipitation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbea77714-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8901/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Acid precipitation” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subchapter the term “acid precipitation” means the wet or dry deposition from the atmosphere of acid chemical compounds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbea77715-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/294/tVII/s702"},"text":"Pub. L. 96–294, title VII, § 702","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-06-30"},"text":"June 30, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/770"},"text":"94 Stat. 770","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbea77716-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbea77717-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"idbea77718-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 701 of title VII ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/294"},"text":"Pub. L. 96–294","children":[],"tail":" provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/96/294"},"text":"“This title [enacting this chapter] may be cited as the ‘Acid Precipitation Act of 1980’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
