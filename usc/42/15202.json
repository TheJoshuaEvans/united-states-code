{"tag":"section","attrib":{"id":"idbfdfd069-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15202"},"text":null,"children":[{"tag":"num","attrib":{"value":"15202"},"text":"§ 15202.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Medal of Valor Board","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfdfd06a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15202/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of Board","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established a Medal of Valor Review Board (hereinafter in this chapter referred to as the “Board”), which shall be composed of 11 members appointed in accordance with subsection (b) and shall conduct its business in accordance with this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfdfd06b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15202/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfdfd06c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15202/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Members","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The members of the Board shall be individuals with knowledge or expertise, whether by experience or training, in the field of public safety, of which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfdfd06d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15202/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" two shall be appointed by the majority leader of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfdfd06e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15202/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" two shall be appointed by the minority leader of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfdfd06f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15202/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" two shall be appointed by the Speaker of the House of Representatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfdfd070-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15202/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" two shall be appointed by the minority leader of the House of Representatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfdfd071-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15202/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" three shall be appointed by the President, including one with experience in firefighting, one with experience in law enforcement, and one with experience in emergency services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfdfd072-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15202/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term of a Board member shall be 4 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfdfd073-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15202/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vacancies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any vacancy in the membership of the Board shall not affect the powers of the Board and shall be filled in the same manner as the original appointment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfdfd074-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15202/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Operation of the Board","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfdfd075-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15202/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chairman","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Chairman of the Board shall be elected by the members of the Board from among the members of the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfdfd076-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15202/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall conduct its first meeting not later than 90 days after the appointment of the last member appointed of the initial group of members appointed to the Board. Thereafter, the Board shall meet at the call of the Chairman of the Board. The Board shall meet not less often than twice each year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfdfd077-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15202/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Voting and rules","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A majority of the members shall constitute a quorum to conduct business, but the Board may establish a lesser quorum for conducting hearings scheduled by the Board. The Board may establish by majority vote any other rules for the conduct of the Board’s business, if such rules are not inconsistent with this chapter or other applicable law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfdfd078-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15202/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall select candidates as recipients of the Medal of Valor from among those applications received by the National Medal of Valor Office. Not more often than once each year, the Board shall present to the Attorney General the name or names of those it recommends as Medal of Valor recipients. In a given year, the Board shall not be required to select any recipients but may not select more than 5 individuals, or groups of individuals, as recipients. The Attorney General may in extraordinary cases increase the number of recipients in a given year. The Board shall set an annual timetable for fulfilling its duties under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfdfd079-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15202/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hearings","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfdfd07a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15202/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board may hold such hearings, sit and act at such times and places, administer such oaths, take such testimony, and receive such evidence as the Board considers advisable to carry out its duties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfdfd07b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15202/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Witness expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Witnesses requested to appear before the Board may be paid the same fees as are paid to witnesses under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s1821"},"text":"section 1821 of title 28","children":[],"tail":". The per diem and mileage allowances for witnesses shall be paid from funds appropriated to the Board."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfdfd07c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15202/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information from Federal agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board may secure directly from any Federal department or agency such information as the Board considers necessary to carry out its duties. Upon the request of the Board, the head of such department or agency may furnish such information to the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfdfd07d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15202/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information to be kept confidential","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall not disclose any information which may compromise an ongoing law enforcement investigation or is otherwise required by law to be kept confidential.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfdfd07e-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/12/s3"},"text":"Pub. L. 107–12, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-05-30"},"text":"May 30, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/20"},"text":"115 Stat. 20","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/162/tXI/s1112"},"text":"Pub. L. 109–162, title XI, § 1112","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-05"},"text":"Jan. 5, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3103"},"text":"119 Stat. 3103","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbfdfd07f-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbfdfd080-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbfdfd081-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsecs. (a), (b)(4)(C), and (c), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/12"},"text":"Pub. L. 107–12","children":[],"tail":", May. 30, 2001, "},{"tag":"ref","attrib":{"href":"/us/stat/115/20"},"text":"115 Stat. 20","children":[],"tail":", which enacted this chapter and amended "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s2214"},"text":"section 2214 of Title 15","children":[],"tail":", Commerce and Trade. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s15201"},"text":"section 15201 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbfdfd082-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/162"},"text":"Pub. L. 109–162","children":[],"tail":" substituted “more than 5 individuals, or groups of individuals, as recipients” for “more than 5 recipients”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
