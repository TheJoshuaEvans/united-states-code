{"tag":"section","attrib":{"id":"idbeffa8ef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858i"},"text":null,"children":[{"tag":"num","attrib":{"value":"9858i"},"text":"§ 9858i.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports and audits","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbeffa8f0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858i/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbeffa8f1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858i/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collection of information by States","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbeffa8f2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858i/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State that receives funds to carry out this subchapter shall collect the information described in subparagraph (B) on a monthly basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbeffa8f3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858i/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required information","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The information required under this subparagraph shall include, with respect to a family unit receiving assistance under this subchapter ","children":[{"tag":"ref","attrib":{"idref":"fn003909"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003909"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be followed by a comma."}],"tail":" information concerning—"}],"tail":null},{"tag":"clause","attrib":{"id":"idbeffa8f4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858i/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" family income;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbeffa8f5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858i/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" county of residence;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbeffa8f6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858i/a/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the gender, race, and age of children receiving such assistance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbeffa8f7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858i/a/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether the head of the family unit is a single parent;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbeffa8f8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858i/a/1/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the sources of family income, including—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbeffa8f9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858i/a/1/B/v/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" employment, including self-employment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbeffa8fa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858i/a/1/B/v/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" cash or other assistance under—","children":[],"tail":null},{"tag":"item","attrib":{"id":"idbeffa8fb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858i/a/1/B/v/II/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the temporary assistance for needy families program under part A of title IV of the Social Security Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s601"},"text":"42 U.S.C. 601","children":[],"tail":" et seq.); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idbeffa8fc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858i/a/1/B/v/II/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State program for which State spending is counted toward the maintenance of effort requirement under section 409(a)(7) of the Social Security Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s609/a/7"},"text":"42 U.S.C. 609(a)(7)","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbeffa8fd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858i/a/1/B/v/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" housing assistance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbeffa8fe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858i/a/1/B/v/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assistance under the Food and Nutrition Act of 2008 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2011"},"text":"7 U.S.C. 2011","children":[],"tail":" et seq.]; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbeffa8ff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858i/a/1/B/v/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other assistance programs;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbeffa900-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858i/a/1/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of months the family has received benefits;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbeffa901-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858i/a/1/B/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the type of child care in which the child was enrolled (such as family child care, home care, or center-based child care);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbeffa902-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858i/a/1/B/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether the child care provider involved was a relative;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbeffa903-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858i/a/1/B/ix"},"text":null,"children":[{"tag":"num","attrib":{"value":"ix"},"text":"(ix)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cost of child care for such families;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbeffa904-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858i/a/1/B/x"},"text":null,"children":[{"tag":"num","attrib":{"value":"x"},"text":"(x)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the average hours per month of such care; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbeffa905-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858i/a/1/B/xi"},"text":null,"children":[{"tag":"num","attrib":{"value":"xi"},"text":"(xi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether the children receiving assistance under this subchapter are homeless children;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"during the period for which such information is required to be submitted.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbeffa906-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858i/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission to Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State described in subparagraph (A) shall, on a quarterly basis, submit the information required to be collected under subparagraph (B) to the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbeffa907-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858i/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of samples","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbeffa908-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858i/a/1/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State may comply with the requirement to collect the information described in subparagraph (B) through the use of disaggregated case record information on a sample of families selected through the use of scientifically acceptable sampling methods approved by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbeffa909-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858i/a/1/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sampling and other methods","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide the States with such case sampling plans and data collection procedures as the Secretary deems necessary to produce statistically valid samples of the information described in subparagraph (B). The Secretary may develop and implement procedures for verifying the quality of data submitted by the States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbeffa90a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858i/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Reports submitted to the Secretary under subparagraph (C) shall not contain personally identifiable information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbeffa90b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858i/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual reports","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2014-11-19"},"text":"November 19, 2014","children":[],"tail":", and annually thereafter,,"},{"tag":"ref","attrib":{"idref":"fn003910"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003910"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original."}],"tail":" a State described in paragraph (1)(A) shall prepare and submit to the Secretary a report that includes aggregate data concerning—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbeffa90c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858i/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of child care providers that received funding under this subchapter as separately identified based on the types of providers listed in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s9858n/6"},"text":"section 9858n(6) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbeffa90d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858i/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the monthly cost of child care services, and the portion of such cost that is paid for with assistance provided under this subchapter, listed by the type of child care services provided;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbeffa90e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858i/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of payments made by the State through vouchers, contracts, cash, and disregards under public benefit programs, listed by the type of child care services provided;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbeffa90f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858i/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the manner in which consumer education information was provided to parents and the number of parents to whom such information was provided; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbeffa910-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858i/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total number (without duplication) of children and families served under this subchapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbeffa911-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858i/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of child fatalities occurring among children while in the care and facility of child care providers receiving assistance under this subchapter, listed by type of child care provider and indicating whether the providers (excluding child care providers described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s9858n/6/B"},"text":"section 9858n(6)(B) of this title","children":[],"tail":") are licensed or license-exempt."},{"tag":"ref","attrib":{"idref":"fn003911"},"text":"3","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003911"},"text":null,"children":[{"tag":"num","attrib":{},"text":"3","children":[],"tail":" So in original. The period probably should be a semicolon."}],"tail":null}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"during the period for which such report is required to be submitted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbeffa912-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858i/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Audits","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbeffa913-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858i/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State shall, after the close of each program period covered by an application approved under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s9858c/d"},"text":"section 9858c(d) of this title","children":[],"tail":" audit its expenditures during such program period from amounts received under this subchapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbeffa914-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858i/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Independent auditor","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Audits under this subsection shall be conducted by an entity that is independent of the State that receives assistance under this subchapter and be in accordance with generally accepted auditing principles.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbeffa915-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858i/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 30 days after the completion of an audit under this subsection, the State shall submit a copy of the audit to the legislature of the State and to the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbeffa916-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858i/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repayment of amounts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each State shall repay to the United States any amounts determined through an audit under this subsection not to have been expended in accordance with this subchapter, or the Secretary may offset such amounts against any other amount to which the State is or may be entitled under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbeffa917-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35/tVI/s658K"},"text":"Pub. L. 97–35, title VI, § 658K","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/tV/s5082/2"},"text":"Pub. L. 101–508, title V, § 5082(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-243"},"text":"104 Stat. 1388–243","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/401/s3/a"},"text":"Pub. L. 102–401, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-07"},"text":"Oct. 7, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1959"},"text":"106 Stat. 1959","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/586/s8/c/1"},"text":"Pub. L. 102–586, § 8(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-11-04"},"text":"Nov. 4, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/5036"},"text":"106 Stat. 5036","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/193/tVI/s611"},"text":"Pub. L. 104–193, title VI, § 611","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-22"},"text":"Aug. 22, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2284"},"text":"110 Stat. 2284","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/33/tV/s5602/2"},"text":"Pub. L. 105–33, title V, § 5602(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/646"},"text":"111 Stat. 646","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tIV/s4002/b/1/B"},"text":"Pub. L. 110–234, title IV, § 4002(b)(1)(B)","children":[],"tail":", (2)(FF), "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1096"},"text":"122 Stat. 1096","children":[],"tail":", 1098; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title IV, § 4002(b)(1)(B), (2)(FF), "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 1857, 1859; "},{"tag":"ref","attrib":{"href":"/us/pl/113/186/s8/c"},"text":"Pub. L. 113–186, § 8(c)","children":[],"tail":", (e), "},{"tag":"date","attrib":{"date":"2014-11-19"},"text":"Nov. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1996"},"text":"128 Stat. 1996","children":[],"tail":", 1998.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbeffa918-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbeffa919-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbeffa91a-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Social Security Act, referred to in subsec. (a)(1)(B)(v)(II)(aa), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"act Aug. 14, 1935, ch. 531","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/620"},"text":"49 Stat. 620","children":[],"tail":". Part A of title IV of the Act is classified generally to part A (§ 601 et seq.) of subchapter IV of chapter 7 of this title. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1305"},"text":"section 1305 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Food and Nutrition Act of 2008, referred to in subsec. (a)(1)(B)(v)(IV), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/525"},"text":"Pub. L. 88–525","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-08-31"},"text":"Aug. 31, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/703"},"text":"78 Stat. 703","children":[],"tail":", which is classified generally to chapter 51 (§ 2011 et seq.) of Title 7, Agriculture. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2011"},"text":"section 2011 of Title 7","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbeffa91b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" made identical amendments to this section. The amendments by "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" were repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbeffa91c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsec. (a)(1)(B)(xi). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/186/s8/c/1"},"text":"Pub. L. 113–186, § 8(c)(1)","children":[],"tail":", which directed amendment of par. (1)(B) by adding cl. (xi) “at the end”, was executed by adding cl. (xi) after cl. (x), to reflect the probable intent of Congress and the presence of concluding provisions in par. (1)(B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/186/s8/e"},"text":"Pub. L. 113–186, § 8(e)","children":[],"tail":", added subpar. (E)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/186/s8/c/2/A"},"text":"Pub. L. 113–186, § 8(c)(2)(A)","children":[],"tail":", substituted “1 year after "},{"tag":"date","attrib":{"date":"2014-11-19"},"text":"November 19, 2014","children":[],"tail":", and annually thereafter,” for “"},{"tag":"date","attrib":{"date":"1997-12-31"},"text":"December 31, 1997","children":[],"tail":", and every 12 months thereafter” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/186/s8/c/2/B"},"text":"Pub. L. 113–186, § 8(c)(2)(B)","children":[],"tail":", substituted “section 9858n(6)” for “section 9858n(5)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/186/s8/c/2/C"},"text":"Pub. L. 113–186, § 8(c)(2)(C)","children":[],"tail":", which directed substitution of “; and” for period at end, was executed by making the substitution for semicolon at end, to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/186/s8/c/2/D"},"text":"Pub. L. 113–186, § 8(c)(2)(D)","children":[],"tail":", which directed amendment of par. (2) by adding subpar. (F) “at the end”, was executed by adding subpar. (F) after subpar. (E), to reflect the probable intent of Congress and the presence of concluding provisions in par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (a)(1)(B)(v)(IV). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4002/b/1/B"},"text":"Pub. L. 110–246, § 4002(b)(1)(B)","children":[],"tail":", (2)(FF), substituted “Food and Nutrition Act of 2008” for “Food Stamp Act of 1977”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (a)(1)(B)(iv). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/33/s5602/2/A/i/I"},"text":"Pub. L. 105–33, § 5602(2)(A)(i)(I)","children":[],"tail":", added cl. (iv) and struck out former cl. (iv) which read as follows: “whether the family includes only one parent;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(B)(v). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/33/s5602/2/A/i/II/aa"},"text":"Pub. L. 105–33, § 5602(2)(A)(i)(II)(aa)","children":[],"tail":", substituted “including—” for “including the amount obtained from (and separately identified)—” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(B)(v)(II). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/33/s5602/2/A/i/II/bb"},"text":"Pub. L. 105–33, § 5602(2)(A)(i)(II)(bb)","children":[],"tail":", added subcl. (II) and struck out former subcl. (II) which read as follows: “cash or other assistance under part A of title IV of the Social Security Act;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(B)(x). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/33/s5602/2/A/i/III"},"text":"Pub. L. 105–33, § 5602(2)(A)(i)(III)","children":[],"tail":", substituted “month” for “week”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/33/s5602/2/A/ii"},"text":"Pub. L. 105–33, § 5602(2)(A)(ii)","children":[],"tail":", added subpar. (D) and struck out heading and text of former subpar. (D). Text read as follows: “The Secretary may disapprove the information collected by a State under this paragraph if the State uses sampling methods to collect such information.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/33/s5602/2/B"},"text":"Pub. L. 105–33, § 5602(2)(B)","children":[],"tail":", substituted “Annual” for “Biannual” in heading and “12” for “6” in introductory provisions of text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/193/s611/1"},"text":"Pub. L. 104–193, § 611(1)","children":[],"tail":", substituted “Reports” for “Annual report” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/193/s611/2"},"text":"Pub. L. 104–193, § 611(2)","children":[],"tail":", amended heading and text of subsec. (a) generally. Prior to amendment, text related to requirement of reports by "},{"tag":"date","attrib":{"date":"1992-12-31"},"text":"Dec. 31, 1992","children":[],"tail":", and annually thereafter, which include specification of expenditures under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s9858c/c/3"},"text":"section 9858c(c)(3) of this title","children":[],"tail":", data on fulfillment of child care needs, description of improvements in affordability and availability, description of review of State licensing and regulatory requirements and policies and results of review, explanation of any reductions in child care standards, and description of standards and health and safety requirements applicable to providers."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/193/s611/2/s3"},"text":"Pub. L. 104–193, § 611(2)[(3)]","children":[],"tail":"(A), substituted “an application approved” for “a application approved”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/193/s611/2/s3"},"text":"Pub. L. 104–193, § 611(2)[(3)]","children":[],"tail":"(B), substituted “the State that receives” for “any agency administering activities that receive”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/193/s611/2/s3"},"text":"Pub. L. 104–193, § 611(2)[(3)]","children":[],"tail":"(C), substituted “entitled under this subchapter” for “entitles under this subchapter”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/401"},"text":"Pub. L. 102–401","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/102/586"},"text":"Pub. L. 102–586","children":[],"tail":" made identical technical corrections to directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/s5082/2"},"text":"Pub. L. 101–508, § 5082(2)","children":[],"tail":", which added this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbeffa91d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbeffa91e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment of this section and repeal of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4"},"text":"section 4 of Pub. L. 110–246","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8701"},"text":"section 8701 of Title 7","children":[],"tail":",