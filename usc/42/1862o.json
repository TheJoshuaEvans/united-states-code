"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2168"},"text":"129 Stat. 2168","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/95/tIX/s9215/i/5"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“In this title [enacting this section and sections 1862n–1a and 1862","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":"–1 to 1862"},{"tag":"i","attrib":{},"text":"o","children":[],"tail":"–15 of this title, amending sections 1862i, 1862"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":", 1862n, 1862n–1, 1862n–2, 1862n–5, 1863, 1870, and 1881a of this title, sections 5503 and 5511 of Title 15, Commerce and Trade, and "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s3801"},"text":"section 3801 of Title 31","children":[],"tail":", Money and Finance, enacting provisions set out as notes under this section and "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1862n–2"},"text":"section 1862n–2 of this title","children":[],"tail":", and amending provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1113"},"text":"section 1113 of Title 31","children":[],"tail":"]:"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Basic research","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘basic research’ has the meaning given such term in the Office of Management and Budget circular No. A–11.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Board","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘Board’ means the National Science Board established under section 2 of the National Science Foundation Act of 1950 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1861"},"text":"42 U.S.C. 1861","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Director","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘Director’ means the Director of the Foundation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Elementary school","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘elementary school’ has the meaning given such term in section 8101 of the Elementary and Secondary Education Act of 1965 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7801"},"text":"20 U.S.C. 7801","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Foundation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘Foundation’ means the National Science Foundation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"“(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Institution of higher education","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘institution of higher education’ has the meaning given such term in section 101(a) of the Higher Education Act of 1965 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001/a"},"text":"20 U.S.C. 1001(a)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"“(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Secondary school","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘secondary school’ has the meaning given such term in section 8101 of the Elementary and Secondary Education Act of 1965 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7801"},"text":"20 U.S.C. 7801","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
