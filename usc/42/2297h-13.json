{"tag":"section","attrib":{"id":"idbc1ed019-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2297h–13"},"text":null,"children":[{"tag":"num","attrib":{"value":"2297h–13"},"text":"§ 2297h–13.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of certain laws","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbc1ed01a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2297h–13/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" OSHA","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc1ed01b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2297h–13/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" As of the privatization date, the private corporation shall be subject to and comply with the Occupational Safety and Health Act of 1970 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s651"},"text":"29 U.S.C. 651","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc1ed01c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2297h–13/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Nuclear Regulatory Commission and the Occupational Safety and Health Administration shall, within 90 days after ","children":[{"tag":"date","attrib":{"date":"1996-04-26"},"text":"April 26, 1996","children":[],"tail":", enter into a memorandum of agreement to govern the exercise of their authority over occupational safety and health hazards at the gaseous diffusion plants, including inspection, investigation, enforcement, and rulemaking relating to such hazards."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc1ed01d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2297h–13/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Antitrust laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of the antitrust laws, the performance by the private corporation of a “matched import” contract under the Suspension Agreement shall be considered to have occurred prior to the privatization date, if at the time of privatization, such contract had been agreed to by the parties in all material terms and confirmed by the Secretary of Commerce under the Suspension Agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc1ed01e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2297h–13/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Energy Reorganization Act requirements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc1ed01f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2297h–13/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The private corporation and its contractors and subcontractors shall be subject to the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5851"},"text":"section 5851 of this title","children":[],"tail":" to the same extent as an employer subject to such section."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc1ed020-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2297h–13/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" With respect to the operation of the facilities leased by the private corporation, ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5846"},"text":"section 5846 of this title","children":[],"tail":" shall apply to the directors and officers of the private corporation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc1ed021-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/134/tIII/s3115"},"text":"Pub. L. 104–134, title III, § 3115","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-26"},"text":"Apr. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1321-348"},"text":"110 Stat. 1321–348","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc1ed022-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc1ed023-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbc1ed024-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Occupational Safety and Health Act of 1970, referred to in subsec. (a)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/596"},"text":"Pub. L. 91–596","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-29"},"text":"Dec. 29, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1590"},"text":"84 Stat. 1590","children":[],"tail":", which is classified principally to chapter 15 (§ 651 et seq.) of Title 29, Labor. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s651"},"text":"section 651 of Title 29","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbc1ed025-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the USEC Privatization Act and also as part of the Omnibus Consolidated Rescissions and Appropriations Act of 1996, and not as part of the Atomic Energy Act of 1954 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
