{"tag":"section","attrib":{"id":"idb7a88b02-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629k"},"text":null,"children":[{"tag":"num","attrib":{"value":"629k"},"text":"§ 629k.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reduction of administrative burden","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb7a88b03-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629k/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall reduce the burden of administering this part imposed on the recipients of funds under this part, by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7a88b04-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629k/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reviewing and revising administrative data collection instruments and forms to eliminate duplication and streamline reporting requirements for the recipients while collecting all data required under this part;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7a88b05-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629k/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in coordination with activities required under the Paperwork Reduction Act, conducting an analysis of the total number of hours reported by the recipients to comply with paperwork requirements and exploring, in consultation with the recipients, how to reduce the number of hours required for the compliance by at least 15 percent;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7a88b06-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629k/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collecting input from the recipients with respect to fiscal and oversight requirements and making changes to ensure consistency with standards and guidelines for other Federal formula grant programs based on the input; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7a88b07-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629k/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" respecting the sovereignty of Indian tribes when complying with this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7a88b08-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629k/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on applicability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsection (a) of this section shall not apply to any reporting or data collection otherwise required by law that would affect the ability of the Secretary to monitor and ensure compliance with State plans approved under this part or ensure that funds are expended consistent with this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb7a88b09-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title IV, § 441, as added "},{"tag":"ref","attrib":{"href":"/us/pl/118/258/tI/s106/f/1"},"text":"Pub. L. 118–258, title I, § 106(f)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2952"},"text":"138 Stat. 2952","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb7a88b0a-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb7a88b0b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb7a88b0c-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Paperwork Reduction Act, referred to in subsec. (a)(2), probably means chapter 35 (§ 3501 et seq.) of Title 44, Public Printing and Documents. See Short Title note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t44/s3501"},"text":"section 3501 of Title 44","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb7a88b0d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb7a88b0e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2025-10-01"},"text":"Oct. 1, 2025","children":[],"tail":", and applicable to payments under this part for calendar quarters beginning on or after such date, with delay permitted if either State legislation or tribal action is required to meet additional requirements, see "},{"tag":"ref","attrib":{"href":"/us/pl/118/258/s117"},"text":"section 117 of Pub. L. 118–258","children":[],"tail":", set out as an Effective Date of 2025 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s622"},"text":"section 622 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb7a88b0f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Implementation","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/258/tI/s106/f/2"},"text":"Pub. L. 118–258, title I, § 106(f)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2953"},"text":"138 Stat. 2953","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/258/tI/s106/f/2"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Within 2 years after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":"], the Secretary of Health and Human Services shall—"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" comply with section 441 of the Social Security Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s629k"},"text":"42 U.S.C. 629k","children":[],"tail":"], as added by the amendment made by paragraph (1); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notify each recipient of funds under part B of title IV of the Social Security Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s620"},"text":"42 U.S.C. 620","children":[],"tail":" et seq.] of any change made by the Secretary pursuant to such section affecting the recipient.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
