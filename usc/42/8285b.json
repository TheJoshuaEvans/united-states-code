{"tag":"section","attrib":{"id":"idbe8d3899-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8285b"},"text":null,"children":[{"tag":"num","attrib":{"value":"8285b"},"text":"§ 8285b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbe8d389a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8285b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may make grants to any Governor of a State for the training and certification of individuals to conduct energy audits.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe8d389b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8285b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Before making a grant under subsection (a) to a Governor, the Secretary must receive from the Governor an application containing—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbe8d389c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8285b/b/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any information which the Secretary deems is necessary to carry out this subchapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe8d389d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8285b/b/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assurance that the grant will supplement and not supplant other funds available for such training and certification and will be used to increase the total amount of funds available for such training and certification.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe8d389e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8285b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe8d389f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8285b/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Before making any grant under subsection (a) the Secretary shall establish minimum standards for the training and certification of individuals to conduct energy audits.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe8d38a0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8285b/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall require each Governor receiving any grant under this subchapter to agree to meet the standards established pursuant to paragraph (1) in any training and certification conducted using funds provided under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbe8d38a1-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/294/tV/s583"},"text":"Pub. L. 96–294, title V, § 583","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-06-30"},"text":"June 30, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/761"},"text":"94 Stat. 761","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbe8d38a2-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbe8d38a3-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbe8d38a4-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Energy Security Act, and not as part of the National Energy Conservation Policy Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
