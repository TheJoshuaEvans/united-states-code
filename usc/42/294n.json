{"tag":"section","attrib":{"id":"idb5e3a891-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294n"},"text":null,"children":[{"tag":"num","attrib":{"value":"294n"},"text":"§ 294n.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Health professions workforce information and analysis","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5e3a892-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294n/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is the purpose of this section to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5e3a893-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294n/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for the development of information describing the health professions workforce and the analysis of workforce related issues; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5e3a894-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294n/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide necessary information for decision-making regarding future directions in health professions and nursing programs in response to societal and professional needs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5e3a895-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294n/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Center for Health Care Workforce Analysis","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5e3a896-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294n/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish the National Center for Health Workforce Analysis (referred to in this section as the “National Center”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5e3a897-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294n/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The National Center, in coordination to the extent practicable with the National Health Care Workforce Commission (established in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s294q"},"text":"section 294q of this title","children":[],"tail":"), and relevant regional and State centers and agencies, shall—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5e3a898-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294n/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for the development of information describing and analyzing the health care workforce and workforce related issues;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5e3a899-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294n/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry out the activities under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s295k/a"},"text":"section 295k(a) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5e3a89a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294n/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" annually evaluate programs under this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5e3a89b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294n/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop and publish performance measures and benchmarks for programs under this subchapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5e3a89c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294n/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish, maintain, and publicize a national Internet registry of each grant awarded under this subchapter and a database to collect data from longitudinal evaluations (as described in subsection (d)(2)) on performance measures (as developed under sections 293","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":"(d)(3), 294f(d)(3), and 294"},{"tag":"i","attrib":{},"text":"o","children":[],"tail":"(a)(3) of this title)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5e3a89d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294n/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collaboration and data sharing","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5e3a89e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294n/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The National Center shall collaborate with Federal agencies and relevant professional and educational organizations or societies for the purpose of linking data regarding grants awarded under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5e3a89f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294n/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contracts for health workforce analysis","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of carrying out the activities described in subparagraph (A), the National Center may enter into contracts with relevant professional and educational organizations or societies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5e3a8a0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294n/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State and regional Centers for Health Workforce Analysis","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5e3a8a1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294n/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall award grants to, or enter into contracts with, eligible entities for purposes of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5e3a8a2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294n/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collecting, analyzing, and reporting data regarding programs under this subchapter to the National Center and to the public; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5e3a8a3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294n/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing technical assistance to local and regional entities on the collection, analysis, and reporting of data.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5e3a8a4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294n/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible for a grant or contract under this subsection, an entity shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5e3a8a5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294n/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be a State, a State workforce investment board, a public health or health professions school, an academic health center, or an appropriate public or private nonprofit entity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5e3a8a6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294n/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit to the Secretary an application at such time, in such manner, and containing such information as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5e3a8a7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294n/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Increase in grants for longitudinal evaluations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5e3a8a8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294n/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall increase the amount awarded to an eligible entity under this subchapter for a longitudinal evaluation of individuals who have received education, training, or financial assistance from programs under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5e3a8a9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294n/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Capability","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A longitudinal evaluation shall be capable of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5e3a8aa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294n/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" studying practice patterns; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5e3a8ab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294n/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collecting and reporting data on performance measures developed under sections 293","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":"(d)(3), 294f(d)(3), and 294"},{"tag":"i","attrib":{},"text":"o","children":[],"tail":"(a)(3) of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5e3a8ac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294n/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guidelines","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A longitudinal evaluation shall comply with guidelines issued under sections 293","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":"(d)(4), 294f(d)(4), and 294"},{"tag":"i","attrib":{},"text":"o","children":[],"tail":"(a)(4) of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5e3a8ad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294n/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be eligible to obtain an increase under this section, an entity shall be a recipient of a grant or contract under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5e3a8ae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294n/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5e3a8af-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294n/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5e3a8b0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294n/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Center","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To carry out subsection (b), there are authorized to be appropriated $5,663,000 for each of fiscal years 2021 through 2025.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5e3a8b1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294n/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State and regional Centers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To carry out subsection (c), there are authorized to be appropriated $4,500,000 for each of fiscal years 2010 through 2014.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5e3a8b2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294n/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants for longitudinal evaluations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To carry out subsection (d), there are authorized to be appropriated such sums as may be necessary for fiscal years 2010 through 2014.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5e3a8b3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294n/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reservation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the amounts appropriated under paragraph (1) for a fiscal year, the Secretary shall reserve not less than $600,000 for conducting health professions research and for carrying out data collection and analysis in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s295k"},"text":"section 295k of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5e3a8b4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294n/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of additional funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts otherwise appropriated for programs or activities under this subchapter may be used for activities under subsection (b) with respect to the programs or activities from which such amounts were made available.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5e3a8b5-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title VII, § 761, as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/392/tI/s104/a"},"text":"Pub. L. 105–392, title I, § 104(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[