{"tag":"section","attrib":{"id":"idbb70b602-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1783"},"text":null,"children":[{"tag":"num","attrib":{"value":"1783"},"text":"§ 1783.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriations for administrative expense","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There are hereby authorized to be appropriated for any fiscal year such sums as may be necessary to the Secretary for the Secretary’s administrative expense under this chapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbb70b603-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/642/s14"},"text":"Pub. L. 89–642, § 14","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-10-11"},"text":"Oct. 11, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/889"},"text":"80 Stat. 889","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/147/tIII/s324"},"text":"Pub. L. 101–147, title III, § 324","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-10"},"text":"Nov. 10, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/917"},"text":"103 Stat. 917","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbb70b604-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbb70b605-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbb70b606-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1