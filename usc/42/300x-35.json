18 through 2022.” for “$2,000,000,000 for fiscal year 2001, and such sums as may be necessary for each of the fiscal years 2002 and 2003”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255/s8002/k/2"},"text":"Pub. L. 114–255, § 8002(k)(2)","children":[],"tail":", substituted “sections 290aa–4(d) and” for “sections 290aa–4 and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/310/s3303/g/1"},"text":"Pub. L. 106–310, § 3303(g)(1)","children":[],"tail":", substituted “$2,000,000,000 for fiscal year 2001, and such sums as may be necessary for each of the fiscal years 2002 and 2003” for “$1,500,000,000 for fiscal year 1993, and such sums as may be necessary for fiscal year 1994”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/310/s3303/g/2"},"text":"Pub. L. 106–310, § 3303(g)(2)","children":[],"tail":", substituted “sections 290aa–4 and 300y of this title” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t42/s290aa–4"},"text":"section 290aa–4 of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/310/s3303/g/3"},"text":"Pub. L. 106–310, § 3303(g)(3)","children":[],"tail":", made technical amendment to reference in original act which appears in text as reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x–58/a"},"text":"section 300x–58(a) of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/310/s3303/g/4"},"text":"Pub. L. 106–310, § 3303(g)(4)","children":[],"tail":", added par. (3)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
