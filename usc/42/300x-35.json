{"tag":"section","attrib":{"id":"idb66e0ebd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–35"},"text":null,"children":[{"tag":"num","attrib":{"value":"300x–35"},"text":"§ 300x–35.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb66e0ebe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–35/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of carrying out this subpart, subpart III and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s290aa–4/d"},"text":"section 290aa–4(d) of this title","children":[],"tail":" with respect to substance use disorders, and "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s290bb–21/d"},"text":"section 290bb–21(d) of this title","children":[],"tail":", there are authorized to be appropriated $1,908,079,000 for each of fiscal years 2023 through 2027."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb66e0ebf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–35/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocations for technical assistance, national data base, data collection, and program evaluations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb66e0ec0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–35/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb66e0ec1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–35/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purpose of carrying out ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x–58/a"},"text":"section 300x–58(a) of this title","children":[],"tail":" with respect to substance use disorders, "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s290bb–21/d"},"text":"section 290bb–21(d) of this title","children":[],"tail":", and the purposes specified in subparagraphs (B) and (C), the Secretary shall obligate 5 percent of the amounts appropriated under subsection (a) each fiscal year."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb66e0ec2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–35/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The purpose specified in this subparagraph is carrying out sections 290aa–4(d) and 300y of this title with respect to substance use disorders.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb66e0ec3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–35/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The purpose specified in this subparagraph is the conduct of evaluations of authorized activities to determine methods for improving the availability and quality of such activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb66e0ec4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–35/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities of Center for Substance Abuse Prevention","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the amounts reserved under paragraph (1) for a fiscal year, the Secretary, acting through the Director of the Center for Substance Abuse Prevention, shall obligate 20 percent for carrying out paragraph (1)(C), ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x–58/a"},"text":"section 300x–58(a) of this title","children":[],"tail":" with respect to prevention activities, and "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s290bb–21/d"},"text":"section 290bb–21(d) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb66e0ec5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–35/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Core data set","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State that receives a new grant, contract, or cooperative agreement from amounts available to the Secretary under paragraph (1), for the purposes of improving the data collection, analysis and reporting capabilities of the State, shall be required, as a condition of receipt of funds, to collect, analyze, and report to the Secretary for each fiscal year subsequent to receiving such funds a core data set to be determined by the Secretary in conjunction with the States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb66e0ec6-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XIX, § 1935, as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/321/tII/s202"},"text":"Pub. L. 102–321, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-10"},"text":"July 10, 1992","children":[],"tail":", "},{"tag":"ref","attrib":