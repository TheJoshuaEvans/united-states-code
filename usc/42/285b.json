{"tag":"section","attrib":{"id":"idb56a0c50-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285b"},"text":null,"children":[{"tag":"num","attrib":{"value":"285b"},"text":"§ 285b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose of Institute","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The general purpose of the National Heart, Lung, and Blood Institute (hereafter in this subpart referred to as the “Institute”) is the conduct and support of research, training, health information dissemination, and other programs with respect to heart, blood vessel, lung, and blood diseases and with respect to the use of blood and blood products and the management of blood resources.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb56a0c51-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title IV, § 418, as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/158/s2"},"text":"Pub. L. 99–158, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-11-20"},"text":"Nov. 20, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/836"},"text":"99 Stat. 836","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
