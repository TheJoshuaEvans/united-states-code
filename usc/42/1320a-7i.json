{"tag":"section","attrib":{"id":"idb83c669f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7i"},"text":null,"children":[{"tag":"num","attrib":{"value":"1320a–7i"},"text":"§ 1320a–7i.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting of information relating to drug samples","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb83c66a0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7i/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than April 1 of each year (beginning with 2012), each manufacturer and authorized distributor of record of an applicable drug shall submit to the Secretary (in a form and manner specified by the Secretary) the following information with respect to the preceding year:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb83c66a1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7i/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In the case of a manufacturer or authorized distributor of record which makes distributions by mail or common carrier under subsection (d)(2) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s353"},"text":"section 353 of title 21","children":[],"tail":", the identity and quantity of drug samples requested and the identity and quantity of drug samples distributed under such subsection during that year, aggregated by—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb83c66a2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7i/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name, address, professional designation, and signature of the practitioner making the request under subparagraph (A)(i) of such subsection, or of any individual who makes or signs for the request on behalf of the practitioner; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb83c66a3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7i/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other category of information determined appropriate by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb83c66a4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7i/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In the case of a manufacturer or authorized distributor of record which makes distributions by means other than mail or common carrier under subsection (d)(3) of such ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s353"},"text":"section 353 of title 21","children":[],"tail":", the identity and quantity of drug samples requested and the identity and quantity of drug samples distributed under such subsection during that year, aggregated by—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb83c66a5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7i/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name, address, professional designation, and signature of the practitioner making the request under subparagraph (A)(i) of such subsection, or of any individual who makes or signs for the request on behalf of the practitioner; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb83c66a6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7i/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other category of information determined appropriate by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb83c66a7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7i/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb83c66a8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7i/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicable drug","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “applicable drug” means a drug—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb83c66a9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7i/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which is subject to subsection (b) of such ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s353"},"text":"section 353 of title 21","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb83c66aa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7i/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for which payment is available under subchapter XVIII or a State plan under subchapter XIX or XXI (or a waiver of such a plan).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb83c66ab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7i/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorized distributor of record","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “authorized distributor of record” has the meaning given that term in subsection (e)(3)(A) of such section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb83c66ac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7i/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Manufacturer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “manufacturer” has the meaning given that term for purposes of subsection (d) of such section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb83c66ad-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title XI, § 1128H, as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tVI/s6004"},"text":"Pub. L. 111–148, title VI, § 6004","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/697"},"text":"124 Stat. 697","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
