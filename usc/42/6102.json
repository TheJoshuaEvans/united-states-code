{"tag":"section","attrib":{"id":"idbd6a3c57-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6102"},"text":null,"children":[{"tag":"num","attrib":{"value":"6102"},"text":"§ 6102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition of discrimination","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Pursuant to regulations prescribed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6103"},"text":"section 6103 of this title","children":[],"tail":", and except as provided by section 6103(b) and "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s6103/c"},"text":"section 6103(c) of this title","children":[],"tail":", no person in the United States shall, on the basis of age, be excluded from participation in, be denied the benefits of, or be subjected to discrimination under, any program or activity receiving Federal financial assistance."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbd6a3c58-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/135/tIII/s303"},"text":"Pub. L. 94–135, title III, § 303","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-11-28"},"text":"Nov. 28, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/728"},"text":"89 Stat. 728","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
