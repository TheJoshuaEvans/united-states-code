{"tag":"section","attrib":{"id":"idb575f391-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285j–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"285j–3"},"text":"§ 285j–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research on multiple sclerosis","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Director of the Institute shall conduct and support research on multiple sclerosis, especially research on effects of genetics and hormonal changes on the progress of the disease.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb575f392-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title IV, § 460, as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/43/tXII/s1201"},"text":"Pub. L. 103–43, title XII, § 1201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-06-10"},"text":"June 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/169"},"text":"107 Stat. 169","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
