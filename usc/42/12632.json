{"tag":"section","attrib":{"id":"idbf852c8e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12632"},"text":null,"children":[{"tag":"num","attrib":{"value":"12632"},"text":"§ 12632.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf852c8f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12632/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State reports","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf852c90-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12632/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each State receiving assistance under this subchapter shall prepare and submit, to the Corporation, an annual report concerning the use of assistance provided under this subchapter and the status of the national and community service programs that receive assistance under such subchapter in such State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf852c91-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12632/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Local grantees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each State may require local grantees that receive assistance under this subchapter to supply such information to the State as is necessary to enable the State to complete the report required under paragraph (1), including a comparison of actual accomplishments with the goals established for the program, the number of participants in the program, the number of service hours generated, and the existence of any problems, delays or adverse conditions that have affected or will affect the attainment of program goals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf852c92-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12632/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report demonstrating compliance","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf852c93-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12632/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each State receiving assistance under this subchapter shall include information in the report required under paragraph (1) that demonstrates the compliance of the State with the provisions of this chapter, including ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12637"},"text":"section 12637 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf852c94-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12632/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Local grantees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each State may require local grantees to supply such information to the State as is necessary to enable the State to comply with the requirement of paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf852c95-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12632/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Reports submitted under paragraph (1) shall be made available to the public on request.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf852c96-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12632/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress by Corporation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf852c97-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12632/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 120 days after the end of each fiscal year, the Corporation shall prepare and submit, to the authorizing committees, the Committee on Appropriations of the House of Representatives, and the Committee on Appropriations of the Senate, a report concerning the programs that receive assistance under the national service laws.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf852c98-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12632/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Content","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Reports submitted under paragraph (1) shall contain a summary of the information contained in the State reports submitted under subsection (a), and shall reflect the findings and actions taken as a result of any evaluation conducted by the Corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf852c99-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/610/tI/s172"},"text":"Pub. L. 101–610, title I, § 172","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3159"},"text":"104 Stat. 3159","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/tI/s114"},"text":"Pub. L. 103–82, title I, § 114","children":[],"tail":", title IV, § 402(b)(1), "},{"tag":"date","attrib":{"date":"1993-09-21"},"text":"Sept. 21, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/861"},"text":"107 Stat. 861","children":[],"tail":", 918; "},{"tag":"ref","attrib":{"href":"/us/pl/111/13/tI/s1602"},"text":"Pub. L. 111–13, title I, § 1602","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-04-21"},"text":"Apr. 21, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1529"},"text":"123 Stat. 1529","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tX/s1063/c"},"text":"Pub. L. 112–81, div. A, title X, § 1063(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1586"},"text":"125 Stat. 1586","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf852c9a-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf852c9b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbf852c9c-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (a)(3)(A), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/610"},"text":"Pub. L. 101–610","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3127"},"text":"104 Stat. 3127","children":[],"tail":", known as the National and Community Service Act of 1990, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12501"},"text":"section 12501 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbf852c9d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2011—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81"},"text":"Pub. L. 112–81","children":[],"tail":" struck out subsec. (c). Prior to amendment, text read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) ","children":[{"tag":"inline","attrib":{},"text":"Study","children":[],"tail":".—The Secretary of Defense shall annually conduct a study of the effect of the programs carried out under this subchapter on recruitment for the Armed Forces."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) ","children":[{"tag":"inline","attrib":{},"text":"Report","children":[],"tail":".—The Secretary of Defense shall annually submit a report to the authorizing committees, the Committee on Armed Services of the House of Representatives, and the Committee on Armed Services of the Senate containing the findings of the study described in paragraph (1) and such recommendations for legislative and administrative reform as the Secretary may determine to be appropriate.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2009—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1602/1"},"text":"Pub. L. 111–13, § 1602(1)","children":[],"tail":", which directed substitution of “authorizing committees, the Committee on Appropriations of the House of Representatives, and the Committee on Appropriations of the Senate” for “appropriate authorizing and appropriations Committees of Congress”, was executed by making the substitution for “appropriate authorizing and appropriation Committees of Congress” to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1602/2"},"text":"Pub. L. 111–13, § 1602(2)","children":[],"tail":", substituted “the authorizing committees, the Committee on Armed Services of the House of Representatives, and the Committee on Armed Services of the Senate” for “the appropriate committees of Congress”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/82/s402/b/1"},"text":"Pub. L. 103–82, § 402(b)(1)","children":[],"tail":", substituted “Corporation” for “Commission”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/82/s114/1"},"text":"Pub. L. 103–82, § 114(1)","children":[],"tail":", substituted “section 12637” for “sections 12637 and 12523(9)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/82/s114/2/A"},"text":"Pub. L. 103–82, § 114(2)(A)","children":[],"tail":", substituted “Report to Congress by Corporation” for “Report to Congress” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/82/s402/b/1"},"text":"Pub. L. 103–82, § 402(b)(1)","children":[],"tail":", substituted “Corporation” for “Commission”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/82/s114/2/B"},"text":"Pub. L. 103–82, § 114(2)(B)","children":[],"tail":", substituted “the national service laws” for “this subchapter”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/82/s402/b/1"},"text":"Pub. L. 103–82, § 402(b)(1)","children":[],"tail":", substituted “Corporation” for “Commission”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/82/s114/3"},"text":"Pub. L. 103–82, § 114(3)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbf852c9e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbf852c9f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2009 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13"},"text":"Pub. L. 111–13","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2009-10-01"},"text":"Oct. 1, 2009","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/111/13/s6101/a"},"text":"section 6101(a) of Pub. L. 111–13","children":[],"tail"