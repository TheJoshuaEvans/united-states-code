{"tag":"section","attrib":{"id":"idbfe946a0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15921"},"text":null,"children":[{"tag":"num","attrib":{"value":"15921"},"text":"§ 15921.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management of Federal oil and gas leasing programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfe946a1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15921/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timely action on leases and permits","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfe946a2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15921/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary of the Interior","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To ensure timely action on oil and gas leases and applications for permits to drill on land otherwise available for leasing, the Secretary of the Interior (referred to in this section as the “Secretary”) shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfe946a3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15921/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure expeditious compliance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4332/2/C"},"text":"section 4332(2)(C) of this title","children":[],"tail":" and any other applicable environmental and cultural resources laws;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfe946a4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15921/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve consultation and coordination with the States and the public; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfe946a5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15921/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve the collection, storage, and retrieval of information relating to the oil and gas leasing activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe946a6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15921/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary of Agriculture","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To ensure timely action on oil and gas lease applications for permits to drill on land otherwise available for leasing, the Secretary of Agriculture shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfe946a7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15921/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure expeditious compliance with all applicable environmental and cultural resources laws; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfe946a8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15921/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve the collection, storage, and retrieval of information relating to the oil and gas leasing activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfe946a9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15921/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Best management practices","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfe946aa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15921/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 18 months after ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":", the Secretary shall develop and implement best management practices to—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfe946ab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15921/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve the administration of the onshore oil and gas leasing program under the Mineral Leasing Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t30/s181"},"text":"30 U.S.C. 181","children":[],"tail":" et seq.); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfe946ac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15921/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure timely action on oil and gas leases and applications for permits to drill on land otherwise available for leasing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe946ad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15921/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Considerations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In developing the best management practices under paragraph (1), the Secretary shall consider any recommendations from the review under section 361.","children":[{"tag":"ref","attrib":{"idref":"fn004197"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004197"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe946ae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15921/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after the development of the best management practices under paragraph (1), the Secretary shall publish, for public comment, proposed regulations that set forth specific timeframes for processing leases and applications in accordance with the best management practices, including deadlines for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfe946af-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15921/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" approving or disapproving—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbfe946b0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15921/b/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" resource management plans and related documents;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbfe946b1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15921/b/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" lease applications;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbfe946b2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15921/b/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" applications for permits to drill; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbfe946b3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15921/b/3/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" surface use plans; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfe946b4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15921/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" related administrative appeals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfe946b5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15921/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Improved enforcement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary and the Secretary of Agriculture shall improve inspection and enforcement of oil and gas activities, including enforcement of terms and conditions in permits to drill on land under the jurisdiction of the Secretary and the Secretary of Agriculture, respectively.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfe946b6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15921/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In addition to amounts made available to carry out activities relating to oil and gas leasing on public land administered by the Secretary and National Forest System land administered by the Secretary of Agriculture, there are authorized to be appropriated for each of fiscal years 2006 through 2010—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfe946b7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15921/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to the Secretary, acting through the Director of the Bureau of Land Management—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfe946b8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15921/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $40,000,000 to carry out subsections (a)(1) and (b); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfe946b9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15921/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $20,000,000 to carry out subsection (c);","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe946ba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15921/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the Secretary, acting through the Director of the United States Fish and Wildlife Service, $5,000,000 to carry out subsection (a)(1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe946bb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15921/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the Secretary of Agriculture, acting through the Chief of the Forest Service, $5,000,000 to carry out subsections (a)(2) and (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfe946bc-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tIII/s362"},"text":"Pub. L. 109–58, title III, § 362","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/721"},"text":"119 Stat. 721","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbfe946bd-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbfe946be-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbfe946bf-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Mineral Leasing Act, referred to in subsec. (b)(1)(A), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1920-02-25/ch85"},"text":"act Feb. 25, 1920, ch. 85","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/41/437"},"text":"41 Stat. 437","children":[],"tail":", which is classified generally to chapter 3A (§ 181 et seq.) of Title 30, Mineral Lands and Mining. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t30/s181"},"text":"section 181 of Title 30","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 361, referred to in subsec. (b)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/s361"},"text":"section 361 of Pub. L. 109–58","children":[],"tail":", title III, "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/720"},"text":"119 Stat. 720","children":[],"tail":", which is not classified to the Code."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
