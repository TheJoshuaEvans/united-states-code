{"tag":"section","attrib":{"id":"idb4ebb466-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254c–11"},"text":null,"children":[{"tag":"num","attrib":{"value":"254c–11"},"text":"§ 254c–11.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary may provide technical assistance to assist entities in complying with the requirements of sections 254c–9 to 254c–13 of this title in order to make such entities eligible to receive grants under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s254c–9"},"text":"section 254c–9 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb4ebb467-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/505/tV/s523"},"text":"Pub. L. 106–505, title V, § 523","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-13"},"text":"Nov. 13, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2344"},"text":"114 Stat. 2344","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb4ebb468-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb4ebb469-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb4ebb46a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Lupus Research and Care Amendments of 2000, and also as part of the Public Health Improvement Act, and not as part of the Public Health Service Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
