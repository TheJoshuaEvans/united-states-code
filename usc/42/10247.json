{"tag":"section","attrib":{"id":"idbf1c3184-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10247"},"text":null,"children":[{"tag":"num","attrib":{"value":"10247"},"text":"§ 10247.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Environmental impact statement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf1c3185-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10247/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Issuance of a construction authorization for a repository or monitored retrievable storage facility under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s10245/b"},"text":"section 10245(b) of this title","children":[],"tail":" shall be considered a major Federal action significantly affecting the quality of the human environment for purposes of the National Environmental Policy Act of 1969 ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"42 U.S.C. 4321","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf1c3186-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10247/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preparation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A final environmental impact statement shall be prepared by the Secretary under such Act and shall accompany any application to the Nuclear Regulatory Commission for a construction authorization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf1c3187-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10247/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adoption","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf1c3188-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10247/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any such environmental impact statement shall, to the extent practicable, be adopted by the Nuclear Regulatory Commission, in accordance with section 1506.3 of title 40, Code of Federal Regulations, in connection with the issuance by the Nuclear Regulatory Commission of a construction authorization and license for such repository or monitored retrievable storage facility.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf1c3189-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10247/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf1c318a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10247/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In any such statement prepared with respect to a repository to be constructed under this subchapter at the Yucca Mountain site, the Nuclear Regulatory Commission need not consider the need for a repository, the time of initial availability of a repository, alternate sites to the Yucca Mountain site, or nongeologic alternatives to such site.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf1c318b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10247/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In any such statement prepared with respect to a repository to be constructed under this subchapter at a site other than the Yucca Mountain site, the Nuclear Regulatory Commission need not consider the need for a repository, the time of initial availability of a repository, or nongeologic alternatives to such site but shall consider the Yucca Mountain site as an alternate to such site in the preparation of such statement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf1c318c-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/425/tIV/s407"},"text":"Pub. L. 97–425, title IV, § 407","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/202/s101/d/tIII"},"text":"Pub. L. 100–202, § 101(d) [title III]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1329-104"},"text":"101 Stat. 1329–104","children":[],"tail":", 1329–121; "},{"tag":"ref","attrib":{"href":"/us/pl/100/203/tV/s5041"},"text":"Pub. L. 100–203, title V, § 5041","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1330-246"},"text":"101 Stat. 1330–246","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf1c318d-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf1c318e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbf1c318f-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The National Environmental Policy Act of 1969, referred to in subsecs. (a) and (b), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/190"},"text":"Pub. L. 91–190","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-01-01"},"text":"Jan. 1, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/852"},"text":"83 Stat. 852","children":[],"tail":", which is classified generally to chapter 55 (§ 4321 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"section 4321 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbf1c3190-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/202"},"text":"Pub. L. 100–202","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/100/203"},"text":"Pub. L. 100–203","children":[],"tail":" added identical sections."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
