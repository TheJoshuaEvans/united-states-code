{"tag":"section","attrib":{"id":"idbfab52ca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12905"},"text":null,"children":[{"tag":"num","attrib":{"value":"12905"},"text":"§ 12905.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibilities of grantees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfab52cb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12905/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition of substitution of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts received from grants under this chapter may not be used to replace other amounts made available or designated by State or local governments for use for the purposes under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfab52cc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12905/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Capability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The recipient shall have, in the determination of the grantee or the Secretary, the capacity and capability to effectively administer a grant under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfab52cd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12905/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The recipient shall agree to cooperate and coordinate in providing assistance under this chapter with the agencies of the relevant State and local governments responsible for services in the area served by the applicant for eligible persons and other public and private organizations and agencies providing services for such eligible persons.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfab52ce-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12905/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition of fees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The recipient shall agree that no fee will be charged to any eligible person for any housing or services provided with amounts from a grant under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfab52cf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12905/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Confidentiality","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The recipient shall agree to ensure the confidentiality of the name of any individual assisted with amounts from a grant under this chapter and any other information regarding individuals receiving such assistance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfab52d0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12905/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial records","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The recipient shall agree to maintain and provide the grantee or the Secretary with financial records sufficient, in the determination of the Secretary, to ensure proper accounting and disbursing of amounts received from a grant under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfab52d1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12905/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative expenses","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfab52d2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12905/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grantees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of this chapter, each grantee may use not more than 3 percent of the grant amount for administrative costs relating to administering grant amounts and allocating such amounts to project sponsors.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfab52d3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12905/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Project sponsors","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of this chapter, each project sponsor receiving amounts from grants made under this chapter ","children":[{"tag":"ref","attrib":{"idref":"fn004140"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004140"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" may use not more than 7 percent of the amounts received for administrative costs relating to carrying out eligible activities under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12904"},"text":"section 12904 of this title","children":[],"tail":", including the costs of staff necessary to carry out eligible activities."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfab52d4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12905/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Environmental review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of environmental review, a grant under this chapter shall be treated as assistance for a special project that is subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3547"},"text":"section 3547 of this title","children":[],"tail":", and shall be subject to the regulations issued by the Secretary to implement such section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfab52d5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12905/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Carbon monoxide alarms","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each dwelling unit assisted under this chapter shall contain installed carbon monoxide alarms or detectors that meet or exceed—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfab52d6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12905/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the standards described in chapters 9 and 11 of the 2018 publication of the International Fire Code, as published by the International Code Council; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfab52d7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12905/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other standards as may be adopted by the Secretary, including any relevant updates to the International Fire Code, through a notice published in the Federal Register.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfab52d8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12905/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifying smoke alarms","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfab52d9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12905/j/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each dwelling unit assisted under this chapter shall contain qualifying smoke alarms that are installed in accordance with applicable codes and standards published by the International Code Council or the National Fire Protection Association and the requirements of the National Fire Protection Association Standard 72, or any successor standard, in each level and in or near each sleeping area in such dwelling unit, including in basements but excepting crawl spaces and unfinished attics, and in each common area in a project containing such a dwelling unit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfab52da-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12905/j/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection, the following definitions shall apply:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfab52db-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12905/j/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Smoke alarm defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “smoke alarm” has the meaning given the term “smoke detector” in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2225/d"},"text":"section 2225(d) of title 15","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfab52dc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12905/j/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifying smoke alarm defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “qualifying smoke alarm” means a smoke alarm that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbfab52dd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12905/j/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of a dwelling unit built before ","children":[{"tag":"date","attrib":{"date":"2022-12-29"},"text":"December 29, 2022","children":[],"tail":", and not substantially rehabilitated after "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"December 29, 2022","children":[],"tail":"—"}],"tail":null},{"tag":"subclause","attrib":{"id":"idbfab52de-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12905/j/2/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"item","attrib":{"id":"idbfab52df-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12905/j/2/B/i/I/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is hardwired; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idbfab52e0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12905/j/2/B/i/I/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" uses 10-year non rechargeable, nonreplaceable primary batteries and—","children":[],"tail":null},{"tag":"subitem","attrib":{"id":"idbfab52e1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12905/j/2/B/i/I/bb/AA"},"text":null,"children":[{"tag":"num","attrib":{"value":"AA"},"text":"(AA)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is sealed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subitem","attrib":{"id":"idbfab52e2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12905/j/2/B/i/I/bb/BB"},"text":null,"children":[{"tag":"num","attrib":{"value":"BB"},"text":"(BB)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is tamper resistant; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subitem","attrib":{"id":"idbfab52e3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12905/j/2/B/i/I/bb/CC"},"text":null,"children":[{"tag":"num","attrib":{"value":"CC"},"text":"(CC)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contains silencing means; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbfab52e4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12905/j/2/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides notification for persons with hearing loss as required by the National Fire Protection Association Standard 72, or any successor standard; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbfab52e5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12905/j/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a dwelling unit built or substantially rehabilitated after ","children":[{"tag":"date","attrib":{"date":"2022-12-29"},"text":"December 29, 2022","children":[],"tail":", is hardwired."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfab52e6-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/625/tVIII/s856"},"text":"Pub. L. 101–625, title VIII, § 856","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4378"},"text":"104 Stat. 4378","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/550/tVI/s606/f"},"text":"Pub. L. 102–550, title VI, § 606(f)","children":[],"tail":", (j)(4), (11)(A), "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3809-3811"},"text":"106 Stat. 3809–3811","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/377/s1/a/1/tII/s203/c"},"text":"Pub. L. 106–377, § 1(a)(1) [title II, § 203(c)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-27"},"text":"Oct. 27, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1441"},"text":"114 Stat. 1441","children":[],"tail":", 1441A–24; "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dQ/tI/s101/e"},"text":"Pub. L. 116–260, div. Q, title I, § 101(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2164"},"text":"134 Stat. 2164","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dAA/tVI/s601/d"},"text":"Pub. L. 117–328, div. AA, title VI, § 601(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5545"},"text":"136 Stat. 5545","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbfab52e7-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbfab52e8-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbfab52e9-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Under this chapter, referred to in subsec. (g)(2), was in the original “under this title”, and was translated as reading “under this subtitle”, meaning under subtitle D (§§ 851–863) of title VIII of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/625"},"text":"Pub. L. 101–625","children":[],"tail":", to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbfab52ea-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (j). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328"},"text":"Pub. L. 117–328","children":[],"tail":" added subsec. (j)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2020—Subsec. (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Pub. L. 116–260","children":[],"tail":" added subsec. (i)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/377"},"text":"Pub. L. 106–377","children":[],"tail":" added subsec. (h)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550/s606/j/4"},"text":"Pub. L. 102–550, § 606(j)(4)","children":[],"tail":", (11)(A), substituted “eligible persons” for “individuals with acquired immunodeficiency syndrome or related diseases” and “services for such eligible persons” for “services for such individuals”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550/s606/f/1"},"text":"Pub. L. 102–550, § 606(f)(1)","children":[],"tail":", added subsec. (d) and struck out former subsec. (d) which read as follows: “"},{"tag":"inline","attrib":{},"text":"No Fee","children":[],"tail":".—The recipient shall agree that no fee will be charged of any low-income individual for any services provided with amounts from a grant under this chapter and that if fees are charged of any other individuals, the fees will be based on the income and resources of the individual.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550/s606/f/2"},"text":"Pub. L. 102–550, § 606(f)(2)","children":[],"tail":", added subsec. (g)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbfab52eb-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbfab52ec-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2022 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328"},"text":"Pub. L. 117–328","children":[],"tail":" effective 2 years after "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dAA/s601/h"},"text":"section 601(h) of div. AA of Pub. L. 117–328","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1701q"},"text":"section 1701q of Title 12","children":[],"tail":", Banks and Banking."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbfab52ed-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2020 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Pub. L. 116–260","children":[],"tail":" effective 2 years after "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dQ/s101/h"},"text":"section 101(h) of div. Q of Pub. L. 116–260","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1701q"},"text":"section 1701q of Title 12","children":[],"tail":", Banks and Banking."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbfab52ee-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Construction of 2022 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Nothing in amendment made by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328"},"text":"Pub. L. 117–328","children":[],"tail":" to be construed to preempt or limit applicability of certain State or local laws relating to smoke alarms, see "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dAA/s601/i"},"text":"section 601(i) of div. AA of Pub. L. 117–328","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1701q"},"text":"section 1701q of Title 12","children":[],"tail":", Banks and Banking."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbfab52ef-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Construction of 2020 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Nothing in amendment made by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Pub. L. 116–260","children":[],"tail":" to be construed to preempt or limit applicability of certain State or local laws relating to carbon monoxide devices, see "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dQ/s101/j"},"text":"section 101(j) of div. Q of Pub. L. 116–260","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1437a"},"text":"section 1437a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
