{"tag":"section","attrib":{"id":"idc048a39f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18024"},"text":null,"children":[{"tag":"num","attrib":{"value":"18024"},"text":"§ 18024.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Related definitions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc048a3a0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18024/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions relating to markets","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this title: ","children":[{"tag":"ref","attrib":{"idref":"fn004309"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004309"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc048a3a1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18024/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Group market","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “group market” means the health insurance market under which individuals obtain health insurance coverage (directly or through any arrangement) on behalf of themselves (and their dependents) through a group health plan maintained by an employer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc048a3a2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18024/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Individual market","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “individual market” means the market for health insurance coverage offered to individuals other than in connection with a group health plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc048a3a3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18024/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Large and small group markets","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “large group market” and “small group market” mean the health insurance market under which individuals obtain health insurance coverage (directly or through any arrangement) on behalf of themselves (and their dependents) through a group health plan maintained by a large employer (as defined in subsection (b)(1)) or by a small employer (as defined in subsection (b)(2)), respectively.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc048a3a4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18024/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employers","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this title: ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc048a3a5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18024/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Large employer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “large employer” means, in connection with a group health plan with respect to a calendar year and a plan year, an employer who employed an average of at least 51 employees on business days during the preceding calendar year and who employs at least 1 employee on the first day of the plan year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc048a3a6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18024/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Small employer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “small employer” means, in connection with a group health plan with respect to a calendar year and a plan year, an employer who employed an average of at least 1 but not more than 50 employees on business days during the preceding calendar year and who employs at least 1 employee on the first day of the plan year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc048a3a7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18024/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State option to extend definition of small employer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding paragraphs (1) and (2), nothing in this section shall prevent a State from applying this subsection by treating as a small employer, with respect to a calendar year and a plan year, an employer who employed an average of at least 1 but not more than 100 employees on business days during the preceding calendar year and who employs at least 1 employee on the first day of the plan year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc048a3a8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18024/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules for determining employer size","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc048a3a9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18024/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of aggregation rule for employers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All persons treated as a single employer under subsection (b), (c), (m), or (","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":") of "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s414"},"text":"section 414 of title 26","children":[],"tail":" shall be treated as 1 employer."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc048a3aa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18024/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employers not in existence in preceding year","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of an employer which was not in existence throughout the preceding calendar year, the determination of whether such employer is a small or large employer shall be based on the average number of employees that it is reasonably expected such employer will employ on business days in the current calendar year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc048a3ab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18024/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Predecessors","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any reference in this subsection to an employer shall include a reference to any predecessor of such employer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc048a3ac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18024/b/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continuation of participation for growing small employers","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc048a3ad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18024/b/4/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a qualified employer that is a small employer makes enrollment in qualified health plans offered in the small group market available to its employees through an Exchange; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc048a3ae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18024/b/4/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the employer ceases to be a small employer by reason of an increase in the number of employees of such employer;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the employer shall continue to be treated as a small employer for purposes of this subchapter for the period beginning with the increase and ending with the first day on which the employer does not make such enrollment available to its employees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc048a3af-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18024/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this title,","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" the term “Secretary” means the Secretary of Health and Human Services."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc048a3b0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18024/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this title,","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" the term “State” means each of the 50 States and the District of Columbia."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc048a3b1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18024/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Educated health care consumers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “educated health care consumer” means an individual who is knowledgeable about the health care system, and has background or experience in making informed decisions regarding health, medical, and scientific matters.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc048a3b2-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/tI/s1304"},"text":"Pub. L. 111–148, title I, § 1304","children":[],"tail":", title X, § 10104(d), "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/171"},"text":"124 Stat. 171","children":[],"tail":", 900; "},{"tag":"ref","attrib":{"href":"/us/pl/114/60/s2/a"},"text":"Pub. L. 114–60, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-10-07"},"text":"Oct. 7, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/543"},"text":"129 Stat. 543","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc048a3b3-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc048a3b4-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc048a3b5-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This title, referred to in subsecs. (a) to (d), is title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148"},"text":"Pub. L. 111–148","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/130"},"text":"124 Stat. 130","children":[],"tail":", which enacted this chapter and enacted, amended, and transferred numerous other sections and notes in the Code. For complete classification of title I to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc048a3b6-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/60/s2/a/1"},"text":"Pub. L. 114–60, § 2(a)(1)","children":[],"tail":", substituted “51” for “101”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/60/s2/a/2"},"text":"Pub. L. 114–60, § 2(a)(2)","children":[],"tail":", substituted “50” for “100”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/60/s2/a/3"},"text":"Pub. L. 114–60, § 2(a)(3)","children":[],"tail":", amended par. (3) generally. Prior to amendment, text read as follows: “In the case of plan years beginning before "},{"tag":"date","attrib":{"date":"2016-01-01"},"text":"January 1, 2016","children":[],"tail":", a State may elect to apply this subsection by substituting ‘51 employees’ for ‘101 employees’ in paragraph (1) and by substituting ‘50 employees’ for ‘100 employees’ in paragraph (2).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/s10104/d"},"text":"Pub. L. 111–148, § 10104(d)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
