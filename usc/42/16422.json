{"tag":"section","attrib":{"id":"idc0144e2e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16422"},"text":null,"children":[{"tag":"num","attrib":{"value":"16422"},"text":"§ 16422.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advanced transmission technologies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc0144e2f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16422/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of advanced transmission technology","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “advanced transmission technology” means a technology that increases the capacity, efficiency, or reliability of an existing or new transmission facility, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0144e30-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16422/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" high-temperature lines (including superconducting cables);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0144e31-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16422/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" underground cables;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0144e32-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16422/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advanced conductor technology (including advanced composite conductors, high-temperature low-sag conductors, and fiber optic temperature sensing conductors);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0144e33-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16422/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" high-capacity ceramic electric wire, connectors, and insulators;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0144e34-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16422/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" optimized transmission line configurations (including multiple phased transmission lines);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0144e35-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16422/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" modular equipment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0144e36-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16422/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" wireless power transmission;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0144e37-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16422/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ultra-high voltage lines;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0144e38-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16422/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" high-voltage DC technology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0144e39-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16422/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" flexible AC transmission systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0144e3a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16422/a/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" energy storage devices (including pumped hydro, compressed air, superconducting magnetic energy storage, flywheels, and batteries);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0144e3b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16422/a/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" controllable load;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0144e3c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16422/a/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" distributed generation (including PV, fuel cells, and microturbines);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0144e3d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16422/a/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhanced power device monitoring;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0144e3e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16422/a/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" direct system state sensors;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0144e3f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16422/a/16"},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"(16)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fiber optic technologies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0144e40-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16422/a/17"},"text":null,"children":[{"tag":"num","attrib":{"value":"17"},"text":"(17)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" power electronics and related software (including real time monitoring and analytical software);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0144e41-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16422/a/18"},"text":null,"children":[{"tag":"num","attrib":{"value":"18"},"text":"(18)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" mobile transformers and mobile substations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0144e42-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16422/a/19"},"text":null,"children":[{"tag":"num","attrib":{"value":"19"},"text":"(19)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other technologies the Commission considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0144e43-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16422/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out the Federal Power Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s791a"},"text":"16 U.S.C. 791a","children":[],"tail":" et seq.) and the Public Utility Regulatory Policies Act of 1978 ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s2601"},"text":"16 U.S.C. 2601","children":[],"tail":" et seq.), the Commission shall encourage, as appropriate, the deployment of advanced transmission technologies."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc0144e44-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tXII/s1223"},"text":"Pub. L. 109–58, title XII, § 1223","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/953"},"text":"119 Stat. 953","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc0144e45-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc0144e46-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc0144e47-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Power Act, referred to in subsec. (b), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1920-06-10/ch285"},"text":"act June 10, 1920, ch. 285","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/41/1063"},"text":"41 Stat. 1063","children":[],"tail":", which is classified generally to chapter 12 (§ 791a et seq.) of Title 16, Conservation. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s791a"},"text":"section 791a of Title 16","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Public Utility Regulatory Policies Act of 1978, referred to in subsec. (b), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/617"},"text":"Pub. L. 95–617","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-09"},"text":"Nov. 9, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3117"},"text":"92 Stat. 3117","children":[],"tail":". For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s2601"},"text":"section 2601 of Title 16","children":[],"tail":", Conservation, and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
