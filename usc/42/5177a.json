{"tag":"section","attrib":{"id":"idbd1b7ff9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5177a"},"text":null,"children":[{"tag":"num","attrib":{"value":"5177a"},"text":"§ 5177a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emergency grants to assist low-income migrant and seasonal farmworkers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd1b7ffa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5177a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Agriculture may make grants to public agencies or private organizations with tax exempt status under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s501/c/3"},"text":"section 501(c)(3) of title 26","children":[],"tail":", that have experience in providing emergency services to low-income migrant and seasonal farmworkers where the Secretary determines that a local, State or national emergency or disaster has caused low-income migrant or seasonal farmworkers to lose income, to be unable to work, or to stay home or return home in anticipation of work shortages. Emergency services to be provided with assistance received under this section may include such types of assistance as the Secretary of Agriculture determines to be necessary and appropriate."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd1b7ffb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5177a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Low-income migrant or seasonal farmworker” defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purposes of this section, the term “low-income migrant or seasonal farmworker” means an individual—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd1b7ffc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5177a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who has, during any consecutive 12 month period within the preceding 24 month period, performed farm work for wages;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd1b7ffd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5177a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who has received not less than one-half of such individual’s total income, or been employed at least one-half of total work time in farm work; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd1b7ffe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5177a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whose annual family income within the 12 month period referred to in paragraph (1) does not exceed the higher of the poverty level or 70 percent of the lower living standard income level.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd1b7fff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5177a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums as may be necessary to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd1b8000-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXXII/s2281"},"text":"Pub. L. 101–624, title XXII, § 2281","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3978"},"text":"104 Stat. 3978","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/tX/s10102"},"text":"Pub. L. 107–171, title X, § 10102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/488"},"text":"116 Stat. 488","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd1b8001-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd1b8002-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbd1b8003-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Food, Agriculture, Conservation, and Trade Act of 1990, and not as part of the Robert T. Stafford Disaster Relief and Emergency Assistance Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd1b8004-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171"},"text":"Pub. L. 107–171","children":[],"tail":" struck out “, not to exceed $20,000,000 annually,” after “Secretary of Agriculture may make grants”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
