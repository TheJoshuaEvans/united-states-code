{"tag":"ref","attrib":{"href":"/us/pl/102/486/tIX/s902/a/8"},"text":"Pub. L. 102–486, title IX, § 902(a)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2944"},"text":"106 Stat. 2944","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/486/tIX/s902/a/8"},"text":"“This Act [enacting this chapter, amending sections 190j and 622 of Title 2, The Congress, and repealing sections 2251 to 2257 and 2315 of this title] may be cited as the ‘Atomic Energy Act of 1954’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"savings","id":"idbbd4cf2b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Savings Clause","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/67/dB/tVI/s603"},"text":"Pub. L. 118–67, div. B, title VI, § 603","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-07-09"},"text":"July 9, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1482"},"text":"138 Stat. 1482","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/67/dB/tVI/s603"},"text":"“Nothing in this Act [probably means “this division”, see Short Title of 2024 Amendment note above] affects authorities of the Department of State.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"separability","id":"idbbd4cf2c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Separability","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1946-08-01/ch724/tI/s281"},"text":"Act Aug. 1, 1946, ch. 724, title I, § 281","children":[],"tail":", as added by act "},{"tag":"date","attrib":{"date":"1954-08-3