 as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2297h–10a"},"text":"section 2297h–10a of this title","children":[],"tail":"] may be cited as the ‘Prohibiting Russian Uranium Imports Act’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idbbd4cf20-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2022 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/139/s1"},"text":"Pub. L. 117–139, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-06-07"},"text":"June 7, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1258"},"text":"136 Stat. 1258","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/139/s1"},"text":"“This Act [amending provisions set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2210"},"text":"section 2210 of this title","children":[],"tail":"] may be cited as the ‘RECA Extension Act of 2022’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idbbd4cf21-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2019 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/439/s1/a"},"text":"Pub. L. 115–439, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-01-14"},"text":"Jan. 14, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5565"},"text":"132 Stat. 5565","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/439/s1/a"},"text":"“This Act [enacting ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2215"},"text":"section 2215 of this title","children":[],"tail":", amend