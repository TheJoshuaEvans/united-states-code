{"tag":"section","attrib":{"id":"idbbd4cf17-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2011"},"text":null,"children":[{"tag":"num","attrib":{"value":"2011"},"text":"§ 2011.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional declaration of policy","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Atomic energy is capable of application for peaceful as well as military purposes. It is therefore declared to be the policy of the United States that—","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbbd4cf18-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2011/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development, use, and control of atomic energy shall be directed so as to make the maximum contribution to the general welfare, subject at all times to the paramount objective of making the maximum contribution to the common defense and security; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbbd4cf19-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2011/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development, use, and control of atomic energy shall be directed so as to promote world peace, improve the general welfare, increase the standard of living, and strengthen free competition in private enterprise.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbbd4cf1a-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-08-01/ch724"},"text":"Aug. 1, 1946, ch. 724","children":[],"tail":", title I, § 1, as added "},{"tag":"ref","attrib":{"href":"/us/act/1954-08-30/ch1073/s1"},"text":"Aug. 30, 1954, ch. 1073, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/921"},"text":"68 Stat. 921","children":[],"tail":"; renumbered title I, "},{"tag":"ref","attrib":{"href":"/us/pl/102/486/tIX/s902/a/8"},"text":"Pub. L. 102–486, title IX, § 902(a)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2944"},"text":"106 Stat. 2944","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbbd4cf1b-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbbd4cf1c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbbd4cf1d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1 of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-08-01/ch724"},"text":"act Aug. 1, 1946, ch. 724","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/60/755"},"text":"60 Stat. 755","children":[],"tail":", which related to declaration of policy and purpose of former chapter 14 of this title, was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1801"},"text":"section 1801 of this title","children":[],"tail":", prior to the general amendment and renumbering of act "},{"tag":"date","attrib":{"date":"1946-08-01"},"text":"Aug. 1, 1946","children":[],"tail":", by act "},{"tag":"date","attrib":{"date":"1954-08-30"},"text":"Aug. 30, 1954","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbbd4cf1e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"c