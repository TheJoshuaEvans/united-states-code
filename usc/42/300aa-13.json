":{"role":"crossHeading","topic":"editorialNotes","id":"idb6778477-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb6778478-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 300aa–13, act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", § 2114, was successively renumbered by subsequent acts and transferred, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s238k"},"text":"section 238k of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior section 2113 of act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", was successively renumbered by subsequent acts and transferred, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s238j"},"text":"section 238j of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb6778479-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/572"},"text":"Pub. L. 102–572","children":[],"tail":" substituted “United States Court of Federal Claims” for “United States Claims Court”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/502"},"text":"Pub. L. 101–502","children":[],"tail":" inserted “the” after “special masters of”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsecs. (a)(1), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239/s6601/j/1"},"text":"Pub. L. 101–239, § 6601(j)(1)","children":[],"tail":", substituted “special master or court” for “court” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239/s6601/j/2"},"text":"Pub. L. 101–239, § 6601(j)(2)","children":[],"tail":", inserted “special masters of” after “established by the”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/203"},"text":"Pub. L. 100–203","children":[],"tail":" substituted “the United States Claims Court” for “a district court of the United States”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb677847a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb677847b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1992 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/572"},"text":"Pub. L. 102–572","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/102/572/s911"},"text":"section 911 of Pub. L. 102–572","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s171"},"text":"section 171 of Title 28","children":[],"tail":", Judiciary and Judicial Procedure."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb677847c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1990 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/502"},"text":"Pub. L. 101–502","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1990-09-30"},"text":"Sept. 30, 1990","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/101/502/s5/h"},"text":"section 5(h) of Pub. L. 101–502","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300aa–11"},"text":"section 300aa–11 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb677847d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1989 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For applicability of amendments by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239"},"text":"Pub. L. 101–239","children":[],"tail":" to petitions filed after "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", petitions currently pending in which the evidentiary record is closed, and petitions currently pending in which the evidentiary record is not closed, with provision for an immediate suspension for 30 days of all pending cases, see "},{"tag":"ref","attrib":{"href":"/us/pl/101/239/s6601/s/1"},"text":"section 6601(s)(1) of Pub. L. 101–239","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300aa–10"},"text":"section 300aa–10 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
