{"tag":"section","attrib":{"id":"idb8059ec7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1002"},"text":null,"children":[{"tag":"num","attrib":{"value":"1002"},"text":"§ 1002.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified individuals","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Except as otherwise provided in this subchapter, an individual—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8059ec8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1002/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who has attained the age of 65 on or before ","children":[{"tag":"date","attrib":{"date":"1999-12-14"},"text":"December 14, 1999","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8059ec9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1002/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who is a World War II veteran;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8059eca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1002/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" who is eligible for a supplemental security income benefit under subchapter XVI for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8059ecb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1002/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the month in which this subchapter is enacted; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8059ecc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1002/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the month in which the individual files an application for benefits under this subchapter;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8059ecd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1002/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whose total benefit income is less than 75 percent of the Federal benefit rate under subchapter XVI;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8059ece-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1002/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who has filed an application for benefits under this subchapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8059ecf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1002/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who is in compliance with all requirements imposed by the Commissioner of Social Security under this subchapter,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be a qualified individual for purposes of this subchapter.","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8059ed0-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title VIII, § 802, as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/169/tII/s251/a"},"text":"Pub. L. 106–169, title II, § 251(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-12-14"},"text":"Dec. 14, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1844"},"text":"113 Stat. 1844","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8059ed1-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8059ed2-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb8059ed3-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For prior provisions, see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1001"},"text":"section 1001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
