{"tag":"section","attrib":{"id":"idbf091ea6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9913"},"text":null,"children":[{"tag":"num","attrib":{"value":"9913"},"text":"§ 9913.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training, technical assistance, and other activities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf091ea7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9913/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf091ea8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9913/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall use amounts reserved in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s9903/b/2"},"text":"section 9903(b)(2) of this title","children":[],"tail":"—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf091ea9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9913/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for training, technical assistance, planning, evaluation, and performance measurement, to assist States in carrying out corrective action activities and monitoring (to correct programmatic deficiencies of eligible entities), and for reporting and data collection activities, related to programs carried out under this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf091eaa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9913/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to distribute amounts in accordance with subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf091eab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9913/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants, contracts, and cooperative agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The activities described in paragraph (1)(A) may be carried out by the Secretary through grants, contracts, or cooperative agreements with appropriate entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf091eac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9913/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms and technical assistance process","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The process for determining the training and technical assistance to be carried out under this section shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf091ead-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9913/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that the needs of eligible entities and programs relating to improving program quality (including quality of financial management practices) are addressed to the maximum extent feasible; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf091eae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9913/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" incorporate mechanisms to ensure responsiveness to local needs, including an ongoing procedure for obtaining input from the national and State networks of eligible entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf091eaf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9913/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distribution requirement","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf091eb0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9913/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amounts reserved under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s9903/b/2/A"},"text":"section 9903(b)(2)(A) of this title","children":[],"tail":" for activities to be carried out under this subsection shall be distributed directly to eligible entities, organizations, or associations described in paragraph (2) for the purpose of improving program quality (including quality of financial management practices), management information and reporting systems, and measurement of program results, and for the purpose of ensuring responsiveness to identified local needs."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf091eb1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9913/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entities, organizations, or associations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Eligible entities, organizations, or associations described in this paragraph shall be eligible entities, or statewide or local organizations or associations, with demonstrated expertise in providing training to individuals and organizations on methods of effectively addressing the needs of low-income families and communities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf091eb2-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35/tVI/s678A"},"text":"Pub. L. 97–35, title VI, § 678A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/285/tII/s201"},"text":"Pub. L. 105–285, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-27"},"text":"Oct. 27, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2742"},"text":"112 Stat. 2742","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
