{"tag":"section","attrib":{"id":"idc0596d46-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18632"},"text":null,"children":[{"tag":"num","attrib":{"value":"18632"},"text":"§ 18632.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Energy Innovation Hubs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc0596d47-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18632/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0596d48-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18632/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advanced energy technology","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “advanced energy technology” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0596d49-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18632/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an innovative technology—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc0596d4a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18632/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that produces energy from solar, wind, geothermal, biomass, tidal, wave, ocean, or other renewable energy resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc0596d4b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18632/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that produces nuclear energy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc0596d4c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18632/a/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for carbon capture and sequestration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc0596d4d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18632/a/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that enables advanced vehicles, vehicle components, and related technologies that result in significant energy savings;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc0596d4e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18632/a/1/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that generates, transmits, distributes, uses, or stores energy more efficiently than conventional technologies, including through Smart Grid technologies; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc0596d4f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18632/a/1/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that enhances the energy independence and security of the United States by enabling improved or expanded supply and production of domestic energy resources, including coal, oil, and natural gas;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0596d50-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18632/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a research, development, demonstration, or commercial application activity necessary to ensure the long-term, secure, and sustainable supply of an energy-critical element; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0596d51-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18632/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other innovative energy technology area identified by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0596d52-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18632/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hub","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0596d53-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18632/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Hub” means an Energy Innovation Hub established under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0596d54-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18632/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Hub” includes any Energy Innovation Hub in existence on ","children":[{"tag":"date","attrib":{"date":"2018-09-28"},"text":"September 28, 2018","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0596d55-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18632/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifying entity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “qualifying entity” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0596d56-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18632/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an institution of higher education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0596d57-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18632/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an appropriate State or Federal entity, including a federally funded research and development center of the Department;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0596d58-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18632/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a nongovernmental organization with expertise in advanced energy technology research, development, demonstration, or commercial application; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0596d59-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18632/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other relevant entity the Secretary determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0596d5a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18632/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0596d5b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18632/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall carry out a program to enhance the economic, environmental, and energy security of the United States by making awards to consortia for establishing and operating hubs, to be known as “Energy Innovation Hubs”, to conduct and support, at, if practicable, one centralized location, multidisciplinary, collaborative research, development, demonstration, and commercial application of advanced energy technologies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0596d5c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18632/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technology development focus","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall designate for each Hub a unique advanced energy technology or basic research focus.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0596d5d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18632/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall ensure the coordination of, and avoid unnecessary duplication of, the activities of each Hub with the activities of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0596d5e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18632/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other research entities of the Department, including the National Laboratories, the Advanced Research Projects Agency—Energy, and Energy Frontier Research Centers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0596d5f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18632/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" industry.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0596d60-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18632/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application process","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0596d61-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18632/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to receive an award for the establishment and operation of a Hub under subsection (b)(1), a consortium shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0596d62-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18632/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be composed of not fewer than two qualifying entities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0596d63-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18632/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" operate subject to a binding agreement, entered into by each member of the consortium, that documents—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc0596d64-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18632/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the proposed partnership agreement, including the governance and management structure of the Hub;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc0596d65-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18632/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" measures the consortium will undertake to enable cost-effective implementation of activities under the program described in subsection (b)(1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc0596d66-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18632/c/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a proposed budget, including financial contributions from non-Federal sources; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0596d67-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18632/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operate as a nonprofit organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0596d68-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18632/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0596d69-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18632/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A consortium seeking to establish and operate a Hub under subsection (b)(1) shall submit to the Secretary an application at such time, in such manner, and containing such information as the Secretary may require, including a detailed description of each element of the consortium agreement required under paragraph (1)(B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0596d6a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18632/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the consortium members will not be located at one centralized location, the application under subparagraph (A) shall include a communications plan that ensures close coordination and integration of Hub activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0596d6b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18632/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0596d6c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18632/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall select consortia for awards for the establishment and operation of Hubs through a competitive selection process.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0596d6d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18632/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Considerations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In selecting consortia under subparagraph (A), the Secretary shall consider—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc0596d6e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18632/c/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the information disclosed by the consortium under this subsection; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc0596d6f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18632/c/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any existing facilities a consortium will provide for Hub activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0596d70-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18632/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0596d71-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18632/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An award made to a Hub under this section shall be for a period of not more than 5 years, subject to the availability of appropriations, after which the award may be renewed, subject to a rigorous merit review.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0596d72-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18632/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Existing Hubs","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A Hub already in existence on, or undergoing a renewal process on, ","children":[{"tag":"date","attrib":{"date":"2018-09-28"},"text":"September 28, 2018","children":[],"tail":"—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0596d73-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18632/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may continue to receive support during the 5-year period beginning on the date of establishment of that Hub; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0596d74-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18632/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be eligible for renewal of that support at the end of that 5-year period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0596d75-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18632/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hub operations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0596d76-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18632/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each Hub shall conduct or provide for multidisciplinary, collaborative research, development, demonstration, and commercial application of advanced energy technologies within the technology development focus designated under subsection (b)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0596d77-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18632/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each Hub shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0596d78-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18632/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage collaboration and communication among the member qualifying entities of the consortium and awardees;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0596d79-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18632/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop and publish proposed plans and programs on a publicly accessible website;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0596d7a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18632/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" submit an annual report to the Department summarizing the activities of the Hub, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc0596d7b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18632/e/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" detailing organizational expenditures; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc0596d7c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18632/e/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describing each project undertaken by the Hub; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0596d7d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18632/e/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" monitor project implementation and coordination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0596d7e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18632/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conflicts of interest","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each Hub shall maintain conflict of interest procedures, consistent with the conflict of interest procedures of the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0596d7f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18632/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on construction","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0596d80-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18632/e/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subparagraph (B)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc0596d81-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18632/e/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no funds provided under this section may be used for construction of new buildings or facilities for Hubs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc0596d82-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18632/e/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" construction of new buildings or facilities shall not be considered as part of the non-Federal share of a Hub cost-sharing agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0596d83-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18632/e/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Test bed and renovation exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this paragraph prohibits the use of funds provided under this section or non-Federal cost share funds for the construction of a test bed or renovations to existing buildings or facilities for the purposes of research if the Secretary determines that the test bed or renovations are limited to a scope and scale necessary for the research to be conducted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc0596d84-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/246/tII/s206"},"text":"Pub. L. 115–246, title II, § 206","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-09-28"},"text":"Sept. 28, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3137"},"text":"132 Stat. 3137","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
