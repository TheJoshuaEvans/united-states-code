{"tag":"section","attrib":{"id":"idbf8ea34e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653b"},"text":null,"children":[{"tag":"num","attrib":{"value":"12653b"},"text":"§ 12653b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ServeAmerica Fellowships","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf8ea34f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf8ea350-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Area of national need","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “area of national need” means an area involved in efforts to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf8ea351-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653b/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve education in schools for economically disadvantaged students;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf8ea352-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653b/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expand and improve access to health care;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf8ea353-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653b/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve energy efficiency and conserve natural resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf8ea354-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653b/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve economic opportunities for economically disadvantaged individuals; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf8ea355-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653b/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve disaster preparedness and response.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf8ea356-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible fellowship recipient","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “eligible fellowship recipient” means an individual who is selected by a State Commission under subsection (c) and, as a result of such selection, is eligible for a ServeAmerica Fellowship.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf8ea357-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653b/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fellow","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “fellow” means an eligible fellowship recipient who is awarded a ServeAmerica Fellowship and is designated a fellow under subsection (e)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf8ea358-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653b/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Small service sponsor organization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “small service sponsor organization” means a service sponsor organization described in subsection (d)(1) that has not more than 10 full-time employees and 10 part-time employees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf8ea359-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf8ea35a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"From the amounts appropriated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12681/a/4/B"},"text":"section 12681(a)(4)(B) of this title","children":[],"tail":" and allotted under paragraph (2)(A), the Corporation shall make grants (including financial assistance and a corresponding allotment of approved national service positions), to the State Commission of each of the several States, the District of Columbia, and the Commonwealth of Puerto Rico with an application approved under this section, to enable such State Commissions to award ServeAmerica Fellowships under subsection (e)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf8ea35b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allotment; administrative costs","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf8ea35c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653b/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allotment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount allotted to a State Commission for a fiscal year shall be equal to an amount that bears the same ratio to the amount appropriated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12681/a/4/B"},"text":"section 12681(a)(4)(B) of this title","children":[],"tail":", as the population of the State bears to the total population of the several States, the District of Columbia, and the Commonwealth of Puerto Rico."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf8ea35d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653b/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reallotment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a State Commission does not apply for an allotment under this subsection for any fiscal year, or if the State Commission’s application is not approved, the Corporation shall reallot the amount of the State Commission’s allotment to the remaining State Commissions in accordance with subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf8ea35e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653b/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the amount allotted to a State Commission under subparagraph (A), not more than 1.5 percent of such amount may be used for administrative costs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf8ea35f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653b/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Number of positions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Corporation shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf8ea360-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653b/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish or increase the number of approved national service positions under this subsection during each of fiscal years 2010 through 2014;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf8ea361-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653b/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish the number of approved positions at 500 for fiscal year 2010; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf8ea362-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653b/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" increase the number of the approved positions to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbf8ea363-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653b/b/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 750 for fiscal year 2011;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf8ea364-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653b/b/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1,000 for fiscal year 2012;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf8ea365-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653b/b/3/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1,250 for fiscal year 2013; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf8ea366-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653b/b/3/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1,500 for fiscal year 2014.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf8ea367-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653b/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uses of grant funds","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf8ea368-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653b/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required uses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A grant awarded under this subsection shall be used to enable fellows to carry out service projects in areas of national need.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf8ea369-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653b/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Permitted uses","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A grant awarded under this subsection may be used for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbf8ea36a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653b/b/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" oversight activities and mechanisms for the service sites of the fellows, as determined necessary by the State Commission or the Corporation, which may include site visits;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf8ea36b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653b/b/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" activities to augment the experience of fellows, including activities to engage the fellows in networking opportunities with other national service participants; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf8ea36c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653b/b/4/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recruitment or training activities for fellows.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf8ea36d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653b/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be eligible to receive a grant under this subsection, a State Commission shall submit an application to the Corporation at such time, in such manner, and containing such information as the Corporation may require, including information on the criteria and procedures that the State Commission will use for overseeing ServeAmerica Fellowship placements for service projects, under subsection (e).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf8ea36e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible fellowship recipients","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf8ea36f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653b/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf8ea370-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653b/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An applicant desiring to become an eligible fellowship recipient shall submit an application to a State Commission that has elected to participate in the program authorized under this section, at such time and in such manner as the Commission may require, and containing the information described in subparagraph (B) and such additional information as the Commission may require. An applicant may submit such application to only 1 State Commission for a fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf8ea371-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653b/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Corporation shall specify information to be provided in an application submitted under this subsection, which—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbf8ea372-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653b/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall include—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbf8ea373-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653b/c/1/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the area of national need that the applicant intends to address in the service project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbf8ea374-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653b/c/1/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the skills and experience the applicant has to address the area of national need;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbf8ea375-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653b/c/1/B/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the type of service the applicant plans to provide as a fellow; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbf8ea376-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653b/c/1/B/i/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information identifying the local area within the State served by the Commission in which the applicant plans to serve for the service project; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf8ea377-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653b/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may include, if the applicant chooses, the size of the registered service sponsor organization with which the applicant hopes to serve.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf8ea378-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653b/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each State Commission shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf8ea379-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653b/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" select, from the applications received by the State Commission for a fiscal year, the number of eligible fellowship recipients that may be supported for that fiscal year based on the amount of the grant received by the State Commission under subsection (b); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf8ea37a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653b/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make an effort to award one-third of the fellowships available to the State Commission for a fiscal year, based on the amount of the grant received under subsection (b), to applicants who propose to serve the fellowship with small service sponsor organizations registered under subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf8ea37b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Service sponsor organizations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf8ea37c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653b/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each service sponsor organization shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf8ea37d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653b/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be a nonprofit organization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf8ea37e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653b/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" satisfy qualification criteria established by the Corporation or the State Commission, including standards relating to organizational capacity, financial management, and programmatic oversight;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf8ea37f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653b/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not be a recipient of other assistance, approved national service positions, or approved summer of service positions under the national service laws; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf8ea380-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653b/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" at the time of registration with a State Commission, enter into an agreement providing that the service sponsor organization shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbf8ea381-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653b/d/1/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" abide by all program requirements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf8ea382-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653b/d/1/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide an amount described in subsection (e)(3)(b) ","children":[{"tag":"ref","attrib":{"idref":"fn004087"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004087"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “(e)(3)(B)”."}],"tail":" for each fellow serving with the organization through the ServeAmerica Fellowship;"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf8ea383-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653b/d/1/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be responsible for certifying whether each fellow serving with the organization successfully completed the ServeAmerica Fellowship, and record and certify in a manner specified by the Corporation the number of hours served by a fellow for purposes of determining the fellow’s eligibility for benefits; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf8ea384-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653b/d/1/D/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide timely access to records relating to the ServeAmerica Fellowship to the State Commission, the Corporation, and the Inspector General of the Corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf8ea385-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653b/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Registration","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf8ea386-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653b/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No service sponsor organization may receive a fellow under this section until the organization registers with the State Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf8ea387-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653b/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Clearinghouse","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The State Commission shall maintain a list of registered service sponsor organizations on a public website.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf8ea388-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653b/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Revocation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a State Commission determines that a service sponsor organization is in violation of any of the applicable provisions of this section—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbf8ea389-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653b/d/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State Commission shall revoke the registration of the organization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf8ea38a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653b/d/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the organization shall not be eligible to receive assistance, approved national service positions, or approved summer of service positions under this subchapter for not less than 5 years; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf8ea38b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653b/d/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State Commission shall have the right to remove a fellow from the organization and relocate the fellow to another site.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf8ea38c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653b/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fellows","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf8ea38d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653b/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to participate in a service project as a fellow and receive a ServeAmerica Fellowship, an eligible fellowship recipient shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf8ea38e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653b/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" within 3 months after being selected as an eligible fellowship recipient by a State Commission, select a registered service sponsor organization described in subsection (d)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbf8ea38f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653b/e/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with which the recipient is interested in serving under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf8ea390-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653b/e/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is located in the State served by the State Commission;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf8ea391-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653b/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" enter into an agreement with the organization—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbf8ea392-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653b/e/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that specifies the service the recipient will provide if the placement is approved; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf8ea393-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653b/e/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in which the recipient agrees to serve for 1 year on a full-time or part-time basis (as determined by the Corporation); and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf8ea394-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653b/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit such agreement to the State Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf8ea395-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653b/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Award","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon receiving the eligible fellowship recipient’s agreement under paragraph (1), the State Commission shall award a ServeAmerica Fellowship to the recipient and designate the recipient as a fellow.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf8ea396-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653b/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fellowship amount","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf8ea397-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653b/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"From amounts received under subsection (b), each State Commission shall award each of the State’s fellows a ServeAmerica Fellowship amount that is equal to 50 percent of the amount of the average annual VISTA subsistence allowance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf8ea398-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653b/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount from service sponsor organization","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbf8ea399-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653b/e/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in clause (ii) and subparagraph (E), the service sponsor organization shall award to the fellow serving such organization an amount that will ensure that the total award received by the fellow for service in the service project (consisting of such amount and the ServeAmerica Fellowship amount the fellow receives under subparagraph (A)) is equal to or greater than 70 percent of the average annual VISTA subsistence allowance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf8ea39a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653b/e/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Small service sponsor organizations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a small service sponsor organization, the small service sponsor organization may decrease the amount of the service sponsor organization award required under clause (i) to not less than an amount that will ensure that the total award received by the fellow for service in the service project (as calculated in clause (i)) is equal to or greater than 60 percent of the average annual VISTA subsistence allowance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf8ea39b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653b/e/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum living allowance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The total amount that may be provided to a fellow under this subparagraph shall not exceed 100 percent of the average annual VISTA subsistence allowance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf8ea39c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653b/e/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Proration of amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a fellow who is authorized to serve a part-time term of service under the agreement described in paragraph (1)(B)(ii), the amount provided to a fellow under this paragraph shall be prorated accordingly.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf8ea39d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653b/e/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Corporation may allow a State Commission to waive the amount required under subparagraph (B) from the service sponsor organization for a fellow serving the organization if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbf8ea39e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653b/e/3/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such requirement is inconsistent with the objectives of the ServeAmerica Fellowship program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf8ea39f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653b/e/3/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount provided to the fellow under subparagraph (A) is sufficient to meet the necessary costs of living (including food, housing, and transportation) in the area in which the ServeAmerica Fellowship program is located.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf8ea3a0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653b/e/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this paragraph, the term “average annual VISTA subsistence allowance” means the total average annual subsistence allowance provided to VISTA volunteers under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4955"},"text":"section 4955 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf9113a1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653b/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compliance with ineligible service categories","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Service under a ServeAmerica Fellowship shall comply with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12584/a"},"text":"section 12584(a) of this title","children":[],"tail":". For purposes of applying that section to this subsection, a reference to assistance shall be considered to be a reference to assistance provided under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf9113a2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653b/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each service sponsor organization that receives a fellow under this section shall, on a biweekly basis, report to the Corporation on the number of hours served and the services provided by that fellow. The Corporation shall establish a web portal for the organizations to use in reporting the information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf9113a3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653b/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Educational awards","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A fellow who serves in a service project under this section shall be considered to have served in an approved national service position and, upon meeting the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12603"},"text":"section 12603 of this title","children":[],"tail":" for full-time or part-time national service, shall be eligible for a national service educational award described in such section. The Corporation shall transfer an appropriate amount of funds to the National Service Trust to provide for the national service educational award for such fellow."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf9113a4-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/610/tI/s198B"},"text":"Pub. L. 101–610, title I, § 198B","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/13/tI/s1805"},"text":"Pub. L. 111–13, title I, § 1805","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-04-21"},"text":"Apr. 21, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1554"},"text":"123 Stat. 1554","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf9113a5-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf9113a6-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbf9113a7-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 12653b, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/610/tI/s198B"},"text":"Pub. L. 101–610, title I, § 198B","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/tI/s104/c"},"text":"Pub. L. 103–82, title I, § 104(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-09-21"},"text":"Sept. 21, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/843"},"text":"107 Stat. 843","children":[],"tail":", which related to Presidential awards for service to individuals providing significant service and to outstanding service programs, was renumbered "},{"tag":"ref","attrib":{"href":"/us/pl/101/610/s198A"},"text":"section 198A of Pub. L. 101–610","children":[],"tail":" by "},{"tag":"ref","attrib":{