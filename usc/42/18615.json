{"tag":"section","attrib":{"id":"idc0596d1e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18615"},"text":null,"children":[{"tag":"num","attrib":{"value":"18615"},"text":"§ 18615.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreements for commercializing technology pilot program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc0596d1f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18615/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall carry out the Agreements for Commercializing Technology pilot program of the Department, as announced by the Secretary on ","children":[{"tag":"date","attrib":{"date":"2011-12-08"},"text":"December 8, 2011","children":[],"tail":", in accordance with this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0596d20-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18615/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each agreement entered into pursuant to the pilot program referred to in subsection (a) shall provide to the contractor of the applicable National Laboratory, to the maximum extent determined to be appropriate by the Secretary, increased authority to negotiate contract terms, such as intellectual property rights, payment structures, performance guarantees, and multiparty collaborations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0596d21-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18615/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0596d22-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18615/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any director of a National Laboratory may enter into an agreement pursuant to the pilot program referred to in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0596d23-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18615/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreements with non-Federal entities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To carry out paragraph (1) and subject to paragraph (3), the Secretary shall permit the directors of the National Laboratories to execute agreements with a non-Federal entity, including a non-Federal entity already receiving Federal funding that will be used to support activities under agreements executed pursuant to paragraph (1), provided that such funding is solely used to carry out the purposes of the Federal award.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0596d24-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18615/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restriction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The requirements of chapter 18 of title 35 (commonly known as the “Bayh-Dole Act”) shall apply if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0596d25-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18615/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the agreement is a funding agreement (as that term is defined in section 201 of that title); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0596d26-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18615/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least one of the parties to the funding agreement is eligible to receive rights under that chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0596d27-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18615/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission to Secretary","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each affected director of a National Laboratory shall submit to the Secretary, with respect to each agreement entered into under this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0596d28-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18615/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a summary of information relating to the relevant project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0596d29-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18615/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total estimated costs of the project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0596d2a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18615/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" estimated commencement and completion dates of the project; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0596d2b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18615/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other documentation determined to be appropriate by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0596d2c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18615/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall require the contractor of the affected National Laboratory to certify that each activity carried out under a project for which an agreement is entered into under this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0596d2d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18615/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not in direct competition with the private sector; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0596d2e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18615/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not present, or minimizes, any apparent conflict of interest, and avoids or neutralizes any actual conflict of interest, as a result of the agreement under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0596d2f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18615/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extension","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The pilot program referred to in subsection (a) shall be extended until ","children":[{"tag":"date","attrib":{"date":"2019-09-30"},"text":"September 30, 2019","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0596d30-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18615/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0596d31-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18615/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Overall assessment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 60 days after the date described in subsection (f), the Secretary, in coordination with directors of the National Laboratories, shall submit to the appropriate committees of Congress a report that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0596d32-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18615/g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assesses the overall effectiveness of the pilot program referred to in subsection (a);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0596d33-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18615/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifies opportunities to improve the effectiveness of the pilot program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0596d34-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18615/g/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assesses the potential for program activities to interfere with the responsibilities of the National Laboratories to the Department; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0596d35-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18615/g/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides a recommendation regarding the future of the pilot program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0596d36-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18615/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transparency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in coordination with directors of the National Laboratories, shall submit to the appropriate committees of Congress an annual report that accounts for all incidences of, and provides a justification for, non-Federal entities using funds derived from a Federal contract or award to carry out agreements pursuant to this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc0596d37-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/246/tI/s107"},"text":"Pub. L. 115–246, title I, § 107","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-09-28"},"text":"Sept. 28, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3132"},"text":"132 Stat. 3132","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
