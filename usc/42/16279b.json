{"tag":"section","attrib":{"id":"idc00384cf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16279b"},"text":null,"children":[{"tag":"num","attrib":{"value":"16279b"},"text":"§ 16279b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" International nuclear energy cooperation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc00384d0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16279b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall carry out a program—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc00384d1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16279b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to collaborate in international efforts with respect to research, development, demonstration, and commercial application of nuclear technology that supports diplomatic, nonproliferation, climate, and international economic objectives for the safe, secure, and peaceful use of such technology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00384d2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16279b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to develop collaboration initiatives with respect to such efforts with a variety of countries through—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc00384d3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16279b/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" research and development agreements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00384d4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16279b/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development of coordinated action plans; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00384d5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16279b/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" new or existing multilateral cooperation commitments including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc00384d6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16279b/a/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the International Framework for Nuclear Energy Cooperation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc00384d7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16279b/a/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Generation IV International Forum;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc00384d8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16279b/a/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the International Atomic Energy Agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc00384d9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16279b/a/2/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Organization for Economic Co-operation and Development Nuclear Energy Agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc00384da-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16279b/a/2/C/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other international collaborative effort with respect to advanced nuclear reactor operations and safety;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00384db-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16279b/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to support, with the concurrence of the Secretary of State, the safe, secure, and peaceful use of civil nuclear technology in countries developing nuclear energy programs, with a focus on countries that have increased civil nuclear cooperation with the Russian Federation or the People’s Republic of China; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00384dc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16279b/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to promote the fullest utilization of the reactors, fuel, equipment, services, and technology of United States nuclear energy companies (as defined in subsection (b) of the International Nuclear Energy Act of 2025 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16283"},"text":"42 U.S.C. 16283","children":[],"tail":"]) in civil nuclear energy programs outside the United States through—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc00384dd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16279b/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" bilateral and multilateral arrangements developed and executed with the concurrence of the Secretary of State that contain commitments for the utilization of the reactors, fuel, equipment, services, and technology of United States nuclear energy companies (as defined in that subsection);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00384de-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16279b/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the designation of 1 or more United States nuclear energy companies (as defined in that subsection) to implement an arrangement under subparagraph (A) if the Secretary determines that the designation is necessary and appropriate to achieve the objectives of this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00384df-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16279b/a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the waiver of any provision of law relating to competition with respect to any activity related to an arrangement under subparagraph (A) if the Secretary, in consultation with the Attorney General and the Secretary of Commerce, determines that a waiver is necessary and appropriate to achieve the objectives of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc00384e0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16279b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The program under subsection (a) shall be supported in consultation with the Secretary of State and implemented by the Secretary—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc00384e1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16279b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to facilitate, to the maximum extent practicable, workshops and expert-based exchanges to engage industry, stakeholders, and foreign governments with respect to international civil nuclear issues, such as—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc00384e2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16279b/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" training;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00384e3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16279b/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" financing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00384e4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16279b/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" safety;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00384e5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16279b/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" security;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00384e6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16279b/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" safeguards;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00384e7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16279b/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" liability;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00384e8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16279b/b/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advanced fuels;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00384e9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16279b/b/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00384ea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16279b/b/1/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" options for multinational cooperation with respect to the disposal of spent nuclear fuel (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s10101"},"text":"section 10101 of this title","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00384eb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16279b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in coordination with any Federal agency that the President determines to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc00384ec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16279b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of funds authorized to be appropriated or otherwise made available to the Secretary to carry out activities related to international civil nuclear energy cooperation, there is authorized to be appropriated for each of fiscal years 2026 through 2030 up to $15,500,000 to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc00384ed-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tIX/s959B"},"text":"Pub. L. 109–58, title IX, § 959B","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dZ/tII/s2003/h/1"},"text":"Pub. L. 116–260, div. Z, title II, § 2003(h)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2470"},"text":"134 Stat. 2470","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dH/tLXXXIII/s8366/g"},"text":"Pub. L. 119–60, div. H, title LXXXIII, § 8366(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1894"},"text":"139 Stat. 1894","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc00384ee-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc00384ef-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc00384f0-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The International Nuclear Energy Act of 2025, referred to in subsec. (a)(4), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s8366"},"text":"section 8366 of Pub. L. 119–60","children":[],"tail":", which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s16283"},"text":"section 16283 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc00384f1-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s8366/g/1"},"text":"Pub. L. 119–60, § 8366(g)(1)","children":[],"tail":", designated existing provisions as subsec. (a) and inserted heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s8366/g/2/A/i"},"text":"Pub. L. 119–60, § 8366(g)(2)(A)(i)","children":[],"tail":", struck out “financing,” after “supports diplomatic,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s8366/g/2/B/i"},"text":"Pub. L. 119–60, § 8366(g)(2)(B)(i)","children":[],"tail":", struck out “preparations for” before “research and development”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3), (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s8366/g/2/A/ii"},"text":"Pub. L. 119–60, § 8366(g)(2)(A)(ii)","children":[],"tail":", (B)(ii), (C), added pars. (3) and (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s8366/g/3"},"text":"Pub. L. 119–60, § 8366(g)(3)","children":[],"tail":", added subsecs. (b) and (c)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
