,"attrib":{"href":"/us/stat/106/938"},"text":"106 Stat. 938","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb57aadab-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb57aadac-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb57aadad-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s292a"},"text":"Section 292a of this title","children":[],"tail":", referred to in subsec. (b), was in the original a reference to section 701 of act "},{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":". Section 701 of that Act was omitted in the general revision of subchapter V of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/102/408/tI/s102"},"text":"Pub. L. 102–408, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-13"},"text":"Oct. 13, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1994"},"text":"106 Stat. 1994","children":[],"tail":". "},{"tag":"ref","attrib":{"href":"/us/pl/102/408"},"text":"Pub. L. 102–408","children":[],"tail":" enacted a new section 701 of act "},{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", relating to statement of purpose, and a new section 702, relating to scope and duration of loan insurance program, which are classified to sections 292 and 292a, respectively, of this title. For provisions relating to definitions, see sections 292"},{"tag":"i","attrib":{},"text":"o","children":[],"tail":" and 295p of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb57aadae-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s290bb–1"},"text":"section 290bb–1 of this title","children":[],"tail":" prior to renumbering by "},{"tag":"ref","attrib":{"href":"/us/pl/102/321"},"text":"Pub. L. 102–321","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4587"},"text":"section 4587 of this title","children":[],"tail":" prior to renumbering by "},{"tag":"ref","attrib":{"href":"/us/pl/98/24"},"text":"Pub. L. 98–24","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4588"},"text":"section 4588 of this title","children":[],"tail":" prior to renumbering by "},{"tag":"ref","attrib":{"href":"/us/pl/97/35"},"text":"Pub. L. 97–35","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb57aadaf-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/352"},"text":"Pub. L. 102–352","children":[],"tail":" substituted “292a(1)” for “292a(2)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/321/s122/d/2"},"text":"Pub. L. 102–321, § 122(d)(2)","children":[],"tail":", struck “or rental” before “of any land”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/570/s4008/1"},"text":"Pub. L. 99–570, § 4008(1)","children":[],"tail":", which directed that subsec. (b) be amended by striking out “or rental” before “any land”, could not be executed because “or rental” appeared before “of any land”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/570/s4008/2"},"text":"Pub. L. 99–570, § 4008(2)","children":[],"tail":", struck out “rental,” before “purchase”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/24/s2/b/9/B/i"},"text":"Pub. L. 98–24, § 2(b)(9)(B)(i)","children":[],"tail":", struck out direction that, insofar as practicable, the Secretary approve applications under this subsection in a manner resulting in an equitable geographic distribution of Centers."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/24/s2/b/9/B/ii"},"text":"Pub. L. 98–24, § 2(b)(9)(B)(ii)","children":[],"tail":", (iii), struck out provision that no annual grant to any Center might exceed $1,500,000, and made a technical amendment to reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s292a"},"text":"section 292a of this title","children":[],"tail":" to reflect the transfer of this section to the Public Health Service Act."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/24/s2/b/9/B/iv"},"text":"Pub. L. 98–24, § 2(b)(9)(B)(iv)","children":[],"tail":", struck out subsec. (c) which authorized $6,000,000 for each of fiscal years ending "},{"tag":"date","attrib":{"date":"1977-09-30"},"text":"Sept. 30, 1977","children":[],"tail":", 1978, and 1979, $8,000,000 for fiscal year ending "},{"tag":"date","attrib":{"date":"1980-09-30"},"text":"Sept. 30, 1980","children":[],"tail":", and $9,000,000 for fiscal year ending "},{"tag":"date","attrib":{"date":"1981-09-30"},"text":"Sept. 30, 1981","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35/s965/b"},"text":"Pub. L. 97–35, § 965(b)","children":[],"tail":", inserted provisions relating to grants made for fiscal years beginning after "},{"tag":"date","attrib":{"date":"1981-09-30"},"text":"Sept. 30, 1981","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/180/s16/a"},"text":"Pub. L. 96–180, § 16(a)","children":[],"tail":", substituted: in first sentence “biomedical, behavioral, and social issues related to alcoholism and alcohol abuse” for “alcohol problems”; in par. (1)(B) “facilities (including laboratory, reference, and data analysis facilities) to carry out the research plan contained in the application” for “laboratory facilities and reference services (including reference services that will afford access to scientific alcohol literature)”; and in par. (1)(E) “medical and osteopathic, nursing, social work, and other specialized graduate students; and” for “medical and osteopathic students and physicians;”, and added par. (1)(F)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/180/s16/b"},"text":"Pub. L. 96–180, § 16(b)","children":[],"tail":", increased annual grant limitation to $1,500,000 from $1,000,000."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/180/s16/c"},"text":"Pub. L. 96–180, § 16(c)","children":[],"tail":", authorized appropriation of $8,000,000 and $9,000,000 for fiscal years ending "},{"tag":"date","attrib":{"date":"1980-09-30"},"text":"Sept. 30, 1980","children":[],"tail":", and 1981."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/622"},"text":"Pub. L. 95–622","children":[],"tail":" inserted provision following par. (2) relating to approval of applications under this subsection by the Secretary in a manner which results in equitable geographic distribution of Centers."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb57aadb0-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb57aadb1-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1992 Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/352"},"text":"Pub. L. 102–352","children":[],"tail":" effective immediately upon effectuation of amendment made by "},{"tag":"ref","attrib":{"href":"/us/pl/102/321"},"text":"Pub. L. 102–321","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/102/352/s3/1"},"text":"section 3(1) of Pub. L. 102–352","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s285n"},"text":"section 285n of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/321"},"text":"Pub. L. 102–321","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1992-10-01"},"text":"Oct. 1, 1992","children":[],"tail":", with provision for programs providing financial assistance, see section 801(c), (d) of "},{"tag":"ref","attrib":{"href":"/us/pl/102/321"},"text":"Pub. L. 102–321","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s236"},"text":"section 236 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
