{"tag":"section","attrib":{"id":"idbbe7e1db-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2112"},"text":null,"children":[{"tag":"num","attrib":{"value":"2112"},"text":"§ 2112.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign distribution of byproduct material","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbbe7e1dc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2112/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperation with other Nations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission is authorized to cooperate with any nation by distributing byproduct material, and to distribute byproduct material, pursuant to the terms of an agreement for cooperation to which such nation is party and which is made in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2153"},"text":"section 2153 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbbe7e1dd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2112/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distribution to individuals","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission is also authorized to distribute byproduct material to any person outside the United States upon application therefor by such person and demand such charge for such material as would be charged for the material if it were distributed within the United States: ","children":[{"tag":"i","attrib":{},"text":"Provided, however","children":[],"tail":", That the Commission shall not distribute any such material to any person under this section if, in its opinion, such distribution would be inimical to the common defense and security: "},{"tag":"i","attrib":{},"text":"And provided further","children":[],"tail":", That the Commission may require such reports regarding the use of material distributed pursuant to the provisions of this section as it deems necessary."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbbe7e1de-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2112/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distributor’s license","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission is authorized to license others to distribute byproduct material to any person outside the United States under the same conditions, except as to charges, as would be applicable if the material were distributed by the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbbe7e1df-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-08-01/ch724"},"text":"Aug. 1, 1946, ch. 724","children":[],"tail":", title I, § 82, as added "},{"tag":"ref","attrib":{"href":"/us/act/1954-08-30/ch1073/s1"},"text":"Aug. 30, 1954, ch. 1073, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/935"},"text":"68 Stat. 935","children":[],"tail":"; renumbered title I, "},{"tag":"ref","attrib":{"href":"/us/pl/102/486/tIX/s902/a/8"},"text":"Pub. L. 102–486, title IX, § 902(a)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2944"},"text":"106 Stat. 2944","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
