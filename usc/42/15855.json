{"tag":"section","attrib":{"id":"idbfe48bc8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15855"},"text":null,"children":[{"tag":"num","attrib":{"value":"15855"},"text":"§ 15855.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants to improve the commercial value of forest biomass for electric energy, useful heat, transportation fuels, and other commercial purposes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfe48bc9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15855/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfe48bca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15855/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Biomass","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “biomass” means nonmerchantable materials or precommercial thinnings that are byproducts of preventive treatments, such as trees, wood, brush, thinnings, chips, and slash, that are removed—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfe48bcb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15855/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to reduce hazardous fuels;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfe48bcc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15855/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to reduce or contain disease or insect infestation; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfe48bcd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15855/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to restore forest health.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe48bce-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15855/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian tribe","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Indian tribe” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304/e"},"text":"section 5304(e) of title 25","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe48bcf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15855/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonmerchantable","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of subsection (b), the term “nonmerchantable” means that portion of the byproducts of preventive treatments that would not otherwise be used for higher value products.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe48bd0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15855/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Person","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “person” includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfe48bd1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15855/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an individual;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfe48bd2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15855/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a community (as determined by the Secretary concerned);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfe48bd3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15855/a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an Indian tribe;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfe48bd4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15855/a/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a small business or a corporation that is incorporated in the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfe48bd5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15855/a/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a nonprofit organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe48bd6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15855/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preferred community","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “preferred community” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfe48bd7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15855/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any Indian tribe;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfe48bd8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15855/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any town, township, municipality, or other similar unit of local government (as determined by the Secretary concerned) that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbfe48bd9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15855/a/5/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a population of not more than 50,000 individuals; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbfe48bda-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15855/a/5/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary concerned, in the sole discretion of the Secretary concerned, determines contains or is located near Federal or Indian land, the condition of which is at significant risk of catastrophic wildfire, disease, or insect infestation or which suffers from disease or insect infestation; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfe48bdb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15855/a/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any county that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbfe48bdc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15855/a/5/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not contained within a metropolitan statistical area; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbfe48bdd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15855/a/5/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary concerned, in the sole discretion of the Secretary concerned, determines contains or is located near Federal or Indian land, the condition of which is at significant risk of catastrophic wildfire, disease, or insect infestation or which suffers from disease or insect infestation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe48bde-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15855/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary concerned","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary concerned” means the Secretary of Agriculture or the Secretary of the Interior.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfe48bdf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15855/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Biomass commercial use grant program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfe48be0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15855/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary concerned may make grants to any person in a preferred community that owns or operates a facility that uses biomass as a raw material to produce electric energy, sensible heat, or transportation fuels to offset the costs incurred to purchase biomass for use by such facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe48be1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15855/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant amounts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A grant under this subsection may not exceed $20 per green ton of biomass delivered.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe48be2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15855/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Monitoring of grant recipient activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As a condition of a grant under this subsection, the grant recipient shall keep such records as the Secretary concerned may require to fully and correctly disclose the use of the grant funds and all transactions involved in the purchase of biomass. Upon notice by a representative of the Secretary concerned, the grant recipient shall afford the representative reasonable access to the facility that purchases or uses biomass and an opportunity to examine the inventory and records of the facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfe48be3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15855/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Improved biomass use grant program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfe48be4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15855/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary concerned may make grants to persons to offset the cost of projects to develop or research opportunities to improve the use of, or add value to, biomass. In making such grants, the Secretary concerned shall give preference to persons in preferred communities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe48be5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15855/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary concerned shall select a grant recipient under paragraph (1) after giving consideration to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfe48be6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15855/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the anticipated public benefits of the project, including the potential to develop thermal or electric energy resources or affordable energy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfe48be7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15855/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" opportunities for the creation or expansion of small businesses and micro-businesses;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfe48be8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15855/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the potential for new job creation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfe48be9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15855/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the potential for the project to improve efficiency or develop cleaner technologies for biomass utilization; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfe48bea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15855/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the potential for the project to reduce the hazardous fuels from the areas in greatest need of treatment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe48beb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15855/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A grant under this subsection may not exceed $500,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfe48bec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15855/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated $50,000,000 for fiscal year 2006 and $35,000,000 for each of fiscal years 2007 through 2016 to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfe48bed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15855/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2010-10-01"},"text":"October 1, 2010","children":[],"tail":", the Secretary of Agriculture, in consultation with the Secretary of the Interior, shall submit to the Committee on Energy and Natural Resources and the Committee on Agriculture, Nutrition, and Forestry of the Senate, and the Committee on Resources, the Committee on Energy and Commerce, and the Committee on Agriculture of the House of Representatives, a report describing the results of the grant programs authorized by this section. The report shall include the following:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfe48bee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15855/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An identification of the size, type, and use of biomass by persons that receive grants under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe48bef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15855/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The distance between the land from which the biomass was removed and the facility that used the biomass.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe48bf0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15855/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The economic impacts, particularly new job creation, resulting from the grants to and operation of the eligible operations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfe48bf1-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tII/s210"},"text":"Pub. L. 109–58, title II, § 210","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/658"},"text":"119 Stat. 658","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/375/s6"},"text":"Pub. L. 109–375, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-01"},"text":"Dec. 1, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2658"},"text":"120 Stat. 2658","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbfe48bf2-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbfe48bf3-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbfe48bf4-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/375"},"text":"Pub. L. 109–375","children":[],"tail":" substituted “$50,000,000 for fiscal year 2006 and $35,000,000 for each of fiscal years 2007 through 2016” for “$50,000,000 for each of the fiscal years 2006 through 2016”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbfe48bf5-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idbfe48bf6-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Resources of House of Representatives changed to Committee on Natural Resources of House of Representatives by House Resolution No. 6, One Hundred Tenth Congress, ","children":[{"tag":"date","attrib":{"date":"2007-01-05"},"text":"Jan. 5, 2007","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
