{"tag":"section","attrib":{"id":"idc08b7906-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19301"},"text":null,"children":[{"tag":"num","attrib":{"value":"19301"},"text":"§ 19301.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Clean Energy Incubator Program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc08b7907-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19301/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Clean energy incubator defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “clean energy incubator”—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc08b7908-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19301/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" means any entity that is designed to accelerate the commercial application of clean energy technologies by providing—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc08b7909-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19301/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" physical workspace, labs, and prototyping facilities to support clean energy startups or established clean energy companies; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc08b790a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19301/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" companies developing such technologies with support, resources, and services, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc08b790b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19301/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" access to business education and counseling;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc08b790c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19301/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" mentorship opportunities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc08b790d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19301/a/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other services rendered for the purpose of aiding the development and commercial application of a clean energy technology; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc08b790e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19301/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may include a program within or established by a National Laboratory, an institution of higher education or a State, territorial, local, or tribal government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc08b790f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19301/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after the enactment of this Act, the Secretary, acting through the Chief Commercialization Officer established in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16391/a"},"text":"section 16391(a) of this title","children":[],"tail":", shall establish a Clean Energy Incubator Program (herein referred to as the “program”) to competitively award grants to clean energy incubators."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc08b7910-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19301/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Clean energy incubator selection","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In awarding grants to clean energy incubators under subsection (b), the Secretary shall, to the maximum extent practicable, prioritize funding clean energy incubators that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc08b7911-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19301/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" partner with entities that carry out activities relevant to the activities of such incubator and that operate at the local, State, and regional levels;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc08b7912-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19301/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support the commercial application activities of startup companies focused on physical hardware, computational, or integrated hardware and software technologies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc08b7913-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19301/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are located in geographically diverse regions of the United States, such as the Great Lakes region;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc08b7914-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19301/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are located in, or partner with entities located in, economically-distressed areas;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc08b7915-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19301/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support the development of entities focused on expanding clean energy tools and technologies to rural, Tribal, and low-income communities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc08b7916-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19301/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support the commercial application of technologies being developed by clean energy entrepreneurs from underrepresented backgrounds; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc08b7917-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19301/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have a plan for sustaining activities of the incubator after grant funds received under this program have been expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc08b7918-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19301/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Award limits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall not award more than $4,000,000 to one or more incubators in one given State, per fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc08b7919-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19301/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each grant under subsection (b) shall be for a period of no longer than 5 years, subject to the availability of appropriations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc08b791a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19301/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An entity receiving a grant under this section may use grant amounts for operating expenses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc08b791b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19301/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Renewal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An award made to a clean energy incubator under this section may be renewed for a period of not more than 3 years, subject to merit review.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc08b791c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19301/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16391a"},"text":"section 16391a of this title","children":[],"tail":", the Secretary shall submit to the Committee on Science, Space, and Technology of the House of Representatives and the Committee on Energy and Natural Resources of the Senate an evaluation of the program established under this section that includes analyses of the performance of the clean energy incubators."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc08b791d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19301/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to the Secretary to carry out this section $15,000,000 for each of fiscal years 2023 through 2027.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc08b791e-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/tVI/s10713"},"text":"Pub. L. 117–167, div. B, title VI, § 10713","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1701"},"text":"136 Stat. 1701","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
