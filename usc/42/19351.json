{"tag":"content","attrib":{},"text":" a State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc08dea35-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19351/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an Indian Tribe (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304"},"text":"section 5304 of title 25","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc08dea36-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19351/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Tribal organization (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304"},"text":"section 5304 of title 25","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc08dea37-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19351/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a unit of local government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc08dea38-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19351/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an electric utility (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s796"},"text":"section 796 of title 16","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc08dea39-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19351/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a National Laboratory (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s15801"},"text":"section 15801 of this title","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc08dea3a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19351/a/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an institution of higher education (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001/a"},"text":"section 1001(a) of title 20","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc08dea3b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19351/a/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a private entity specializing in—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc08dea3c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19351/a/2/H/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advanced nuclear technology development;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc08dea3d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19351/a/2/H/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nuclear supply chains; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc08dea3e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19351/a/2/H/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to nuclear technologies and nonelectric applications of nuclear technologies, construction, project financing, contract structuring and risk allocation, or regulatory and licensing processes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc08dea3f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19351/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “program” means the program established under subsection (b)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc08dea40-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19351/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of Energy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc08dea41-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19351/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc08dea42-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19351/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a program to provide Federal financial assistance to eligible entities to support the research, development, demonstration, and deployment of advanced nuclear reactors and associated supply chain infrastructure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc08dea43-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19351/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Competitive procedures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the maximum extent practicable, the Secretary shall carry out the program using a competitive, merit-based review process that is consistent with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16353"},"text":"section 16353 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc08dea44-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19351/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An eligible entity desiring Federal financial assistance under the program shall submit to the Secretary an application at such time, in such manner, and containing such information as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc08dea45-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19351/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In selecting eligible entities to receive Federal financial assistance under the program, the Secretary shall give priority to eligible entities that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc08dea46-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19351/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" plan to carry out projects at or near the site of 1 or more fossil fuel electric generation facilities that are retired or scheduled to retire, including multi-unit facilities that are partially shut down—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc08dea47-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19351/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to support the productive reuse of fossil fuel electric generation facilities that are retired or scheduled to retire; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc08dea48-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19351/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to sustain and revitalize communities impacted by the closure of fossil fuel electric generation facilities;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc08dea49-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19351/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" plan to support nonelectric applications, including supplying heat for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc08dea4a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19351/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" energy storage;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc08dea4b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19351/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hydrogen or other liquid and gaseous fuel or chemical production;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc08dea4c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19351/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" industrial processes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc08dea4d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19351/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" desalination technologies and processes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc08dea4e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19351/d/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" isotope production;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc08dea4f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19351/d/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" district heating; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc08dea50-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19351/d/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other applications, as the Secretary determines to be appropriate; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc08dea51-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19351/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have implemented or demonstrated the ability to successfully implement workforce training or retraining programs to train workers to perform activities relating to the research, development, and demonstration of advanced nuclear reactors.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc08dea52-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19351/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16352"},"text":"Section 16352 of this title","children":[],"tail":" shall apply to Federal financial assistance provided under the program."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc08dea53-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19351/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In addition to amounts otherwise available, there are authorized to be appropriated to the Secretary to carry out the program—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc08dea54-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19351/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $75,000,000 for fiscal year 2023;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc08dea55-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19351/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $100,000,000 for fiscal year 2024;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc08dea56-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19351/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $150,000,000 for fiscal year 2025;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc08dea57-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19351/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $225,000,000 for fiscal year 2026; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc08dea58-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19351/f/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $250,000,000 for fiscal year 2027.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc08dea59-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/tVI/s10781"},"text":"Pub. L. 117–167, div. B, title VI, § 10781","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1728"},"text":"136 Stat. 1728","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/dC/tXXXI/s3131/p/1"},"text":"Pub. L. 118–31, div. C, title XXXI, § 3131(p)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/803"},"text":"137 Stat. 803","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc08dea5a-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc08dea5b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc08dea5c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2023—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31"},"text":"Pub. L. 118–31","children":[],"tail":" substituted “demonstration, and deployment of advanced nuclear reactors and associated supply chain infrastructure” for “and demonstration of advanced nuclear reactors”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
