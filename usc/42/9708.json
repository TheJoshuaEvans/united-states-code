{"tag":"section","attrib":{"id":"idbed98439-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9708"},"text":null,"children":[{"tag":"num","attrib":{"value":"9708"},"text":"§ 9708.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to the Secretary to carry out this chapter such sums as may be authorized by legislation hereafter enacted.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbed9843a-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/567/s9"},"text":"Pub. L. 96–567, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-22"},"text":"Dec. 22, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3333"},"text":"94 Stat. 3333","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
