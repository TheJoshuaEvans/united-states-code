{"tag":"section","attrib":{"id":"idc0786637-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19054"},"text":null,"children":[{"tag":"num","attrib":{"value":"19054"},"text":"§ 19054.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Climate change research","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Director shall make awards, on a competitive basis, to institutions of higher education or non-profit organizations (or consortia of such institutions or organizations) to support research to improve our understanding of the climate system and related human and environmental systems.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc0786638-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/tIII/s10345"},"text":"Pub. L. 117–167, div. B, title III, § 10345","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1560"},"text":"136 Stat. 1560","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
