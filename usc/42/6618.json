{"tag":"section","attrib":{"id":"idbdb1ccb6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6618"},"text":null,"children":[{"tag":"num","attrib":{"value":"6618"},"text":"§ 6618.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Major science and technology proposals","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Director shall identify and provide an annual report to Congress on each major multinational science and technology project, in which the United States is not a participant, which has a total estimated cost greater than $1,000,000,000.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbdb1ccb7-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/282/tII/s209"},"text":"Pub. L. 94–282, title II, § 209","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/245/tV/s502"},"text":"Pub. L. 102–245, title V, § 502","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-02-14"},"text":"Feb. 14, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/24"},"text":"106 Stat. 24","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbdb1ccb8-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbdb1ccb9-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbdb1ccba-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 6618, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/282/tII/s209"},"text":"Pub. L. 94–282, title II, § 209","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-05-11"},"text":"May 11, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/468"},"text":"90 Stat. 468","children":[],"tail":", directed President to transmit annually to Congress a report on science and technology to be prepared by Office of Science and Technology Policy, and directed Director of Office to make the report available as a public document, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/97/375/tII/s215/1"},"text":"Pub. L. 97–375, title II, § 215(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-12-21"},"text":"Dec. 21, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1826"},"text":"96 Stat. 1826","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s6615"},"text":"section 6615 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
