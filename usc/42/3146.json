{"tag":"section","attrib":{"id":"idbc74b7fb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3146"},"text":null,"children":[{"tag":"num","attrib":{"value":"3146"},"text":"§ 3146.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations on relative needs and allocations","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In promulgating rules, regulations, and procedures for assistance under this subchapter, the Secretary shall ensure that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc74b7fc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3146/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the relative needs of eligible areas are given adequate consideration by the Secretary, as determined based on, among other relevant factors—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc74b7fd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3146/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the severity of the rates of unemployment in the eligible areas and the duration of the unemployment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc74b7fe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3146/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the per capita income levels, the labor force participation rate, and the extent of underemployment in eligible areas; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc74b7ff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3146/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the outmigration of population from eligible areas and the extent to which the outmigration is causing economic injury in the eligible areas;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc74b800-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3146/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allocations of assistance under this subchapter are prioritized to ensure that the level of economic distress of an area, rather than a preference for a geographic area or a specific type of economic distress, is the primary factor in allocating the assistance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc74b801-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3146/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc74b802-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3146/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rural and urban economically distressed areas are not harmed by the establishment or implementation by the Secretary of a private sector leveraging goal for a project under this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc74b803-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3146/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any private sector leveraging goal established by the Secretary does not prohibit or discourage grant applicants under this subchapter from public works in, or economic development of, rural or urban economically distressed areas; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc74b804-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3146/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the relevant Committees of Congress are notified prior to making any changes to any private sector leveraging goal; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc74b805-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3146/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" grants made under this subchapter promote job creation and retention and will have a high probability of meeting or exceeding applicable performance requirements established in connection with the grants.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc74b806-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/136/tII/s206"},"text":"Pub. L. 89–136, title II, § 206","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/393/tI/s102/a"},"text":"Pub. L. 105–393, title I, § 102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3604"},"text":"112 Stat. 3604","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/373/tII/s204"},"text":"Pub. L. 108–373, title II, § 204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-27"},"text":"Oct. 27, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1761"},"text":"118 Stat. 1761","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/272/dB/tII/s2216"},"text":"Pub. L. 118–272, div. B, title II, § 2216","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/3181"},"text":"138 Stat. 3181","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc74b807-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc74b808-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbc74b809-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Par. (1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272/s2216/1"},"text":"Pub. L. 118–272, § 2216(1)","children":[],"tail":", added subpar. (B) and struck out former subpar. (B) which read as follows: “the income levels and the extent of underemployment in eligible areas; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272/s2216/2"},"text":"Pub. L. 118–272, § 2216(2)","children":[],"tail":", inserted “and retention” after “creation”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Pars. (3), (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/373"},"text":"Pub. L. 108–373","children":[],"tail":" added pars. (3) and (4)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbc74b80a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbc74b80b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1999-02-11"},"text":"Feb. 11, 1999","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/393/s105"},"text":"section 105 of Pub. L. 105–393","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3121"},"text":"section 3121 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
