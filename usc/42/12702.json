{"tag":"section","attrib":{"id":"idbf95ce8e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12702"},"text":null,"children":[{"tag":"num","attrib":{"value":"12702"},"text":"§ 12702.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Objective of national housing policy","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The objective of national housing policy shall be to reaffirm the long-established national commitment to decent, safe, and sanitary housing for every American by strengthening a nationwide partnership of public and private institutions able—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf95ce8f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12702/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to ensure that every resident of the United States has access to decent shelter or assistance in avoiding homelessness;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf95ce90-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12702/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to increase the Nation’s supply of decent housing that is affordable to low-income and moderate-income families and accessible to job opportunities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf95ce91-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12702/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to improve housing opportunities for all residents of the United States, particularly members of disadvantaged minorities, on a nondiscriminatory basis;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf95ce92-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12702/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to help make neighborhoods safe and livable;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf95ce93-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12702/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to expand opportunities for homeownership;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf95ce94-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12702/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide every American community with a reliable, readily available supply of mortgage finance at the lowest possible interest rates; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf95ce95-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12702/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to encourage tenant empowerment and reduce generational poverty in federally assisted and public housing by improving the means by which self-sufficiency may be achieved.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf95ce96-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/625/tI/s102"},"text":"Pub. L. 101–625, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4085"},"text":"104 Stat. 4085","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
