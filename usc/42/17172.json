{"tag":"section","attrib":{"id":"idc02c1bad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17172"},"text":null,"children":[{"tag":"num","attrib":{"value":"17172"},"text":"§ 17172.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Solar energy curriculum development and certification grants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc02c1bae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17172/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish in the Office of Solar Energy Technologies a competitive grant program to create and strengthen solar industry workforce training and internship programs in installation, operation, and maintenance of solar energy products. The goal of this program is to ensure a supply of well-trained individuals to support the expansion of the solar energy industry.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc02c1baf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17172/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorized activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Grant funds may be used to support the following activities:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc02c1bb0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17172/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Creation and development of a solar energy curriculum appropriate for the local educational, entrepreneurial, and environmental conditions, including curriculum for community colleges.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02c1bb1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17172/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Support of certification programs for individual solar energy system installers, instructors, and training programs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02c1bb2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17172/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Internship programs that provide hands-on participation by students in commercial applications.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02c1bb3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17172/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Activities required to obtain certification of training programs and facilities by an industry-accepted quality-control certification program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02c1bb4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17172/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Incorporation of solar-specific learning modules into traditional occupational training and internship programs for construction-related trades.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02c1bb5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17172/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The purchase of equipment necessary to carry out activities under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02c1bb6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17172/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Support of programs that provide guidance and updates to solar energy curriculum instructors.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc02c1bb7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17172/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration of grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Grants may be awarded under this section for up to 3 years. The Secretary shall award grants to ensure sufficient geographic distribution of training programs nationally. Grants shall only be awarded for programs certified by an industry-accepted quality-control certification institution, or for new and growing programs with a credible path to certification. Due consideration shall be given to women, underrepresented minorities, and persons with disabilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc02c1bb8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17172/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall make public, on the website of the Department or upon request, information on the name and institution for all grants awarded under this section, including a brief description of the project as well as the grant award amount.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc02c1bb9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17172/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to the Secretary for carrying out this section $10,000,000 for each of the fiscal years 2008 through 2012.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc02c1bba-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/tVI/s604"},"text":"Pub. L. 110–140, title VI, § 604","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1675"},"text":"121 Stat. 1675","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc02c1bbb-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc02c1bbc-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc02c1bbd-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the date that is 1 day after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/s1601"},"text":"section 1601 of Pub. L. 110–140","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1824"},"text":"section 1824 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
