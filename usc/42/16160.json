{"tag":"section","attrib":{"id":"idbff52d3d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16160"},"text":null,"children":[{"tag":"num","attrib":{"value":"16160"},"text":"§ 16160.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbff52d3e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16160/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subsection (c), not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":", and triennially thereafter, the Secretary shall submit to Congress a report describing—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbff52d3f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16160/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" activities carried out by the Department under this subchapter,","children":[{"tag":"ref","attrib":{"idref":"fn004211"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004211"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The comma probably should not appear."}],"tail":" for hydrogen and fuel cell technology;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff52d40-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16160/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" measures the Secretary has taken during the preceding 3 years to support the transition of primary industry (or a related industry) to a fully commercialized hydrogen economy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff52d41-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16160/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any change made to the strategy relating to hydrogen and fuel cell technology to reflect the results of a learning demonstrations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff52d42-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16160/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" progress, including progress in infrastructure, made toward achieving the goal of producing and deploying not less than—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbff52d43-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16160/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 100,000 hydrogen-fueled vehicles in the United States by 2010; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff52d44-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16160/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 2,500,000 hydrogen-fueled vehicles in the United States by 2020;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff52d45-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16160/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" progress made toward achieving the goal of supplying hydrogen at a sufficient number of fueling stations in the United States by 2010 including by integrating—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbff52d46-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16160/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hydrogen activities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff52d47-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16160/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" associated targets and timetables for the development of hydrogen technologies;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff52d48-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16160/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any problem relating to the design, execution, or funding of a program under this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff52d49-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16160/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" progress made toward and goals achieved in carrying out this subchapter and updates to the developmental roadmap, including the results of the reviews conducted by the National Academy of Sciences under subsection (b) for the fiscal years covered by the report; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff52d4a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16160/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any updates to strategic plans that are necessary to meet the goals described in paragraph (4).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff52d4b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16160/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" External review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall enter into an arrangement with the National Academy of Sciences under which the Academy will review the programs under sections 16154 and 16157 of this title every fourth year following ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":". The Academy’s review shall include the program priorities and technical milestones, and evaluate the progress toward achieving them. The first review shall be completed not later than 5 years after "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":". Not later than 45 days after receiving the review, the Secretary shall transmit the review to Congress along with a plan to implement the review’s recommendations or an explanation for the reasons that a recommendation will not be implemented."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff52d4c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16160/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this section $1,500,000 for each of fiscal years 2006 through 2020.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbff52d4d-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tVIII/s811"},"text":"Pub. L. 109–58, title VIII, § 811","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/852"},"text":"119 Stat. 852","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
