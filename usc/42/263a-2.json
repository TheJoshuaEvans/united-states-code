{"tag":"section","attrib":{"id":"idb5169454-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s263a–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"263a–2"},"text":"§ 263a–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification of embryo laboratories","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5169455-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s263a–2/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5169456-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s263a–2/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Development","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"1992-10-24"},"text":"October 24, 1992","children":[],"tail":", the Secretary, through the Centers for Disease Control, shall develop a model program for the certification of embryo laboratories (referred to in this section as a “certification program”) to be carried out by the States."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5169457-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s263a–2/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In developing the certification program under paragraph (1), the Secretary shall consult with appropriate consumer and professional organizations with expertise in using, providing, and evaluating professional services and embryo laboratories associated with the assisted reproductive technology programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5169458-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s263a–2/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distribution","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall distribute a description of the certification program to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5169459-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s263a–2/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Governor of each State,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb516945a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s263a–2/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the presiding officers of each State legislature,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb516945b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s263a–2/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the public health official of each State, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb516945c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s263a–2/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the official responsible in each State for the operation of the State’s contract with the Secretary under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395aa"},"text":"section 1395aa of this title","children":[],"tail":","}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"and shall encourage such officials to assist in the State adopting such program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb516945d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s263a–2/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The certification program shall include the following requirements:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb516945e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s263a–2/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The certification program shall be administered by the State and shall provide for the inspection and certification of embryo laboratories in the State by the State or by approved accreditation organizations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb516945f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s263a–2/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The certification program shall provide for the submission of an application to a State by an embryo laboratory for certification, in such form as may be specified by the State. Such an application shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5169460-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s263a–2/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assurances satisfactory to the State that the embryo laboratory will be operated in accordance with the standards under subsection (d),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5169461-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s263a–2/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a report to the State identifying the assisted reproductive technology programs with which the laboratory is associated, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5169462-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s263a–2/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other information as the State finds necessary.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"An embryo laboratory which meets the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s263a"},"text":"section 263a of this title","children":[],"tail":" shall, for the purposes of subparagraph (A) be considered in compliance with the standards referred to in such subparagraph which are the same as the standards in effect under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s263a"},"text":"section 263a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5169463-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s263a–2/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standards","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The certification program shall include the following standards developed by the Secretary:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5169464-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s263a–2/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A standard to assure consistent performance of procedures by each embryo laboratory certified under the certification program or by an approved accreditation organization in a State which has not adopted the certification program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5169465-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s263a–2/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A standard for a quality assurance and a quality control program to assure valid, reliable, and reproduceable ","children":[{"tag":"ref","attrib":{"idref":"fn002114"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002114"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “reproducible”."}],"tail":" procedures in the laboratory."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5169466-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s263a–2/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A standard for the maintenance of records (on a program by program basis) on laboratory tests and procedures performed, including the scientific basis of, and the methodology used for, the tests, procedures, and preparation of any standards or controls, criteria for acceptable and unacceptable outcomes, criteria for sample rejection, and procedures for safe sample disposal.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5169467-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s263a–2/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A standard for the maintenance of written records on personnel and facilities necessary for proper and effective operation of the laboratory, schedules of preventive maintenance, function verification for equipment, and the release of such records to the State upon demand.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5169468-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s263a–2/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A standard for the use of such personnel who meet such qualifications as the Secretary may develop.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5169469-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s263a–2/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification under State programs","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A State may qualify to adopt the certification program if the State has submitted an application to the Secretary to adopt such program and the Secretary has approved the application. Such an application shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb516946a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s263a–2/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assurances by the State satisfactory to the Secretary that the certification program within the State meets the requirements of this section,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb516946b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s263a–2/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an agreement to make such reports as the Secretary may require, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb516946c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s263a–2/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information about any proposed use of accreditation organizations under subsection (g).","children":[{"tag":"ref","attrib":{"idref":"fn002115"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002115"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be subsection “(f)”."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb516946d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s263a–2/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of accreditation organizations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State which has adopted the certification program may use accreditation organizations approved under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s263a–3"},"text":"section 263a–3 of this title","children":[],"tail":" to inspect and certify embryo laboratories."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb516946e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s263a–2/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inspections","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb516946f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s263a–2/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State which qualifies to adopt the certification program within the State shall conduct inspections in accordance with paragraph (2) to determine if laboratories in the State meet the requirements of such program. Such inspections shall be carried out by the State or by accreditation organizations used by the State under subsection (g).","children":[{"tag":"sup","attrib":{},"text":"2","children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5169470-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s263a–2/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Inspections carried out under paragraph (1) shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5169471-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s263a–2/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be periodic and unannounced, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5169472-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s263a–2/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be announced in such circumstances as the Secretary determines will not diminish the likelihood of discovering deficiencies in the operations of a laboratory.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Before making a determination under subparagraph (B), the Secretary shall make public, in such manner as to facilitate comment from any person (including any Federal or other public agency), a proposal indicating the circumstances under which announced inspections would be permitted.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5169473-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s263a–2/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Results","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The specific findings, including deficiencies, identified in an inspection carried out under paragraph (1) and any subsequent corrections to those deficiencies shall be announced and made available to the public upon request beginning no later than 60 days after the date of the inspection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5169474-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s263a–2/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Validation inspections","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5169475-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s263a–2/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may enter and inspect, during regular hours of operation, embryo laboratories—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5169476-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s263a–2/h/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which have been certified by a State under the certification program, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5169477-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s263a–2/h/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which have been certified by an accreditation organization approved by the Secretary under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s263a–3"},"text":"section 263a–3 of this title","children":[],"tail":","}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"for the purpose of determining whether the laboratory is being operated in accordance with the standards in subsection (d).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5169478-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s263a–2/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Access to facilities and records","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In conducting an inspection of an embryo laboratory under paragraph (1), the Secretary shall have access to all facilities, equipment, materials, records, and information which the Secretary determines is necessary to determine if such laboratory is being operated in accordance with the standards in subsection (d). As part of such an inspection, the Secretary may copy any material, record, or information inspected or require it to be submitted to the Secretary. Such an inspection may be made only upon the presentation of identification to the owner, operator, or agent in charge of the laboratory being inspected.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5169479-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s263a–2/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to comply","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Secretary determines as a result of an inspection under paragraph (1) that the embryo laboratory is not in compliance with the standards in subsection (d), the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb516947a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s263a–2/h/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notify the State in which the laboratory is located and, if appropriate, the accreditation organization which certified the laboratory,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb516947b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s263a–2/h/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make available to the public the results of the inspection,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb516947c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s263a–2/h/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" conduct additional inspections of other embryo laboratories under paragraph (1) to determine if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb516947d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s263a–2/h/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such State in carrying out the certification program is reliably identifying the deficiencies of such laboratory, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb516947e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s263a–2/h/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the accreditation organization which certified such laboratories is reliably identifying such deficencies,","children":[{"tag":"ref","attrib":{"idref":"fn002116"},"text":"3","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002116"},"text":null,"children":[{"tag":"num","attrib":{},"text":"3","children":[],"tail":" So in original. Probably should be “deficiencies,”."}],"tail":" and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb516947f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s263a–2/h/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" if the Secretary determines—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb5169480-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s263a–2/h/3/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that such State in carrying out the certification program has not met the requirements applicable to such program, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5169481-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s263a–2/h/3/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the accreditation organization which certified such laboratory has not met the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s263a–3"},"text":"section 263a–3 of this title","children":[],"tail":","}],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the Secretary may revoke the approval of the State certification program or revoke the approval of such accreditation organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5169482-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s263a–2/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5169483-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s263a–2/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In developing the certification program, the Secretary may not establish any regulation, standard, or requirement which has the effect of exercising supervision or control over the practice of medicine in assisted reproductive technology programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5169484-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s263a–2/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In adopting the certification program, a State may not establish any regulation, standard, or requirement which has the effect of exercising supervision or control over the practice of medicine in assisted reproductive technology programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5169485-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s263a–2/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term of a certification issued by a State or an accreditation organization in a State shall be prescribed by the Secretary in the certification program and shall be valid for a period of time to be defined by the Secretary through the public comment process described in subsection (h)(2).","children":[{"tag":"ref","attrib":{"idref":"fn002117"},"text":"4","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002117"},"text":null,"children":[{"tag":"num","attrib":{},"text":"4","children":[],"tail":" So in original. Probably should be subsection “(g)(2)”."}],"tail":" The Secretary shall provide an application for recertification to be submitted at the time of changes in the ownership of a certified laboratory or changes in the administration of such a laboratory."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5169486-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/493/s3"},"text":"Pub. L. 102–493, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3146"},"text":"106 Stat. 3146","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb5169487-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb5169488-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb5169489-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Fertility Clinic Success Rate and Certification Act of 1992, and not as part of the Public Health Service Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb516948a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idb516948b-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Centers for Disease Control changed to Centers for Disease Control and Prevention by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/531/tIII/s312"},"text":"Pub. L. 102–531, title III, § 312","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-27"},"text":"Oct. 27, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3504"},"text":"106 Stat. 3504","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb516948c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective upon expiration of 2 years after ","children":[{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/102/493/s9"},"text":"section 9 of Pub. L. 102–493","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s263a–1"},"text":"section 263a–1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
