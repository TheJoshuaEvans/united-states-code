{"tag":"section","attrib":{"id":"idb573a8bc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285f–4"},"text":null,"children":[{"tag":"num","attrib":{"value":"285f–4"},"text":"§ 285f–4.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Microbicide research and development","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Director of the Institute, acting through the head of the Division of AIDS, shall, consistent with the peer-review process of the National Institutes of Health, carry out research on, and development of, safe and effective methods for use by women to prevent the transmission of the human immunodeficiency virus, which may include microbicides.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb573a8bd-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title IV, § 447C, as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/293/tII/s203/c"},"text":"Pub. L. 110–293, title II, § 203(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-07-30"},"text":"July 30, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2941"},"text":"122 Stat. 2941","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
