{"tag":"section","attrib":{"id":"idb72cca61-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s407"},"text":null,"children":[{"tag":"num","attrib":{"value":"407"},"text":"§ 407.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assignment of benefits","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb72cca62-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s407/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The right of any person to any future payment under this subchapter shall not be transferable or assignable, at law or in equity, and none of the moneys paid or payable or rights existing under this subchapter shall be subject to execution, levy, attachment, garnishment, or other legal process, or to the operation of any bankruptcy or insolvency law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb72cca63-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s407/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amendment of section","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No other provision of law, enacted before, on, or after ","children":[{"tag":"date","attrib":{"date":"1983-04-20"},"text":"April 20, 1983","children":[],"tail":", may be construed to limit, supersede, or otherwise modify the provisions of this section except to the extent that it does so by express reference to this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb72cca64-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s407/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Withholding of taxes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed to prohibit withholding taxes from any benefit under this subchapter, if such withholding is done pursuant to a request made in accordance with section 3402(p)(1) of the Internal Revenue Code of 1986 by the person entitled to such benefit or such person’s representative payee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb72cca65-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title II, § 207, "},{"tag":"ref","attrib":{"href":"/us/stat/49/624"},"text":"49 Stat. 624","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1939-08-10/ch666"},"text":"Aug. 10, 1939, ch. 666","children":[],"tail":", title II, § 201, "},{"tag":"ref","attrib":{"href":"/us/stat/53/1362"},"text":"53 Stat. 1362","children":[],"tail":", 1372; "},{"tag":"ref","attrib":{"href":"/us/pl/98/21/tIII/s335/a"},"text":"Pub. L. 98–21, title III, § 335(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-04-20"},"text":"Apr. 20, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/130"},"text":"97 Stat. 130","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dJ/tIV/s4005/a"},"text":"Pub. L. 105–277, div. J, title IV, § 4005(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-911"},"text":"112 Stat. 2681–911","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb72cca66-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb72cca67-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb72cca68-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Internal Revenue Code of 1986, referred to in subsec. (c), is classified generally to Title 26, Internal Revenue Code.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb72cca69-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsec. (b), “","children":[{"tag":"date","attrib":{"date":"1983-04-20"},"text":"April 20, 1983","children":[],"tail":"” substituted for “the date of the enactment of this section”, which was translated as meaning the date of enactment of this subsection, as the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb72cca6a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277"},"text":"Pub. L. 105–277","children":[],"tail":" added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/21"},"text":"Pub. L. 98–21","children":[],"tail":" designated existing provisions as subsec. (a) and added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1939—Act ","children":[{"tag":"date","attrib":{"date":"1939-08-10"},"text":"Aug. 10, 1939","children":[],"tail":", amended section generally, incorporating provisions of former "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s408"},"text":"section 408 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb72cca6b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb72cca6c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1983 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/21/tIII/s335/c"},"text":"Pub. L. 98–21, title III, § 335(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-04-20"},"text":"Apr. 20, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/130"},"text":"97 Stat. 130","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/98/21/tIII/s335/c"},"text":"“The amendments made by subsection (a) [amending this section] shall apply only with respect to benefits payable or rights existing under the Social Security Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s301"},"text":"42 U.S.C. 301","children":[],"tail":" et seq.] on or after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1983-04-20"},"text":"Apr. 20, 1983","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb72cca6d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1939 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1939-08-10/ch666/tII/s201"},"text":"Act Aug. 10, 1939, ch. 666, title II, § 201","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/53/1362"},"text":"53 Stat. 1362","children":[],"tail":", provided that the amendment made by that section is effective "},{"tag":"date","attrib":{"date":"1940-01-01"},"text":"Jan. 1, 1940","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
