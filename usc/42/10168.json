{"tag":"section","attrib":{"id":"idbf1776a4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10168"},"text":null,"children":[{"tag":"num","attrib":{"value":"10168"},"text":"§ 10168.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction authorization","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf1776a5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10168/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Environmental impact statement","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf1776a6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10168/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Once the selection of a site is effective under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s10166"},"text":"section 10166 of this title","children":[],"tail":", the requirements of the National Environmental Policy Act of 1969 ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"42 U.S.C. 4321","children":[],"tail":" et seq.) shall apply with respect to construction of a monitored retrievable storage facility, except that any environmental impact statement prepared with respect to such facility shall not be required to consider the need for such facility or any alternative to the design criteria for such facility set forth in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s10161/b/1"},"text":"section 10161(b)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf1776a7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10168/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nothing in this section shall be construed to limit the consideration of alternative facility designs consistent with the criteria described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s10161/b/1"},"text":"section 10161(b)(1) of this title","children":[],"tail":" in any environmental impact statement, or in any licensing procedure of the Commission, with respect to any monitored retrievable storage facility authorized under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s10162/b"},"text":"section 10162(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf1776a8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10168/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application for construction license","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Once the selection of a site for a monitored retrievable storage facility is effective under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s10166"},"text":"section 10166 of this title","children":[],"tail":", the Secretary may submit an application to the Commission for a license to construct such a facility as part of an integrated nuclear waste management system and in accordance with the provisions of this section and applicable agreements under this chapter affecting such facility."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf1776a9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10168/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Licensing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any monitored retrievable storage facility authorized pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s10162/b"},"text":"section 10162(b) of this title","children":[],"tail":" shall be subject to licensing under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5842/3"},"text":"section 5842(3) of this title","children":[],"tail":". In reviewing the application filed by the Secretary for licensing of such facility, the Commission may not consider the need for such facility or any alternative to the design criteria for such facility set forth in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s10161/b/1"},"text":"section 10161(b)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf1776aa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10168/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Licensing conditions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any license issued by the Commission for a monitored retrievable storage facility under this section shall provide that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf1776ab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10168/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" construction of such facility may not begin until the Commission has issued a license for the construction of a repository under section 10135(d) ","children":[{"tag":"ref","attrib":{"idref":"fn003946"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003946"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s10135/d"},"text":"Section 10135(d) of this title","children":[],"tail":" does not relate to Commission issuance of license."}],"tail":" of this title;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf1776ac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10168/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" construction of such facility or acceptance of spent nuclear fuel or high-level radioactive waste shall be prohibited during such time as the repository license is revoked by the Commission or construction of the repository ceases;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf1776ad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10168/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the quantity of spent nuclear fuel or high-level radioactive waste at the site of such facility at any one time may not exceed 10,000 metric tons of heavy metal until a repository under this chapter first accepts spent nuclear fuel or solidified high-level radioactive waste; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf1776ae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10168/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the quantity of spent nuclear fuel or high-level radioactive waste at the site of such facility at any one time may not exceed 15,000 metric tons of heavy metal.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf1776af-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/425/tI/s148"},"text":"Pub. L. 97–425, title I, § 148","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/202/s101/d/tIII/s300"},"text":"Pub. L. 100–202, § 101(d) [title III, § 300]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1329-104"},"text":"101 Stat. 1329–104","children":[],"tail":", 1329–121; "},{"tag":"ref","attrib":{"href":"/us/pl/100/203/tV/s5021"},"text":"Pub. L. 100–203, title V, § 5021","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1330-235"},"text":"101 Stat. 1330–235","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf1776b0-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf1776b1-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbf1776b2-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The National Environmental Policy Act of 1969, referred to in subsec. (a)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/190"},"text":"Pub. L. 91–190","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-01-01"},"text":"Jan. 1, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/852"},"text":"83 Stat. 852","children":[],"tail":", which is classified generally to chapter 55 (§ 4321 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"section 4321 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbf1776b3-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/202"},"text":"Pub. L. 100–202","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/100/203"},"text":"Pub. L. 100–203","children":[],"tail":" added identical sections."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
