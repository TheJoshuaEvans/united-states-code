{"tag":"section","attrib":{"id":"idc06c7fcc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18812"},"text":null,"children":[{"tag":"num","attrib":{"value":"18812"},"text":"§ 18812.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Leveraging existing agency programs to assist small and medium manufacturers","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary shall expand the scope of technologies covered by the industrial research and assessment centers of the Department—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc06c7fcd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18812/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to include smart manufacturing technologies and practices; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06c7fce-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18812/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to equip the directors of the industrial research and assessment centers with the training and tools necessary to provide technical assistance in smart manufacturing technologies and practices, including energy management systems, to manufacturers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc06c7fcf-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dD/tV/s40532"},"text":"Pub. L. 117–58, div. D, title V, § 40532","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1069"},"text":"135 Stat. 1069","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc06c7fd0-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc06c7fd1-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc06c7fd2-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Wage Rate Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions relating to rates of wages to be paid to laborers and mechanics on projects for construction, alteration, or repair work funded under div. D or an amendment by div. D of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":", including authority of Secretary of Labor, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s18851"},"text":"section 18851 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
