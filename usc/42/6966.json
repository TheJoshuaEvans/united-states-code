{"tag":"section","attrib":{"id":"idbddf1e4c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966"},"text":null,"children":[{"tag":"num","attrib":{"value":"6966"},"text":"§ 6966.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Increased use of recovered mineral component in federally funded projects involving procurement of cement or concrete","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbddf1e4d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbddf1e4e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agency head","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “agency head” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbddf1e4f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Transportation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbddf1e50-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the head of any other Federal agency that, on a regular basis, procures, or provides Federal funds to pay or assist in paying the cost of procuring, material for cement or concrete projects.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbddf1e51-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cement or concrete project","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “cement or concrete project” means a project for the construction or maintenance of a highway or other transportation facility or a Federal, State, or local government building or other public facility that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbddf1e52-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" involves the procurement of cement or concrete; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbddf1e53-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is carried out, in whole or in part, using Federal funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbddf1e54-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recovered mineral component","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “recovered mineral component” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbddf1e55-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ground granulated blast furnace slag, excluding lead slag;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbddf1e56-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coal combustion fly ash; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbddf1e57-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other waste material or byproduct recovered or diverted from solid waste that the Administrator, in consultation with an agency head, determines should be treated as recovered mineral component under this section for use in cement or concrete projects paid for, in whole or in part, by the agency head.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbddf1e58-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation of requirements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbddf1e59-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":", the Administrator and each agency head shall take such actions as are necessary to implement fully all procurement requirements and incentives in effect as of "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":" (including guidelines under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s6962"},"text":"section 6962 of this title","children":[],"tail":") that provide for the use of cement and concrete incorporating recovered mineral component in cement or concrete projects."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbddf1e5a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out paragraph (1), an agency head shall give priority to achieving greater use of recovered mineral component in cement or concrete projects for which recovered mineral components historically have not been used or have been used only minimally.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbddf1e5b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal procurement requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator and each agency head shall carry out this subsection in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6962"},"text":"section 6962 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbddf1e5c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Full implementation study","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbddf1e5d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator, in cooperation with the Secretary of Transportation and the Secretary of Energy, shall conduct a study to determine the extent to which procurement requirements, when fully implemented in accordance with subsection (b), may realize energy savings and environmental benefits attainable with substitution of recovered mineral component in cement used in cement or concrete projects.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbddf1e5e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matters to be addressed","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The study shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbddf1e5f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" quantify—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbddf1e60-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which recovered mineral components are being substituted for Portland cement, particularly as a result of procurement requirements; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbddf1e61-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the energy savings and environmental benefits associated with the substitution;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbddf1e62-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify all barriers in procurement requirements to greater realization of energy savings and environmental benefits, including barriers resulting from exceptions from the law; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbddf1e63-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbddf1e64-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966/c/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify potential mechanisms to achieve greater substitution of recovered mineral component in types of cement or concrete projects for which recovered mineral components historically have not been used or have been used only minimally;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbddf1e65-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966/c/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluate the feasibility of establishing guidelines or standards for optimized substitution rates of recovered mineral component in those cement or concrete projects; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbddf1e66-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966/c/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify any potential environmental or economic effects that may result from greater substitution of recovered mineral component in those cement or concrete projects.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbddf1e67-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 30 months after ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":", the Administrator shall submit to Congress a report on the study."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbddf1e68-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional procurement requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Unless the study conducted under subsection (c) identifies any effects or other problems described in subsection (c)(2)(C)(iii) that warrant further review or delay, the Administrator and each agency head shall, not later than 1 year after the date on which the report under subsection (c)(3) is submitted, take additional actions under this chapter to establish procurement requirements and incentives that provide for the use of cement and concrete with increased substitution of recovered mineral component in the construction and maintenance of cement or concrete projects—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbddf1e69-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to realize more fully the energy savings and environmental benefits associated with increased substitution; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbddf1e6a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to eliminate barriers identified under subsection (c)(2)(B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbddf1e6b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of section","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section affects the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6962"},"text":"section 6962 of this title","children":[],"tail":" (including the guidelines and specifications for implementing those requirements)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbddf1e6c-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/272/tII/s6005"},"text":"Pub. L. 89–272, title II, § 6005","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/58/tI/s108/a"},"text":"Pub. L. 109–58, title I, § 108(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/612"},"text":"119 Stat. 612","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbddf1e6d-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbddf1e6e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbddf1e6f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/272/s6005"},"text":"section 6005 of Pub. L. 89–272","children":[],"tail":" is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s6966a"},"text":"section 6966a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
