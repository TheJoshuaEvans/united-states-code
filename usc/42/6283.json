{"tag":"section","attrib":{"id":"idbd7b04bc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6283"},"text":null,"children":[{"tag":"num","attrib":{"value":"6283"},"text":"§ 6283.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Summer fill and fuel budgeting programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd7b04bd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6283/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd7b04be-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6283/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Budget contract","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “budget contract” means a contract between a retailer and a consumer under which the heating expenses of the consumer are spread evenly over a period of months.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd7b04bf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6283/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fixed-price contract","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “fixed-price contract” means a contract between a retailer and a consumer under which the retailer charges the consumer a set price for propane, kerosene, or heating oil without regard to market price fluctuations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd7b04c0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6283/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Price cap contract","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “price cap contract” means a contract between a retailer and a consumer under which the retailer charges the consumer the market price for propane, kerosene, or heating oil, but the cost of the propane, kerosene, or heating oil may exceed a maximum amount stated in the contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd7b04c1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6283/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"At the request of the chief executive officer of a State, the Secretary shall provide information, technical assistance, and funding—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd7b04c2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6283/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop education and outreach programs to encourage consumers to fill their storage facilities for propane, kerosene, and heating oil during the summer months; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd7b04c3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6283/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to promote the use of budget contracts, price cap contracts, fixed-price contracts, and other advantageous financial arrangements,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"to avoid severe seasonal price increases for and supply shortages of those products.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd7b04c4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6283/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preference","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In implementing this section, the Secretary shall give preference to States that contribute public funds or leverage private funds to develop State summer fill and fuel budgeting programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd7b04c5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6283/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated to carry out this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd7b04c6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6283/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $25,000,000 for fiscal year 2001; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd7b04c7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6283/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such sums as are necessary for each fiscal year thereafter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd7b04c8-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/163/tII/s273"},"text":"Pub. L. 94–163, title II, § 273","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/469/tVI/s602/a"},"text":"Pub. L. 106–469, title VI, § 602(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-09"},"text":"Nov. 9, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2040"},"text":"114 Stat. 2040","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/58/tIII/s301/b/2"},"text":"Pub. L. 109–58, title III, § 301(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/683"},"text":"119 Stat. 683","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd7b04c9-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd7b04ca-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd7b04cb-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2005—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58"},"text":"Pub. L. 109–58","children":[],"tail":" struck out heading and text of subsec. (e). Text read as follows: “"},{"tag":"ref","attrib":{"href":"/us/usc/t42/s6285"},"text":"Section 6285 of this title","children":[],"tail":" does not apply to this section.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
