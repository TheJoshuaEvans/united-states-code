{"tag":"section","attrib":{"id":"idbda12a78-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6372i"},"text":null,"children":[{"tag":"num","attrib":{"value":"6372i"},"text":"§ 6372i.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Records","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Each recipient of assistance under this part shall keep such records, provide such reports, and furnish such access to books and records as the Secretary may by rule prescribe.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbda12a79-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/163/tIII/s400J"},"text":"Pub. L. 94–163, title III, § 400J","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/95/619/tIII/s311/a"},"text":"Pub. L. 95–619, title III, § 311(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-09"},"text":"Nov. 9, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3253"},"text":"92 Stat. 3253","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
