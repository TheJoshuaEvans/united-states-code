{"tag":"section","attrib":{"id":"idc04b1469-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18032"},"text":null,"children":[{"tag":"num","attrib":{"value":"18032"},"text":"§ 18032.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consumer choice","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc04b146a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18032/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Choice","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc04b146b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18032/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified individuals","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A qualified individual may enroll in any qualified health plan available to such individual and for which such individual is eligible.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc04b146c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18032/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified employers","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc04b146d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18032/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employer may specify level","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A qualified employer may provide support for coverage of employees under a qualified health plan by selecting any level of coverage under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s18022/d"},"text":"section 18022(d) of this title","children":[],"tail":" to be made available to employees through an Exchange."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc04b146e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18032/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employee may choose plans within a level","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each employee of a qualified employer that elects a level of coverage under subparagraph (A) may choose to enroll in a qualified health plan that offers coverage at that level.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc04b146f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18032/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment of premiums by qualified individuals","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A qualified individual enrolled in any qualified health plan may pay any applicable premium owed by such individual to the health insurance issuer issuing such qualified health plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc04b1470-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18032/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Single risk pool","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc04b1471-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18032/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Individual market","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A health insurance issuer shall consider all enrollees in all health plans (other than grandfathered health plans) offered by such issuer in the individual market, including those enrollees who do not enroll in such plans through the Exchange, to be members of a single risk pool.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc04b1472-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18032/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Small group market","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A health insurance issuer shall consider all enrollees in all health plans (other than grandfathered health plans) offered by such issuer in the small group market, including those enrollees who do not enroll in such plans through the Exchange, to be members of a single risk pool.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc04b1473-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18032/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Merger of markets","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State may require the individual and small group insurance markets within a State to be merged if the State determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc04b1474-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18032/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State law","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State law requiring grandfathered health plans to be included in a pool described in paragraph (1) or (2) shall not apply.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc04b1475-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18032/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Empowering consumer choice","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc04b1476-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18032/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continued operation of market outside Exchanges","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this title ","children":[{"tag":"ref","attrib":{"idref":"fn004311"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004311"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" shall be construed to prohibit—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc04b1477-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18032/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a health insurance issuer from offering outside of an Exchange a health plan to a qualified individual or qualified employer; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc04b1478-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18032/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a qualified individual from enrolling in, or a qualified employer from selecting for its employees, a health plan offered outside of an Exchange.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc04b1479-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18032/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continued operation of State benefit requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this title ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" shall be construed to terminate, abridge, or limit the operation of any requirement under State law with respect to any policy or plan that is offered outside of an Exchange to offer benefits."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc04b147a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18032/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Voluntary nature of an Exchange","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc04b147b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18032/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Choice to enroll or not to enroll","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this title ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" shall be construed to restrict the choice of a qualified individual to enroll or not to enroll in a qualified health plan or to participate in an Exchange."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc04b147c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18032/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition against compelled enrollment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this title ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" shall be construed to compel an individual to enroll in a qualified health plan or to participate in an Exchange."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc04b147d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18032/d/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Individuals allowed to enroll in any plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A qualified individual may enroll in any qualified health plan, except that in the case of a catastrophic plan described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s18022/e"},"text":"section 18022(e) of this title","children":[],"tail":", a qualified individual may enroll in the plan only if the individual is eligible to enroll in the plan under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s18022/e/2"},"text":"section 18022(e)(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc04b147e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18032/d/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Members of Congress in the Exchange","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc04b147f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18032/d/3/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of law, after the effective date of this subtitle, the only health plans that the Federal Government may make available to Members of Congress and congressional staff with respect to their service as a Member of Congress or congressional staff shall be health plans that are—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idc04b1480-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18032/d/3/D/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" created under this Act (or an amendment made by this Act); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc04b1481-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18032/d/3/D/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" offered through an Exchange established under this Act (or an amendment made by this Act).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc04b1482-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18032/d/3/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idc04b1483-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18032/d/3/D/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Member of Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Member of Congress” means any member of the House of Representatives or the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc04b1484-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18032/d/3/D/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional staff","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “congressional staff” means all full-time and part-time employees employed by the official office of a Member of Congress, whether in Washington, DC or outside of Washington, DC.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc04b1485-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18032/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No penalty for transferring to minimum essential coverage outside Exchange","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An Exchange, or a qualified health plan offered through an Exchange, shall not impose any penalty or other fee on an individual who cancels enrollment in a plan because the individual becomes eligible for minimum essential coverage (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s5000A/f"},"text":"section 5000A(f) of title 26","children":[],"tail":" without regard to paragraph (1)(C) or (D) thereof) or such coverage becomes affordable (within the meaning of section 36B(c)(2)(C) of such title)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc04b1486-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18032/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enrollment through agents or brokers","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall establish procedures under which a State may allow agents or brokers—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc04b1487-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18032/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to enroll individuals and employers in any qualified health plans in the individual or small group market as soon as the plan is offered through an Exchange in the State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc04b1488-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18032/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assist individuals in applying for premium tax credits and cost-sharing reductions for plans sold through an Exchange.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc04b1489-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18032/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified individuals and employers; access limited to citizens and lawful residents","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc04b148a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18032/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified individuals","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this title: ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc04b148b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18032/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “qualified individual” means, with respect to an Exchange, an individual who—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc04b148c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18032/f/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is seeking to enroll in a qualified health plan in the individual market offered through the Exchange; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc04b148d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18032/f/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" resides in the State that established the Exchange.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc04b148e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18032/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Incarcerated individuals excluded","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An individual shall not be treated as a qualified individual if, at the time of enrollment, the individual is incarcerated, other than incarceration pending the disposition of charges.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc04b148f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18032/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified employer","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this title: ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc04b1490-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18032/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “qualified employer” means a small employer that elects to make all full-time employees of such employer eligible for 1 or more qualified health plans offered in the small group market through an Exchange that offers qualified health plans.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc04b1491-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18032/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extension to large groups","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc04b1492-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18032/f/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Beginning in 2017, each State may allow issuers of health insurance coverage in the large group market in the State to offer qualified health plans in such market through an Exchange. Nothing in this subparagraph shall be construed as requiring the issuer to offer such plans through an Exchange.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc04b1493-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18032/f/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Large employers eligible","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a State under clause (i) allows issuers to offer qualified health plans in the large group market through an Exchange, the term “qualified employer” shall include a large employer that elects to make all full-time employees of such employer eligible for 1 or more qualified health plans offered in the large group market through the Exchange.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc04b1494-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18032/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Access limited to lawful residents","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If an individual is not, or is not reasonably expected to be for the entire period for which enrollment is sought, a citizen or national of the United States or an alien lawfully present in the United States, the individual shall not be treated as a qualified individual and may not be covered under a qualified health plan in the individual market that is offered through an Exchange.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc04b1495-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/tI/s1312"},"text":"Pub. L. 111–148, title I, § 1312","children":[],"tail":", title X, § 10104(i), "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/182"},"text":"124 Stat. 182","children":[],"tail":", 901.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc04b1496-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc04b1497-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc04b1498-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This title, referred to in subsecs. (d)(1), (2), (3)(A), (B) and (f)(1), (2), is title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148"},"text":"Pub. L. 111–148","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/130"},"text":"124 Stat. 130","children":[],"tail":", which enacted this chapter and enacted, amended, and transferred numerous other sections and notes in the Code. For complete classification of title I to the Code, see Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The effective date of this subtitle, referred to in subsec. (d)(3)(D)(i), is the effective date of subtitle D of title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148"},"text":"Pub. L. 111–148","children":[],"tail":", which is "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This Act, referred to in subsec. (d)(3)(D)(i), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148"},"text":"Pub. L. 111–148","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/119"},"text":"124 Stat. 119","children":[],"tail":", known as the Patient Protection and Affordable Care Act. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s18001"},"text":"section 18001 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc04b1499-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/s10104/i/1"},"text":"Pub. L. 111–148, § 10104(i)(1)","children":[],"tail":", inserted “and for which such individual is eligible” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/s10104/i/2/B"},"text":"Pub. L. 111–148, § 10104(i)(2)(B)","children":[],"tail":", struck out concluding provisions which read as follows: “Such procedures may include the establishment of rate schedules for broker commissions paid by health benefits plans offered through an exchange.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/s10104/i/2/A"},"text":"Pub. L. 111–148, § 10104(i)(2)(A)","children":[],"tail":", inserted “and employers” after “enroll individuals”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(1)(A)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/s10104/i/3"},"text":"Pub. L. 111–148, § 10104(i)(3)","children":[],"tail":", struck out “(except with respect to territorial agreements under this subsection)” before period at end."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
