{"tag":"section","attrib":{"id":"idc073abc6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18991"},"text":null,"children":[{"tag":"num","attrib":{"value":"18991"},"text":"§ 18991.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" PreK–12 STEM education","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc073abc7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18991/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Academies study","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 120 days after ","children":[{"tag":"date","attrib":{"date":"2022-08-09"},"text":"August 9, 2022","children":[],"tail":", the Director shall enter into an agreement with the National Academies to conduct a study to—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc073abc8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18991/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review the research literature and identify research gaps regarding the interconnected factors that foster and hinder successful implementation of promising, evidence-based PreK–12 STEM education innovations at the local, regional, and national level;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc073abc9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18991/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" present a compendium of promising, evidence-based PreK–12 STEM education practices, models, programs, and technologies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc073abca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18991/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify barriers to widespread and sustained implementation of such innovations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc073abcb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18991/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make recommendations to the Foundation, the Department of Education, the National Science and Technology Council’s Committee on Science, Technology, Engineering, and Mathematics Education, State and local educational agencies, and other relevant stakeholders on measures to address such barriers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc073abcc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18991/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc073abcd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18991/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" [Log 907 S2522] ","children":[{"tag":"ref","attrib":{"idref":"fn004376"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004376"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original."}],"tail":" National STEM Teacher Corps pilot"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc073abce-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18991/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It is the purpose of this subsection to elevate the profession of STEM teaching by establishing a National STEM Teacher Corps pilot program to recognize outstanding STEM teachers in our Nation’s classrooms, rewards ","children":[{"tag":"ref","attrib":{"idref":"fn004377"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004377"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be “reward”."}],"tail":" them for their accomplishments, elevates "},{"tag":"ref","attrib":{"idref":"fn004378"},"text":"3","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004378"},"text":null,"children":[{"tag":"num","attrib":{},"text":"3","children":[],"tail":" So in original. Probably should be “elevate”."}],"tail":" their public profile, and creates "},{"tag":"ref","attrib":{"idref":"fn004379"},"text":"4","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004379"},"text":null,"children":[{"tag":"num","attrib":{},"text":"4","children":[],"tail":" So in original. Probably should be “create”."}],"tail":" rewarding career paths to which all STEM teachers can aspire, both to prepare future STEM researchers and to create a scientifically literate public."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc073abcf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18991/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc073abd0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18991/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrator","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Administrator” means the Administrator of the National STEM Teacher Corps.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc073abd1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18991/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible entity” means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc073abd2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18991/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an institution of higher education; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc073abd3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18991/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a consortium consisting of an institution of higher education and one or more of the following:","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idc073abd4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18991/c/2/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A State educational agency (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7801"},"text":"section 7801 of title 20","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc073abd5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18991/c/2/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A local educational agency (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7801"},"text":"section 7801 of title 20","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc073abd6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18991/c/2/B/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An education nonprofit Association.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc073abd7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18991/c/2/B/ii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A cross sector ","children":[{"tag":"ref","attrib":{"idref":"fn004380"},"text":"5","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004380"},"text":null,"children":[{"tag":"num","attrib":{},"text":"5","children":[],"tail":" So in original. Probably should be “cross-sector”."}],"tail":" STEM organization."}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc073abd8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18991/c/2/B/ii/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A private entity, including a STEM-related business.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc073abd9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18991/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" High-need school","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “high-need school” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6631/b"},"text":"section 6631(b) of title 20","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc073abda-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18991/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Professional development","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “professional Development” ","children":[{"tag":"ref","attrib":{"idref":"fn004381"},"text":"6","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004381"},"text":null,"children":[{"tag":"num","attrib":{},"text":"6","children":[],"tail":" So in original. Probably should not be capitalized."}],"tail":" has the meaning given the term in "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s7801"},"text":"section 7801 of title 20","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc073abdb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18991/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Corps Alliance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Corps Alliance” means a regionally or topically based award under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc073abdc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18991/c/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National STEM Teacher Corps Advisory Board","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “National STEM Teacher Corps Advisory Board” means the Advisory Board for the National STEM Teacher Corps established under paragraph (5).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc073abdd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18991/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of National STEM Teacher Corps","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director may, subject to the availability of appropriations, establish within the Foundation, a National STEM Teacher Corps 10-year pilot program to be administered by the Administrator, who shall be appointed by the Director. As appropriate, the Director may use existing NSF programs to establish and execute this program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc073abde-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18991/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties of the Administrator","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc073abdf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18991/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" create a process and standards for selection of eligible applicants to become members of the National STEM Teacher Corps, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc073abe0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18991/c/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" uniform selection criteria that includes ","children":[{"tag":"ref","attrib":{"idref":"fn004382"},"text":"7","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004382"},"text":null,"children":[{"tag":"num","attrib":{},"text":"7","children":[],"tail":" So in original. Probably should be “include”."}],"tail":"—"}],"tail":null},{"tag":"subclause","attrib":{"id":"idc073abe1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18991/c/4/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deep knowledge of STEM content and pedagogy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc073abe2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18991/c/4/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a passion for STEM subjects and dedication to teaching, evidence of leadership skills, and potential for continued career growth as an educator; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc073abe3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18991/c/4/A/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrated experience increasing STEM student achievement and STEM participation rates for all students, particularly those from rural and high-need schools; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc073abe4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18991/c/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a uniform selection process, including a comprehensive application that includes recommendations and other relevant professional information;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc073abe5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18991/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote the National STEM Teacher Corps and elevate best practices that emerge from the National STEM Teacher Corps to a national audience;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc073abe6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18991/c/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluate the operation and effectiveness of the Corps alliances; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc073abe7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18991/c/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" evaluate the overall and long-term impact of the National STEM Teacher Corps by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc073abe8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18991/c/4/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" documenting, monitoring, and assessing the program outcomes or impact on the STEM careers of participants; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc073abe9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18991/c/4/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" documenting, monitoring, and assessing the program outcomes for the STEM education profession nationwide, particularly for rural and high-need schools.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc073abea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18991/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National STEM Teacher Corps Advisory Board","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc073abeb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18991/c/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established a National STEM Teacher Corps Advisory Board to advise the Director on matters pertaining to the National STEM Teacher Corps for the length of the pilot program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc073abec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18991/c/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Composition","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc073abed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18991/c/5/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The membership of the National STEM Teacher Corps Advisory Board shall—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idc073abee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18991/c/5/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be appointed by the Director;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc073abef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18991/c/5/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include a representative from each of the following: School leaders, STEM researchers, STEM education researchers, Business leaders, PreK–12 STEM educators, and Students pursuing a postsecondary STEM degree; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc073abf0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18991/c/5/B/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be geographically diverse.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc073abf1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18991/c/5/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Existing committee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director may assign the duties of the National STEM Teacher Corps Advisory Board to another advisory committee of the Foundation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc073abf2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18991/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties of the Corps alliances","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to the availability of appropriated funds, the Administrator may make awards on a competitive, merit-review basis, to establish Corps alliances at eligible entities. Activities carried out by such alliances shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc073abf3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18991/c/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" engaging local partners, which may include local educational agencies, institutions of higher education, STEM organizations, or education nonprofit organizations, to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc073abf4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18991/c/6/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop and serve the community of National STEM Teacher Corps members within the region or topic area, in coordination with local partners to carry out day-to-day activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc073abf5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18991/c/6/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate professional development activities, including activities led by National STEM Teacher Corps members;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc073abf6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18991/c/6/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" connect National STEM Teacher Corps members with existing educator professional development programs and coordinate members’ involvement as cooperating teachers or mentors;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc073abf7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18991/c/6/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" seek opportunities to involve teachers who are not members of the National STEM Teacher Corps to participate in National STEM Teacher Corps activities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc073abf8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18991/c/6/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" build partnerships with existing education organizations and other efforts by State educational agencies and local educational agencies that operate programs relevant to the National STEM Teacher Corps and its activities;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc073abf9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18991/c/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recruiting eligible applicants, with a focus on recruiting diverse STEM educators to advance equity based on race, ethnicity, sex, socioeconomic status, age, disability status, geography, and language ability;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc073abfa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18991/c/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" screening, interviewing, and selecting members of the National STEM Teacher Corps using procedures and standards provided by the Administrator;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc073abfb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18991/c/6/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinating the online network that supports all National STEM Teacher Corps members in the region or topic area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc073abfc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18991/c/6/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" convening occasional meetings of National STEM Teacher Corps members in a region or topic area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc073abfd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18991/c/6/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" creating opportunities for the professional growth of National STEM Teacher Corps members, with a focus on increasing STEM student achievement and STEM participation rates for all students, particularly those from rural and high-need schools; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc073abfe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18991/c/6/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supporting the retention and success of National STEM Teacher Corps members in the region or topic area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc073abff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18991/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties of members of the National STEM Teacher Corps","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An applicant that is selected by a Corps alliance to be a member of the National STEM Teacher Corps shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc073ac00-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18991/c/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serve a 4-year term with a possibility of reappointment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc073ac01-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18991/c/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" receive an annual stipend in an amount not less than $10,000; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc073ac02-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18991/c/7/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" have substantial responsibilities, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc073ac03-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18991/c/7/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" working with other members of the National STEM Teacher Corps to develop and improve innovative teaching practices, including practices such as inquiry-based learning;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc073ac04-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18991/c/7/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" participating in professional development in innovative teaching methodology and mentorship; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc073ac05-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18991/c/7/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" continuing to excel in teaching the member’s own students, with a focus on advancing equity by spending additional time teaching and coaching underserved students to increase STEM student achievement and STEM participation rates for students from rural and high-need schools.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc073ac06-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18991/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director, acting through the Administrator, shall submit a report to Congress after the third year of the pilot program that includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc073ac07-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18991/c/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment, drawing on the evaluations the Administrator shall conduct under subparagraphs (C) and (D) of paragraph (4), and other sources of information, of the effectiveness of the pilot program in recruiting and retaining high-quality STEM teachers in the selected regions or topic areas, particularly in high-need and rural schools; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc073ac08-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18991/c/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if deemed effective, a proposal to Congress for permanent implementation of the pilot program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc073ac09-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18991/c/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sunset","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The authority to carry out this subsection shall terminate on the date that is 15 years after ","children":[{"tag":"date","attrib":{"date":"2022-08-09"},"text":"August 9, 2022","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc073ac0a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18991/c/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated $60,000,000 for each of fiscal years 2023 through 2032 to carry out this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc073ac0b-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/tIII/s10311"},"text":"Pub. L. 117–167, div. B, title III, § 10311","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1510"},"text":"136 Stat. 1510","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc073ac0c-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc073ac0d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idc073ac0e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/s10311"},"text":"section 10311 of div. B of Pub. L. 117–167","children":[],"tail":". Subsec. (b) of "},{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/s10311"},"text":"section 10311 of div. B of Pub. L. 117–167","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1862q"},"text":"section 1862q of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
