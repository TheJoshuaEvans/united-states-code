{"tag":"section","attrib":{"id":"idbf8072bf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12617"},"text":null,"children":[{"tag":"num","attrib":{"value":"12617"},"text":"§ 12617.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Service projects","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf8072c0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12617/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Project requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The service projects carried out by the National Civilian Community Corps shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf8072c1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12617/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meet an identifiable public need, with specific emphasis on projects in support of infrastructure improvement, energy conservation, and urban and rural development;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf8072c2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12617/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" emphasize the performance of community service activities that provide meaningful community benefits and opportunities for service-learning and skills development;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf8072c3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12617/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the maximum extent practicable, encourage work to be accomplished in teams of diverse individuals working together; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf8072c4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12617/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include continued education and training in various technical fields.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf8072c5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12617/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Project proposals","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf8072c6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12617/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Development of proposals","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf8072c7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12617/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specific executive departments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon the establishment of the Program, the Secretary of Agriculture, the Secretary of the Interior, the Secretary of Housing and Urban Development, the Administrator of the Environmental Protection Agency, the Administrator of the Federal Emergency Management Agency, the Secretary of Energy, the Secretary of Transportation, and the Chief of the Forest Service shall develop proposals for Corps projects pursuant to guidance which the Director shall prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf8072c8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12617/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other sources","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Other public and private organizations and agencies, including community-based entities and representatives of local communities in the vicinity of a Corps campus, may develop proposals for projects for a Corps campus. Corps members shall also be encouraged to identify projects for the Corps.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf8072c9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12617/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The process for developing project proposals under paragraph (1) shall include consultation with the Corporation, representatives of local communities, State Commissions, and persons involved in other youth service programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf8072ca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12617/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Project selection, organization, and performance","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf82bbbb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12617/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The campus director of a Corps campus shall select the projects to be performed by the members of the Corps assigned to the units in that campus. The campus director shall select projects from among the projects proposed or identified pursuant to subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf82bbbc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12617/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Innovative local arrangements for project performance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall encourage campus directors to negotiate with representatives of local communities, to the extent practicable, innovative arrangements for the performance of projects. The arrangements may provide for cost-sharing and the provision by the communities of in-kind support and other support.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf82bbbd-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/610/tI/s157"},"text":"Pub. L. 101–610, title I, § 157","children":[],"tail":", formerly § 195F, as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/484/dA/tX/s1092/a/1"},"text":"Pub. L. 102–484, div. A, title X, § 1092(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2526"},"text":"106 Stat. 2526","children":[],"tail":"; renumbered § 157 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/tI/s104/b"},"text":"Pub. L. 103–82, title I, § 104(b)","children":[],"tail":", title IV, §§ 402(b)(2), 403(b), "},{"tag":"date","attrib":{"date":"1993-09-21"},"text":"Sept. 21, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/840"},"text":"107 Stat. 840","children":[],"tail":", 919, 920; "},{"tag":"ref","attrib":{"href":"/us/pl/111/13/tI/s1507"},"text":"Pub. L. 111–13, title I, § 1507","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-04-21"},"text":"Apr. 21, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1524"},"text":"123 Stat. 1524","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf82bbbe-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf82bbbf-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbf82bbc0-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12653f"},"text":"section 12653f of this title","children":[],"tail":" prior to renumbering by "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/s104/b"},"text":"Pub. L. 103–82, § 104(b)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbf82bbc1-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/610/s157"},"text":"section 157 of Pub. L. 101–610","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12602"},"text":"section 12602 of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/s104/a"},"text":"Pub. L. 103–82, § 104(a)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbf82bbc2-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2009—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1507/1/A"},"text":"Pub. L. 111–13, § 1507(1)(A)","children":[],"tail":", inserted “National” before “Civilian Community Corps” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1507/1/B"},"text":"Pub. L. 111–13, § 1507(1)(B)","children":[],"tail":", inserted “, with specific emphasis on projects in support of infrastructure improvement, energy conservation, and urban and rural development” before semicolon at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1507/1/C"},"text":"Pub. L. 111–13, § 1507(1)(C)","children":[],"tail":", substituted “service-learning” for “service learning”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1507/2/A/i"},"text":"Pub. L. 111–13, § 1507(2)(A)(i)","children":[],"tail":", substituted “the Secretary of Housing and Urban Development, the Administrator of the Environmental Protection Agency, the Administrator of the Federal Emergency Management Agency, the Secretary of Energy, the Secretary of Transportation, and the Chief of the Forest Service” for “and the Secretary of Housing and Urban Development”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1507/2/A/ii"},"text":"Pub. L. 111–13, § 1507(2)(A)(ii)","children":[],"tail":", inserted “community-based entities and” before “representatives of local communities” and substituted “campus” for “camp” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1507/2/B"},"text":"Pub. L. 111–13, § 1507(2)(B)","children":[],"tail":", inserted “State Commissions,” before “and persons involved in other youth service programs.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1507/3/A"},"text":"Pub. L. 111–13, § 1507(3)(A)","children":[],"tail":", substituted “campus director of a Corps campus” for “superintendent of a Corps camp” and “campus. The campus director” for “camp. The superintendent”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1507/3/B"},"text":"Pub. L. 111–13, § 1507(3)(B)","children":[],"tail":", substituted “campus directors” for “camp superintendents”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (b)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/82/s403/b"},"text":"Pub. L. 103–82, § 403(b)","children":[],"tail":", substituted “Director” for “Director of the Civilian Community Corps”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/82/s402/b/2"},"text":"Pub. L. 103–82, § 402(b)(2)","children":[],"tail":", substituted “Corporation” for “Commission on National and Community Service”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbf82bbc3-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbf82bbc