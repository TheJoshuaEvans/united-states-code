{"tag":"section","attrib":{"id":"idbc63efe5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3056d"},"text":null,"children":[{"tag":"num","attrib":{"value":"3056d"},"text":"§ 3056d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distribution of assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbc63efe6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3056d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reservations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc63efe7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3056d/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reservation for pilot demonstration and evaluation projects","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the funds appropriated to carry out this subchapter for each fiscal year, the Secretary may first reserve not more than 1.5 percent to carry out demonstration projects, pilot projects, and evaluation projects under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3056/e"},"text":"section 3056(e) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc63efe8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3056d/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reservation for territories","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Of the funds appropriated to carry out this subchapter for each fiscal year, the Secretary shall reserve 0.75 percent, of which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc63efe9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3056d/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Guam, American Samoa, and the United States Virgin Islands shall each receive 30 percent of the funds so reserved; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc63efea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3056d/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Commonwealth of the Northern Mariana Islands shall receive 10 percent of the funds so reserved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc63efeb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3056d/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reservation for organizations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the funds appropriated to carry out this subchapter for each fiscal year, the Secretary shall reserve such amount as may be necessary to make national grants to public or nonprofit national Indian aging organizations with the ability to provide community service employment and other authorized activities for eligible individuals who are Indians and to national public or nonprofit Pacific Island and Asian American aging organizations with the ability to provide community service employment and other authorized activities for eligible individuals who are Pacific Island and Asian Americans.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc63efec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3056d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State allotments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The allotment for each State shall be the sum of the amounts allotted for national grants in such State under subsection (d) and for the grant to such State under subsection (e).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc63efed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3056d/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Division between national grants and grants to States","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The funds appropriated to carry out this subchapter for any fiscal year that remain after amounts are reserved under paragraphs (1), (2), and (3) of subsection (a) shall be divided by the Secretary between national grants and grants to States as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc63efee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3056d/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reservation of funds for fiscal year 2000 level of activities","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc63efef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3056d/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall reserve the amount of funds necessary to maintain the fiscal year 2000 level of activities supported by grantees that operate under this subchapter under national grants from the Secretary, and the fiscal year 2000 level of activities supported by State grantees under this subchapter, in proportion to their respective fiscal year 2000 levels of activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc63eff0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3056d/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Insufficient appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If in any fiscal year the funds appropriated to carry out this subchapter are insufficient to satisfy the requirement specified in subparagraph (A), then the amount described in subparagraph (A) shall be reduced proportionally.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc63eff1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3056d/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding in excess of fiscal year 2000 level of activities","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc63eff2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3056d/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Up to $35,000,000","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of funds remaining (if any) after the application of paragraph (1), but not to exceed $35,000,000, shall be divided so that 75 percent shall be provided to State grantees and 25 percent shall be provided to grantees that operate under this subchapter under national grants from the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc63eff3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3056d/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Over $35,000,000","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of funds remaining (if any) after the application of subparagraph (A) shall be divided so that 50 percent shall be provided to State grantees and 50 percent shall be provided to grantees that operate under this subchapter under national grants from the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc63eff4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3056d/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allotments for national grants","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"From funds available under subsection (c) for national grants, the Secretary shall allot for public and nonprofit private agency and organization grantees that operate under this subchapter under national grants from the Secretary in each State, an amount that bears the same ratio to such funds as the product of the number of individuals age 55 or older in the State and the allotment percentage of such State bears to the sum of the corresponding products for all States, except as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc63eff5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3056d/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum allotment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No State shall be provided an amount under this subsection that is less than ½ of 1 percent of the amount provided under subsection (c) for public and nonprofit private agency and organization grantees that operate under this subchapter under national grants from the Secretary in all of the States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc63eff6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3056d/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hold harmless","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If such amount provided under subsection (c) is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc63eff7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3056d/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" equal to or less than the amount necessary to maintain the fiscal year 2000 level of activities, allotments for grantees that operate under this subchapter under national grants from the Secretary in each State shall be proportional to the amount necessary to maintain their fiscal year 2000 level of activities; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc63eff8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3056d/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" greater than the amount necessary to maintain the fiscal year 2000 level of activities, no State shall be provided a percentage increase above the amount necessary to maintain the fiscal year 2000 level of activities for grantees that operate under this subchapter under national grants from the Secretary in the State that is less than 30 percent of the percentage increase above the amount necessary to maintain the fiscal year 2000 level of activities for public and private nonprofit agency and organization grantees that operate under this subchapter under national grants from the Secretary in all of the States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc63eff9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3056d/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reduction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Allotments for States not affected by paragraphs (1) and (2)(B) shall be reduced proportionally to satisfy the conditions in such paragraphs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc63effa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3056d/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allotments for grants to States","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"From the amount provided for grants to States under subsection (c), the Secretary shall allot for the State grantee in each State an amount that bears the same ratio to such amount as the product of the number of individuals age 55 or older in the State and the allotment percentage of such State bears to the sum of the corresponding products for all States, except as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc63effb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3056d/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum allotment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No State shall be provided an amount under this subsection that is less than ½ of 1 percent of the amount provided under subsection (c) for State grantees in all of the States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc63effc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3056d/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hold harmless","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If such amount provided under subsection (c) is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc63effd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3056d/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" equal to or less than the amount necessary to maintain the fiscal year 2000 level of activities, allotments for State grantees in each State shall be proportional to the amount necessary to maintain their fiscal year 2000 level of activities; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc63effe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3056d/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" greater than the amount necessary to maintain the fiscal year 2000 level of activities, no State shall be provided a percentage increase above the amount necessary to maintain the fiscal year 2000 level of activities for State grantees in the State that is less than 30 percent of the percentage increase above the amount necessary to maintain the fiscal year 2000 level of activities for State grantees in all of the States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc63efff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3056d/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reduction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Allotments for States not affected by paragraphs (1) and (2)(B) shall be reduced proportionally to satisfy the conditions in such paragraphs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc63f000-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3056d/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allotment percentage","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subsections (d) and (e) and this subsection—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc63f001-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3056d/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the allotment percentage of each State shall be 100 percent less that percentage that bears the same ratio to 50 percent as the per capita income of such State bears to the per capita income of the United States, except that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc63f002-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3056d/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the allotment percentage shall be not more than 75 percent and not less than 33 percent; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc63f003-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3056d/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the allotment percentage for the District of Columbia and the Commonwealth of Puerto Rico shall be 75 percent;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc63f004-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3056d/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of individuals age 55 or older in any State and in all States, and the per capita income in any State and in all States, shall be determined by the Secretary on the basis of the most satisfactory data available to the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc63f005-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3056d/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the purpose of determining the allotment percentage, the term “United States” means the 50 States,","children":[{"tag":"ref","attrib":{"idref":"fn003307"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003307"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The comma probably should not appear."}],"tail":" and the District of Columbia."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc63f006-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3056d/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc63f007-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3056d/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost per authorized position","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “cost per authorized position” means the sum of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc63f008-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3056d/g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the hourly minimum wage rate specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s206/a/1"},"text":"section 206(a)(1) of title 29","children":[],"tail":", multiplied by the number of hours equal to the product of 21 hours and 52 weeks;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc63f009-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3056d/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an amount equal to 11 percent of the amount specified under subparagraph (A), for the purpose of covering Federal payments for fringe benefits; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc63f00a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3056d/g/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an amount determined by the Secretary, for the purpose of covering Federal payments for the remainder of all other program and administrative costs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc63f00b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3056d/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fiscal year 2000 level of activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “fiscal year 2000 level of activities” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc63f00c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3056d/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to public and nonprofit private agency and organization grantees that operate under this subchapter under national grants from the Secretary, their level of activities for fiscal year 2000; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc63f00d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3056d/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to State grantees, their level of activities for fiscal year 2000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc63f00e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3056d/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants to States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “grants to States” means grants made under this subchapter by the Secretary to the States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc63f00f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3056d/g/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Level of activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “level of activities” means the number of authorized positions multiplied by the cost per authorized position.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc63f010-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3056d/g/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “national grants” means grants made under this subchapter by the Secretary to public and nonprofit private agency and organization grantees that operate under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc63f011-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3056d/g/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State” does not include Guam, American Samoa, the Commonwealth of the Northern Mariana Islands, and the United States Virgin Islands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc63f012-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/73/tV/s506"},"text":"Pub. L. 89–73, title V, § 506","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/365/tV/s501"},"text":"Pub. L. 109–365, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2576"},"text":"120 Stat. 2576","child