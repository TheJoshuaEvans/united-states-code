{"tag":"section","attrib":{"id":"idbb92215e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862p–13"},"text":null,"children":[{"tag":"num","attrib":{"value":"1862p–13"},"text":"§ 1862p–13.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tribal colleges and universities program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbb92215f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862p–13/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall continue to support a program to award grants on a competitive, merit-reviewed basis to tribal colleges and universities (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1059c"},"text":"section 1059c of title 20","children":[],"tail":", including institutions described in "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1059d"},"text":"section 1059d of title 20","children":[],"tail":"), to enhance the quality of undergraduate STEM education at such institutions and to increase the retention and graduation rates of Native American students pursuing associate’s or baccalaureate degrees in STEM."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb922160-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862p–13/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program components","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Grants awarded under this section shall support—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb922161-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862p–13/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" activities to improve courses and curriculum in STEM;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb922162-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862p–13/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" faculty development;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb922163-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862p–13/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" stipends for undergraduate students participating in research; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb922164-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862p–13/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other activities consistent with subsection (a), as determined by the Director.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb922165-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862p–13/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Instrumentation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funding provided under this section may be used for laboratory equipment and materials.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb922166-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862p–13/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Awards to broaden Tribal College and University student participation in computer science","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb922167-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862p–13/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director, as part of the program authorized under this section, shall make awards on a competitive, merit-reviewed basis to eligible entities to increase the participation of Tribal populations in computer science and computational thinking education programs to enable students to develop skills and competencies in coding, problem-solving, critical thinking, creativity and collaboration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb922168-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862p–13/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Awards made under this subsection shall support—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbb922169-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862p–13/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" research and development needed to bring computer science and computational thinking courses and degrees to Tribal Colleges or Universities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb92216a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862p–13/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" research and development of instructional materials needed to integrate computer science and computational thinking into programs that are culturally relevant to students attending Tribal Colleges or Universities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb92216b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862p–13/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" research, development and evaluation of distance education for computer science and computational thinking courses and degree programs for students attending Tribal Colleges and Universities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb92216c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862p–13/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other activities consistent with the activities described in paragraphs (1) through (4) of subsection (b), as determined by the Director.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb92216d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862p–13/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Partnerships","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A Tribal College or University seeking an award under this subsection, or consortia thereof, may partner with an institution of higher education or nonprofit organization with demonstrated expertise in academic program development.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb92216e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862p–13/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out this subsection, the Director shall consult and cooperate with the programs and policies of other relevant Federal agencies to avoid duplication with and enhance the effectiveness of the program under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb92216f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862p–13/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to the Director $2,000,000 in each of fiscal years 2023 through 2027 to carry out this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbb922170-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/358/tV/s525"},"text":"Pub. L. 111–358, title V, § 525","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4019"},"text":"124 Stat. 4019","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/tV/s10525/a"},"text":"Pub. L. 117–167, div. B, title V, § 10525(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1625"},"text":"136 Stat. 1625","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbb922171-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbb922172-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbb922173-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the America COMPETES Reauthorization Act of 2010, also known as the America Creating Opportunities to Meaningfully Promote Excellence in Technology, Education, and Science Reauthorization Act of 2010, and also as part of the National Science Foundation Authorization Act of 2010, and not as part of the National Science Foundation Act of 1950 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbb922174-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167"},"text":"Pub. L. 117–167","children":[],"tail":" added subsec. (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbb922175-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idbb922176-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definitions of terms used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/358/s2"},"text":"section 2 of Pub. L. 111–358","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s6621"},"text":"section 6621 of this title","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/111/358/s502"},"text":"section 502 of Pub. L. 111–358","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1862p"},"text":"section 1862p of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
