{"tag":"section","attrib":{"id":"idbc7bbd93-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3336"},"text":null,"children":[{"tag":"num","attrib":{"value":"3336"},"text":"§ 3336.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of grant","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbc7bbd94-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3336/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation; Federal and non-Federal contributions; projects or activities eligible for assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3335"},"text":"section 3335 of this title","children":[],"tail":" shall not exceed (1) 20 per centum of the cost of the project for which the grant is made; nor (2) the Federal grant made with respect to the project under the legislation referred to in paragraph (2) of "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3338"},"text":"section 3338 of this title","children":[],"tail":". In no case shall the total Federal contributions to the cost of such project be more than 80 per centum. Notwithstanding any other provision of law, including requirements with respect to non-Federal contributions, grants under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3335"},"text":"section 3335 of this title","children":[],"tail":" shall be eligible for inclusion (directly or through refunds or credits) as part of the financing for such projects: "},{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That proj­ects or activities on the basis of which assistance is provided under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3305/c"},"text":"section 3305(c) of this title","children":[],"tail":" shall not be eligible for assistance under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3335"},"text":"section 3335 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc7bbd95-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3336/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations; availability of funds for expenditures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated for grants under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3335"},"text":"section 3335 of this title","children":[],"tail":" not to exceed $25,000,000 for the fiscal year ending "},{"tag":"date","attrib":{"date":"1967-06-30"},"text":"June 30, 1967","children":[],"tail":", and not to exceed $50,000,000 for the fiscal year ending "},{"tag":"date","attrib":{"date":"1968-06-30"},"text":"June 30, 1968","children":[],"tail":". Any amounts appropriated under this section shall remain available until expended, and any amounts authorized for any fiscal year under this section but not appropriated may be appropriated for any succeeding fiscal year commencing prior to "},{"tag":"date","attrib":{"date":"1970-07-01"},"text":"July 1, 1970","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc7bbd96-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/754/tII/s206"},"text":"Pub. L. 89–754, title II, § 206","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-11-03"},"text":"Nov. 3, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1264"},"text":"80 Stat. 1264","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/448/tVI/s602/f"},"text":"Pub. L. 90–448, title VI, § 602(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-08-01"},"text":"Aug. 1, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/532"},"text":"82 Stat. 532","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc7bbd97-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc7bbd98-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbc7bbd99-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3305"},"text":"Section 3305 of this title","children":[],"tail":", referred to in subsec. (a), was omitted from the Code pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5316"},"text":"section 5316 of this title","children":[],"tail":", which terminated the authority to make grants and loans under subchapter I of this chapter after "},{"tag":"date","attrib":{"date":"1975-01-01"},"text":"Jan. 1, 1975","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbc7bbd9a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1968—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/448"},"text":"Pub. L. 90–448","children":[],"tail":" permitted any amounts authorized for any fiscal year but not appropriated to be appropriated for any succeeding fiscal year commencing prior to "},{"tag":"date","attrib":{"date":"1970-07-01"},"text":"July 1, 1970","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
