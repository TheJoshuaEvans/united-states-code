{"tag":"section","attrib":{"id":"idb79f142c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s628"},"text":null,"children":[{"tag":"num","attrib":{"value":"628"},"text":"§ 628.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments to Indian tribal organizations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb79f142d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s628/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reservation of funds; direct payments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Out of any amount appropriated pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s625"},"text":"section 625 of this title","children":[],"tail":" for a fiscal year, the Secretary shall reserve 3 percent for grants to Indian tribes and tribal organizations, which shall be paid directly to Indian tribes and tribal organizations with a plan approved under this subpart, in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s629c/a"},"text":"section 629c(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb79f142e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s628/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to streamline reporting requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall, in consultation with the affected Indian tribes, modify any reporting requirement imposed by or under this part on an Indian tribe, tribal organization, or tribal consortium if the total of the amounts allotted to the Indian tribe, tribal organization, or tribal consortium under this part for the fiscal year is not more than $50,000, and in a manner that limits the administrative burden on any tribe to which not more than $50,000 is allotted under this subpart for the fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb79f142f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s628/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tribal authority to substitute the Federal negotiated indirect cost rate for administrative costs cap","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of sections 622(b)(14) and 624(e) of this title, an Indian tribal organization may elect to have the weighted average of the indirect cost rates in effect under part 220 of title 2, Code of Federal Regulations ","children":[{"tag":"ref","attrib":{"idref":"fn002617"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002617"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be followed by a comma."}],"tail":" with respect to the administrative costs of the Indian tribal organization apply in lieu of the percentage specified in each such section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb79f1430-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s628/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Indian tribe” and “tribal organization” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the terms “Indian tribe” and “tribal organization” shall have the meanings given such terms by subsections (e) and (","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":") of "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304"},"text":"section 5304 of title 25","children":[],"tail":", respectively."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb79f1431-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title IV, § 428, as added "},{"tag":"ref","attrib":{"href":"/us/pl/96/272/tI/s103/b"},"text":"Pub. L. 96–272, title I, § 103(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-06-17"},"text":"June 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/520"},"text":"94 Stat. 520","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/66/tXIII/s13711/b/3"},"text":"Pub. L. 103–66, title XIII, § 13711(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-10"},"text":"Aug. 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/655"},"text":"107 Stat. 655","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/193/tIII/s375/d"},"text":"Pub. L. 104–193, title III, § 375(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-22"},"text":"Aug. 22, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2257"},"text":"110 Stat. 2257","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/288/s6/f/1"},"text":"Pub. L. 109–288, § 6(f)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-09-28"},"text":"Sept. 28, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1247"},"text":"120 Stat. 1247","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/258/tI/s107/a/1/A"},"text":"Pub. L. 118–258, title I, § 107(a)(1)(A)","children":[],"tail":", (C), (3)(A), "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2953-2955"},"text":"138 Stat. 2953–2955","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb79f1432-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb79f1433-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb79f1434-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/258/s107/a/1/A"},"text":"Pub. L. 118–258, § 107(a)(1)(A)","children":[],"tail":", (3)(A), added subsecs. (a) and (b) and struck out former subsecs. (a) and (b) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(a) The Secretary may, in appropriate cases (as determined by the Secretary) make payments under this subpart directly to an Indian tribal organization within any State which has a plan for child welfare services approved under this subpart. Such payments shall be made in such manner and in such amounts as the Secretary determines to be appropriate.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(b) Amounts paid under subsection (a) shall be deemed to be a part of the allotment (as determined under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s623"},"text":"section 623 of this title","children":[],"tail":") for the State in which such Indian tribal organization is located.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/258/s107/a/3/A"},"text":"Pub. L. 118–258, § 107(a)(3)(A)","children":[],"tail":", added subsec. (c). Former subsec. (c) redesignated (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/258/s107/a/1/C"},"text":"Pub. L. 118–258, § 107(a)(1)(C)","children":[],"tail":", made technical amendment to reference in original act which appears in text as reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304"},"text":"section 5304 of title 25","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/258/s107/a/3/A"},"text":"Pub. L. 118–258, § 107(a)(3)(A)","children":[],"tail":", redesignated subsec. (c) as (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/288"},"text":"Pub. L. 109–288","children":[],"tail":" substituted “section 623” for “section 621”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/193"},"text":"Pub. L. 104–193","children":[],"tail":" amended subsec. (c) generally. Prior to amendment, subsec. (c) read as follows: “For purposes of this section—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) the term ‘tribal organization’ means the recognized governing body of any Indian tribe, or any legally established organization of Indians which is controlled, sanctioned, or chartered by such governing body; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) the term ‘Indian tribe’ means any tribe, band, nation, or other organized group or community of Indians (including any Alaska Native village or regional or village corporation as defined in or established pursuant to the Alaska Native Claims Settlement Act (","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/203"},"text":"Public Law 92–203","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/85/688"},"text":"85 Stat. 688","children":[],"tail":")) which (A) is recognized as eligible for the special programs and services provided by the United States to Indians because of their status as Indians, or (B) is located on, or in proximity to, a Federal or State reservation or rancheria.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/66"},"text":"Pub. L. 103–66","children":[],"tail":" substituted “under this subpart” for “under this part” in two places."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb79f1435-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb79f1436-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2025 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/258"},"text":"Pub. L. 118–258","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2025-10-01"},"text":"Oct. 1, 2025","children":[],"tail":", and applicable to payments under this part for calendar quarters beginning on or after such date, with delay permitted if either State legislation or tribal action is required to meet additional requirements, see "},{"tag":"ref","attrib":{"href":"/us/pl/118/258/s117"},"text":"section 117 of Pub. L. 118–258","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s622"},"text":"section 622 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb79f1437-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2006 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/288"},"text":"Pub. L. 109–288","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2006-10-01"},"text":"Oct. 1, 2006","children":[],"tail":", and applicable to payments under this part and part E of this subchapter for calendar quarters beginning on or after such date, without regard to whether implementing regulations have been promulgated, and with delay permitted if State legislation is required to meet additional requirements, see section 12(a), (b) of "},{"tag":"ref","attrib":{"href":"/us/pl/109/288"},"text":"Pub. L. 109–288","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s621"},"text":"section 621 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb79f1438-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For effective date of amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/193"},"text":"Pub. L. 104–193","children":[],"tail":", see section 395(a)–(c) of "},{"tag":"ref","attrib":{"href":"/us/pl/104/193"},"text":"Pub. L. 104–193","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s654"},"text":"section 654 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb79f1439-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1993 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/66"},"text":"Pub. L. 103–66","children":[],"tail":" effective with respect to calendar quarters beginning on or after "},{"tag":"date","attrib":{"date":"1993-10-01"},"text":"Oct. 1, 1993","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/66/s13711/c"},"text":"section 13711(c) of Pub. L. 103–66","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s622"},"text":"section 622 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
