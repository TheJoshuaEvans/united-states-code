{"tag":"section","attrib":{"id":"idc02c1bce-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17191"},"text":null,"children":[{"tag":"num","attrib":{"value":"17191"},"text":"§ 17191.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this part:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc02c1bcf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17191/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Engineered","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"When referring to enhanced geothermal systems, the term “engineered” means designed to access subsurface heat, including stimulation and nonstimulation technologies to address one or more of the following issues:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc02c1bd0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17191/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Lack of effective permeability, porosity or open fracture connectivity within the heat reservoir.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02c1bd1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17191/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Insufficient contained geofluid in the heat reservoir.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02c1bd2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17191/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A low average geothermal gradient which necessitates deeper drilling, or the use of alternative heat sources or heat generation processes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02c1bd3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17191/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible entity” means any of the following entities:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc02c1bd4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17191/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An institution of higher education.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02c1bd5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17191/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A National laboratory.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02c1bd6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17191/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A Federal research agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02c1bd7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17191/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A State research agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02c1bd8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17191/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A nonprofit research organization.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02c1bd9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17191/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An industrial entity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02c1bda-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17191/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A consortium of 2 or more entities described in subparagraphs (A) through (F).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02c1bdb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17191/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enhanced geothermal systems","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “enhanced geothermal systems” means geothermal reservoir systems that are engineered, as opposed to occurring naturally.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02c1bdc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17191/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Geofluid","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “geofluid” means any fluid used to extract thermal energy from the Earth which is transported to the surface for direct use or electric power generation, except that such term shall not include oil or natural gas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02c1bdd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17191/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Geopressured resources","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “geopressured resources” mean geothermal deposits found in sedimentary rocks under higher than normal pressure and saturated with gas or methane.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02c1bde-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17191/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Geothermal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “geothermal” refers to heat energy stored in the Earth’s crust that can be accessed for direct use or electric power generation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02c1bdf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17191/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hydrothermal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “hydrothermal” refers to naturally occurring subsurface reservoirs of hot water or steam.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02c1be0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17191/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Systems approach","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “systems approach” means an approach to solving problems or designing systems that attempts to optimize the performance of the overall system, rather than a particular component of the system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc02c1be1-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/tVI/s612"},"text":"Pub. L. 110–140, title VI, § 612","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1679"},"text":"121 Stat. 1679","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dZ/tIII/s3002/a"},"text":"Pub. L. 116–260, div. Z, title III, § 3002(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2487"},"text":"134 Stat. 2487","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc02c1be2-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc02c1be3-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc02c1be4-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s3002/a"},"text":"Pub. L. 116–260, § 3002(a)","children":[],"tail":", amended par. (1) generally. Prior to amendment, par. (1) defined the term “engineered”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (2) to (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s3002/a/2"},"text":"Pub. L. 116–260, § 3002(a)(2)","children":[],"tail":", (3), added par. (2) and redesignated former pars. (2) to (7) as (3) to (8), respectively."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc02c1be5-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc02c1be6-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the date that is 1 day after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/s1601"},"text":"section 1601 of Pub. L. 110–140","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1824"},"text":"section 1824 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"idc02c1be7-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This part known as the “Advanced Geothermal Energy Research and Development Act of 2007”, see Short Title note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s17001"},"text":"section 17001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
