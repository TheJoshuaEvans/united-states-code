{"tag":"section","attrib":{"id":"idbef87d44-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9852c"},"text":null,"children":[{"tag":"num","attrib":{"value":"9852c"},"text":"§ 9852c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General provisions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbef87d45-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9852c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subchapter shall be construed to authorize or permit the Secretary or any employee or contractor of the Department of Health and Human Services to mandate, direct, or control, the selection of a curriculum, a program of instruction, or instructional materials, for a Head Start program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbef87d46-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9852c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subchapter shall be construed to authorize a Head Start program or a local educational agency to require the other to select or implement a specific curriculum or program of instruction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbef87d47-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9852c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this subchapter, the term “health”, when used to refer to services or care provided to enrolled children, their parents, or their siblings, shall be interpreted to refer to both physical and mental health.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbef87d48-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35/tVI/s657C"},"text":"Pub. L. 97–35, title VI, § 657C","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/134/s27"},"text":"Pub. L. 110–134, § 27","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-12"},"text":"Dec. 12, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1448"},"text":"121 Stat. 1448","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
