{"tag":"section","attrib":{"id":"idc027611d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113b"},"text":null,"children":[{"tag":"num","attrib":{"value":"17113b"},"text":"§ 17113b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advanced industrial facilities deployment program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc027611e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of Clean Energy Demonstrations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to amounts otherwise available, there is appropriated to the Secretary, acting through the Office of Clean Energy Demonstrations, for fiscal year 2022, out of any money in the Treasury not otherwise appropriated, $5,812,000,000, to remain available through ","children":[{"tag":"date","attrib":{"date":"2026-09-30"},"text":"September 30, 2026","children":[],"tail":", to carry out this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc027611f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial assistance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall use funds appropriated by subsection (a) to provide financial assistance, on a competitive basis, to eligible entities to carry out projects for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0276120-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the purchase and installation, or implementation, of advanced industrial technology at an eligible facility;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0276121-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" retrofits, upgrades to, or operational improvements at an eligible facility to install or implement advanced industrial technology; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0276122-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113b/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" engineering studies and other work needed to prepare an eligible facility for activities described in paragraph (1) or (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0276123-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be eligible to receive financial assistance under subsection (b), an eligible entity shall submit to the Secretary an application at such time, in such manner, and containing such information as the Secretary may require, including the expected greenhouse gas emissions reductions to be achieved by carrying out the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0276124-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In providing financial assistance under subsection (b), the Secretary shall give priority consideration to projects on the basis of, as determined by the Secretary—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0276125-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113b/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the expected greenhouse gas emissions reductions to be achieved by carrying out the project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0276126-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113b/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which the project would provide the greatest benefit for the greatest number of people within the area in which the eligible facility is located; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0276127-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113b/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether the eligible entity participates or would participate in a partnership with purchasers of the output of the eligible facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0276128-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113b/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall require an eligible entity to provide not less than 50 percent of the cost of a project carried out pursuant to this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0276129-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113b/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall reserve not more than $300,000,000 of amounts made available under subsection (a) for administrative costs of carrying out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc027612a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113b/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc027612b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113b/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advanced industrial technology","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “advanced industrial technology” means a technology directly involved in an industrial process, as described in any of paragraphs (1) through (6) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s17113/c"},"text":"section 17113(c) of this title","children":[],"tail":", and designed to accelerate greenhouse gas emissions reduction progress to net-zero at an eligible facility, as determined by the Secretary."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc027612c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113b/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “eligible entity” means the owner or operator of an eligible facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc027612d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113b/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible facility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “eligible facility” means a domestic, non-Federal, nonpower industrial or manufacturing facility engaged in energy-intensive industrial processes, including production processes for iron, steel, steel mill products, aluminum, cement, concrete, glass, pulp, paper, industrial ceramics, chemicals, and other energy intensive industrial processes, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc027612e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113b/g/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “financial assistance” means a grant, rebate, direct loan, or cooperative agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc027612f-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/169/tV/s50161"},"text":"Pub. L. 117–169, title V, § 50161","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-16"},"text":"Aug. 16, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2049"},"text":"136 Stat. 2049","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc0276130-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc0276131-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idc0276132-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/169"},"text":"Pub. L. 117–169","children":[],"tail":", and not as part of the Energy Independence and Security Act of 2007 which comprises this chapter."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc0276133-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idc0276134-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/169/tV/s50111"},"text":"Pub. L. 117–169, title V, § 50111","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-16"},"text":"Aug. 16, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2033"},"text":"136 Stat. 2033","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/169/tV/s50111"},"text":"\n","children":[{"tag":"p","attrib":{},"text":"“In this subtitle [subtitle A (§§ 50111–50173) of title V of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/169"},"text":"Pub. L. 117–169","children":[],"tail":", enacting this section, sections 16517, 18715 to 18715b, and 18795 to 18795b of this title, and amending sections 16511, 16512, and 17013 of this title and "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s3502"},"text":"section 3502 of Title 25","children":[],"tail":", Indians]:"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Greenhouse gas","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘greenhouse gas’ has the meaning given the term in section 1610(a) of the Energy Policy Act of 1992 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s13389/a"},"text":"42 U.S.C. 13389(a)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Secretary","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘Secretary’ means the Secretary of Energy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"State","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘State’ means a State, the District of Columbia, and a United States Insular Area (as that term is defined in section 50211 [of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/169"},"text":"Pub. L. 117–169","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s3006"},"text":"43 U.S.C. 3006","children":[],"tail":" note])."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"State energy office","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘State energy office’ has the meaning given the term in section 124(a) of the Energy Policy Act of 2005 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s15821/a"},"text":"42 U.S.C. 15821(a)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"State energy program","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘State Energy Program’ means the State Energy Program established pursuant to part D of title III of the Energy Policy and Conservation Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6321"},"text":"42 U.S.C. 6321","children":[],"tail":" through 6326).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
