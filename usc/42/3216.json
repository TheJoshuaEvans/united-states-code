{"tag":"section","attrib":{"id":"idbc7973ad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3216"},"text":null,"children":[{"tag":"num","attrib":{"value":"3216"},"text":"§ 3216.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employment of expediters and administrative employees","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Assistance shall not be provided by the Secretary under this chapter to any business unless the owners, partners, or officers of the business—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc7973ae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3216/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" certify to the Secretary the names of any attorneys, agents, and other persons engaged by or on behalf of the business for the purpose of expediting applications made to the Secretary for assistance of any kind, under this chapter, and the fees paid or to be paid to the person for expediting the applications; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc7973af-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3216/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" execute an agreement binding the business, for the 2-year period beginning on the date on which the assistance is provided by the Secretary to the business, to refrain from employing, offering any office or employment to, or retaining for professional services, any person who, on the date on which the assistance or any part of the assistance was provided, or within the 1-year period ending on that date—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc7973b0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3216/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" served as an officer, attorney, agent, or employee of the Department; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc7973b1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3216/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" occupied a position or engaged in activities that the Secretary determines involved discretion with respect to the granting of assistance under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc7973b2-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/136/tVI/s606"},"text":"Pub. L. 89–136, title VI, § 606","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/393/tI/s102/a"},"text":"Pub. L. 105–393, title I, § 102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3615"},"text":"112 Stat. 3615","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc7973b3-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc7973b4-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbc7973b5-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 3216, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/136/tVII/s706"},"text":"Pub. L. 89–136, title VII, § 706","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-08-26"},"text":"Aug. 26, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/573"},"text":"79 Stat. 573","children":[],"tail":", defined terms as used in this chapter, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/105/393/s102/b/3"},"text":"Pub. L. 105–393, § 102(b)(3)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbc7973b6-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbc7973b7-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1999-02-11"},"text":"Feb. 11, 1999","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/393/s105"},"text":"section 105 of Pub. L. 105–393","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3121"},"text":"section 3121 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
