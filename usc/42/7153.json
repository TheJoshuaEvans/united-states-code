{"tag":"section","attrib":{"id":"idbdf6eb3b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7153"},"text":null,"children":[{"tag":"num","attrib":{"value":"7153"},"text":"§ 7153.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration of leasing transfers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbdf6eb3c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7153/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority retained by Secretary of the Interior","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior shall retain any authorities not transferred under section 7152(b) ","children":[{"tag":"ref","attrib":{"idref":"fn003563"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003563"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title and shall be solely responsible for the issuance and supervision of Federal leases and the enforcement of all regulations applicable to the leasing of mineral resources, including but not limited to lease terms and conditions and production rates. No regulation promulgated by the Secretary shall restrict or limit any authority retained by the Secretary of the Interior under section 7152(b) "},{"tag":"ref","attrib":{"idref":"fn003563"},"text":"1","children":[],"tail":" of this title with respect to the issuance or supervision of Federal leases. Nothing in section 7152(b) "},{"tag":"ref","attrib":{"idref":"fn003563"},"text":"1","children":[],"tail":" of this title shall be construed to affect Indian lands and resources or to transfer any functions of the Secretary of the Interior concerning such lands and resources."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdf6eb3d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7153/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation with Secretary of the Interior with respect to promulgation of regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In exercising the authority under section 7152(b) ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of this title to promulgate regulations, the Secretary shall consult with the Secretary of the Interior during the preparation of such regulations and shall afford the Secretary of the Interior not less than thirty days, prior to the date on which the Department first publishes or otherwise prescribes regulations, to comment on the content and effect of such regulations."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdf6eb3e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7153/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repealed. ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/100/tII/s201"},"text":"Pub. L. 97–100, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-12-23"},"text":"Dec. 23, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1407"},"text":"95 Stat. 1407","children":[],"tail":null}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdf6eb3f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7153/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preparation of environmental impact statement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Department of the Interior shall be the lead agency for the purpose of preparation of an environmental impact statement required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4332/2/C"},"text":"section 4332(2)(C) of this title","children":[],"tail":" for any action with respect to the Federal leases taken under the authority of this section, unless the action involves only matters within the exclusive authority of the Secretary."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbdf6eb40-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/91/tIII/s303"},"text":"Pub. L. 95–91, title III, § 303","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-08-04"},"text":"Aug. 4, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/579"},"text":"91 Stat. 579","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/100/tII/s201"},"text":"Pub. L. 97–100, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-12-23"},"text":"Dec. 23, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1407"},"text":"95 Stat. 1407","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbdf6eb41-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbdf6eb42-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbdf6eb43-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7152/b"},"text":"Section 7152(b) of this title","children":[],"tail":", referred to in subsecs. (a) and (b), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/97/100/tII/s201"},"text":"Pub. L. 97–100, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-12-23"},"text":"Dec. 23, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1407"},"text":"95 Stat. 1407","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbdf6eb44-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1981—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/100"},"text":"Pub. L. 97–100","children":[],"tail":" struck out subsec. (c) which afforded the Secretary of Energy the opportunity to disapprove any terms and conditions on which the Secretary of the Interior proposed to issue a Federal lease."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
