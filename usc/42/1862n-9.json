{"tag":"section","attrib":{"id":"idbb8d6688-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862n–9"},"text":null,"children":[{"tag":"num","attrib":{"value":"1862n–9"},"text":"§ 1862n–9.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Astronomy and Astrophysics Advisory Committee","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbb8d6689-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862n–9/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Foundation, the National Aeronautics and Space Administration, and the Department of Energy shall jointly establish an Astronomy and Astrophysics Advisory Committee (in this section referred to as the “Advisory Committee”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb8d668a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862n–9/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Advisory Committee shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb8d668b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862n–9/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assess, and make recommendations regarding, the coordination of astronomy and astrophysics programs of the Foundation, the National Aeronautics and Space Administration, and the Department of Energy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb8d668c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862n–9/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assess, and make recommendations regarding, the status of the activities of the Foundation, the National Aeronautics and Space Administration, and the Department of Energy as they relate to the recommendations contained in the National Research Council’s 2001 report entitled “Astronomy and Astrophysics in the New Millennium”, and the recommendations contained in subsequent National Research Council reports of a similar nature; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb8faf7d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862n–9/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than March 15 of each year, transmit a report to the Director, the Administrator of the National Aeronautics and Space Administration, the Secretary of Energy, the Committee on Science of the House of Representatives, the Committee on Commerce, Science, and Transportation of the Senate, and the Committee on Health, Education, Labor, and Pensions of the Senate on the Advisory Committee’s findings and recommendations under paragraphs (1) and (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb8faf7e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862n–9/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Advisory Committee shall consist of 13 members, none of whom shall be a Federal employee, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb8faf7f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862n–9/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 4 members selected by the Director;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb8faf80-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862n–9/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 4 members selected by the Administrator of the National Aeronautics and Space Administration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb8faf81-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862n–9/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 3 members selected by the Secretary of Energy; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb8faf82-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862n–9/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 2 members selected by the Director of the Office of Science and Technology Policy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb8faf83-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862n–9/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection process","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Initial selections under subsection (c) shall be made within 3 months after ","children":[{"tag":"date","attrib":{"date":"2002-12-19"},"text":"December 19, 2002","children":[],"tail":". Vacancies shall be filled in the same manner as provided in subsection (c)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb8faf84-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862n–9/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chairperson","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Advisory Committee shall select a chairperson from among its members.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb8faf85-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862n–9/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Advisory Committee shall coordinate with other Federal advisory committees that advise Federal agencies that engage in related research activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb8faf86-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862n–9/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The members of the Advisory Committee shall serve without compensation, but shall receive travel expenses, including per diem in lieu of subsistence, in accordance with sections 5702 and 5703 of title 5.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb8faf87-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862n–9/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Advisory Committee shall convene, in person or by electronic means, at least 4 times a year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb8faf88-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862n–9/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quorum","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A majority of the members serving on the Advisory Committee shall constitute a quorum for purposes of conducting the business of the Advisory Committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb8faf89-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862n–9/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s1013"},"text":"Section 1013 of title 5","children":[],"tail":" shall not apply to the Advisory Committee."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbb8faf8a-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/368/s23"},"text":"Pub. L. 107–368, § 23","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-19"},"text":"Dec. 19, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/3065"},"text":"116 Stat. 3065","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/423/s5/a"},"text":"Pub. L. 108–423, § 5(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-11-30"},"text":"Nov. 30, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2402"},"text":"118 Stat. 2402","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/258"},"text":"Pub. L. 117–286, § 4(a)(258)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4334"},"text":"136 Stat. 4334","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbb8faf8b-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbb8faf8c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbb8faf8d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the National Science Foundation Authorization Act of 2002, and not as part of the National Science Foundation Act of 1950 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbb8faf8e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (j). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":" substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t5/s1013"},"text":"Section 1013 of title 5","children":[],"tail":"” for “Section 14 of the Federal Advisory Committee Act”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsecs. (a), (b)(1), (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/423/s5/a/1"},"text":"Pub. L. 108–423, § 5(a)(1)","children":[],"tail":", substituted “, the National Aeronautics and Space Administration, and the Department of Energy” for “and the National Aeronautics and Space Administration”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/423/s5/a/2"},"text":"Pub. L. 108–423, § 5(a)(2)","children":[],"tail":", substituted “Administration, the Secretary of Energy,” for “Administration, and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1), (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/423/s5/a/3/A"},"text":"Pub. L. 108–423, § 5(a)(3)(A)","children":[],"tail":", substituted “4” for “5”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3), (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/423/s5/a/3/B"},"text":"Pub. L. 108–423, § 5(a)(3)(B)","children":[],"tail":"–(D), added par. (3) and redesignated former par. (3) as (4) and substituted “2” for “3”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/423/s5/a/4"},"text":"Pub. L. 108–423, § 5(a)(4)","children":[],"tail":", substituted “other Federal advisory committees that advise Federal agencies that engage in related research activities” for “the advisory bodies of other Federal agencies, such as the Department of Energy, which may engage in related research activities”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbb8faf8f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idbb8faf90-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Science of House of Representatives changed to Committee on Science and Technology of House of Representatives by House Resolution No. 6, One Hundred Tenth Congress, ","children":[{"tag":"date","attrib":{"date":"2007-01-05"},"text":"Jan. 5, 2007","children":[],"tail":". Committee on Science and Technology of House of Representatives changed to Committee on Science, Space, and Technology of House of Representatives by House Resolution No. 5, One Hundred Twelfth Congress, "},{"tag":"date","attrib":{"date":"2011-01-05"},"text":"Jan. 5, 2011","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbb8faf91-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2004 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/423/s5/b"},"text":"Pub. L. 108–423, § 5(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-11-30"},"text":"Nov. 30, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2402"},"text":"118 Stat. 2402","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/423/s5/b"},"text":"“The amendments made by subsection (a) [amending this section] take effect on ","children":[{"tag":"date","attrib":{"date":"2005-03-15"},"text":"March 15, 2005","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idbb8faf92-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definitions of terms used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/368/s4"},"text":"section 4 of Pub. L. 107–368","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1862n"},"text":"section 1862n of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
