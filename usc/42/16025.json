{"tag":"section","attrib":{"id":"idbfee2955-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16025"},"text":null,"children":[{"tag":"num","attrib":{"value":"16025"},"text":"§ 16025.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Project timelines and authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfee2956-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16025/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Target date to complete the first project phase","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2011-09-30"},"text":"September 30, 2011","children":[],"tail":", the Secretary shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfee2957-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16025/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" select the technology to be used by the Project for high-temperature hydrogen production and the initial design parameters for the prototype nuclear plant; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfee2958-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16025/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit to Congress a report establishing an alternative date for making the selection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfee2959-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16025/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Design competition for second project phase","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfee295a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16025/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Idaho National Laboratory, shall fund not more than 4 teams for not more than 2 years to develop detailed proposals for competitive evaluation and selection of a single proposal for a final design of the prototype nuclear reactor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfee295b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16025/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Systems integration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may structure Project activities in the second project phase to use the lead industrial partner of the competitively selected design under paragraph (1) in a systems integration role for final design and construction of the Project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff0714c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16025/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Target date to complete project construction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2021-09-30"},"text":"September 30, 2021","children":[],"tail":", the Secretary shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbff0714d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16025/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" complete construction and begin operations of the prototype nuclear reactor and associated energy or hydrogen facilities; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff0714e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16025/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit to Congress a report establishing an alternative date for completion.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff0714f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16025/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is authorized to be appropriated to the Secretary for research and construction activities under this part (including for transfer to the Nuclear Regulatory Commission for activities under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16024"},"text":"section 16024 of this title","children":[],"tail":" as appropriate)—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbff07150-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16025/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $1,250,000,000 for the period of fiscal years 2006 through 2015; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff07151-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16025/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such sums as are necessary for each of fiscal years 2016 through 2021.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbff07152-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tVI/s645"},"text":"Pub. L. 109–58, title VI, § 645","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/798"},"text":"119 Stat. 798","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
