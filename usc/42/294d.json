dren":[],"tail":"; amended "},{"tag":"date","attrib":{"date":"1965-10-22"},"text":"Oct. 22, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/89/290/s4/e"},"text":"Pub. L. 89–290, § 4(e)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/1057"},"text":"79 Stat. 1057","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1966-11-03"},"text":"Nov. 3, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/89/751/s5/a"},"text":"Pub. L. 89–751, § 5(a)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1230"},"text":"80 Stat. 1230","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1968-08-16"},"text":"Aug. 16, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/90/490/tI/s121/d"},"text":"Pub. L. 90–490, title I, § 121(d)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/778"},"text":"82 Stat. 778","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1971-07-09"},"text":"July 9, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/92/52/s1/c"},"text":"Pub. L. 92–52, § 1(c)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/144"},"text":"85 Stat. 144","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1971-11-18"},"text":"Nov. 18, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/92/157/tI/s105/e/3"},"text":"Pub. L. 92–157, title I, § 105(e)(3)","children":[],"tail":", (f)(2), "},{"tag":"ref","attrib":{"href":"/us/stat/85/451"},"text":"85 Stat. 451","children":[],"tail":", provided for loans to schools to capitalize health professions student loan funds, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/94/484/tIV/s406/a/1"},"text":"Pub. L. 94–484, title IV, § 406(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-12"},"text":"Oct. 12, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2268"},"text":"90 Stat. 2268","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb5deed9f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—Subsec. (b)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/136"},"text":"Pub. L. 116–136","children":[],"tail":" substituted “innovative or evidence-based” for “new and innovative”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
