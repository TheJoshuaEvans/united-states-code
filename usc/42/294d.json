{"tag":"section","attrib":{"id":"idb5deed84-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294d"},"text":null,"children":[{"tag":"num","attrib":{"value":"294d"},"text":"§ 294d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quentin N. Burdick program for rural interdisciplinary training","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5deed85-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may make grants or contracts under this section to help entities fund authorized activities under an application approved under subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5deed86-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of amounts","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5deed87-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294d/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Amounts provided under subsection (a) shall be used by the recipients to fund interdisciplinary training projects designed to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5deed88-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294d/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use innovative or evidence-based methods to train health care practitioners to provide services in rural areas;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5deed89-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294d/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrate and evaluate innovative interdisciplinary methods and models designed to provide access to cost-effective comprehensive health care;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5deed8a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294d/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deliver health care services to individuals residing in rural areas;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5deed8b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294d/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhance the amount of relevant research conducted concerning health care issues in rural areas; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5deed8c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294d/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase the recruitment and retention of health care practitioners from rural areas and make rural practice a more attractive career choice for health care practitioners.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5deed8d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294d/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Methods","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A recipient of funds under subsection (a) may use various methods in carrying out the projects described in paragraph (1), including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5deed8e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294d/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the distribution of stipends to students of eligible applicants;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5deed8f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294d/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the establishment of a post-doctoral fellowship program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5deed90-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294d/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the training of faculty in the economic and logistical problems confronting rural health care delivery systems; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5deed91-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294d/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the purchase or rental of transportation and telecommunication equipment where the need for such equipment due to unique characteristics of the rural area is demonstrated by the recipient.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5deed92-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294d/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5deed93-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294d/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An applicant shall not use more than 10 percent of the funds made available to such applicant under subsection (a) for administrative expenses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5deed94-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294d/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not more than 10 percent of the individuals receiving training with funds made available to an applicant under subsection (a) shall be trained as doctors of medicine or doctors of osteopathy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5deed95-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294d/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An institution that receives a grant under this section shall use amounts received under such grant to supplement, not supplant, amounts made available by such institution for activities of the type described in subsection (b)(1) in the fiscal year preceding the year for which the grant is received.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5deed96-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294d/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Applications submitted for assistance under this section shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5deed97-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294d/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be jointly submitted by at least two eligible applicants with the express purpose of assisting individuals in academic institutions in establishing long-term collaborative relationships with health care providers in rural areas; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5deed98-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294d/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designate a rural health care agency or agencies for clinical treatment or training, including hospitals, community health centers, migrant health centers, rural health clinics, community behavioral and mental health centers, long-term care facilities, Native Hawaiian health centers, or facilities operated by the Indian Health Service or an Indian tribe or tribal organization or Indian organization under a contract with the Indian Health Service under the Indian Self-Determination Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5321"},"text":"25 U.S.C. 5321","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5deed99-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294d/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purposes of this section, the term “rural” means geographic areas that are located outside of standard metropolitan statistical areas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5deed9a-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title VII, § 754, as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/392/tI/s103"},"text":"Pub. L. 105–392, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3547"},"text":"112 Stat. 3547","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/136/dA/tIII/s3401/7"},"text":"Pub. L. 116–136, div. A, title III, § 3401(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-03-27"},"text":"Mar. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/386"},"text":"134 Stat. 386","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb5deed9b-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb5deed9c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb5deed9d-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Indian Self-Determination Act, referred to in subsec. (c)(2), is title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/638"},"text":"Pub. L. 93–638","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-04"},"text":"Jan. 4, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2206"},"text":"88 Stat. 2206","children":[],"tail":", which is classified principally to subchapter I (§ 5321 et seq.) of chapter 46 of Title 25, Indians. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5301"},"text":"section 5301 of Title 25","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb5deed9e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 294d, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373/tVII/s766"},"text":"act July 1, 1944, ch. 373, title VII, § 766","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/408/tI/s102"},"text":"Pub. L. 102–408, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-13"},"text":"Oct. 13, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2047"},"text":"106 Stat. 2047","children":[],"tail":", authorized grants and contracts for development of advanced training of allied health professionals, prior to the general amendment of this part by "},{"tag":"ref","attrib":{"href":"/us/pl/105/392"},"text":"Pub. L. 105–392","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 294d, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373/tVII/s731"},"text":"act July 1, 1944, ch. 373, title VII, § 731","children":[],"tail":", as added "},{"tag":"date","attrib":{"date":"1976-10-12"},"text":"Oct. 12, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/94/484/tIV/s401/b/3"},"text":"Pub. L. 94–484, title IV, § 401(b)(3)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2258"},"text":"90 Stat. 2258","children":[],"tail":"; amended "},{"tag":"date","attrib":{"date":"1977-08-01"},"text":"Aug. 1, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/95/83/tIII/s307/c/1"},"text":"Pub. L. 95–83, title III, § 307(c)(1)","children":[],"tail":", (2), "},{"tag":"ref","attrib":{"href":"/us/stat/91/389"},"text":"91 Stat. 389","children":[],"tail":", 390; "},{"tag":"date","attrib":{"date":"1977-12-19"},"text":"Dec. 19, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/95/215/s4/a"},"text":"Pub. L. 95–215, § 4(a)","children":[],"tail":"–(d), (e)(6), "},{"tag":"ref","attrib":{"href":"/us/stat/91/1505"},"text":"91 Stat. 1505","children":[],"tail":", 1506; "},{"tag":"date","attrib":{"date":"1980-12-17"},"text":"Dec. 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/96/538/tIV/s402"},"text":"Pub. L. 96–538, title IV, § 402","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3192"},"text":"94 Stat. 3192","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tXXVII/s2728"},"text":"Pub. L. 97–35, title XXVII, § 2728","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/918"},"text":"95 Stat. 918","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1985-10-22"},"text":"Oct. 22, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/99/129/tII"},"text":"Pub. L. 99–129, title II","children":[],"tail":", §§ 20