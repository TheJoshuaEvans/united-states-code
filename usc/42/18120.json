{"tag":"section","attrib":{"id":"idc0524094-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18120"},"text":null,"children":[{"tag":"num","attrib":{"value":"18120"},"text":"§ 18120.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of the Patient Protection and Affordable Care Act, nothing in such Act (or an amendment made by such Act) shall be construed to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0524095-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18120/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prohibit (or authorize the Secretary of Health and Human Services to promulgate regulations that prohibit) a group health plan or health insurance issuer from carrying out utilization management techniques that are commonly used as of ","children":[{"tag":"date","attrib":{"date":"2010-03-23"},"text":"March 23, 2010","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0524096-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18120/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" restrict the application of the amendments made by this subtitle.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc0524097-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/tI/s1563/d"},"text":"Pub. L. 111–148, title I, § 1563(d)","children":[],"tail":", formerly § 1562(d), title X, § 10107(b)(1), "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/269"},"text":"124 Stat. 269","children":[],"tail":", 911.)"}],"tail":"\n"},{