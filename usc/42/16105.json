{"tag":"section","attrib":{"id":"idbff2e338-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16105"},"text":null,"children":[{"tag":"num","attrib":{"value":"16105"},"text":"§ 16105.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Biodiesel engine testing program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbff2e339-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16105/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later that ","children":[{"tag":"ref","attrib":{"idref":"fn004208"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004208"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “than”."}],"tail":" 180 days after "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":", the Secretary shall initiate a partnership with diesel engine, diesel fuel injection system, and diesel vehicle manufacturers and diesel and biodiesel fuel providers, to include biodiesel testing in advanced diesel engine and fuel system technology."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff2e33a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16105/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scope","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The program shall provide for testing to determine the impact of biodiesel from different sources on current and future emission control technologies, with emphasis on—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbff2e33b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16105/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the impact of biodiesel on emissions warranty, in-use liability, and antitampering provisions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff2e33c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16105/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the impact of long-term use of biodiesel on engine operations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff2e33d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16105/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the options for optimizing these technologies for both emissions and performance when switching between biodiesel and diesel fuel; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff2e33e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16105/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the impact of using biodiesel in these fueling systems and engines when used as a blend with 2006 Environmental Protection Agency-mandated diesel fuel containing a maximum of 15-parts-per-million sulfur content.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff2e33f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16105/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":", the Secretary shall provide an interim report to Congress on the findings of the program, including a comprehensive analysis of impacts from biodiesel on engine operation for both existing and expected future diesel technologies, and recommendations for ensuring optimal emissions reductions and engine performance with biodiesel."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff2e340-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16105/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated $5,000,000 for each of fiscal years 2006 through 2010 to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff2e341-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16105/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “biodiesel” means a diesel fuel substitute produced from nonpetroleum renewable resources that meets the registration requirements for fuels and fuel additives established by the Environmental Protection Agency under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7545"},"text":"section 7545 of this title","children":[],"tail":" and that meets the American Society for Testing and Materials D6751–02a Standard Specification for Biodiesel Fuel (B100) Blend Stock for Distillate Fuels."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbff2e342-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tVII/s757"},"text":"Pub. L. 109–58, title VII, § 757","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/832"},"text":"119 Stat. 832","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
