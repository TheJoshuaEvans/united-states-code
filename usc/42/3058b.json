{"tag":"section","attrib":{"id":"idbc68aae2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058b"},"text":null,"children":[{"tag":"num","attrib":{"value":"3058b"},"text":"§ 3058b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allotment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbc68aae3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc68aae4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Population","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out the program described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3058"},"text":"section 3058 of this title","children":[],"tail":", the Assistant Secretary shall initially allot to each State, from the funds appropriated under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3058a"},"text":"section 3058a of this title","children":[],"tail":" for each fiscal year, an amount that bears the same ratio to the funds as the population of older individuals in the State bears to the population of older individuals in all States."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc68aae5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum allotments","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc68aae6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058b/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After making the initial allotments described in paragraph (1), the Assistant Secretary shall adjust the allotments on a pro rata basis in accordance with subparagraphs (B) and (C).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc68aae7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058b/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General minimum allotments","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbc68aae8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058b/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum allotment for States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No State shall be allotted less than one-half of 1 percent of the funds appropriated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3058a"},"text":"section 3058a of this title","children":[],"tail":" for the fiscal year for which the determination is made."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc68aae9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058b/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum allotment for territories","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Guam, the United States Virgin Islands, and the Trust Territory of the Pacific Islands, shall each be allotted not less than one-fourth of 1 percent of the funds appropriated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3058a"},"text":"section 3058a of this title","children":[],"tail":" for the fiscal year for which the determination is made. American Samoa and the Commonwealth of the Northern Mariana Islands shall each be allotted not less than one-sixteenth of 1 percent of the sum appropriated under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3058a"},"text":"section 3058a of this title","children":[],"tail":" for the fiscal year for which the determination is made."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc68aaea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058b/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum allotments for ombudsman and elder abuse programs","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbc68aaeb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058b/a/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ombudsman program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No State shall be allotted for a fiscal year, from the funds appropriated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3058a"},"text":"section 3058a of this title","children":[],"tail":" and made available to carry out subpart II of this part, less than the amount allotted to the State under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3024"},"text":"section 3024 of this title","children":[],"tail":" in fiscal year 2000 to carry out the State Long-Term Care Ombudsman program under subchapter III."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc68aaec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058b/a/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Elder abuse programs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No State shall be allotted for a fiscal year, from the funds appropriated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3058a"},"text":"section 3058a of this title","children":[],"tail":" and made available to carry out subpart III of this part, less than the amount allotted to the State under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3024"},"text":"section 3024 of this title","children":[],"tail":" in fiscal year 2000 to carry out programs with respect to the prevention of elder abuse, neglect, and exploitation under subchapter III."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc68aaed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058b/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “State” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purposes of this paragraph, the term “State” does not include Guam, American Samoa, the United States Virgin Islands, the Trust Territory of the Pacific Islands, and the Commonwealth of the Northern Mariana Islands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc68aaee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reallotment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc68aaef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Assistant Secretary determines that any amount allotted to a State for a fiscal year under this section will not be used by the State for carrying out the purpose for which the allotment was made, the Assistant Secretary shall make the amount available to a State that the Assistant Secretary determines will be able to use the amount for carrying out the purpose.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc68aaf0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any amount made available to a State from an appropriation for a fiscal year in accordance with paragraph (1) shall, for purposes of this part, be regarded as part of the allotment of the State (as determined under subsection (a)) for the year, but shall remain available until the end of the succeeding fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc68aaf1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Withholding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Assistant Secretary finds that any State has failed to carry out this subchapter in accordance with the assurances made and description provided under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3058d"},"text":"section 3058d of this title","children":[],"tail":", the Assistant Secretary shall withhold the allotment of funds to the State. The Assistant Secretary shall disburse the funds withheld directly to any public or nonprofit private institution or organization, agency, or political subdivision of the State submitting an approved plan containing the assurances and description."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc68aaf2-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/73/tVII/s703"},"text":"Pub. L. 89–73, title VII, § 703","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/375/tVII/s701"},"text":"Pub. L. 102–375, title VII, § 701","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-09-30"},"text":"Sept. 30, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1271"},"text":"106 Stat. 1271","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/171/s3/a/13"},"text":"Pub. L. 103–171, § 3(a)(13)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-02"},"text":"Dec. 2, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1990"},"text":"107 Stat. 1990","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/501/tVII/s702"},"text":"Pub. L. 106–501, title VII, § 702","children":[],"tail":", title VIII, § 801(e)(1), "},{"tag":"date","attrib":{"date":"2000-11-13"},"text":"Nov. 13, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2289"},"text":"114 Stat. 2289","children":[],"tail":", 2293.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc68aaf3-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc68aaf4-3a