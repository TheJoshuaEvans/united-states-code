{"tag":"section","attrib":{"id":"idbc107855-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2240"},"text":null,"children":[{"tag":"num","attrib":{"value":"2240"},"text":"§ 2240.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Licensee incident reports as evidence","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No report by any licensee of any incident arising out of or in connection with a licensed activity made pursuant to any requirement of the Commission shall be admitted as evidence in any suit or action for damages growing out of any matter mentioned in such report.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbc107856-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-08-01/ch724"},"text":"Aug. 1, 1946, ch. 724","children":[],"tail":", title I, § 190, as added "},{"tag":"ref","attrib":{"href":"/us/pl/87/206/s16"},"text":"Pub. L. 87–206, § 16","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-09-06"},"text":"Sept. 6, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/479"},"text":"75 Stat. 479","children":[],"tail":"; renumbered title I, "},{"tag":"ref","attrib":{"href":"/us/pl/102/486/tIX/s902/a/8"},"text":"Pub. L. 102–486, title IX, § 902(a)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2944"},"text":"106 Stat. 2944","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
