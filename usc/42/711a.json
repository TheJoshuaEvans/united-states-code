{"tag":"section","attrib":{"id":"idb7f746a6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s711a"},"text":null,"children":[{"tag":"num","attrib":{"value":"711a"},"text":"§ 711a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emergency assistance to families through home visiting programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb7f746a7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s711a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supplemental appropriation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to amounts otherwise appropriated, out of any money in the Treasury of the United States not otherwise appropriated, there are appropriated to the Secretary $150,000,000, to remain available through ","children":[{"tag":"date","attrib":{"date":"2022-09-30"},"text":"September 30, 2022","children":[],"tail":", to enable eligible entities to conduct programs in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s711"},"text":"section 711 of this title","children":[],"tail":" and subsection (c) of this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7f746a8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s711a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility for funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to receive funds made available by subsection (a) of this section, an entity shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7f746a9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s711a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as of ","children":[{"tag":"date","attrib":{"date":"2021-03-11"},"text":"March 11, 2021","children":[],"tail":", be conducting a program under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s711"},"text":"section 711 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7f746aa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s711a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" ensure the modification of grants, contracts, and other agreements, as applicable, executed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s711"},"text":"section 711 of this title","children":[],"tail":" under which the program is conducted as are necessary to provide that, during the period that begins with "},{"tag":"date","attrib":{"date":"2021-03-11"},"text":"March 11, 2021","children":[],"tail":", and ends with the end of the 2nd succeeding fiscal year after the funds are awarded, the entity shall—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb7f746ab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s711a/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not reduce funding for, or staffing levels of, the program on account of reduced enrollment in the program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7f746ac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s711a/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" when using funds to provide emergency supplies to eligible families receiving grant services under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s711"},"text":"section 711 of this title","children":[],"tail":", ensure coordination with local diaper banks to the extent practicable; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7f746ad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s711a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reaffirm that, in conducting the program, the entity will focus on priority populations (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s711/d/4"},"text":"section 711(d)(4) of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7f746ae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s711a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uses of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An entity to which funds are provided under this section shall use the funds—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7f746af-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s711a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to serve families with home visits or with virtual visits, that may be conducted by the use of electronic information and telecommunications technologies, in a service delivery model described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s711/d/3/A"},"text":"section 711(d)(3)(A) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7f746b0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s711a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to pay hazard pay or other additional staff costs associated with providing home visits or administration for programs funded under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s711"},"text":"section 711 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7f746b1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s711a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to train home visitors employed by the entity in conducting a virtual home visit and in emergency preparedness and response planning for families served, and may include training on how to safely conduct intimate partner violence screenings, and training on safety and planning for families served to support the family outcome improvements listed in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s711/d/2/B"},"text":"section 711(d)(2)(B) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7f746b2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s711a/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the acquisition by families served by programs under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s711"},"text":"section 711 of this title","children":[],"tail":" of such technological means as are needed to conduct and support a virtual home visit;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7f746b3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s711a/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide emergency supplies (such as diapers and diapering supplies including diaper wipes and diaper cream, necessary to ensure that a child using a diaper is properly cleaned and protected from diaper rash, formula, food, water, hand soap and hand sanitizer) to an eligible family (as defined in section 711(","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(2) of this title);"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7f746b4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s711a/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to coordinate with and provide reimbursement for supplies to diaper banks when using such entities to provide emergency supplies specified in paragraph (5); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7f746b5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s711a/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide prepaid grocery cards to an eligible family (as defined in section 711(","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(2) of this title) participating in the maternal, infant, and early childhood home visiting program under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s711"},"text":"section 711 of this title","children":[],"tail":" for the purpose of enabling the family to meet the emergency needs of the family."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb7f746b6-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title V, § 511A, as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/2/tIX/s9101"},"text":"Pub. L. 117–2, title IX, § 9101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-03-11"},"text":"Mar. 11, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/123"},"text":"135 Stat. 123","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dFF/tVI/s6101/f/2/B"},"text":"Pub. L. 117–328, div. FF, title VI, § 6101(f)(2)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5962"},"text":"136 Stat. 5962","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb7f746b7-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb7f746b8-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb7f746b9-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (c)(5), (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328"},"text":"Pub. L. 117–328","children":[],"tail":" substituted “section 711("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(2)” for “section 711(k)(2)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb7f746ba-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb7f746bb-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2022 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328"},"text":"Pub. L. 117–328","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2022-10-01"},"text":"Oct. 1, 2022","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/s6101/i/1"},"text":"section 6101(i)(1) of Pub. L. 117–328","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s711"},"text":"section 711 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb7f746bc-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/2/tIX/s9101"},"text":"Pub. L. 117–2, title IX, § 9101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-03-11"},"text":"Mar. 11, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/123"},"text":"135 Stat. 123","children":[],"tail":", provided in part that this section is effective 1 day after the date of enactment of this Act ("},{"tag":"date","attrib":{"date":"2021-03-11"},"text":"Mar. 11, 2021","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
