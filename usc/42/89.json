{"tag":"section","attrib":{"id":"idb406d2b0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s89"},"text":null,"children":[{"tag":"num","attrib":{"value":"89"},"text":"§ 89.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quarantine warehouses; erection","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There shall be purchased or erected, under the orders of the President, suitable warehouses, with wharves and inclosures, where merchandise may be unladen and deposited, from any vessel which shall be subject to a quarantine, or other restraint, pursuant to the health laws of any State, at such convenient places therein as the safety of the public revenue and the observance of such health laws may require.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb406d2b1-3a70-11f1-ae07-e4213316b5fa"},"text":"(R.S. § 4794.)","children":[],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb406d2b2-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb406d2b3-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb406d2b4-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 4794 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1799-02-23/ch12/s3"},"text":"act Feb. 23, 1799, ch. 12, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/1/620"},"text":"1 Stat. 620","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
