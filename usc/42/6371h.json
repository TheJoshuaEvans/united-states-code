{"tag":"section","attrib":{"id":"idbd9eb981-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6371h"},"text":null,"children":[{"tag":"num","attrib":{"value":"6371h"},"text":"§ 6371h.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration; detailed description in annual report","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd9eb982-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6371h/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may prescribe such rules as may be necessary in order to carry out the provisions of this part.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd9eb983-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6371h/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall include in his annual report a detailed description of the actions taken under this part in the preceding fiscal year and the actions planned to be taken in the subsequent fiscal year. Such description shall show the allocations made (including the allocations made to each State) and include information on the types of conservation measures implemented, with funds allocated, and an estimate of the energy savings achieved.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd9eb984-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/163/tIII/s399"},"text":"Pub. L. 94–163, title III, § 399","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/95/619/tIII/s302/a"},"text":"Pub. L. 95–619, title III, § 302(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-09"},"text":"Nov. 9, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3247"},"text":"92 Stat. 3247","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/96/470/tII/s203/b"},"text":"Pub. L. 96–470, title II, § 203(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-19"},"text":"Oct. 19, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2242"},"text":"94 Stat. 2242","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd9eb985-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd9eb986-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd9eb987-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1980—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/470"},"text":"Pub. L. 96–470","children":[],"tail":" substituted “include in his annual report a detailed description” for “, within one year after "},{"tag":"date","attrib":{"date":"1978-11-09"},"text":"November 9, 1978","children":[],"tail":", and annually thereafter while funds are available under this part, submit to Congress a detailed report” and “Such description” for “Such report”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
