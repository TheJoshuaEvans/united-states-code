{"tag":"section","attrib":{"id":"idb7c7ab66-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s669b"},"text":null,"children":[{"tag":"num","attrib":{"value":"669b"},"text":"§ 669b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants to States for access and visitation programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb7c7ab67-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s669b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administration for Children and Families shall make grants under this section to enable States to establish and administer programs to support and facilitate noncustodial parents’ access to and visitation of their children, by means of activities including mediation (both voluntary and mandatory), counseling, education, development of parenting plans, visitation enforcement (including monitoring, supervision and neutral drop-off and pickup), and development of guidelines for visitation and alternative custody arrangements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7c7ab68-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s669b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of grant","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount of the grant to be made to a State under this section for a fiscal year shall be an amount equal to the lesser of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7c7ab69-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s669b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 90 percent of State expenditures during the fiscal year for activities described in subsection (a); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7c7ab6a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s669b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the allotment of the State under subsection (c) for the fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7c7ab6b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s669b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allotments to States","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7c7ab6c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s669b/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The allotment of a State for a fiscal year is the amount that bears the same ratio to $10,000,000 for grants under this section for the fiscal year as the number of children in the State living with only 1 biological parent bears to the total number of such children in all States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7c7ab6d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s669b/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum allotment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administration for Children and Families shall adjust allotments to States under paragraph (1) as necessary to ensure that no State is allotted less than—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb7c7ab6e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s669b/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $50,000 for fiscal year 1997 or 1998; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7c7ab6f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s669b/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $100,000 for any succeeding fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7c7ab70-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s669b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No supplantation of State expenditures for similar activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State to which a grant is made under this section may not use the grant to supplant expenditures by the State for activities specified in subsection (a), but shall use the grant to supplement such expenditures at a level at least equal to the level of such expenditures for fiscal year 1995.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7c7ab71-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s669b/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State administration","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each State to which a grant is made under this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7c7ab72-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s669b/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may administer State programs funded with the grant, directly or through grants to or contracts with courts, local public agencies, or nonprofit private entities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7c7ab73-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s669b/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not be required to operate such programs on a statewide basis; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7c7ab74-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s669b/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall monitor, evaluate, and report on such programs in accordance with regulations prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb7c7ab75-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title IV, § 469B, as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/193/tIII/s391"},"text":"Pub. L. 104–193, title III, § 391","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-22"},"text":"Aug. 22, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2258"},"text":"110 Stat. 2258","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb7c7ab76-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb7c7ab77-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb7c7ab78-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For effective date of section, see section 395(a)–(c) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/193"},"text":"Pub. L. 104–193","children":[],"tail":", set out as an Effective Date of 1996 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s654"},"text":"section 654 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
