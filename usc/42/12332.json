{"tag":"section","attrib":{"id":"idbf6aee00-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12332"},"text":null,"children":[{"tag":"num","attrib":{"value":"12332"},"text":"§ 12332.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this part:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf6aee01-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12332/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Community referral services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “community referral services” means services to assist families in obtaining community resources, including health care, mental health care, employability development and job training, and other social services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf6aee02-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12332/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Core services","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “core services” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf6aee03-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12332/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" educational and support services provided to assist parents in acquiring parenting skills, learning about child development, and responding appropriately to the behavior of their children; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf6aee04-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12332/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the early developmental screening of children to assess any needs of such children and to identify specific types of support that may be provided;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf6aee05-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12332/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" outreach services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf6aee06-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12332/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" community referral services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf6aee07-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12332/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" follow up services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf6aee08-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12332/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Follow up services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “follow up services” means services provided to ensure that necessary services are received by families and are effective in meeting their needs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf6aee09-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12332/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Independent State body","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “independent State body” means the entity established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12336"},"text":"section 12336 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf6aee0a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12332/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lead agency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “lead agency” means an existing State agency, or other public or nonprofit private entity designated by the chief executive officer of the State as the agency responsible for the development and implementation of local family resource and support programs. Such agency shall have demonstrated ability to work with other State and community based agencies, to provide training and technical assistance, and shall also have a commitment to parental participation in the design and administration of family resource and support programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf6aee0b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12332/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other services","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “other services” and “other support services” includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf6aee0c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12332/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" child care, early childhood development and intervention programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf6aee0d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12332/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" employability development services (including skill training);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf6aee0e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12332/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" educational services, such as scholastic tutoring, literacy training, and General Educational Degree (GED) services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf6aee0f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12332/6/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nutritional education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf6aee10-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12332/6/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" life management skills training;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf6aee11-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12332/6/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" peer counseling and crisis intervention, family violence counseling and referrals for such services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf6aee12-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12332/6/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" referral for substance abuse counseling and treatment referral; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf6aee13-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12332/6/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" referral for primary health and mental health services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf6aee14-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12332/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Outreach services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “outreach services” means services provided to ensure (through home visits or other methods) that parents are aware of and able to participate in family resource and support program activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf6aee15-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/501/tIX/s926"},"text":"Pub. L. 101–501, title IX, § 926","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-03"},"text":"Nov. 3, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1268"},"text":"104 Stat. 1268","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf6aee16-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbf6aee17-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbf6aee18-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1990-10-01"},"text":"Oct. 1, 1990","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/101/501/s1001/a"},"text":"section 1001(a) of Pub. L. 101–501","children":[],"tail":", set out as an Effective Date of 1990 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s8621"},"text":"section 8621 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
