{"tag":"section","attrib":{"id":"idbf6d5e8a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12404"},"text":null,"children":[{"tag":"num","attrib":{"value":"12404"},"text":"§ 12404.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Demonstrations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf6d5e8b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12404/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall conduct demonstrations of critical technologies, preferably in self-contained locations, so that technical and non-technical parameters can be evaluated to best determine commercial applicability of the technology.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf6d5e8c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12404/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Small-scale demonstrations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Concurrently with activities conducted pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12403"},"text":"section 12403 of this title","children":[],"tail":", the Secretary shall conduct small-scale demonstrations of hydrogen technology at self-contained sites."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf6d5e8d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12404/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-Federal funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall require a commitment from non-Federal sources of at least 50 percent of the cost of any demonstration conducted under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf6d5e8e-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/566/s105"},"text":"Pub. L. 101–566, § 105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-15"},"text":"Nov. 15, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2799"},"text":"104 Stat. 2799","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/271/tI/s104"},"text":"Pub. L. 104–271, title I, § 104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-09"},"text":"Oct. 9, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3306"},"text":"110 Stat. 3306","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf6d5e8f-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf6d5e90-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbf6d5e91-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/271"},"text":"Pub. L. 104–271","children":[],"tail":" added subsec. (c)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
