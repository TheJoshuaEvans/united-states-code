{"tag":"section","attrib":{"id":"idb6240d40-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300e–10"},"text":null,"children":[{"tag":"num","attrib":{"value":"300e–10"},"text":"§ 300e–10.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restrictive State laws and practices","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb6240d41-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300e–10/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Entities operating as health maintenance organizations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any entity—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6240d42-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300e–10/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" which cannot do business as a health maintenance organization in a State in which it proposes to furnish basic and supplemental health services because that State by law, regulation, or otherwise—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6240d43-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300e–10/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requires as a condition to doing business in that State that a medical society approve the furnishing of services by the entity,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6240d44-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300e–10/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requires that physicians constitute all or a percentage of its governing body,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6240d45-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300e–10/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requires that all physicians or a percentage of physicians in the locale participate or be permitted to participate in the provision of services for the entity,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6240d46-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300e–10/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requires that the entity meet requirements for insurers of health care services doing business in that State respecting initial capitalization and establishment of financial reserves against insolvency, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6240d47-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300e–10/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" imposes requirements which would prohibit the entity from complying with the requirements of this subchapter, and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6240d48-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300e–10/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for which a grant, contract, loan, or loan guarantee was made under this subchapter or which is a qualified health maintenance organization for purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300e–9"},"text":"section 300e–9 of this title","children":[],"tail":" (relating to employees’ health benefits plans),"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"such requirements shall not apply to that entity so as to prevent it from operating as a health maintenance organization in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300e"},"text":"section 300e of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6240d49-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300e–10/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advertising","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No State may establish or enforce any law which prevents a health maintenance organization for which a grant, contract, loan, or loan guarantee was made under this subchapter or which is a qualified health maintenance organization for purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300e–9"},"text":"section 300e–9 of this title","children":[],"tail":" (relating to employees’ health benefits plans), from soliciting members through advertising its services, charges, or other nonprofessional aspects of its operation. This subsection does not authorize any advertising which identifies, refers to, or makes any qualitative judgement concerning, any health professional who provides services for a health maintenance organization."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6240d4a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300e–10/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Digest of State laws, regulations, and practices; legal consultative assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall, within 6 months after ","children":[{"tag":"date","attrib":{"date":"1976-10-08"},"text":"October 8, 1976","children":[],"tail":", develop a digest of State laws, regulations, and practices pertaining to development, establishment, and operation of health maintenance organizations which shall be updated at least annually and relevant sections of which shall be provided to the Governor of each State annually. Such digest shall indicate which State laws, regulations, and practices appear to be inconsistent with the operation of this section. The Secretary shall also insure that appropriate legal consultative assistance is available to the States for the purpose of complying with the provisions of this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb6240d4b-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XIII, § 1311, as added "},{"tag":"ref","attrib":{"href":"/us/pl/93/222/s2"},"text":"Pub. L. 93–222, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-12-29"},"text":"Dec. 29, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/931"},"text":"87 Stat. 931","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/460/tI/s114"},"text":"Pub. L. 94–460, title I, § 114","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-08"},"text":"Oct. 8, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1954"},"text":"90 Stat. 1954","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/660/tVIII/s809"},"text":"Pub. L. 99–660, title VIII, § 809","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3801"},"text":"100 Stat. 3801","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/517/s8"},"text":"Pub. L. 100–517, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-24"},"text":"Oct. 24, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2583"},"text":"102 Stat. 2583","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb6240d4c-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb6240d4d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb6240d4e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1311 of act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s211a"},"text":"section 211a of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/93/222/s7/b"},"text":"Pub. L. 93–222, § 7(b)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb6240d4f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—Subsec. (a)(1)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/517"},"text":"Pub. L. 100–517","children":[],"tail":" added subpar. (E)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/660"},"text":"Pub. L. 99–660","children":[],"tail":" substituted “annually” for “quarterly” after “at least”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/460"},"text":"Pub. L. 94–460","children":[],"tail":" added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb6240d50-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb6240d51-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/660"},"text":"Pub. L. 99–660","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1985-10-01"},"text":"Oct. 1, 1985","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/660/s815/a"},"text":"section 815(a) of Pub. L. 99–660","children":[],"tail":", set out as an Effective and Termination Dates of 1986 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300e–1"},"text":"section 300e–1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb6240d52-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1976 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/460"},"text":"Pub. L. 94–460","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1976-10-08"},"text":"Oct. 8, 1976","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/94/460/s118"},"text":"section 118 of Pub. L. 94–460","children":[],"tail":", set out as a note under "},{"