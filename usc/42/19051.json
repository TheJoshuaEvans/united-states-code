{"tag":"section","attrib":{"id":"idc0786609-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19051"},"text":null,"children":[{"tag":"num","attrib":{"value":"19051"},"text":"§ 19051.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Broader impacts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc078660a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19051/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 120 days after ","children":[{"tag":"date","attrib":{"date":"2022-08-09"},"text":"August 9, 2022","children":[],"tail":", the Director shall enter into an agreement with a qualified independent organization to assess how the Broader Impacts review criterion is applied across the Foundation and make recommendations for improving the effectiveness for meeting the goals established in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1862p–14"},"text":"section 1862p–14 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc078660b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19051/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director shall make awards on a competitive basis, to institutions of higher education or non-profit organizations (or consortia of such institutions or organizations) to support activities to increase the efficiency, effectiveness, and availability of resources for implementing the Broader Impacts review criterion, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc078660c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19051/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" training and workshops for program officers, merit review panelists, award office administrators, faculty, and students to improve understanding of the goals and the full range of potential broader impacts available to researchers to satisfy this criterion;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc078660d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19051/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" repositories and clearinghouses for sharing best practices and facilitating collaboration; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc078660e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19051/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" tools for evaluating and documenting societal impacts of research.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc078660f-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/tIII/s10341"},"text":"Pub. L. 117–167, div. B, title III, § 10341","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1557"},"text":"136 Stat. 1557","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
