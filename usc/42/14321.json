{"tag":"section","attrib":{"id":"idbfcf06c0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14321"},"text":null,"children":[{"tag":"num","attrib":{"value":"14321"},"text":"§ 14321.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purpose of this subchapter is to facilitate the efficient recycling or proper disposal of used nickel-cadmium rechargeable batteries, used small sealed lead-acid rechargeable batteries, other regulated batteries, and such rechargeable batteries in used consumer products, by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfcf06c1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14321/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing for uniform labeling requirements and streamlined regulatory requirements for regulated battery collection programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfcf06c2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14321/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encouraging voluntary industry programs by eliminating barriers to funding the collection and recycling or proper disposal of used rechargeable batteries.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfcf06c3-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/142/tI/s102"},"text":"Pub. L. 104–142, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-05-13"},"text":"May 13, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1332"},"text":"110 Stat. 1332","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
