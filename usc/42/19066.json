{"tag":"section","attrib":{"id":"idc078666a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19066"},"text":null,"children":[{"tag":"num","attrib":{"value":"19066"},"text":"§ 19066.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technology and behavioral science research","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc078666b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19066/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director shall make awards on a merit-reviewed, competitive basis for research and development to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc078666c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19066/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase understanding of social media and consumer technology access and use patterns and related mental health, behavioral, and substance use disorder issues, particularly for children and adolescents; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc078666d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19066/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" explore the role of social media and consumer technology in rising rates of mental health and substance use disorder issues, including within communities experiencing long-term economic distress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc078666e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19066/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination to avoid duplication","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In making awards under this subsection, the Director shall, for purposes of avoiding duplication of activities and research, consult, collaborate, and coordinate with the heads of other relevant Federal departments and agencies, including the Department of Health and Human Services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc078666f-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/tIII/s10357"},"text":"Pub. L. 117–167, div. B, title III, § 10357","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1563"},"text":"136 Stat. 1563","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
