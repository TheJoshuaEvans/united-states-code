{"tag":"section","attrib":{"id":"idbf1c3174-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10245"},"text":null,"children":[{"tag":"num","attrib":{"value":"10245"},"text":"§ 10245.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Site characterization; licensing","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf1c3175-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10245/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Site characterization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon enactment of legislation to implement an agreement to site a repository negotiated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s10243/a"},"text":"section 10243(a) of this title","children":[],"tail":", the Secretary shall conduct appropriate site characterization activities for the site that is the subject of such agreement subject to the conditions and terms of such agreement. Any such site characterization activities shall be conducted in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s10133"},"text":"section 10133 of this title","children":[],"tail":", except that references in such section to the Yucca Mountain site and the State of Nevada shall be deemed to refer to the site that is the subject of the agreement and the State or Indian tribe entering into the agreement."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf1c3176-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10245/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Licensing","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf1c3177-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10245/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Upon the completion of site characterization activities carried out under subsection (a), the Secretary shall submit to the Nuclear Regulatory Commission an application for construction authorization for a repository at such site.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf1c3178-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10245/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Nuclear Regulatory Commission shall consider an application for a construction authorization for a repository or monitored retrievable storage facility in accordance with the laws applicable to such applications, except that the Nuclear Regulatory Commission shall issue a final decision approving or disapproving the issuance of a construction authorization not later than 3 years after the date of the submission of such application.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf1c3179-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/425/tIV/s405"},"text":"Pub. L. 97–425, title IV, § 405","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/202/s101/d/tIII"},"text":"Pub. L. 100–202, § 101(d) [title III]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1329-104"},"text":"101 Stat. 1329–104","children":[],"tail":", 1329–121; "},{"tag":"ref","attrib":{"href":"/us/pl/100/203/tV/s5041"},"text":"Pub. L. 100–203, title V, § 5041","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1330-246"},"text":"101 Stat. 1330–246","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf1c317a-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf1c317b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbf1c317c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/202"},"text":"Pub. L. 100–202","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/100/203"},"text":"Pub. L. 100–203","children":[],"tail":" added identical sections."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
