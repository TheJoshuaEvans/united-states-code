{"tag":"section","attrib":{"id":"idbbd0142d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000ff–8"},"text":null,"children":[{"tag":"num","attrib":{"value":"2000ff–8"},"text":"§ 2000ff–8.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbbd0142e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000ff–8/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this chapter shall be construed to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbbd0142f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000ff–8/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" limit the rights or protections of an individual under any other Federal or State statute that provides equal or greater protection to an individual than the rights or protections provided for under this chapter, including the protections of an individual under the Americans with Disabilities Act of 1990 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12101"},"text":"42 U.S.C. 12101","children":[],"tail":" et seq.) (including coverage afforded to individuals under section 102 of such Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12112"},"text":"42 U.S.C. 12112","children":[],"tail":")), or under the Rehabilitation Act of 1973 ("},{"tag":"ref","attrib":{"href":"/us/usc/t29/s701"},"text":"29 U.S.C. 701","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbd01430-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000ff–8/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbbd01431-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000ff–8/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" limit the rights or protections of an individual to bring an action under this chapter against an employer, employment agency, labor organization, or joint labor-management committee for a violation of this chapter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbbd01432-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000ff–8/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide for enforcement of, or penalties for violation of, any requirement or prohibition applicable to any employer, employment agency, labor organization, or joint labor-management committee subject to enforcement for a violation under—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbbd01433-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000ff–8/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amendments made by title I of this Act;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbbd01434-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000ff–8/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbbd01435-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000ff–8/a/2/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subsection (a) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1181"},"text":"section 1181 of title 29","children":[],"tail":" as such section applies with respect to genetic information pursuant to subsection (b)(1)(B) of such section;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbbd01436-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000ff–8/a/2/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1182/a/1/F"},"text":"section 1182(a)(1)(F) of title 29","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbbd01437-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000ff–8/a/2/B/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1182/b/1"},"text":"section 1182(b)(1) of title 29","children":[],"tail":" as such section applies with respect to genetic information as a health status-related factor;"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbbd01438-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000ff–8/a/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbbd01439-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000ff–8/a/2/B/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subsection (a) of section 2701 ","children":[{"tag":"ref","attrib":{"idref":"fn003250"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003250"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of the Public Health Service Act as such section applies with respect to genetic information pursuant to subsection (b)(1)(B) of such section;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbbd0143a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000ff–8/a/2/B/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 2702(a)(1)(F) ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of such Act; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbbd0143b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000ff–8/a/2/B/iii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 2702(b)(1) ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of such Act as such section applies with respect to genetic information as a health status-related factor; or"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbbd0143c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000ff–8/a/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbbd0143d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000ff–8/a/2/B/iv/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subsection (a) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s9801"},"text":"section 9801 of title 26","children":[],"tail":" as such section applies with respect to genetic information pursuant to subsection (b)(1)(B) of such section;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbbd0143e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000ff–8/a/2/B/iv/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s9802/a/1/F"},"text":"section 9802(a)(1)(F) of title 26","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbbd0143f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000ff–8/a/2/B/iv/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s9802/b/1"},"text":"section 9802(b)(1) of title 26","children":[],"tail":" as such section applies with respect to genetic information as a health status-related factor;"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbd01440-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000ff–8/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" apply to the Armed Forces Repository of Specimen Samples for the Identification of Remains;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbd01441-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000ff–8/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" limit or expand the protections, rights, or obligations of employees or employers under applicable workers’ compensation laws;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbd01442-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000ff–8/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" limit the authority of a Federal department or agency to conduct or sponsor occupational or other health research that is conducted in compliance with the regulations contained in part 46 of title 45, Code of Federal Regulations (or any corresponding or similar regulation or rule);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbd01443-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000ff–8/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" limit the statutory or regulatory authority of the Occupational Safety and Health Administration or the Mine Safety and Health Administration to promulgate or enforce workplace safety and health laws and regulations; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbd01444-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000ff–8/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require any specific benefit for an employee or member or a family member of an employee or member under any group health plan or health insurance issuer offering group health insurance coverage in connection with a group health plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbbd01445-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000ff–8/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Genetic information of a fetus or embryo","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any reference in this chapter to genetic information concerning an individual or family member of an individual shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbbd01446-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000ff–8/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to such an individual or family member of an individual who is a pregnant woman, include genetic information of any fetus carried by such pregnant woman; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbd01447-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000ff–8/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to an individual or family member utilizing an assisted reproductive technology, include genetic information of any embryo legally held by the individual or family member.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbbd01448-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000ff–8/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relation to authorities under title I","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to a group health plan, or a health insurance issuer offering group health insurance coverage in connection with a group health plan, this chapter does not prohibit any activity of such plan or issuer that is authorized for the plan or issuer under any provision of law referred to in clauses (i) through (iv) of subsection (a)(2)(B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbbd01449-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/233/tII/s209"},"text":"Pub. L. 110–233, title II, § 209","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-21"},"text":"May 21, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/918"},"text":"122 Stat. 918","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbbd0144a-3a70-1