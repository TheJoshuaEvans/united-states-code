{"tag":"section","attrib":{"id":"idbd310322-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5204c"},"text":null,"children":[{"tag":"num","attrib":{"value":"5204c"},"text":"§ 5204c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hazard mitigation for insular areas","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The total of contributions under the last sentence of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5170c"},"text":"section 5170c of this title","children":[],"tail":" for the insular areas shall not exceed 10 percent of the estimated aggregate amounts of grants to be made under sections 5170b, 5172, 5173, 5174, and 5178 "},{"tag":"ref","attrib":{"idref":"fn003419"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003419"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title for any disaster: "},{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That the President shall require a 50 percent local match for assistance in excess of 10 percent of the estimated aggregate amount of grants to be made under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5172"},"text":"section 5172 of this title","children":[],"tail":" for any disaster."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbd310323-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/247/tII/s204"},"text":"Pub. L. 102–247, title II, § 204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-02-24"},"text":"Feb. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/38"},"text":"106 Stat. 38","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd310324-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd310325-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbd310326-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5178"},"text":"Section 5178 of this title","children":[],"tail":", referred to in text, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/106/390/tII/s206/c"},"text":"Pub. L. 106–390, title II, § 206(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1571"},"text":"114 Stat. 1571","children":[],"tail":", effective 18 months after "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbd310327-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Omnibus Insular Areas Act of 1992, and not as part of the Robert T. Stafford Disaster Relief and Emergency Assistance Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
