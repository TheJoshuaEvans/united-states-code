{"tag":"section","attrib":{"id":"idb6de0f4e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"300mm–1"},"text":"§ 300mm–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" WTC Health Program Scientific/Technical Advisory Committee; WTC Health Program Steering Committees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb6de0f4f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisory Committee","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6de0f50-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–1/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The WTC Program Administrator shall establish an advisory committee to be known as the WTC Health Program Scientific/Technical Advisory Committee (in this subsection referred to as the “Advisory Committee”) to review scientific and medical evidence and to make recommendations to the Administrator on additional WTC Program eligibility criteria and on additional WTC-related health conditions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6de0f51-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–1/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Composition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The WTC Program Administrator shall appoint the members of the Advisory Committee and shall include at least—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6de0f52-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–1/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 4 occupational physicians, at least 2 of whom have experience treating WTC rescue and recovery workers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6de0f53-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–1/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 physician with expertise in pulmonary medicine;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6de0f54-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–1/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 2 environmental medicine or environmental health specialists;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6de0f55-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–1/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 2 representatives of WTC responders;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6de0f56-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–1/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 2 representatives of certified-eligible WTC survivors;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6de0f57-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–1/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an industrial hygienist;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6de0f58-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–1/a/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a toxicologist;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6de0f59-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–1/a/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an epidemiologist; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6de0f5a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–1/a/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a mental health professional.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6de0f5b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–1/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Advisory Committee shall meet at such frequency as may be required to carry out its duties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6de0f5c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–1/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The WTC Program Administrator shall provide for publication of recommendations of the Advisory Committee on the public Web site established for the WTC Program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6de0f5d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–1/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, the Advisory Committee shall continue in operation during the period in which the WTC Program is in operation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6de0f5e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–1/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of chapter 10 of title 5","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as otherwise specifically provided, the Advisory Committee shall be subject to Chapter ","children":[{"tag":"ref","attrib":{"idref":"fn002542"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002542"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should not be capitalized."}],"tail":" 10 of title 5."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6de0f5f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" WTC Health Program Steering Committees","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6de0f60-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–1/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The WTC Program Administrator shall consult with 2 steering committees (each in this section referred to as a “Steering Committee”) that are established as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6de0f61-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–1/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" WTC Responders Steering Committee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"One Steering Committee, to be known as the WTC Responders Steering Committee, for the purpose of receiving input from affected stakeholders and facilitating the coordination of monitoring and treatment programs for the enrolled WTC responders under subpart 1 of part B.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6de0f62-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–1/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" WTC Survivors Steering Committee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"One Steering Committee, to be known as the WTC Survivors Steering Committee, for the purpose of receiving input from affected stakeholders and facilitating the coordination of initial health evaluations, monitoring, and treatment programs for screening-eligible and certified-eligible WTC survivors under subpart 2 of part B.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6de0f63-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–1/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6de0f64-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–1/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" WTC Responders Steering Committee","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb6de0f65-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–1/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Representation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The WTC Responders Steering Committee shall include—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb6de0f66-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–1/b/2/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" representatives of the Centers of Excellence providing services to WTC responders;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb6de0f67-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–1/b/2/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" representatives of labor organizations representing firefighters, police, other New York City employees, and recovery and cleanup workers who responded to the ","children":[{"tag":"date","attrib":{"date":"2001-09-11"},"text":"September 11, 2001","children":[],"tail":", terrorist attacks; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb6de0f68-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–1/b/2/A/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 3 representatives of New York City, 1 of whom will be selected by the police commissioner of New York City, 1 by the health commissioner of New York City, and 1 by the mayor of New York City.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6de0f69-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–1/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial membership","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The WTC Responders Steering Committee shall initially be composed of members of the WTC Monitoring and Treatment Program Steering Committee (as in existence on the day before ","children":[{"tag":"date","attrib":{"date":"2011-01-02"},"text":"January 2, 2011","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6de0f6a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–1/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" WTC Survivors Steering Committee","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb6de0f6b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–1/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Representation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The WTC Survivors Steering Committee shall include representatives of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb6de0f6c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–1/b/2/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Centers of Excellence providing services to screening-eligible and certified-eligible WTC survivors;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb6de0f6d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–1/b/2/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the population of residents, students, and area and other workers affected by the ","children":[{"tag":"date","attrib":{"date":"2001-09-11"},"text":"September 11, 2001","children":[],"tail":", terrorist attacks;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb6de0f6e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–1/b/2/B/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" screening-eligible and certified-eligible survivors receiving initial health evaluations, monitoring, or treatment under subpart 2 of part B and organizations advocating on their behalf; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb6de0f6f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–1/b/2/B/i/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" New York City.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6de0f70-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–1/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial membership","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The WTC Survivors Steering Committee shall initially be composed of members of the WTC Environmental Health Center Survivor Advisory Committee (as in existence on the day before ","children":[{"tag":"date","attrib":{"date":"2011-01-02"},"text":"January 2, 2011","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6de0f71-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–1/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional appointments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each Steering Committee may recommend, if approved by a majority of voting members of the Committee, additional members to the Committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6de0f72-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–1/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vacancies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A vacancy in a Steering Committee shall be filled by an individual recommended by the Steering Committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb6de0f73-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XXXIII, § 3302, as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/347/tI/s101"},"text":"Pub. L. 111–347, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-02"},"text":"Jan. 2, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3627"},"text":"124 Stat. 3627","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/247"},"text":"Pub. L. 117–286, § 4(a)(247)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4333"},"text":"136 Stat. 4333","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb6de0f74-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb6de0f75-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb6de0f76-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (a)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":" substituted “chapter 10 of title 5” for “FACA” in heading and “Chapter 10 of title 5.” for “the Federal Advisory Committee Act.” in text."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
