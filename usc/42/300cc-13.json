{"tag":"section","attrib":{"id":"idb6836bb7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–13"},"text":null,"children":[{"tag":"num","attrib":{"value":"300cc–13"},"text":"§ 300cc–13.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terry Beirn Community-Based AIDS Research Initiative","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb6836bb8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–13/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After consultation with the Commissioner of Food and Drugs, the Director of the National Institutes of Health, acting through the Director of the National Institute of Allergy and Infectious Diseases, may make grants to public entities and nonprofit private entities concerned with acquired immune deficiency syndrome, and may enter into contracts with public and private such ","children":[{"tag":"ref","attrib":{"idref":"fn002413"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002413"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original."}],"tail":" entities, for the purpose of planning and conducting, in the community involved, clinical trials of experimental treatments for infection with the etiologic agent for such syndrome that are approved by the Commissioner of Food and Drugs for investigational use under regulations issued under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s355"},"text":"section 355 of title 21","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6836bb9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–13/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement of certain projects","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6836bba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–13/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Financial assistance under subsection (a) shall include such assistance to community-based organizations and community health centers for the purpose of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6836bbb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–13/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" retaining appropriate medical supervision;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6836bbc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–13/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assisting with administration, data collection and record management; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6836bbd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–13/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conducting training of community physicians, nurse practitioners, physicians’ assistants and other health professionals for the purpose of conducting clinical trials.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6836bbe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–13/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6836bbf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–13/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Financial assistance under subsection (a) shall include such assistance for demonstration projects designed to implement and conduct community-based clinical trials in order to provide access to the entire scope of communities affected by infections with the etiologic agent for acquired immune deficiency syndrome, including minorities, hemophiliacs and transfusion-exposed individuals, women, children, users of intravenous drugs, and individuals who are asymptomatic with respect to such infection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6836bc0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–13/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Director of the National Institutes of Health may not provide financial assistance under this paragraph unless the application for such assistance is approved—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb6836bc1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–13/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by the Commissioner of Food and Drugs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6836bc2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–13/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by a duly constituted Institutional Review Board that meets the requirements of part 56 of title 21, Code of Federal Regulations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6836bc3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–13/b/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by the Director of the National Institute of Allergy and Infectious Diseases.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6836bc4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–13/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Participation of private industry, schools of medicine and primary providers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Programs carried out with financial assistance provided under subsection (a) shall be designed to encourage private industry and schools of medicine, osteopathic medicine, and existing consortia of primary care providers organized to conduct clinical research concerning acquired immune deficiency syndrome to participate in, and to support, the clinical trials conducted pursuant to the programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6836bc5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–13/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement of application","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may not provide financial assistance under subsection (a) unless—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6836bc6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–13/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an application for the assistance is submitted to the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6836bc7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–13/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to carrying out the purpose for which the assistance is to be made, the application provides assurances of compliance satisfactory to the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6836bc8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–13/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the application otherwise is in such form, is made in such manner, and contains such agreements, assurances, and information as the Secretary determines to be necessary to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6836bc9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–13/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6836bca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–13/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purpose of carrying out subsection (b)(1), there are authorized to be appropriated such sums as may be necessary for each of the fiscal years 1989 through 1996.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6836bcb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–13/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purpose of carrying out subsection (b)(2), there are authorized to be appropriated such sums as may be necessary for each of the fiscal years 1989 through 1996.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb6836bcc-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XXIII, § 2313, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/607/tII/s201/4"},"text":"Pub. L. 100–607, title II, § 201(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-04"},"text":"Nov. 4, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3068"},"text":"102 Stat. 3068","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tII/s2617/b"},"text":"Pub. L. 100–690, title II, § 2617(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4240"},"text":"102 Stat. 4240","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/93/s6"},"text":"Pub. L. 101–93, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-08-16"},"text":"Aug. 16, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/615"},"text":"103 Stat. 615","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/96/s3"},"text":"Pub. L. 102–96, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-08-14"},"text":"Aug. 14, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/481"},"text":"105 Stat. 481","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb6836bcd-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb6836bce-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb6836bcf-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 300cc–13, act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", § 2314, was successively renumbered by subsequent acts and transferred, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s238k"},"text":"section 238k of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb6836bd0-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/96/s3/1"},"text":"Pub. L. 102–96, § 3(1)","children":[],"tail":", substituted “Terry Beirn Community-Based AIDS Research Initiative” for “Community-based evaluations of experimental therapies” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/96/s3/2"},"text":"Pub. L. 102–96, § 3(2)","children":[],"tail":", substituted “, schools of medicine and primary providers” for “and schools of medicine” in heading and substituted “schools of medicine, osteopathic medicine, and existing consortia of primary care providers organized to conduct clinical research concerning acquired immune deficiency syndrome” for “schools of medicine and osteopathic medicine”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/96/s3/3"},"text":"Pub. L. 102–96, § 3(3)","children":[],"tail":", substituted “1996” for “1991” in pars. (1) and (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/93"},"text":"Pub. L. 101–93","children":[],"tail":" inserted “and osteopathic medicine” after “schools of medicine”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690/s2617/b/1"},"text":"Pub. L. 100–690, § 2617(b)(1)","children":[],"tail":", which directed substitution of “through the Director of the National Institute of Allergy” for “through the National Institutes of Allergy”, was executed by making substitution for “through the National Institute of Allergy” as the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(B)(iii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690/s2617/b/2"},"text":"Pub. L. 100–690, § 2617(b)(2)","children":[],"tail":", which directed substitution of “Institute” for “Institutes”, could not be executed because “Institute” was singular in original."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb6836bd1-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb6836bd2-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690"},"text":"Pub. L. 100–690","children":[],"tail":" effective immediately after enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/100/607"},"text":"Pub. L. 100–607","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"1988-11-04"},"text":"Nov. 4, 1988","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/s2600"},"text":"section 2600 of Pub. L. 100–690","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s242m"},"text":"section 242m of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb6836bd3-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Reference to Community, Migrant, Public Housing, or Homeless Health Center Considered Reference to Health Center","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Reference to community health center, migrant health center, public housing health center, or homeless health center considered reference to health center, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/299/s4/c"},"text":"section 4(c) of Pub. L. 104–299","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s254b"},"text":"section 254b of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb6836bd4-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Findings and Sense of Congress","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/96/s2"},"text":"Pub. L. 102–96, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-08-14"},"text":"Aug. 14, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/481"},"text":"105 Stat. 481","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/96/s2"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Findings","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" community-based clinical trials complement the National Institute of Allergy and Infectious Diseases’ university-based research in order to provide increased access to experimental therapies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" community-based clinical trials provide an efficient and cost-effective means to develop new HIV-related treatments, benefiting all people living with HIV disease and other illnesses; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" because the community-based clinical trials model has a proven ability to conduct rapid trials that meet the very highest standards of scientific inquiry, this program should be reauthorized and significantly expanded.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sense of Congress","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"It is the sense of Congress that, because of Terry Beirn’s tireless efforts to foster a partnership among all parties invested in AIDS research (including the National Institutes of Health university-based research system, primary care physicians practicing in the community, and patients), the community-based clinical trials program should be renamed as the ‘Terry Beirn Community-Based AIDS Research Initiative’ in his honor.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
