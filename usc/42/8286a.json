{"tag":"section","attrib":{"id":"idbe8d38ba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8286a"},"text":null,"children":[{"tag":"num","attrib":{"value":"8286a"},"text":"§ 8286a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of factors and data","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Factors and data consented to pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s8286"},"text":"section 8286 of this title","children":[],"tail":" may be revised and agreed to by a consensus of the heads of the various Federal agencies involved. Such factors and data shall be used by all Federal agencies in establishing and revising various energy conservation standards used by such agencies, except that other factors and data may be used with respect to the standards applicable to any program if—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe8d38bb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8286a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the other factors and data are approved by the Secretary of Energy solely on the basis that such other factors and data are critical to meet the unique needs of the program concerned;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe8d38bc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8286a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" using the consented to factors and data would cause a violation of an express provision of law; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe8d38bd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8286a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" statutory requirements or responsibilities require a modification of the consented to factors and data.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbe8d38be-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/294/tV/s596"},"text":"Pub. L. 96–294, title V, § 596","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-06-30"},"text":"June 30, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/762"},"text":"94 Stat. 762","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbe8d38bf-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbe8d38c0-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbe8d38c1-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Energy Security Act, and not as part of the National Energy Conservation Policy Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
