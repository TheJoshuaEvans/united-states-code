{"tag":"section","attrib":{"id":"idbc44f653-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3018"},"text":null,"children":[{"tag":"num","attrib":{"value":"3018"},"text":"§ 3018.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports to Congress","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbc44f654-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3018/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than one hundred and twenty days after the close of each fiscal year, the Assistant Secretary shall prepare and submit to the President and to the Congress a full and complete report on the activities carried out under this chapter. Such annual reports shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc44f655-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3018/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" statistical data reflecting services and activities provided to individuals during the preceding fiscal year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc44f656-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3018/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" statistical data collected under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3012/a/16"},"text":"section 3012(a)(16) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc44f657-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3018/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" statistical data and an analysis of information regarding the effectiveness of the State agency and area agencies on aging in targeting services to older individuals with greatest economic need and older individuals with greatest social need, with particular attention to low-income minority individuals, older individuals residing in rural areas, low-income individuals, and frail individuals (including individuals with any physical or mental functional impairment); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc44f658-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3018/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the implementation of the plan required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3012/a/14"},"text":"section 3012(a)(14) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc44f659-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3018/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report on ombudsman program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc44f65a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3018/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Not later than March 1 of each year, the Assistant Secretary shall compile a report—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc44f65b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3018/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" summarizing and analyzing the data collected under subchapters III and XI in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3058g/c"},"text":"section 3058g(c) of this title","children":[],"tail":" for the then most recently concluded fiscal year;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc44f65c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3018/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying significant problems and issues revealed by such data (with special emphasis on problems relating to quality of care and residents’ rights);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc44f65d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3018/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" discussing current issues concerning the long-term care ombudsman programs of the States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc44f65e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3018/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" making recommendations regarding legislation and administrative actions to resolve such problems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc44f65f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3018/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Assistant Secretary shall submit the report required by paragraph (1) to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc44f660-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3018/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Special Committee on Aging of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc44f661-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3018/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Education and Labor of the House of Representatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc44f662-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3018/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Health, Education, Labor, and Pensions of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc44f663-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3018/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Assistant Secretary shall provide the report required by paragraph (1), and make the State reports required under subchapters III and XI in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3058g/h/1"},"text":"section 3058g(h)(1) of this title","children":[],"tail":" available, to—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc44f664-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3018/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Administrator of the Centers for Medicare & Medicaid Services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc44f665-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3018/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Office of the Inspector General of the Department of Health and Human Services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc44f666-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3018/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Office of Civil Rights of the Department of Health and Human Services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc44f667-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3018/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Veterans Affairs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc44f668-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3018/b/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each public agency or private organization designated as an Office of the State Long-Term Care Ombudsman under subchapter III or XI in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3058g/a/4/A"},"text":"section 3058g(a)(4)(A) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc44f669-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3018/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Outreach activities; report on evaluations to be included in annual report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Assistant Secretary shall, as part of the annual report submitted under subsection (a), prepare and submit a report on the outreach activities supported under this chapter, together with such recommendations as the Assistant Secretary deems appropriate. In carrying out this subsection, the Assistant Secretary shall consider—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc44f66a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3018/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of older individuals reached through the activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc44f66b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3018/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the dollar amount of the assistance and benefits received by older individuals as a result of such activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc44f66c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3018/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cost of such activities in terms of the number of individuals reached and the dollar amount described in paragraph (2);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc44f66d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3018/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effect of such activities on supportive services and nutrition services furnished under subchapter III of this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc44f66e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3018/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effectiveness of State and local efforts to target older individuals with greatest economic need (including low-income minority individuals and older individuals residing in rural areas) and older individuals with greatest social need (including low-income minority individuals and older individuals residing in rural areas) to receive services under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc44f66f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3018/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation to Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Assistant Secretary shall provide the evaluation required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3017/b"},"text":"section 3017(b) of this title","children":[],"tail":" to—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc44f670-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3018/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Health, Education, Labor, and Pensions of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc44f671-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3018/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Appropriations of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc44f672-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3018/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Special Committee on Aging of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc44f673-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3018/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Education and Labor of the House of Representatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc44f674-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3018/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Appropriations of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc44f675-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/73/tII/s207"},"text":"Pub. L. 89–73, title II, § 207","children":[],"tail":", formerly § 208, as added "},{"tag":"ref","attrib":{"href":"/us/pl/93/29/tII/s201/c"},"text":"Pub. L. 93–29, title II, § 201(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-05-03"},"text":"May 3, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/35"},"text":"87 Stat. 35","children":[],"tail":"; renumbered § 207, "},{"tag":"ref","attrib":{"href":"/us/pl/97/115/s2/e/2"},"text":"Pub. L. 97–115, § 2(e)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-12-29"},"text":"Dec. 29, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1596"},"text":"95 Stat. 1596","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/98/459/tII/s207"},"text":"Pub. L. 98–459, title II, § 207","children":[