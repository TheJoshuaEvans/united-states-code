{"tag":"section","attrib":{"id":"idb5f200f0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s296e"},"text":null,"children":[{"tag":"num","attrib":{"value":"296e"},"text":"§ 296e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Generally applicable provisions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5f200f1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s296e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Awarding of grants and contracts","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall ensure that grants and contracts under this subchapter are awarded on a competitive basis, as appropriate, to carry out innovative demonstration projects or provide for strategic workforce supplementation activities as needed to address national nursing needs, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5f200f2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s296e/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" addressing challenges, including through supporting training and education of nursing students, related to the distribution of the nursing workforce and existing or projected nursing workforce shortages in geographic areas that have been identified as having, or that are projected to have, a nursing shortage;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5f200f3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s296e/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increasing access to and the quality of health care services, including by supporting the training of professional registered nurses, advanced practice registered nurses, and advanced education nurses within community based settings and in a variety of health delivery system settings; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5f200f4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s296e/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" addressing the strategic goals and priorities identified by the Secretary and that are in accordance with this subchapter.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Contracts may be entered into under this subchapter with public or private entities as determined necessary by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5f200f5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s296e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information requirements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5f200f6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s296e/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Recipients of grants and contracts under this subchapter shall meet information requirements as specified by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5f200f7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s296e/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish procedures to ensure the annual evaluation of programs and projects operated by recipients of grants under this subchapter. Such procedures shall ensure that continued funding for such programs and projects will be conditioned upon the reporting of data and information demonstrating that satisfactory progress has been made by the program or project in meeting the performance outcome standards (as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s296a"},"text":"section 296a of this title","children":[],"tail":") of such program or project."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5f200f8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s296e/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training programs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Training programs conducted with amounts received under this subchapter shall meet applicable accreditation and quality standards.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5f200f9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s296e/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration of assistance","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5f200fa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s296e/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (2), in the case of an award to an entity of a grant, cooperative agreement, or contract under this subchapter, the period during which payments are made to the entity under the award may not exceed 5 years. The provision of payments under the award shall be subject to annual approval by the Secretary of the payments and subject to the availability of appropriations for the fiscal year involved to make the payments. This paragraph may not be construed as limiting the number of awards under the program involved that may be made to the entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5f200fb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s296e/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of an award to an entity of a grant, cooperative agreement, or contract under this subchapter, paragraph (1) shall apply only to the extent not inconsistent with any other provision of this subchapter that relates to the period during which payments may be made under the award.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5f200fc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s296e/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Peer review regarding certain programs","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5f200fd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s296e/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each application for a grant under this subchapter, except advanced nurse traineeship grants under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s296j/a/2"},"text":"section 296j(a)(2) of this title","children":[],"tail":", shall be submitted to a peer review group for an evaluation of the merits of the proposals made in the application. The Secretary may not approve such an application unless a peer review group has recommended the application for approval."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5f200fe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s296e/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Composition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each peer review group under this subsection shall be composed principally of individuals who are not officers or employees of the Federal Government, and have relevant expertise and experience. In providing for the establishment of peer review groups and procedures, the Secretary shall, except as otherwise provided, ensure sex, racial, ethnic, and geographic representation among the membership of such groups.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5f200ff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s296e/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This subsection shall be carried out by the Secretary acting through the Administrator of the Health Resources and Services Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5f20100-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s296e/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Analytic activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall ensure that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5f20101-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s296e/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cross-cutting workforce analytical activities are carried out as part of the workforce information and analysis activities under this subchapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5f20102-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s296e/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" discipline-specific workforce information is developed and analytical activities are carried out as part of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5f20103-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s296e/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the advanced education nursing activities under part B;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5f20104-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s296e/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the workforce diversity activities under part C; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5f20105-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s296e/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" basic nursing education and practice activities under part D.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5f20106-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s296e/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State and regional priorities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Activities under grants or contracts under this subchapter shall, to the extent practicable, be consistent with related Federal, State, or regional nursing professions program plans and priorities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5f20107-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s296e/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Filing of applications","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5f20108-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s296e/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Applications for grants or contracts under this subchapter may be submitted by health professions schools, schools of nursing, academic health centers, State or local governments, or other appropriate public or private nonprofit entities as determined appropriate by the Secretary in accordance with this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5f20109-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s296e/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" For-profit entities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding paragraph (1), a for-profit entity may be eligible for a grant or contract under this subchapter as determined appropriate by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5f2010a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s296e/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Biennial report on nursing workforce program improvements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2020-09-30"},"text":"September 30, 2020","children":[],"tail":", and biennially thereafter, the Secretary shall submit to the Committee on Health, Education, Labor, and Pensions of the Senate and the Committee on Energy and Commerce of the House of Representatives, a report that contains an assessment of the programs and activities of the Department of Health and Human Services related to enhancing the nursing workforce, including the extent to which programs and activities under this subchapter meet the identified goals and performance measures developed for the respective programs and activities, and the extent to which the Department coordinates with other Federal departments regarding programs designed to improve the nursing workforce."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5f2010b-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title VIII, § 806, as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/392/tI/s123/4"},"text":"Pub. L. 105–392, title I, § 123(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3565"},"text":"112 Stat. 3565","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/136/dA/tIII/s3404/a/4"},"text":"Pub. L. 116–136, div. A, title III, § 3404(a)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-03-27"},"text":"Mar. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/392"},"text":"134 Stat. 392","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb5f2010c-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb5f2010d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb5f2010e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 296e, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373/tVIII/s810"},"text":"act July 1, 1944, ch. 373, title VIII, § 810","children":[],"tail":", formerly § 806, as added "},{"tag":"date","attrib":{"date":"1964-09-04"},"text":"Sept. 4, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/88/581/s2"},"text":"Pub. L. 88–581, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/912"},"text":"78 Stat. 912","children":[],"tail":"; amended "},{"tag":"date","attrib":{"date":"1967-12-05"},"text":"Dec. 5, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/90/174/s12/a"},"text":"Pub. L. 90–174, § 12(a)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/541"},"text":"81 Stat. 541","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1968-08-16"},"text":"Aug. 16, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/90/490/tII/s211"},"text":"Pub. L. 90–490, title II, § 211","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/781"},"text":"82 Stat. 781","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1971-11-18"},"text":"Nov. 18, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/92/158/s4/a"},"text":"Pub. L. 92–158, § 4(a)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/470"},"text":"85 Stat. 470","children":[],"tail":"; renumbered § 810 and amended "},{"tag":"date","attrib":{"date":"1975-07-29"},"text":"July 29, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/94/63/tIX"},"text":"Pub. L. 94–63, title IX","children":[],"tail":", §§ 902(b), 915(a)–(c), 916(a), (b), 941(e), "},{"tag":"ref","attrib":{"href":"/us/stat/89/354"},"text":"89 Stat. 354","children":[],"tail":", 356, 358, 365; "},{"tag":"date","attrib":{"date":"1977-08-01"},"text":"Aug. 1, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/95/83/tIII/s307"},"text":"Pub. L. 95–83, title III, § 307","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":")(1)–(4), "},{"tag":"ref","attrib":{"href":"/us/stat/91/393"},"text":"91 Stat. 393","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1979-09-29"},"text":"Sept. 29, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/96/76/tI/s104"},"text":"Pub. L. 96–76, title I, § 104","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/579"},"text":"93 Stat. 579","children":[],"tail":", set forth provisions relating to computation, requirements, etc., respecting grants for institutional support, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/99/92"},"text":"Pub. L. 99–92","children":[],"tail":", §§ 9(a)(1), 10(a), "},{"tag":"date","attrib":{"date":"1985-08-16"},"text":"Aug. 16, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/400"},"text":"99 Stat. 400","children":[],"tail":", 402, effective "},{"tag":"date","attrib":{"date":"1985-10-01"},"text":"Oct. 1, 1985","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb5f2010f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/136/s3404/a/4/A"},"text":"Pub. L. 116–136, § 3404(a)(4)(A)","children":[],"tail":", substituted “as needed to address national nursing needs, including—”, pars. (1) to (3), and concluding provisions for “as needed to meet national nursing service goals and in accordance with this subchapter. Contracts may be entered into under this subchapter with public or private entities as determined necessary by the Secretary.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/136/s3404/a/4/B"},"text":"Pub. L. 116–136, § 3404(a)(4)(B)","children":[],"tail":", substituted “the reporting of data and information demonstrating that satisfactory progress has been made by the program or project in meeting the performance outcome standards (as described in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s296a"},"text":"section 296a of this title","children":[],"tail":") of such program or project.” for “a demonstration that satisfactory progress has been made by the program or project in meeting the objectives of the program or project.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/136/s3404/a/4/C"},"text":"Pub. L. 116–136, § 3404(a)(4)(C)","children":[],"tail":", inserted “, and have relevant expertise and experience” before period at end of first sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/136/s3404/a/4/D"},"text":"Pub. L. 116–136, § 3404(a)(4)(D)","children":[],"tail":", added subsec. (i)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
