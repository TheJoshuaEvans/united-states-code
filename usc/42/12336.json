{"tag":"section","attrib":{"id":"idbf6aee45-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12336"},"text":null,"children":[{"tag":"num","attrib":{"value":"12336"},"text":"§ 12336.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Independent State body","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf6aee46-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12336/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A State shall not be eligible to receive a grant from an allotment under section 12337 or 12338 of this title unless—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf6aee47-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12336/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the chief executive officer of such State designates an independent State body that is composed of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf6aee48-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12336/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cabinet level representatives from each agency of such State that has responsibilities for programs affecting young individuals who shall comprise a majority of the independent State body; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf6aee49-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12336/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" individuals appointed from among—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbf6aee4a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12336/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" private nonprofit providers of services to young individuals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf6aee4b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12336/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advocacy and citizens groups concerned with young individuals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf6aee4c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12336/a/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" committees of the legislature of such State that have responsibility for young individuals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf6aee4d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12336/a/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" leaders who are young individuals, including such leaders who are recipients of services provided under this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf6aee4e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12336/a/1/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" representatives of the business community;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf6aee4f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12336/a/1/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" representatives of employees of providers of services to young individuals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf6aee50-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12336/a/1/B/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" representatives of general purpose local government; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf6aee51-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12336/a/1/B/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" such staff as shall be necessary to—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbf6aee52-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12336/a/1/B/viii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop a State plan to be submitted to the Commissioner for approval under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12337"},"text":"section 12337 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbf6aee53-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12336/a/1/B/viii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" administer and monitor the State plan within such State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbf6aee54-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12336/a/1/B/viii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist in the coordination of all State activities related to the purpose of the chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbf6aee55-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12336/a/1/B/viii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serve as an effective and visible advocate for young individuals by reviewing and commenting on all State plans, budgets, and policies that affect such individuals and the families of such individuals by providing technical assistance to any agency, organization, association, or individual representing the needs of young individuals; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf6aee56-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12336/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the independent State body designated under paragraph (1)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf6aee57-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12336/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develops a system for the distribution within the State of funds received under sections 12337 and 12338 of this title by the chief executive officer;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf6aee58-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12336/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submits a description of such system to the Commissioner for review and comment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf6aee59-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12336/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" ensures that preference will be given in such distribution of funds to developing or supporting local service delivery systems that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbf6aee5a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12336/a/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide a range of services organized to tailor responses to needs rather than a predetermined array of services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf6aee5b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12336/a/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are rooted in and part of the communities that such systems are designed to serve as measured by the degree to which public and private community leaders and young individuals participate in the planning of such systems; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf6aee5c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12336/a/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrate an ability to develop systematic collaboration among service providers on behalf of children, youth and families, including joint planning, joint financing, joint service delivery, common intake and assessment, and other arrangements that promote more effective service systems for such individuals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf6aee5d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12336/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Existing entity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commissioner may approve a State plan in which the chief executive officer of the State designates as the independent State body an existing State entity that is comprised of the parties described in subsection (a) and that is authorized to conduct the same range of interagency planning and coordination activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf6aee5e-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/501/tIX/s930"},"text":"Pub. L. 101–501, title IX, § 930","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-03"},"text":"Nov. 3, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1270"},"text":"104 Stat. 1270","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf6aee5f-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbf6aee60-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbf6aee61-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1990-10-01"},"text":"Oct. 1, 1990","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/101/501/s1001/a"},"text":"section 1001(a) of Pub. L. 101–501","children":[],"tail":", set out as an Effective Date of 1990 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s8621"},"text":"section 8621 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
