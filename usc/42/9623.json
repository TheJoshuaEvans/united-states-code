{"tag":"section","attrib":{"id":"idbed257c5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9623"},"text":null,"children":[{"tag":"num","attrib":{"value":"9623"},"text":"§ 9623.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimbursement to local governments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbed257c6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9623/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any general purpose unit of local government for a political subdivision which is affected by a release or threatened release at any facility may apply to the President for reimbursement under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbed257c7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9623/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimbursement","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbed257c8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9623/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Temporary emergency measures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President is authorized to reimburse local community authorities for expenses incurred (before or after ","children":[{"tag":"date","attrib":{"date":"1986-10-17"},"text":"October 17, 1986","children":[],"tail":") in carrying out temporary emergency measures necessary to prevent or mitigate injury to human health or the environment associated with the release or threatened release of any hazardous substance or pollutant or contaminant. Such measures may include, where appropriate, security fencing to limit access, response to fires and explosions, and other measures which require immediate response at the local level."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbed257c9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9623/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Local funds not supplanted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Reimbursement under this section shall not supplant local funds normally provided for response.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbed257ca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9623/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of any reimbursement to any local authority under subsection (b)(1) may not exceed $25,000 for a single response. The reimbursement under this section with respect to a single facility shall be limited to the units of local government having jurisdiction over the political subdivision in which the facility is located.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbed257cb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9623/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedure","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Reimbursements authorized pursuant to this section shall be in accordance with rules promulgated by the Administrator within one year after ","children":[{"tag":"date","attrib":{"date":"1986-10-17"},"text":"October 17, 1986","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbed257cc-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/510/tI/s123"},"text":"Pub. L. 96–510, title I, § 123","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/499/tI/s123/a"},"text":"Pub. L. 99–499, title I, § 123(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-17"},"text":"Oct. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1688"},"text":"100 Stat. 1688","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
