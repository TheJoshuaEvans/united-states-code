{"tag":"section","attrib":{"id":"idc033469d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17244"},"text":null,"children":[{"tag":"num","attrib":{"value":"17244"},"text":"§ 17244.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Renewable Energy Innovation Manufacturing Partnership","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc033469e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17244/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall carry out a program, to be known as the Renewable Energy Innovation Manufacturing Partnership Program (referred to in this section as the “Program”), to make assistance awards to eligible entities for use in carrying out research, development, and demonstration relating to the manufacturing of renewable energy technologies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc033469f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17244/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Solicitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To carry out the Program, the Secretary shall annually conduct a competitive solicitation for assistance awards for an eligible project described in subsection (e).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc03346a0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17244/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of the Program are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc03346a1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17244/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop, or aid in the development of, advanced manufacturing processes, materials, and infrastructure;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc03346a2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17244/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to increase the domestic production of renewable energy technology and components; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc03346a3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17244/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to better coordinate Federal, State, and private resources to meet regional and national renewable energy goals through advanced manufacturing partnerships.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc03346a4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17244/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An entity shall be eligible to receive an assistance award under the Program to carry out an eligible project described in subsection (e) if the entity is composed of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc03346a5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17244/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 or more public or private nonprofit institutions or national laboratories engaged in research, development, demonstration, or technology transfer, that would participate substantially in the project; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc03346a6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17244/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 or more private entities engaged in the manufacturing or development of renewable energy system components (including solar energy, wind energy, biomass, geothermal energy, energy storage, or fuel cells).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc03346a7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17244/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible projects","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An eligible entity may use an assistance award provided under this section to carry out a project relating to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc03346a8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17244/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the conduct of studies of market opportunities for component manufacturing of renewable energy systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc03346a9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17244/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the conduct of multiyear applied research, development, demonstration, and deployment projects for advanced manufacturing processes, materials, and infrastructure for renewable energy systems; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc03346aa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17244/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other similar ventures, as approved by the Secretary, that promote advanced manufacturing of renewable technologies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc03346ab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17244/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria and guidelines","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish criteria and guidelines for the submission, evaluation, and funding of proposed projects under the Program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc03346ac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17244/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost sharing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16352"},"text":"Section 16352 of this title","children":[],"tail":" shall apply to a project carried out under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc03346ad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17244/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosure","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may, for a period of up to 5 years after an award is granted under this section, exempt from mandatory disclosure under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552"},"text":"section 552 of title 5","children":[],"tail":" (popularly known as the Freedom of Information Act) information that the Secretary determines would be a privileged or confidential trade secret or commercial or financial information under subsection (b)(4) of such section if the information had been obtained from a non-Government party."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc03346ae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17244/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sense of the Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It is the sense of the Congress that the Secretary should ensure that small businesses engaged in renewable manufacturing be given priority consideration for the assistance awards provided under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc03346af-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17244/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated out of funds already authorized to carry out this section $25,000,000 for each of fiscal years 2008 through 2013, to remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc03346b0-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/tVI/s656"},"text":"Pub. L. 110–140, title VI, § 656","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1703"},"text":"121 Stat. 1703","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc03346b1-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc03346b2-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc03346b3-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the date that is 1 day after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/s1601"},"text":"section 1601 of Pub. L. 110–140","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1824"},"text":"section 1824 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
