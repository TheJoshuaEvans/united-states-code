{"tag":"section","attrib":{"id":"idb52e6281-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280c–5"},"text":null,"children":[{"tag":"num","attrib":{"value":"280c–5"},"text":"§ 280c–5.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General provisions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb52e6282-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280c–5/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on administrative expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may not make a grant or cooperative agreement under sections ","children":[{"tag":"ref","attrib":{"idref":"fn002135"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002135"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “section”."}],"tail":" 280c–3 or 280c–4 of this title to an entity unless the entity agrees that not more than 5 percent of the grant or cooperative agreement will be expended for administrative expenses with respect to the grant or cooperative agreement."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb52e6283-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280c–5/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement of application","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may not make a grant under sections ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" 280c–3 or 280c–4 of this title to an entity unless the entity has submitted to the Secretary an application for the grant. The application shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb52e6284-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280c–5/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contain the description of intended expenditures;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb52e6285-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280c–5/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to carrying out the purpose for which the grant is to be made, provide assurances of compliance satisfactory to the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb52e6286-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280c–5/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" otherwise be in such form, be made in such manner, and contain such information and agreements as the Secretary determines to be necessary to carry out this subpart.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb52e6287-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280c–5/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluations and report by Secretary","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb52e6288-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280c–5/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for an evaluation of the activities for which an award is made under sections ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" 280c–3 or 280c–4 of this title; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb52e6289-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280c–5/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 1 year after the completion of such evaluations, submit to the Congress a report describing the findings made as a result of the evaluations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb52e628a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280c–5/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this subpart, the terms “Indian tribe” and “tribal organization” have the meanings given such terms in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1603"},"text":"section 1603 of title 25","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb52e628b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280c–5/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorizations of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of carrying out this subpart, there are authorized to be appropriated $20,000,000 for each of fiscal years 2020 through 2024 and $33,000,000 for each of fiscal years 2025 through 2029.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb52e628c-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"