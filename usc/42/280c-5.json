","attrib":{"href":"/us/stat/138/1662"},"text":"138 Stat. 1662","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb52e628d-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb52e628e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb52e628f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/142"},"text":"Pub. L. 118–142","children":[],"tail":" inserted “and $33,000,000 for each of fiscal years 2025 through 2029” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/406/s4/1"},"text":"Pub. L. 115–406, § 4(1)","children":[],"tail":", inserted “or cooperative agreement” after “grant” wherever appearing and substituted “sections 280c–3 or 280c–4 of this title to an entity unless the entity” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t42/s280c–3/a"},"text":"section 280c–3(a) of this title","children":[],"tail":" to a State unless the State” and “5 percent” for “10 percent”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/406/s4/4/A"},"text":"Pub. L. 115–406, § 4(4)(A)","children":[],"tail":", substituted “sections 280c–3 or 280c–4 of this title to an entity unless the entity” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t42/s280c–3/a"},"text":"section 280c–3(a) of this title","children":[],"tail":" to a State unless the State” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":