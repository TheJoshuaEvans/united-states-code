{"tag":"section","attrib":{"id":"idbff52c38-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16135"},"text":null,"children":[{"tag":"num","attrib":{"value":"16135"},"text":"§ 16135.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Outreach and incentives","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbff52c39-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16135/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of eligible technology","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “eligible technology” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbff52c3a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16135/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a verified technology; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff52c3b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16135/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an emerging technology.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff52c3c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16135/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technology transfer program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbff52c3d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16135/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall establish a program under which the Administrator—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbff52c3e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16135/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" informs stakeholders of the benefits of eligible technologies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff52c3f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16135/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develops nonfinancial incentives to promote the use of eligible technologies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff52c40-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16135/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible stakeholders","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Eligible stakeholders under this section include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbff52c41-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16135/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" equipment owners and operators;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff52c42-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16135/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" emission and pollution control technology manufacturers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff52c43-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16135/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" engine and equipment manufacturers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff52c44-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16135/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State and local officials responsible for air quality management;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff52c45-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16135/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" community organizations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff52c46-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16135/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" public health, educational, and environmental organizations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff52c47-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16135/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State implementation plans","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall develop appropriate guidance to provide credit to a State for emission reductions in the State created by the use of eligible technologies through a State implementation plan under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7410"},"text":"section 7410 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff52c48-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16135/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" International markets","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator, in coordination with the Department of Commerce and industry stakeholders, shall inform foreign countries with air quality problems of the potential of technology developed or used in the United States to provide emission reductions in those countries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbff52c49-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tVII/s795"},"text":"Pub. L. 109–58, title VII, § 795","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/843"},"text":"119 Stat. 843","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
