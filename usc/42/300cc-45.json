{"tag":"section","attrib":{"id":"idb6884d00-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–45"},"text":null,"children":[{"tag":"num","attrib":{"value":"300cc–45"},"text":"§ 300cc–45.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General provisions regarding Office","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb6884d01-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–45/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative support for Office","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Director of the National Institutes of Health, shall provide administrative support and support services to the Director of the Office and shall ensure that such support takes maximum advantage of existing administrative structures at the agencies of the National Institutes of Health.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6884d02-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–45/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 5 years after ","children":[{"tag":"date","attrib":{"date":"1993-06-10"},"text":"June 10, 1993","children":[],"tail":", the Secretary shall conduct an evaluation to—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6884d03-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–45/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determine the effect of this section on the planning and coordination of the AIDS research programs at the institutes, centers and divisions of the National Institutes of Health;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6884d04-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–45/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluate the extent to which this part has eliminated the duplication of administrative resources among such Institutes, centers and divisions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6884d05-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–45/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide recommendations concerning future alterations with respect to this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6884d06-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–45/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this part:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6884d07-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–45/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “AIDS activities” means AIDS research and other activities that relate to acquired immune deficiency syndrome.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6884d08-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–45/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “AIDS research” means research with respect to acquired immune deficiency syndrome.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6884d09-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–45/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Office” means the Office of AIDS Research.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6884d0a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–45/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Plan” means the plan required in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300cc–40c/a/1"},"text":"section 300cc–40c(a)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb6884d0b-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XXIII, § 2359, as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/43/tXVIII/s1803"},"text":"Pub. L. 103–43, title XVIII, § 1803","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-06-10"},"text":"June 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/198"},"text":"107 Stat. 198","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/482/tI/s104/b/2/F"},"text":"Pub. L. 109–482, title I, § 104(b)(2)(F)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-01-15"},"text":"Jan. 15, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3693"},"text":"120 Stat. 3693","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb6884d0c-3a70-11f1-ae07-e4213316b5fa"},"tex