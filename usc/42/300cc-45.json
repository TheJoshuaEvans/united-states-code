e only with respect to amounts appropriated for fiscal year 2007 or subsequent fiscal years, see "},{"tag":"ref","attrib":{"href":"/us/pl/109/482/s109"},"text":"section 109 of Pub. L. 109–482","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s281"},"text":"section 281 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
