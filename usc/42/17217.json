{"tag":"section","attrib":{"id":"idc02e6582-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17217"},"text":null,"children":[{"tag":"num","attrib":{"value":"17217"},"text":"§ 17217.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of other laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing in this part shall be construed as waiving, modifying, or superseding the applicability of any requirement under any environmental or other Federal or State law.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc02e6583-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/tVI/s638"},"text":"Pub. L. 110–140, title VI, § 638","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dZ/tIII/s3001/a"},"text":"Pub. L. 116–260, div. Z, title III, § 3001(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2486"},"text":"134 Stat. 2486","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
