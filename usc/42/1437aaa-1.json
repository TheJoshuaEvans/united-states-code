{"tag":"section","attrib":{"id":"idbb0c9d3d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437aaa–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1437aaa–1"},"text":"§ 1437aaa–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Planning grants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbb0c9d3e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437aaa–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to make planning grants to applicants for the purpose of developing homeownership programs under this subchapter. The amount of a planning grant under this section may not exceed $200,000, except that the Secretary may for good cause approve a grant in a higher amount.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb0c9d3f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437aaa–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Planning grants may be used for activities to develop homeownership programs (which may include programs for cooperative ownership), including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb0c9d40-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437aaa–1/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" development of resident management corporations and resident councils;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb0c9d41-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437aaa–1/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" training and technical assistance for applicants related to development of a specific homeownership program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb0c9d42-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437aaa–1/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" studies of the feasibility of a homeownership program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb0c9d43-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437aaa–1/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inspection for lead-based paint hazards, as required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4822/a"},"text":"section 4822(a) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb0c9d44-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437aaa–1/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preliminary architectural and engineering work;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb0c9d45-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437aaa–1/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" tenant and homebuyer counseling and training;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb0c9d46-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437aaa–1/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" planning for economic development, job training, and self-sufficiency activities that promote economic self-sufficiency of homebuyers and homeowners under the homeownership program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb0c9d47-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437aaa–1/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" development of security plans; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb0c9d48-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437aaa–1/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preparation of an application for an implementation grant under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb0c9d49-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437aaa–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb0c9d4a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437aaa–1/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form and procedures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An application for a planning grant shall be submitted by an applicant in such form and in accordance with such procedures as the Secretary shall establish.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb0c9d4b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437aaa–1/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall require that an application contain at a minimum—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbb0c9d4c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437aaa–1/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a request for a planning grant, specifying the activities proposed to be carried out, the schedule for completing the activities, the personnel necessary to complete the activities, and the amount of the grant requested;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb0c9d4d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437aaa–1/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the applicant and a statement of its qualifications;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb0c9d4e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437aaa–1/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identification and description of the public housing project or projects involved, and a description of the composition of the tenants, including family size and income;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb0c9d4f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437aaa–1/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a certification by the public official responsible for submitting the comprehensive housing affordability strategy under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12705"},"text":"section 12705 of this title","children":[],"tail":" that the proposed activities are consistent with the approved housing strategy of the State or unit of general local government within which the project is located (or, during the first 12 months after "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"November 28, 1990","children":[],"tail":", that the application is consistent with such other existing State or local housing plan or strategy that the Secretary shall determine to be appropriate); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb0c9d50-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437aaa–1/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a certification that the applicant will comply with the requirements of the Fair Housing Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3601"},"text":"42 U.S.C. 3601","children":[],"tail":" et seq.], title VI of the Civil Rights Act of 1964 ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2000d"},"text":"42 U.S.C. 2000d","children":[],"tail":" et seq.], "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s794"},"text":"section 794 of title 29","children":[],"tail":", and the Age Discrimination Act of 1975 ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s6101"},"text":"42 U.S.C. 6101","children":[],"tail":" et seq.], and will affirmatively further fair housing."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb0c9d51-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437aaa–1/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall, by regulation, establish selection criteria for a national competition for assistance under this section, which shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb0c9d52-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437aaa–1/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the qualifications or potential capabilities of the applicant;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb0c9d53-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437aaa–1/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent of tenant interest in the development of a homeownership program for the project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb0c9d54-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437aaa–1/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the potential of the applicant for developing a successful and affordable homeownership program and the suitability of the project for homeownership;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb0c9d55-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437aaa–1/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" national geographic diversity among projects for which applicants are selected to receive assistance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb0c9d56-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437aaa–1/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other factors that the Secretary shall require that (in the determination of the Secretary) are appropriate for purposes of carrying out the program established by this subchapter in an effective and efficient manner.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbb0c9d57-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1937-09-01/ch896"},"text":"Sept. 1, 1937, ch. 896","children":[],"tail":", title III, § 302, as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/625/tIV/s411"},"text":"Pub. L. 101–625, title IV, § 411","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4149"},"text":"104 Stat. 4149","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/550/tX/s1012/h/1"},"text":"Pub. L. 102–550, title X, § 1012(h)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3906"},"text":"106 Stat. 3906","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbb0c9d58-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbb0c9d59-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbb0c9d5a-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Fair Housing Act, referred to in subsec. (c)(2)(E), is title VIII of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/284"},"text":"Pub. L. 90–284","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-04-11"},"text":"Apr. 11, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/81"},"text":"82 Stat. 81","children":[],"tail":", which is classified principally to subchapter I (§ 3601 et seq.) of chapter 45 of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3601"},"text":"section 3601 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Civil Rights Act of 1964, referred to in subsec. (c)(2)(E), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/352"},"text":"Pub. L. 88–352","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-07-02"},"text":"July 2, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/241"},"text":"78 Stat. 241","children":[],"tail":". Title VI of the Act is classified generally to subchapter V (§ 2000d et seq.) of chapter 21 of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2000a"},"text":"section 2000a of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Age Discrimination Act of 1975, referred to in subsec. (c)(2)(E), is title III of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/135"},"text":"Pub. L. 94–135","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-11-28"},"text":"Nov. 28, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/728"},"text":"89 Stat. 728","children":[],"tail":", which is classified generally to chapter 76 (§ 6101 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s6101"},"text":"section 6101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbb0c9d5b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—Subsec. (b)(4) to (9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550"},"text":"Pub. L. 102–550","children":[],"tail":" added par. (4) and redesignated former pars. (4) to (8) as (5) to (9), respectively."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
