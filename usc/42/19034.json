{"tag":"section","attrib":{"id":"idc075f5c2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19034"},"text":null,"children":[{"tag":"num","attrib":{"value":"19034"},"text":"§ 19034.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Online resource","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Director shall develop an online resource hosted on the Foundation’s website containing up-to-date information, tailored for institutions and individual researchers, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc075f5c3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19034/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an explanation of Foundation research security policies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc075f5c4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19034/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" unclassified guidance on potential security risks that threaten research integrity and other risks to the research enterprise;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc075f5c5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19034/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" examples of beneficial international collaborations and how such collaborations differ from foreign government interference efforts that threaten research integrity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc075f5c6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19034/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" best practices for mitigating security risks that threaten research integrity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc075f5c7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19034/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" additional reference materials, including tools that assist organizations seeking Foundation funding and awardees in information disclosure to the Foundation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc075f5c8-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/tIII/s10334"},"text":"Pub. L. 117–167, div. B, title III, § 10334","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1552"},"text":"136 Stat. 1552","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
