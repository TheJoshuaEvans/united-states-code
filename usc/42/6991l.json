{"tag":"section","attrib":{"id":"idbdeb04ef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6991l"},"text":null,"children":[{"tag":"num","attrib":{"value":"6991l"},"text":"§ 6991l.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tanks on tribal lands","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbdeb04f0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6991l/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Strategy","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator, in coordination with Indian tribes, shall, not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":", develop and implement a strategy—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbdeb04f1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6991l/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" giving priority to releases that present the greatest threat to human health or the environment, to take necessary corrective action in response to releases from leaking underground storage tanks located wholly within the boundaries of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbdeb04f2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6991l/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an Indian reservation; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbdeb04f3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6991l/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other area under the jurisdiction of an Indian tribe; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdeb04f4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6991l/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to implement and enforce requirements concerning underground storage tanks located wholly within the boundaries of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbdeb04f5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6991l/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an Indian reservation; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbdeb04f6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6991l/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other area under the jurisdiction of an Indian tribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdeb04f7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6991l/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":", the Administrator shall submit to Congress a report that summarizes the status of implementation and enforcement of this subchapter in areas located wholly within—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbdeb04f8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6991l/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the boundaries of Indian reservations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdeb04f9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6991l/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other areas under the jurisdiction of an Indian tribe.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The Administrator shall make the report under this subsection available to the public.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdeb04fa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6991l/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Not a safe harbor","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section does not relieve any person from any obligation or requirement under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdeb04fb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6991l/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section applies to any underground storage tank that is located in an area under the jurisdiction of a State, or that is subject to regulation by a State, as of ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbdeb04fc-3a70-1