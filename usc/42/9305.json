{"tag":"section","attrib":{"id":"idbeb35e1d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9305"},"text":null,"children":[{"tag":"num","attrib":{"value":"9305"},"text":"§ 9305.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Magnetic fusion engineering center","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbeb35e1e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9305/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Development plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall develop a plan for the creation of a national magnetic fusion engineering center for the purpose of accelerating fusion technology development via the concentration and coordination of major magnetic fusion engineering devices and associated activities at such a national center.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbeb35e1f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9305/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Factors considered in formulation of development plan","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In developing the plan, the Secretary shall include relevant factors including, but not limited to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbeb35e20-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9305/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means of saving cost and time through the establishment of the national center relative to the cost and schedule currently projected for the program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbeb35e21-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9305/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means of providing common facilities to be shared by many magnetic fusion concepts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbeb35e22-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9305/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assessment of the environmental and safety-related aspects of the national center;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbeb35e23-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9305/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provisions for international cooperation in magnetic fusion activities at the national center;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbeb35e24-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9305/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provision of access to facilities for the broader technical involvement of domestic industry and universities in the magnetic fusion energy program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbeb35e25-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9305/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" siting criteria for the national center including a list of potential sites;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbeb35e26-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9305/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the advisability of establishing such a center considering all factors, including the alternative means and associated costs of pursuing such technology; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbeb35e27-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9305/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" changes in the management structure of the magnetic fusion program to allow more effective direction of activities related to the national center.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbeb35e28-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9305/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congressional committees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall submit not later than ","children":[{"tag":"date","attrib":{"date":"1981-07-01"},"text":"July 1, 1981","children":[],"tail":", a report to the House Committee on Science and Technology and the Senate Committee on Energy and Natural Resources characterizing the plan and setting forth the steps necessary for implementation of the plan, including any steps already implemented."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbeb35e29-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/386/s6"},"text":"Pub. L. 96–386, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-07"},"text":"Oct. 7, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1541"},"text":"94 Stat. 1541","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbeb35e2a-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbeb35e2b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idbeb35e2c-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Science and Technology of House of Representatives changed to Committee on Science, Space, and Technology of House of Representatives by House Resolution No. 5, One Hundred Twelfth Congress, ","children":[{"tag":"date","attrib":{"date":"2011-01-05"},"text":"Jan. 5, 2011","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
