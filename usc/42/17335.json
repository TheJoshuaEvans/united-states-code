{"tag":"section","attrib":{"id":"idc0359155-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17335"},"text":null,"children":[{"tag":"num","attrib":{"value":"17335"},"text":"§ 17335.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Actions by United States Trade and Development Agency","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc0359156-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17335/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance authorized","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director of the Trade and Development Agency shall establish or support policies that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0359157-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17335/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" proactively seek opportunities to fund projects that involve the utilization of clean and efficient energy technologies, including in trade capacity building and capital investment projects;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0359158-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17335/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" where appropriate, advance the utilization of clean and efficient energy technologies, particularly to countries that have the potential for significant reduction in greenhouse gas emissions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0359159-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17335/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recruit and retain individuals with appropriate expertise or experience in clean, renewable, and efficient energy technologies to identify and evaluate opportunities for projects that involve clean and efficient energy technologies and services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc035915a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17335/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall include in the annual report on the activities of the Trade and Development Agency required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2421/d"},"text":"section 2421(d) of title 22","children":[],"tail":" a description of the activities carried out to implement this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc035915b-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/tIX/s915"},"text":"Pub. L. 110–140, title IX, § 915","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1727"},"text":"121 Stat. 1727","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc035915c-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc035915d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc035915e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the date that is 1 day after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/s1601"},"text":"section 1601 of Pub. L. 110–140","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1824"},"text":"section 1824 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
