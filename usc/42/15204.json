{"tag":"section","attrib":{"id":"idbfdfd089-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15204"},"text":null,"children":[{"tag":"num","attrib":{"value":"15204"},"text":"§ 15204.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfdfd08a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15204/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public safety officer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “public safety officer” means a person serving a public agency, with or without compensation, as a firefighter, law enforcement officer, or emergency services officer, as determined by the Attorney General. For the purposes of this paragraph, the term “law enforcement officer” includes a person who is a corrections or court officer or a civil defense officer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfdfd08b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15204/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State” means each of the several States of the United States, the District of Columbia, the Commonwealth of Puerto Rico, the Virgin Islands, Guam, American Samoa, and the Commonwealth of the Northern Mariana Islands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfdfd08c-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/12/s5"},"text":"Pub. L. 107–12, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-05-30"},"text":"May 30, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/22"},"text":"115 Stat. 22","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbfdfd08d-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbfdfd08e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbfdfd08f-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in introductory provisions, was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/12"},"text":"Pub. L. 107–12","children":[],"tail":", May. 30, 2001, "},{"tag":"ref","attrib":{"href":"/us/stat/115/20"},"text":"115 Stat. 20","children":[],"tail":", known as the Public Safety Officer Medal of Valor Act of 2001, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s15201"},"text":"section 15201 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
