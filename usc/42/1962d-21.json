{"tag":"section","attrib":{"id":"idbbac5edd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1962d–21"},"text":null,"children":[{"tag":"num","attrib":{"value":"1962d–21"},"text":"§ 1962d–21.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" John Glenn Great Lakes basin program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbbac5ede-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1962d–21/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Strategic plans","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbbac5edf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1962d–21/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall conduct a comprehensive study of the Great Lakes region to ensure the future use, management, and protection of water resources and related resources of the Great Lakes basin.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbac5ee0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1962d–21/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbbac5ee1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1962d–21/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As expeditiously as possible, but not later than 3 years after ","children":[{"tag":"date","attrib":{"date":"1999-08-17"},"text":"August 17, 1999","children":[],"tail":", and every 2 years thereafter, the Secretary shall submit to the Committee on Transportation and Infrastructure of the House of Representatives and the Committee on Environment and Public Works of the Senate a report outlining a strategic plan for Corps of Engineers programs and proposed Corps of Engineers projects in the Great Lakes basin."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbbac5ee2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1962d–21/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The plan shall include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbbac5ee3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1962d–21/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" details of projects in the Great Lakes region relating to—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbbac5ee4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1962d–21/a/2/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" navigation improvements, maintenance, and operations for commercial and recreational vessels;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbbac5ee5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1962d–21/a/2/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" environmental restoration activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbbac5ee6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1962d–21/a/2/B/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" water level maintenance activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbbac5ee7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1962d–21/a/2/B/i/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" technical and planning assistance to States and remedial action planning committees;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbbac5ee8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1962d–21/a/2/B/i/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sediment transport analysis, sediment management planning, and activities to support prevention of excess sediment loadings;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbbac5ee9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1962d–21/a/2/B/i/VI"},"text":null,"children":[{"tag":"num","attrib":{"value":"VI"},"text":"(VI)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" flood damage reduction and shoreline erosion prevention; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbbac5eea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1962d–21/a/2/B/i/VII"},"text":null,"children":[{"tag":"num","attrib":{"value":"VII"},"text":"(VII)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all other relevant activities of the Corps of Engineers; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbbac5eeb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1962d–21/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an analysis of factors limiting use of programs and authorities of the Corps of Engineers in existence on ","children":[{"tag":"date","attrib":{"date":"1999-08-17"},"text":"August 17, 1999","children":[],"tail":", in the Great Lakes basin, including the need for new or modified authorities."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbac5eec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1962d–21/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this section $1,000,000 for the period of fiscal years 2000 through 2003.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbbac5eed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1962d–21/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Great Lakes biohydrological information","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbbac5eee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1962d–21/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inventory","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbbac5eef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1962d–21/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"1999-08-17"},"text":"August 17, 1999","children":[],"tail":", the Secretary shall request each Federal agency that may possess information relevant to the Great Lakes biohydrological system to provide an inventory of all such information in the possession of the agency."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbbac5ef0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1962d–21/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relevant information","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purpose of subparagraph (A), relevant information includes information on—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbbac5ef1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1962d–21/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ground and surface water hydrology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbbac5ef2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1962d–21/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" natural and altered tributary dynamics;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbbac5ef3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1962d–21/b/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" biological aspects of the system influenced by and influencing water quantity and water movement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbbac5ef4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1962d–21/b/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meteorological projections and the impacts of weather conditions on Great Lakes water levels; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbbac5ef5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1962d–21/b/1/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other Great Lakes biohydrological system data relevant to sustainable water use management.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbac5ef6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1962d–21/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbbac5ef7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1962d–21/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 18 months after ","children":[{"tag":"date","attrib":{"date":"1999-08-17"},"text":"August 17, 1999","children":[],"tail":", the Secretary, in consultation with the States, Indian tribes, and Federal agencies, and after requesting information from the provinces and the federal government of Canada, shall—"}],"tail":null},{"tag":"clause","attrib":{"id":"idbbac5ef8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1962d–21/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compile the inventories of information;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbbac5ef9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1962d–21/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" analyze the information for consistency and gaps; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbbac5efa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1962d–21/b/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit to Congress, the International Joint Commission, and the Great Lakes States a report that includes recommendations on ways to improve the information base on the biohydrological dynamics of the Great Lakes ecosystem as a whole, so as to support environmentally sound decisions regarding diversions and consumptive uses of Great Lakes water.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbbac5efb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1962d–21/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recommendations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The recommendations in the report under subparagraph (A) shall include recommendations relating to the resources and funds necessary for implementing improvement of the information base.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbbac5efc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1962d–21/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Considerations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In developing the report under subparagraph (A), the Secretary, in cooperation with the Secretary of State, the Secretary of Transportation, and the heads of other agencies as appropriate, shall consider and report on the status of the issues described and recommendations made in—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbbac5efd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1962d–21/b/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Report of the International Joint Commission to the Governments of the United States and Canada under the 1977 reference issued in 1985; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbbac5efe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1962d–21/b/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the 1993 Report of the International Joint Commission to the Governments of Canada and the United States on Methods of Alleviating Adverse Consequences of Fluctuating Water Levels in the Great Lakes St. Lawrence Basin.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbbac5eff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1962d–21/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Great Lakes recreational boating","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 18 months after ","children":[{"tag":"date","attrib":{"date":"1999-08-17"},"text":"August 17, 1999","children":[],"tail":", the Secretary, using information and studies in existence on "},{"tag":"date","attrib":{"date":"1999-08-17"},"text":"August 17, 1999","children":[],"tail":", to the extent practicable, and in cooperation with the Great Lakes States, shall submit to Congress a report detailing the economic benefits of recreational boating in the Great Lakes basin, particularly at harbors benefiting from operation and maintenance projects of the Corps of Engineers."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbbac5f00-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1962d–21/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In undertaking activities under this section, the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbbac5f01-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1962d–21/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage public participation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbac5f02-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1962d–21/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cooperate, and, as appropriate, collaborate, with Great Lakes States, tribal governments, and Canadian federal, provincial, and tribal governments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbbac5f03-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1962d–21/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Water use activities and policies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may provide technical assistance to the Great Lakes States to develop interstate guidelines to improve the consistency and efficiency of State-level water use activities and policies in the Great Lakes basin.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbbac5f04-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1962d–21/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost sharing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may seek and accept funds from non-Federal entities to be used to pay up to 25 percent of the cost of carrying out subsections (b), (c), (d), and (e).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbbac5f05-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1962d–21/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In-kind contributions for study","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The non-Federal interest may provide up to 100 percent of the non-Federal share required under subsection (f) in the form of in-kind services and materials.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbbac5f06-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/53/tIV/s455"},"text":"Pub. L. 106–53, title IV, § 455","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-08-17"},"text":"Aug. 17, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/330"},"text":"113 Stat. 330","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/114/tIV/s4001"},"text":"Pub. L. 110–114, title IV, § 4001","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-11-08"},"text":"Nov. 8, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1173"},"text":"121 Stat. 1173","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbbac5f07-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbbac5f08-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbbac5f09-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Water Resources Development Act of 1999, and not as part of the Water Resources Planning Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbbac5f0a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2007—Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/114"},"text":"Pub. L. 110–114","children":[],"tail":" added subsec. (g)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbbac5f0b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idbbac5f0c-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Army, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/53/s2"},"text":"section 2 of Pub. L. 106–53","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2201"},"text":"section 2201 of Title 33","children":[],"tail":", Navigation and Navigable Waters."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
