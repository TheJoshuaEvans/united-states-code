{"tag":"section","attrib":{"id":"idbc44f697-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3020b"},"text":null,"children":[{"tag":"num","attrib":{"value":"3020b"},"text":"§ 3020b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reduction of paperwork","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In order to reduce unnecessary, duplicative, or disruptive demands for information, the Assistant Secretary, in consultation with State agencies and other appropriate agencies and organizations, shall continually review and evaluate all requests by the Administration for information under this chapter and take such action as may be necessary to reduce the paperwork required under this chapter. The Assistant Secretary shall request only such information as the Assistant Secretary deems essential to carry out the objectives and provisions of this chapter and, in gathering such information, shall make use of uniform service definitions to the extent that such definitions are available.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbc44f698-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/73/tII/s211"},"text":"Pub. L. 89–73, title II, § 211","children":[],"tail":", formerly § 212, as added "},{"tag":"ref","attrib":{"href":"/us/pl/95/478/tI/s102/i"},"text":"Pub. L. 95–478, title I, § 102(i)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-18"},"text":"Oct. 18, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1515"},"text":"92 Stat. 1515","children":[],"tail":"; renumbered § 211, "},{"tag":"ref","attrib":{"href":"/us/pl/97/115/s2/e/2"},"text":"Pub. L. 97–115, § 2(e)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-12-29"},"text":"Dec. 29, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1596"},"text":"95 Stat. 1596","ch