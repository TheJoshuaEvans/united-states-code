{"tag":"section","attrib":{"id":"idbd03b251-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5108"},"text":null,"children":[{"tag":"num","attrib":{"value":"5108"},"text":"§ 5108.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Monitoring and oversight","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary shall conduct monitoring to ensure that each State that receives a grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5106a"},"text":"section 5106a of this title","children":[],"tail":" is in compliance with the requirements of "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5106a/b"},"text":"section 5106a(b) of this title","children":[],"tail":", which—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd03b252-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5108/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd03b253-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5108/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be in addition to the review of the State plan upon its submission under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5106a/b/1/A"},"text":"section 5106a(b)(1)(A) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd03b254-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5108/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include monitoring of State policies and procedures required under clauses (ii) and (iii) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5106a/b/2/B"},"text":"section 5106a(b)(2)(B) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd03b255-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5108/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" may include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd03b256-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5108/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a comparison of activities carried out by the State to comply with the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5106a/b"},"text":"section 5106a(b) of this title","children":[],"tail":" with the State plan most recently approved under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s629b"},"text":"section 629b of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd03b257-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5108/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a review of information available on the website of the State relating to its compliance with the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5106a/b"},"text":"section 5106a(b) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd03b258-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5108/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" site visits, as may be necessary to carry out such monitoring; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd03b259-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5108/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a review of information available in the State’s Annual Progress and Services Report most recently submitted under section 1357.16 of title 45, Code of Federal Regulations (or successor regulations).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd03b25a-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/247/tI/s114"},"text":"Pub. L. 93–247, title I, § 114","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/198/tV/s503/d/1"},"text":"Pub. L. 114–198, title V, § 503(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-07-22"},"text":"July 22, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/730"},"text":"130 Stat. 730","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
