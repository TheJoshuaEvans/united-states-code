{"tag":"section","attrib":{"id":"idbf2cfad0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10702"},"text":null,"children":[{"tag":"num","attrib":{"value":"10702"},"text":"§ 10702.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of Institute; duties","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf2cfad1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10702/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment; purpose; incorporation; powers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established a private nonprofit corporation which shall be known as the State Justice Institute. The purpose of the Institute shall be to further the development and adoption of improved judicial administration in State courts in the United States. The Institute may be incorporated in any State pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s10703/a/6"},"text":"section 10703(a)(6) of this title","children":[],"tail":". To the extent consistent with the provisions of this chapter, the Institute may exercise the powers conferred upon a nonprofit corporation by the laws of the State in which it is incorporated."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf2cfad2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10702/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Institute shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf2cfad3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10702/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" direct a national program of assistance designed to assure each person ready access to a fair and effective system of justice by providing funds to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf2cfad4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10702/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State courts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf2cfad5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10702/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" national organizations which support and are supported by State courts; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf2cfad6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10702/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other nonprofit organization that will support and achieve the purposes of this chapter;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf2cfad7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10702/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" foster coordination and cooperation with the Federal judiciary in areas of mutual concern;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf2cfad8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10702/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote recognition of the importance of the separation of powers doctrine to an independent judiciary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf2cfad9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10702/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage education for judges and support personnel of State court systems through national and State organizations, including universities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf2cfada-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10702/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duplication of functions; responsibility of State agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Institute shall not duplicate functions adequately performed by existing nonprofit organizations and shall promote, on the part of agencies of State judicial administration, responsibility for the success and effectiveness of State court improvement programs supported by Federal funding.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf2cfadb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10702/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maintenance of offices in State of incorporation; agent for receipt of service of process","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Institute shall maintain its principal offices in the State in which it is incorporated and shall maintain therein a designated agent to accept service of process for the Institute. Notice to or service upon the agent shall be deemed notice to or service upon the Institute.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf2cfadc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10702/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tax status of Institute and programs assisted thereby","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Institute, and any program assisted by the Institute, shall be eligible to be treated as an organization described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s170/c/2/B"},"text":"section 170(c)(2)(B) of title 26","children":[],"tail":" and as an organization described in "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s501/c/3"},"text":"section 501(c)(3) of title 26","children":[],"tail":" which is exempt from taxation under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s501/a"},"text":"section 501(a) of title 26","children":[],"tail":". If such treatments are conferred in accordance with the provisions of title 26, the Institute, and programs assisted by the Institute, shall be subject to all provisions of title 26 relevant to the conduct of organizations exempt from taxation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf2cfadd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10702/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules, regulations, etc.; notice and comment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Institute shall afford notice and reasonable opportunity for comment to interested parties prior to issuing rules, regulations, guidelines, and instructions under this chapter, and it shall publish in the Federal Register all rules, regulations, guidelines, and instructions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf2cfade-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/620/tII/s203"},"text":"Pub. L. 98–620, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-11-08"},"text":"Nov. 8, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3336"},"text":"98 Stat. 3336","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s2"},"text":"Pub. L. 99–514, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2095"},"text":"100 Stat. 2095","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tVII/s7321/b/1"},"text":"Pub. L. 100–690, title VII, § 7321(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4466"},"text":"102 Stat. 4466","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/702/tVI/s601"},"text":"Pub. L. 100–702, title VI, § 601","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-19"},"text":"Nov. 19, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4652"},"text":"102 Stat. 4652","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/528/s3/1"},"text":"Pub. L. 102–528, § 3(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-27"},"text":"Oct. 27, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3462"},"text":"106 Stat. 3462","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf2cfadf-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf2cfae0-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbf2cfae1-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsecs. (a), (b)(1)(C), and (f), was in the original “this title”, meaning title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/620"},"text":"Pub. L. 98–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-11-08"},"text":"Nov. 8, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3336"},"text":"98 Stat. 3336","children":[],"tail":", known as the State Justice Institute Act of 1984, which is classified principally to this chapter. For complete classification of title II to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s10701"},"text":"section 10701 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbf2cfae2-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/528"},"text":"Pub. L. 102–528","children":[],"tail":" struck out at end “The publication of a substantive rule shall not be made less than thirty days before the effective date of such rule, except as otherwise provided by the Institute for good cause found and published with the rule.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690"},"text":"Pub. L. 100–690","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/100/702"},"text":"Pub. L. 100–702","children":[],"tail":" made substantially identical amendments, striking out “, at least thirty days prior to their effective date,” after “Federal Register” and inserting sentence at end relating to publication of a substantive rule."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" substituted “Internal Revenue Code of 1986” for “Internal Revenue Code of 1954” wherever appearing, which for purposes of codification was translated as “title 26” thus requiring no change in text."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbf2cfae3-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbf2cfae4-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1985-10-01"},"text":"Oct. 1, 1985","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/620/s216"},"text":"section 216 of Pub. L. 98–620","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s10701"},"text":"section 10701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbf2cfae5-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Battered Women’s Testimony","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/527"},"text":"Pub. L. 102–527","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-27"},"text":"Oct. 27, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3459"},"text":"106 Stat. 3459","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/527"},"text":"\n","children":[{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“SECTION 1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" SHORT TITLE.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"“This Act may be cited as the ‘Battered Women’s Testimony Act of 1992’.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“SEC. 2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" AUTHORITY OF STATE JUSTICE INSTITUTE.","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"“The State Justice Institute shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" collect nationwide and analyze information regarding—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the admissibility and quality of expert testimony on the experiences of battered women offered as part of the defense in criminal cases under State law, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sources of, and methods to obtain, funds to pay costs incurred to provide such testimony, particularly in cases involving indigent women defendants,","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" develop training materials to assist—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" battered women, operators of domestic violence shelters, battered women’s advocates, and attorneys to use such expert testimony in appropriate cases, particularly appropriate cases involving indigent women defendants, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" individuals with expertise in the experiences of battered women to develop skills appropriate to providing such expert testimony, and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disseminate such information and such training materials, and provide related technical assistance, to battered women, such operators, such advocates, such attorneys, and such individuals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“SEC. 3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ADMINISTRATIVE PROVISIONS.","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"“For purposes of this Act—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subsections (d) and (e) of section 206 of the State Justice Institute Act of 1984 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s10705/d"},"text":"42 U.S.C. 10705(d)","children":[],"tail":", (e)], and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subsections (a) and (b) of section 207 of such Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s10706/a"},"text":"42 U.S.C. 10706(a)","children":[],"tail":", (b)],"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall apply in the same manner as such subsections apply with respect to grants and contracts made under such Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s10701"},"text":"42 U.S.C. 10701","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“SEC. 4.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" AUTHORIZATION OF APPROPRIATIONS.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"“There is authorized to be appropriated $600,000 to carry out this Act.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
