"attrib":{"href":"/us/pl/104/193"},"text":"Pub. L. 104–193","children":[],"tail":" added subsec. (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (a)(2)(B)(iii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" substituted “Internal Revenue Code of 1986” for “Internal Revenue Code of 1954”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369"},"text":"Pub. L. 98–369","children":[],"tail":" substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t31/s6503"},"text":"section 6503 of title 31","children":[],"tail":"” for “section 203 of the Intergovernmental Cooperation Act of 1968 ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4213"},"text":"42 U.S.C. 4213","children":[],"tail":")”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbaa85d1f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbaa85d20-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369"},"text":"Pub. L. 98–369","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", but not to be construed as changing or affecting any right, liability, status, or interpretation which existed (under the provisions of law involved) before that date, see "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/s2664/b"},"text":"section 2664(b) of Pub. L. 98–369","children":[],"tail":", set out as a note under "},{"