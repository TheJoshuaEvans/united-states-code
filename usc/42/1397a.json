{"tag":"section","attrib":{"id":"idbaa85d07-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1397a"},"text":"§ 1397a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments to States","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbaa85d08-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount; covered services","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbaa85d09-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each State shall be entitled to payment under this division for each fiscal year in an amount equal to its allotment for such fiscal year, to be used by such State for services directed at the goals set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1397"},"text":"section 1397 of this title","children":[],"tail":", subject to the requirements of this division."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaa85d0a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of paragraph (1)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbaa85d0b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397a/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" services which are directed at the goals set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1397"},"text":"section 1397 of this title","children":[],"tail":" include, but are not limited to, child care services, protective services for children and adults, services for children and adults in foster care, services related to the management and maintenance of the home, day care services for adults, transportation services, family planning services, training and related services, employment services, information, referral, and counseling services, the preparation and delivery of meals, health support services and appropriate combinations of services designed to meet the special needs of children, the aged, the mentally retarded, the blind, the emotionally disturbed, the physically handicapped, and alcoholics and drug addicts; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaa85d0c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397a/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" expenditures for such services may include expenditures for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbaa85d0d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397a/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" administration (including planning and evaluation);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbaa85d0e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397a/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" personnel training and retraining directly related to the provision of those services (including both short- and long-term training at educational institutions through grants to such institutions or by direct financial assistance to students enrolled in such institutions); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbaa85d0f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397a/a/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conferences or workshops, and training or retraining through grants to nonprofit organizations within the meaning of section 501(c)(3) of the Internal Revenue Code of 1986 or to individuals with social services expertise, or through financial assistance to individuals participating in such conferences, workshops, and training or retraining (and this clause shall apply with respect to all persons involved in the delivery of such services).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbaa85d10-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall make payments in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s6503"},"text":"section 6503 of title 31","children":[],"tail":" to each State from its allotment for use under this division."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbaa85d11-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expenditure of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Payments to a State from its allotment for any fiscal year must be expended by the State in such fiscal year or in the succeeding fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbaa85d12-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfers of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State may transfer up to 10 percent of its allotment under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1397b"},"text":"section 1397b of this title","children":[],"tail":" for any fiscal year for its use for that year under other provisions of Federal law providing block grants for support of health services, health promotion and disease prevention activities, or low-income home energy assistance (or any combination of those activities). Amounts allotted to a State under any provisions of Federal law referred to in the preceding sentence and transferred by a State for use in carrying out the purposes of this division shall be treated as if they were paid to the State under this division but shall not affect the computation of the State’s allotment under this division. The State shall inform the Secretary of any such transfer of funds."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbaa85d13-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of portion of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State may use a portion of the amounts described in subsection (a) for the purpose of purchasing technical assistance from public or private entities if the State determines that such assistance is required in developing, implementing, or administering programs funded under this division.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbaa85d14-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to use vouchers","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A State may use funds provided under this division to provide vouchers, for services directed at the goals set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1397"},"text":"section 1397 of this title","children":[],"tail":", to families, including—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbaa85d15-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397a/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" families who have become ineligible for assistance under a State program funded under part A of subchapter IV by reason of a durational limit on the provision of such assistance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaa85d16-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397a/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" families denied cash assistance under the State program funded under part A of subchapter IV for a child who is born to a member of the family who is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbaa85d17-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397a/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a recipient of assistance under the program; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaa85d18-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397a/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a person who received such assistance at any time during the 10-month period ending with the birth of the child.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbaa85d19-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title XX, § 2002, as added "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tXXIII/s2352/a"},"text":"Pub. L. 97–35, title XXIII, § 2352(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/867"},"text":"95 Stat. 867","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dB/tVI/s2663/h/1"},"text":"Pub. L. 98–369, div. B, title VI, § 2663(h)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1169"},"text":"98 Stat. 1169","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s2"},"text":"Pub. L. 99–514, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2095"},"text":"100 Stat. 2095","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/193/tIX/s908/b"},"text":"Pub. L. 104–193, title IX, § 908(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-22"},"text":"Aug. 22, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2351"},"text":"110 Stat. 2351","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tVI/s6703/d/1/B"},"text