5/291"},"text":"Pub. L. 95–291","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-06-12"},"text":"June 12, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/304"},"text":"92 Stat. 304","children":[],"tail":", authorized appropriations for payments to States in settlement of unpaid claims of States against the United States for reimbursement of expenditures made by States prior to "},{"tag":"date","attrib":{"date":"1975-10-01"},"text":"Oct. 1, 1975","children":[],"tail":", for services and administrative costs under a State plan pursuant to specific subchapters of this chapter, provided schedules for payment of a claim asserted prior to the ninety-first day after "},{"tag":"date","attrib":{"date":"1978-06-12"},"text":"June 12, 1978","children":[],"tail":", depending on when the claim was asserted, barred other claims and certain claims of the United States for recovery, provided for review of determinations, barred judicial review, and provided for allotment of appropriations for claims."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbaa85d23-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Payments to States for Fiscal Period Beginning ","children":[{"tag":"date","attrib":{"date":"1976-07-01"},"text":"July 1, 1976","children":[],"tail":", and Ending "},{"tag":"date","attrib":{"date":"1976-09-30"},"text":"September 30, 1976","children":[],"tail":", and Fiscal Years Ending "},{"tag":"date","attrib":{"date":"1977-09-30"},"text":"September 30, 1977","children":[],"tail":", 1978, and 1979, Computation Amounts, Limitations, Etc."}],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/401/s3"},"text":"Pub. L. 94–401, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-09-07"},"text":"Sept. 7, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1215"},"text":"90 Stat.