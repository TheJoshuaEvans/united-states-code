{"tag":"section","attrib":{"id":"idb575f331-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285g–6"},"text":null,"children":[{"tag":"num","attrib":{"value":"285g–6"},"text":"§ 285g–6.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program regarding obstetrics and gyne­cology","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Director of the Institute shall establish and maintain within the Institute an intramural laboratory and clinical research program in obstetrics and gynecology.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb575f332-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title IV, § 452B, as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/43/tX/s1011"},"text":"Pub. L. 103–43, title X, § 1011","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-06-10"},"text":"June 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/166"},"text":"107 Stat. 166","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
