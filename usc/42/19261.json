{"tag":"section","attrib":{"id":"idc08907d7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19261"},"text":null,"children":[{"tag":"num","attrib":{"value":"19261"},"text":"§ 19261.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quantum networking and communications","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc08907d8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19261/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc08907d9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19261/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Director” means the Director of the National Science Foundation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc08907da-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19261/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriate committees of Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “appropriate committees of Congress” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s8801"},"text":"section 8801 of title 15","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc08907db-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19261/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Q2work Program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Q2Work Program” means the Q2Work Program supported by the Foundation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc08907dc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19261/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":", (c) Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc08907dd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19261/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quantum information science workforce evaluation and acceleration","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc08907de-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19261/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2022-08-09"},"text":"August 9, 2022","children":[],"tail":", the Director shall enter into an agreement with the National Academies of Sciences, Engineering, and Medicine to conduct a study to evaluate and make recommendations for the quantum information science workforce. The study shall—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc08907df-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19261/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" characterize the quantum information science workforce, including by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc08907e0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19261/d/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describing what constitutes a quantum information science qualified worker across sectors, including academia, the Federal Government, and industry; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc08907e1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19261/d/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describing the size and makeup of the quantum information science workforce, including an assessment of current and future trends;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc08907e2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19261/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" identify near- and long-term quantum information science workforce needs across government, academia, and industry sectors, including identifying the cross-disciplinary academic degrees or academic courses necessary to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc08907e3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19261/d/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prepare students for multiple career pathways in quantum information sciences and related fields;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc08907e4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19261/d/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure the United States is competitive in the field of quantum information science while preserving national security; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc08907e5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19261/d/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support the development of quantum applications;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc08907e6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19261/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" assess the state of quantum information science education and skills training at all education levels and identify gaps in meeting current and future workforce needs, including with respect to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc08907e7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19261/d/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" elementary, middle, and high-school student access to foundational courses, age-appropriate quantum concepts, and hands-on learning opportunities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc08907e8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19261/d/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" elementary, middle, and high-school teacher professional development and access to resources, materials, lesson plans, modules, and curricula;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc08907e9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19261/d/1/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" career pivot and skills training opportunities, including professional certificates and internships; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc08907ea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19261/d/1/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" higher education curricula, laboratory experiences in academia, the Federal Government, and industry settings, and cross-discipline degree programs aligned with workforce needs; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc08907eb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19261/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make recommendations for developing a diverse, flexible, and sustainable quantum information science workforce that meets the evolving needs of academia, the Federal Government, and industry.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc08907ec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19261/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than two years after ","children":[{"tag":"date","attrib":{"date":"2022-08-09"},"text":"August 9, 2022","children":[],"tail":", the National Academies of Science, Engineering, and Medicine shall submit to Congress and the Director a report containing the results of the study conducted pursuant to paragraph (1)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc08907ed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19261/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc08907ee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19261/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quantum Education Pilot Program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc08907ef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19261/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than one year after ","children":[{"tag":"date","attrib":{"date":"2022-08-09"},"text":"August 9, 2022","children":[],"tail":", the Director, building on the National Science Foundation’s role in the National Q–12 Education Partnership and programs such as Q2Work Program, shall make awards to institutions of higher education, non-profit organizations, or consortia thereof to carry out a pilot program, to be known as the “Next Generation Quantum Leaders Pilot Program” (in this subsection referred to as the “Program”), for the education and training of the next generation of students and teachers in the fundamental principles of quantum mechanics."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc08907f0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19261/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc08907f1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19261/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the Program, the Director shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc08907f2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19261/f/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage awardees to coordinate with educational service agencies (as such term “educational service agency” is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1401/5"},"text":"section 1401(5) of title 20","children":[],"tail":"), associations that support STEM educators or local educational agencies, and partnerships through the Q–12 Education Partnership, to encourage elementary schools, middle schools, and secondary schools, and State educational agencies to participate in the Program; "},{"tag":"ref","attrib":{"idref":"fn004405"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004405"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be followed by “and”."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc08907f3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19261/f/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require that awardees partner with elementary schools, middle schools, or secondary schools, or consortia thereof, and State educational agencies, to carry out activities under the Program; ","children":[{"tag":"ref","attrib":{"idref":"fn004406"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004406"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. The semicolon probably should be a period."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc08907f4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19261/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the Program, the Director shall make competitive, merit-reviewed awards to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc08907f5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19261/f/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support testing, evaluation, dissemination, and implementation of age-appropriate quantum information sciences curricula and resources, including the integration of quantum information science and engineering into the STEM curriculum pursuant to subsection (d) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s8841"},"text":"section 8841 of title 15","children":[],"tail":", as added by subsection (e);"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc08907f6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19261/f/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support opportunities for informal education on quantum concepts, including informal hands-on learning opportunities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc08907f7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19261/f/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support opportunities for students to further explore quantum information science education and related careers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc08907f8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19261/f/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop and implement training, research, and professional development programs for teachers, including innovative pre-service and in-service programs, in quantum information science and related fields; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc08907f9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19261/f/2/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry out such other activities as the Director determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc08907fa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19261/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distribution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out the Program and to the extent practicable, the Director shall ensure there is a wide, equitable distribution of Program participants across diverse geographic areas and that the Program includes a diverse representation of students, including students from groups historically underrepresented in STEM.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc08907fb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19261/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall carry out the Program in consultation with the QIS Workforce Working Group of the Subcommittee on Quantum Information Science of the National Science and Technology Council and the Advancing Informal STEM Learning Program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc08907fc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19261/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than four years after ","children":[{"tag":"date","attrib":{"date":"2022-08-09"},"text":"August 9, 2022","children":[],"tail":", the Director shall submit to Congress a report that includes the following:"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc08907fd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19261/f/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An assessment, that includes feedback from a wide range of stakeholders in academia, K-12 education, and the private sector, of the effectiveness of the Program in scaling up implementation of effective quantum education and training innovations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc08907fe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19261/f/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If determined to be effective, a plan for integrating the Program into existing programs, including the feasibility and advisability of expanding the scope of the Program to include additional technology areas, grade levels, and educational institutions beyond those originally selected to participate in the Program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc08907ff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19261/f/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to the Director $8,000,000 for each of fiscal years 2023 through 2026 to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0890800-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19261/f/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This subsection shall terminate on the date that is four years after ","children":[{"tag":"date","attrib":{"date":"2022-08-09"},"text":"August 9, 2022","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc0890801-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/tVI/s10661"},"text":"Pub. L. 117–167, div. B, title VI, § 10661","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1683"},"text":"136 Stat. 1683","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc0890802-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc0890803-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idc0890804-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/s10661"},"text":"section 10661 of Pub. L. 117–167","children":[],"tail":". Subsecs. (b), (c), and (e) of "},{"tag":"ref","attrib":{"href":"/us/pl/117/167/s10661"},"text":"section 10661 of Pub. L. 117–167","children":[],"tail":" amended sections 8813, 8831, and 8841, respectively, of Title 15, Commerce and Trade."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
