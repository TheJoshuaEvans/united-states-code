{"tag":"section","attrib":{"id":"idbce4b840-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4855"},"text":null,"children":[{"tag":"num","attrib":{"value":"4855"},"text":"§ 4855.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal implementation and insurance study","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbce4b841-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4855/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal implementation study","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Comptroller General of the United States shall assess the effectiveness of Federal enforcement and compliance with lead safety laws and regulations, including any changes needed in annual inspection procedures to identify lead-based paint hazards in units receiving assistance under subsections (b) and (","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":") of "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1437f"},"text":"section 1437f of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbce4b842-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4855/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Insurance study","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Comptroller General of the United States shall assess the availability of liability insurance for owners of residential housing that contains lead-based paint and persons engaged in lead-based paint hazard evaluation and reduction activities. In carrying out the assessment, the Comptroller General shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbce4b843-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4855/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" analyze any precedents in the insurance industry for the containment and abatement of environmental hazards, such as asbestos, in federally assisted housing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbce4b844-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4855/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide an assessment of the recent insurance experience in the public housing lead hazard identification and reduction program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbce4b845-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4855/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommend measures for increasing the availability of liability insurance to owners and contractors engaged in federally supported work.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbce4b846-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550/tX/s1056"},"text":"Pub. L. 102–550, title X, § 1056","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3926"},"text":"106 Stat. 3926","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
