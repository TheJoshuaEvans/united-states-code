{"tag":"section","attrib":{"id":"idb65d4576-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–8"},"text":null,"children":[{"tag":"num","attrib":{"value":"300u–8"},"text":"§ 300u–8.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Biennial report regarding nutrition and health","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb65d4577-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–8/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Biennial report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall require the Surgeon General of the Public Health Service to prepare biennial reports on the relationship between nutrition and health. Such reports may, with respect to such relationship, include any recommendations of the Secretary and the Surgeon General.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb65d4578-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–8/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall ensure that, not later than February 1 of 1995 and of every second year thereafter, a report under subsection (a) is submitted to the Committee on Energy and Commerce of the House of Representatives and the Committee on Labor and Human Resources of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb65d4579-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XVII, § 1709, as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/183/tVII/s704"},"text":"Pub. L. 103–183, title VII, § 704","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-14"},"text":"Dec. 14, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2240"},"text":"107 Stat. 2240","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb65d457a-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb65d457b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb65d457c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 300u–8, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373/tXVII/s1709"},"text":"act July 1, 1944, ch. 373, title XVII, § 1709","children":[],"tail":", as added "},{"tag":"date","attrib":{"date":"1978-11-10"},"text":"Nov. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/95/626/tV/s502"},"text":"Pub. L. 95–626, title V, § 502","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3594"},"text":"92 Stat. 3594","children":[],"tail":", related to establishment of national program on sports medicine research, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/98/551/s2/c"},"text":"Pub. L. 98–551, § 2(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2816"},"text":"98 Stat. 2816","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb65d457d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idb65d457e-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Labor and Human Resources of Senate changed to Committee on Health, Education, Labor, and Pensions of Senate by Senate Resolution No. 20, One Hundred Sixth Congress, ","children":[{"tag":"date","attrib":{"date":"1999-01-19"},"text":"Jan. 19, 1999","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Energy and Commerce of House of Representatives treated as referring to Committee on Commerce of House of Representatives by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/14/s1/a"},"text":"section 1(a) of Pub. L. 104–14","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s21"},"text":"section 21 of Title 2","children":[],"tail":", The Congress. Committee on Commerce of House of Representatives changed to Committee on Energy and Commerce of House of Representatives, and jurisdiction over matters relating to securities and exchanges and insurance generally transferred to Committee on Financial Services of House of Representatives by House Resolution No. 5, One Hundred Seventh Congress, "},{"tag":"date","attrib":{"date":"2001-01-03"},"text":"Jan. 3, 2001","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
