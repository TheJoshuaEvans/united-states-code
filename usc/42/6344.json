{"tag":"section","attrib":{"id":"idbd99fea2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6344"},"text":null,"children":[{"tag":"num","attrib":{"value":"6344"},"text":"§ 6344.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional incentives for recovery, use, and prevention of industrial waste energy","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd99fea3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6344/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consideration of standard","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd99fea4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6344/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after the receipt by a State regulatory authority (with respect to each electric utility for which the authority has ratemaking authority), or nonregulated electric utility, of a request from a project sponsor or owner or operator, the State regulatory authority or nonregulated electric utility shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd99fea5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6344/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide public notice and conduct a hearing respecting the standard established by subsection (b); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd99fea6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6344/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on the basis of the hearing, consider and make a determination whether or not it is appropriate to implement the standard to carry out the purposes of this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd99fea7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6344/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relationship to State law","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of any determination under paragraph (1) and any review of the determination in any court, the purposes of this section supplement otherwise applicable State law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd99fea8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6344/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonadoption of standard","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this part prohibits any State regulatory authority or nonregulated electric utility from making any determination that it is not appropriate to adopt any standard described in paragraph (1), pursuant to authority under otherwise applicable State law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd99fea9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6344/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standard for sales of excess power","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the standard referred to in subsection (a) shall provide that an owner or operator of a waste energy recovery project identified on the Registry that generates net excess power shall be eligible to benefit from at least 1 of the options described in subsection (c) for disposal of the net excess power in accordance with the rate conditions and limitations described in subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd99feaa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6344/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Options","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The options referred to in subsection (b) are as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd99feab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6344/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sale of net excess power to utility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The electric utility shall purchase the net excess power from the owner or operator of the eligible waste energy recovery project during the operation of the project under a contract entered into for that purpose.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd99feac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6344/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transport by utility for direct sale to third party","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The electric utility shall transmit the net excess power on behalf of the project owner or operator to up to 3 separate locations on the system of the utility for direct sale by the owner or operator to third parties at those locations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd99fead-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6344/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transport over private transmission lines","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The State and the electric utility shall permit, and shall waive or modify such laws as would otherwise prohibit, the construction and operation of private electric wires constructed, owned, and operated by the project owner or operator, to transport the power to up to 3 purchasers within a 3-mile radius of the project, allowing the wires to use or cross public rights-of-way, without subjecting the project to regulation as a public utility, and according the wires the same treatment for safety, zoning, land use, and other legal privileges as apply or would apply to the wires of the utility, except that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd99feae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6344/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there shall be no grant of any power of eminent domain to take or cross private property for the wires; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd99feaf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6344/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the wires shall be physically segregated and not interconnected with any portion of the system of the utility, except on the customer side of the revenue meter of the utility and in a manner that precludes any possible export of the electricity onto the utility system, or disruption of the system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd99feb0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6344/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreed on alternatives","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The utility and the owner or operator of the project may reach agreement on any alternate arrangement and payments or rates associated with the arrangement that is mutually satisfactory and in accord with State law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd99feb1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6344/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rate conditions and criteria","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd99feb2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6344/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd99feb3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6344/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Per unit distribution costs","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “per unit distribution costs” means (in kilowatt hours) the quotient obtained by dividing—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbd99feb4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6344/d/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the depreciated book-value distribution system costs of a utility; by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd99feb5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6344/d/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the volume of utility electricity sales or transmission during the previous year at the distribution level.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd99feb6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6344/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Per unit distribution margin","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “per unit distribution margin” means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbd99feb7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6344/d/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of a State-regulated electric utility, a per-unit gross pretax profit equal to the product obtained by multiplying—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbd99feb8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6344/d/1/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State-approved percentage rate of return for the utility for distribution system assets; by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbd99feb9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6344/d/1/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the per unit distribution costs; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd99feba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6344/d/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of a nonregulated utility, a per unit contribution to net revenues determined multiplying—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbd99febb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6344/d/1/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the percentage (but not less than 10 percent) obtained by dividing—","children":[],"tail":null},{"tag":"item","attrib":{"id":"idbd99febc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6344/d/1/B/ii/I/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of any net revenue payment or contribution to the owners or subscribers of the nonregulated utility during the prior year; by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idbd99febd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6344/d/1/B/ii/I/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the gross revenues of the utility during the prior year to obtain a percentage; by","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbd99febe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6344/d/1/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the per unit distribution costs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd99febf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6344/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Per unit transmission costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “per unit transmission costs” means the total cost of those transmission services purchased or provided by a utility on a per-kilowatt-hour basis as included in the retail rate of the utility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd99fec0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6344/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Options","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The options described in paragraphs (1) and (2) in subsection (c) shall be offered under purchase and transport rate conditions that reflect the rate components defined under paragraph (1) as applicable under the circumstances described in paragraph (3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd99fec1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6344/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicable rates","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd99fec2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6344/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rates applicable to sale of net excess power","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbd99fec3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6344/d/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Sales made by a project owner or operator of a facility under the option described in subsection (c)(1) shall be paid for on a per kilowatt hour basis that shall equal the full undiscounted retail rate paid to the utility for power purchased by the facility minus per unit distribution costs, that applies to the type of utility purchasing the power.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd99fec4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6344/d/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Voltages exceeding 25 kilovolts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the net excess power is made available for purchase at voltages that must be transformed to or from voltages exceeding 25 kilovolts to be available for resale by the utility, the purchase price shall further be reduced by per unit transmission costs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd99fec5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6344/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rates applicable to transport by utility for direct sale to third parties","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbd99fec6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6344/d/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Transportation by utilities of power on behalf of the owner or operator of a project under the option described in subsection (c)(2) shall incur a transportation rate that shall equal the per unit distribution costs and per unit distribution margin, that applies to the type of utility transporting the power.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd99fec7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6344/d/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Voltages exceeding 25 kilovolts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the net excess power is made available for transportation at voltages that must be transformed to or from voltages exceeding 25 kilovolts to be transported to the designated third-party purchasers, the transport rate shall further be increased by per unit transmission costs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd99fec8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6344/d/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" States with competitive retail markets for electricity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In a State with a competitive retail market for electricity, the applicable transportation rate for similar transportation shall be applied in lieu of any rate calculated under this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd99fec9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6344/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd99feca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6344/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any rate established for sale or transportation under this section shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbd99fecb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6344/d/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be modified over time with changes in the underlying costs or rates of the electric utility; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd99fecc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6344/d/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reflect the same time-sensitivity and billing periods as are established in the retail sales or transportation rates offered by the utility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd99fecd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6344/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No utility shall be required to purchase or transport a quantity of net excess power under this section that exceeds the available capacity of the wires, meter, or other equipment of the electric utility serving the site unless the owner or operator of the project agrees to pay necessary and reasonable upgrade costs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd99fece-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6344/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedural requirements for consideration and determination","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd99fecf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6344/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public notice and hearing","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd99fed0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6344/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The consideration referred to in subsection (a) shall be made after public notice and hearing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd99fed1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6344/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The determination referred to in subsection (a) shall be—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbd99fed2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6344/e/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in writing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd99fed3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6344/e/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" based on findings included in the determination and on the evidence presented at the hearing; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd99fed4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6344/e/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" available to the public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd99fed5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6344/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Intervention by Administrator","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator may intervene as a matter of right in a proceeding conducted under this section—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd99fed6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6344/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to calculate—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbd99fed7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6344/e/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the energy and emissions likely to be saved by electing to adopt 1 or more of the options; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd99fed8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6344/e/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the costs and benefits to ratepayers and the utility; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd99fed9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6344/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to advocate for the waste-energy recovery opportunity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd99feda-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6344/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedures","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd99fedb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6344/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as otherwise provided in paragraphs (1) and (2), the procedures for the consideration and determination referred to in subsection (a) shall be the procedures established by the State regulatory authority or the nonregulated electric utility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd99fedc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6344/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Multiple projects","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If there is more than 1 project seeking consideration simultaneously in connection with the same utility, the proceeding may encompass all such projects, if full attention is paid to individual circumstances and merits and an individual judgment is reached with respect to each project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd99fedd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6344/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd99fede-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6344/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The State regulatory authority (with respect to each electric utility for which the authority has ratemaking authority) or nonregulated electric utility may, to the extent consistent with otherwise applicable State law—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd99fedf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6344/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" implement the standard determined under this section; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd99fee0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6344/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" decline to implement any such standard.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd99fee1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6344/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonimplementation of standard","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd99fee2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6344/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a State regulatory authority (with respect to each electric utility for which the authority has ratemaking authority) or nonregulated electric utility declines to implement any standard established by this section, the authority or nonregulated electric utility shall state in writing the reasons for declining to implement the standard.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd99fee3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6344/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability to public","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The statement of reasons shall be available to the public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd99fee4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6344/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall include in an annual report submitted to Congress a description of the lost opportunities for waste-heat recovery from the project described in subparagraph (A), specifically identifying the utility and stating the quantity of lost energy and emissions savings calculated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd99fee5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6344/f/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" New petition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a State regulatory authority (with respect to each electric utility for which the authority has ratemaking authority) or nonregulated electric utility declines to implement the standard established by this section, the project sponsor may submit a new petition under this section with respect to the project at any time after the date that is 2 years after the date on which the State regulatory authority or nonregulated utility declined to implement the standard.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd99fee6-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/163/tIII/s374"},"text":"Pub. L. 94–163, title III, § 374","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/tIV/s451/a"},"text":"Pub. L. 110–140, title IV, § 451(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1628"},"text":"121 Stat. 1628","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd99fee7-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd99fee8-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbd99fee9-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Prior sections 6344 and 6344a were repealed by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/509/tIII/s3101/b"},"text":"Pub. L. 99–509, title III, § 3101(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-21"},"text":"Oct. 21, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1888"},"text":"100 Stat. 1888","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 6344, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/163/tIII/s374"},"text":"Pub. L. 94–163, title III, § 374","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-12-22"},"text":"Dec. 22, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/936"},"text":"89 Stat. 936","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/619/tVI/s691/b/2"},"text":"Pub. L. 95–619, title VI, § 691(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-09"},"text":"Nov. 9, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3288"},"text":"92 Stat. 3288","children":[],"tail":", related to establishment of individual energy improvement targets for each of the 10 most energy-consumptive industries."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 6344a, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/163/tIII/s374A"},"text":"Pub. L. 94–163, title III, § 374A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/95/619/tIV/s461/c"},"text":"Pub. L. 95–619, title IV, § 461(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-09"},"text":"Nov. 9, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3273"},"text":"92 Stat. 3273","children":[],"tail":", related to targets for increased utilization of energy-saving recovered materials for specified industries."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbd99feea-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbd99feeb-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the date that is 1 day after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/s1601"},"text":"section 1601 of Pub. L. 110–140","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1824"},"text":"section 1824 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
