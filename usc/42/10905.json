{"tag":"section","attrib":{"id":"idbf342604-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10905"},"text":null,"children":[{"tag":"num","attrib":{"value":"10905"},"text":"§ 10905.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this chapter such sums as may be necessary for fiscal year 1995.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbf342605-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/425/tVI/s606"},"text":"Pub. L. 99–425, title VI, § 606","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-09-30"},"text":"Sept. 30, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/977"},"text":"100 Stat. 977","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/501/tV/s503"},"text":"Pub. L. 101–501, title V, § 503","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-03"},"text":"Nov. 3, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1256"},"text":"104 Stat. 1256","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/252/tI/s124"},"text":"Pub. L. 103–252, title I, § 124","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-05-18"},"text":"May 18, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/650"},"text":"108 Stat. 650","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf342606-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf342607-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":