{"tag":"section","attrib":{"id":"idbc022091-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2201b"},"text":null,"children":[{"tag":"num","attrib":{"value":"2201b"},"text":"§ 2201b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commission workforce","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbc022092-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2201b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Direct hire authority","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc022093-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2201b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2201/d"},"text":"section 2201(d) of this title","children":[],"tail":" and any provision of Reorganization Plan No. 1 of 1980 ("},{"tag":"ref","attrib":{"href":"/us/stat/94/3585"},"text":"94 Stat. 3585","children":[],"tail":"; 5 U.S.C. app.),"},{"tag":"ref","attrib":{"idref":"fn003271"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003271"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be capitalized."}],"tail":" and without regard to any provision of title 5 (except section 3328) governing appointments in the civil service, the Chairman of the Nuclear Regulatory Commission (in this section referred to as the “Chairman”) may, in order to carry out the Nuclear Regulatory Commission’s (in this section referred to as the “Commission”) responsibilities and activities in a timely, efficient, and effective manner and subject to the limitations described in paragraphs (2), (3), and (4)—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc022094-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2201b/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recruit and directly appoint exceptionally well-qualified individuals into the excepted service for covered positions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc022095-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2201b/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish in the excepted service term-limited covered positions and recruit and directly appoint exceptionally well-qualified individuals into such term-limited covered positions, which may not exceed a term of 4 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc022096-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2201b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc022097-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2201b/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Number","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbc022098-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2201b/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The number of exceptionally well-qualified individuals serving in covered positions pursuant to paragraph (1)(A) may not exceed 210 at any one time.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc022099-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2201b/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term-limited covered positions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Chairman may not appoint more than 20 exceptionally well-qualified individuals into term-limited covered positions pursuant to paragraph (1)(B) during any fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc02209a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2201b/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbc02209b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2201b/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual rate","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The annual basic rate of pay for any individual appointed under paragraph (1)(A) or paragraph (1)(B) may not exceed the annual basic rate of pay for level III of the Executive Schedule under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5314"},"text":"section 5314 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc02209c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2201b/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Experience and qualifications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any individual recruited and directly appointed into a covered position or a term-limited covered position shall be compensated at a rate of pay that is commensurate with such individual’s experience and qualifications.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc02209d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2201b/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Senior executive service position","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Chairman may not, under paragraph (1)(A) or paragraph (1)(B), appoint exceptionally well-qualified individuals to any Senior Executive Service position, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3132"},"text":"section 3132 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc02209e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2201b/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Level of positions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the extent practicable, in carrying out paragraph (1) the Chairman shall recruit and directly appoint exceptionally well-qualified individuals into the excepted service to entry, mid, and senior level covered positions, including term-limited covered positions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc02209f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2201b/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consideration of future workforce needs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"When recruiting and directly appointing exceptionally well-qualified individuals to covered positions pursuant to paragraph (1)(A), to maintain sufficient flexibility under the limitations of paragraph (2)(A)(i), the Chairman shall consider the future workforce needs of the Commission to carry out its responsibilities and activities in a timely, efficient, and effective manner.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc0220a0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2201b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Addressing insufficient compensation of employees and other personnel of the Commission","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc0220a1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2201b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, the Chairman may fix the compensation for employees or other personnel serving in a covered position without regard to any provision of title 5 governing General Schedule classification and pay rates.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc0220a2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2201b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The authority under this subsection to fix the compensation of employees or other personnel shall apply with respect to an employee or other personnel serving in a covered position regardless of when the employee or other personnel was hired.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc0220a3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2201b/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on compensation","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc0220a4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2201b/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual rate","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Chairman may not use the authority under paragraph (1) to fix the compensation of employees or other personnel—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbc0220a5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2201b/b/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at an annual rate of basic pay higher than the annual basic rate of pay for level III of the Executive Schedule under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5314"},"text":"section 5314 of title 5","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc0220a6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2201b/b/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at an annual rate of basic pay that is not commensurate with such an employee or other personnel’s experience and qualifications.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc0220a7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2201b/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Senior Executive Service positions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Chairman may not use the authority under paragraph (1) to fix the compensation of an employee serving in a Senior Executive Service position, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3132"},"text":"section 3132 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc0220a8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2201b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional compensation authority","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc0220a9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2201b/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" For new employees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Chairman may pay an individual recruited and directly appointed under subsection (a) a 1-time hiring bonus in an amount not to exceed $25,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc0220aa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2201b/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" For existing employees","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc0220ab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2201b/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subparagraphs (B) and (C), an employee or other personnel who the Chairman determines exhibited exceptional performance in a fiscal year may be paid a performance bonus in an amount not to exceed the least of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbc0220ac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2201b/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $25,000; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc0220ad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2201b/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of the limitation that is applicable for a calendar year under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5307/a/1"},"text":"section 5307(a)(1) of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc0220ae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2201b/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptional performance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Exceptional performance under subparagraph (A) includes—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbc0220af-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2201b/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" leading a project team in a timely and efficient licensing review to enable the safe use of nuclear technology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc0220b0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2201b/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" making significant contributions to a timely and efficient licensing review to enable the safe use of nuclear technology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc0220b1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2201b/c/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the resolution of novel or first-of-a-kind regulatory issues;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc0220b2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2201b/c/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing or implementing licensing or regulatory oversight processes to improve the effectiveness of the Commission; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc0220b3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2201b/c/2/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other performance, as determined by the Chairman.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc0220b4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2201b/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbc0220b5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2201b/c/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subsequent bonuses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person who receives a performance bonus under subparagraph (A) may not receive another performance bonus under that subparagraph for a period of 5 years thereafter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc0220b6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2201b/c/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hiring bonuses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person who receives a 1-time hiring bonus under paragraph (1) may not receive a performance bonus under subparagraph (A) unless more than one year has elapsed since the payment of such 1-time hiring bonus.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc0220b7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2201b/c/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No bonus for Senior Executive Service positions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No person serving in a Senior Executive Service position, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3132"},"text":"section 3132 of title 5","children":[],"tail":", may receive a performance bonus under subparagraph (A)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc0220b8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2201b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation plan and report","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc0220b9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2201b/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2024-07-09"},"text":"July 9, 2024","children":[],"tail":", the Chairman shall develop and implement a plan to carry out this section. Before implementing such plan, the Chairman shall submit to the Committee on Energy and Commerce of the House of Representatives, the Committee on Environment and Public Works of the Senate, and the Office of Personnel Management a report on the details of the plan."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc0220ba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2201b/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report content","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The report submitted under paragraph (1) shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc0220bb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2201b/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evidence and supporting documentation justifying the plan; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc0220bc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2201b/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" budgeting projections on costs and benefits resulting from the plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc0220bd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2201b/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Chairman may consult with the Office of Personnel Management, the Office of Management and Budget, and the Comptroller General of the United States in developing the plan under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc0220be-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2201b/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Delegation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Chairman shall delegate, subject to the direction and supervision of the Chairman, the authority provided by subsections (a), (b), and (c) to the Executive Director for Operations of the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc0220bf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2201b/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information on hiring, vacancies, and compensation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc0220c0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2201b/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall include in its budget materials submitted in support of the budget of the President (submitted to Congress pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105"},"text":"section 1105 of title 31","children":[],"tail":"), for fiscal year 2026 and each fiscal year thereafter, information relating to hiring, vacancies, and compensation at the Commission."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc0220c1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2201b/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The information described in paragraph (1) shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc0220c2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2201b/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an analysis of any trends with respect to hiring, vacancies, and compensation at the Commission;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc0220c3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2201b/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the efforts to retain and attract employees or other personnel to serve in covered positions at the Commission;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc0220c4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2201b/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" information that describes—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbc0220c5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2201b/f/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how the authority provided by subsection (a) is being used to address the hiring needs of the Commission;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc0220c6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2201b/f/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the total number of exceptionally well-qualified individuals serving in—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbc0220c7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2201b/f/2/C/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" covered positions described in subsection (g)(1) pursuant to subsection (a)(1)(A);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbc0220c8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2201b/f/2/C/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" covered positions described in subsection (g)(2) pursuant to subsection (a)(1)(A);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbc0220c9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2201b/f/2/C/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" term-limited covered positions described in subsection (g)(1) pursuant to subsection (a)(1)(B); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbc0220ca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2201b/f/2/C/ii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" term-limited covered positions described in subsection (g)(2) pursuant to subsection (a)(1)(B);","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc0220cb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2201b/f/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how the authority provided by subsection (b) is being used to address the hiring or retention needs of the Commission;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc0220cc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2201b/f/2/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total number of employees or other personnel serving in a covered position that have their compensation fixed pursuant to subsection (b); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc0220cd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2201b/f/2/C/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the attrition levels with respect to term-limited covered positions appointed under subsection (a)(1)(B), including the number of individuals leaving a term-limited covered position before completion of the applicable term of service and the average length of service for such individuals as a percentage of the applicable term of service; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc0220ce-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2201b/f/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an assessment of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbc0220cf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2201b/f/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the current critical workforce needs of the Commission and any critical workforce needs that the Commission anticipates in the next five years; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc0220d0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2201b/f/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" additional skillsets that are or likely will be needed for the Commission to fulfill the licensing and oversight responsibilities of the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc0220d1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2201b/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered position","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “covered position” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc0220d2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2201b/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a position in which an employee or other personnel is responsible for conducting work of a highly-specialized scientific, technical, engineering, mathematical, or otherwise skilled nature to address a critical licensing or regulatory oversight need for the Commission; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc0220d3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2201b/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a position that the Executive Director for Operations of the Commission determines is necessary to fulfill the responsibilities of the Commission in a timely, efficient, and effective manner.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc0220d4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2201b/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sunset","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc0220d5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2201b/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), the authorities provided by subsections (a) and (b) shall terminate on ","children":[{"tag":"date","attrib":{"date":"2034-09-30"},"text":"September 30, 2034","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc0220d6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2201b/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If, no later than the date referenced in paragraph (1), the Commission issues a certification that the authorities provided by subsection (a), subsection (b), or both subsections are necessary for the Commission to carry out its responsibilities and activities in a timely, efficient, and effective manner, the authorities provided by the applicable subsection shall terminate on ","children":[{"tag":"date","attrib":{"date":"2039-09-30"},"text":"September 30, 2039","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc0220d7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2201b/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The termination of the authorities provided by subsections (a) and (b) shall not affect the compensation of an employee or other personnel serving in a covered position whose compensation was fixed by the Chairman in accordance with subsection (a) or (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc0220d8-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-08-01/ch724"},"text":"Aug. 1, 1946, ch. 724","children":[],"tail":", title I, § 161B, as added "},{"tag":"ref","attrib":{"href":"/us/pl/118/67/dB/tV/s502/a/1"},"text":"Pub. L. 118–67, div. B, title V, § 502(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-07-09"},"text":"July 9, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1471"},"text":"138 Stat. 1471","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc0220d9-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc0220da-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbc0220db-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Reorganization Plan No. 1 of 1980, referred to in subsec. (a)(1), is set out in the Appendix to Title 5, Government Organization and Employees, and as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5841"},"text":"section 5841 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbc0220dc-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbc0220dd-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Annual Solicitation for Nuclear Regulator Apprenticeship Network Applications","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/67/dB/tV/s502/c"},"text":"Pub. L. 118–67, div. B, title V, § 502(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-07-09"},"text":"July 9, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1476"},"text":"138 Stat. 1476","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/67/dB/tV/s502/c"},"text":"“The [Nuclear Regulatory] Commission, on an annual basis, shall solicit applications for the Nuclear Regulator Apprenticeship Network.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
