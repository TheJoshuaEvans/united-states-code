{"tag":"section","attrib":{"id":"idbcc82fd8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4347"},"text":null,"children":[{"tag":"num","attrib":{"value":"4347"},"text":"§ 4347.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out the provisions of this chapter not to exceed $300,000 for fiscal year 1970, $700,000 for fiscal year 1971, and $1,000,000 for each fiscal year thereafter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbcc82fd9-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/190/tII/s209"},"text":"Pub. L. 91–190, title II, § 209","children":[],"tail":", formerly § 207, "},{"tag":"date","attrib":{"date":"1970-01-01"},"text":"Jan. 1, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/856"},"text":"83 Stat. 856","children":[],"tail":", renumbered § 209, "},{"tag":"ref","attrib":{"href":"/us/pl/94/52/s3"},"text":"Pub. L. 94–52, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-07-03"},"text":"July 3, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/258"},"text":"89 Stat. 258","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
