{"tag":"section","attrib":{"id":"idbc1ecfee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2297h–10b"},"text":null,"children":[{"tag":"num","attrib":{"value":"2297h–10b"},"text":"§ 2297h–10b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretarial determinations; congressional notification","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbc1ecfef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2297h–10b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretarial determinations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this fiscal year, and in each subsequent fiscal year, any determination (including a determination made prior to ","children":[{"tag":"date","attrib":{"date":"2014-12-16"},"text":"December 16, 2014","children":[],"tail":") by the Secretary of Energy under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2297h–10/d/2/B"},"text":"section 2297h–10(d)(2)(B) of this title","children":[],"tail":" shall be valid for not more than 2 calendar years subsequent to such determination."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc1ecff0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2297h–10b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional notification","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this fiscal year, and in each subsequent fiscal year, not less than 30 days prior to the provision of uranium in any form the Secretary of Energy shall notify the Committees on Appropriations of the House of Representatives and the Senate of the following—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc1ecff1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2297h–10b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the provisions of law (including regulations) authorizing the provision of uranium;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc1ecff2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2297h–10b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of uranium to be provided;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc1ecff3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2297h–10b/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an estimate by the Secretary of Energy of the gross fair market value of the uranium on the expected date of the provision of the uranium;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc1ecff4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2297h–10b/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the expected date of the provision of the uranium;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc1ecff5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2297h–10b/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the recipient of the uranium;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc1ecff6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2297h–10b/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the value the Secretary of Energy expects to receive in exchange for the uranium, including any adjustments to the gross fair market value of the uranium; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc1ecff7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2297h–10b/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether the uranium to be provided is encumbered by any restriction on use under an international agreement or otherwise.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc1ecff8-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/235/dD/tIII/s306"},"text":"Pub. L. 113–235, div. D, title III, § 306","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-16"},"text":"Dec. 16, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2324"},"text":"128 Stat. 2324","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc1ecff9-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc1ecffa-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbc1ecffb-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Energy and Water Development and Related Agencies Appropriations Act, 2015, and also as part of the Consolidated and Further Continuing Appropriations Act, 2015, and not as part of the Atomic Energy Act of 1954 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
