{"tag":"section","attrib":{"id":"idb53cb9fb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–5"},"text":null,"children":[{"tag":"num","attrib":{"value":"280g–5"},"text":"§ 280g–5.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public and health care provider education and support services","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb53cb9fc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–5/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, directly or through the awarding of grants to public or private nonprofit entities, may conduct activities, which may include demonstration projects for the purpose of improving the provision of information on prematurity to health professionals and other health care providers and the public and improving the treatment and outcomes mothers ","children":[{"tag":"ref","attrib":{"idref":"fn002140"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002140"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be preceded by “for”."}],"tail":" of infants born preterm, and infants born preterm, as appropriate."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb53cb9fd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–5/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Activities to be carried out under subsection (a) may include the establishment of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb53cb9fe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–5/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" programs, including those to test and evaluate strategies, which, in collaboration with States, localities, tribes, and community organizations, support the provision of information and education to health professionals, other health care providers, and the public concerning—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb53cb9ff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–5/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the core risk factors for preterm labor and delivery;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb53cba00-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–5/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evidence-based strategies to prevent preterm birth and associated outcomes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb53cba01-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–5/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" medically indicated deliveries before full term, and the risks of non-medically indicated deliveries before full term;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb53cba02-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–5/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the importance of preconception and prenatal care, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb53cba03-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–5/b/1/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" smoking cessation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb53cba04-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–5/b/1/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" weight maintenance and good nutrition, including folic acid intake;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb53cba05-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–5/b/1/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the screening for and the treatment of infections;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb53cba06-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–5/b/1/D/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" screening for and treatment of substance use disorders;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb53cba07-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–5/b/1/D/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" screening for and treatment of maternal depression;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb53cba08-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–5/b/1/D/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maternal immunization; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb53cba09-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–5/b/1/D/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" stress management;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb53cba0a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–5/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" treatments and outcomes for premature infants, including late preterm infants; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb53cba0b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–5/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the informational needs of families during the stay of an infant in a neonatal intensive care unit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53cba0c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–5/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" programs to increase the availability, awareness, and use of pregnancy and post-term information services that provide evidence-based, clinical information through counselors, community outreach efforts, electronic or telephonic communication, or other appropriate means regarding causes associated with prematurity, birth defects, or health risks to a post-term infant, as well as prevention of a future preterm birth;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53cba0d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–5/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" programs to respond to the informational needs of families during the stay of an infant in a neonatal intensive care unit, during the transition of the infant to the home, and in the event of a newborn death; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53cba0e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–5/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other programs as the Secretary determines appropriate to achieve the purpose specified in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb53cba0f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–5/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this section $1,900,000 for each of fiscal years 2014 through 2018.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb53cba10-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title III, § 399Q, as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/450/s4/2"},"text":"Pub. L. 109–450, § 4(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-22"},"text":"Dec. 22, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3342"},"text":"120 Stat. 3342","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/113/55/tI/s103/b"},"text":"Pub. L. 113–55, title I, § 103(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-11-27"},"text":"Nov. 27, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/642"},"text":"127 Stat. 642","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/328/s3"},"text":"Pub. L. 115–328, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-18"},"text":"Dec. 18, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4472"},"text":"132 Stat. 4472","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb53cba11-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb53cba12-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb53cba13-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/328/s3/1"},"text":"Pub. L. 115–328, § 3(1)","children":[],"tail":", substituted “conduct activities, which may include demonstration projects” for “conduct demonstration projects” and “mothers of infants born preterm, and infants born preterm, as appropriate” for “for babies born preterm”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/328/s3/2/A"},"text":"Pub. L. 115–328, § 3(2)(A)","children":[],"tail":", struck out “under the demonstration project” after “to be carried out” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/328/s3/2/B/i"},"text":"Pub. L. 115–328, § 3(2)(B)(i)","children":[],"tail":", substituted “programs, including those to test and evaluate strategies, which, in collaboration with States, localities, tribes, and community organizations, support the provision of” for “programs to test and evaluate various strategies to provide” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/328/s3/2/B/iii"},"text":"Pub. L. 115–328, § 3(2)(B)(iii)","children":[],"tail":", added subpar. (B). Former subpar. (B) redesignated (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/328/s3/2/B/ii"},"text":"Pub. L. 115–328, § 3(2)(B)(ii)","children":[],"tail":", (iv), redesignated subpar. (B) as (C) and inserted “, and the risks of non-medically indicated deliveries before full term” before semicolon at end. Former subpar. (C) redesignated (D)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/328/s3/2/B/ii"},"text":"Pub. L. 115–328, § 3(2)(B)(ii)","children":[],"tail":", redesignated subpar. (C) as (D). Former subpar. (D) redesignated (E)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(D)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/328/s3/2/B/v/I"},"text":"Pub. L. 115–328, § 3(2)(B)(v)(I)","children":[],"tail":", inserted “intake” after “folic acid”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(D)(iv) to (vii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/328/s3/2/B/v/II"},"text":"Pub. L. 115–328, § 3(2)(B)(v)(II)","children":[],"tail":"–(IV), added cls. (iv) to (vi) and redesignated former cl. (iv) as (vii)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(E) to (G). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/328/s3/2/B/ii"},"text":"Pub. L. 115–328, § 3(2)(B)(ii)","children":[],"tail":", (vi)–(viii), redesignated subpars. (D) to (F) as (E) to (G), respectively, and struck out subpar. (G), as redesignated, which read as follows: “utilization of evidence-based strategies to prevent birth injuries;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/328/s3/2/C"},"text":"Pub. L. 115–328, § 3(2)(C)","children":[],"tail":", inserted “, as well as prevention of a future preterm birth” before semicolon at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/55/s103/b/1/A"},"text":"Pub. L. 113–55, § 103(b)(1)(A)","children":[],"tail":", added subpars. (A) to (F) and struck out former subpars. (A) to (F) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) the signs of preterm labor, updated as new research results become available;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) the screening for and the treating of infections;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(c) counseling on optimal weight and good nutrition, including folic acid;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(D) smoking cessation education and counseling;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(E) stress management; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(F) appropriate prenatal care;”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/55/s103/b/1/B"},"text":"Pub. L. 113–55, § 103(b)(1)(B)","children":[],"tail":", added par. (2) and struck out former par. (2) which read as follows: “programs to improve the treatment and outcomes for babies born premature, including the use of evidence-based standards of care by health care professionals for pregnant women at risk of preterm labor or other serious complications and for infants born preterm and at a low birthweight;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/55/s103/b/2"},"text":"Pub. L. 113–55, § 103(b)(2)","children":[],"tail":", substituted “$1,900,000 for each of fiscal years 2014 through 2018.” for “$5,000,000 for each of fiscal years 2007 through 2011.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
