{"tag":"section","attrib":{"id":"idbb9e0782-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1881a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1881a"},"text":"§ 1881a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Alan T. Waterman Award","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbb9e0783-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1881a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment; amounts; terms","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The National Science Foundation is authorized to establish the Alan T. Waterman Award for research or advanced study in the mathematical, physical, medical, biological, engineering, behavioral, social, or other sciences. The award authorized by this section shall consist of a suitable medal and a grant to support further research or study by the recipient. The National Science Board will periodically establish the amounts and terms of such grants under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb9e0784-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1881a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Awards under this section shall be made to recognize and encourage the work of younger scientists whose capabilities and accomplishments show exceptional promise of significant future achievement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb9e0785-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1881a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Number","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not more than three awards may be made under this section in any one fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbb9e0786-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/86/s6"},"text":"Pub. L. 94–86, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-08-09"},"text":"Aug. 9, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/430"},"text":"89 Stat. 430","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/516/s22/b"},"text":"Pub. L. 96–516, § 22(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3010"},"text":"94 Stat. 3010","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/159/tI/s109/g"},"text":"Pub. L. 99–159, title I, § 109(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-11-22"},"text":"Nov. 22, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/890"},"text":"99 Stat. 890","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/207/tII/s202/b"},"text":"Pub. L. 105–207, title II, § 202(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-07-29"},"text":"July 29, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/874"},"text":"112 Stat. 874","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/69/tVII/s7015/c"},"text":"Pub. L. 110–69, title VII, § 7015(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-08-09"},"text":"Aug. 9, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/684"},"text":"121 Stat. 684","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbb9e0787-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbb9e0788-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbb9e0789-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the National Science Foundation Authorization Act, 1976, and not as part of the National Science Foundation Act of 1950 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbb9e078a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2007—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/69"},"text":"Pub. L. 110–69","children":[],"tail":" amended subsec. (c) generally. Prior to amendment, subsec. (c) read as follows: “No more than one award shall be made under this section in any one fiscal year.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/207"},"text":"Pub. L. 105–207","children":[],"tail":" substituted “social,” for “social, social,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1985—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/159"},"text":"Pub. L. 99–159","children":[],"tail":" substituted provisions requiring the National Science Board to periodically establish amounts and terms of grants, for provisions limiting the grant awarded to $50,000 per year for a period not exceeding three years."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/516"},"text":"Pub. L. 96–516","children":[],"tail":" inserted “, behavioral, social” after “engineering”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
