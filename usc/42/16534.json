{"tag":"section","attrib":{"id":"idc0190914-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16534"},"text":null,"children":[{"tag":"num","attrib":{"value":"16534"},"text":"§ 16534.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Department of Energy early career awards for science, engineering, and mathematics researchers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc0190915-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16534/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant awards","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the Office of Science of the Department (referred to in this section as the “Director”) shall carry out a program to award grants to scientists and engineers at an early career stage at institutions of higher education and organizations described in subsection (c) to conduct research in fields relevant to the mission of the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0190916-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16534/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount and duration","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0190917-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16534/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount of a grant awarded under this section shall be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0190918-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16534/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than $80,000; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0190919-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16534/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not more than $125,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc019091a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16534/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term of a grant awarded under this section shall be not more than 5 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc019091b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16534/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc019091c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16534/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to receive a grant under this section, an individual shall, as determined by the Director—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc019091d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16534/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to paragraph (2), have completed a doctorate or other terminal degree not more than 10 years before the date on which the proposal for a grant is submitted under subsection (e)(1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc019091e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16534/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have demonstrated promise in a science, engineering, or mathematics field relevant to the missions of the Department; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc019091f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16534/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" be employed—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc0190920-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16534/c/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in a tenure track-position as an assistant professor or equivalent title at an institution of higher education in the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc0190921-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16534/c/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at an organization in the United States that is a nonprofit, nondegree-granting research organization such as a museum, observatory, or research laboratory; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc0190922-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16534/c/1/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as a scientist at a National Laboratory.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0190923-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16534/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding paragraph (1)(A), the Director may determine that an individual who has completed a doctorate more than 10 years before the date of submission of a proposal under subsection (e)(1) is eligible to receive a grant under this section if the individual was unable to conduct research for a period of time because of extenuating circumstances, including military service or family responsibilities, as determined by the Director.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0190924-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16534/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Grant recipients shall be selected on a competitive, merit-reviewed basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0190925-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16534/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection process and criteria","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0190926-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16534/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Proposal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be eligible to receive a grant under this section, an individual shall submit to the Director a proposal at such time, in such manner, and containing such information as the Director may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0190927-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16534/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In evaluating the proposals submitted under paragraph (1), the Director shall take into consideration, at a minimum—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0190928-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16534/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the intellectual merit of the proposed project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0190929-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16534/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the innovative or transformative nature of the proposed research;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc019092a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16534/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which the proposal integrates research and education, including undergraduate education in science and engineering disciplines; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc019092b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16534/e/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the potential of the applicant for leadership at the frontiers of knowledge.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc01b521c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16534/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Diversity requirement","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc01b521d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16534/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In awarding grants under this section, the Director shall endeavor to ensure that the grant recipients represent a variety of types of institutions of higher education and nonprofit, nondegree-granting research organizations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc01b521e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16534/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In support of the goal described in paragraph (1), the Director shall broadly disseminate information regarding the deadlines applicable to, and manner in which to submit, proposals for grants under this section, including by conducting outreach activities for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc01b521f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16534/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" part B institutions, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1061"},"text":"section 1061 of title 20","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc01b5220-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16534/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" minority institutions, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1067k"},"text":"section 1067k of title 20","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc01b5221-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16534/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report on recruiting and retaining early career science and engineering researchers at National Laboratories","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc01b5222-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16534/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"2007-08-09"},"text":"August 9, 2007","children":[],"tail":", the Director shall submit to the Committee on Science and Technology of the House of Representatives and the Committee on Energy and Natural Resources of the Senate a report describing efforts of the Director to recruit and retain young scientists and engineers at early career stages at the National Laboratories."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc01b5223-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16534/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The report under paragraph (1) shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc01b5224-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16534/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of applicable Department and National Laboratory policies and procedures, including policies and procedures relating to financial incentives, awards, promotions, time reserved for independent research, access to equipment or facilities, and other forms of recognition, designed to attract and retain young scientists and engineers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc01b5225-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16534/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an evaluation of the impact of the incentives described in subparagraph (A) on—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc01b5226-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16534/g/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the careers of young scientists and engineers at the National Laboratories; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc01b5227-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16534/g/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the quality of the research at the National Laboratories and in Department programs;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc01b5228-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16534/g/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of barriers, if any, that exist with respect to efforts to recruit and retain young scientists and engineers, including the limited availability of full-time equivalent positions, legal and procedural requirements, and pay grading systems; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc01b5229-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16534/g/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of funding devoted to efforts to recruit and retain young researchers, and the source of the funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc01b522a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16534/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to the Secretary, acting through the Director, to carry out this section $25,000,000 for each of fiscal years 2008 through 2013.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc01b522b-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/69/tV/s5006"},"text":"Pub. L. 110–69, title V, § 5006","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-08-09"},"text":"Aug. 9, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/615"},"text":"121 Stat. 615","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/358/tIX/s902/c"},"text":"Pub. L. 111–358, title IX, § 902(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4045"},"text":"124 Stat. 4045","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc01b522c-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc01b522d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc01b522e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2011—Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/358"},"text":"Pub. L. 111–358","children":[],"tail":" substituted “2013” for “2010”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc01b522f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idc01b5230-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Science and Technology of House of Representatives changed to Committee on Science, Space, and Technology of House of Representatives by House Resolution No. 5, One Hundred Twelfth Congress, ","children":[{"tag":"date","attrib":{"date":"2011-01-05"},"text":"Jan. 5, 2011","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
