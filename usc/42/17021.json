{"tag":"section","attrib":{"id":"idc02034f0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17021"},"text":null,"children":[{"tag":"num","attrib":{"value":"17021"},"text":"§ 17021.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Biomass-based diesel and biodiesel labeling","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc02034f1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17021/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each retail diesel fuel pump shall be labeled in a manner that informs consumers of the percent of biomass-based diesel or biodiesel that is contained in the biomass-based diesel blend or biodiesel blend that is offered for sale, as determined by the Federal Trade Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc02034f2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17021/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Labeling requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"December 19, 2007","children":[],"tail":", the Federal Trade Commission shall promulgate biodiesel labeling requirements as follows:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc02034f3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17021/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Biomass-based diesel blends or biodiesel blends that contain less than or equal to 5 percent biomass-based diesel or biodiesel by volume and that meet ASTM D975 diesel specifications shall not require any additional labels.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02034f4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17021/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Biomass-based diesel blends or biodiesel blends that contain more than 5 percent biomass-based diesel or biodiesel by volume but not more than 20 percent by volume shall be labeled “contains biomass-based diesel or biodiesel in quantities between 5 percent and 20 percent”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02034f5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17021/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Biomass-based diesel or biodiesel blends that contain more than 20 percent biomass based or biodiesel by volume shall be labeled “contains more than 20 percent biomass-based diesel or biodiesel”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc02034f6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17021/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc02034f7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17021/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ASTM","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “ASTM” means the American Society of Testing and Materials.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02034f8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17021/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Biomass-based diesel","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “biomass-based diesel” means biodiesel as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s13220/f"},"text":"section 13220(f) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02034f9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17021/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Biodiesel","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “biodiesel” means the monoalkyl esters of long chain fatty acids derived from plant or animal matter that meet—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc02034fa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17021/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the registration requirements for fuels and fuel additives under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02034fb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17021/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the requirements of ASTM standard D6751.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02034fc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17021/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Biomass-based diesel and biodiesel blends","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “biomass-based diesel blend” and “biodiesel blend” means a blend of “biomass-based diesel” or “biodiesel” fuel that is blended with petroleum-based diesel fuel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc02034fd-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/tII/s205"},"text":"Pub. L. 110–140, title II, § 205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1529"},"text":"121 Stat. 1529","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc02034fe-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc02034ff-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc0203500-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the date that is 1 day after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/s1601"},"text":"section 1601 of Pub. L. 110–140","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1824"},"text":"section 1824 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
