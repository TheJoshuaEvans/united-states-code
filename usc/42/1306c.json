{"tag":"section","attrib":{"id":"idb81b2256-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1306c"},"text":null,"children":[{"tag":"num","attrib":{"value":"1306c"},"text":"§ 1306c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restriction on access to the Death Master File","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb81b2257-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1306c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Commerce shall not disclose to any person information contained on the Death Master File with respect to any deceased individual at any time during the 3-calendar-year period beginning on the date of the individual’s death, unless such person is certified under the program established under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb81b2258-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1306c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb81b2259-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1306c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Commerce shall establish a program—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb81b225a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1306c/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to certify persons who are eligible to access the information described in subsection (a) contained on the Death Master File, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb81b225b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1306c/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to perform periodic and unscheduled audits of certified persons to determine the compliance by such certified persons with the requirements of the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb81b225c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1306c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A person shall not be certified under the program established under paragraph (1) unless such person certifies that access to the information described in subsection (a) is appropriate because such person—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb81b225d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1306c/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" has—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb81b225e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1306c/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a legitimate fraud prevention interest, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb81b225f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1306c/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a legitimate business purpose pursuant to a law, governmental rule, regulation, or fiduciary duty, and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb81b2260-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1306c/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has systems, facilities, and procedures in place to safeguard such information, and experience in maintaining the confidentiality, security, and appropriate use of such information, pursuant to requirements similar to the requirements of section 6103(p)(4) of the Internal Revenue Code of 1986, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb81b2261-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1306c/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" agrees to satisfy the requirements of such section 6103(p)(4) as if such section applied to such person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb81b2262-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1306c/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fees","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb81b2263-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1306c/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Commerce shall establish under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s9701"},"text":"section 9701 of title 31","children":[],"tail":" a program for the charge of fees sufficient to cover (but not to exceed) all costs associated with evaluating applications for certification and auditing, inspecting, and monitoring certified persons under the program. Any fees so collected shall be deposited and credited as offsetting collections to the accounts from which such costs are paid."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb81b2264-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1306c/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Commerce shall report on an annual basis to the Committee on Finance of the Senate and the Committee on Ways and Means of the House of Representatives on the total fees collected during the preceding year and the cost of administering the certification program under this subsection for such year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb81b2265-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1306c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Imposition of penalty","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb81b2266-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1306c/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any person who is certified under the program established under subsection (b), who receives information described in subsection (a), and who during the period of time described in subsection (a)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb81b2267-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1306c/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" discloses such information to any person other than a person who meets the requirements of subparagraphs (A), (B), and (C) of subsection (b)(2),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb81b2268-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1306c/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" discloses such information to any person who uses the information for any purpose not listed under subsection (b)(2)(A) or who further discloses the information to a person who does not meet such requirements, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb81b2269-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1306c/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" uses any such information for any purpose not listed under subsection (b)(2)(A),","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"and any person to whom such information is disclosed who further discloses or uses such information as described in the preceding subparagraphs, shall pay a penalty of $1,000 for each such disclosure or use.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb81b226a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1306c/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on penalty","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb81b226b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1306c/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The total amount of the penalty imposed under this subsection on any person for any calendar year shall not exceed $250,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb81b226c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1306c/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for willful violations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subparagraph (A) shall not apply in the case of violations under paragraph (1) that the Secretary of Commerce determines to be willful or intentional violations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb81b226d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1306c/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Death Master File","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “Death Master File” means information on the name, social security account number, date of birth, and date of death of deceased individuals maintained by the Commissioner of Social Security, other than information that was provided to such Commissioner under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s405/r"},"text":"section 405(r) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb81b226e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1306c/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption from Freedom of Information Act requirement with respect to certain records of deceased individuals","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb81b226f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1306c/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No Federal agency shall be compelled to disclose the information described in subsection (a) to any person who is not certified under the program established under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb81b2270-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1306c/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552"},"text":"section 552 of title 5","children":[],"tail":", this section shall be considered a statute described in subsection (b)(3) of such section 552."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb81b2271-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1306c/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb81b2272-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1306c/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), this section shall take effect on the date that is 90 days after ","children":[{"tag":"date","attrib":{"date":"2013-12-26"},"text":"December 26, 2013","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb81b2273-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1306c/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" FOIA exemption","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsection (e) shall take effect on ","children":[{"tag":"date","attrib":{"date":"2013-12-26"},"text":"December 26, 2013","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb81b2274-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/67/dA/tII/s203"},"text":"Pub. L. 113–67, div. A, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-12-26"},"text":"Dec. 26, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/1177"},"text":"127 Stat. 1177","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb81b2275-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb81b2276-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb81b2277-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Internal Revenue Code of 1986, referred to in subsec. (b)(2)(B), is classified generally to Title 26, Internal Revenue Code.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb81b2278-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Bipartisan Budget Act of 2013, and not as part of the Social Security Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
