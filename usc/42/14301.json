{"tag":"section","attrib":{"id":"idbfcf067f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14301"},"text":null,"children":[{"tag":"num","attrib":{"value":"14301"},"text":"§ 14301.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfcf0680-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14301/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" it is in the public interest to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfcf0681-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14301/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" phase out the use of mercury in batteries and provide for the efficient and cost-effective collection and recycling or proper disposal of used nickel cadmium batteries, small sealed lead-acid batteries, and other regulated batteries; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfcf0682-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14301/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" educate the public concerning the collection, recycling, and proper disposal of such batteries;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfcf0683-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14301/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" uniform national labeling requirements for regulated batteries, rechargeable consumer products, and product packaging will significantly benefit programs for regulated battery collection and recycling or proper disposal; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfcf0684-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14301/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" it is in the public interest to encourage persons who use rechargeable batteries to participate in collection for recycling of used nickel-cadmium, small sealed lead-acid, and other regulated batteries.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfcf0685-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/142/s2"},"text":"Pub. L. 104–142, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-05-13"},"text":"May 13, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1329"},"text":"110 Stat. 1329","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbfcf0686-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbfcf0687-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"idbfcf0688-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/142/s1"},"text":"Pub. L. 104–142, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-05-13"},"text":"May 13, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1329"},"text":"110 Stat. 1329","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/142/s1"},"text":"“This Act [enacting this chapter] may be cited as the ‘Mercury-Containing and Rechargeable Battery Management Act’.”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/142/tI/s101"},"text":"Pub. L. 104–142, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-05-13"},"text":"May 13, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1332"},"text":"110 Stat. 1332","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/142/tI/s101"},"text":"“This title [enacting subchapter II of this chapter] may be cited as the ‘Rechargeable Battery Recycling Act’.”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/142/tII/s201"},"text":"Pub. L. 104–142, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-05-13"},"text":"May 13, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1336"},"text":"110 Stat. 1336","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/142/tII/s201"},"text":"“This title [enacting subchapter III of this chapter] may be cited as the ‘Mercury-Containing Battery Management Act’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
