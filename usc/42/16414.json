{"tag":"section","attrib":{"id":"idc0144dd0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16414"},"text":null,"children":[{"tag":"num","attrib":{"value":"16414"},"text":"§ 16414.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Power Plant Operations Technology and Educational Center","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc0144dd1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16414/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall support the establishment of a National Power Plant Operations Technology and Education Center (referred to in this section as the “Center”), to address the need for training and educating certified operators and technicians for the electric power industry.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0144dd2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16414/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Location of Center","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall support the establishment of the Center at an institution of higher education that has—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0144dd3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16414/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expertise in providing degree programs in electric power generation, transmission, and distribution technologies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0144dd4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16414/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expertise in providing onsite and Internet-based training; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0144dd5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16414/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrated responsiveness to workforce and training requirements in the electric power industry.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0144dd6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16414/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training and continuing education","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0144dd7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16414/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Center shall provide training and continuing education in electric power generation, transmission, and distribution technologies and operations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0144dd8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16414/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Location","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Center shall carry out training and education activities under paragraph (1)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0144dd9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16414/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at the Center; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0144dda-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16414/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" through Internet-based information technologies that allow for learning at remote sites.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc0144ddb-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tXI/s1106"},"text":"Pub. L. 109–58, title XI, § 1106","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/940"},"text":"119 Stat. 940","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
