{"tag":"section","attrib":{"id":"idbb817edc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1856c"},"text":null,"children":[{"tag":"num","attrib":{"value":"1856c"},"text":"§ 1856c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Service in line of duty","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any service performed under section 1856a or ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1856b"},"text":"section 1856b of this title","children":[],"tail":", by any officer or employee of the United States or any member of any armed force of the United States shall constitute service rendered in line of duty in such office, employment, or force. The performance of such service by any other individual shall not constitute such individual an officer or employee of the United States for the purposes of subchapter I of chapter 81 of title 5."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbb817edd-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1955-05-27/ch105/s4"},"text":"May 27, 1955, ch. 105, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/69/67"},"text":"69 Stat. 67","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbb817ede-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbb817edf-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbb817ee0-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Subchapter I of chapter 81 of title 5” substituted for “the Federal Employees’ Compensation Act, as amended” on authority of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554/s7/b"},"text":"Pub. L. 89–554, § 7(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/631"},"text":"80 Stat. 631","children":[],"tail":", the first section of which enacted Title 5, Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
