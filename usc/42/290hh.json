{"tag":"section","attrib":{"id":"idb5c4af12-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290hh"},"text":null,"children":[{"tag":"num","attrib":{"value":"290hh"},"text":"§ 290hh.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Children and violence","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5c4af13-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290hh/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in consultation with the Secretary of Education and the Attorney General, shall carry out directly or through grants, contracts or cooperative agreements with public entities a program to assist local communities in developing ways to assist children in dealing with violence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5c4af14-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290hh/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Under the program under subsection (a), the Secretary may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5c4af15-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290hh/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide financial support to enable local communities to implement programs to foster the health and development of children;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5c4af16-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290hh/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide technical assistance to local communities with respect to the development of programs described in paragraph (1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5c4af17-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290hh/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide assistance to local communities in the development of policies to address violence when and if it occurs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5c4af18-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290hh/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist in the creation of community partnerships among law enforcement, education systems and mental health and substance abuse service systems; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5c4af19-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290hh/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish mechanisms for children and adolescents to report incidents of violence or plans by other children or adolescents to commit violence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5c4af1a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290hh/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An application for a grant, contract or cooperative agreement under subsection (a) shall demonstrate that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5c4af1b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290hh/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the applicant will use amounts received to create a partnership described in subsection (b)(4) to address issues of violence in schools;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5c4af1c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290hh/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the activities carried out by the applicant will provide a comprehensive method for addressing violence, that will include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5c4af1d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290hh/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" security;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5c4af1e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290hh/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" educational reform;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5c4af1f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290hh/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the review and updating of school policies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5c4af20-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290hh/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" alcohol and drug abuse prevention and early intervention services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5c4af21-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290hh/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" mental health prevention and treatment services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5c4af22-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290hh/c/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" early childhood development and psychosocial services; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5c4af23-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290hh/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the applicant will use amounts received only for the services described in subparagraphs (D), (E), and (F) of paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5c4af24-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290hh/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Geographical distribution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall ensure that grants, contracts or cooperative agreements under subsection (a) will be distributed equitably among the regions of the country and among urban and rural areas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5c4af25-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290hh/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration of awards","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to a grant, contract or cooperative agreement under subsection (a), the period during which payments under such an award will be made to the recipient may not exceed 5 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5c4af26-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290hh/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall conduct an evaluation of each project carried out under this section and shall disseminate the results of such evaluations to appropriate public and private entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5c4af27-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290hh/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information and education","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish comprehensive information and education programs to disseminate the findings of the knowledge development and application under this section to the general public and to health care professionals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5c4af28-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290hh/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this section, $100,000,000 for fiscal year 2001, and such sums as may be necessary for each of fiscal years 2002 and 2003.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5c4af29-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title V, § 581, as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/310/dB/tXXXI/s3101"},"text":"Pub. L. 106–310, div. B, title XXXI, § 3101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-17"},"text":"Oct. 17, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1168"},"text":"114 Stat. 1168","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb5c4af2a-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb5c4af2b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb5c4af2c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another section 581 of act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", was renumbered section 596 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s290kk"},"text":"section 290kk of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
