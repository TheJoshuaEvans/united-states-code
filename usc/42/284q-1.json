{"tag":"section","attrib":{"id":"idb5655195-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284q–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"284q–1"},"text":"§ 284q–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" NIH opioid research","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5655196-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284q–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director of the National Institutes of Health (referred to in this section as the “NIH”) may intensify and coordinate fundamental, translational, and clinical research of the NIH with respect to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5655197-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284q–1/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the understanding of pain;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5655198-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284q–1/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the discovery and development of therapies for chronic pain; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5655199-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284q–1/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development of alternatives to opioids for effective pain treatments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb565519a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284q–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority and direction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The prioritization and direction of the Federally funded portfolio of pain research studies shall consider recommendations made by the Interagency Pain Research Coordinating Committee in concert with the Pain Management Best Practices Inter-Agency Task Force, and in accordance with the National Pain Strategy, the Federal Pain Research Strategy, and the NIH-Wide Strategic Plan for Fiscal Years 2016–2020, the latter of which calls for the relative burdens of individual diseases and medical disorders to be regarded as crucial considerations in balancing the priorities of the Federal research portfolio.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb565519b-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/198/tI/s108"},"text":"Pub. L. 114–198, title I, § 108","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-07-22"},"text":"July 22, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/705"},"text":"130 Stat. 705","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb565519c-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb565519d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb565519e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Comprehensive Addiction and Recovery Act of 2016, and not as part of the Public Health Service Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
