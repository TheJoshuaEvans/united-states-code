{"tag":"section","attrib":{"id":"idbd1df0bf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189f"},"text":null,"children":[{"tag":"num","attrib":{"value":"5189f"},"text":"§ 5189f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public assistance program alternative procedures","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd1df0c0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189f/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval of projects","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President, acting through the Administrator of the Federal Emergency Management Agency, may approve projects under the alternative procedures adopted under this section for any major disaster or emergency declared on or after ","children":[{"tag":"date","attrib":{"date":"2013-01-29"},"text":"January 29, 2013","children":[],"tail":". The Administrator may also apply the alternate procedures adopted under this section to a major disaster or emergency declared before enactment of this Act for which construction has not begun as of the date of enactment of this Act."},{"tag":"ref","attrib":{"idref":"fn003409"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003409"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd1df0c1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189f/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adoption","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator, in coordination with States, tribal and local governments, and owners or operators of private nonprofit facilities, may adopt alternative procedures to administer assistance provided under sections 5170b(a)(3)(A), 5172, 5173, and 5192(a)(5) of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd1df0c2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189f/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Goals of procedures","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The alternative procedures adopted under subsection (a) shall further the goals of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd1df0c3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189f/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reducing the costs to the Federal Government of providing such assistance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd1df0c4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189f/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increasing flexibility in the administration of such assistance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd1df0c5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189f/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expediting the provision of such assistance to a State, tribal or local government, or owner or operator of a private nonprofit facility; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd1df0c6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189f/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing financial incentives and disincentives for a State, tribal or local government, or owner or operator of a private nonprofit facility for the timely and cost-effective completion of projects with such assistance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd1df0c7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189f/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Participation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd1df0c8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189f/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Participation in the alternative procedures adopted under this section shall be at the election of a State, tribal or local government, or owner or operator of a private nonprofit facility consistent with procedures determined by the Administrator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd1df0c9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189f/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No conditions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President may not condition the provision of Federal assistance under this chapter on the election by a State, local, or Indian tribal government, or owner or operator of a private nonprofit facility to participate in the alternative procedures adopted under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd1df0ca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189f/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum procedures","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The alternative procedures adopted under this section shall include the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd1df0cb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189f/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For repair, restoration, and replacement of damaged facilities under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5172"},"text":"section 5172 of this title","children":[],"tail":"—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd1df0cc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189f/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" making grants on the basis of fixed estimates, if the State, tribal or local government, or owner or operator of the private nonprofit facility agrees to be responsible for any actual costs that exceed the estimate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd1df0cd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189f/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" providing an option for a State, tribal or local government, or owner or operator of a private nonprofit facility to elect to receive an in-lieu contribution, without reduction, on the basis of estimates of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbd1df0ce-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189f/e/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cost of repair, restoration, reconstruction, or replacement of a public facility owned or controlled by the State, tribal or local government or owner or operator of a private nonprofit facility; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd1df0cf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189f/e/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" management expenses;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd1df0d0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189f/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consolidating, to the extent determined appropriate by the Administrator, the facilities of a State, tribal or local government, or owner or operator of a private nonprofit facility as a single project based upon the estimates adopted under the procedures;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd1df0d1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189f/e/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" if the actual costs of a project completed under the procedures are less than the estimated costs thereof, the Administrator may permit a grantee or subgrantee to use all or part of the excess funds for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbd1df0d2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189f/e/1/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cost-effective activities that reduce the risk of future damage, hardship, or suffering from a major disaster; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd1df0d3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189f/e/1/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other activities to improve future Public Assistance operations or planning;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd1df0d4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189f/e/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in determining eligible costs under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5172"},"text":"section 5172 of this title","children":[],"tail":", the Administrator shall make available, at an applicant’s request and where the Administrator or the certified cost estimate prepared by the applicant’s professionally licensed engineers has estimated an eligible Federal share for a project of at least $5,000,000, an independent expert panel to validate the estimated eligible cost consistent with applicable regulations and policies implementing this section;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd1df0d5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189f/e/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in determining eligible costs under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5172"},"text":"section 5172 of this title","children":[],"tail":", the Administrator shall, at the applicant’s request, consider properly conducted and certified cost estimates prepared by professionally licensed engineers (mutually agreed upon by the Administrator and the applicant), to the extent that such estimates comply with applicable regulations, policy, and guidance; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd1df0d6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189f/e/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" once certified by a professionally licensed engineer and accepted by the Administrator, the estimates on which grants made pursuant to this section are based shall be presumed to be reasonable and eligible costs, as long as there is no evidence of fraud.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd1df0d7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189f/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For debris removal under sections 5170b(a)(3)(A), 5173, and 5192(a)(5) of this title—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd1df0d8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189f/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" making grants on the basis of fixed estimates to provide financial incentives and disincentives for the timely or cost-effective completion if the State, tribal or local government, or owner or operator of the private nonprofit facility agrees to be responsible to pay for any actual costs that exceed the estimate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd1df0d9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189f/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" using a sliding scale for determining the Federal share for removal of debris and wreckage based on the time it takes to complete debris and wreckage removal;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd1df0da-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189f/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allowing use of program income from recycled debris without offset to the grant amount;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd1df0db-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189f/e/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reimbursing base and overtime wages for employees and extra hires of a State, tribal or local government, or owner or operator of a private nonprofit facility performing or administering debris and wreckage removal;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd1df0dc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189f/e/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing incentives to a State or tribal or local government to have a debris management plan approved by the Administrator and have pre-qualified 1 or more debris and wreckage removal contractors before the date of declaration of the major disaster; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd1df0dd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189f/e/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" if the actual costs of projects under subparagraph (A) are less than the estimated costs of the project, the Administrator may permit a grantee or subgrantee to use all or part of the excess funds for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbd1df0de-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189f/e/2/F/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" debris management planning;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd1df0df-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189f/e/2/F/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acquisition of debris management equipment for current or future use; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd1df0e0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189f/e/2/F/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other activities to improve future debris removal operations, as determined by the Administrator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd1df0e1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189f/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver authority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Until such time as the Administrator promulgates regulations to implement this section, the Administrator may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd1df0e2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189f/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" waive notice and comment rulemaking, if the Administrator determines the waiver is necessary to expeditiously implement this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd1df0e3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189f/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry out the alternative procedures under this section as a pilot program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd1df0e4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189f/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Overtime payments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The guidelines for reimbursement for costs under subsection (e)(2)(D) shall ensure that no State or local government is denied reimbursement for overtime payments that are required pursuant to the Fair Labor Standards Act of 1938 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s201"},"text":"29 U.S.C. 201","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd1df0e5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189f/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd1df0e6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189f/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not earlier than 3 years, and not later than 5 years, after ","children":[{"tag":"date","attrib":{"date":"2013-01-29"},"text":"January 29, 2013","children":[],"tail":", the Inspector General of the Department of Homeland Security shall submit to the Committee on Homeland Security and Governmental Affairs of the Senate and the Committee on Transportation and Infrastructure of the House of Representatives a report on the alternative procedures for the repair, restoration, and replacement of damaged facilities under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5172"},"text":"section 5172 of this title","children":[],"tail":" authorized under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd1df0e7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189f/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The report shall contain an assessment of the effectiveness of the alternative procedures, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd1df0e8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189f/h/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether the alternative procedures helped to improve the general speed of disaster recovery;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd1df0e9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189f/h/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the accuracy of the estimates relied upon;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd1df0ea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189f/h/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether the financial incentives and disincentives were effective;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd1df0eb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189f/h/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether the alternative procedures were cost effective;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd1df0ec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189f/h/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether the independent expert panel described in subsection (e)(1)(E) was effective; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd1df0ed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189f/h/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommendations for whether the alternative procedures should be continued and any recommendations for changes to the alternative procedures.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd1df0ee-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/288/tIV/s428"},"text":"Pub. L. 93–288, title IV, § 428","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/113/2/dB/s1102/2"},"text":"Pub. L. 113–2, div. B, § 1102(2)","children":[]