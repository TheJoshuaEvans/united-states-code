{"tag":"section","attrib":{"id":"idb9a210c4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395jj"},"text":null,"children":[{"tag":"num","attrib":{"value":"1395jj"},"text":"§ 1395jj.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation of organization or publication by name","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Designation in this subchapter, by name, of any nongovernmental organization or publication shall not be affected by change of name of such organization or publication, and shall apply to any successor organization or publication which the Secretary finds serves the purpose for which such designation is made.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb9a210c5-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title XVIII, § 1873, as added "},{"tag":"ref","attrib":{"href":"/us/pl/89/97/tI/s102/a"},"text":"Pub. L. 89–97, title I, § 102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-07-30"},"text":"July 30, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/332"},"text":"79 Stat. 332","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
