{"tag":"section","attrib":{"id":"idbe054358-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7322"},"text":null,"children":[{"tag":"num","attrib":{"value":"7322"},"text":"§ 7322.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional review","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbe054359-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7322/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each proposed Plan shall be referred to the appropriate committees in the Senate and the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe05435a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7322/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each such committee shall review the proposed Plan and, if it deems appropriate and necessary, report to the Senate or the House of Representatives legislation regarding such Plan which may contain such alternatives to, modifications of, or additions to the proposed Plan submitted by the President as the committee deems appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbe05435b-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/91/tVIII/s802"},"text":"Pub. L. 95–91, title VIII, § 802","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-08-04"},"text":"Aug. 4, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/611"},"text":"91 Stat. 611","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
