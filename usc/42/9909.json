{"tag":"section","attrib":{"id":"idbf06d580-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9909"},"text":null,"children":[{"tag":"num","attrib":{"value":"9909"},"text":"§ 9909.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation and redesignation of eligible entities in unserved areas","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf06d581-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9909/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified organization in or near area","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf06d582-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9909/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If any geographic area of a State is not, or ceases to be, served by an eligible entity under this chapter, and if the chief executive officer of the State decides to serve such area, the chief executive officer may solicit applications from, and designate as an eligible entity—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf06d583-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9909/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a private nonprofit organization (which may include an eligible entity) that is geographically located in the unserved area, that is capable of providing a broad range of services designed to eliminate poverty and foster self-sufficiency, and that meets the requirements of this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf06d584-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9909/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a private nonprofit eligible entity that is geographically located in an area contiguous to or within reasonable proximity of the unserved area and that is already providing related services in the unserved area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf06d585-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9909/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In order to serve as the eligible entity for the area, an entity described in paragraph (1)(B) shall agree to add additional members to the board of the entity to ensure adequate representation—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf06d586-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9909/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in each of the three required categories described in subparagraphs (A), (B), and (C) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s9910/a/2"},"text":"section 9910(a)(2) of this title","children":[],"tail":", by members that reside in the community comprised by the unserved area; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf06d587-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9909/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the category described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s9910/a/2/B"},"text":"section 9910(a)(2)(B) of this title","children":[],"tail":", by members that reside in the neighborhood to be served."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf06d588-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9909/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special consideration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In designating an eligible entity under subsection (a), the chief executive officer shall grant the designation to an organization of demonstrated effectiveness in meeting the goals and purposes of this chapter and may give priority, in granting the designation, to eligible entities that are providing related services in the unserved area, consistent with the needs identified by a community-needs assessment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf06d589-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9909/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No qualified organization in or near area","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If no private, nonprofit organization is identified or determined to be qualified under subsection (a) to serve the unserved area as an eligible entity the chief executive officer may designate an appropriate political subdivision of the State to serve as an eligible entity for the area. In order to serve as the eligible entity for that area, the political subdivision shall have a board or other mechanism as required in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s9910/b"},"text":"section 9910(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf06d58a-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35/tVI/s676A"},"text":"Pub. L. 97–35, title VI, § 676A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/285/tII/s201"},"text":"Pub. L. 105–285, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-27"},"text":"Oct. 27, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2739"},"text":"112 Stat. 2739","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf06d58b-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf06d58c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbf06d58d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 9909, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35/tVI/s680"},"text":"Pub. L. 97–35, title VI, § 680","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/517"},"text":"95 Stat. 517","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/425/tIV/s405/c/2"},"text":"Pub. L. 99–425, title IV, § 405(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-09-30"},"text":"Sept. 30, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/970"},"text":"100 Stat. 970","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/171/s7/c/3"},"text":"Pub. L. 103–171, § 7(c)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-02"},"text":"Dec. 2, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1994"},"text":"107 Stat. 1994","children":[],"tail":", related to limitation on use of grants for construction and waiver of such limitation, prior to the general amendment of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/105/285"},"text":"Pub. L. 105–285","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35/s676A"},"text":"section 676A of Pub. L. 97–35","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s9905a"},"text":"section 9905a of this title","children":[],"tail":", prior to the general amendment of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/105/285"},"text":"Pub. L. 105–285","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
