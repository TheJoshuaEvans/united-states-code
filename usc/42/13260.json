{"tag":"section","attrib":{"id":"idbfb73a14-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13260"},"text":null,"children":[{"tag":"num","attrib":{"value":"13260"},"text":"§ 13260.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect on other laws","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfb73a15-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13260/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this Act or the amendments made by this Act shall be construed to alter, affect, or modify the provisions of the Clean Air Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7401"},"text":"42 U.S.C. 7401","children":[],"tail":" et seq.], or regulations issued thereunder."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfb73a16-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13260/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compliance by alternative fueled vehicles","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Alternative fueled vehicles, whether dedicated vehicles or dual fueled vehicles, and the alternative fuels for operating such vehicles, shall comply with requirements of the Clean Air Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7401"},"text":"42 U.S.C. 7401","children":[],"tail":" et seq.] applicable to such vehicles and fuels."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfb73a17-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/tV/s510"},"text":"Pub. L. 102–486, ti