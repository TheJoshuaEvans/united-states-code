{"tag":"section","attrib":{"id":"idbc107870-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2243"},"text":null,"children":[{"tag":"num","attrib":{"value":"2243"},"text":"§ 2243.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Licensing of uranium enrichment facilities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbc107871-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2243/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Environmental impact statement","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc107872-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2243/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Major Federal action","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The issuance of a license under sections 2073 and 2093 of this title for the construction and operation of any uranium enrichment facility shall be considered a major Federal action significantly affecting the quality of the human environment for purposes of the National Environmental Policy Act of 1969 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"42 U.S.C. 4321","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc107873-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2243/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An environmental impact statement prepared under paragraph (1) shall be prepared before the hearing on the issuance of a license for the construction and operation of a uranium enrichment facility is completed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc107874-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2243/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjudicatory hearing","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc107875-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2243/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall conduct a single adjudicatory hearing on the record with regard to the licensing of the construction and operation of a uranium enrichment facility under sections 2073 and 2093 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc107876-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2243/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Such hearing shall be completed and a decision issued before the issuance of a license for such construction and operation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc107877-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2243/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Single proceeding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No further Commission licensing action shall be required to authorize operation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc107878-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2243/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inspection and operation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Prior to commencement of operation of a uranium enrichment facility licensed hereunder, the Commission shall verify through inspection that the facility has been constructed in accordance with the requirements of the license for construction and operation. The Commission shall publish notice of the inspection results in the Federal Register.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc107879-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2243/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Insurance and decommissioning","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc10787a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2243/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Commission shall require, as a condition of the issuance of a license under sections 2073 and 2093 of this title for a uranium enrichment facility, that the licensee have and maintain liability insurance of such type and in such amounts as the Commission judges appropriate to cover liability claims arising out of any occurrence within the United States, causing, within or outside the United States, bodily injury, sickness, disease, or death, or loss of or damage to property, or loss of use of property, arising out of or resulting from the radioactive, toxic, explosive, or other hazardous properties of chemical compounds containing source or special nuclear material.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc10787b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2243/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Commission shall require, as a condition for the issuance of a license under sections 2073 and 2093 of this title for a uranium enrichment facility, that the licensee provide adequate assurance of the availability of funds for the decommissioning (including decontamination) of such facility using funding mechanisms that may include, but are not necessarily limited to, the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc10787c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2243/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Prepayment (in the form of a trust, escrow account, government fund, certificate of deposit, or deposit of government securities).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc10787d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2243/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Surety (in the form of a surety or performance bond, letter of credit, or line of credit), insurance, or other guarantee (including parent company guarantee) method.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc10787e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2243/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" External sinking fund in which deposits are made at least annually.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc10787f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2243/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No Price-Anderson coverage","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2210"},"text":"Section 2210 of this title","children":[],"tail":" shall not apply to any license under section 2073 or 2093 of this title for a uranium enrichment facility constructed after "},{"tag":"date","attrib":{"date":"1990-11-15"},"text":"November 15, 1990","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc107880-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2243/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No license or certificate of compliance may be issued to the United States Enrichment Corporation or its successor under this section or sections ","children":[{"tag":"ref","attrib":{"idref":"fn003280"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003280"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “section”."}],"tail":" 2073, 2093, or 2297f of this title, if the Commission determines that—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc107881-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2243/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Corporation is owned, controlled, or dominated by an alien, a foreign corporation, or a foreign government; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc107882-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2243/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the issuance of such a license or certificate of compliance would be inimical to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc107883-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2243/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the common defense and security of the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc107884-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2243/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the maintenance of a reliable and economical domestic source of enrichment services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc107885-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-08-01/ch724"},"text":"Aug. 1, 1946, ch. 724","children":[],"tail":", title I, § 193, as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/575/s5/e"},"text":"Pub. L. 101–575, § 5(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-15"},"text":"Nov. 15, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2835"},"text":"104 Stat. 2835","children":[],"tail":"; renumbered title I, "},{"tag":"ref","attrib":{"href":"/us/pl/102/486/tIX/s902/a/8"},"text":"Pub. L. 102–486, title IX, § 902(a)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2944"},"text":"106 Stat. 2944","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/134/tIII/s3116/b/2"},"text":"Pub. L. 104–134, title III, § 3116(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-26"},"text":"Apr. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1321-349"},"text":"110 Stat. 1321–349","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc107886-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc107887-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbc107888-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The National Environmental Policy Act of 1969, referred to in subsec. (a)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/190"},"text":"Pub. L. 91–190","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-01-01"},"text":"Jan. 1, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/852"},"text":"83 Stat. 852","children":[],"tail":", which is classified generally to chapter 55 (§ 4321 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"section 4321 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbc107889-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/134"},"text":"Pub. L. 104–134","children":[],"tail":" added subsec. (f)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbc10788a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbc10788b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"References to United States Enrichment Corporation","children":[],"tail":null},{"tag":"p","attrib":{},"text":"References to the United States Enrichment Corporation deemed, as of the privatization date (","children":[{"tag":"date","attrib":{"date":"1998-07-28"},"text":"July 28, 1998","children":[],"tail":"), to be references to the private corporation, see "},{"tag":"ref","attrib":{"href":"/us/pl/104/134/s3116/e"},"text":"section 3116(e) of Pub. L. 104–134","children":[],"tail":", set out as a note under former "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2297"},"text":"section 2297 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
