{"tag":"section","attrib":{"id":"idbdc023e0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6864c"},"text":null,"children":[{"tag":"num","attrib":{"value":"6864c"},"text":"§ 6864c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contractor optimization","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbdc023e1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6864c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may request that entities receiving funding from the Federal Government or from a State through a weatherization assistance program under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6863"},"text":"section 6863 of this title","children":[],"tail":" or "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s6864"},"text":"section 6864 of this title","children":[],"tail":" perform periodic reviews of the use of private contractors in the provision of weatherization assistance, and encourage expanded use of contractors as appropriate."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdc023e2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6864c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of training funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Entities described in subsection (a) may use funding described in such subsection to train private, non-Federal entities that are contracted to provide weatherization assistance under a weatherization program, in accordance with rules determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbdc023e3-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/385/tIV/s414C"},"text":"Pub. L. 94–385, title IV, § 414C","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dZ/tI/s1011/d/1"},"text":"Pub. L. 116–260, div. Z, title I, § 1011(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2442"},"text":"134 Stat. 2442","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
