{"tag":"section","attrib":{"id":"idbfa1b580-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12804"},"text":null,"children":[{"tag":"num","attrib":{"value":"12804"},"text":"§ 12804.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rehabilitation loans","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfa1b581-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12804/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall make available a model program to provide direct loans to finance the rehabilitation of low and moderate income single family and multifamily residential properties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfa1b582-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12804/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Condition of loans","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish terms and conditions to ensure that such loans are acceptable risks, taking into consideration the need for rehabilitation, the security for the loan and the ability of the borrower to repay the loan. The Secretary may establish the interest rate for loans under the model program, which shall include special interest rates for loans to borrowers with incomes below 80 percent of the area median income.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfa1b583-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12804/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional restrictions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Guidelines for the model program may require that the property—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfa1b584-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12804/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be located in an area that contains a substantial number of dwellings in need of rehabilitation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfa1b585-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12804/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the property ","children":[{"tag":"ref","attrib":{"idref":"fn004114"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004114"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The words “the property” probably should not appear."}],"tail":" is residential and owner-occupied; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfa1b586-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12804/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the property ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" is in need of rehabilitation or concentrated code enforcement within a reasonable time, and the rehabilitation of such property is consistent with a local plan for rehabilitation or code enforcement."}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Additional guidelines for the model program shall generally comport with the additional protections and restrictions specified under section 1452b ","children":[{"tag":"ref","attrib":{"idref":"fn004115"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004115"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" See References in Text note below."}],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfa1b587-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/625/tII/s254"},"text":"Pub. L. 101–625, title II, § 254","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4121"},"text":"104 Stat. 4121","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbfa1b588-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbfa1b589-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbfa1b58a-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1452b"},"text":"Section 1452b of this title","children":[],"tail":", referred to in subsec. (c), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/101/625/tII/s289/b/1"},"text":"Pub. L. 101–625, title II, § 289(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4128"},"text":"104 Stat. 4128","children":[],"tail":", which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12839/b/1"},"text":"section 12839(b)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
