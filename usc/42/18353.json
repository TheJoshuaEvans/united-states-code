{"tag":"section","attrib":{"id":"idc056fbce-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18353"},"text":null,"children":[{"tag":"num","attrib":{"value":"18353"},"text":"§ 18353.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maintenance of the United States segment and assurance of continued operations of the International Space Station","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc056fbcf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18353/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall take all actions necessary to ensure the safe and effective operation, maintenance, and maximum utilization of the United States segment of the ISS through at least ","children":[{"tag":"date","attrib":{"date":"2030-09-30"},"text":"September 30, 2030","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc056fbd0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18353/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vehicle and component review","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc056fbd1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18353/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall, as soon as is practicable after ","children":[{"tag":"date","attrib":{"date":"2010-10-11"},"text":"October 11, 2010","children":[],"tail":", carry out a comprehensive assessment of the essential modules, operational systems and components, structural elements, and permanent scientific equipment on board or planned for delivery and installation aboard the ISS, including both United States and international partner elements, for purposes of identifying the spare or replacement modules, systems and components, elements, and equipment that are required to ensure complete, effective, and safe functioning and full scientific utilization of the ISS through "},{"tag":"date","attrib":{"date":"2020-09-30"},"text":"September 30, 2020","children":[],"tail":"."},{"tag":"ref","attrib":{"idref":"fn004354"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004354"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc056fbd2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18353/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out the assessment, the Administrator shall assemble any existing data, and provide for the development of any data or analysis not currently available, that is necessary for purposes of the assessment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc056fbd3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18353/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc056fbd4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18353/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report on assessment","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc056fbd5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18353/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"2010-10-11"},"text":"October 11, 2010","children":[],"tail":", the Administrator shall submit to the appropriate committees of Congress a report on the assessment required by subsection (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc056fbd6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18353/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Elements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The report required by this paragraph shall include, at minimum, the following:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc056fbd7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18353/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A description of the spare or replacement modules, systems and components, elements, and equipment identified pursuant to the assessment that are currently produced, in inventory, or on order, a description of the state of their readiness, and a schedule for their delivery to the ISS (including the planned transportation means for such delivery), including for each such module, system or component, element, or equipment a description of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idc056fbd8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18353/c/1/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" its specifications, including size, weight, and necessary configuration for launch and delivery to the ISS;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc056fbd9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18353/c/1/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" its function;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc056fbda-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18353/c/1/B/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" its location; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc056fbdb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18353/c/1/B/i/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" its criticality for ISS system integrity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc056fbdc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18353/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A description of the spare or replacement modules, systems and components, elements, and equipment identified pursuant to the assessment that are not currently produced, in inventory, or on order, including for each such module, system or component, element, or equipment a description of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idc056fbdd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18353/c/1/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" its specifications, including size, weight, and necessary configuration for launch and delivery to the ISS;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc056fbde-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18353/c/1/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" its function;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc056fbdf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18353/c/1/B/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" its location;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc056fbe0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18353/c/1/B/ii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" its criticality for ISS system integrity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc056fbe1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18353/c/1/B/ii/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the anticipated cost and schedule for its design, procurement, manufacture, and delivery to the ISS.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc056fbe2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18353/c/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A detailed summary of the delivery schedule and associated delivery vehicle requirements necessary to transport all spare and replacement elements considered essential for the ongoing and sustained functionality of all critical systems of the ISS, both in and of themselves and as an element of an integrated, mutually dependent essential capability, including an assessment of the current schedule for delivery, the availability of delivery vehicles to meet that schedule, and the likelihood of meeting that schedule through such vehicles.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc056fbe3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18353/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" GAO report","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc056fbe4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18353/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 90 days after the submittal to Congress under paragraph (1) of the assessment required by subsection (b), the Comptroller General of the United States shall submit to the appropriate committees of Congress a report on the assessment. The report shall set forth an evaluation of the assessment by the Comptroller General, including an evaluation of the accuracy and level of confidence in the findings of the assessment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc056fbe5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18353/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperation with GAO","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall provide for the monitoring and participation of the Comptroller General in the assessment in a manner that permits the Comptroller General to prepare and submit the report required by subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc056fbe6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18353/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Utilization of research facilities and capabilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Utilization of research facilities and capabilities aboard the ISS (other than exploration-related research and technology development facilities and capabilities, and associated ground support and logistics), shall be planned, managed, and supported as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s18354"},"text":"section 18354 of this title","children":[],"tail":". Exploration-related research and technology development facilities, capabilities, and associated ground support and logistics shall be planned, managed, and supported by the appropriate NASA organizations and officials in a manner that does not interfere with other activities under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s18354"},"text":"section 18354 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc056fbe7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18353/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Space Shuttle mission to ISS","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc056fbe8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18353/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Space Shuttle mission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall fly the Launch-On-Need Shuttle mission currently designated in the Shuttle Flight Manifest dated ","children":[{"tag":"date","attrib":{"date":"2010-02-28"},"text":"February 28, 2010","children":[],"tail":", to the ISS in fiscal year 2011, but no earlier than "},{"tag":"date","attrib":{"date":"2011-06-01"},"text":"June 1, 2011","children":[],"tail":", unless required earlier by an operations contingency, and pending the results of the assessment required by paragraph (2) and the determination under paragraph (3)(A)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc056fbe9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18353/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessment of safe means of return","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall provide for an assessment by the NASA Engineering and Safety Center of the procedures and plans developed to ensure the safety of the Space Shuttle crew, and alternative means of return, in the event the Space Shuttle is damaged or otherwise unable to return safely to Earth.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc056fbea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18353/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Schedule and payload","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The determination of the schedule and payload for the mission authorized by paragraph (1) shall take into account the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc056fbeb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18353/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The supply and logistics delivery requirements of the ISS.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc056fbec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18353/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The findings of the study required by paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc056fbed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18353/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts authorized to be appropriated by section 101(2)(B) ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" shall be available for the mission authorized by paragraph (1)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc056fbee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18353/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Space Shuttle manifest flight assurance","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc056fbef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18353/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall take all actions necessary to preserve Space Shuttle launch capability through fiscal year 2011 in a manner that enables the launch, at a minimum, of missions and primary payloads in the Shuttle flight manifest as of ","children":[{"tag":"date","attrib":{"date":"2010-02-28"},"text":"February 28, 2010","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc056fbf0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18353/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continuation of contractor support","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator may not terminate any contract that provides the system transitions necessary for shuttle-derived hardware to be used on either the multi-purpose crew vehicle described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s18323"},"text":"section 18323 of this title","children":[],"tail":" or the Space Launch System described in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s18322"},"text":"section 18322 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc056fbf1-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/267/tV/s503"},"text":"Pub. L. 111–267, title V, § 503","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-11"},"text":"Oct. 11, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2823"},"text":"124 Stat. 2823","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/90/tI/s114/b/2"},"text":"Pub. L. 114–90, title I, § 114(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-11-25"},"text":"Nov. 25, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/716"},"text":"129 Stat. 716","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/tVII/s10815/b"},"text":"Pub. L. 117–167, div. B, title VII, § 10815(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1737"},"text":"136 Stat. 1737","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc056fbf2-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc056fbf3-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc056fbf4-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Reference to ","children":[{"tag":"date","attrib":{"date":"2020-09-30"},"text":"September 30, 2020","children":[],"tail":", referred to in subsec. (b)(1), was not amended by "},{"tag":"ref","attrib":{"href":"/us/pl/114/90/s114/b"},"text":"section 114(b) of Pub. L. 114–90","children":[],"tail":", which substituted references to “2024” for references to “2020” in other provisions throughout this subchapter. See also "},{"tag":"ref","attrib":{"href":"/us/usc/t51/s70907"},"text":"section 70907 of Title 51","children":[],"tail":", National and Commercial Space Programs, as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/114/90/s114/b"},"text":"section 114(b) of Pub. L. 114–90","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 101(2)(B), referred to in subsec. (e)(4), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/267/tI/s101/2/B"},"text":"Pub. L. 111–267, title I, § 101(2)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-11"},"text":"Oct. 11, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2809"},"text":"124 Stat. 2809","children":[],"tail":", which is not classified to the Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc056fbf5-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167"},"text":"Pub. L. 117–167","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2030-09-30"},"text":"September 30, 2030","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2024-09-30"},"text":"September 30, 2024","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2015—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/90/s114/b/2/A"},"text":"Pub. L. 114–90, § 114(b)(2)(A)","children":[],"tail":", substituted “through at least "},{"tag":"date","attrib":{"date":"2024-09-30"},"text":"September 30, 2024","children":[],"tail":"” for “through at least "},{"tag":"date","attrib":{"date":"2020-09-30"},"text":"September 30, 2020","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/90/s114/b/2/B"},"text":"Pub. L. 114–90, § 114(b)(2)(B)","children":[],"tail":", substituted “The Administrator” for “In carrying out subsection (a), the Administrator”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
