{"tag":"section","attrib":{"id":"idc016975a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16502"},"text":null,"children":[{"tag":"num","attrib":{"value":"16502"},"text":"§ 16502.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advanced Biofuel Technologies Program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc016975b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16502/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the availability of appropriations under subsection (d), the Administrator of the Environmental Protection Agency shall, in consultation with the Secretary of Agriculture and the Biomass Research and Development Technical Advisory Committee established under section 8605 ","children":[{"tag":"ref","attrib":{"idref":"fn004228"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004228"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of title 7, establish a program, to be known as the “Advanced Biofuel Technologies Program”, to demonstrate advanced technologies for the production of alternative transportation fuels."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc016975c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16502/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out the program under subsection (a), the Administrator shall give priority to projects that enhance the geographical diversity of alternative fuels production and utilize feedstocks that represent 10 percent or less of ethanol or biodiesel fuel production in the United States during the previous fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc016975d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16502/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Demonstration projects","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc016975e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16502/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As part of the program under subsection (a), the Administrator shall fund demonstration projects—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc016975f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16502/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop not less than 4 different conversion technologies for producing cellulosic biomass ethanol; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0169760-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16502/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop not less than 5 technologies for coproducing value-added bioproducts (such as fertilizers, herbicides, and pesticides) resulting from the production of biodiesel fuel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0169761-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16502/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Demonstration projects under this subsection shall be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0169762-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16502/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conducted based on a merit-reviewed, competitive process; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0169763-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16502/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to the cost-sharing requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16352"},"text":"section 16352 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0169764-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16502/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this section $110,000,000 for each of fiscal years 2005 through 2009.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc0169765-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tXV/s1514"},"text":"Pub. L. 109–58, title XV, § 1514","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1090"},"text":"119 Stat. 1090","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc0169766-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc0169767-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc0169768-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s8605"},"text":"Section 8605 of title 7","children":[],"tail":", referred to in subsec. (a), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/tIX/s9001/b"},"text":"Pub. L. 110–246, title IX, § 9001(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2095"},"text":"122 Stat. 2095","children":[],"tail":". Provisions relating to a Biomass Research and Development Technical Advisory Committee are now contained in "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8108/d"},"text":"section 8108(d) of title 7","children":[],"tail":", Agriculture."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
