{"tag":"section","attrib":{"id":"idc029ab0a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17154"},"text":null,"children":[{"tag":"num","attrib":{"value":"17154"},"text":"§ 17154.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"An eligible entity may use a grant received under this part to carry out activities to achieve the purposes of the program, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc029ab0b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17154/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" development and implementation of an energy efficiency and conservation strategy under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s17155/b"},"text":"section 17155(b) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc029ab0c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17154/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" retaining technical consultant services to assist the eligible entity in the development of such a strategy, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc029ab0d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17154/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" formulation of energy efficiency, energy conservation, and energy usage goals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc029ab0e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17154/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" identification of strategies to achieve those goals—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc029ab0f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17154/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" through efforts to increase energy efficiency and reduce energy consumption; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc029ab10-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17154/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by encouraging behavioral changes among the population served by the eligible entity;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc029ab11-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17154/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" development of methods to measure progress in achieving the goals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc029ab12-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17154/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" development and publication of annual reports to the population served by the eligible entity describing—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc029ab13-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17154/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the strategies and goals; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc029ab14-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17154/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the progress made in achieving the strategies and goals during the preceding calendar year; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc029ab15-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17154/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other services to assist in the implementation of the energy efficiency and conservation strategy;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc029ab16-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17154/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conducting residential and commercial building energy audits;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc029ab17-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17154/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishment of financial incentive programs for energy efficiency improvements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02c1b18-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17154/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the provision of grants to nonprofit organizations and governmental agencies for the purpose of performing energy efficiency retrofits;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02c1b19-3a70-11f1-ae07-e4213316b5fa","i