","identifier":"/us/usc/t42/s17154/7/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" synchronization of traffic signals; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02c1b25-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17154/7/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other measures that increase energy efficiency and decrease energy consumption;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02c1b26-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17154/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" development and implementation of building codes and inspection services to promote building energy efficiency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02c1b27-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17154/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" application and implementation of energy distribution technologies that significantly increase energy efficiency, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc02c1b28-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17154/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" distributed resources; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02c1b29-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17154/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" district heating and cooling systems;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02c1b2a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17154/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" activities to increase participation and efficiency rates for material conservation programs, including source reduction, recycling, and recycled content procurement programs that lead to increases in energy efficiency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02c1b2b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17154/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the purchase and implementation of technologies to reduce, capture, and, to the maximum extent practicable, use methane and other greenhouse gases generated by landfills or similar sources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02c1b2c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17154/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" replacement of traffic signals and street lighting with energy efficient lighting technologies, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc02c1b2d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17154/12/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" light emitting diodes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02c1b2e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17154/12/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other technology of equal or greater energy efficiency;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02c1b2f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17154/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" development, implementation, and installation on or in any government building of the eligible entity of onsite renewable energy technology that generates electricity from renewable resources, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc02c1b30-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17154/13/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" solar energy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02c1b31-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17154/13/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" wind energy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02c1b32-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17154/13/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fuel cells; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02c1b33-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17154/13/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" biomass;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02