{"tag":"section","attrib":{"id":"idbdb686b7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6634"},"text":null,"children":[{"tag":"num","attrib":{"value":"6634"},"text":"§ 6634.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continuation of Committee","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbdb686b8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6634/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Ninety days after submission of the final report prepared under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6633"},"text":"section 6633 of this title","children":[],"tail":", the Committee shall cease to exist, unless the President, before the expiration of the ninety-day period, makes a determination that it is advantageous for the Committee to continue in being."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdb686b9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6634/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the President determines that it is advantageous for the Committee to continue in being, (1) the Committee shall exercise such functions as are prescribed by the President; and (2) the members of the Committee shall serve at the pleasure of the President.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbdb686ba-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/282/tIII/s304"},"text":"Pub. L. 94–282, title III, § 304","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-05-11"},"text":"May 11, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/470"},"text":"90 Stat. 470","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbdb686bb-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idbdb686bc-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbdb686bd-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Abolition of President’s Committee on Science and Technology; Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"See note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6631"},"text":"section 6631 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
