title","children":[],"tail":", was renumbered section 516 of act "},{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", by "},{"tag":"ref","attrib":{"href":"/us/pl/102/321"},"text":"Pub. L. 102–321","children":[],"tail":" and transferred to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s290bb–22"},"text":"section 290bb–22 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb5a36b52-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s1212/1"},"text":"Pub. L. 117–328, § 1212(1)","children":[],"tail":", substituted “use disorder” for “abuse” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s1212/2"},"text":"Pub. L. 117–328, § 1212(2)","children":[],"tail":", substituted “Tribes and Tribal organizations (as such terms are defined” for “tribes and tribal organizations (as the terms ‘Indian tribes’ and ‘tribal organizations’ are defined” and “in substance use disorders” for “in substance abuse”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s1212/3"},"text":"Pub. L. 117–328, § 1212(3)","children":[],"tail":", substituted “use disorder” for “abuse” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s1212/4"},"text":"Pub. L. 117–328, § 1212(4)","children":[],"tail":", substituted “$521,517,000 for each of fiscal years 2023 through 2027” for “$333,806,000 for each of fiscal years 2018 through 2022”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255/s7004/1/A"},"text":"Pub. L. 114–255, § 7004(1)(A)","children":[],"tail":", (C), in introductory provisions, substituted “use disorder” for “abuse” and, in concluding provisions, inserted “, contracts,” before “or cooperative agreements” and substituted “Indian tribes or tribal organizations (as such terms are defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304"},"text":"section 5304 of title 25","children":[],"tail":"), health facilities, or programs operated by or in accordance with a contract or grant with the Indian Health Service, or” for “Indian tribes and tribal organizations,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255/s7004/1/B"},"text":"Pub. L. 114–255, § 7004(1)(B)","children":[],"tail":", inserted before period at end “that permit States, local governments, communities, and Indian tribes and tribal organizations (as the terms ‘Indian tribes’ and ‘tribal organizations’ are defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304"},"text":"section 5304 of title 25","children":[],"tail":") to focus on emerging trends in substance abuse and co-occurrence of substance use disorders with mental illness or other conditions”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255/s7004/2"},"text":"Pub. L. 114–255, § 7004(2)","children":[],"tail":", substituted “use disorder” for “abuse” in pars. (1) and (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255/s7004/3"},"text":"Pub. L. 114–255, § 7004(3)","children":[],"tail":", substituted “use disorder” for “abuse”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255/s7004/4"},"text":"Pub. L. 114–255, § 7004(4)","children":[],"tail":", substituted “$333,806,000 for each of fiscal years 2018 through 2022.” for “$300,000,000 for fiscal year 2001 and such sums as may be necessary for each of the fiscal years 2002 and 2003.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/310"},"text":"Pub. L. 106–310","children":[],"tail":" amended section catchline and text generally, substituting provisions relating to priority substance abuse treatment needs of regional and national significance for provisions relating to outpatient treatment programs for pregnant and postpartum women."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb5a36b53-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb5a36b54-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1992-10-01"},"text":"Oct. 1, 1992","children":[],"tail":", with provision for programs providing financial assistance, see section 801(c), (d) of "},{"tag":"ref","attrib":{"href":"/us/pl/102/321"},"text":"Pub. L. 102–321","children":[],"tail":", set out as an Effective Date of 1992 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s236"},"text":"section 236 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
