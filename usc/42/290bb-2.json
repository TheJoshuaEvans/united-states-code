{"tag":"section","attrib":{"id":"idb5a36b3e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"290bb–2"},"text":"§ 290bb–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority substance use disorder treatment needs of regional and national significance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5a36b3f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–2/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Projects","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall address priority substance use disorder treatment needs of regional and national significance (as determined under subsection (b)) through the provision of or through assistance for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5a36b40-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–2/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" knowledge development and application projects for treatment and rehabilitation and the conduct or support of evaluations of such projects;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5a36b41-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–2/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" training and technical assistance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5a36b42-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–2/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" targeted capacity response programs that permit States, local governments, communities, and Indian Tribes and Tribal organizations (as such terms are defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304"},"text":"section 5304 of title 25","children":[],"tail":") to focus on emerging trends in substance use disorders and co-occurrence of substance use disorders with mental illness or other conditions."}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The Secretary may carry out the activities described in this section directly or through grants, contracts, or cooperative agreements with States, political subdivisions of States, Indian tribes or tribal organizations (as such terms are defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304"},"text":"section 5304 of title 25","children":[],"tail":"), health facilities, or programs operated by or in accordance with a contract or grant with the Indian Health Service, or other public or nonprofit private entities."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5a36b43-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–2/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority substance use disorder treatment needs","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5a36b44-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–2/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Priority substance use disorder treatment needs of regional and national significance shall be determined by the Secretary after consultation with States and other interested groups. The Secretary shall meet with the States and interested groups on an annual basis to discuss program priorities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5a36b45-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–2/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special consideration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In developing program priorities under paragraph (1), the Secretary shall give special consideration to promoting the integration of substance use disorder treatment services into primary health care systems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5a36b46-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–2/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5a36b47-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–2/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Recipients of grants, contracts, or cooperative agreements under this section shall comply with information and application requirements determined appropriate by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5a36b48-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–2/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration of award","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to a grant, contract, or cooperative agreement awarded under this section, the period during which payments under such award are made to the recipient may not exceed 5 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5a36b49-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–2/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matching funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may, for projects carried out under subsection (a), require that entities that apply for grants, contracts, or cooperative agreements under that project provide non-Federal matching funds, as determined appropriate by the Secretary, to ensure the institutional commitment of the entity to the projects funded under the grant, contract, or cooperative agreement. Such non-Federal matching funds may be provided directly or through donations from public or private entities and may be in cash or in kind, fairly evaluated, including plant, equipment, or services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5a36b4a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–2/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maintenance of effort","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to activities for which a grant, contract, or cooperative agreement is awarded under this section, the Secretary may require that recipients for specific projects under subsection (a) agree to maintain expenditures of non-Federal amounts for such activities at a level that is not less than the level of such expenditures maintained by the entity for the fiscal year preceding the fiscal year for which the entity receives such a grant, contract, or cooperative agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5a36b4b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–2/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall evaluate each project carried out under subsection (a)(1) and shall disseminate the findings with respect to each such evaluation to appropriate public and private entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5a36b4c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–2/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information and education","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish comprehensive information and education programs to disseminate and apply the findings of the knowledge development and application, training and technical assistance programs, and targeted capacity response programs under this section to the general public, to health professionals and other interested groups. The Secretary shall make every effort to provide linkages between the findings of supported projects and State agencies responsible for carrying out substance use disorder prevention and treatment programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5a36b4d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–2/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this section, $521,517,000 for each of fiscal years 2023 through 2027.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5a36b4e-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title V, § 509, as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/321/tI/s108/a"},"text":"Pub. L. 102–321, title I, § 108(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-10"},"text":"July 10, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/341"},"text":"106 Stat. 341","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/310/dB/tXXXIII/s3301/b"},"text":"Pub. L. 106–310, div. B, title XXXIII, § 3301(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-17"},"text":"Oct. 17, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1207"},"text":"114 Stat. 1207","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/255/dB/tVII/s7004"},"text":"Pub. L. 114–255, div. B, title VII, § 7004","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-13"},"text":"Dec. 13, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1223"},"text":"130 Stat. 1223","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dFF/tI/s1212"},"text":"Pub. L. 117–328, div. FF, title I, § 1212","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5661"},"text":"136 Stat. 5661","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb5a36b4f-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb5a36b50-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb5a36b51-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 290bb–2, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373/tV/s513"},"text":"act July 1, 1944, ch. 373, title V, § 513","children":[],"tail":", formerly § 512, formerly "},{"tag":"ref","attrib":{"href":"/us/pl/91/616/tV/s504"},"text":"Pub. L. 91–616, title V, § 504","children":[],"tail":", formerly § 503, as added "},{"tag":"ref","attrib":{"href":"/us/pl/94/371/s7"},"text":"Pub. L. 94–371, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-07-26"},"text":"July 26, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1039"},"text":"90 Stat. 1039","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/96/180/s15"},"text":"Pub. L. 96–180, § 15","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-01-02"},"text":"Jan. 2, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/1305"},"text":"93 Stat. 1305","children":[],"tail":"; renumbered "},{"tag":"ref","attrib":{"href":"/us/pl/91/616/s504"},"text":"§ 504 of Pub. L. 91–616","children":[],"tail":" and amended "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tIX/s965/a"},"text":"Pub. L. 97–35, title IX, § 965(a)","children":[],"tail":", (c), "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","child