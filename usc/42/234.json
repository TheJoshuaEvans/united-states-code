{"tag":"section","attrib":{"id":"idb47b8d23-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s234"},"text":null,"children":[{"tag":"num","attrib":{"value":"234"},"text":"§ 234.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Health care professionals assisting during a public health emergency","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb47b8d24-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s234/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on liability","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of law, a health care professional who is a member of the Medical Reserve Corps under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300hh–15"},"text":"section 300hh–15 of this title","children":[],"tail":" or who is included in the Emergency System for Advance Registration of Volunteer Health Professionals under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s247d–7b"},"text":"section 247d–7b of this title","children":[],"tail":" and who—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb47b8d25-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s234/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is responding—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb47b8d26-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s234/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to a public health emergency determined under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s247d/a"},"text":"section 247d(a) of this title","children":[],"tail":", during the initial period of not more than 90 days (as determined by the Secretary) of the public health emergency determination (excluding any period covered by a renewal of such determination); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb47b8d27-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s234/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to a major disaster or an emergency as declared by the President under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5170"},"text":"section 5170 of this title","children":[],"tail":" or under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1621"},"text":"section 1621 of title 50","children":[],"tail":" during the initial period of such declaration;"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb47b8d28-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s234/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is alleged to be liable for an act or omission—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb47b8d29-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s234/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" during the initial period of a determination or declaration described in paragraph (1) and related to the treatment of individuals in need of health care services due to such public health emergency, major disaster, or emergency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb47b8d2a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s234/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the State or States for which such determination or declaration is made;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb47b8d2b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s234/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the health care professional’s capacity as a member of the Medical Reserve Corps or a professional included in the Emergency System for Advance Registration of Volunteer Health Professionals under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s247d–7b"},"text":"section 247d–7b of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb47b8d2c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s234/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the course of providing services that are within the scope of the license, registration, or certification of the professional, as defined by the State of licensure, registration, or certification; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb47b8d2d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s234/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prior to the rendering of such act or omission, was authorized by the State’s authorization of deploying such State’s Emergency System for Advance Registration of Volunteer Health Professionals described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s247d–7b"},"text":"section 247d–7b of this title","children":[],"tail":" or the Medical Reserve Corps established under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300hh–15"},"text":"section 300hh–15 of this title","children":[],"tail":", to provide health care services,"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be subject only to the State liability laws of the State in which such act or omission occurred, in the same manner and to the same extent as a similar health care professional who is a resident of such State would be subject to such State laws, except with respect to the licensure, registration, and certification of such individual.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb47b8d2e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s234/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Volunteer Protection Act","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed to affect an individual’s right to protections under the Volunteer Protection Act of 1997 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s14501"},"text":"42 U.S.C. 14501","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb47b8d2f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s234/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preemption","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall supersede the laws of any State that would subject a health care professional described in subsection (a) to the liability laws of any State other than the State liability laws to which such individual is subject pursuant to such subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb47b8d30-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s234/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb47b8d31-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s234/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “health care professional” means an individual licensed, registered, or certified under Federal or State laws or regulations to provide health care services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb47b8d32-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s234/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “health care services” means any services provided by a health care professional, or by any individual working under the supervision of a health care professional, that relate to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb47b8d33-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s234/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the diagnosis, prevention, or treatment of any human disease or impairment; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb47b8d34-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s234/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the assessment or care of the health of human beings.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb47b8d35-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s234/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb47b8d36-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s234/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall take effect 90 days after ","children":[{"tag":"date","attrib":{"date":"2019-06-24"},"text":"June 24, 2019","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb47b8d37-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s234/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall apply to a claim for harm only if the act or omission that caused such harm occurred on or after the effective date described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb47b8d38-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title II, § 225, as added "},{"tag":"ref","attrib":{"href":"/us/pl/116/22/tII/s208/a"},"text":"Pub. L. 116–22, title II, § 208(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-06-24"},"text":"June 24, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/927"},"text":"133 Stat. 927","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb47b8d39-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb47b8d3a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb47b8d3b-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Volunteer Protection Act of 1997, referred to in subsec. (b), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/19"},"text":"Pub. L. 105–19","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-06-18"},"text":"June 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/218"},"text":"111 Stat. 218","children":[],"tail":", which is classified generally to chapter 139 (§ 14501 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s14501"},"text":"section 14501 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb47b8d3c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A former section 234, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373/tII/s225"},"text":"act July 1, 1944, ch. 373, title II, § 225","children":[],"tail":", as added "},{"tag":"date","attrib":{"date":"1972-10-27"},"text":"Oct. 27, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/92/585/s5"},"text":"Pub. L. 92–585, § 5","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1293"},"text":"86 Stat. 1293","children":[],"tail":"; amended "},{"tag":"date","attrib":{"date":"1974-08-23"},"text":"Aug. 23, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/93/385/s1"},"text":"Pub. L. 93–385, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/741"},"text":"88 Stat. 741","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1976-04-22"},"text":"Apr. 22, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/94/278/tIX/s901"},"text":"Pub. L. 94–278, title IX, § 901","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/415"},"text":"90 Stat. 415","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1976-09-30"},"text":"Sept. 30, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/94/437/tI/s104"},"text":"Pub. L. 94–437, title I, § 104","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1403"},"text":"90 Stat. 1403","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1976-10-12"},"text":"Oct. 12, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/94/484/tI/s101/t"},"text":"Pub. L. 94–484, title I, § 101(t)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2246"},"text":"90 Stat. 2246","children":[],"tail":", related to Public Health and National Health Service Corps Scholarship Training program, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/94/484/tIV/s408/b/1"},"text":"Pub. L. 94–484, title IV, § 408(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-12"},"text":"Oct. 12, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2281"},"text":"90 Stat. 2281","children":[],"tail":", effective "},{"tag":"date","attrib":{"date":"1977-10-01"},"text":"Oct. 1, 1977","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb47b8d3d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb47b8d3e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Limitation on Liability for Volunteer Health Care Professionals During COVID–19 Emergency Response","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/136/dA/tIII/s3215"},"text":"Pub. L. 116–136, div. A, title III, § 3215","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-03-27"},"text":"Mar. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/374"},"text":"134 Stat. 374","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/136/dA/tIII/s3215"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on Liability","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subsection (b), a health care professional shall not be liable under Federal or State law for any harm caused by an act or omission of the professional in the provision of health care services during the public health emergency with respect to COVID–19 declared by the Secretary of Health and Human Services (referred to in this section as the ‘Secretary’) under section 319 of the Public Health Service Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s247d"},"text":"42 U.S.C. 247d","children":[],"tail":") on "},{"tag":"date","attrib":{"date":"2020-01-31"},"text":"January 31, 2020","children":[],"tail":", if—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the professional is providing health care services in response to such public health emergency, as a volunteer; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the act or omission occurs—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the course of providing health care services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the health care professional’s capacity as a volunteer;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the course of providing health care services that—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are within the scope of the license, registration, or certification of the volunteer, as defined by the State of licensure, registration, or certification; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" do not exceed the scope of license, registration, or certification of a substantially similar health professional in the State in which such act or omission occurs; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"“(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in a good faith belief that the individual being treated is in need of health care services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exceptions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsection (a) does not apply if—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the harm was caused by an act or omission constituting willful or criminal misconduct, gross negligence, reckless misconduct, or a conscious flagrant indifference to the rights or safety of the individual harmed by the health care professional; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the health care professional rendered the health care services under the influence (as determined pursuant to applicable State law) of alcohol or an intoxicating drug.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Preemption.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section preempts the laws of a State or any political subdivision of a State to the extent that such laws are inconsistent with this section, unless such laws provide greater protection from liability.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Volunteer protection act","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Protections afforded by this section are in addition to those provided by the Volunteer Protection Act of 1997 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/19"},"text":"Public Law 105–19","children":[],"tail":") ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s14501"},"text":"42 U.S.C. 14501","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term ‘harm’ includes physical, nonphysical, economic, and noneconomic losses;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term ‘health care professional’ means an individual who is licensed, registered, or certified under Federal or State law to provide health care services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term ‘health care services’ means any services provided by a health care professional, or by any individual working under the supervision of a health care professional that relate to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the diagnosis, prevention, or treatment of COVID–19; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the assessment or care of the health of a human being related to an actual or suspected case of COVID–19; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term ‘volunteer’ means a health care professional who, with respect to the health care services rendered, does not receive compensation or any other thing of value in lieu of compensation, which compensation—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes a payment under any insurance policy or health plan, or under any Federal or State health benefits program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" excludes—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" receipt of items to be used exclusively for rendering health care services in the health care professional’s capacity as a volunteer described in subsection (a)(1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any reimbursement for travel to the site where the volunteer services are rendered and any payments in cash or kind to cover room and board, if services are being rendered more than 75 miles from the volunteer’s principal place of residence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"“(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effective Date","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section shall take effect upon the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2020-03-27"},"text":"Mar. 27, 2020","children":[],"tail":"], and applies to a claim for harm only if the act or omission that caused such harm occurred on or after the date of enactment."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"“(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sunset","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section shall be in effect only for the length of the public health emergency declared by the Secretary of Health and Human Services (referred to in this section as the ‘Secretary’) under section 319 of the Public Health Service Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s247d"},"text":"42 U.S.C. 247d","children":[],"tail":") on "},{"tag":"date","attrib":{"date":"2020-01-31"},"text":"January 31, 2020","children":[],"tail":" with respect to COVID–19.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
