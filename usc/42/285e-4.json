{"tag":"section","attrib":{"id":"idb5713833-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285e–4"},"text":null,"children":[{"tag":"num","attrib":{"value":"285e–4"},"text":"§ 285e–4.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Awards for leadership and excellence in Alzheimer’s disease and related dementias","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5713834-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285e–4/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Senior researchers in biomedical research","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the Institute shall make awards to senior researchers who have made distinguished achievements in biomedical research in areas relating to Alzheimer’s disease and related dementias. Awards under this section shall be used by the recipients to support research in areas relating to such disease and dementias, and may be used by the recipients to train junior researchers who demonstrate exceptional promise to conduct research in such areas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5713835-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285e–4/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible centers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the Institute may make awards under this section to researchers at centers supported under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s285e–2"},"text":"section 285e–2 of this title","children":[],"tail":" and to researchers at other public and nonprofit private entities."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5713836-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285e–4/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required recommendation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the Institute shall make awards under this section only to researchers who have been recommended for such awards by the National Advisory Council on Aging.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5713837-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285e–4/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection procedures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the Institute shall establish procedures for the selection of the recipients of awards under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5713838-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285e–4/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term of award; renewal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Awards under this section shall be made for a one-year period, and may be renewed for not more than six additional consecutive one-year periods.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5713839-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title IV, § 445B, formerly "},{"tag":"ref","attrib":{"href":"/us/pl/99/660/tIX/s931"},"text":"Pub. L. 99–660, title IX, § 931","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3807"},"text":"100 Stat. 3807","children":[],"tail":"; renumbered § 445B of act "},{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", and amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/607/tI/s142/a"},"text":"Pub. L. 100–607, title I, § 142(a)","children":[],"tail":", (d)(1), "},{"tag":"date","attrib":{"date":"1988-11-04"},"text":"Nov. 4, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3057"},"text":"102 Stat. 3057","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb571383a-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb571383b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb571383c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11231"},"text":"section 11231 of this title","children":[],"tail":" prior to renumbering by "},{"tag":"ref","attrib":{"href":"/us/pl/100/607"},"text":"Pub. L. 100–607","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb571383d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/607/s142/a"},"text":"Pub. L. 100–607, § 142(a)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s11231"},"text":"section 11231 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/607/s142/d/1/A"},"text":"Pub. L. 100–607, § 142(d)(1)(A)","children":[],"tail":", substituted “the Institute” for “the National Institute on Aging”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/607/s142/d/1/B"},"text":"Pub. L. 100–607, § 142(d)(1)(B)","children":[],"tail":", substituted “the Institute” for “the National Institute on Aging” and made technical amendment to reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s285e–2"},"text":"section 285e–2 of this title","children":[],"tail":" to correct reference to corresponding provision of original act."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/607/s142/d/1/C"},"text":"Pub. L. 100–607, § 142(d)(1)(C)","children":[],"tail":", substituted “the Institute” for “the National Institute on Aging”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb571383e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb571383f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Availability of Appropriations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/607/tI/s142/b"},"text":"Pub. L. 100–607, title I, § 142(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-04"},"text":"Nov. 4, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3057"},"text":"102 Stat. 3057","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/607/tI/s142/b"},"text":"“With respect to amounts made available in appropriation Acts for the purpose of carrying out the programs transferred by subsection (a) to the Public Health Service Act [sections 285e–4 to 285e–8 of this title], such subsection may not be construed to affect the availability of such funds for such purpose.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
